  schema:description """conjunction 'while' that triggers word order 3 (WO3), sending the verb to
  the end of the clause or sentence"""@en ;
  dcterms:modified "2026-06-07T15:30:02.427616Z"^^xsd:dateTime .

oakcurric:keyword-frequency-adverb
  a curric:Keyword ;
  schema:name "frequency adverb"@en ;
  schema:description "describes how often something happens"@en ;
  dcterms:modified "2026-06-07T15:30:02.427705Z"^^xsd:dateTime .

oakcurric:keyword-ich-bin
  a curric:Keyword ;
  schema:name "ich bin"@en ;
  schema:description "I am"@en ;
  dcterms:modified "2026-06-07T15:30:02.427844Z"^^xsd:dateTime .

oakcurric:keyword-du-bist
  a curric:Keyword ;
  schema:name "du bist"@en ;
  schema:description "you are"@en ;
  dcterms:modified "2026-06-07T15:30:02.427849Z"^^xsd:dateTime .

oakcurric:keyword-kein-keine
  a curric:Keyword ;
  schema:name "kein, keine"@en ;
  schema:description "forms of 'no' or 'not a' used with nouns"@en ;
  dcterms:modified "2026-06-07T15:30:02.427854Z"^^xsd:dateTime .

oakcurric:keyword-final-e
  a curric:Keyword ;
  schema:name "final [e]"@en ;
  schema:description "pronounced as in 'Liebe'"@en ;
  dcterms:modified "2026-06-07T15:30:02.428558Z"^^xsd:dateTime .

oakcurric:keyword-final-er
  a curric:Keyword ;
  schema:name "final [er]"@en ;
  schema:description "pronounced as in 'lieber'"@en ;
  dcterms:modified "2026-06-07T15:30:02.428565Z"^^xsd:dateTime .

oakcurric:keyword-plural-rule-five
  a curric:Keyword ;
  schema:name "plural rule five"@en ;
  schema:description """add '–s'; these words are typically borrowed from other languages and may
  end in –a, -i,-o,-u-or –y"""@en ;
  dcterms:modified "2026-06-07T15:30:02.428571Z"^^xsd:dateTime .

# ----------------------------------------------------------------------
# Misconceptions
# ----------------------------------------------------------------------

oakcurric:misconception-verb-strong-its-past-participle
  a curric:Misconception ;
  curric:statement "If a verb is 'strong', its past participle always has a vowel change."@en ;
  curric:correction """In German, a strong verb has a stem change in one or more tenses. Some strong
  verbs have a stem change in the present tense but not in the perfect tense, e.g., 'sehen'
  - 'er, sie, es sieht' - 'hat gesehen'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.084153Z"^^xsd:dateTime .

oakcurric:misconception-talking-travel-went-given-order
  a curric:Misconception ;
  curric:statement """When talking about travel, where and how you went can be given in any order,
  as is the case in English."""@en ;
  curric:correction """When using adverbs to say where and how you went in the same sentence, manner
  (how) always comes before place (where)."""@en ;
  dcterms:modified "2026-06-07T15:30:15.084518Z"^^xsd:dateTime .

oakcurric:misconception-grammatical-gender-same-biological-gender
  a curric:Misconception ;
  curric:statement """Grammatical gender is the same as biological gender. If a word is feminine we
  think of it as a girl if it is masculine we think of it as a boy."""@en ;
  curric:correction """Grammatical gender is not the same as biological gender. Spelling clues help
  to identify Spanish grammatical gender: nouns ending in -o are usually masculine, nouns
  ending in -a are usually feminine."""@en ;
  dcterms:modified "2026-06-07T15:30:15.084676Z"^^xsd:dateTime .

oakcurric:misconception-german-pronoun-singular-informal-du
  a curric:Misconception ;
  curric:statement "The German pronoun for singular informal 'you' is always 'du'."@en ;
  curric:correction """German uses 'du' as subject pronoun, 'dich' as direct object pronoun, and
  'dir' as indirect object pronoun. There are also two object pronouns for 'me'. E.g., 'Du
  fragst mich.' ('You ask me.'), 'Du antwortest mir.' ('You answer me'.)."""@en ;
  dcterms:modified "2026-06-07T15:30:15.084799Z"^^xsd:dateTime .

oakcurric:misconception-need-know-gender-noun-choose
  a curric:Misconception ;
  curric:statement """I only need to know the gender of the noun to choose the right spelling for
  the possessive adjective."""@en ;
  curric:correction """Possessive adjectives change spelling to match the gender of the noun, but
  they also change to match the required case. Verbs and prepositions affect the case that
  is needed for possessive adjectives."""@en ;
  dcterms:modified "2026-06-07T15:30:15.084900Z"^^xsd:dateTime .

oakcurric:misconception-want-say-her-german-word
  a curric:Misconception ;
  curric:statement "If we want to say 'her' in German, the word is always 'ihr'."@en ;
  curric:correction """After many verbs, the word for 'her' is 'sie'; same as the word for 'she',
  e.g., 'ich frage sie'. The word 'ihr' means 'her' after a dative verb, e.g., 'ich antworte
  ihr'. 'Ihr' is also the possessive adjective 'her', e.g., 'ihr Lieblingsgeschenk'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.084910Z"^^xsd:dateTime .

oakcurric:misconception-words-stick-my-memory-read
  a curric:Misconception ;
  curric:statement "Words will stick in my memory if I read them enough times."@en ;
  curric:correction """It is the act of reaching for words that roots them deeper in memory, so
  testing oneself or working in pairs to try to recall words from memory is the most
  effective learning strategy for holding on to words in your long term memory."""@en ;
  dcterms:modified "2026-06-07T15:30:15.084916Z"^^xsd:dateTime .

oakcurric:misconception-past-participles-formed-same-way
  a curric:Misconception ;
  curric:statement "All past participles are formed in the same way."@en ;
  curric:correction """Regular -er verb past participles are formed by changing the -er at the end
  of the infinitive to é but there are other past participle patterns such as verbs like
  prendre changing to 'pris' and some irregular past participles."""@en ;
  dcterms:modified "2026-06-07T15:30:15.084921Z"^^xsd:dateTime .

oakcurric:misconception-translate-english-present-continuous-form
  a curric:Misconception ;
  curric:statement """You translate the English present continuous with a form of 'sein', e.g., 'Ich
  bin machen ...'."""@en ;
  curric:correction """There is only one present tense in German. 'Ich mache' means 'I do' and 'I am
  doing'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.085485Z"^^xsd:dateTime .

oakcurric:misconception-gefallen-means-like-works-like
  a curric:Misconception ;
  curric:statement """'Gefallen' means ‘to like’ and works like a normal verb where I am the subject
  that does the action of ‘liking’."""@en ;
  curric:correction """'Gefallen' means ‘to please’, so works differently. You are not doing the
  ‘liking’, the thing you like is ‘pleasing’ you. E.g., 'das Kleid gefällt mir' - literally,
  'the dress pleases me'. More naturally translated - 'I like the dress'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.085706Z"^^xsd:dateTime .

oakcurric:misconception-nicht-used-make-negative-statements
  a curric:Misconception ;
  curric:statement "'Nicht' is always used to make negative statements in German."@en ;
  curric:correction """There are two ways of making negative statements: 'nicht' and 'kein'. It is
  not always obvious when 'kein' should be used to translate negative English statements,
  e.g., 'I don't have a car' is 'ich habe kein Auto'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.085711Z"^^xsd:dateTime .

oakcurric:misconception-terms-weak-verb-strong-verb
  a curric:Misconception ;
  curric:statement """The terms 'weak verb' and 'strong verb' refer to whether the action is
  powerful or not."""@en ;
  curric:correction """The term 'weak verb' is used to describe verbs that follow a regular pattern
  across all tenses. The term 'strong verb' describes verbs that have a stem change in
  either present or past tenses."""@en ;
  dcterms:modified "2026-06-07T15:30:15.085717Z"^^xsd:dateTime .

oakcurric:misconception-german-uhr-means-hour
  a curric:Misconception ;
  curric:statement "In German, ‘Uhr’ means ‘hour’."@en ;
  curric:correction """‘Die Uhr’ looks and sounds a bit like ‘hour’ but it means ‘clock’ and ‘um …
  Uhr’ means ‘at … o’clock’. 'Die Stunde' means ‘hour’."""@en ;
  dcterms:modified "2026-06-07T15:30:15.085797Z"^^xsd:dateTime .

oakcurric:misconception-use-du-mean-german
  a curric:Misconception ;
  curric:statement "We always use ‘du’ to mean ‘you’ in German."@en ;
  curric:correction """'Du' is informal 'you'. You should use 'Sie' (formal 'you') when speaking
  with adults that you address by surname. Use 'du' with friends, family, other people you
  know very well and other children."""@en ;
  dcterms:modified "2026-06-07T15:30:15.085919Z"^^xsd:dateTime .

oakcurric:misconception-am-translated-ich-bin-machen
  a curric:Misconception ;
  curric:statement "'I am doing' is translated as 'Ich bin machen'."@en ;
  curric:correction """There is no present continuous ('-ing' form) tense in German, and therefore
  no use of the verb 'sein'. Use a time adverb to express what you are doing right now in
  German, e.g., 'Ich mache jetzt ...'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.086046Z"^^xsd:dateTime .

oakcurric:misconception-past-participles-pattern-ge-stem
  a curric:Misconception ;
  curric:statement """All past participles have the pattern 'ge-' + stem + '-t', e.g.,
  'gemacht'."""@en ;
  curric:correction """While most weak verbs form past participles like this, most strong verbs have
  the pattern ge- + stem + -en, e.g., 'gelesen', some with vowel changes, e.g., 'gesungen'.
  Verbs beginning with be-, er- or ver- don’t add ge-, e.g., 'erlebt', 'verbracht'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.086052Z"^^xsd:dateTime .

oakcurric:misconception-form-questions-prepositions-same-way
  a curric:Misconception ;
  curric:statement """Form questions with prepositions in the same way as in English, by adding a
  preposition at the end, e.g., 'What does he find out about?'."""@en ;
  curric:correction """German doesn't leave prepositions hanging at the end of questions like in
  English. Form questions by placing the prefix 'wo-' or 'wor-' before the preposition at
  the start of the question."""@en ;
  dcterms:modified "2026-06-07T15:30:15.086057Z"^^xsd:dateTime .

oakcurric:misconception-k-kn-silent
  a curric:Misconception ;
  curric:statement "The 'k' in [kn] is silent."@en ;
  curric:correction """Both sounds in [kn] must be pronounced. This is different from English.
  Compare English 'knee' and German 'Knie'. Remember to pronounce the 'k' in German words
  containing [kn]."""@en ;
  dcterms:modified "2026-06-07T15:30:15.086465Z"^^xsd:dateTime .

oakcurric:misconception-names-e-g-alex-pronouns
  a curric:Misconception ;
  curric:statement """Names (e.g., Alex) and pronouns (e.g., 'er') are not interchangeable and need
  different verb endings."""@en ;
  curric:correction "Names and pronouns are interchangeable and use the same verb endings."@en ;
  dcterms:modified "2026-06-07T15:30:15.086591Z"^^xsd:dateTime .

oakcurric:misconception-wer-means-english-because-sounds
  a curric:Misconception ;
  curric:statement "'Wer' means 'where' in English because it sounds the same."@en ;
  curric:correction """'Wer' means 'who' in English. Words that sound identical but have different
  meanings are called false friends and we should be aware of them."""@en ;
  dcterms:modified "2026-06-07T15:30:15.086739Z"^^xsd:dateTime .

oakcurric:misconception-plurals-formed-same-way
  a curric:Misconception ;
  curric:statement "All plurals are formed in the same way."@en ;
  curric:correction """Nouns have different rules for plurals depending on their gender and
  spelling."""@en ;
  dcterms:modified "2026-06-07T15:30:15.086793Z"^^xsd:dateTime .

oakcurric:misconception-stress-placed-first-syllable-german
  a curric:Misconception ;
  curric:statement "Stress is always placed on the first syllable in German words."@en ;
  curric:correction """Most German words place stress on the first syllable, but the 2nd syllable is
  stressed in words beginning with inseparable prefixes. Borrowed words stress the 2nd or
  final syllable."""@en ;
  dcterms:modified "2026-06-07T15:30:15.086849Z"^^xsd:dateTime .

oakcurric:misconception-saying-times-24-hour-format
  a curric:Misconception ;
  curric:statement """Saying times in 24-hour format in German works in exactly the same way as in
  English."""@en ;
  curric:correction """Saying the time in 24-hour format uses numbers like in English. The
  difference is that German needs 'Uhr' - 'o'clock' - between the hour and the minutes,
  e.g., 21:50 is 'einundzwanzig Uhr fünfzig'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087456Z"^^xsd:dateTime .

oakcurric:misconception-infinitives-verbs
  a curric:Misconception ;
  curric:statement "Infinitives are always verbs."@en ;
  curric:correction """Many infinitives can be used as nouns. In German, infinitive nouns start with
  a capital letter, are always neuter, can be used with or without 'das' & are typically
  translated into English with the gerund -ing, e.g., '(das) Schwimmen' - 'swimmming'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087631Z"^^xsd:dateTime .

oakcurric:misconception-spellings-ss-make-different-sounds
  a curric:Misconception ;
  curric:statement "The spellings 'ss' and 'ß' make different sounds."@en ;
  curric:correction """The spellings 'ss' and 'ß' make the same sound, but write 'ss' after a short
  vowel, 'ß' after a long vowel."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087637Z"^^xsd:dateTime .

oakcurric:misconception-haben-weak-verb
  a curric:Misconception ;
  curric:statement "'Haben' is a weak verb."@en ;
  curric:correction """'Haben' is an irregular verb because it does not follow a regular pattern of
  changes in the same way a weak verb does, even if the 'ich', 'wir' and 'sie' (they) forms
  look like weak verbs."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087783Z"^^xsd:dateTime .

oakcurric:misconception-object-pronouns-like-me-him
  a curric:Misconception ;
  curric:statement """Object pronouns like me, him, they are always the same in German, like
  English."""@en ;
  curric:correction """German object pronouns can be direct or indirect; they change their spelling
  depending on the case needed, e.g. direct object pronoun 'dich' - you is accusative;
  indirect object pronoun 'dir' - you is dative. The case is often determined by the verb."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087873Z"^^xsd:dateTime .

oakcurric:misconception-use-indefinite-article-using-sein
  a curric:Misconception ;
  curric:statement """You have to use an indefinite article when using 'sein' and a
  profession noun."""@en ;
  curric:correction """Do not use an indefinite article when using 'sein' and a profession noun,
  e.g., 'Ich bin Sänger'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.088351Z"^^xsd:dateTime .

oakcurric:misconception-greet-german-speakers-use-either
  a curric:Misconception ;
  curric:statement "To greet German speakers, use either ‘hallo’ or ‘guten Tag’."@en ;
  curric:correction """Greetings in German-speaking countries vary depending on time of day,
  country/region and level of formality, e.g., ‘hallo’ in Germany but ‘servus’ in Austria
  and ‘hoi’ in Switzerland."""@en ;
  dcterms:modified "2026-06-07T15:30:15.088453Z"^^xsd:dateTime .

oakcurric:misconception-present-continuous-e-g-translated
  a curric:Misconception ;
  curric:statement """The present continuous, e.g., ‘He is doing’ is translated as ‘Er ist
  machen’."""@en ;
  curric:correction """There is only one present tense in German. ‘Er macht’ = ‘He does / He is
  doing’."""@en ;
  dcterms:modified "2026-06-07T15:30:15.088739Z"^^xsd:dateTime .

oakcurric:misconception-feminine-noun-plurals-same-masculine
  a curric:Misconception ;
  curric:statement "Feminine noun plurals are the same as masculine and neuter noun plurals."@en ;
  curric:correction """Most feminine nouns add either an -e or an -en to the end of the noun in its
  plural form. Feminine nouns ending in -el or -er also add an -n unlike in the masculine
  and neuter form where nouns ending in these letters don't tend to change."""@en ;
  dcterms:modified "2026-06-07T15:30:15.088835Z"^^xsd:dateTime .

oakcurric:misconception-compound-nouns-take-gender-their
  a curric:Misconception ;
  curric:statement "Compound nouns take the gender of their first noun."@en ;
  curric:correction "Compound nouns take the gender of their final noun."@en ;
  dcterms:modified "2026-06-07T15:30:15.088841Z"^^xsd:dateTime .

oakcurric:misconception-mean-period-time-use-vor
  a curric:Misconception ;
  curric:statement "To mean 'for' with a period of time, use 'vor' in German."@en ;
  curric:correction """'Vor' means 'ago', e.g. vor zwei Jahren - two years ago. To mean 'for' with a
  period of time in the present tense, use 'seit'; in the past, add 'lang' after the time
  phrase, but don't use a preposition for 'for'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.089140Z"^^xsd:dateTime .

oakcurric:misconception-prepositions-case-used-depends-whether
  a curric:Misconception ;
  curric:statement """After all prepositions, the case used depends on whether the verb describes
  'location in' or 'movement to'."""@en ;
  curric:correction """Some prepositions always require dative endings regardless of the verb
  meaning; e.g., 'aus, bei, mit, nach, seit, von, zu'; other prepositions are only ever used
  with the accusative, e.g., 'durch, für'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.089321Z"^^xsd:dateTime .

oakcurric:misconception-use-word-nicht-negate-statement
  a curric:Misconception ;
  curric:statement "Always use the word 'nicht' to negate a statement."@en ;
  curric:correction """Use the correct form of 'kein' to translate 'not a/any' with nouns. Use
  'nicht' with verbs and adjectives."""@en ;
  dcterms:modified "2026-06-07T15:30:15.089550Z"^^xsd:dateTime .

oakcurric:misconception-different-forms-german-ich-er
  a curric:Misconception ;
  curric:statement "'Was' and 'had' have different forms in German for 'ich' and 'er, sie'."@en ;
  curric:correction """In German, 'war' means 'was', 'hatte' means 'had'. Both forms remain
  unchanged for 'ich' and 'er, sie', like in English."""@en ;
  dcterms:modified "2026-06-07T15:30:15.089556Z"^^xsd:dateTime .

oakcurric:misconception-perfect-tense-german-translated-done
  a curric:Misconception ;
  curric:statement "The perfect tense in German is often only translated as 'have done'."@en ;
  curric:correction """Give clear examples of both translations 'have done' and 'did' with
  appropriate time adverbials. Emphasise the role of time adverbials in helping to decide on
  the correct English translation."""@en ;
  dcterms:modified "2026-06-07T15:30:15.089781Z"^^xsd:dateTime .

oakcurric:misconception-german-speakers-speak-same-way
  a curric:Misconception ;
  curric:statement """All German-speakers speak the same way. There aren't different accents, unlike
  in the United Kingdom."""@en ;
  curric:correction """There are both different accents and different dialects in Germany, Austria
  and Switzerland. This means there are different ways of saying sounds, and different
  vocabulary. ‘Standard German’ is the version of German taught in schools."""@en ;
  dcterms:modified "2026-06-07T15:30:15.089923Z"^^xsd:dateTime .

oakcurric:misconception-word-required-two-verb-sentences
  a curric:Misconception ;
  curric:statement "A word for 'to' is always required in two-verb sentences in German."@en ;
  curric:correction """'Zu' is needed after verbs like 'hoffen' but after modal verbs and 'werden',
  'zu' is not needed, e.g., 'Ich werde als Arzt arbeiten'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.089928Z"^^xsd:dateTime .

oakcurric:misconception-german-number-billion-means-billion
  a curric:Misconception ;
  curric:statement "The German number ‘Billion’ means billion in English."@en ;
  curric:correction """The German word for 'billion' is ‘Milliarde’; ‘Billion’ in German means
  'trillion' in English."""@en ;
  dcterms:modified "2026-06-07T15:30:15.090153Z"^^xsd:dateTime .

oakcurric:misconception-two-verb-structures-infinitive-use
  a curric:Misconception ;
  curric:statement "All two-verb structures with an infinitive use 'zu' before the infinitive."@en ;
  curric:correction """Some two-verb structures with an infinitive use 'zu' before the verb, but not
  all. It depends on the verb in the sentence; 'zu' is not needed following modal verbs or
  'werden' meaning 'will', but is needed after the structure 'es ist' + adjective."""@en ;
  dcterms:modified "2026-06-07T15:30:15.090167Z"^^xsd:dateTime .

oakcurric:misconception-saying-your-occupation-use-indefinite
  a curric:Misconception ;
  curric:statement "When saying your occupation, use an indefinite article, like in English."@en ;
  curric:correction """In German, when saying what your occupation is or what you would like to
  become, an indefinite article is not needed, e.g., 'Ich möchte in Zukunft Lehrer werden.'
  - 'In the future, I would like to become a teacher.'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.090512Z"^^xsd:dateTime .

oakcurric:misconception-same-plural-rules-apply-nouns
  a curric:Misconception ;
  curric:statement """The same plural rules apply to nouns of all three genders (masculine,
  feminine, neuter)."""@en ;
  curric:correction """There are different rules for different nouns. It often depends on whether
  the noun is masculine, feminine or neuter. It is important to learn the plural noun form
  when learning a new noun."""@en ;
  dcterms:modified "2026-06-07T15:30:15.090557Z"^^xsd:dateTime .

oakcurric:misconception-german-v-pronounced-like-english
  a curric:Misconception ;
  curric:statement "German [v] is always pronounced like English [f]."@en ;
  curric:correction """In many words, German [v] sounds like English [f]. However, in German words
  of foreign origin, [v] usually sounds the same as English [v], e.g., 'Universität',
  'November', 'Aktivität'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.090857Z"^^xsd:dateTime .

oakcurric:misconception-two-words-needed-express-like
  a curric:Misconception ;
  curric:statement "Two words are needed to express 'would like', as in English."@en ;
  curric:correction """'Möcht-' is a form of the verb 'mögen' and is used to mean 'would like'.
  'Möcht-' can be used as part of a 2-verb structure to say what you would like to do. The
  second (infinitive) verb moves to the end of the sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:15.090946Z"^^xsd:dateTime .

oakcurric:misconception-german-words-look-sound-similar
  a curric:Misconception ;
  curric:statement """All German words that look or sound similar to words in English are
  cognates."""@en ;
  curric:correction """Similar looking and sounding words are only cognates if they share the same
  meaning in both languages. When the meaning is different, similar words are called false
  friends."""@en ;
  dcterms:modified "2026-06-07T15:30:15.091029Z"^^xsd:dateTime .

oakcurric:misconception-add-suffix-los-german-noun
  a curric:Misconception ;
  curric:statement "You can add the suffix -los to any German noun to make an adjective."@en ;
  curric:correction """You can't just add -los to any noun to form an adjective. It only works if
  the result makes real sense - usually where there’s a natural English -less equivalent
  (like 'hairless', 'hopeless', 'windowless')."""@en ;
  dcterms:modified "2026-06-07T15:30:15.091265Z"^^xsd:dateTime .

oakcurric:misconception-subject-pronoun-sie-means
  a curric:Misconception ;
  curric:statement "The subject pronoun 'sie' always means 'she'."@en ;
  curric:correction """The subject pronoun 'sie' means 'she' when used with a 3rd person singular
  verb ending or 'they' when used with a 3rd person plural verb ending. If written as 'Sie'
  and is used with a 3rd person plural verb ending, it can mean 'you (formal)'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.091306Z"^^xsd:dateTime .

oakcurric:misconception-cognate-recognition-strategy-need-understand
  a curric:Misconception ;
  curric:statement """Cognate recognition is the only strategy I need to understand texts in
  German."""@en ;
  curric:correction """Cognates are helpful, but not always enough. You will understand much more if
  you know some common word and spelling patterns in German, and if you use your vocabulary
  and grammar knowledge creatively to work out the meanings of unfamiliar words."""@en ;
  dcterms:modified "2026-06-07T15:30:15.091535Z"^^xsd:dateTime .

oakcurric:misconception-one-word-german-our-their
  a curric:Misconception ;
  curric:statement """There is only one word in German for 'our' and 'their', just like in
  English."""@en ;
  curric:correction """Possessive adjectives like 'unser' and 'ihr' change the spelling according to
  the gender of the noun and the case that is needed e.g. 'unser Hund', 'unsere Katze'; 'ihr
  Vater', 'ihre Mutter'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.091552Z"^^xsd:dateTime .

oakcurric:misconception-perfect-tense-german-formed-part
  a curric:Misconception ;
  curric:statement """The perfect tense in German is always formed with a part of 'haben' to express
  what someone has done."""@en ;
  curric:correction """Some verbs require a part of 'sein' to form the perfect tense, often with
  verbs of movement to a destination."""@en ;
  dcterms:modified "2026-06-07T15:30:15.091571Z"^^xsd:dateTime .

oakcurric:misconception-nouns-change-their-plural-form
  a curric:Misconception ;
  curric:statement "All nouns change in their plural form."@en ;
  curric:correction """Different nouns have different rules for forming plurals. It is important to
  learn these and acknowledge that there will always be exceptions to any rule."""@en ;
  dcterms:modified "2026-06-07T15:30:15.092324Z"^^xsd:dateTime .

oakcurric:misconception-german-numbers-21-work-same
  a curric:Misconception ;
  curric:statement """German numbers 21 and above work the same as in English: ten followed
  by unit."""@en ;
  curric:correction """In German, numbers 21 and above are structured unit-und-ten, e.g.,
  'einundzwanzig' - twenty-one. It translates literally as 'one and twenty'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.092329Z"^^xsd:dateTime .

oakcurric:misconception-talk-future-german-use-future
  a curric:Misconception ;
  curric:statement """To talk about the future in German you have to use the future tense with
  'werden'."""@en ;
  curric:correction """In German, you can use the present tense and a future time phrase to talk
  about the future: 'ich spiele nächste Woche Tennis' - 'I'm playing/going to play tennis
  next week'. 'Planen' and 'vorhaben' in the present tense also express future intentions."""@en ;
  dcterms:modified "2026-06-07T15:30:15.092438Z"^^xsd:dateTime .

oakcurric:misconception-possessive-adjectives-match-gender-person
  a curric:Misconception ;
  curric:statement """Possessive adjectives match the gender of the person who possesses the
  noun."""@en ;
  curric:correction """Possessive adjectives match the gender of the noun they describe, not the
  person who possesses it!"""@en ;
  dcterms:modified "2026-06-07T15:30:15.092609Z"^^xsd:dateTime .

oakcurric:misconception-er-sie-mean
  a curric:Misconception ;
  curric:statement "'Er' and 'sie' only mean 'he' and 'she'."@en ;
  curric:correction """Whilst 'er' and 'sie' do mean 'he' and 'she', they are also the masculine and
  neuter words for 'it'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.092936Z"^^xsd:dateTime .

oakcurric:misconception-strong-verbs-vowel-change-parts
  a curric:Misconception ;
  curric:statement "Strong verbs have a vowel change in all parts of the verb."@en ;
  curric:correction """Strong verbs have a vowel change in the 2nd and 3rd person singular forms of
  the verb only (e.g., 'ich werfe', 'du wirfst', 'sie wirft')."""@en ;
  dcterms:modified "2026-06-07T15:30:15.093152Z"^^xsd:dateTime .

oakcurric:misconception-word-needed-forming-questions-german
  a curric:Misconception ;
  curric:statement """A word for 'do', 'does', 'is' or 'are' is needed when forming yes/no questions
  in German."""@en ;
  curric:correction """In German, yes/no questions can be formed simply by inverting the subject and
  the verb. There is no need for a word like 'do' or 'are' at the start, e.g. 'Läufst du
  schnell?' - 'Do you run fast?'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.093160Z"^^xsd:dateTime .

oakcurric:misconception-zu-meaning-needed-part-two
  a curric:Misconception ;
  curric:statement """'Zu', meaning 'to', is always needed as part of two-verb infinitive
  structures, e.g., 'Ich hoffe, mehr in die Schule zu lernen.'."""@en ;
  curric:correction """'Werden' and modal verbs do not need 'zu' before the second verb: 'Ich werde
  mehr in der Schule lernen'. Other verbs that do not require 'zu' include 'helfen',
  'lassen' and 'mögen'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.093305Z"^^xsd:dateTime .

oakcurric:misconception-add-zu-infinitive-two-verb
  a curric:Misconception ;
  curric:statement "Always add 'zu' before the infinitive in two-verb structures."@en ;
  curric:correction """Some verbs, like 'werden' and modal verbs, do not require 'zu' before the
  infinitive in two-verb structures."""@en ;
  dcterms:modified "2026-06-07T15:30:15.093314Z"^^xsd:dateTime .

oakcurric:misconception-verbs-need-en-ending-changed
  a curric:Misconception ;
  curric:statement """All verbs only need the -en ending changed to match the subject in the present
  tense."""@en ;
  curric:correction """Some verbs need a change to the vowel in the stem in addition to the change
  to the -en ending, but only for 'du', 'er' and 'sie' (she)."""@en ;
  dcterms:modified "2026-06-07T15:30:15.093491Z"^^xsd:dateTime .

oakcurric:misconception-adjectives-change-their-spelling-according
  a curric:Misconception ;
  curric:statement """Adjectives only change their spelling according to the gender of the noun they
  describe."""@en ;
  curric:correction """Adjectives change their spelling to match both the gender of the noun and the
  case, e.g., 'das ist ein lustiger Hund', 'ich habe einen lustigen Hund'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.093511Z"^^xsd:dateTime .

oakcurric:misconception-necessary-use-du-saying-german
  a curric:Misconception ;
  curric:statement "It is only necessary to use 'du' when saying 'you' in German."@en ;
  curric:correction """In German, there are four words for you: 'du' for friends or family; 'Sie' in
  formal situations e.g., talking to teachers or strangers; 'ihr' when speaking to several
  friends or family members; 'man' to talk about people in general."""@en ;
  dcterms:modified "2026-06-07T15:30:15.095198Z"^^xsd:dateTime .

oakcurric:misconception-seit-used-continuous-past-like
  a curric:Misconception ;
  curric:statement """'Seit' is always used with the continuous past, like in English, e.g. 'I have
  been learning German since June'."""@en ;
  curric:correction """In German, 'seit' is used with the present tense to say 'for', e.g. 'Ich
  lerne seit vier Jahren Deutsch' - 'I have been learning German for 4 years', as well as
  'since', e.g. 'Ich lerne seit Juni Deutsch' - 'I have been learning German since June'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.095660Z"^^xsd:dateTime .

oakcurric:misconception-cognates-e-g-musik-makes
  a curric:Misconception ;
  curric:statement """In cognates, e.g., ‘Musik’, [i] makes the same sound as in English
  ‘music’."""@en ;
  curric:correction """The [i] sound is short (like English) when followed by 2 consonants, e.g.,
  ‘Film’. Otherwise, it’s a long vowel."""@en ;
  dcterms:modified "2026-06-07T15:30:15.097592Z"^^xsd:dateTime .

oakcurric:misconception-mich-dich-direct-object-pronouns
  a curric:Misconception ;
  curric:statement "'Mich' and 'dich' are only direct object pronouns meaning me and you."@en ;
  curric:correction """'Mich' and 'dich' can also be reflexive pronouns and then mean myself and
  yourself. Reflexive pronouns are required when using a verb reflexively."""@en ;
  dcterms:modified "2026-06-07T15:30:15.098728Z"^^xsd:dateTime .

oakcurric:misconception-using-two-verb-constructions-second
  a curric:Misconception ;
  curric:statement """When using two-verb constructions, the second verb is always in the infinitive
  and comes at the end of the clause."""@en ;
  curric:correction """When a two-verb construction follows a subordinating conjunction like ‘weil’,
  the short form of the verb moves to the end, after the infinitive (WO3), e.g., ‘Ich hoffe,
  dieses Jahr zu feiern, weil es Spaß machen wird.’."""@en ;
  dcterms:modified "2026-06-07T15:30:15.098794Z"^^xsd:dateTime .

oakcurric:misconception-german-ie-pronounced-english-die
  a curric:Misconception ;
  curric:statement "German [ie] is pronounced as in English 'die'."@en ;
  curric:correction "German [ie] is pronounced as in the German 'Liebe'."@en ;
  dcterms:modified "2026-06-07T15:30:15.098825Z"^^xsd:dateTime .

oakcurric:misconception-nicht-goes-verb-like-english
  a curric:Misconception ;
  curric:statement "'Nicht' goes before the verb like 'not' in English."@en ;
  curric:correction """In German, 'nicht' usually goes before the element it negates — unless it's
  negating the whole sentence, in which case it tends to go at the end, e.g., 'Ich kaufe das
  Auto nicht' - 'I'm not buying the car'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.099017Z"^^xsd:dateTime .

oakcurric:misconception-saying-time-half-past-expressed
  a curric:Misconception ;
  curric:statement """When saying the time, 'half past' is expressed the same way in German as in
  English, i.e., half past the current hour."""@en ;
  curric:correction """In German, 'half past' is expressed as half of the next hour, e.g., 'halb
  neun' is half of nine o'clock, or half past eight."""@en ;
  dcterms:modified "2026-06-07T15:30:15.099032Z"^^xsd:dateTime .

oakcurric:misconception-separable-verbs-work-exactly-same
  a curric:Misconception ;
  curric:statement """Separable verbs work exactly the same as all other verbs in the
  present tense."""@en ;
  curric:correction """Separable verbs use the same endings as all other present tense verbs, but in
  most sentences the separable verb prefix moves to the end of the sentence, e.g., 'anrufen'
  - 'ich rufe meinen Freund an'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.099043Z"^^xsd:dateTime .

oakcurric:misconception-give-reason-german-use-denn
  a curric:Misconception ;
  curric:statement """To give a reason in German, we use 'denn' or 'weil' and subject-verb word
  order, as in English."""@en ;
  curric:correction """'Denn' and 'weil' both mean 'because'. After 'denn' we use subject-verb word
  order (word order 1) but after 'weil' the verb goes to the end of the clause (word order
  3)."""@en ;
  dcterms:modified "2026-06-07T15:30:15.099057Z"^^xsd:dateTime .

oakcurric:misconception-giving-time-half-past-hour
  a curric:Misconception ;
  curric:statement """Giving the time as half past the hour works the same in German as it does in
  English, e.g., ‘halb neun’ is 'half past nine'."""@en ;
  curric:correction """In German, half past is expressed as half of the next hour, so 'half past
  nine' is 'halb zehn', or 'half way to ten', the next hour."""@en ;
  dcterms:modified "2026-06-07T15:30:15.101194Z"^^xsd:dateTime .

oakcurric:misconception-proper-nouns-capital-letter
  a curric:Misconception ;
  curric:statement "Only proper nouns have a capital letter."@en ;
  curric:correction """In German, all nouns, regardless of where they are in a sentence, have a
  capital letter."""@en ;
  dcterms:modified "2026-06-07T15:30:15.103556Z"^^xsd:dateTime .

oakcurric:misconception-learning-gender-nouns-important
  a curric:Misconception ;
  curric:statement "Learning the gender of nouns is not important."@en ;
  curric:correction """It is important to learn the gender of nouns so that you can use them
  accurately in sentences."""@en ;
  dcterms:modified "2026-06-07T15:30:15.104005Z"^^xsd:dateTime .

oakcurric:misconception-english-verbs-use-same-prepositions
  a curric:Misconception ;
  curric:statement "English verbs use the same prepositions as in German."@en ;
  curric:correction """German verbs often use different prepositions from those used with English
  verbs; for example 'ich hoffe auf' - 'I'm hoping for' (not 'hoping on')."""@en ;
  dcterms:modified "2026-06-07T15:30:15.105330Z"^^xsd:dateTime .

oakcurric:misconception-use-conversational-language-informal-register
  a curric:Misconception ;
  curric:statement """You can use conversational language (an informal register) whenever you want
  to."""@en ;
  curric:correction """A situation affects the register we use when speaking (i.e., the words we
  use). You use an informal register with friends, but a formal register with a teacher.
  Using formal register in formal situations is important in German-speaking communities."""@en ;
  dcterms:modified "2026-06-07T15:30:15.106558Z"^^xsd:dateTime .

oakcurric:misconception-addressing-questions-someone-use-du
  a curric:Misconception ;
  curric:statement "When addressing questions to someone, I can just use 'du'."@en ;
  curric:correction """Questions often need to be asked using 'Sie', in situations where respect
  should be shown, such as when asking a teacher or an unknown adult."""@en ;
  dcterms:modified "2026-06-07T15:30:15.107228Z"^^xsd:dateTime .

oakcurric:misconception-two-object-nouns-sentence-word
  a curric:Misconception ;
  curric:statement """When two object nouns are in a sentence, the word order is the same as
  English: direct object - indirect object."""@en ;
  curric:correction """When two object nouns are in a sentence, the indirect object (in dative)
  precedes the direct object (in accusative). This is different from English."""@en ;
  dcterms:modified "2026-06-07T15:30:15.107233Z"^^xsd:dateTime .

oakcurric:misconception-talk-past-using-perfect-tense
  a curric:Misconception ;
  curric:statement """To talk about the past using the perfect tense, we always use the present
  tense of ‘haben’ with a past participle."""@en ;
  curric:correction """Some verbs require the present tense of ‘sein’ with a past participle when
  forming the past perfect tense. These are mostly verbs of movement to a destination, e.g.,
  ‘fahren’ to travel, ‘fliegen’ to fly."""@en ;
  dcterms:modified "2026-06-07T15:30:15.107483Z"^^xsd:dateTime .

oakcurric:misconception-grammatical-gender-feminine-nouns-changes
  a curric:Misconception ;
  curric:statement """The grammatical gender of feminine nouns changes to masculine in the dative
  case."""@en ;
  curric:correction """Feminine nouns are always feminine, no matter what case their article may
  change to."""@en ;
  dcterms:modified "2026-06-07T15:30:15.107911Z"^^xsd:dateTime .

oakcurric:misconception-german-verbs-end-en
  a curric:Misconception ;
  curric:statement "All German verbs end in -en."@en ;
  curric:correction """Verbs have different forms (endings) depending on the subject. Long form ends
  in -en and short form ends in -t."""@en ;
  dcterms:modified "2026-06-07T15:30:15.108080Z"^^xsd:dateTime .

oakcurric:misconception-auf-means-onto
  a curric:Misconception ;
  curric:statement "'Auf' always means 'on' or 'onto'."@en ;
  curric:correction """'Auf' sometimes means ‘at’ or ‘to’, especially with events or open
  spaces."""@en ;
  dcterms:modified "2026-06-07T15:30:15.108308Z"^^xsd:dateTime .

oakcurric:misconception-english-one-word
  a curric:Misconception ;
  curric:statement "As in English, there is only one word for 'every'."@en ;
  curric:correction """In German, 'jed-' changes its spelling in the same way as 'der', 'die' and
  'das', to match the gender and case of the noun that follows."""@en ;
  dcterms:modified "2026-06-07T15:30:15.108344Z"^^xsd:dateTime .

oakcurric:misconception-pupils-either-forget-haben-altogether
  a curric:Misconception ;
  curric:statement """Pupils often either forget 'haben' altogether in a sentence or question, or
  forget to change it when talking about different people."""@en ;
  curric:correction """Use cards or physical gestures to demonstrate the elements of the sentence to
  reinforce the core structure, then vary these to demonstrate changing 'haben' to match the
  subject of the sentence, and to demonstrate change in word order in questions."""@en ;
  dcterms:modified "2026-06-07T15:30:15.108401Z"^^xsd:dateTime .

oakcurric:misconception-meaning-german-phrases-taken-literally
  a curric:Misconception ;
  curric:statement "The meaning of all German phrases should be taken literally."@en ;
  curric:correction """Just like English, German contains idioms, phrases that mean something other
  than their literal meaning, e.g., ‘da haben wir den Salat’ - 'we have the salad there',
  which should be understood as 'now we have a problem'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.108488Z"^^xsd:dateTime .

oakcurric:misconception-wer-means
  a curric:Misconception ;
  curric:statement "'Wer?' means 'Where?'."@en ;
  curric:correction """'Wer?' means 'Who?'. A good way to remember its meaning is to think of a
  ‘hoover’: 'Who Wer?'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.108566Z"^^xsd:dateTime .

oakcurric:misconception-adjectives-work-same-way-german
  a curric:Misconception ;
  curric:statement """Adjectives work the same way in German as in English and do not change their
  spelling."""@en ;
  curric:correction """German adjectives change their ending when placed before the noun, depending
  on the case needed, and the gender of the noun they describe."""@en ;
  dcterms:modified "2026-06-07T15:30:15.108859Z"^^xsd:dateTime .

oakcurric:misconception-form-closed-questions-german-adding
  a curric:Misconception ;
  curric:statement """Form closed questions in German by adding 'do you ...' or 'are you ...', as in
  English."""@en ;
  curric:correction """Swap only the position of the subject and verb in a German statement to form
  a closed question."""@en ;
  dcterms:modified "2026-06-07T15:30:15.109261Z"^^xsd:dateTime .

oakcurric:misconception-german-ich-means
  a curric:Misconception ;
  curric:statement "The German 'Ich will' means 'I will'."@en ;
  curric:correction """The German 'will' comes from 'wollen' and means 'want'. Do not confuse this
  with the future tense. 'Ich werde' means 'I will'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.109600Z"^^xsd:dateTime .

oakcurric:misconception-rules-help-learn-verbs-strong
  a curric:Misconception ;
  curric:statement """There are no rules to help you learn which verbs are strong and have a vowel
  change in their stem."""@en ;
  curric:correction "Only verbs with an 'a' or 'e' in their stem can be strong."@en ;
  dcterms:modified "2026-06-07T15:30:15.109606Z"^^xsd:dateTime .

oakcurric:misconception-time-manner-place-rule-means
  a curric:Misconception ;
  curric:statement """The time-manner-place rule means that all sentences must have time before
  manner before place."""@en ;
  curric:correction """German sentences can start with any adverb to emphasise that element. The TMP
  order is then retained for any other adverbs in that sentence. For example, 'Mit dem Zug
  (M) fahren wir morgen (T) nach Liechtenstein (P).'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.109916Z"^^xsd:dateTime .

oakcurric:misconception-vowel-change-2nd-person-singular
  a curric:Misconception ;
  curric:statement """There is no vowel change in the 2nd person singular 'du' present tense forms
  of strong verbs."""@en ;
  curric:correction """The vowel in the stem of strong verbs with an 'a' or 'e' in their stem will
  change in the 2nd person singular 'du' present tense form."""@en ;
  dcterms:modified "2026-06-07T15:30:15.110217Z"^^xsd:dateTime .

oakcurric:misconception-end-word-e-sounds-same
  a curric:Misconception ;
  curric:statement "At the end of a word, [e] sounds the same as short [e]."@en ;
  curric:correction """Final [e] sounds like 'uh', as in 'danke', 'Klasse'. Short [e] sounds more
  like 'eh' as in 'denken'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.110285Z"^^xsd:dateTime .

oakcurric:misconception-two-present-tenses-german-english
  a curric:Misconception ;
  curric:statement "There are two present tenses in German, as in English."@en ;
  curric:correction """There is only one present tense in German. 'Ich lerne' means 'I learn' and 'I
  am learning'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.110422Z"^^xsd:dateTime .

oakcurric:misconception-word-german-wer
  a curric:Misconception ;
  curric:statement "The word for 'who' in German is 'wer'."@en ;
  curric:correction """We use 'wer' to ask or report a question: 'Wer ist das?', 'Ich weiß nicht,
  wer das ist.' But in sentences like 'that is someone, who ...' we use a relative pronoun -
  'der', 'die', 'das' - which matches the gender of noun it refers to."""@en ;
  dcterms:modified "2026-06-07T15:30:15.110430Z"^^xsd:dateTime .

oakcurric:misconception-sie-refer-feminine-used-subject
  a curric:Misconception ;
  curric:statement "'Sie' always refer to feminine 'it' when used as a subject pronoun."@en ;
  curric:correction """'Sie' means 'it' in the feminine form and 'they' in the plural form. 'Sie' is
  used for all plural forms."""@en ;
  dcterms:modified "2026-06-07T15:30:15.110470Z"^^xsd:dateTime .

oakcurric:misconception-gern-verb-meaning-like-liking
  a curric:Misconception ;
  curric:statement """'Gern' is a verb meaning 'to like, liking' and can be used in front of the
  noun in sentence, e.g., 'ich gern Fußball'."""@en ;
  curric:correction """'Gern' is an adverb meaning 'gladly'. It is used to express liking doing an
  action and follows the verb that names the action, e.g., 'ich spiele gern Fußball'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.110556Z"^^xsd:dateTime .

oakcurric:misconception-bilingual-dictionary-lists-words-z
  a curric:Misconception ;
  curric:statement "A bilingual dictionary lists words from A-Z in one long list."@en ;
  curric:correction """A bilingual dictionary is split into two sections. These is German to
  English, and English to German. Each section lists words from A-Z. To find the English
  meaning of a German word, look for it in the German to English section, and vice versa."""@en ;
  dcterms:modified "2026-06-07T15:30:15.110567Z"^^xsd:dateTime .

oakcurric:misconception-use-simple-present-translate-future
  a curric:Misconception ;
  curric:statement """Use the simple present to translate future plans from German into English,
  e.g., 'Nächstes Jahr spiele ich Tennis.' - 'Next year I play tennis.'."""@en ;
  curric:correction """Use the present continuous in English when translating future plans (that are
  expressed in the present tense) from German, e.g., 'Nächstes Jahr spiele ich Tennis.' -
  'Next year I am going to play tennis.'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.110589Z"^^xsd:dateTime .

oakcurric:misconception-german-st-sp-sound-same
  a curric:Misconception ;
  curric:statement """German [st] and [sp] sound the same as in English, wherever they appear in the
  word."""@en ;
  curric:correction """At the start of words, German [sp-] and [st-] are pronounced 'schp-' and
  'scht-'. If [sp] and [st] occur in the middle or end of a word, pronounce them as in
  English, except for compound nouns and separable verbs, which are also 'schp-' and
  'scht-'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.111116Z"^^xsd:dateTime .

oakcurric:misconception-infinitive-follows-conjugated-verb-english
  a curric:Misconception ;
  curric:statement """The infinitive follows the conjugated verb, as in the English 'I can
  play'."""@en ;
  curric:correction """In German, the infinitive is placed at the end of a sentence when used with a
  modal verb, as in 'Ich kann spielen.'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.111353Z"^^xsd:dateTime .

oakcurric:misconception-two-verbs-german-sentence-infinitive
  a curric:Misconception ;
  curric:statement """If there are two verbs in a German sentence, the infinitive stays with the
  subject of the action."""@en ;
  curric:correction """If there are two verbs in a German sentence, the infinitive goes to the end
  of the sentence. This is different word order to English and is called the ‘two-verb
  rule’."""@en ;
  dcterms:modified "2026-06-07T15:30:15.111373Z"^^xsd:dateTime .

oakcurric:misconception-dont-change-possessive-pronoun-used
  a curric:Misconception ;
  curric:statement """Don't change the possessive pronoun used in a question when you give your
  answer."""@en ;
  curric:correction """If a question is addressed to you (i.e., uses a form of 'dein', as in 'Was
  ist dein Lieblingssport?'), respond with the correct form of 'mein' in the answer."""@en ;
  dcterms:modified "2026-06-07T15:30:15.111385Z"^^xsd:dateTime .

oakcurric:misconception-like-english-word-needed-german
  a curric:Misconception ;
  curric:statement """Like in English, a word for 'more' is needed in German when making comparisons
  like 'more difficult' or 'more interesting'."""@en ;
  curric:correction """German adjectives form comparatives by adding -er; there is no need to
  include 'more', e.g., more interesting > 'interessanter'; more difficult >'schwieriger'.
  English does this with 1- and some 2-syllable adjectives, e.g., 'small' > 'smaller'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.111390Z"^^xsd:dateTime .

oakcurric:misconception-use-m-ssen-negative-sentences
  a curric:Misconception ;
  curric:statement """Always use 'müssen' in negative sentences to translate the idea of 'must not'
  in English."""@en ;
  curric:correction """English often uses 'must not' in lieu of 'don't have to', 'not allowed to'
  and 'should not'. However, you should use the correct modal verb in German to express
  these ideas, e.g. 'du musst nicht', 'du darfst nicht', 'du sollst nicht'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.111627Z"^^xsd:dateTime .

oakcurric:misconception-use-same-word-order-english
  a curric:Misconception ;
  curric:statement "Use the same word order as English when using indirect object pronouns."@en ;
  curric:correction """In German, the indirect object pronoun comes straight after the verb, not at
  the end of the sentence. For example, 'Musik ist mir wichtig.' - 'Music is important to
  me.'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.113784Z"^^xsd:dateTime .

oakcurric:misconception-umlauts-make-difference-pronunciation-letter
  a curric:Misconception ;
  curric:statement "Umlauts do not make a difference to the pronunciation of a letter."@en ;
  curric:correction """German vowels (with or without umlauts) can be short or long. Vowels are
  short when followed by more than one consonant. Vowels are long when there is a double
  vowel, followed by 'h', or a single consonant."""@en ;
  dcterms:modified "2026-06-07T15:30:15.118338Z"^^xsd:dateTime .

oakcurric:misconception-word-order-tells-sentence-question
  a curric:Misconception ;
  curric:statement "Word order tells you if a sentence is a question or a statement."@en ;
  curric:correction """Use clues such as intonation and vocabulary meanings to help you decide if a
  sentence is a question or a statement, as the word order in questions is similar to word
  order 2."""@en ;
  dcterms:modified "2026-06-07T15:30:15.119082Z"^^xsd:dateTime .

oakcurric:misconception-closed-questions-german-require-translation
  a curric:Misconception ;
  curric:statement """Closed questions in German require a translation of ‘do you …’ or ‘are you …’,
  as in English."""@en ;
  curric:correction """Swap the position of the verb and the subject to create a closed question in
  German. Do not use translations of ‘do you …’ or ‘are you …’."""@en ;
  dcterms:modified "2026-06-07T15:30:15.123159Z"^^xsd:dateTime .

oakcurric:misconception-v-pronounced-like-english-v
  a curric:Misconception ;
  curric:statement "[v] is pronounced like the English 'v'."@en ;
  curric:correction "[v] is pronounced like an English 'f'. [w] sounds like an English 'v'."@en ;
  dcterms:modified "2026-06-07T15:30:15.124834Z"^^xsd:dateTime .

oakcurric:misconception-separable-prefixes-move-end-clause
  a curric:Misconception ;
  curric:statement "Separable prefixes always move to the end of a clause."@en ;
  curric:correction """Separable verbs have a prefix that goes to the end of the clause in word
  order one clauses (standard word order), but in word order three (verb to end) the prefix
  and the verb reunite. Separable prefixes are always joined to the past participle."""@en ;
  dcterms:modified "2026-06-07T15:30:15.124984Z"^^xsd:dateTime .

oakcurric:misconception-wie-means
  a curric:Misconception ;
  curric:statement "'Wie' always means 'how'."@en ;
  curric:correction """'Wie?' has two meanings: 1. 'How?' (e.g., 'Wie geht's?' - How's it going? /
  How are you?_; 2. 'What?' (e.g., 'Wie ist [der Gast]?' - What is [the guest] like?).
  Encourage pupils to learn both meanings and specific examples."""@en ;
  dcterms:modified "2026-06-07T15:30:15.128337Z"^^xsd:dateTime .

oakcurric:misconception-verb-sentence-tell-us-whether
  a curric:Misconception ;
  curric:statement """It is only the verb in a sentence that can tell us whether the action of the
  verb implies movement towards a destination or a static location."""@en ;
  curric:correction """The case (form of the article 'the' or 'a') used after prepositions 'in' and
  'auf' tells us whether movement or location are implied, e.g., when the article is in the
  accusative case ('in den', 'in die', 'ins') it means 'into' and indicates movement."""@en ;
  dcterms:modified "2026-06-07T15:30:15.129044Z"^^xsd:dateTime .

oakcurric:misconception-sounds-t-th-make-same
  a curric:Misconception ;
  curric:statement """The sounds ‘t’ and [th] make the same sound in English as they do in
  German."""@en ;
  curric:correction """The sounds ‘t’ and [th] sound the same in German. Even though many words with
  these spellings come from English, German pronounces 't' and [th] in the same way."""@en ;
  dcterms:modified "2026-06-07T15:30:15.129536Z"^^xsd:dateTime .

oakcurric:misconception-german-one-general-verb-meaning
  a curric:Misconception ;
  curric:statement "German has one general verb meaning 'to put, putting'."@en ;
  curric:correction """German has 3 placement verbs meaning 'to put'; 'stellen' - to make something
  stand (vertically), 'setzen' - to make something sit, and 'legen' - to make something lay
  down (horizontally). Equivalent position verbs are 'stehen', 'sitzen', 'liegen'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.138155Z"^^xsd:dateTime .

oakcurric:misconception-sound-symbol-correspondence-ie-pronounced
  a curric:Misconception ;
  curric:statement "The sound-symbol correspondence [ie] is always pronounced as in 'Liebe'."@en ;
  curric:correction """When [ie] is the final but unstressed syllable in a word, pronounce [i] and
  [e] as separate vowel sounds, e.g., 'Familie'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.139603Z"^^xsd:dateTime .

oakcurric:misconception-versions-grimm-brothers-fairy-tales
  a curric:Misconception ;
  curric:statement """The only versions of Grimm brothers' fairy tales that exist are written in the
  imperfect tense."""@en ;
  curric:correction """There are many versions of the Grimm brothers' fairy tales. Many are written
  in the imperfect tense but there are also simpler, modern adaptations written in the
  present or perfect tenses, especially in children's books."""@en ;
  dcterms:modified "2026-06-07T15:30:15.139614Z"^^xsd:dateTime .

oakcurric:misconception-wenn-used-question-words-ask
  a curric:Misconception ;
  curric:statement "'Wenn' can be used in question words to ask 'When?'."@en ;
  curric:correction """Use the question word 'Wann?' to ask 'When?' in German. Use 'wenn' to say
  'when' in a present tense statement."""@en ;
  dcterms:modified "2026-06-07T15:30:15.139640Z"^^xsd:dateTime .

oakcurric:misconception-infinitive-comes-directly-form-k
  a curric:Misconception ;
  curric:statement """The infinitive comes directly after the form of 'können', as in English: 'I
  can play guitar'."""@en ;
  curric:correction """The infinitive comes at the end of the sentence in German when used with a
  modal verb such as 'können', as in 'Ich kann Gitarre spielen'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.139692Z"^^xsd:dateTime .

oakcurric:misconception-one-german-pronoun-singular-informal
  a curric:Misconception ;
  curric:statement """There is just one German pronoun for singular informal 'you', as in English,
  e.g., 'you see me, I see you'."""@en ;
  curric:correction """German has two different pronouns in this scenario: 'du' is subject pronoun
  'you', 'dich' is object pronoun 'you', e.g., 'du siehst mich, ich sehe dich'. This is
  similar to the 'I, me' difference in English, which German also shares: 'ich, mich'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.139729Z"^^xsd:dateTime .

oakcurric:misconception-same-verb-endings-added-verb
  a curric:Misconception ;
  curric:statement "The same verb endings can be added to all verb stems."@en ;
  curric:correction """Weak verbs (also known as regular verbs) follow a set pattern of changes to
  verb endings. Strong verbs (also known as irregular verbs) do not follow this pattern."""@en ;
  dcterms:modified "2026-06-07T15:30:15.141205Z"^^xsd:dateTime .

oakcurric:misconception-j-pronounced-same-english-german
  a curric:Misconception ;
  curric:statement "'J' is pronounced the same in both English and German."@en ;
  curric:correction """In German, 'j' is pronounced like 'yot' and sounds like the English 'y'. The
  German letter 'y' is called 'oopsilon'. It sounds like the German 'j' at the start of
  borrowed words, e.g., 'Yoga', but like a short ü 'oo' in others, e.g. 'das System'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.143003Z"^^xsd:dateTime .

oakcurric:misconception-compound-nouns-completely-different-words
  a curric:Misconception ;
  curric:statement """Compound nouns are completely different words that cannot be understood or
  pronounced unless they have been met before."""@en ;
  curric:correction """Compound nouns are made up of two (or more) nouns, one or more of which
  pupils may already know. Knowledge of formation and read aloud can promote recognition as
  can activities where pupils produce compounds from known words."""@en ;
  dcterms:modified "2026-06-07T15:30:15.143734Z"^^xsd:dateTime .

oakcurric:misconception-word-order-2-words-sentence
  a curric:Misconception ;
  curric:statement """In word order 2, all the words in a sentence change position from word order
  1."""@en ;
  curric:correction """The verb remains in the same position in word order 2 as in word order 1. If
  emphasis is on the adverb, the adverb and subject swap position."""@en ;
  dcterms:modified "2026-06-07T15:30:15.147993Z"^^xsd:dateTime .

oakcurric:misconception-viel-viele-interchangeable
  a curric:Misconception ;
  curric:statement "'Viel' and 'viele' are interchangeable."@en ;
  curric:correction """Use 'viel' with uncountable nouns (i.e., you cannot put a number in front of
  it) and use 'viele' with countable nouns (i.e., you can put a number in front of it)."""@en ;
  dcterms:modified "2026-06-07T15:30:15.149606Z"^^xsd:dateTime .

oakcurric:misconception-conjunctions-send-verb-end-clause
  a curric:Misconception ;
  curric:statement "All conjunctions send the verb to the end of the clause."@en ;
  curric:correction """Not all conjunctions send the verb to the end of the clause. For example,
  'und' and 'denn' use word order one (standard word order). They are called co-ordinating
  conjunctions."""@en ;
  dcterms:modified "2026-06-07T15:30:15.150276Z"^^xsd:dateTime .

oakcurric:misconception-understand-single-word-text-order
  a curric:Misconception ;
  curric:statement """I have to understand every single word in a text in order to understand its
  general meaning."""@en ;
  curric:correction """It is difficult to know all of the words in any given language! Use the words
  you do know and other contextual and linguistic clues to help you decipher the meaning of
  unfamiliar vocabulary."""@en ;
  dcterms:modified "2026-06-07T15:30:15.150306Z"^^xsd:dateTime .

oakcurric:misconception-answer-question-why-use-weil
  a curric:Misconception ;
  curric:statement """To answer the question 'why' you have to use 'weil' or 'denn', which mean
  'because'."""@en ;
  curric:correction """The structure 'um ... zu' followed by an infinitive verb means 'in order to'
  and can be used to give a reason or say why something is done. This structure is the same
  for any tense."""@en ;
  dcterms:modified "2026-06-07T15:30:15.150416Z"^^xsd:dateTime .

oakcurric:misconception-verbs-form-their-past-participles
  a curric:Misconception ;
  curric:statement """Verbs form their past participles by sandwiching the verb stem with 'ge-' and
  '-t' or '-en'."""@en ;
  curric:correction """Not all verbs form past participles in the same way. For instance, verbs that
  start with inseparable prefixes or end '-ieren' do not add 'ge-'. Some groups of verbs
  have a vowel change in the stem, e.g., 'finden', 'gefunden'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.150576Z"^^xsd:dateTime .

oakcurric:misconception-one-way-saying-german
  a curric:Misconception ;
  curric:statement "There is only one way of saying 'when' in German."@en ;
  curric:correction """Use 'wenn' to mean 'when' for present or future events. The question word is
  'wann'. The conjunction 'als' means 'when', for a one-off past event. It sends the verb to
  the end of the clause, like 'weil'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.150780Z"^^xsd:dateTime .

oakcurric:misconception-imperfect-tense-german-used-writing
  a curric:Misconception ;
  curric:statement "The imperfect tense in German is only used in writing."@en ;
  curric:correction """Whilst the imperfect is largely used in writing, modal verbs are also used in
  speaking, along with verbs like 'war', 'hatte' and 'gab'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.150996Z"^^xsd:dateTime .

oakcurric:misconception-use-auf-interchangeably-mean-onto
  a curric:Misconception ;
  curric:statement "I can use 'an' and 'auf' interchangeably to mean 'on' or 'onto'."@en ;
  curric:correction """We use 'an' to mean 'on' or 'onto' when the position is vertical, e.g., 'on
  the wall' - 'an der Wand'. We use 'auf' to mean 'on' or 'onto' when the position is
  horizontal, e.g., 'on the table' - 'auf dem Tisch'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.151131Z"^^xsd:dateTime .

oakcurric:misconception-word-order-same-german-english
  a curric:Misconception ;
  curric:statement "Word order is the same in German and English."@en ;
  curric:correction """German sentences containing adverbs have a different word order to
  English."""@en ;
  dcterms:modified "2026-06-07T15:30:15.151389Z"^^xsd:dateTime .

oakcurric:misconception-although-german-words-one-meaning
  a curric:Misconception ;
  curric:statement """Although some German words have more than one meaning, most of them have a
  main meaning and it's not important to know the other meanings."""@en ;
  curric:correction """Some very frequent words have several different meanings, all of them
  commonly used. It is important to know the meanings and to use context to select the right
  meaning. For example, 'vor' can mean 'in front of', 'before' and 'ago'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.151395Z"^^xsd:dateTime .

oakcurric:misconception-sie-means
  a curric:Misconception ;
  curric:statement "'Sie' always means 'she'."@en ;
  curric:correction """As a subject pronoun, 'sie' can mean 'she' or 'they'. As an object pronoun,
  'sie' means 'her' or 'it'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.151816Z"^^xsd:dateTime .

oakcurric:misconception-es-german-word
  a curric:Misconception ;
  curric:statement "'Es' is the only German word for 'it'."@en ;
  curric:correction """Object pronouns such as 'es' tell us the grammatical gender of the object of
  the sentence. German has three words for the object pronoun 'it' - masculine 'ihn',
  feminine 'sie' and neuter 'es'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.151822Z"^^xsd:dateTime .

oakcurric:misconception-arent-patterns-german-nouns-help
  a curric:Misconception ;
  curric:statement """There aren't any patterns in German nouns that help you identify their
  grammatical gender."""@en ;
  curric:correction """There are some suffixes in German nouns that signal the noun is feminine, for
  example '-heit', '-ung', '-in'. There may be some exceptions!"""@en ;
  dcterms:modified "2026-06-07T15:30:15.151827Z"^^xsd:dateTime .

oakcurric:misconception-imperfect-tense-used-written-usually
  a curric:Misconception ;
  curric:statement "The imperfect tense is used in written, but not usually in spoken German."@en ;
  curric:correction """The imperfect tense forms of 'sein', 'haben' and 'es gibt' are widely used in
  spoken German, along with imperfect modal verbs which, combined with a 2nd (infinitive)
  verb, are used to say what you and others wanted, were able or had to do."""@en ;
  dcterms:modified "2026-06-07T15:30:15.151833Z"^^xsd:dateTime .

oakcurric:misconception-r-sound-german-same-regardless
  a curric:Misconception ;
  curric:statement """The [r] sound in German is always the same, regardless of where it appears
  within the word."""@en ;
  curric:correction """German [r] can be pronounced in different ways. [r] is a gentle ‘rolling’
  vibration pronounced from the back of the throat, if [r] is at a syllable start, after a
  consonant or between two vowels. [r] is a gentle ‘ah’ sound after a long vowel."""@en ;
  dcterms:modified "2026-06-07T15:30:15.152439Z"^^xsd:dateTime .

oakcurric:misconception-words-same-prepositions
  a curric:Misconception ;
  curric:statement "The words for 'the' and 'a' are always the same after prepositions."@en ;
  curric:correction """Prepositions take a specific case, e.g., 'durch' always takes the accusative.
  Some prepositions take different cases to create different meanings, e.g., 'in' and 'auf'
  can take the accusative, to show movement to, or the dative, to show location."""@en ;
  dcterms:modified "2026-06-07T15:30:15.152630Z"^^xsd:dateTime .

oakcurric:misconception-2-verb-structures-2nd-infinitive
  a curric:Misconception ;
  curric:statement "In 2-verb structures, the 2nd infinitive verb is always followed by 'zu'."@en ;
  curric:correction """When followed by a 2nd verb in the infinitive, modal verbs and 'werden' never
  take 'zu'. Many other verbs do, for example 'versuchen, etwas zu tun' and 'helfen, etwas
  zu tun'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.154134Z"^^xsd:dateTime .

oakcurric:misconception-speak-pitch-our-voice-rises
  a curric:Misconception ;
  curric:statement """When we speak, the pitch of our voice rises and falls in the same way in
  German and English."""@en ;
  curric:correction """The rise and fall of our voice is similar in German and English sentences,
  but more marked in German and more noticeable with one-syllable words. Note the larger
  fall when saying 'gut' in German compared to 'good' in English."""@en ;
  dcterms:modified "2026-06-07T15:30:15.154146Z"^^xsd:dateTime .

oakcurric:misconception-one-verb-meaning-like-german
  a curric:Misconception ;
  curric:statement "There is one verb meaning 'to like' in German, and that is 'mögen'."@en ;
  curric:correction """'Mögen' is 'to like', e.g., 'ich mag Mathe' ('I like maths'). However,
  'gefallen' is another verb for expressing 'liking'. Its literal meaning is 'to please', so
  it's used with an indirect object, e.g., 'Mathe gefällt mir' - 'I like maths'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.154171Z"^^xsd:dateTime .

oakcurric:misconception-indefinite-article-ein-refers-masculine
  a curric:Misconception ;
  curric:statement "The indefinite article 'ein' always refers to a masculine noun."@en ;
  curric:correction """'Ein' could refer to a masculine or a neuter noun. Learn noun genders and
  look for other clues about a noun's gender. Only masculine nouns use 'einen' after forms
  of 'haben' and most other verbs, except 'sein'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.154177Z"^^xsd:dateTime .

oakcurric:misconception-say-german-use-du
  a curric:Misconception ;
  curric:statement "To say 'you' in German, we just use 'du'."@en ;
  curric:correction """'Du' is 'you' when talking to one person you address by first name. When
  talking to more than one person you know this well, use 'ihr'. The verb ending is -t."""@en ;
  dcterms:modified "2026-06-07T15:30:15.155686Z"^^xsd:dateTime .

oakcurric:misconception-german-one-word
  a curric:Misconception ;
  curric:statement "'You’ in German is just one word."@en ;
  curric:correction """German has four different words for 'you', depending on who you're talking
  to: 'du' – informal, singular; 'ihr' - informal, plural; 'Sie' - formal, singular; 'man' -
  people in general, one."""@en ;
  dcterms:modified "2026-06-07T15:30:15.156953Z"^^xsd:dateTime .

oakcurric:misconception-comparative-form-gern-besser
  a curric:Misconception ;
  curric:statement "The comparative form of 'gern' is 'besser'."@en ;
  curric:correction """The comparative form of 'gern' is 'lieber'. 'Besser' is the comparative form
  of 'gut'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.157685Z"^^xsd:dateTime .

oakcurric:misconception-ei-pronounced-like-english-e
  a curric:Misconception ;
  curric:statement "[ei] is pronounced like the English [e]."@en ;
  curric:correction "[ei] is pronounced as in the key word 'frei' and like the English 'eye'."@en ;
  dcterms:modified "2026-06-07T15:30:15.159226Z"^^xsd:dateTime .

oakcurric:misconception-german-word-order-like-english
  a curric:Misconception ;
  curric:statement "German word order is just like English - it's always subject-verb-object."@en ;
  curric:correction """In English, word order is usually fixed: subject-verb-object, e.g., 'she eats
  an apple'. In German, the word order is more flexible because in main clauses the verb
  must be in second position. Any element can start a German sentence for emphasis."""@en ;
  dcterms:modified "2026-06-07T15:30:15.159468Z"^^xsd:dateTime .

oakcurric:misconception-use-k-nnen-translate-german
  a curric:Misconception ;
  curric:statement "Always use 'können' to translate 'can' into German."@en ;
  curric:correction """'Can' is often used with two different meanings in English - ability or
  permission. Use 'können' to express ability (e.g., 'Kannst du schwimmen?') and 'dürfen' to
  express permission (e.g., 'Darfst du schwimmen?')."""@en ;
  dcterms:modified "2026-06-07T15:30:15.162364Z"^^xsd:dateTime .

oakcurric:misconception-s-pronounced-same-english-s
  a curric:Misconception ;
  curric:statement "[s] is pronounced the same as the English 's'."@en ;
  curric:correction """[s] is pronounced like the English 'z' when it comes before a vowel.
  Elsewhere, both [s] and [ß] are pronounced like the English 's'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.163441Z"^^xsd:dateTime .

oakcurric:misconception-capitalised-letter-b
  a curric:Misconception ;
  curric:statement "[ß] is a capitalised letter 'B'."@en ;
  curric:correction "[ß] is a symbol representing 'ss' and is called 'Eszett' or 'scharfes s'."@en ;
  dcterms:modified "2026-06-07T15:30:15.164159Z"^^xsd:dateTime .

oakcurric:misconception-poetry-descriptive-doesnt-tell-stories
  a curric:Misconception ;
  curric:statement "Poetry is always descriptive and doesn't tell stories."@en ;
  curric:correction """Ballads are poems that tell stories with a sequence of events. They include
  scene-setting, action, change moments and a conclusion. Ballads are also lyrical - they
  use poetic language, imagery, rhythm, rhyme - and dramatic - often with direct speech."""@en ;
  dcterms:modified "2026-06-07T15:30:15.164732Z"^^xsd:dateTime .

oakcurric:misconception-viel-pronounced-like-vile-english
  a curric:Misconception ;
  curric:statement "‘Viel’ is pronounced like ‘vile’ in English."@en ;
  curric:correction """‘Weil’ in German sounds similar to ‘vile’ in English. However, ‘viel’
  contains [v] which sounds like English ‘f’ and [ie] which is like English double ‘ee’."""@en ;
  dcterms:modified "2026-06-07T15:30:15.164739Z"^^xsd:dateTime .

oakcurric:misconception-german-english-word-order-same
  a curric:Misconception ;
  curric:statement "German and English word order are the same."@en ;
  curric:correction """English mostly uses subject-verb word order and time phrases appear most
  naturally at the end of phrases. German word order is much more variable. Any element
  (subject, object, time-manner-location adverb) can start a German sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:15.165096Z"^^xsd:dateTime .

oakcurric:misconception-words-look-same-english-german
  a curric:Misconception ;
  curric:statement """Words which look the same in English and German will have the same
  meaning."""@en ;
  curric:correction """There are many false friends in German. These are words that look exactly the
  same but do not have the same meaning: for example, 'bald' means 'soon'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.165205Z"^^xsd:dateTime .

oakcurric:misconception-prepositions-auf-followed-accusative-case
  a curric:Misconception ;
  curric:statement """The prepositions 'auf' and 'an' are always followed by the accusative
  case."""@en ;
  curric:correction """'Auf' and 'an' are followed by the accusative case when there is movement.
  They are followed by the dative case when a location is being described."""@en ;
  dcterms:modified "2026-06-07T15:30:15.165211Z"^^xsd:dateTime .

oakcurric:misconception-separable-verbs-german-their-word
  a curric:Misconception ;
  curric:statement """All separable verbs in German have their word-for-word English equivalent,
  e.g., 'stattfinden' - 'to take place', 'mitbringen' - to bring with, along'."""@en ;
  curric:correction """Many two-part separable verbs in German have single word English
  translations, e.g., 'einkaufen' - 'to shop', 'anfangen' - 'to start'. It is especially
  important with these verbs not to forget the separable prefix in German."""@en ;
  dcterms:modified "2026-06-07T15:30:15.165217Z"^^xsd:dateTime .

oakcurric:misconception-names-foreign-cities-towns-dont
  a curric:Misconception ;
  curric:statement "Names of foreign cities and towns don't have English equivalents."@en ;
  curric:correction """Some cities around the world (e.g., München) have an English equivalent
  (e.g., Munich)."""@en ;
  dcterms:modified "2026-06-07T15:30:15.165532Z"^^xsd:dateTime .

oakcurric:misconception-use-da-compound-refer-back
  a curric:Misconception ;
  curric:statement """We can use a da-compound to refer back to any object noun already
  mentioned."""@en ;
  curric:correction """We can only use a da-compound to replace inanimate (non-living) nouns. For
  animate objects (people and animals), we use direct or indirect object pronouns to replace
  the noun."""@en ;
  dcterms:modified "2026-06-07T15:30:15.165596Z"^^xsd:dateTime .

oakcurric:misconception-german-numbers-said-same-way
  a curric:Misconception ;
  curric:statement """German numbers are said in the same way as English numbers, i.e., tens then
  units."""@en ;
  curric:correction """The unit is said before the ten in German, e.g., 'neunundvierzig' = '9 and
  40' = 49. It is helpful to write from right to left when taking down numbers so that you
  produce them in the correct order."""@en ;
  dcterms:modified "2026-06-07T15:30:15.165746Z"^^xsd:dateTime .

oakcurric:misconception-es-word-used-translate-german
  a curric:Misconception ;
  curric:statement "'Es' is the only word used to translate 'it' in German."@en ;
  curric:correction """'Es' is for neuter nouns or abstract ideas. Use the correct subject or object
  pronouns according to the grammatical gender of the noun they replace."""@en ;
  dcterms:modified "2026-06-07T15:30:15.165871Z"^^xsd:dateTime .

oakcurric:misconception-say-german-say-nicht-ein
  a curric:Misconception ;
  curric:statement "To say 'not a' in German, say 'nicht ein'."@en ;
  curric:correction "Use 'kein' to say what you do not have."@en ;
  dcterms:modified "2026-06-07T15:30:15.165876Z"^^xsd:dateTime .

oakcurric:misconception-word-gefallen-means-fell
  a curric:Misconception ;
  curric:statement "The word 'gefallen' always means 'fell'."@en ;
  curric:correction """The past participle of 'fallen' ('to fall') is 'gefallen', as is the past
  participle of 'gefallen' ('to please'). The difference is that the auxiliary verb 'haben'
  is used with 'gefallen' (to please), but 'sein' is used with 'fallen' (to fall)."""@en ;
  dcterms:modified "2026-06-07T15:30:15.166070Z"^^xsd:dateTime .

oakcurric:misconception-opinions-phrases-followed-dass-word
  a curric:Misconception ;
  curric:statement """All opinions phrases can be followed by 'dass' and word order 3
  (subordination)."""@en ;
  curric:correction """Whilst many opinion verbs, including 'meinen', 'glauben' and 'denken' are
  usually followed by 'dass' and word order 3, this is not always the case. 'Meiner Meinung
  nach' must be followed by word order 2 (inversion)."""@en ;
  dcterms:modified "2026-06-07T15:30:15.166076Z"^^xsd:dateTime .

oakcurric:misconception-german-alphabet-same-number-letters
  a curric:Misconception ;
  curric:statement """The German alphabet has the same number of letters (26) as the English
  alphabet."""@en ;
  curric:correction """The German alphabet also includes the letters 'ä, ö, ü, ß' and so consists of
  30 letters."""@en ;
  dcterms:modified "2026-06-07T15:30:15.166476Z"^^xsd:dateTime .

oakcurric:misconception-verbs-verbs-nouns-nouns
  a curric:Misconception ;
  curric:statement "Verbs are always verbs and nouns are always nouns."@en ;
  curric:correction """Sometimes words of one type can be used as another type. For example, 'ich
  mag das Schwimmen' (I like swimming) is the verb 'schwimmen' used as a noun. When used as
  nouns, verbs have a gender (neuter), the article 'das' and a capital letter."""@en ;
  dcterms:modified "2026-06-07T15:30:15.166699Z"^^xsd:dateTime .

oakcurric:misconception-modal-verbs-require-zu-infinitive
  a curric:Misconception ;
  curric:statement "Modal verbs require a 'zu' before the infinitive."@en ;
  curric:correction """Two-verb structures without a modal verb require 'zu' before the infinitive,
  e.g., 'Ich habe Lust, schwimmen zu gehen.'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.166705Z"^^xsd:dateTime .

oakcurric:misconception-nouns-german-capital-letters-same
  a curric:Misconception ;
  curric:statement """Nouns in German have capital letters in the same situations as English
  nouns."""@en ;
  curric:correction """German nouns are always capitalised, no matter where or how they are used in
  a sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:15.166832Z"^^xsd:dateTime .

oakcurric:misconception-long-know-meaning-noun-dont
  a curric:Misconception ;
  curric:statement """As long as we know the meaning of a noun, we don't need to worry about its
  grammatical gender."""@en ;
  curric:correction """Knowing the grammatical gender of a noun is very important, because the
  gender affects the form of other parts of a sentence, such as the article or preposition.
  This in turn affects the clarity and comprehensibility of the message."""@en ;
  dcterms:modified "2026-06-07T15:30:15.168195Z"^^xsd:dateTime .

oakcurric:misconception-german-d-pronounced-english-d
  a curric:Misconception ;
  curric:statement "German [d] is always pronounced as English [d]."@en ;
  curric:correction """German [d] at the beginning of a word or syllable sounds like English 'd';
  [d] at the end of a syllable sounds like -t. For example, the sentence 'die Landschaft in
  Deutschland ist wunderschön' contains examples of both [d] sounds."""@en ;
  dcterms:modified "2026-06-07T15:30:15.168327Z"^^xsd:dateTime .

oakcurric:misconception-modal-verbs-dont-require-2nd
  a curric:Misconception ;
  curric:statement """Modal verbs don't require a 2nd verb in the infinitive unless they are in the
  present tense."""@en ;
  curric:correction """Modal verbs require a 2nd verb in the infinitive in other tenses, including
  the imperfect tense, e.g., 'ich konnte schwimmen'. They do not require a preceding 'zu'
  before the infinitive. Other verbs do."""@en ;
  dcterms:modified "2026-06-07T15:30:15.168490Z"^^xsd:dateTime .

oakcurric:misconception-change-word-order-time-adverbials
  a curric:Misconception ;
  curric:statement "There is no change in word order after time adverbials."@en ;
  curric:correction """Practise short examples with and without time adverbials, and use cards (or
  the pupils themselves) to move to demonstrate word order 2 with time adverbials at
  beginning of sentences."""@en ;
  dcterms:modified "2026-06-07T15:30:15.168576Z"^^xsd:dateTime .

oakcurric:misconception-german-verbs-stress-same-syllable
  a curric:Misconception ;
  curric:statement "German verbs always stress the same syllable."@en ;
  curric:correction """Generally German infinitive verbs stress the first syllable; however, words
  starting with inseparable prefixes be-, er-, ge-, ver-, ent- stress the 2nd syllable,
  which includes most past participles; -ieren verbs stress the 'ie' in present and past."""@en ;
  dcterms:modified "2026-06-07T15:30:15.168582Z"^^xsd:dateTime .

oakcurric:misconception-way-communicate-past-events-german
  a curric:Misconception ;
  curric:statement """The only way to communicate about past events in German is by using the 2-verb
  perfect tense, e.g., 'Ich bin nach Deutschland gefahren. Ich habe dort einen Strandurlaub
  gemacht.'."""@en ;
  curric:correction """We also use the single verb imperfect tense - 'war', 'hatte' and 'es gab',
  and imperfect modal forms - 'musste', 'konnte', 'wollte', with a 2nd (infinitive) verb, to
  talk about events in the past."""@en ;
  dcterms:modified "2026-06-07T15:30:15.168826Z"^^xsd:dateTime .

oakcurric:misconception-direct-object-precedes-indirect-object
  a curric:Misconception ;
  curric:statement "The direct object precedes the indirect object in a German sentence."@en ;
  curric:correction """If there are two objects in a sentence and one is a pronoun, the pronoun will
  precede the noun, regardless of whether it is the direct or indirect object. However, if
  both objects are nouns, the indirect object is first."""@en ;
  dcterms:modified "2026-06-07T15:30:15.168832Z"^^xsd:dateTime .

oakcurric:misconception-german-verb-use-needed-saying
  a curric:Misconception ;
  curric:statement "The German verb for 'use' is needed when saying what used to happen."@en ;
  curric:correction """'Used to' in German is communicated by using the adverb 'früher' - 'in the
  past', 'in former times'. There is no need to include a German verb for 'use'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.168987Z"^^xsd:dateTime .

oakcurric:misconception-german-two-ways-formulate-present
  a curric:Misconception ;
  curric:statement """German has two ways to formulate present tense questions - just like in
  English; e.g., 'Do you do play guitar?'; 'Are you playing guitar?'."""@en ;
  curric:correction """German just has one present tense; this means that the question 'Spielst du
  Gitarre?' means 'Do you play guitar?' and 'Are you playing guitar?'. The context and/or
  the temporal adverb (on Tuesdays, today) help us to use the correct translation."""@en ;
  dcterms:modified "2026-06-07T15:30:15.169036Z"^^xsd:dateTime .

oakcurric:misconception-word-order-german-remains-same
  a curric:Misconception ;
  curric:statement "Word order in German remains the same as English after ‘weil’ ('because')."@en ;
  curric:correction """When using ‘weil’ to give a reason, the verb moves to the end of the clause,
  e.g., ‘ich spiele gern Fußball, weil es Spaß macht'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.169041Z"^^xsd:dateTime .

oakcurric:misconception-make-imperfect-stem-strong-verbs
  a curric:Misconception ;
  curric:statement """Make the imperfect stem of strong verbs just by removing -en and changing the
  stem vowel."""@en ;
  curric:correction """Many strong verbs form their imperfect stem in this way: 'lesen' - 'las',
  'geben', 'gab'. Other verbs have other small changes too: 'kommen' - 'kam', 'essen' -
  'aß'. Others are more irregular: 'gehen' - 'ging', 'sein' - 'war', 'haben' - 'hatte'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.169058Z"^^xsd:dateTime .

oakcurric:misconception-zu-means
  a curric:Misconception ;
  curric:statement "'Zu' always means 'to'."@en ;
  curric:correction """'Zu' can also mean 'too', 'closed', 'off' and 'shut'! Context is important
  when translating into English."""@en ;
  dcterms:modified "2026-06-07T15:30:15.169199Z"^^xsd:dateTime .

oakcurric:misconception-ch-pronounced-english-cheese
  a curric:Misconception ;
  curric:statement "[ch] is pronounced as in the English 'cheese'."@en ;
  curric:correction """[ch] is soft in German after [i] or [e]. It is hard after [a] [o] or [u].
  This is because [a] [o] and [u] are pronounced with a more open mouth whilst [i] and [e]
  have a more closed mouth."""@en ;
  dcterms:modified "2026-06-07T15:30:15.170070Z"^^xsd:dateTime .

oakcurric:misconception-nicht-used-negate
  a curric:Misconception ;
  curric:statement "'Nicht' is always used to negate."@en ;
  curric:correction """You can use 'nicht' or 'kein(e)' to negate a sentence. 'Nicht' is used with
  adjectives whereas 'kein, keine' is used with nouns."""@en ;
  dcterms:modified "2026-06-07T15:30:15.170208Z"^^xsd:dateTime .

oakcurric:misconception-add-s-form-plural-nouns
  a curric:Misconception ;
  curric:statement "Add '-s' to form the plural of all nouns in German."@en ;
  curric:correction """There is a set of rules that help you know how to form plural nouns in
  German. Not all nouns form their plural in the same way, so the rules need to be learned."""@en ;
  dcterms:modified "2026-06-07T15:30:15.170250Z"^^xsd:dateTime .

oakcurric:misconception-plural-nouns-formed-same-way
  a curric:Misconception ;
  curric:statement "All plural nouns are formed the same way in German."@en ;
  curric:correction """Nouns can form their plural in different ways in German. There are rules to
  help you learn this."""@en ;
  dcterms:modified "2026-06-07T15:30:15.170401Z"^^xsd:dateTime .

oakcurric:misconception-begin-inversion-sentence-word-order
  a curric:Misconception ;
  curric:statement """You can only begin an inversion sentence (word order two) with a time phrase,
  nothing else."""@en ;
  curric:correction """The emphasis is on whatever comes first in the sentence when using inversion
  (word order 2). It is acceptable to put the object of the sentence before the verb. For
  example, 'Den Kaffee trinken wir heute'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.170667Z"^^xsd:dateTime .

oakcurric:misconception-german-past-participles-prefix-ge
  a curric:Misconception ;
  curric:statement "All German past participles have the prefix ge-."@en ;
  curric:correction """German verbs starting with be-, ver- and er- do not have the prefix ge- added
  for the past participle, e.g., 'besucht' - 'visited' or 'verdient' - 'earnt'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.171077Z"^^xsd:dateTime .

oakcurric:misconception-german-adjectives-come-noun-dont
  a curric:Misconception ;
  curric:statement """When German adjectives come before the noun, they don't change their spelling,
  just like in English, e.g., 'The dog is black'; 'The black dog is over there.'."""@en ;
  curric:correction """In German, when adjectives come after the verb 'sein' (to be) they don't
  change. However, adjectives in front of a noun add endings do; this is called adjective
  agreement. There are different endings depending on gender (m, f, nt) and on the article."""@en ;
  dcterms:modified "2026-06-07T15:30:15.171083Z"^^xsd:dateTime .

oakcurric:misconception-opinion-verb-e-g-denken
  a curric:Misconception ;
  curric:statement """After an opinion verb (e.g., 'denken') and the conjunction 'dass', we use
  normal subject-verb word order."""@en ;
  curric:correction """To say 'I think that ...' in German, we use the conjunction 'dass', which
  triggers word order 3 (WO3); e.g., 'Ich denke, dass Rapmusik toll ist.'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.171288Z"^^xsd:dateTime .

oakcurric:misconception-final-e-long-vowel-sound
  a curric:Misconception ;
  curric:statement "Final [e] is a long vowel sound in German."@en ;
  curric:correction """Final [e] is a short [e] sound, as in 'Liebe'. Final [er] is a longer sound,
  as in 'lieber'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.171305Z"^^xsd:dateTime .
