# ----------------------------------------------------------------------
# Key Learning Points
# ----------------------------------------------------------------------

oakcurric:keylearningpoint-lesson-26309-1
  a curric:KeyLearningPoint ;
  rdfs:label """The German alphabet has 26 standard letters, like English, and four additional
  characters [ä], [ö], [ü] and ß."""@en ;
  dcterms:modified "2026-06-07T15:30:29Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26309-2
  a curric:KeyLearningPoint ;
  rdfs:label """The umlaut letters [ä], [ö], [ü] sound very different from [a], [o] and [u] and
  require practice."""@en ;
  dcterms:modified "2026-06-07T15:30:29.000004Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26309-3
  a curric:KeyLearningPoint ;
  rdfs:label """Sentence building is the process of creating meaningful sentences using knowledge of
  both vocabulary and grammar."""@en ;
  dcterms:modified "2026-06-07T15:30:29.000008Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26309-4
  a curric:KeyLearningPoint ;
  rdfs:label """The perfect tense with most verbs uses the present tense of the verb ‘haben’
  together with a past participle."""@en ;
  dcterms:modified "2026-06-07T15:30:29.000012Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26309-5
  a curric:KeyLearningPoint ;
  rdfs:label """For strong past participles, ge- and –en sandwich the stem; the stem may have a
  vowel change, too."""@en ;
  dcterms:modified "2026-06-07T15:30:29.000016Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26296-1
  a curric:KeyLearningPoint ;
  rdfs:label """[a] and [o] are short when followed by two consonants, but long when followed by
  single consonants or 'h', ('Bahnhof')."""@en ;
  dcterms:modified "2026-06-07T15:30:29.001493Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26296-2
  a curric:KeyLearningPoint ;
  rdfs:label """The perfect tense is formed with a part of 'haben' or 'sein' + a past participle,
  which goes at the end of the sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.001500Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26296-3
  a curric:KeyLearningPoint ;
  rdfs:label """‘Mit’ + dative is used to describe the manner in which a person travels, and goes
  before place in a sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.001507Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26305-1
  a curric:KeyLearningPoint ;
  rdfs:label """German vowels can be long or short; vowels followed by more than one consonant are
  short; other vowels are long."""@en ;
  dcterms:modified "2026-06-07T15:30:29.002497Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26305-2
  a curric:KeyLearningPoint ;
  rdfs:label """Some German and English cognates or near-cognates have the same pronunciation of [i]
  ('Kilo'); others not ('Musik')."""@en ;
  dcterms:modified "2026-06-07T15:30:29.002501Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26305-3
  a curric:KeyLearningPoint ;
  rdfs:label """Many German verbs are followed by direct objects; personal direct object pronouns
  are 'mich', 'dich', 'ihn', 'sie'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.002506Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26305-4
  a curric:KeyLearningPoint ;
  rdfs:label """With certain German verbs we use indirect objects; personal indirect object pronouns
  are 'mir', 'dir', 'ihm', 'ihr'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.002510Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26305-5
  a curric:KeyLearningPoint ;
  rdfs:label """Sometimes indirect object pronouns mean ‘to me’, ‘to you’, etc., but they can just
  mean ‘me’, ‘you’, ‘him’, ‘her’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.002514Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26370-1
  a curric:KeyLearningPoint ;
  rdfs:label "Reading longer texts is a useful way to deepen knowledge of vocabulary."@en ;
  dcterms:modified "2026-06-07T15:30:29.002975Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26370-2
  a curric:KeyLearningPoint ;
  rdfs:label """Prepositions 'ohne' and 'für' are followed by a direct object and always take the
  accusative case."""@en ;
  dcterms:modified "2026-06-07T15:30:29.002979Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26370-3
  a curric:KeyLearningPoint ;
  rdfs:label """Prepositions 'mit' and 'von' are followed by an indirect object and always take the
  dative case."""@en ;
  dcterms:modified "2026-06-07T15:30:29.002983Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26370-4
  a curric:KeyLearningPoint ;
  rdfs:label """Possessive adjectives change spelling according to the gender of the noun they
  relate to and the case."""@en ;
  dcterms:modified "2026-06-07T15:30:29.002987Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26306-1
  a curric:KeyLearningPoint ;
  rdfs:label """Circumlocution is an effective way to deepen word knowledge, making use of synonyms,
  antonyms or short descriptions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.002992Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26306-2
  a curric:KeyLearningPoint ;
  rdfs:label """Possessive adjectives follow the same pattern as indefinite articles 'ein', 'eine',
  'ein', changing for gender and case."""@en ;
  dcterms:modified "2026-06-07T15:30:29.002996Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26306-3
  a curric:KeyLearningPoint ;
  rdfs:label """The preposition 'für' ('for') is always followed by the accusative case; 'von'
  ('from') by the dative."""@en ;
  dcterms:modified "2026-06-07T15:30:29.003000Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26306-4
  a curric:KeyLearningPoint ;
  rdfs:label """Dative verbs are always used with indirect object pronouns: 'mir', 'dir', 'ihm',
  'ihr' - (to, for) me, you, him, her."""@en ;
  dcterms:modified "2026-06-07T15:30:29.003005Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26287-1
  a curric:KeyLearningPoint ;
  rdfs:label """When adjectives come before nouns, they have different endings depending on the noun
  gender, type of article and case."""@en ;
  dcterms:modified "2026-06-07T15:30:29.003009Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26287-2
  a curric:KeyLearningPoint ;
  rdfs:label "The accusative case is used for the ‘object’ of the verb."@en ;
  dcterms:modified "2026-06-07T15:30:29.003013Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26287-3
  a curric:KeyLearningPoint ;
  rdfs:label """Singular accusative adjective endings for indefinite articles are: -en (masculine)
  -e (feminine) and -es (neuter)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.003017Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26287-4
  a curric:KeyLearningPoint ;
  rdfs:label """For accusative plural nouns after 'keine', the adjective ending is -en; without an
  article the accusative ending is -e."""@en ;
  dcterms:modified "2026-06-07T15:30:29.003023Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26234-1
  a curric:KeyLearningPoint ;
  rdfs:label "German only has one present tense."@en ;
  dcterms:modified "2026-06-07T15:30:29.004959Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26234-2
  a curric:KeyLearningPoint ;
  rdfs:label "Weak verbs use a regular pattern of verb endings in the present tense."@en ;
  dcterms:modified "2026-06-07T15:30:29.004965Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26234-3
  a curric:KeyLearningPoint ;
  rdfs:label """Singular present tense weak verb endings are 1st person '-e', 2nd person '-st' and
  3rd person '-t'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004969Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26234-4
  a curric:KeyLearningPoint ;
  rdfs:label "'Werden' is a frequently used irregular verb meaning 'to become, becoming'."@en ;
  dcterms:modified "2026-06-07T15:30:29.004974Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26392-1
  a curric:KeyLearningPoint ;
  rdfs:label "German [th] sounds like 't' in English."@en ;
  dcterms:modified "2026-06-07T15:30:29.251645Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26392-2
  a curric:KeyLearningPoint ;
  rdfs:label """If 't' and 'h' are in different syllables, you say both sounds separately, like in
  'Rathaus'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.251650Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26392-3
  a curric:KeyLearningPoint ;
  rdfs:label """The verbs 'mögen' and 'gefallen' both express 'liking', but they work in different
  ways."""@en ;
  dcterms:modified "2026-06-07T15:30:29.251655Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26392-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Mögen' works like a standard verb where the subject likes something, e.g., 'ich mag
  Fußball'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.251663Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26392-5
  a curric:KeyLearningPoint ;
  rdfs:label """'Gefallen' is 'to please'; use it with an indirect object pronoun, e.g., 'Fußball
  gefällt mir' - 'football pleases me'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.251668Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26356-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Nicht' means 'not' and 'kein' means 'no, not a' with a noun."@en ;
  dcterms:modified "2026-06-07T15:30:29.251673Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26356-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Nicht' is used when the noun is preceded by the definite article, a possessive
  adjective, or before a proper noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.251678Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26356-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Kein' is used if the noun is preceded by the indefinite article."@en ;
  dcterms:modified "2026-06-07T15:30:29.251683Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26356-4
  a curric:KeyLearningPoint ;
  rdfs:label "'Kein' goes before the noun it negates."@en ;
  dcterms:modified "2026-06-07T15:30:29.251688Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26356-5
  a curric:KeyLearningPoint ;
  rdfs:label """'Nicht' goes before the element it negates, or at the end of the phrase if it
  negates the whole phrase."""@en ;
  dcterms:modified "2026-06-07T15:30:29.251693Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26299-1
  a curric:KeyLearningPoint ;
  rdfs:label """[ä] is an important sound-symbol correspondence (SSC) and needs to be practised
  regularly."""@en ;
  dcterms:modified "2026-06-07T15:30:29.251698Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26299-2
  a curric:KeyLearningPoint ;
  rdfs:label """Weak verbs ollow a clear pattern across tenses, e.g., 'spielen' - 'ich spiele' -
  'ich habe gespielt'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.251703Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26299-3
  a curric:KeyLearningPoint ;
  rdfs:label """Strong verbs have a stem change in one or more tenses, e.g., 'fallen' - 'du fällst'
  - 'du bist gefallen'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.251710Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26299-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Ander-er, -e,-es' is an adjective meaning 'other' and is used with an indefinite
  article."""@en ;
  dcterms:modified "2026-06-07T15:30:29.251716Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26299-5
  a curric:KeyLearningPoint ;
  rdfs:label """'Gern' is an adverb of manner which conveys liking doing something. It follows the
  verb in a sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.251721Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26294-1
  a curric:KeyLearningPoint ;
  rdfs:label """Revisiting individual word meanings in listening, reading and speaking practice
  activities strengthens memory."""@en ;
  dcterms:modified "2026-06-07T15:30:29.251961Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26294-2
  a curric:KeyLearningPoint ;
  rdfs:label """Contrasting the present and perfect tense in practice tasks deepens the knowledge of
  both structures."""@en ;
  dcterms:modified "2026-06-07T15:30:29.251966Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26294-3
  a curric:KeyLearningPoint ;
  rdfs:label """‘Uhr’ means 'o’clock'. ‘Um’ means ‘at’ with time, e.g., 'um drei Uhr' ('at three o’
  clock'). ‘Die Stunde’ means ‘hour’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.251970Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26294-4
  a curric:KeyLearningPoint ;
  rdfs:label """Starting with time triggers word order 2 so the verb stays in 2nd place, e.g., 'um
  zwei Uhr habe ich Karten gespielt'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.251975Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26281-1
  a curric:KeyLearningPoint ;
  rdfs:label """Long and short [u] and [ü] need practice and clarity as the umlaut is often added to
  form plural nouns."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252474Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26281-2
  a curric:KeyLearningPoint ;
  rdfs:label """Certain expressions which use 'haben' (to have) translate differently in English,
  e.g., 'Ich habe Hunger' - I am hungry."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252479Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26281-3
  a curric:KeyLearningPoint ;
  rdfs:label """Use 'du' (you, sing.) for a friend, family member or person you know well, and 'Sie'
  for adults you address by surname."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252486Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26281-4
  a curric:KeyLearningPoint ;
  rdfs:label "Verbs with 'Sie' (you, formal) are the same as the infinitive (dictionary) form."@en ;
  dcterms:modified "2026-06-07T15:30:29.252491Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26281-5
  a curric:KeyLearningPoint ;
  rdfs:label "'Sie' (you, formal) is written with a capital letter."@en ;
  dcterms:modified "2026-06-07T15:30:29.252496Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26259-1
  a curric:KeyLearningPoint ;
  rdfs:label """[j] is pronounced as in 'ja'. Loan words from English which begin with 'j' in
  English are pronounced with English 'j'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252972Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26259-2
  a curric:KeyLearningPoint ;
  rdfs:label "The simple present is the only present tense in German."@en ;
  dcterms:modified "2026-06-07T15:30:29.252977Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26259-3
  a curric:KeyLearningPoint ;
  rdfs:label "Adverbs indicate if the present continuous is needed in an English translation."@en ;
  dcterms:modified "2026-06-07T15:30:29.252981Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26259-4
  a curric:KeyLearningPoint ;
  rdfs:label """Form closed questions by swapping the position of the subject and verb. Add a
  question word to form an open question."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252989Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26293-1
  a curric:KeyLearningPoint ;
  rdfs:label """German [ch] is two sounds, hard and soft, depending on the preceding vowel. [ch] and
  [ck] are different sounds."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252994Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26293-2
  a curric:KeyLearningPoint ;
  rdfs:label """‘So’, ‘wirklich’ and ‘also’ can make our use of German more natural, adding emphasis
  or acting as conversation fillers."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252998Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26293-3
  a curric:KeyLearningPoint ;
  rdfs:label "The preposition ‘von’ means ‘from’ and ‘of’ and is followed by the dative case."@en ;
  dcterms:modified "2026-06-07T15:30:29.253003Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26293-4
  a curric:KeyLearningPoint ;
  rdfs:label """The ‘we’ form of the past (perfect) tense in German is ‘wir haben' + past
  participle, e.g., 'wir haben Karten gespielt'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.253008Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26417-1
  a curric:KeyLearningPoint ;
  rdfs:label "Use the imperfect tense in German to narrative past events, mainly in writing."@en ;
  dcterms:modified "2026-06-07T15:30:29.253013Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26417-2
  a curric:KeyLearningPoint ;
  rdfs:label """Infer the likely meaning of an unfamiliar word by knowing surrounding words and by
  the structure of the word itself."""@en ;
  dcterms:modified "2026-06-07T15:30:29.253017Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26417-3
  a curric:KeyLearningPoint ;
  rdfs:label """Da-compounds are used to replace and refer back to inanimate (non-living) nouns
  which have already been mentioned."""@en ;
  dcterms:modified "2026-06-07T15:30:29.253022Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26417-4
  a curric:KeyLearningPoint ;
  rdfs:label """Use wo-compounds to ask questions with prepositions, putting wo- at the start of the
  question before the preposition."""@en ;
  dcterms:modified "2026-06-07T15:30:29.253026Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26417-5
  a curric:KeyLearningPoint ;
  rdfs:label """Use dar- and wor- for da- and wo-compounds for prepositions starting with a
  vowel."""@en ;
  dcterms:modified "2026-06-07T15:30:29.253031Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26330-1
  a curric:KeyLearningPoint ;
  rdfs:label """Both sounds are pronounced in the sound-symbol correspondence [kn]. This is
  different from English."""@en ;
  dcterms:modified "2026-06-07T15:30:29.254432Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26330-2
  a curric:KeyLearningPoint ;
  rdfs:label """The modal verb 'sollen' expresses obligation or probability and requires a 2nd verb
  in the infinitive at the end."""@en ;
  dcterms:modified "2026-06-07T15:30:29.254437Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26330-3
  a curric:KeyLearningPoint ;
  rdfs:label """Use inversion (word order two) to emphasise a particular element. The verb is always
  the 2nd idea in the sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.254443Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26330-4
  a curric:KeyLearningPoint ;
  rdfs:label """Open (wh) questions use inversion (word order two). For example: 'Wann soll ich die
  Tickets kaufen?'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.254448Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26330-5
  a curric:KeyLearningPoint ;
  rdfs:label """Use a comma before 'zu' in two-verb structures that don't involve a modal verb,
  e.g., 'Er hofft, das Buch zu lesen.'"""@en ;
  dcterms:modified "2026-06-07T15:30:29.254453Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26209-1
  a curric:KeyLearningPoint ;
  rdfs:label """The verb 'haben' means 'to have/having'. 'Ich habe' means 'I have', 'du hast' - 'you
  have', er/sie hat' - 'he/she has.'"""@en ;
  dcterms:modified "2026-06-07T15:30:29.254830Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26209-2
  a curric:KeyLearningPoint ;
  rdfs:label """The masculine indefinite article 'ein' changes to 'einen' after 'haben' and most
  verbs, but not after 'sein'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.254834Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26209-3
  a curric:KeyLearningPoint ;
  rdfs:label """The masculine definite article 'der' changes to 'den' after 'haben' and most verbs,
  but not after 'sein'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.254839Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26209-4
  a curric:KeyLearningPoint ;
  rdfs:label "The accusative case is used after 'haben' to mark belongings (direct objects)."@en ;
  dcterms:modified "2026-06-07T15:30:29.254843Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26207-1
  a curric:KeyLearningPoint ;
  rdfs:label "[w] sounds like the English [v]."@en ;
  dcterms:modified "2026-06-07T15:30:29.255354Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26207-2
  a curric:KeyLearningPoint ;
  rdfs:label "The question word 'Wer?' means 'Who?'."@en ;
  dcterms:modified "2026-06-07T15:30:29.255358Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26207-3
  a curric:KeyLearningPoint ;
  rdfs:label "The verb 'haben' means 'to have/having'. Its short form 'hat' means 'has'."@en ;
  dcterms:modified "2026-06-07T15:30:29.255362Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26207-4
  a curric:KeyLearningPoint ;
  rdfs:label """The masculine word for 'the' ('der') changes to 'den' after most verbs (including
  'haben') but not after 'sein'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.255367Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26229-1
  a curric:KeyLearningPoint ;
  rdfs:label """[äu] is an important sound symbol correspondence, used often in noun plurals; for
  example, 'Häuser'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.255535Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26229-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Wie viele ...?' means 'How many ...?'."@en ;
  dcterms:modified "2026-06-07T15:30:29.255539Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26229-3
  a curric:KeyLearningPoint ;
  rdfs:label """Knowing noun genders well is key to applying German plural noun rules 1 to 4
  correctly."""@en ;
  dcterms:modified "2026-06-07T15:30:29.255544Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26229-4
  a curric:KeyLearningPoint ;
  rdfs:label """Place a question word directly in front of the verb to change a closed question into
  an open one."""@en ;
  dcterms:modified "2026-06-07T15:30:29.255548Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26382-1
  a curric:KeyLearningPoint ;
  rdfs:label """Stress the 2nd syllable of words that start with an inseparable prefix. Borrowed
  words stress the 2nd or final syllable."""@en ;
  dcterms:modified "2026-06-07T15:30:29.255707Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26382-2
  a curric:KeyLearningPoint ;
  rdfs:label """Verbs of movement or which imply a change of state form the perfect tense with
  'sein', e.g., 'er ist gestorben'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.255712Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26382-3
  a curric:KeyLearningPoint ;
  rdfs:label """Verbs which require an object are transitive verbs. Verbs that don't require an
  object are intransitive verbs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.255716Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26382-4
  a curric:KeyLearningPoint ;
  rdfs:label """Calendar years in German are said as long numbers, e.g., 'neunzehnhundertfünf' =
  1905."""@en ;
  dcterms:modified "2026-06-07T15:30:29.255720Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26382-5
  a curric:KeyLearningPoint ;
  rdfs:label "Calendar years 2000+ are said 'zweitausend-', e.g., 'zweitausendeins' = 2001."@en ;
  dcterms:modified "2026-06-07T15:30:29.255724Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26373-1
  a curric:KeyLearningPoint ;
  rdfs:label """Regular revisiting of phonic rules supports effective transcription and reading
  aloud."""@en ;
  dcterms:modified "2026-06-07T15:30:29.257399Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26373-2
  a curric:KeyLearningPoint ;
  rdfs:label "Practising new and known vocabulary regularly supports successful recall."@en ;
  dcterms:modified "2026-06-07T15:30:29.257405Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26373-3
  a curric:KeyLearningPoint ;
  rdfs:label """For 24-hour clock, we say 'Uhr' instead of ':' and minutes are said as numbers,
  e.g., 'vierzehn Uhr fünfunddreißig'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.257410Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26373-4
  a curric:KeyLearningPoint ;
  rdfs:label """Open questions are formed by using a question word and inverting the subject and
  verb, e.g., 'Wann gehen wir ins Kino?'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.257414Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26369-1
  a curric:KeyLearningPoint ;
  rdfs:label """Using a range of strategies, e.g., synonym spotting, can help deepen vocabulary
  knowledge."""@en ;
  dcterms:modified "2026-06-07T15:30:29.257882Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26369-2
  a curric:KeyLearningPoint ;
  rdfs:label """Using surrounding words to help infer meaning of unfamiliar words is a key strategy
  in reading comprehension."""@en ;
  dcterms:modified "2026-06-07T15:30:29.257890Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26369-3
  a curric:KeyLearningPoint ;
  rdfs:label """Infinitive verbs can be changed into nouns by capitalising the first letter of the
  infinitive."""@en ;
  dcterms:modified "2026-06-07T15:30:29.257895Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26369-4
  a curric:KeyLearningPoint ;
  rdfs:label """Infinitive nouns are always neuter; English equivalents end in -ing, e.g., 'das
  Schwimmen' - 'swimming'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.257899Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26369-5
  a curric:KeyLearningPoint ;
  rdfs:label """In addition to modal verbs and 'werden', a few other verbs don’t need 'zu' before
  the infinitive in two-verb sentences."""@en ;
  dcterms:modified "2026-06-07T15:30:29.257903Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26271-1
  a curric:KeyLearningPoint ;
  rdfs:label """[s] sounds like the English 'z' before a vowel. Elsewhere [s], 'ss' and [ß] sound
  like the English 's'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.257907Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26271-2
  a curric:KeyLearningPoint ;
  rdfs:label """Write 'ss' after a short vowel but [ß] after a long vowel like 'Fuß' or after 2
  vowels together like 'weiß'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.257911Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26271-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Nächst-' means 'next' and takes the same ending as the definite article of the noun
  it precedes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.257915Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26271-4
  a curric:KeyLearningPoint ;
  rdfs:label """Use a time adverbial with the present tense to express what you are doing in future,
  e.g., 'Nächste Woche tanze ich'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.257919Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26271-5
  a curric:KeyLearningPoint ;
  rdfs:label """When translating future meaning from German into English, use the present continuous
  tense (i.e., 'I am going to')."""@en ;
  dcterms:modified "2026-06-07T15:30:29.257923Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26258-1
  a curric:KeyLearningPoint ;
  rdfs:label """[j] is pronounced as in 'ja'. Loan words from English beginning with 'j' are
  pronounced like the English 'j' in 'jeans'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.258457Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26258-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Sein' is an irregular verb meaning 'to be': 'ich bin; du bist; sie, er, es ist; wir
  sind; sie sind'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.258461Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26258-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Haben' is an irregular verb meaning 'to have': 'ich habe; du hast; sie, er, es hat;
  wir haben; sie haben'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.258465Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26322-1
  a curric:KeyLearningPoint ;
  rdfs:label """Practising vocabulary, both known and new, is important for building language
  knowledge."""@en ;
  dcterms:modified "2026-06-07T15:30:29.258697Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26322-2
  a curric:KeyLearningPoint ;
  rdfs:label """Starting school in Germany is different from a child’s first day at school in
  England."""@en ;
  dcterms:modified "2026-06-07T15:30:29.258701Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26322-3
  a curric:KeyLearningPoint ;
  rdfs:label """Many German verbs are followed by direct objects or pronouns; two plural direct
  object pronouns are ‘uns' and 'sie'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.258704Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26322-4
  a curric:KeyLearningPoint ;
  rdfs:label """Some German verbs use indirect or dative objects; two plural indirect object
  pronouns are 'uns' and 'ihnen'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.258710Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26322-5
  a curric:KeyLearningPoint ;
  rdfs:label """Sometimes indirect object pronouns mean ‘to us’, ‘to them’, etc., but they can just
  mean ‘us’, ‘them’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.258714Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26237-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Sein' is an irregular verb. 'Wir sind' means 'we are'."@en ;
  dcterms:modified "2026-06-07T15:30:29.259638Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26237-2
  a curric:KeyLearningPoint ;
  rdfs:label """No indefinite article is needed when using ‘sein’ + profession noun, e.g., ‘Sie ist
  Lehrerin’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259642Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26237-3
  a curric:KeyLearningPoint ;
  rdfs:label "The simple present is the only present tense in German."@en ;
  dcterms:modified "2026-06-07T15:30:29.259645Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26237-4
  a curric:KeyLearningPoint ;
  rdfs:label """Adverbs of time tell us which English tense to use (simple present or present
  continuous) when translating from German."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259649Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26338-1
  a curric:KeyLearningPoint ;
  rdfs:label "‘Nach’ means 'past' and ‘vor’ means 'to' the hour when saying the time."@en ;
  dcterms:modified "2026-06-07T15:30:29.259935Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26338-2
  a curric:KeyLearningPoint ;
  rdfs:label "In Germany, Austria and Switzerland, greetings vary by region and time of day."@en ;
  dcterms:modified "2026-06-07T15:30:29.259939Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26338-3
  a curric:KeyLearningPoint ;
  rdfs:label """The accusative is used with 'in', 'an', 'auf' when there is movement to a place,
  e.g., ‘ich gehe in den Zoo’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259942Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26338-4
  a curric:KeyLearningPoint ;
  rdfs:label """The dative is used with 'in', 'an', 'auf' when the person is at or in a place, e.g.,
  ‘ich bin im Zoo’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259946Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26212-1
  a curric:KeyLearningPoint ;
  rdfs:label """[o] can be either short (followed by 2 consonants) or long (followed by a single
  consonant, double vowel or 'h')."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260535Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26212-2
  a curric:KeyLearningPoint ;
  rdfs:label """The infinitive of a verb is the form listed in the dictionary. In German, it usually
  ends in 'en'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260538Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26212-3
  a curric:KeyLearningPoint ;
  rdfs:label """The short form of the verb (3rd person singular) is used to talk about 'he' or
  'she'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260542Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26212-4
  a curric:KeyLearningPoint ;
  rdfs:label """Remove 'en' from the infinitive and add a 't' for the 3rd person singular of most
  verbs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260546Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26212-5
  a curric:KeyLearningPoint ;
  rdfs:label """German has one present tense. English has two present tenses, e.g., 'er macht' can
  mean 'he does' or 'he is doing'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260551Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26224-1
  a curric:KeyLearningPoint ;
  rdfs:label """'Sein' means 'to be, being', 'ist' (is) is the 3rd person singular and 'sind' is the
  3rd person plural."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260770Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26224-2
  a curric:KeyLearningPoint ;
  rdfs:label "For all plural nouns, the German word for 'the' is 'die'."@en ;
  dcterms:modified "2026-06-07T15:30:29.260774Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26224-3
  a curric:KeyLearningPoint ;
  rdfs:label "For noun plural rule 3, most feminine nouns add '-n' or '-en'."@en ;
  dcterms:modified "2026-06-07T15:30:29.260778Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26224-4
  a curric:KeyLearningPoint ;
  rdfs:label """Feminine nouns ending in -el, -en or -er almost always add -n or -en in the plural
  form too."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260781Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26241-1
  a curric:KeyLearningPoint ;
  rdfs:label """[r] is a rolling sound at the start of a syllable, after a consonant or a short
  vowel. This is consonantal [r]."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260785Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26241-2
  a curric:KeyLearningPoint ;
  rdfs:label """[r] is a gentle 'ah' sound after a long vowel and in '-er'. It often sounds barely
  there. This is vocalic [r]."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260789Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26241-3
  a curric:KeyLearningPoint ;
  rdfs:label """Combine two or more nouns to form a compound noun. Its grammatical gender will be
  the same as that of the final noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260793Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26241-4
  a curric:KeyLearningPoint ;
  rdfs:label """The English meaning of German compound nouns is not always a word-for-word
  translation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260796Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26241-5
  a curric:KeyLearningPoint ;
  rdfs:label """Strong verbs have a vowel change in their verb stem in the ‘du’, ‘sie’, ‘er’ and
  ‘es’ forms."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260800Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26324-1
  a curric:KeyLearningPoint ;
  rdfs:label """Long [e] and [ä] make similar sounds but knowing the difference is important for
  speaking and listening."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261637Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26324-2
  a curric:KeyLearningPoint ;
  rdfs:label "The prepositions 'seit', 'vor' and 'bei' are followed by the dative case."@en ;
  dcterms:modified "2026-06-07T15:30:29.261641Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26324-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Seit' means 'since' or 'for' and is used with the present tense and a unit of time
  in the dative."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261644Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26324-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Vor' can mean ago and is used with the perfect tense and a unit of time in the
  dative."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261648Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26324-5
  a curric:KeyLearningPoint ;
  rdfs:label """'Bei' means 'at (the house of)', 'for' or 'with' and is followed by a noun or
  pronoun in the dative."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261651Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26335-1
  a curric:KeyLearningPoint ;
  rdfs:label """After the verb 'sein', adjectives before nouns have nominative endings, because the
  noun is the subject of the sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262137Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26335-2
  a curric:KeyLearningPoint ;
  rdfs:label """After most other verbs, prenominal adjectives have accusative endings, because the
  noun is the object of the sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262141Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26335-3
  a curric:KeyLearningPoint ;
  rdfs:label """German [v] usually sounds like English and German [f]; to write words correctly
  their spelling needs to be known."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262144Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26335-4
  a curric:KeyLearningPoint ;
  rdfs:label """Some prepositions always require dative endings; e.g., aus; others are only ever
  used with the accusative, e.g., durch."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262148Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26335-5
  a curric:KeyLearningPoint ;
  rdfs:label """The dative adjective ending is -en for singular and plural, definite and indefinite
  articles."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262152Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26239-1
  a curric:KeyLearningPoint ;
  rdfs:label """'Können' is a modal verb used to say what you can and cannot do (as in physically or
  situationally able)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262783Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26239-2
  a curric:KeyLearningPoint ;
  rdfs:label """Modal verbs such as 'können' require a 2nd verb in the infinitive, placed at the end
  of the sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262787Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26239-3
  a curric:KeyLearningPoint ;
  rdfs:label """Use part of 'können' + 'nicht' before the infinitive verb to mean 'cannot'/'can't',
  e.g., 'Ich kann nicht singen.'"""@en ;
  dcterms:modified "2026-06-07T15:30:29.262791Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26239-4
  a curric:KeyLearningPoint ;
  rdfs:label """Use part of 'können' + 'kein' + noun to mean 'cannot'/'can't', e.g., 'Ich kann kein
  Haus sehen' - 'I can't see a house'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262794Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26311-1
  a curric:KeyLearningPoint ;
  rdfs:label """Mastering German phonics is essential for good understanding in listening, speaking
  and writing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262798Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26311-2
  a curric:KeyLearningPoint ;
  rdfs:label "Practising vocabulary in a range of ways helps with recall."@en ;
  dcterms:modified "2026-06-07T15:30:29.262802Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26311-3
  a curric:KeyLearningPoint ;
  rdfs:label "The imperfect tense can be used to describe how things were in the past."@en ;
  dcterms:modified "2026-06-07T15:30:29.262807Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26311-4
  a curric:KeyLearningPoint ;
  rdfs:label "'War' means 'was'; 'es gab' means 'there was, were'; 'hatte' means 'had'."@en ;
  dcterms:modified "2026-06-07T15:30:29.262811Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26277-1
  a curric:KeyLearningPoint ;
  rdfs:label """[ei] and [ie] are tricky German sounds and need to be read, written and pronounced
  correctly."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263452Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26277-2
  a curric:KeyLearningPoint ;
  rdfs:label """To understand what you did in the past, use the present tense of ‘haben’ and a past
  participle."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263455Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26277-3
  a curric:KeyLearningPoint ;
  rdfs:label """The perfect tense in German can be translated in two ways in English: 'have done'
  and 'did'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263459Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26277-4
  a curric:KeyLearningPoint ;
  rdfs:label "The English meaning we use often depends on time adverbs."@en ;
  dcterms:modified "2026-06-07T15:30:29.263463Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26256-1
  a curric:KeyLearningPoint ;
  rdfs:label """[ig] varies in pronunciation between German-speaking regions and sounds either like
  'ich' or 'ik'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263889Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26256-2
  a curric:KeyLearningPoint ;
  rdfs:label """The verb 'gehen' means 'to go (on foot)' whereas the verb 'fahren' means 'to go (by
  transport)'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263893Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26256-3
  a curric:KeyLearningPoint ;
  rdfs:label """Prepositions describe the position of something, i.e., its location or movement,
  e.g., 'in' can mean 'in' or 'into'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263897Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26256-4
  a curric:KeyLearningPoint ;
  rdfs:label """Adverbs and adverbial phrases use the dative case when talking about where things
  are, e.g., 'im Zimmer'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263900Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26256-5
  a curric:KeyLearningPoint ;
  rdfs:label """Adverbs and adverbial phrases use the accusative case when talking about where
  things go, e.g., 'in das [ins] Zimmer'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263906Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26366-1
  a curric:KeyLearningPoint ;
  rdfs:label "Practising vocabulary in a variety of ways supports recall."@en ;
  dcterms:modified "2026-06-07T15:30:29.263912Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26366-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Werden' meaning 'will' can be used as part of a two-verb structure to describe
  future plans."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263916Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26366-3
  a curric:KeyLearningPoint ;
  rdfs:label """In the two-verb future tense with 'werden', the second verb is an infinitive and
  placed at the end of the clause."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263920Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26366-4
  a curric:KeyLearningPoint ;
  rdfs:label """In some two-verb structures, the second infinitive verb is preceded by 'zu', e.g.,
  'Ich hoffe, als Arzt zu arbeiten'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263923Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26390-1
  a curric:KeyLearningPoint ;
  rdfs:label "Numbers 21 to 99 are said with the units first, then ‘und’, then the tens."@en ;
  dcterms:modified "2026-06-07T15:30:29.265083Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26390-2
  a curric:KeyLearningPoint ;
  rdfs:label """Higher numbers are ‘hundert’, ‘tausend’, ‘eine Million’, ‘eine Milliarde’, ‘eine
  Billion’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.265087Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26390-3
  a curric:KeyLearningPoint ;
  rdfs:label "Most plural nouns are formed in one of six ways."@en ;
  dcterms:modified "2026-06-07T15:30:29.265091Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26390-4
  a curric:KeyLearningPoint ;
  rdfs:label """‘Mögen’ means to like, liking; ‘möcht-’ is the conditional form of ‘mögen’ which
  means 'would like'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.265094Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26368-1
  a curric:KeyLearningPoint ;
  rdfs:label """The stress on cognates is often different in German compared to English, e.g.,
  'consequence' - 'Konsequenz'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.265111Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26368-2
  a curric:KeyLearningPoint ;
  rdfs:label "Regular revisiting of vocabulary is important for developing recall."@en ;
  dcterms:modified "2026-06-07T15:30:29.265115Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26368-3
  a curric:KeyLearningPoint ;
  rdfs:label """An infinitive is a verb in its long form, giving its general meaning, e.g., 'helfen'
  - 'to help'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.265118Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26368-4
  a curric:KeyLearningPoint ;
  rdfs:label """In a two-verb structure with an infinitive, the infinitive is typically the second
  verb and is at the end of the clause."""@en ;
  dcterms:modified "2026-06-07T15:30:29.265122Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26368-5
  a curric:KeyLearningPoint ;
  rdfs:label """Some but not all two-verb structures with an infinitive use ‘zu’ before the
  infinitive; modal verbs and 'werden' do not."""@en ;
  dcterms:modified "2026-06-07T15:30:29.265126Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26391-1
  a curric:KeyLearningPoint ;
  rdfs:label """Word substitution when reading texts is a good way to strengthen vocabulary and
  grammar knowledge."""@en ;
  dcterms:modified "2026-06-07T15:30:29.266162Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26391-2
  a curric:KeyLearningPoint ;
  rdfs:label """Calendar years are expressed as hundreds and thousands up to year 1099 and as
  hundreds only from 1100 to 1999."""@en ;
  dcterms:modified "2026-06-07T15:30:29.266166Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26391-3
  a curric:KeyLearningPoint ;
  rdfs:label "Years from 2000 onwards are expressed as thousands."@en ;
  dcterms:modified "2026-06-07T15:30:29.266170Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26391-4
  a curric:KeyLearningPoint ;
  rdfs:label """Occupations do not require an article in sentences like 'ich bin Schülerin', 'ich
  möchte Ärztin werden'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.266173Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26228-1
  a curric:KeyLearningPoint ;
  rdfs:label """For noun plural rule 4, some masculine and neuter nouns add -er with or without an
  umlaut on the vowel (ä, ö, ü)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.266312Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26228-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Wie viele ...?' means 'How many ...?'."@en ;
  dcterms:modified "2026-06-07T15:30:29.266316Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26228-3
  a curric:KeyLearningPoint ;
  rdfs:label """Numbers 1-12 in German are: eins, zwei, drei, vier, fünf, sechs, sieben, acht, neun,
  zehn, elf, zwölf."""@en ;
  dcterms:modified "2026-06-07T15:30:29.266320Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26336-1
  a curric:KeyLearningPoint ;
  rdfs:label "German [w] sounds like English [v]; German [v] sounds like English [f]."@en ;
  dcterms:modified "2026-06-07T15:30:29.267178Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26336-2
  a curric:KeyLearningPoint ;
  rdfs:label "In German words of foreign origin, [v] usually sounds like English [v]."@en ;
  dcterms:modified "2026-06-07T15:30:29.267182Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26336-3
  a curric:KeyLearningPoint ;
  rdfs:label """Some German adverbs are adjective + (er)weise, where English adverbs are adjectives
  + ly, e.g. normalerweise - normally."""@en ;
  dcterms:modified "2026-06-07T15:30:29.267188Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26336-4
  a curric:KeyLearningPoint ;
  rdfs:label """The dative case is always used after the prepositions 'aus', 'bei', 'mit', 'nach',
  'seit', 'von', and 'zu'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.267192Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26336-5
  a curric:KeyLearningPoint ;
  rdfs:label """After 'in, an, auf, vor, neben, hinter', dative is used when talking about location
  in, but accusative for movement to."""@en ;
  dcterms:modified "2026-06-07T15:30:29.267195Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26365-1
  a curric:KeyLearningPoint ;
  rdfs:label "Practising vocabulary in a range of ways deepens knowledge and understanding."@en ;
  dcterms:modified "2026-06-07T15:30:29.267440Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26365-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Möcht-' means 'would like' and can be used with a noun to say which object you
  would like."""@en ;
  dcterms:modified "2026-06-07T15:30:29.267446Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26365-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Möcht-' can be used with a second verb in the infinitive form to express what you
  would like to do."""@en ;
  dcterms:modified "2026-06-07T15:30:29.267452Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26365-4
  a curric:KeyLearningPoint ;
  rdfs:label """When 'möcht-' is used as part of a 2-verb structure, the second verb moves to the
  end of the sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.267456Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26365-5
  a curric:KeyLearningPoint ;
  rdfs:label "The determiner before the object of a sentence matches the gender and case."@en ;
  dcterms:modified "2026-06-07T15:30:29.267459Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26333-1
  a curric:KeyLearningPoint ;
  rdfs:label """The sound-symbol correspondences [eu] and [äu] have the same sound, which is
  different from [au]."""@en ;
  dcterms:modified "2026-06-07T15:30:29.267710Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26333-2
  a curric:KeyLearningPoint ;
  rdfs:label """Cognates help you understand new words more quickly, since they look or sound
  similar to words in your own language."""@en ;
  dcterms:modified "2026-06-07T15:30:29.267713Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26333-3
  a curric:KeyLearningPoint ;
  rdfs:label """It’s important to be aware of false friends - words that are similar in two
  languages but have different meanings."""@en ;
  dcterms:modified "2026-06-07T15:30:29.267717Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26333-4
  a curric:KeyLearningPoint ;
  rdfs:label """German adjectives take endings before a noun — you need to know the noun’s gender
  and case to get them right."""@en ;
  dcterms:modified "2026-06-07T15:30:29.267721Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26333-5
  a curric:KeyLearningPoint ;
  rdfs:label """The accusative case is used for the direct object, after most verbs and some
  prepositions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.267725Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26381-1
  a curric:KeyLearningPoint ;
  rdfs:label """Adding the suffix -los to German nouns creates adjectives with the English
  equivalent -less or the meaning 'without'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268387Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26381-2
  a curric:KeyLearningPoint ;
  rdfs:label """Relative clauses add information about the noun in a main clause without starting
  another sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268393Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26381-3
  a curric:KeyLearningPoint ;
  rdfs:label """German subject relative clauses start with a relative pronoun, 'der', 'die', 'das',
  'die' and end with a verb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268397Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26381-4
  a curric:KeyLearningPoint ;
  rdfs:label """Relative clauses can be embedded in main clauses, with commas before and after the
  clause."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268401Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26385-1
  a curric:KeyLearningPoint ;
  rdfs:label """Some sound-symbol correspondences are written differently, but sound the same, e.g.,
  [äu] and [eu]."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268517Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26385-2
  a curric:KeyLearningPoint ;
  rdfs:label """Notice verb endings and use surrounding context to help identify the subject of a
  sentence using a form of 'you'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268521Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26385-3
  a curric:KeyLearningPoint ;
  rdfs:label """The 'wir', 'sie/Sie' imperfect tense forms of 'haben' are both 'hatten'. For 'sein'
  they are both 'waren'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268525Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26385-4
  a curric:KeyLearningPoint ;
  rdfs:label "The 'ihr' imperfect tense form of 'haben' is 'hattet'. For 'sein' it is 'wart'."@en ;
  dcterms:modified "2026-06-07T15:30:29.268528Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26385-5
  a curric:KeyLearningPoint ;
  rdfs:label """The subject pronoun 'sie' can mean 'she, it' or 'they'. With a capital letter, 'Sie'
  is formal 'you'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268532Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26326-1
  a curric:KeyLearningPoint ;
  rdfs:label """German [ch] is two sounds, hard and soft, depending on the preceding vowel. [ch] and
  [ck] are different sounds."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269176Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26326-2
  a curric:KeyLearningPoint ;
  rdfs:label """Word patterns can help you understand unfamiliar words in a text, e.g., German words
  with -cht may be -ght in English."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269181Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26326-3
  a curric:KeyLearningPoint ;
  rdfs:label """It helps to think creatively; some words have second meanings which are related to
  the meaning you already know."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269185Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26326-4
  a curric:KeyLearningPoint ;
  rdfs:label """Vocabulary and grammar knowledge (e.g., word order and word forms) help to work out
  the meaning of unknown words."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269191Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26321-1
  a curric:KeyLearningPoint ;
  rdfs:label """[er] is usually stressed when it's part of the first syllable of a word or a single
  syllable word e.g. Herz, er, lernen."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269231Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26321-2
  a curric:KeyLearningPoint ;
  rdfs:label "[er] is most often unstressed when it is is at the end of a word e.g. Bruder."@en ;
  dcterms:modified "2026-06-07T15:30:29.269235Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26321-3
  a curric:KeyLearningPoint ;
  rdfs:label """Adding the suffix -heit to certain (though not all) adjectives creates nouns,
  usually meaning adjective + -ity or -ness."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269239Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26321-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Unser' and 'ihr' are possessive adjectives; 'unser' means 'our' and 'ihr' means
  'their'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269242Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26321-5
  a curric:KeyLearningPoint ;
  rdfs:label """Possessive adjectives 'unser' and 'ihr' change their spelling to agree with gender
  of the noun and the case."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269246Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26297-1
  a curric:KeyLearningPoint ;
  rdfs:label """Learning new words requires practice in a range of ways, e.g., the look, cover,
  write, check method and self-testing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269292Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26297-2
  a curric:KeyLearningPoint ;
  rdfs:label """[er] is two common sounds in German, which need to be practised regularly in reading
  aloud, speaking and writing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269296Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26297-3
  a curric:KeyLearningPoint ;
  rdfs:label """The 3rd person singular perfect tense uses 'hat' or 'ist' with a past participle to
  say what he or she did or has done."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269300Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26297-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Durch' is a preposition meaning 'through' and is always followed by the
  accusative."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269303Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26223-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Es gibt' means 'there is' or 'there are' and 'viele' means 'lots of' or 'many'."@en ;
  dcterms:modified "2026-06-07T15:30:29.271178Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26223-2
  a curric:KeyLearningPoint ;
  rdfs:label """[ü] can be either short (followed by 2 or more consonants) or long (followed by a
  single consonant or 'h')."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271181Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26223-3
  a curric:KeyLearningPoint ;
  rdfs:label """For noun plural rule 1, most masculine and neuter nouns add -e to the end and an
  umlaut on the vowel (ä,ö, ü)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271185Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26223-4
  a curric:KeyLearningPoint ;
  rdfs:label """For noun plural rule 2, words ending in -el, -en or -er are often the same in the
  plural."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271189Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26223-5
  a curric:KeyLearningPoint ;
  rdfs:label """‘O Tannenbaum’ is a popular German Christmas song and translates as ‘O fir
  tree’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271195Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26355-1
  a curric:KeyLearningPoint ;
  rdfs:label """Numbers 20 and above are formed as unit + 'und' + ten, e.g., 21 -
  'einundzwanzig'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271199Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26355-2
  a curric:KeyLearningPoint ;
  rdfs:label """There are a number of rules for forming noun plurals which should be learnt and
  practised."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271203Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26355-3
  a curric:KeyLearningPoint ;
  rdfs:label """Encountering previously taught language when listening and reading in German
  develops our comprehension."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271207Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26355-4
  a curric:KeyLearningPoint ;
  rdfs:label """Awareness of register helps us choose words and structures suited to spoken or
  written language."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271211Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26222-1
  a curric:KeyLearningPoint ;
  rdfs:label """[ü] can be either short (followed by 2 or more consonants) or long (followed by a
  single consonant or 'h')."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271477Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26222-2
  a curric:KeyLearningPoint ;
  rdfs:label "For all plural nouns, the German word for 'the' is 'die'."@en ;
  dcterms:modified "2026-06-07T15:30:29.271481Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26222-3
  a curric:KeyLearningPoint ;
  rdfs:label """For noun plural rule 1, most masculine and neuter nouns add -e to the end and an
  umlaut to the vowel."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271485Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26222-4
  a curric:KeyLearningPoint ;
  rdfs:label """For noun plural rule 2, words ending in -el, -en or -er are often the same in the
  plural."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271488Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26420-1
  a curric:KeyLearningPoint ;
  rdfs:label """Frequent reading aloud and transcription can aid fluency in both speaking and
  comprehension."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271492Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26420-2
  a curric:KeyLearningPoint ;
  rdfs:label """When discussing past goals, use the perfect for most verbs, but the imperfect for
  modals."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271496Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26420-3
  a curric:KeyLearningPoint ;
  rdfs:label """For future goals, the present tense can be used to express future intentions, with a
  future time phrase."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271499Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26420-4
  a curric:KeyLearningPoint ;
  rdfs:label """The word 'als' can mean 'when' in the past tense, 'as a' (role), or 'than' in
  comparisons."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271503Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26420-5
  a curric:KeyLearningPoint ;
  rdfs:label """Translation into and from German requires attention to vocabulary, tenses, word
  order, accuracy, and careful checking."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271507Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26255-1
  a curric:KeyLearningPoint ;
  rdfs:label "There is a German-speaking community in Namibia."@en ;
  dcterms:modified "2026-06-07T15:30:29.271993Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26255-2
  a curric:KeyLearningPoint ;
  rdfs:label "Verb endings show who is doing an action."@en ;
  dcterms:modified "2026-06-07T15:30:29.271997Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26255-3
  a curric:KeyLearningPoint ;
  rdfs:label """Subject pronouns represent the person, people or thing(s) doing the verb and have
  specific verb endings."""@en ;
  dcterms:modified "2026-06-07T15:30:29.272001Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26255-4
  a curric:KeyLearningPoint ;
  rdfs:label """Verb endings for weak verbs are ‘ich’ -e, ‘du’ -st, ‘sie, er, es’ -t, ‘wir’ -en and
  ‘sie’ (they) -en."""@en ;
  dcterms:modified "2026-06-07T15:30:29.272004Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26255-5
  a curric:KeyLearningPoint ;
  rdfs:label """Possessive adjectives show who possesses something, and must match the noun in
  gender and number."""@en ;
  dcterms:modified "2026-06-07T15:30:29.272008Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26226-1
  a curric:KeyLearningPoint ;
  rdfs:label "[ö] can be either long like in 'schön' or short like in 'plötzlich'."@en ;
  dcterms:modified "2026-06-07T15:30:29.272870Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26226-2
  a curric:KeyLearningPoint ;
  rdfs:label "In German, subject pronouns tell us the grammatical gender of the subject."@en ;
  dcterms:modified "2026-06-07T15:30:29.272874Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26226-3
  a curric:KeyLearningPoint ;
  rdfs:label """German has three words for the subject pronoun 'it' - masculine 'er', feminine 'sie'
  and neuter 'es'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.272878Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26270-1
  a curric:KeyLearningPoint ;
  rdfs:label """A strong verb has a vowel change in the verb stem of the 2nd and 3rd person singular
  forms."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273520Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26270-2
  a curric:KeyLearningPoint ;
  rdfs:label """Modal verbs (e.g., 'können') are used with an infinitive, which is placed at the end
  of the sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273523Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26270-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Jed-' means 'every'. Use the same ending as the definite article if the noun is the
  subject: ‘jeder', 'jede', 'jedes’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273527Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26270-4
  a curric:KeyLearningPoint ;
  rdfs:label """When a masculine noun is the object in the sentence, use 'jeden'. The feminine and
  neuter forms remain unchanged."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273531Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26270-5
  a curric:KeyLearningPoint ;
  rdfs:label """Dictogloss tasks help you practise language through summarising and reproducing
  language you have read or heard."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273535Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26318-1
  a curric:KeyLearningPoint ;
  rdfs:label "[z] is pronounced as in 'Zug' and [s-] is pronounced as in 'sollen'."@en ;
  dcterms:modified "2026-06-07T15:30:29.273539Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26318-2
  a curric:KeyLearningPoint ;
  rdfs:label """Separable verbs have a prefix and a base verb, which uses the same endings as other
  verbs in the present tense."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273542Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26318-3
  a curric:KeyLearningPoint ;
  rdfs:label """In questions as well as statements with separable verbs, the prefix moves to the end
  of the sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273546Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26318-4
  a curric:KeyLearningPoint ;
  rdfs:label """Listening carefully to questions, including question words, helps with understanding
  and forming suitable responses."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273552Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26376-1
  a curric:KeyLearningPoint ;
  rdfs:label "Regular practice of a range of phonic rules supports pronunciation skills."@en ;
  dcterms:modified "2026-06-07T15:30:29.274014Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26376-2
  a curric:KeyLearningPoint ;
  rdfs:label "The Leitner System is a powerful tool for learning vocabulary effectively."@en ;
  dcterms:modified "2026-06-07T15:30:29.274018Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26376-3
  a curric:KeyLearningPoint ;
  rdfs:label """Future intentions can be expressed using 'werden', modal, and other verbs like
  'vorhaben' and 'planen' plus infinitive."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274023Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26376-4
  a curric:KeyLearningPoint ;
  rdfs:label """Verbs like 'vorhaben', 'planen' and 'es ist' plus adjective need a comma and then
  'zu' before the second verb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274027Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26376-5
  a curric:KeyLearningPoint ;
  rdfs:label """'Werden' and modal verbs like 'wollen', 'können', 'dürfen' and 'müssen' do not need
  'zu' before the second verb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274031Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26332-1
  a curric:KeyLearningPoint ;
  rdfs:label """In two-verb structures, the 2nd verb is in the infinitive, at the end of the
  sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274035Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26332-2
  a curric:KeyLearningPoint ;
  rdfs:label "In two-verb structures, most verbs add 'zu' before the infinitive verb."@en ;
  dcterms:modified "2026-06-07T15:30:29.274041Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26332-3
  a curric:KeyLearningPoint ;
  rdfs:label """A comma separates the verb phrases in two-verb structures, e.g., 'Ich plane, Gemüse
  zu essen'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274045Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26332-4
  a curric:KeyLearningPoint ;
  rdfs:label """Future tense sentences with 'werden', like modal sentences, do not require 'zu'
  before the infinitive."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274049Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26300-1
  a curric:KeyLearningPoint ;
  rdfs:label "The sounds [a] and [ä] are pronounced differently."@en ;
  dcterms:modified "2026-06-07T15:30:29.274338Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26300-2
  a curric:KeyLearningPoint ;
  rdfs:label """In the present tense, the verb ending changes depending on who is doing the
  action."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274342Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26300-3
  a curric:KeyLearningPoint ;
  rdfs:label """Some present tense verb stems change their vowel in the 'du, er and sie' forms,
  e.g., 'treffen' becomes 'du triffst'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274346Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26300-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Welch-' means which and is commonly used in questions. It agrees with the noun it
  is linked to like other adjectives."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274349Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26300-5
  a curric:KeyLearningPoint ;
  rdfs:label """'Gern' means 'gladly' and is used to express liking for different actions, e.g.'
  'Ich spiele gern Fußball'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274353Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26339-1
  a curric:KeyLearningPoint ;
  rdfs:label """The gender of a noun needs to be learnt, together with its meaning, spelling and
  sound."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274390Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26339-2
  a curric:KeyLearningPoint ;
  rdfs:label """Nominative adjective endings are used when the noun is the subject, the person or
  thing doing the action."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274393Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26339-3
  a curric:KeyLearningPoint ;
  rdfs:label """Accusative adjective endings are used when the noun is the direct object, directly
  receiving the action."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274397Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26339-4
  a curric:KeyLearningPoint ;
  rdfs:label """'War', 'hatte' and 'es gab' are imperfect tense verbs used to describe what things
  were like."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274403Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26213-1
  a curric:KeyLearningPoint ;
  rdfs:label """[o] can be either short (followed by 2 consonants) or long (followed by a single
  consonant, double vowel or 'h')."""@en ;
  dcterms:modified "2026-06-07T15:30:29.278705Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26213-2
  a curric:KeyLearningPoint ;
  rdfs:label """Remove 'en' from the infinitive to create the verb stem and add 't' for the 3rd
  person singular of most verbs in German."""@en ;
  dcterms:modified "2026-06-07T15:30:29.278708Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26213-3
  a curric:KeyLearningPoint ;
  rdfs:label "Use 'er' for he and 'sie' for she with the 3rd person singular of the verb."@en ;
  dcterms:modified "2026-06-07T15:30:29.278712Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26213-4
  a curric:KeyLearningPoint ;
  rdfs:label """If the verb stem ends in –d or –t, an –e is added so that you can hear the verb
  ending –t."""@en ;
  dcterms:modified "2026-06-07T15:30:29.278718Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26225-1
  a curric:KeyLearningPoint ;
  rdfs:label """[ä] can be either short (followed by 2 or more consonants) or long (followed by a
  single consonant or 'h')."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279342Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26225-2
  a curric:KeyLearningPoint ;
  rdfs:label """For noun plural rule 1, most masculine and neuter nouns add -e to the end and an
  umlaut on the vowel (ä, ö, ü)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279346Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26225-3
  a curric:KeyLearningPoint ;
  rdfs:label """For noun plural rule 2, words ending in -el, -en or -er are often the same in the
  plural."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279352Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26225-4
  a curric:KeyLearningPoint ;
  rdfs:label "For noun plural rule 3, most feminine nouns add '-n' or '-en'."@en ;
  dcterms:modified "2026-06-07T15:30:29.279357Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26353-1
  a curric:KeyLearningPoint ;
  rdfs:label """To say 'you' in German, use 'du' (singular), 'Sie' (formal), ihr (plural) or 'man'
  (you, one or 'people')."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279635Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26353-2
  a curric:KeyLearningPoint ;
  rdfs:label """In the present tense, strong German verbs change their vowel in the 'du' and
  'er/sie/es/man' forms."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279639Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26353-3
  a curric:KeyLearningPoint ;
  rdfs:label """Strong verbs stems with 'e' change to 'i' or 'ie'. Stems with 'a' change to 'ä' or
  'au' to 'äu'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279642Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26323-1
  a curric:KeyLearningPoint ;
  rdfs:label "Short [e] and [ä] are pronounced the same."@en ;
  dcterms:modified "2026-06-07T15:30:29.280966Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26323-2
  a curric:KeyLearningPoint ;
  rdfs:label """In some singular nouns with short [a], the vowel changes to short [ä] in the
  plural."""@en ;
  dcterms:modified "2026-06-07T15:30:29.280971Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26323-3
  a curric:KeyLearningPoint ;
  rdfs:label """Using a range of skills to develop vocabulary is an important part of language
  learning."""@en ;
  dcterms:modified "2026-06-07T15:30:29.280975Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26323-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Seit' can mean 'since' when used with a point in time, or 'for' when used with a
  time span."""@en ;
  dcterms:modified "2026-06-07T15:30:29.280979Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26323-5
  a curric:KeyLearningPoint ;
  rdfs:label """Seit is followed by the dative and is used with the present tense in German, though
  in English we say 'have been -ing'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.280982Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26214-1
  a curric:KeyLearningPoint ;
  rdfs:label """[i] can be either short (followed by 2 consonants) or long (followed by a single
  consonant, double vowel or 'h')."""@en ;
  dcterms:modified "2026-06-07T15:30:29.287220Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26214-2
  a curric:KeyLearningPoint ;
  rdfs:label """Remove 'en' from the infinitive and add 'e' for the 1st person singular of weak
  verbs in German."""@en ;
  dcterms:modified "2026-06-07T15:30:29.287223Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26214-3
  a curric:KeyLearningPoint ;
  rdfs:label """Remove 'en' from the infinitive and add 't' for the 3rd person singular of weak
  verbs in German."""@en ;
  dcterms:modified "2026-06-07T15:30:29.287227Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26214-4
  a curric:KeyLearningPoint ;
  rdfs:label """Practise using common high frequency verbs with varied vocabulary in different
  contexts (at school and at home)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.287231Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26372-1
  a curric:KeyLearningPoint ;
  rdfs:label """Using exclamations to give conversational reactions can make our German sound more
  natural."""@en ;
  dcterms:modified "2026-06-07T15:30:29.290789Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26372-2
  a curric:KeyLearningPoint ;
  rdfs:label """Many verbs can be used reflexively to show the action is being done to oneself,
  e.g., 'sich waschen' - 'to have a wash'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.290793Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26372-3
  a curric:KeyLearningPoint ;
  rdfs:label """The meaning of a verb may change slightly when used reflexively, e.g., 'Sie setzt
  sie/sich hin': She puts her/sits down."""@en ;
  dcterms:modified "2026-06-07T15:30:29.290797Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26372-4
  a curric:KeyLearningPoint ;
  rdfs:label """Reflexive pronouns are 'mich' myself, 'dich' yourself and 'sich' him/her/itself.
  'Mich/dich' also mean 'me/you'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.290801Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26372-5
  a curric:KeyLearningPoint ;
  rdfs:label """Context is important when understanding the intended meaning of pronouns like 'mich'
  and 'dich'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.290805Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26377-1
  a curric:KeyLearningPoint ;
  rdfs:label """Seeing vocabulary in a range of contexts is a good way to support effective
  learning."""@en ;
  dcterms:modified "2026-06-07T15:30:29.291031Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26377-2
  a curric:KeyLearningPoint ;
  rdfs:label """Chinese New Year is celebrated every January/February by around 120,000 people of
  Chinese descent who live in Germany."""@en ;
  dcterms:modified "2026-06-07T15:30:29.291037Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26377-3
  a curric:KeyLearningPoint ;
  rdfs:label "Conjunctions like ‘denn’ and ‘aber’ do not cause a change in word order."@en ;
  dcterms:modified "2026-06-07T15:30:29.291042Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26377-4
  a curric:KeyLearningPoint ;
  rdfs:label """Subordinating conjunctions like ‘weil’ and ‘obwohl’ send the verb to the end of the
  clause (word order 3)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.291046Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26377-5
  a curric:KeyLearningPoint ;
  rdfs:label """In two-verb structures with subordinating conjunctions, the short form verb is after
  the infinitive at the end."""@en ;
  dcterms:modified "2026-06-07T15:30:29.291050Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26210-1
  a curric:KeyLearningPoint ;
  rdfs:label "[ie] sounds like the [ie] in 'Liebe'."@en ;
  dcterms:modified "2026-06-07T15:30:29.291139Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26210-2
  a curric:KeyLearningPoint ;
  rdfs:label """The subject and verb of a German sentence swap places to turn a statement into a
  closed (yes/no) question."""@en ;
  dcterms:modified "2026-06-07T15:30:29.291143Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26210-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Wie sagt man ...?' is a key question starter to find out how to say a word in
  German."""@en ;
  dcterms:modified "2026-06-07T15:30:29.291147Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26210-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Wie schreibt man ...?' is a key question starter to find out how to spell a word in
  German."""@en ;
  dcterms:modified "2026-06-07T15:30:29.291151Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26302-1
  a curric:KeyLearningPoint ;
  rdfs:label "Sound-symbol correspondence [ig] is pronounced as in 'richtig'."@en ;
  dcterms:modified "2026-06-07T15:30:29.291725Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26302-2
  a curric:KeyLearningPoint ;
  rdfs:label """Practising vocabulary regularly is important to help understanding in listening and
  reading."""@en ;
  dcterms:modified "2026-06-07T15:30:29.291728Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26302-3
  a curric:KeyLearningPoint ;
  rdfs:label """Inversion questions are formed by inverting the subject and the verb in a statement,
  e.g., 'Kommst du aus Deutschland?'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.291732Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26302-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Nicht' usually goes before the element it negates; if negating a whole, short
  sentence, it tends to go at the end."""@en ;
  dcterms:modified "2026-06-07T15:30:29.291736Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26375-1
  a curric:KeyLearningPoint ;
  rdfs:label "Practising new vocabulary in a range of ways supports effective learning."@en ;
  dcterms:modified "2026-06-07T15:30:29.291748Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26375-2
  a curric:KeyLearningPoint ;
  rdfs:label """When verbs are used reflexively, the person doing the action is also the receiver of
  the action."""@en ;
  dcterms:modified "2026-06-07T15:30:29.291752Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26375-3
  a curric:KeyLearningPoint ;
  rdfs:label "‘Halb’ means half, ‘nach’ means past and ‘vor’ means to in 12-hour clock times."@en ;
  dcterms:modified "2026-06-07T15:30:29.291756Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26375-4
  a curric:KeyLearningPoint ;
  rdfs:label """In German, ‘half past' is expressed as half of the next hour, e.g., ‘halb acht’ is
  7:30."""@en ;
  dcterms:modified "2026-06-07T15:30:29.291760Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26375-5
  a curric:KeyLearningPoint ;
  rdfs:label """Learning about cultural traditions strengthens language learning, improving
  comprehension and cultural knowledge."""@en ;
  dcterms:modified "2026-06-07T15:30:29.291766Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26317-1
  a curric:KeyLearningPoint ;
  rdfs:label """Regular practice of different sound-symbol correspondences (SSCs) supports listening
  and speaking skills."""@en ;
  dcterms:modified "2026-06-07T15:30:29.291795Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26317-2
  a curric:KeyLearningPoint ;
  rdfs:label """Separable verbs are made up of a prefix and a base verb, e.g., ‘einkaufen’ - 'to
  shop, shopping'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.291799Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26317-3
  a curric:KeyLearningPoint ;
  rdfs:label """Present tense separable verbs match verb and subject, using the same endings as
  other verbs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.291804Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26317-4
  a curric:KeyLearningPoint ;
  rdfs:label """The prefix of a separable verb usually moves to the end of the sentence in the
  present tense."""@en ;
  dcterms:modified "2026-06-07T15:30:29.291807Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26289-1
  a curric:KeyLearningPoint ;
  rdfs:label """'Weil' and 'denn' both mean 'because'. Both are conjunctions and connect clauses or
  sentences."""@en ;
  dcterms:modified "2026-06-07T15:30:29.291827Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26289-2
  a curric:KeyLearningPoint ;
  rdfs:label "In German there is always a comma before 'weil' or 'denn'."@en ;
  dcterms:modified "2026-06-07T15:30:29.291831Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26289-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Denn' is followed by word order 1 (WO1), subject-verb word order."@en ;
  dcterms:modified "2026-06-07T15:30:29.291837Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26289-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Weil' is followed by word order 3 (WO3), where the verb goes to the end of the
  sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.291841Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26289-5
  a curric:KeyLearningPoint ;
  rdfs:label "Use 'weil' and 'denn' to give reasons for likes and dislikes."@en ;
  dcterms:modified "2026-06-07T15:30:29.291845Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26337-1
  a curric:KeyLearningPoint ;
  rdfs:label """[y] commonly sounds like [ü], e.g., 'typisch'. In English words like 'Yoga' and
  'Baby', [y] is pronounced as in English."""@en ;
  dcterms:modified "2026-06-07T15:30:29.294354Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26337-2
  a curric:KeyLearningPoint ;
  rdfs:label """Words ending in -ic/-ical in English often end in -isch in German, e.g.,
  'typisch'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.294358Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26337-3
  a curric:KeyLearningPoint ;
  rdfs:label "There are three different ways to say 'you' in German: 'du', 'Sie' and 'man'."@en ;
  dcterms:modified "2026-06-07T15:30:29.294362Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26337-4
  a curric:KeyLearningPoint ;
  rdfs:label """The perfect tense is made up of a part of ‘haben’ or ‘sein’ in the present tense,
  and a past participle."""@en ;
  dcterms:modified "2026-06-07T15:30:29.294368Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26337-5
  a curric:KeyLearningPoint ;
  rdfs:label """Half past the hour is expressed as half to the next hour in German, e.g., 9:30 is
  ‘halb zehn’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.294373Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26199-1
  a curric:KeyLearningPoint ;
  rdfs:label """[a] can be short or long, but an 'e' at the end of a word is always very short, for
  example 'danke'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.301623Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26199-2
  a curric:KeyLearningPoint ;
  rdfs:label "All German nouns start with a capital letter."@en ;
  dcterms:modified "2026-06-07T15:30:29.301627Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26199-3
  a curric:KeyLearningPoint ;
  rdfs:label """German has three words for 'the': der (masculine), die (feminine) and das
  (neuter)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.301631Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26199-4
  a curric:KeyLearningPoint ;
  rdfs:label """Wo ist ..?', meaning 'Where is ... ?' is followed by the definite article and noun
  for simple location questions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.301637Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26199-5
  a curric:KeyLearningPoint ;
  rdfs:label """Simple location questions can be answered using 'ist' (is) and 'hier' (here) or 'da'
  (there)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.301645Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26201-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Sein' means 'to be, being' and 'ist' means 'is'."@en ;
  dcterms:modified "2026-06-07T15:30:29.302901Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26201-2
  a curric:KeyLearningPoint ;
  rdfs:label "When learning a noun, learn its gender and the correct word for 'the'."@en ;
  dcterms:modified "2026-06-07T15:30:29.302907Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26201-3
  a curric:KeyLearningPoint ;
  rdfs:label "Regular revisiting helps you to learn your vocabulary."@en ;
  dcterms:modified "2026-06-07T15:30:29.302912Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26201-4
  a curric:KeyLearningPoint ;
  rdfs:label """Learners can build their own repertoire (treasure trove) of vocabulary that is
  important to them."""@en ;
  dcterms:modified "2026-06-07T15:30:29.302916Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26404-1
  a curric:KeyLearningPoint ;
  rdfs:label """At the start or in the middle of words, German [g] as in 'gehen' is usually
  pronounced like the 'g' in English 'go'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.306319Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26404-2
  a curric:KeyLearningPoint ;
  rdfs:label """When [g] is the final sound in a syllable, it sounds more like 'k', as in
  'Flugzeug'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.306323Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26404-3
  a curric:KeyLearningPoint ;
  rdfs:label """A reflexive pronoun is used instead of an object when the subject is also affected
  by the action of the verb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.306327Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26404-4
  a curric:KeyLearningPoint ;
  rdfs:label """Reflexive verbs require reflexive pronouns, which replace the object in the
  sentence, as in English."""@en ;
  dcterms:modified "2026-06-07T15:30:29.306332Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26404-5
  a curric:KeyLearningPoint ;
  rdfs:label """Some verbs need prepositions to link them to a noun. Some verbs use different
  prepositions in English than German."""@en ;
  dcterms:modified "2026-06-07T15:30:29.306336Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26268-1
  a curric:KeyLearningPoint ;
  rdfs:label """[sch] is pronounced as in 'schreiben', [sp] as in 'spielen' and [st] as in
  'stark'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.309906Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26268-2
  a curric:KeyLearningPoint ;
  rdfs:label """Conversational words are used in informal situations to add emotion to a statement,
  e.g., 'Echt?' (really?!)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.309910Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26268-3
  a curric:KeyLearningPoint ;
  rdfs:label """Modal verbs (e.g., 'können') are used with an infinitive, which is placed at the end
  of the sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.309914Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26268-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Jed-' means 'every'. Use the same ending as the definite article if the noun is the
  subject: ‘jeder, jede, jedes’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.309918Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26268-5
  a curric:KeyLearningPoint ;
  rdfs:label """When a masculine noun is the object in the sentence, use 'jeden'. The feminine and
  neuter forms remain unchanged."""@en ;
  dcterms:modified "2026-06-07T15:30:29.309922Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26340-1
  a curric:KeyLearningPoint ;
  rdfs:label """Plural nouns are formed in different ways, depending on factors such as gender and
  how the singular form ends."""@en ;
  dcterms:modified "2026-06-07T15:30:29.312216Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26340-2
  a curric:KeyLearningPoint ;
  rdfs:label """Ordinal numbers indicate position or order in a list or sequence, e.g., first,
  second, third; we use them for dates."""@en ;
  dcterms:modified "2026-06-07T15:30:29.312222Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26340-3
  a curric:KeyLearningPoint ;
  rdfs:label """Questions are formed by inverting subject and verb; a question word can be added to
  create an open question."""@en ;
  dcterms:modified "2026-06-07T15:30:29.312226Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26340-4
  a curric:KeyLearningPoint ;
  rdfs:label """‘Sie’ with the correct verb form should be used when asking questions in formal
  situations."""@en ;
  dcterms:modified "2026-06-07T15:30:29.312230Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26402-1
  a curric:KeyLearningPoint ;
  rdfs:label """Final [d] (a [d] at the end of a word) sounds like [t]. Final [b] (a [b] at the end
  of a word) sounds like [p]."""@en ;
  dcterms:modified "2026-06-07T15:30:29.312234Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26402-2
  a curric:KeyLearningPoint ;
  rdfs:label """Pronouns replace nouns. Their form changes depending on whether the noun is the
  subject or object in the sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.312238Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26402-3
  a curric:KeyLearningPoint ;
  rdfs:label """Direct objects are directly affected by the action of the verb and are in the
  accusative, e.g., 'Ich sehe den Mann'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.312242Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26402-4
  a curric:KeyLearningPoint ;
  rdfs:label """Indirect objects are indirectly affected by the action of the verb and are in the
  dative case, e.g., 'Ich antworte dir'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.312246Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26402-5
  a curric:KeyLearningPoint ;
  rdfs:label """When two object nouns are in a sentence, the indirect object (in dative) precedes
  the direct object (in accusative)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.312250Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26295-1
  a curric:KeyLearningPoint ;
  rdfs:label "[a] and [o] are short when followed by two consonants, but long in other words."@en ;
  dcterms:modified "2026-06-07T15:30:29.313046Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26295-2
  a curric:KeyLearningPoint ;
  rdfs:label """‘Mit’ is used with an article in the dative to describe the manner in which a person
  travels, e.g., ‘mit dem Bus’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.313052Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26295-3
  a curric:KeyLearningPoint ;
  rdfs:label """The perfect (past) tense is formed with three parts: subject, part of ‘haben’ or
  ‘sein’ and past participle."""@en ;
  dcterms:modified "2026-06-07T15:30:29.313057Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26295-4
  a curric:KeyLearningPoint ;
  rdfs:label """‘Sein’ is used to form the perfect tense with past participles of verbs of movement
  to a destination."""@en ;
  dcterms:modified "2026-06-07T15:30:29.313061Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26250-1
  a curric:KeyLearningPoint ;
  rdfs:label "[st] is pronounced as in 'stark'. At the start of a word, it sounds like 'sht'."@en ;
  dcterms:modified "2026-06-07T15:30:29.314173Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26250-2
  a curric:KeyLearningPoint ;
  rdfs:label """Use ‘in’ (into) and ‘auf’ (onto) with accusative definite articles to describe
  movement towards something or someone."""@en ;
  dcterms:modified "2026-06-07T15:30:29.314179Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26250-3
  a curric:KeyLearningPoint ;
  rdfs:label """Use ‘in’ (in) and ‘auf’ (on) with dative definite articles to describe the location
  of something or someone."""@en ;
  dcterms:modified "2026-06-07T15:30:29.314216Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26250-4
  a curric:KeyLearningPoint ;
  rdfs:label "Accusative definite articles are 'den' (m), 'die' (f), 'das' (nt)."@en ;
  dcterms:modified "2026-06-07T15:30:29.314222Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26250-5
  a curric:KeyLearningPoint ;
  rdfs:label "Dative definite articles are 'dem' (m), 'der' (f), 'dem' (nt)."@en ;
  dcterms:modified "2026-06-07T15:30:29.314226Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26198-1
  a curric:KeyLearningPoint ;
  rdfs:label """'Hallo' is an informal greeting meaning 'hello' or 'hi' and 'Guten Tag' is a more
  formal version of 'hello'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.314246Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26198-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Wo ist?' asks 'where is?' in simple location questions."@en ;
  dcterms:modified "2026-06-07T15:30:29.314250Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26198-3
  a curric:KeyLearningPoint ;
  rdfs:label """[a] can be either short (followed by 2 consonants) or long (followed by a single
  consonant, double vowel or 'h')."""@en ;
  dcterms:modified "2026-06-07T15:30:29.314253Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26198-4
  a curric:KeyLearningPoint ;
  rdfs:label """German has three words for 'the': der (masculine), die (feminine) and das
  (neuter)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.314257Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26198-5
  a curric:KeyLearningPoint ;
  rdfs:label """Every noun in German has a grammatical gender, which is not the same as biological
  gender."""@en ;
  dcterms:modified "2026-06-07T15:30:29.314261Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26200-1
  a curric:KeyLearningPoint ;
  rdfs:label """[e] can be either short (followed by 2 consonants) or long (followed by a single
  consonant, double vowel or 'h')."""@en ;
  dcterms:modified "2026-06-07T15:30:29.314752Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26200-2
  a curric:KeyLearningPoint ;
  rdfs:label "The question word 'Was ...?' meaning 'What ...?' is used to identify things."@en ;
  dcterms:modified "2026-06-07T15:30:29.314757Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26200-3
  a curric:KeyLearningPoint ;
  rdfs:label """The verb 'sagen' means 'to say, to tell' in the infinitive and its short form 'sagt'
  means 'says, tells'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.314760Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26251-1
  a curric:KeyLearningPoint ;
  rdfs:label "[st] is pronounced as in ‘stark’. At the start of a word, it sounds like ‘sht’."@en ;
  dcterms:modified "2026-06-07T15:30:29.315416Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26251-2
  a curric:KeyLearningPoint ;
  rdfs:label """Use 'in' (into) and 'auf' (onto, to) with accusative definite articles to describe
  movement towards something/someone."""@en ;
  dcterms:modified "2026-06-07T15:30:29.315422Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26251-3
  a curric:KeyLearningPoint ;
  rdfs:label """Use 'in' (in) and 'auf' (on, at) with dative definite articles to describe the
  location of something or someone."""@en ;
  dcterms:modified "2026-06-07T15:30:29.315426Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26251-4
  a curric:KeyLearningPoint ;
  rdfs:label """Accusative definite articles are ‘den’ (m), ‘die’ (f), ‘das’ (nt) and dative forms
  are ‘dem’ (m), ‘der’ (f), ‘dem’ (nt)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.315430Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26251-5
  a curric:KeyLearningPoint ;
  rdfs:label """'Auf' can also mean 'to' or 'at', especially when referring to events or open
  spaces."""@en ;
  dcterms:modified "2026-06-07T15:30:29.315434Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26364-1
  a curric:KeyLearningPoint ;
  rdfs:label """[b] is pronounced like English 'p' when it's the final letter in a word, or followed
  by a consonant, e.g., 'der Korb'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.315541Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26364-2
  a curric:KeyLearningPoint ;
  rdfs:label "[b] sounds like English b when it's followed by a vowel, e.g., 'die Körbe'."@en ;
  dcterms:modified "2026-06-07T15:30:29.315547Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26364-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Alle' is a pronoun meaning 'everyone' or 'everybody' and is followed by a plural
  verb ending -en."""@en ;
  dcterms:modified "2026-06-07T15:30:29.315551Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26364-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Jeder' is a pronoun meaning 'everyone' or 'everybody' and is followed by a singular
  verb ending -t."""@en ;
  dcterms:modified "2026-06-07T15:30:29.315555Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26364-5
  a curric:KeyLearningPoint ;
  rdfs:label """'Jed-' is the determiner ‘every’ and its endings match the gender and case of the
  noun that follows, e.g., 'jedes Kind'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.315559Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26280-1
  a curric:KeyLearningPoint ;
  rdfs:label """'Welch-' is a determiner and question word which needs to agree with the noun it
  refers to."""@en ;
  dcterms:modified "2026-06-07T15:30:29.315864Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26280-2
  a curric:KeyLearningPoint ;
  rdfs:label "Past participles of weak and strong verbs with 'haben' are consolidated."@en ;
  dcterms:modified "2026-06-07T15:30:29.315869Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26280-3
  a curric:KeyLearningPoint ;
  rdfs:label """The form of 'haben' changes when talking about different people but the past
  participle stays the same."""@en ;
  dcterms:modified "2026-06-07T15:30:29.315872Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26280-4
  a curric:KeyLearningPoint ;
  rdfs:label """For questions in the past tense, swap 'haben' and the subject. The past participle
  stays at the end of the sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.315876Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26374-1
  a curric:KeyLearningPoint ;
  rdfs:label """Idioms are expressions that often don’t have a literal meaning and may not translate
  directly into another language."""@en ;
  dcterms:modified "2026-06-07T15:30:29.316225Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26374-2
  a curric:KeyLearningPoint ;
  rdfs:label """Several German idioms include ‘Wurst’ because sausage is a culturally important
  German food, popular at many festivals."""@en ;
  dcterms:modified "2026-06-07T15:30:29.316230Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26374-3
  a curric:KeyLearningPoint ;
  rdfs:label """Stress is part of intonation and syllable stress refers to the syllable in a word
  that is spoken more strongly."""@en ;
  dcterms:modified "2026-06-07T15:30:29.316234Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26374-4
  a curric:KeyLearningPoint ;
  rdfs:label """Plural reflexive pronouns 'uns', 'euch' and 'sich' make verbs reflexive when subject
  and object are the same."""@en ;
  dcterms:modified "2026-06-07T15:30:29.316237Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26374-5
  a curric:KeyLearningPoint ;
  rdfs:label """In sentences where subject and object are different, 'uns' (us) and 'euch' (you all)
  are object pronouns."""@en ;
  dcterms:modified "2026-06-07T15:30:29.316241Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26206-1
  a curric:KeyLearningPoint ;
  rdfs:label "[w] sounds like the English [v]."@en ;
  dcterms:modified "2026-06-07T15:30:29.317091Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26206-2
  a curric:KeyLearningPoint ;
  rdfs:label "The question word 'Wer?' means 'Who?'."@en ;
  dcterms:modified "2026-06-07T15:30:29.317095Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26206-3
  a curric:KeyLearningPoint ;
  rdfs:label "The question words 'Was?', 'Wo?' and 'Wie?' mean 'What?', 'Where?' and 'How?'."@en ;
  dcterms:modified "2026-06-07T15:30:29.317099Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26206-4
  a curric:KeyLearningPoint ;
  rdfs:label """Two nouns can combine to form a compound noun, which takes the gender of the 2nd
  noun; for example, 'der Fußball'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.317103Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26312-1
  a curric:KeyLearningPoint ;
  rdfs:label """Knowing sound-symbol correspondences well helps develop reading and transcription
  skills."""@en ;
  dcterms:modified "2026-06-07T15:30:29.318032Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26312-2
  a curric:KeyLearningPoint ;
  rdfs:label """The nominative is used for articles and adjectives following ‘sein’, e.g., ‘das ist
  ein großes Schloss’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.318068Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26312-3
  a curric:KeyLearningPoint ;
  rdfs:label """The accusative is used for articles and adjectives following most other verbs, e.g.,
  'Ich habe einen kleinen Hund'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.318073Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26312-4
  a curric:KeyLearningPoint ;
  rdfs:label "The imperfect tense is used to describe the way things were in in the past."@en ;
  dcterms:modified "2026-06-07T15:30:29.318078Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26235-1
  a curric:KeyLearningPoint ;
  rdfs:label """[er] can be stressed or unstressed. It is stressed when it is the first syllable in
  the word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319139Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26235-2
  a curric:KeyLearningPoint ;
  rdfs:label "Closed questions are formed by swapping the verb and subject in a statement."@en ;
  dcterms:modified "2026-06-07T15:30:29.319143Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26235-3
  a curric:KeyLearningPoint ;
  rdfs:label """Open questions are formed by placing a question word directly in front of the verb
  in a closed question."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319147Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26235-4
  a curric:KeyLearningPoint ;
  rdfs:label """Making notes as you listen and reconstructing the text in a dictagloss task
  practises vocabulary and grammar knowledge."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319151Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26331-1
  a curric:KeyLearningPoint ;
  rdfs:label "Regular practice of sound-symbol correspondences helps to improve fluency."@en ;
  dcterms:modified "2026-06-07T15:30:29.320139Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26331-2
  a curric:KeyLearningPoint ;
  rdfs:label """Some German words have multiple meanings. Context helps you work out which meaning
  is intended."""@en ;
  dcterms:modified "2026-06-07T15:30:29.320176Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26331-3
  a curric:KeyLearningPoint ;
  rdfs:label """The present tense of 'werden' with an infinitive at sentence end forms the future,
  meaning ‘will do’ or ‘going to do’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.320181Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26331-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Werden' is irregular. The 'ich' form of 'werden' is 'werde', 'du' form 'wirst',
  'sie, er, es' form 'wird'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.320187Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26331-5
  a curric:KeyLearningPoint ;
  rdfs:label """The German 'will' comes from 'wollen' and means 'want'. Do not confuse this with the
  future tense."""@en ;
  dcterms:modified "2026-06-07T15:30:29.320192Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26240-1
  a curric:KeyLearningPoint ;
  rdfs:label """A strong verb changes its vowel in the verb stem of the 'sie', 'er', 'es' forms of
  the verb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.320215Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26240-2
  a curric:KeyLearningPoint ;
  rdfs:label "There is no vowel change in the ‘ich’ form of strong verbs."@en ;
  dcterms:modified "2026-06-07T15:30:29.320219Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26240-3
  a curric:KeyLearningPoint ;
  rdfs:label "Only verbs with a 'a' or 'e' in their verb stem can be strong."@en ;
  dcterms:modified "2026-06-07T15:30:29.320223Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26240-4
  a curric:KeyLearningPoint ;
  rdfs:label "Verb stems with 'a' change to 'ä' and those with 'e' become 'i' or 'ie'."@en ;
  dcterms:modified "2026-06-07T15:30:29.320227Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26240-5
  a curric:KeyLearningPoint ;
  rdfs:label "Use reference materials to learn which verbs are strong."@en ;
  dcterms:modified "2026-06-07T15:30:29.320231Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26398-1
  a curric:KeyLearningPoint ;
  rdfs:label "The sound symbol correspondence (SSC)  [sch] sounds like the English 'sh'."@en ;
  dcterms:modified "2026-06-07T15:30:29.321155Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26398-2
  a curric:KeyLearningPoint ;
  rdfs:label "The SSC [sp] starts with the English sound 'sh' before the 'p'."@en ;
  dcterms:modified "2026-06-07T15:30:29.321161Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26398-3
  a curric:KeyLearningPoint ;
  rdfs:label """The SSC [st] starts with the English should 'sh' before the 't' at the start of a
  word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.321165Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26398-4
  a curric:KeyLearningPoint ;
  rdfs:label """Add 's' to days/times of day to convert from noun to adverb: 'am Samstag' (on
  Saturday) becomes 'samstags' (Saturdays)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.321169Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26398-5
  a curric:KeyLearningPoint ;
  rdfs:label """German adverbs in a sentence follow the order time before manner before place,
  abbreviated to TMP."""@en ;
  dcterms:modified "2026-06-07T15:30:29.321173Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26242-1
  a curric:KeyLearningPoint ;
  rdfs:label "[eu] is pronounced as in 'Deutschland' and sounds the same as [äu]."@en ;
  dcterms:modified "2026-06-07T15:30:29.321996Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26242-2
  a curric:KeyLearningPoint ;
  rdfs:label """Strong verbs change the vowel in their stem in the 2nd and 3rd person singular
  forms."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322000Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26242-3
  a curric:KeyLearningPoint ;
  rdfs:label "Only verbs with an 'a' or e' in their stem can be strong."@en ;
  dcterms:modified "2026-06-07T15:30:29.322004Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26242-4
  a curric:KeyLearningPoint ;
  rdfs:label """Swap the position of the subject and verb in a statement and add a question word to
  the start to form an open question."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322008Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26252-1
  a curric:KeyLearningPoint ;
  rdfs:label "[ie] is pronounced as in  'Liebe' and like the English 'ee' sound."@en ;
  dcterms:modified "2026-06-07T15:30:29.322209Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26252-2
  a curric:KeyLearningPoint ;
  rdfs:label "[ei] is pronounced as in 'frei' and like the English word 'eye'."@en ;
  dcterms:modified "2026-06-07T15:30:29.322212Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26252-3
  a curric:KeyLearningPoint ;
  rdfs:label """A possessive adjective describes a noun by saying who possesses (owns) it, e.g.,
  'meine Schwester'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322216Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26252-4
  a curric:KeyLearningPoint ;
  rdfs:label "Possessive adjectives must agree with the gender of the noun that follows."@en ;
  dcterms:modified "2026-06-07T15:30:29.322224Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26252-5
  a curric:KeyLearningPoint ;
  rdfs:label "'Dein' means 'your', 'sein' means 'his' and 'ihr' means 'her'."@en ;
  dcterms:modified "2026-06-07T15:30:29.322228Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26386-1
  a curric:KeyLearningPoint ;
  rdfs:label """Vowels are short if followed by more than one consonant. They are long before 'h', a
  single consonant, or if doubled."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322233Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26386-2
  a curric:KeyLearningPoint ;
  rdfs:label """The prefixes 'Lieblings-' and 'Haupt- can be added to a noun to form a new compound
  noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322269Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26386-3
  a curric:KeyLearningPoint ;
  rdfs:label "Germany is home to a large number of residents with a migration background."@en ;
  dcterms:modified "2026-06-07T15:30:29.322274Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26386-4
  a curric:KeyLearningPoint ;
  rdfs:label """Remove any umlauts from the stem of a modal verb and add '-te' to form its 1st and
  3rd person singular imperfect tense."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322278Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26386-5
  a curric:KeyLearningPoint ;
  rdfs:label """Remove any umlauts from the stem of a modal verb and add '-test' to form its 2nd
  person singular imperfect tense."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322282Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26220-1
  a curric:KeyLearningPoint ;
  rdfs:label """[u] can be either short (followed by 2 or more consonants) or long (followed by a
  single consonant or 'h')."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322788Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26220-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Buch' is an exception, with a long [u] before 2 consonants."@en ;
  dcterms:modified "2026-06-07T15:30:29.322794Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26220-3
  a curric:KeyLearningPoint ;
  rdfs:label """There is only one present tense in German: 'ich lerne' means 'I learn' and 'I am
  learning'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322798Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26378-1
  a curric:KeyLearningPoint ;
  rdfs:label """Relative clauses add information about the noun in the main clause, without starting
  another sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322804Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26378-2
  a curric:KeyLearningPoint ;
  rdfs:label """English uses relative pronouns ‘who’, ‘that’, ‘which’, while German uses the
  definite article that matches the noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322808Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26378-3
  a curric:KeyLearningPoint ;
  rdfs:label """In German the relative pronoun kicks the verb to the end of the relative clause;
  this is called word order three (WO3)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322812Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26378-4
  a curric:KeyLearningPoint ;
  rdfs:label """Use indefinite pronouns 'jemand' ('someone') or 'niemand' ('no one') instead of a
  noun when the exact person is unknown."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322816Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26378-5
  a curric:KeyLearningPoint ;
  rdfs:label """When using 'jemand' or 'niemand' in subject relative clauses, use the relative
  pronoun 'der' as for masculine nouns."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322820Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26227-1
  a curric:KeyLearningPoint ;
  rdfs:label """[o] and [ö] need practice to distinguish between singular and plural forms of some
  nouns, e.g., 'Vogel' and 'Vögel'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322924Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26227-2
  a curric:KeyLearningPoint ;
  rdfs:label """Masculine and neuter nouns ending in -el, -en and -er don’t usually change in the
  plural form."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322928Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26227-3
  a curric:KeyLearningPoint ;
  rdfs:label """A few -el, -en and -er plurals do add an umlaut to ‘a’, ‘o’, and ‘u’, e.g.,
  'Vögel'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322932Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26227-4
  a curric:KeyLearningPoint ;
  rdfs:label "To say 'they' in German, use 'sie' for all genders."@en ;
  dcterms:modified "2026-06-07T15:30:29.322936Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26227-5
  a curric:KeyLearningPoint ;
  rdfs:label """The subject pronoun 'sie' means both 'it' (feminine) and 'they'. The verb form tells
  us what is being talked about."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322940Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26301-1
  a curric:KeyLearningPoint ;
  rdfs:label """SSC [g] at the end of a word is pronounced as in 'Berg', or at the start or middle
  as in 'Berge'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.323215Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26301-2
  a curric:KeyLearningPoint ;
  rdfs:label """Most German verbs follow a regular pattern in the present tense; others change their
  vowel for ‘du’ and ‘er, sie, es’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.323219Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26301-3
  a curric:KeyLearningPoint ;
  rdfs:label """Gern is an adverb meaning 'gladly' and expresses likes, and dislikes when preceded
  by ‘nicht’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.323223Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26301-4
  a curric:KeyLearningPoint ;
  rdfs:label """In German, the verb is always the second idea in a sentence, whether the subject or
  another element starts the sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.323227Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26301-5
  a curric:KeyLearningPoint ;
  rdfs:label """Any sentence element can be emphasised by using word order two (WO2), e.g., adverb -
  verb - subject - noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.323230Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26243-1
  a curric:KeyLearningPoint ;
  rdfs:label "[eu] sounds the same as [äu] and is pronounced as in 'Deutschland'."@en ;
  dcterms:modified "2026-06-07T15:30:29.323246Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26243-2
  a curric:KeyLearningPoint ;
  rdfs:label """Form closed questions by swapping the position of the subject and verb in a
  statement."""@en ;
  dcterms:modified "2026-06-07T15:30:29.323250Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26243-3
  a curric:KeyLearningPoint ;
  rdfs:label "Form open questions by placing a question word in front of a closed question."@en ;
  dcterms:modified "2026-06-07T15:30:29.323257Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26243-4
  a curric:KeyLearningPoint ;
  rdfs:label """A bilingual dictionary is split into two halves. The German side has English
  translations, and vice versa."""@en ;
  dcterms:modified "2026-06-07T15:30:29.323261Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26243-5
  a curric:KeyLearningPoint ;
  rdfs:label """Dictionaries indicate what part of speech a word is, e.g., noun, verb,
  adjective."""@en ;
  dcterms:modified "2026-06-07T15:30:29.323265Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26272-1
  a curric:KeyLearningPoint ;
  rdfs:label """[s] sounds like the English 'z' before a vowel. Elsewhere [s], [ss] and [ß] sound
  like the English 's'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.323361Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26272-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Nächst-' means 'next' and takes the same ending as the definite article of the noun
  it precedes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.323367Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26272-3
  a curric:KeyLearningPoint ;
  rdfs:label """Use time phrases (e.g., 'nächstes Jahr') with the present tense to refer to future
  plans."""@en ;
  dcterms:modified "2026-06-07T15:30:29.323371Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26272-4
  a curric:KeyLearningPoint ;
  rdfs:label """When translating future meaning from German into English, use the present continuous
  (e.g., 'next week I am going')."""@en ;
  dcterms:modified "2026-06-07T15:30:29.323375Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26272-5
  a curric:KeyLearningPoint ;
  rdfs:label """Use simple present tense in English translations of German statements about present
  routines (e.g., ‘normally I go’)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.323380Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26319-1
  a curric:KeyLearningPoint ;
  rdfs:label """At the start of words, German [sp-] and [st-] are pronounced 'schp-' and
  'scht-'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.324794Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26319-2
  a curric:KeyLearningPoint ;
  rdfs:label """[st] and [sp] sound like in English in the middle or at the end of words, except in
  compound nouns or separable verbs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.324798Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26319-3
  a curric:KeyLearningPoint ;
  rdfs:label "Practising vocabulary in different ways strengthens long-term recall."@en ;
  dcterms:modified "2026-06-07T15:30:29.324802Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26319-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Lieber' is an adverb meaning 'rather' and goes after the verb to talk about
  preferring to do something."""@en ;
  dcterms:modified "2026-06-07T15:30:29.324806Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26319-5
  a curric:KeyLearningPoint ;
  rdfs:label """It is important not to confuse 'lieber' with 'lieben', which is a verb meaning 'to
  love, loving'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.324810Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26260-1
  a curric:KeyLearningPoint ;
  rdfs:label "[ü] is pronounced long as in 'Tür' or short as in 'fünf'."@en ;
  dcterms:modified "2026-06-07T15:30:29.325681Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26260-2
  a curric:KeyLearningPoint ;
  rdfs:label "Modal verbs express ideas of necessity or possibility (must, can, want)."@en ;
  dcterms:modified "2026-06-07T15:30:29.325685Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26260-3
  a curric:KeyLearningPoint ;
  rdfs:label """Modal verbs are used with a 2nd verb in the infinitive, which goes to the end of the
  sentence (two-verb rule)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.325689Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26260-4
  a curric:KeyLearningPoint ;
  rdfs:label """Modal verbs include ‘müssen’ - to have to, must; ‘dürfen’ - to be allowed to, may;
  ‘wollen’ - to want to."""@en ;
  dcterms:modified "2026-06-07T15:30:29.325693Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26260-5
  a curric:KeyLearningPoint ;
  rdfs:label """Put 'nicht' before an infinitive ('Ich muss nicht singen') but forms of 'kein'
  before nouns ('Er will kein Buch lesen')."""@en ;
  dcterms:modified "2026-06-07T15:30:29.325697Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26328-1
  a curric:KeyLearningPoint ;
  rdfs:label """The SSC [d] often corresponds to an English 't' or 'th' spelling. The SSC [t] often
  corresponds to English 'd'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.325744Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26328-2
  a curric:KeyLearningPoint ;
  rdfs:label """Modal verbs require a 2nd verb in the infinitive, placed at the end of the
  sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.325748Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26328-3
  a curric:KeyLearningPoint ;
  rdfs:label """Some verbs use 'zu' in two-verb structures, e.g., 'Er vergisst, Wasser zu trinken.'
  A comma separates the verb phrases."""@en ;
  dcterms:modified "2026-06-07T15:30:29.325754Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26253-1
  a curric:KeyLearningPoint ;
  rdfs:label """[ei] is pronounced as in 'frei', like English 'eye'. [ie] is pronounced as in
  'Liebe', like English 'ee'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.325781Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26253-2
  a curric:KeyLearningPoint ;
  rdfs:label """Possessive adjectives show who possesses something: ‘mein’ (my), ‘dein’ (your),
  ‘ihr’ (her), ‘sein’ (his)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.325785Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26253-3
  a curric:KeyLearningPoint ;
  rdfs:label """Possessive adjectives agree with the noun they are describing, i.e., they need to be
  the same gender."""@en ;
  dcterms:modified "2026-06-07T15:30:29.325789Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26253-4
  a curric:KeyLearningPoint ;
  rdfs:label """Form closed questions by inverting the subject and verb in a statement. Add a
  question word before for an open question."""@en ;
  dcterms:modified "2026-06-07T15:30:29.325793Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26253-5
  a curric:KeyLearningPoint ;
  rdfs:label """Add the prefix 'Lieblings-' to a noun to mean 'favourite'; for example, ‘mein
  Lieblingsobst’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.325797Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26313-1
  a curric:KeyLearningPoint ;
  rdfs:label "Care is needed with [ich] and [isch] when listening and speaking."@en ;
  dcterms:modified "2026-06-07T15:30:29.325801Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26313-2
  a curric:KeyLearningPoint ;
  rdfs:label """Comparative statements are created by adding -er to most adjectives, e.g.,
  'lustiger' + 'als'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.325805Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26313-3
  a curric:KeyLearningPoint ;
  rdfs:label """Some adjectives need an additional change to make the comparative, e.g., 'lang'
  becomes 'länger'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.325809Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26313-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Gut' works like English: its comparative is 'besser', like 'good' becomes 'better'
  in English."""@en ;
  dcterms:modified "2026-06-07T15:30:29.325813Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26313-5
  a curric:KeyLearningPoint ;
  rdfs:label "'Mehr' is an adverb that can be used by itself as a comparative."@en ;
  dcterms:modified "2026-06-07T15:30:29.325817Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26329-1
  a curric:KeyLearningPoint ;
  rdfs:label "Pronounce both letters in the sound-symbol correspondence [pf] in German."@en ;
  dcterms:modified "2026-06-07T15:30:29.326560Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26329-2
  a curric:KeyLearningPoint ;
  rdfs:label "The English spelling 'p' often corresponds to [pf] in German."@en ;
  dcterms:modified "2026-06-07T15:30:29.326566Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26329-3
  a curric:KeyLearningPoint ;
  rdfs:label """Use your existing knowledge of language to understand meanings of unfamiliar words
  and to identify word families."""@en ;
  dcterms:modified "2026-06-07T15:30:29.326570Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26329-4
  a curric:KeyLearningPoint ;
  rdfs:label """Use the modal verb 'sollen' to mean ‘should', 'be supposed to’ in expectations or
  obligations, and for probability."""@en ;
  dcterms:modified "2026-06-07T15:30:29.326576Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26329-5
  a curric:KeyLearningPoint ;
  rdfs:label """Use the modal verb 'müssen' to mean ‘must’ and the modal verb 'dürfen' to mean
  ‘may', 'allowed’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.326580Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26348-1
  a curric:KeyLearningPoint ;
  rdfs:label "The sound-symbol correspondence [ie] is pronounced as in 'Liebe'."@en ;
  dcterms:modified "2026-06-07T15:30:29.332609Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26348-2
  a curric:KeyLearningPoint ;
  rdfs:label "The sound-symbol correspondence [ei] is pronounced as in 'frei'."@en ;
  dcterms:modified "2026-06-07T15:30:29.332614Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26348-3
  a curric:KeyLearningPoint ;
  rdfs:label """Pronouns replace nouns. Subject pronouns replace the noun doing the action of the
  verb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.332618Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26348-4
  a curric:KeyLearningPoint ;
  rdfs:label """After most verbs, use direct object pronouns (accusative case), e.g., 'Ich habe
  ihn.'"""@en ;
  dcterms:modified "2026-06-07T15:30:29.332624Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26348-5
  a curric:KeyLearningPoint ;
  rdfs:label """After certain verbs or prepositions, indirect object pronouns (dative case) are
  used, e.g., 'Ich helfe ihm'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.332628Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26244-1
  a curric:KeyLearningPoint ;
  rdfs:label """German vowels (with or without umlauts) can be short or long. Vowels are short when
  followed by more than one consonant."""@en ;
  dcterms:modified "2026-06-07T15:30:29.346642Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26244-2
  a curric:KeyLearningPoint ;
  rdfs:label """Vowels are long when there is a double vowel, followed by 'h', or a single
  consonant."""@en ;
  dcterms:modified "2026-06-07T15:30:29.346645Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26244-3
  a curric:KeyLearningPoint ;
  rdfs:label """Change the vowel in the stem for the 2nd and 3rd person singular forms of strong
  verbs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.346651Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26249-1
  a curric:KeyLearningPoint ;
  rdfs:label "To ask an open question, we place a question word directly in front of the verb."@en ;
  dcterms:modified "2026-06-07T15:30:29.349105Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26249-2
  a curric:KeyLearningPoint ;
  rdfs:label """The word order in open questions is similar to that of statements in word order 2,
  but a question word is at the start."""@en ;
  dcterms:modified "2026-06-07T15:30:29.349109Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26249-3
  a curric:KeyLearningPoint ;
  rdfs:label """To ask a closed question, swap the position of the subject and verb in a
  statement."""@en ;
  dcterms:modified "2026-06-07T15:30:29.349129Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26249-4
  a curric:KeyLearningPoint ;
  rdfs:label """Do not rely on word order to tell you if a sentence is a question or a statement.
  Intonation is important."""@en ;
  dcterms:modified "2026-06-07T15:30:29.349133Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26249-5
  a curric:KeyLearningPoint ;
  rdfs:label "Use 'wann?' to ask open questions about when things happen."@en ;
  dcterms:modified "2026-06-07T15:30:29.349137Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26236-1
  a curric:KeyLearningPoint ;
  rdfs:label "[v] is pronounced as in 'vor'."@en ;
  dcterms:modified "2026-06-07T15:30:29.363723Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26236-2
  a curric:KeyLearningPoint ;
  rdfs:label "The 1st person plural 'wir' present tense ending for weak verbs is '-en'."@en ;
  dcterms:modified "2026-06-07T15:30:29.363727Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26236-3
  a curric:KeyLearningPoint ;
  rdfs:label """The 1st person plural 'wir' present tense form of a weak verb looks identical to the
  infinitive."""@en ;
  dcterms:modified "2026-06-07T15:30:29.363730Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26236-4
  a curric:KeyLearningPoint ;
  rdfs:label "Adverbs are used after the verb."@en ;
  dcterms:modified "2026-06-07T15:30:29.363734Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26236-5
  a curric:KeyLearningPoint ;
  rdfs:label """Add a capital letter to change an adjective into a noun. Its grammatical gender will
  be neuter."""@en ;
  dcterms:modified "2026-06-07T15:30:29.363740Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26383-1
  a curric:KeyLearningPoint ;
  rdfs:label """Add -te to form ordinal numbers 1-19 and -ste for 20+. Exceptions are 'erste',
  'dritte', 'siebte'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.364173Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26383-2
  a curric:KeyLearningPoint ;
  rdfs:label """Use 'am' with dates to say 'on the' and add -n to the ordinal number, e.g., 'am
  zehnten Juli'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.364177Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26383-3
  a curric:KeyLearningPoint ;
  rdfs:label "In word order three clauses, separable prefixes rejoin the verb."@en ;
  dcterms:modified "2026-06-07T15:30:29.364181Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26383-4
  a curric:KeyLearningPoint ;
  rdfs:label """Form past participles of separable verbs by adding the prefix before ge-, e.g.,
  'eingeladen', 'aufgemacht'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.364187Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26383-5
  a curric:KeyLearningPoint ;
  rdfs:label """Understanding separable prefixes and the base verb meanings allows you to predict
  most meanings of separable verbs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.364191Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26203-1
  a curric:KeyLearningPoint ;
  rdfs:label """'Wie?' has two meanings: 'How?' and 'What ... like?', e.g., 'Wie geht's?' and 'Wie
  ist der Mann?'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.372144Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26203-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Ist' means 'is'."@en ;
  dcterms:modified "2026-06-07T15:30:29.372148Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26203-3
  a curric:KeyLearningPoint ;
  rdfs:label "Use an adjective after 'ist' to say what something or someone is like."@en ;
  dcterms:modified "2026-06-07T15:30:29.372152Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26203-4
  a curric:KeyLearningPoint ;
  rdfs:label """Learners can build and use their own treasure trove of vocabulary that is important
  to them."""@en ;
  dcterms:modified "2026-06-07T15:30:29.372156Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26310-1
  a curric:KeyLearningPoint ;
  rdfs:label """Strong past participles are formed by 'ge-' and '–en' surrounding the stem; the stem
  may have a vowel change, too."""@en ;
  dcterms:modified "2026-06-07T15:30:29.373036Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26310-2
  a curric:KeyLearningPoint ;
  rdfs:label """With certain verbs, often verbs of movement to a destination, the perfect tense is
  formed with ‘sein’, not 'haben'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.373041Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26310-3
  a curric:KeyLearningPoint ;
  rdfs:label """With movement, prepositions 'in' and 'auf' mean 'into' and 'onto', and are followed
  by the accusative case."""@en ;
  dcterms:modified "2026-06-07T15:30:29.373045Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26310-4
  a curric:KeyLearningPoint ;
  rdfs:label """When starting sentences with time adverbs to sequence narration, we use word order 2
  so that the verb remains second."""@en ;
  dcterms:modified "2026-06-07T15:30:29.373049Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26247-1
  a curric:KeyLearningPoint ;
  rdfs:label "The sounds ‘t’ and [th] sound the same in German, as in ‘Hotel’ and ‘Theater’."@en ;
  dcterms:modified "2026-06-07T15:30:29.373775Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26247-2
  a curric:KeyLearningPoint ;
  rdfs:label """Word order 1 (WO1) means that the words in a sentence follow this pattern: subject -
  verb - adverb - noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.373779Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26247-3
  a curric:KeyLearningPoint ;
  rdfs:label """Word order 2 (WO2) means that the sentence begins with something other than the
  subject."""@en ;
  dcterms:modified "2026-06-07T15:30:29.373783Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26247-4
  a curric:KeyLearningPoint ;
  rdfs:label "The verb doesn’t change position in WO2."@en ;
  dcterms:modified "2026-06-07T15:30:29.373787Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26247-5
  a curric:KeyLearningPoint ;
  rdfs:label """Practising writing from memory is important to practise your application of
  vocabulary and grammar."""@en ;
  dcterms:modified "2026-06-07T15:30:29.373791Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26401-1
  a curric:KeyLearningPoint ;
  rdfs:label """Short [u] is pronounced as in 'Punkt' and long [u] as in 'du'; short [ü] sounds as
  in 'fünf' and long [ü] as in 'Tür'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.393798Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26401-2
  a curric:KeyLearningPoint ;
  rdfs:label """Dual-case prepositions take the accusative case with movement and the dative case
  for location."""@en ;
  dcterms:modified "2026-06-07T15:30:29.393802Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26401-3
  a curric:KeyLearningPoint ;
  rdfs:label """Three placement verbs ‘stellen’, ‘setzen’, ‘legen’ describe putting something
  somewhere, and take the accusative case."""@en ;
  dcterms:modified "2026-06-07T15:30:29.393806Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26401-4
  a curric:KeyLearningPoint ;
  rdfs:label """Placement verbs can also be used reflexively for animate objects, when the
  sentence's subject and object are the same."""@en ;
  dcterms:modified "2026-06-07T15:30:29.393810Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26401-5
  a curric:KeyLearningPoint ;
  rdfs:label """When items are already in position, we use equivalent position verbs 'stehen',
  'sitzen' and 'liegen' with the dative."""@en ;
  dcterms:modified "2026-06-07T15:30:29.393814Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26388-1
  a curric:KeyLearningPoint ;
  rdfs:label """When [ie] is part of the final syllable in a word and is stressed, then [i] is a
  long vowel."""@en ;
  dcterms:modified "2026-06-07T15:30:29.398164Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26388-2
  a curric:KeyLearningPoint ;
  rdfs:label """When [ie] is part of the final but unstressed syllable in a word, pronounce [i] and
  [e] as separate vowel sounds."""@en ;
  dcterms:modified "2026-06-07T15:30:29.398168Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26388-3
  a curric:KeyLearningPoint ;
  rdfs:label """The suffix '-keit' is added to adjectives or adverbs to form nouns corresponding to
  English nouns ending '-ty', '-ness'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.398174Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26388-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Weder... noch' (neither... nor) negates two things, avoiding repetition, e.g. 'Er
  spricht weder Englisch noch Deutsch'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.398178Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26388-5
  a curric:KeyLearningPoint ;
  rdfs:label """'Welch-' means 'which' and its form matches noun gender and case. Use dative case
  with certain prepositions or verbs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.398182Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26418-1
  a curric:KeyLearningPoint ;
  rdfs:label "Use the imperfect tense in German to narrate past events, mainly in writing."@en ;
  dcterms:modified "2026-06-07T15:30:29.398221Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26418-2
  a curric:KeyLearningPoint ;
  rdfs:label """Singular weak imperfect verbs add -te to the stem for ‘ich’ and ‘er, sie, es’ and an
  additional -st for the ‘du’ form."""@en ;
  dcterms:modified "2026-06-07T15:30:29.398227Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26418-3
  a curric:KeyLearningPoint ;
  rdfs:label """Strong verbs have an irregular stem including a vowel change, and don’t add -te;
  ‘du’ forms add -st to the stem."""@en ;
  dcterms:modified "2026-06-07T15:30:29.398231Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26418-4
  a curric:KeyLearningPoint ;
  rdfs:label """Oral retelling of fairy tales can be done in the perfect tense; simpler versions can
  be written in the present tense."""@en ;
  dcterms:modified "2026-06-07T15:30:29.398237Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26345-1
  a curric:KeyLearningPoint ;
  rdfs:label """Some sound-symbol correspondences are written differently, but sound the same as
  each other, e.g., [eu] and [äu]."""@en ;
  dcterms:modified "2026-06-07T15:30:29.398297Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26345-2
  a curric:KeyLearningPoint ;
  rdfs:label """Use your previous knowledge to decipher the meaning of new vocabulary, including
  compound words and large numbers."""@en ;
  dcterms:modified "2026-06-07T15:30:29.398304Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26345-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Aus' means 'from' when used with a country or city to describe origins. 'Von' means
  'from' with starting points."""@en ;
  dcterms:modified "2026-06-07T15:30:29.398310Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26345-4
  a curric:KeyLearningPoint ;
  rdfs:label """Use 'wann' to ask 'when' in a question. Use 'wenn' to say 'when' in a present tense
  statement."""@en ;
  dcterms:modified "2026-06-07T15:30:29.398314Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26345-5
  a curric:KeyLearningPoint ;
  rdfs:label """Depending on the context, 'wenn' can also mean 'if'. It triggers word order 3: 'Ich
  schwimme im Meer, wenn es warm ist.'"""@en ;
  dcterms:modified "2026-06-07T15:30:29.398318Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26238-1
  a curric:KeyLearningPoint ;
  rdfs:label "[au] is pronounced as in 'Haus'."@en ;
  dcterms:modified "2026-06-07T15:30:29.398473Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26238-2
  a curric:KeyLearningPoint ;
  rdfs:label """Learning new vocabulary (especially verbs) allows you to use familiar vocabulary in
  different ways."""@en ;
  dcterms:modified "2026-06-07T15:30:29.398477Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26238-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Können' is a modal verb used to say what you can and cannot do (as in physically or
  situationally able)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.398481Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26238-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Kann' means 'can' and is used with 'ich', 'sie', 'er', 'es'. 'Du kannst' means 'you
  can'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.398485Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26238-5
  a curric:KeyLearningPoint ;
  rdfs:label """Modal verbs such as 'können' require a 2nd verb in the infinitive, placed at the end
  of the sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.398488Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26292-1
  a curric:KeyLearningPoint ;
  rdfs:label """Trying to remember words you have previously learned is essential for building a
  strong vocabulary."""@en ;
  dcterms:modified "2026-06-07T15:30:29.398595Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26292-2
  a curric:KeyLearningPoint ;
  rdfs:label "Listening to understand numbers speeds up mental processing."@en ;
  dcterms:modified "2026-06-07T15:30:29.398599Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26292-3
  a curric:KeyLearningPoint ;
  rdfs:label """Speaking to practise using strong verbs speeds up recall and develops confidence in
  their use more generally."""@en ;
  dcterms:modified "2026-06-07T15:30:29.398605Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26292-4
  a curric:KeyLearningPoint ;
  rdfs:label """Direct object pronouns replace the noun that is the 'receiver' of the action of the
  verb: 'mich' ('me'), 'dich' ('you')."""@en ;
  dcterms:modified "2026-06-07T15:30:29.398609Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26292-5
  a curric:KeyLearningPoint ;
  rdfs:label """Using direct object pronouns avoids repeating the noun and makes our communication
  smoother and more natural."""@en ;
  dcterms:modified "2026-06-07T15:30:29.398613Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26215-1
  a curric:KeyLearningPoint ;
  rdfs:label "Revisit [a], [e], [ei], [i], [w], [o], [ie] and [z]."@en ;
  dcterms:modified "2026-06-07T15:30:29.402883Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26215-2
  a curric:KeyLearningPoint ;
  rdfs:label """Remove 'en' from the infinitive, add 'e' for the 1st person singular of weak verbs
  in German."""@en ;
  dcterms:modified "2026-06-07T15:30:29.402893Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26215-3
  a curric:KeyLearningPoint ;
  rdfs:label """Remove 'en' from the infinitive, add 't' for the 3rd person singular of weak verbs
  in German."""@en ;
  dcterms:modified "2026-06-07T15:30:29.402898Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26215-4
  a curric:KeyLearningPoint ;
  rdfs:label "Use 'und', 'oder' and 'aber' to link ideas and make longer sentences."@en ;
  dcterms:modified "2026-06-07T15:30:29.402902Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26215-5
  a curric:KeyLearningPoint ;
  rdfs:label """'Sein' is an irregular verb and does not follow a regular pattern of verb
  endings."""@en ;
  dcterms:modified "2026-06-07T15:30:29.402914Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26205-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Wie sagt man das?' means 'How do you say that?'."@en ;
  dcterms:modified "2026-06-07T15:30:29.407927Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26205-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Wie schreibt man das?' means 'How do you write that?'."@en ;
  dcterms:modified "2026-06-07T15:30:29.407931Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26205-3
  a curric:KeyLearningPoint ;
  rdfs:label """Knowing the German alphabet allows you to spell words out loud and write
  them down."""@en ;
  dcterms:modified "2026-06-07T15:30:29.407935Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26246-1
  a curric:KeyLearningPoint ;
  rdfs:label """[th] is pronounced as in 'Theater'. All German words containing [th] come from other
  languages. The 'h' is silent."""@en ;
  dcterms:modified "2026-06-07T15:30:29.418424Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26246-2
  a curric:KeyLearningPoint ;
  rdfs:label """Word order 1 (WO1) - subject, verb, adverb, noun - is the standard word order of a
  simple German sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.418428Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26246-3
  a curric:KeyLearningPoint ;
  rdfs:label """To emphasise when something happens, swap the position of the subject and the
  adverb. This is word order 2 (WO2)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.418435Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26246-4
  a curric:KeyLearningPoint ;
  rdfs:label "The verb remains in the same position in WO2 as in WO1."@en ;
  dcterms:modified "2026-06-07T15:30:29.418439Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26257-1
  a curric:KeyLearningPoint ;
  rdfs:label """[ig] is pronounced soft as in 'ich'. In some regions it is pronounced hard as in
  'ik'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.422996Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26257-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Viel' means 'a lot (of)'; 'viele' means 'lots of'. Use 'viel' with uncountable
  nouns and 'viele' with countable nouns."""@en ;
  dcterms:modified "2026-06-07T15:30:29.423000Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26257-3
  a curric:KeyLearningPoint ;
  rdfs:label """Put adverbs at the start of a statement for emphasis. This triggers word
  order 2."""@en ;
  dcterms:modified "2026-06-07T15:30:29.423004Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26257-4
  a curric:KeyLearningPoint ;
  rdfs:label """Adverbs of time are often the last thing in an English sentence, but not the last
  thing in a German sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.423008Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26361-1
  a curric:KeyLearningPoint ;
  rdfs:label """When faced with unfamiliar words, use your previous knowledge to identify noun-verb
  pairs, e.g., 'die Feier' - 'feiern'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.425226Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26361-2
  a curric:KeyLearningPoint ;
  rdfs:label """Add -nen to all feminine person nouns ending -in to form their plurals (plural rule
  six)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.425230Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26361-3
  a curric:KeyLearningPoint ;
  rdfs:label """The sound-symbol correspondence [r] is formed at the back of the throat, barely
  moving the lips, e.g., ‘Autorin’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.425234Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26361-4
  a curric:KeyLearningPoint ;
  rdfs:label """The conjunction 'bevor' means 'before' and sends the verb to the end of the clause
  (word order three)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.425240Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26361-5
  a curric:KeyLearningPoint ;
  rdfs:label """The conjunction 'nachdem' means 'after' and sends the verb to the end of the clause
  (word order three)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.425245Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26395-1
  a curric:KeyLearningPoint ;
  rdfs:label """Challenge your language skills by limiting the amount of support or time you have to
  prepare."""@en ;
  dcterms:modified "2026-06-07T15:30:29.425293Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26395-2
  a curric:KeyLearningPoint ;
  rdfs:label """A two-verb structure contains a conjugated verb and another verb in the infinitive
  or past participle."""@en ;
  dcterms:modified "2026-06-07T15:30:29.425297Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26395-3
  a curric:KeyLearningPoint ;
  rdfs:label "In two-verb structures, the second verb comes at the end of the clause."@en ;
  dcterms:modified "2026-06-07T15:30:29.425301Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26395-4
  a curric:KeyLearningPoint ;
  rdfs:label """Some conjunctions (e.g., 'weil') trigger word order three, which sends the
  conjugated verb to the end of the clause."""@en ;
  dcterms:modified "2026-06-07T15:30:29.425305Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26395-5
  a curric:KeyLearningPoint ;
  rdfs:label """Word order 3 conjunctions affect clauses in all tenses, and in both single and
  two-verb structures."""@en ;
  dcterms:modified "2026-06-07T15:30:29.425310Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26409-1
  a curric:KeyLearningPoint ;
  rdfs:label """Da-compounds are used to replace and refer back to inanimate (non-living) nouns
  which have already been mentioned."""@en ;
  dcterms:modified "2026-06-07T15:30:29.425591Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26409-2
  a curric:KeyLearningPoint ;
  rdfs:label """Use wo-compounds to ask questions with prepositions. Place the prefix wo- +
  preposition at the start of the question."""@en ;
  dcterms:modified "2026-06-07T15:30:29.425596Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26409-3
  a curric:KeyLearningPoint ;
  rdfs:label """For animate things (people and animals), use an object pronoun instead of a
  da-compound to replace the noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.425600Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26409-4
  a curric:KeyLearningPoint ;
  rdfs:label """For ‘who’ questions with prepositions relating to animate nouns, use a form of
  ‘wer’, not a wo-compound."""@en ;
  dcterms:modified "2026-06-07T15:30:29.425604Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26409-5
  a curric:KeyLearningPoint ;
  rdfs:label """Use dar- and wor- for da- and wo-compounds with prepositions starting with a
  vowel."""@en ;
  dcterms:modified "2026-06-07T15:30:29.425608Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26397-1
  a curric:KeyLearningPoint ;
  rdfs:label """Remove any umlauts from the stem of a modal verb and add -te for 1st and 3rd person
  singular imperfect tense."""@en ;
  dcterms:modified "2026-06-07T15:30:29.425633Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26397-2
  a curric:KeyLearningPoint ;
  rdfs:label """Remove any umlauts from the stem of a modal verb and add -test to form its 2nd
  person singular imperfect tense."""@en ;
  dcterms:modified "2026-06-07T15:30:29.425637Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26397-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Um ... zu', meaning 'in order to', is used with an infinitive to answer the
  question 'why'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.425641Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26397-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Denn' (word order 1) and 'weil' (word order 3) both mean 'because' and can start
  clauses to answer the question 'why'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.425645Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26359-1
  a curric:KeyLearningPoint ;
  rdfs:label """A compound noun is made up of two or more nouns. Its gender comes from the final
  noun, e.g., 'die Partymusik'"""@en ;
  dcterms:modified "2026-06-07T15:30:29.426137Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26359-2
  a curric:KeyLearningPoint ;
  rdfs:label """Some groups of verbs form their past participles following the same vowel changes,
  e.g., [ei] to [ie]; [e] to [o]."""@en ;
  dcterms:modified "2026-06-07T15:30:29.426141Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26359-3
  a curric:KeyLearningPoint ;
  rdfs:label """The imperfect tense is a one-word past tense, mostly used in written German, apart
  from some key verbs, e.g., 'es gab'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.426145Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26359-4
  a curric:KeyLearningPoint ;
  rdfs:label """Sometimes the present tense is used to narrate past events. This is the 'historical
  present' and is mostly written."""@en ;
  dcterms:modified "2026-06-07T15:30:29.426151Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26359-5
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the historical present is to make events feel more immediate or
  heighten the drama."""@en ;
  dcterms:modified "2026-06-07T15:30:29.426156Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26221-1
  a curric:KeyLearningPoint ;
  rdfs:label """German has three words for 'the': 'der' (masculine), 'die' (feminine) and 'das'
  (neuter)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.426339Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26221-2
  a curric:KeyLearningPoint ;
  rdfs:label "When learning a German noun, learn its grammatical gender."@en ;
  dcterms:modified "2026-06-07T15:30:29.426343Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26221-3
  a curric:KeyLearningPoint ;
  rdfs:label """There is only one present tense in German: 'ich lerne' means 'I learn' and 'I am
  learning'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.426347Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26360-1
  a curric:KeyLearningPoint ;
  rdfs:label """For calendar years in German, say the hundred or thousand, but leave out the 'und',
  e.g., 2001 - 'zweitausend(und)eins'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.426905Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26360-2
  a curric:KeyLearningPoint ;
  rdfs:label """Add -er or -ung to the stem of some verbs to create related nouns, e.g., 'forschen'
  - 'der Forscher' - 'die Forschung'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.426909Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26360-3
  a curric:KeyLearningPoint ;
  rdfs:label """Add -in to some masculine people nouns to create the feminine form, e.g., 'der
  Entdecker', 'die Entdeckerin'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.426920Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26360-4
  a curric:KeyLearningPoint ;
  rdfs:label """The conjunction 'als' means 'when' for a one-off past event. It triggers word order
  three, sending the verb to the end."""@en ;
  dcterms:modified "2026-06-07T15:30:29.426925Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26360-5
  a curric:KeyLearningPoint ;
  rdfs:label """Use 'wenn' to mean 'when' for present or future events. The question word is
  'wann'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.426931Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26421-1
  a curric:KeyLearningPoint ;
  rdfs:label """Vocabulary knowledge can be consolidated and deepened through longer reading
  texts."""@en ;
  dcterms:modified "2026-06-07T15:30:29.427660Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26421-2
  a curric:KeyLearningPoint ;
  rdfs:label """Skills for reading comprehension include strong vocabulary knowledge, close reading
  of questions and checking answers."""@en ;
  dcterms:modified "2026-06-07T15:30:29.427665Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26421-3
  a curric:KeyLearningPoint ;
  rdfs:label """Focus is required for longer texts, for questions across a number of texts and for
  questions in German."""@en ;
  dcterms:modified "2026-06-07T15:30:29.427669Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26421-4
  a curric:KeyLearningPoint ;
  rdfs:label """Imperfect forms of modal verbs are commonly used in speaking, for example in open
  questions about past experiences."""@en ;
  dcterms:modified "2026-06-07T15:30:29.427673Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26421-5
  a curric:KeyLearningPoint ;
  rdfs:label """Learning about the lives of famous young Germans is a rewarding way of consolidating
  vocabulary and grammar knowledge."""@en ;
  dcterms:modified "2026-06-07T15:30:29.427677Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26325-1
  a curric:KeyLearningPoint ;
  rdfs:label """The prepositions 'an' and 'auf' tell us where something or someone is moving to,
  when used with the accusative case."""@en ;
  dcterms:modified "2026-06-07T15:30:29.428131Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26325-2
  a curric:KeyLearningPoint ;
  rdfs:label """The prepositions 'an' and 'auf' tell us where something or someone is located, when
  used with the dative case."""@en ;
  dcterms:modified "2026-06-07T15:30:29.428135Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26325-3
  a curric:KeyLearningPoint ;
  rdfs:label """Knowledge of word patterns and word families helps you to understand more words in a
  text."""@en ;
  dcterms:modified "2026-06-07T15:30:29.428139Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26218-1
  a curric:KeyLearningPoint ;
  rdfs:label """A simple German sentence contains a subject (for example I, you) and a verb with the
  correct ending."""@en ;
  dcterms:modified "2026-06-07T15:30:29.429030Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26218-2
  a curric:KeyLearningPoint ;
  rdfs:label """Extend a sentence by adding a noun after the verb, for example 'Ich spiele
  Fußball.'"""@en ;
  dcterms:modified "2026-06-07T15:30:29.429034Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26218-3
  a curric:KeyLearningPoint ;
  rdfs:label "Adverbs normally come after the verb in German, splitting up the verb and noun."@en ;
  dcterms:modified "2026-06-07T15:30:29.429040Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26218-4
  a curric:KeyLearningPoint ;
  rdfs:label "Sentences are turned into questions by swapping the verb and subject."@en ;
  dcterms:modified "2026-06-07T15:30:29.429045Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26399-1
  a curric:KeyLearningPoint ;
  rdfs:label """Consolidating vocabulary in different contexts is an important skill which needs
  regular practice."""@en ;
  dcterms:modified "2026-06-07T15:30:29.429049Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26399-2
  a curric:KeyLearningPoint ;
  rdfs:label """Some words have more than one meaning and it is important to use context to select
  the correct meaning"""@en ;
  dcterms:modified "2026-06-07T15:30:29.429053Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26399-3
  a curric:KeyLearningPoint ;
  rdfs:label """German adverbs in a sentence follow the order time before manner before place,
  abbreviated to TMP."""@en ;
  dcterms:modified "2026-06-07T15:30:29.429057Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26399-4
  a curric:KeyLearningPoint ;
  rdfs:label "TMP, in German wann-wie-wo, applies in all tenses."@en ;
  dcterms:modified "2026-06-07T15:30:29.429061Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26399-5
  a curric:KeyLearningPoint ;
  rdfs:label """In the perfect tense, the past partiple goes at the sentence end after the TMP
  elements."""@en ;
  dcterms:modified "2026-06-07T15:30:29.429065Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26245-1
  a curric:KeyLearningPoint ;
  rdfs:label """Vowels are long when followed by a single consonant, 'h' or if there is a double
  vowel; vowels are otherwise short."""@en ;
  dcterms:modified "2026-06-07T15:30:29.430299Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26245-2
  a curric:KeyLearningPoint ;
  rdfs:label """The subject pronoun 'sie' can mean both 'she' and 'they'. It means 'they' when used
  with a 3rd person plural verb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.430303Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26245-3
  a curric:KeyLearningPoint ;
  rdfs:label """Strong verbs change their vowel in the verb stem of the 2nd person singular and 3rd
  person singular forms only."""@en ;
  dcterms:modified "2026-06-07T15:30:29.430307Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26245-4
  a curric:KeyLearningPoint ;
  rdfs:label """The 3rd person plural form of weak and strong verbs is identical to the
  infinitive."""@en ;
  dcterms:modified "2026-06-07T15:30:29.430314Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26344-1
  a curric:KeyLearningPoint ;
  rdfs:label """Regularly practise reading aloud to improve your fluency and knowledge of
  sound-symbol correspondences."""@en ;
  dcterms:modified "2026-06-07T15:30:29.430318Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26344-2
  a curric:KeyLearningPoint ;
  rdfs:label """We can use the present tense with a future time phrase to refer to future plans,
  e.g., 'Ich spiele morgen Tennis.'"""@en ;
  dcterms:modified "2026-06-07T15:30:29.430322Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26344-3
  a curric:KeyLearningPoint ;
  rdfs:label """We can form the future tense in German by using the present tense of 'werden' plus
  an infinitive."""@en ;
  dcterms:modified "2026-06-07T15:30:29.430327Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26344-4
  a curric:KeyLearningPoint ;
  rdfs:label """In two-verb structures, the second verb is in the infinitive at the end of the
  sentence, preceded by a comma and 'zu'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.430331Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26344-5
  a curric:KeyLearningPoint ;
  rdfs:label """There is no 'zu' in two-verb structures using 'werden' or modal verbs (e.g.,
  'wollen', 'sollen')."""@en ;
  dcterms:modified "2026-06-07T15:30:29.430335Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26230-1
  a curric:KeyLearningPoint ;
  rdfs:label "[sch] is pronounced like the English 'sh'."@en ;
  dcterms:modified "2026-06-07T15:30:29.430339Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26230-2
  a curric:KeyLearningPoint ;
  rdfs:label "[sp] always starts with the English sound 'sh' before the 'p'."@en ;
  dcterms:modified "2026-06-07T15:30:29.430343Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26230-3
  a curric:KeyLearningPoint ;
  rdfs:label """The verb 'mögen' means 'to like', 'ich mag' means 'I like' and 'du magst' means 'you
  like'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.430347Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26230-4
  a curric:KeyLearningPoint ;
  rdfs:label """In German, object pronouns tell us the grammatical gender of the object of the
  sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.430351Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26230-5
  a curric:KeyLearningPoint ;
  rdfs:label """German has three words for the object pronoun 'it' - masculine 'ihn', feminine 'sie'
  and neuter 'es'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.430355Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26362-1
  a curric:KeyLearningPoint ;
  rdfs:label """German nouns ending '-heit' often correspond to English nouns ending '-ity',
  '-ness', e.g., 'die Sicherheit' (security)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.430359Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26362-2
  a curric:KeyLearningPoint ;
  rdfs:label """After WW2, Germany was split into West and East Germany. Life was very different in
  each country."""@en ;
  dcterms:modified "2026-06-07T15:30:29.430364Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26362-3
  a curric:KeyLearningPoint ;
  rdfs:label """Use the perfect tense and shorter imperfect tense forms 'war', 'waren', 'es gab',
  'hatte' to narrate past events."""@en ;
  dcterms:modified "2026-06-07T15:30:29.430368Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26362-4
  a curric:KeyLearningPoint ;
  rdfs:label """The conjunctions 'als' or 'bevor' trigger word order three and can be used at the
  start of a sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.430374Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26362-5
  a curric:KeyLearningPoint ;
  rdfs:label """If 'als' or 'bevor' begin a clause, the following clause uses word order two,
  creating a verb-comma-verb pattern."""@en ;
  dcterms:modified "2026-06-07T15:30:29.430378Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26412-1
  a curric:KeyLearningPoint ;
  rdfs:label """The sound-symbol correspondences [eu] and [äu] have the same sound, which is
  different from [au]."""@en ;
  dcterms:modified "2026-06-07T15:30:29.430383Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26412-2
  a curric:KeyLearningPoint ;
  rdfs:label """Adverbs in a sentence follow the order time, manner, place (TMP); this word order
  applies in all tenses."""@en ;
  dcterms:modified "2026-06-07T15:30:29.430387Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26412-3
  a curric:KeyLearningPoint ;
  rdfs:label """Any adverb can start a sentence for emphasis. Where this occurs, use word order two
  (WO2) and TMP for remaining adverbs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.430391Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26412-4
  a curric:KeyLearningPoint ;
  rdfs:label """Use imperfect modal verbs in speech and writing to say what you and others wanted,
  were able or had to do."""@en ;
  dcterms:modified "2026-06-07T15:30:29.430397Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26288-1
  a curric:KeyLearningPoint ;
  rdfs:label """[r] needs practice to distinguish its pronunciation depending on its within-word
  position and surrounding letters."""@en ;
  dcterms:modified "2026-06-07T15:30:29.432329Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26288-2
  a curric:KeyLearningPoint ;
  rdfs:label """Feminine words for jobs often add -in to the masculine noun, often resulting in the
  mid-word consonantal [r] sound."""@en ;
  dcterms:modified "2026-06-07T15:30:29.432333Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26288-3
  a curric:KeyLearningPoint ;
  rdfs:label """When adjectives come before nouns, they have different endings depending on the noun
  gender, type of article and case."""@en ;
  dcterms:modified "2026-06-07T15:30:29.432337Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26288-4
  a curric:KeyLearningPoint ;
  rdfs:label """Singular accusative adjective endings for indefinite articles are: -en (masculine),
  -e (feminine) and -es (neuter)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.432341Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26288-5
  a curric:KeyLearningPoint ;
  rdfs:label """For accusative plural nouns after 'keine', the adjective ending is -en; without an
  article the accusative ending is -e."""@en ;
  dcterms:modified "2026-06-07T15:30:29.432345Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26298-1
  a curric:KeyLearningPoint ;
  rdfs:label """Regular practice of vocabulary helps with understanding and effective
  communication."""@en ;
  dcterms:modified "2026-06-07T15:30:29.432911Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26298-2
  a curric:KeyLearningPoint ;
  rdfs:label """Prepositions are used before nouns and pronouns and show where, when or how
  something happens."""@en ;
  dcterms:modified "2026-06-07T15:30:29.432915Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26298-3
  a curric:KeyLearningPoint ;
  rdfs:label """The perfect tense is formed with a part of 'haben' or 'sein' and a past participle
  to say what someone did or has done."""@en ;
  dcterms:modified "2026-06-07T15:30:29.432920Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26298-4
  a curric:KeyLearningPoint ;
  rdfs:label """Questions about past events can be formed by inverting the subject and the part of
  'haben' or 'sein'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.432924Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26396-1
  a curric:KeyLearningPoint ;
  rdfs:label """[v] is pronounced as in 'vor' and [w] as in 'Welt'. The letter f' sounds the same in
  both languages."""@en ;
  dcterms:modified "2026-06-07T15:30:29.437287Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26396-2
  a curric:KeyLearningPoint ;
  rdfs:label """In 2-verb structures, the 2nd verb in the infinitive comes at the end of the
  sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.437291Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26396-3
  a curric:KeyLearningPoint ;
  rdfs:label """Some verbs require the addition of 'zu' when combined with a 2nd
  (infinitive) verb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.437296Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26396-4
  a curric:KeyLearningPoint ;
  rdfs:label """Infinitive constructions with 'zu' are separated from other clauses with a
  comma."""@en ;
  dcterms:modified "2026-06-07T15:30:29.437300Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26396-5
  a curric:KeyLearningPoint ;
  rdfs:label """'Um ... zu', meaning 'in order to', is used with an infinitive to answer the
  question 'why?'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.437304Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26415-1
  a curric:KeyLearningPoint ;
  rdfs:label """When saying sentences, pitch rises on the 1st stressed word, is maintained, then
  falls on the final stressed syllable."""@en ;
  dcterms:modified "2026-06-07T15:30:29.437327Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26415-2
  a curric:KeyLearningPoint ;
  rdfs:label """The rise and fall is similar in German and English, but more marked in German; more
  noticeable with one-syllable words."""@en ;
  dcterms:modified "2026-06-07T15:30:29.437331Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26415-3
  a curric:KeyLearningPoint ;
  rdfs:label "Word substitution tasks strengthen vocabulary and grammar knowledge."@en ;
  dcterms:modified "2026-06-07T15:30:29.437335Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26415-4
  a curric:KeyLearningPoint ;
  rdfs:label """Indirect object pronouns replace the person or thing that the action is done to or
  for, e.g., 'ich gebe ihm das Geld'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.437339Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26415-5
  a curric:KeyLearningPoint ;
  rdfs:label """If a sentence has two objects, the indirect object comes first. If one object is a
  pronoun, the pronoun comes first."""@en ;
  dcterms:modified "2026-06-07T15:30:29.437343Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26307-1
  a curric:KeyLearningPoint ;
  rdfs:label """Combining previously taught and new words in new contexts strengthens vocabulary
  knowledge."""@en ;
  dcterms:modified "2026-06-07T15:30:29.437412Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26307-2
  a curric:KeyLearningPoint ;
  rdfs:label """Indirect objects are people or things that the verb action is done 'to' or 'for',
  e.g., 'the book belongs to the pupil'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.437416Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26307-3
  a curric:KeyLearningPoint ;
  rdfs:label """Indirect object pronouns replace indirect objects that we don't need to repeat,
  e.g., 'the book belongs to him/her'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.437420Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26307-4
  a curric:KeyLearningPoint ;
  rdfs:label """Verbs that are always used with indirect object pronouns are called dative
  verbs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.437427Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26307-5
  a curric:KeyLearningPoint ;
  rdfs:label """Some dative verbs translate differently into English - 'das Buch gefällt mir' - the
  book pleases me > I like the book."""@en ;
  dcterms:modified "2026-06-07T15:30:29.437431Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26208-1
  a curric:KeyLearningPoint ;
  rdfs:label """The verb 'haben' means to have, having. 'Ich habe' means ' I have', 'Du hast' means
  you have."""@en ;
  dcterms:modified "2026-06-07T15:30:29.437435Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26208-2
  a curric:KeyLearningPoint ;
  rdfs:label """The masculine word for 'a' - 'ein' changes to 'einen' after haben and most
  verbs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.437440Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26208-3
  a curric:KeyLearningPoint ;
  rdfs:label "After sein, words for 'a' stay the same."@en ;
  dcterms:modified "2026-06-07T15:30:29.437444Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26351-1
  a curric:KeyLearningPoint ;
  rdfs:label """The vowels [a], [ä], [o], and [ö] need practice and clarity as an umlaut is often
  added to form plural nouns."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588054Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26351-2
  a curric:KeyLearningPoint ;
  rdfs:label """'You (plural, informal)' is 'ihr' and the verb ending is -t, e.g., 'ihr habt'. The
  'ihr' form of 'sein' is 'ihr seid'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588059Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26351-3
  a curric:KeyLearningPoint ;
  rdfs:label "Most verbs take the accusative (direct object) case."@en ;
  dcterms:modified "2026-06-07T15:30:29.588063Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26351-4
  a curric:KeyLearningPoint ;
  rdfs:label """Certain verbs take the dative (indirect object), which often has the meaning of
  giving something to someone."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588068Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26352-1
  a curric:KeyLearningPoint ;
  rdfs:label """To say 'you' in German, use 'du' (singular) or 'Sie' (formal) or 'ihr' (plural
  informal) or 'man' (you, one or people)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.592214Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26352-2
  a curric:KeyLearningPoint ;
  rdfs:label """In a sentence with two object nouns, the indirect object (dative) always comes
  first."""@en ;
  dcterms:modified "2026-06-07T15:30:29.592219Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26352-3
  a curric:KeyLearningPoint ;
  rdfs:label """Identify the indirect object in a sentence by asking 'to/for whom'?' something is
  done and looking for dative articles."""@en ;
  dcterms:modified "2026-06-07T15:30:29.592223Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26393-1
  a curric:KeyLearningPoint ;
  rdfs:label """Add -ung to the verb stem to create a feminine noun, e.g., 'meinen' - 'die Meinung'
  ('opinion')."""@en ;
  dcterms:modified "2026-06-07T15:30:29.594694Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26393-2
  a curric:KeyLearningPoint ;
  rdfs:label """Adjectives can be made into comparative adverbs by adding the suffix -er, e.g.,
  'schneller' ('faster')."""@en ;
  dcterms:modified "2026-06-07T15:30:29.594698Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26393-3
  a curric:KeyLearningPoint ;
  rdfs:label """Some comparatives are irregular, e.g., 'gern' becomes 'lieber' and 'gut' becomes
  'besser'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.594702Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26393-4
  a curric:KeyLearningPoint ;
  rdfs:label """Asking and answering questions about a photo is a useful skill, which should be
  practised regularly."""@en ;
  dcterms:modified "2026-06-07T15:30:29.594706Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26202-1
  a curric:KeyLearningPoint ;
  rdfs:label "[ei] sounds like the German word 'frei' and the English word 'eye'."@en ;
  dcterms:modified "2026-06-07T15:30:29.600827Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26202-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Wie?' means 'How?', like in 'Wie geht's?' ('How's it going?')."@en ;
  dcterms:modified "2026-06-07T15:30:29.600834Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26202-3
  a curric:KeyLearningPoint ;
  rdfs:label """German has three words for 'a': 'ein' (masculine), 'eine' (feminine) and 'ein'
  (neuter)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.600838Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26202-4
  a curric:KeyLearningPoint ;
  rdfs:label """'A' (ein, eine, ein) introduces new information; 'the' (der, die, das) refers to
  something already mentioned or known."""@en ;
  dcterms:modified "2026-06-07T15:30:29.600842Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26334-1
  a curric:KeyLearningPoint ;
  rdfs:label """Knowing key word patterns helps us understand words more quickly and recall them
  more easily."""@en ;
  dcterms:modified "2026-06-07T15:30:29.601664Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26334-2
  a curric:KeyLearningPoint ;
  rdfs:label """Add 'Haupt-' to nouns to mean 'main'. The created noun has the gender of its base
  noun: 'die Idee' - 'die Hauptidee'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.601668Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26334-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Wo' is the question word 'where'; it asks where something is located and is
  answered in the dative case."""@en ;
  dcterms:modified "2026-06-07T15:30:29.601672Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26334-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Wohin' is the question word 'where to'; it asks where something is going and is
  answered in the accusative case."""@en ;
  dcterms:modified "2026-06-07T15:30:29.601676Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26334-5
  a curric:KeyLearningPoint ;
  rdfs:label """Start German sentences with any element (e.g., object, adverb) to emphasise it. The
  verb stays in 2nd place."""@en ;
  dcterms:modified "2026-06-07T15:30:29.601683Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26265-1
  a curric:KeyLearningPoint ;
  rdfs:label """[r] is consonantal at the start of a syllable, after a consonant or a short vowel,
  e.g., 'reden'. It is a rolling sound."""@en ;
  dcterms:modified "2026-06-07T15:30:29.610180Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26265-2
  a curric:KeyLearningPoint ;
  rdfs:label """[r] is vocalic after a long vowel and in '-er', e.g., 'Markt', 'aber'. It often
  sounds barely there."""@en ;
  dcterms:modified "2026-06-07T15:30:29.610184Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26265-3
  a curric:KeyLearningPoint ;
  rdfs:label """Translate 'can' as in ability with 'können', but use 'dürfen' for permission, i.e.,
  'may I ... ?'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.610188Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26265-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Man' is a pronoun used to refer to people in general and is often translated as
  'you' or 'one'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.610193Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26233-1
  a curric:KeyLearningPoint ;
  rdfs:label "[s] sounds like the English 'z' before a vowel."@en ;
  dcterms:modified "2026-06-07T15:30:29.614611Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26233-2
  a curric:KeyLearningPoint ;
  rdfs:label "Elsewhere [s], 'ss' and [ß] sound like the English 's'."@en ;
  dcterms:modified "2026-06-07T15:30:29.614615Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26233-3
  a curric:KeyLearningPoint ;
  rdfs:label """Write 'ss' after a short vowel but [ß] after a long vowel like 'Fuß' or after 2
  vowels together like 'weiß'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.614619Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26233-4
  a curric:KeyLearningPoint ;
  rdfs:label """The object pronoun 'it' is masculine 'ihn', feminine 'sie' or neuter 'es'; 'ihn' or
  'sie' also mean 'him' or 'her'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.614624Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26233-5
  a curric:KeyLearningPoint ;
  rdfs:label "To say 'them' in German, use the plural object pronoun 'sie' for all genders."@en ;
  dcterms:modified "2026-06-07T15:30:29.614630Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26232-1
  a curric:KeyLearningPoint ;
  rdfs:label "[s] sounds like the English 'z'."@en ;
  dcterms:modified "2026-06-07T15:30:29.616303Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26232-2
  a curric:KeyLearningPoint ;
  rdfs:label "[ß] sounds like the English 's'."@en ;
  dcterms:modified "2026-06-07T15:30:29.616309Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26232-3
  a curric:KeyLearningPoint ;
  rdfs:label """The verb 'finden' adds an 'e' before the '-st' and '-t' endings to make it easier to
  pronounce: 'du findest, er findet'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.616314Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26232-4
  a curric:KeyLearningPoint ;
  rdfs:label """The object pronoun 'it' is masculine 'ihn', feminine 'sie' or neuter 'es'; 'ihn' or
  'sie' also mean 'him' or 'her'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.616318Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26232-5
  a curric:KeyLearningPoint ;
  rdfs:label "To say 'them' in German, use the plural object pronoun 'sie' for all genders."@en ;
  dcterms:modified "2026-06-07T15:30:29.616322Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26219-1
  a curric:KeyLearningPoint ;
  rdfs:label "[ch] is a hard sound after a, o, u and au, and soft after other sounds."@en ;
  dcterms:modified "2026-06-07T15:30:29.617182Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26219-2
  a curric:KeyLearningPoint ;
  rdfs:label """The infinitive form of a verb is found in the dictionary and usually ends in
  'en'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.617186Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26219-3
  a curric:KeyLearningPoint ;
  rdfs:label """Singular persons of regular (weak) verbs in the present tense can be recognised by
  the endings -e, -st or -t."""@en ;
  dcterms:modified "2026-06-07T15:30:29.617191Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26341-1
  a curric:KeyLearningPoint ;
  rdfs:label "A ballad is a type of poem that tells a story in short, poetic verses."@en ;
  dcterms:modified "2026-06-07T15:30:29.618249Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26341-2
  a curric:KeyLearningPoint ;
  rdfs:label """Ballads combine three elements: narrative (epic), poetic language (lyric) and direct
  speech or tension (dramatic)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.618255Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26341-3
  a curric:KeyLearningPoint ;
  rdfs:label """Prose is continuous, written language, as in stories, articles and blogs, without
  deliberate rhyme or rhythmic pattern."""@en ;
  dcterms:modified "2026-06-07T15:30:29.618260Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26341-4
  a curric:KeyLearningPoint ;
  rdfs:label """Poetry uses rhythm, line breaks, and sometimes rhyme to shape meaning and feeling
  differently."""@en ;
  dcterms:modified "2026-06-07T15:30:29.618266Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26341-5
  a curric:KeyLearningPoint ;
  rdfs:label """To turn prose into a ballad, focus on key moments, break sentences into short,
  rhythmic lines, with or without rhyme."""@en ;
  dcterms:modified "2026-06-07T15:30:29.618271Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26290-1
  a curric:KeyLearningPoint ;
  rdfs:label """'Viel' means 'lots of' and is used with uncountable nouns like 'love' or 'time'.
  'Viele' means 'many' with plural nouns."""@en ;
  dcterms:modified "2026-06-07T15:30:29.618275Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26290-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Weil' and 'denn' both mean 'because'. Both are conjunctions and connect clauses or
  sentences."""@en ;
  dcterms:modified "2026-06-07T15:30:29.618279Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26290-3
  a curric:KeyLearningPoint ;
  rdfs:label """Add 'un-' to make some German adjectives negative, like the English 'un-' or
  'im-'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.618283Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26290-4
  a curric:KeyLearningPoint ;
  rdfs:label """Open or information questions start with a wh- word and have more information in the
  answer than yes/no."""@en ;
  dcterms:modified "2026-06-07T15:30:29.618288Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26350-1
  a curric:KeyLearningPoint ;
  rdfs:label """Open questions start with a question word (e.g., 'wo', 'wie', 'warum') and use
  verb-subject word order."""@en ;
  dcterms:modified "2026-06-07T15:30:29.619163Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26350-2
  a curric:KeyLearningPoint ;
  rdfs:label """It’s important to be very confident with question words to understand information
  and ask questions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.619167Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26350-3
  a curric:KeyLearningPoint ;
  rdfs:label """German sentences can start with any other element (other than the subject) to
  emphasise it and then the verb second."""@en ;
  dcterms:modified "2026-06-07T15:30:29.619171Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26350-4
  a curric:KeyLearningPoint ;
  rdfs:label """Present tense verbs plus the adverb 'gern' (gladly) say what we like doing. As all
  adverbs, it can start a sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.619175Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26406-1
  a curric:KeyLearningPoint ;
  rdfs:label """By regularly revisiting a range of vocabulary, you will be better prepared to
  understand authentic texts."""@en ;
  dcterms:modified "2026-06-07T15:30:29.619571Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26406-2
  a curric:KeyLearningPoint ;
  rdfs:label """Add –er to an adjective or adverb to form the comparative. Some comparatives are
  irregular, such as 'gut' - 'besser'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.619575Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26406-3
  a curric:KeyLearningPoint ;
  rdfs:label """Relative clauses add information about the noun in a main clause, without starting
  another sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.619579Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26406-4
  a curric:KeyLearningPoint ;
  rdfs:label """Relative clauses start with a relative pronoun. Use the definite article that
  matches the noun in the main clause."""@en ;
  dcterms:modified "2026-06-07T15:30:29.619583Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26406-5
  a curric:KeyLearningPoint ;
  rdfs:label """'Wenn' (if, when[ever]) is a conjunction that triggers word order three, sending the
  verb to the end of the statement."""@en ;
  dcterms:modified "2026-06-07T15:30:29.619589Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26405-1
  a curric:KeyLearningPoint ;
  rdfs:label """At the end of a word, [-ig] is pronounced as a soft [ch], as in 'richtig'. In
  Austria, it sounds like [k]."""@en ;
  dcterms:modified "2026-06-07T15:30:29.619596Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26405-2
  a curric:KeyLearningPoint ;
  rdfs:label """Prepositions used with some verbs in German may not be the same as those used with
  the same verbs in English."""@en ;
  dcterms:modified "2026-06-07T15:30:29.619601Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26405-3
  a curric:KeyLearningPoint ;
  rdfs:label """Prepositions may change the form of the article that follows, as they are used with
  specific cases."""@en ;
  dcterms:modified "2026-06-07T15:30:29.619605Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26405-4
  a curric:KeyLearningPoint ;
  rdfs:label """Verbs with the preposition 'für' are always followed by the accusative. Verbs with
  'vor' are followed by the dative."""@en ;
  dcterms:modified "2026-06-07T15:30:29.619609Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26405-5
  a curric:KeyLearningPoint ;
  rdfs:label """Verbs with the preposition 'auf' usually take the accusative. Verbs with 'an' are
  often followed by the dative."""@en ;
  dcterms:modified "2026-06-07T15:30:29.619613Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26303-1
  a curric:KeyLearningPoint ;
  rdfs:label """Preparing to listen by predicting what you will hear improves your understanding
  when you listen."""@en ;
  dcterms:modified "2026-06-07T15:30:29.619617Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26303-2
  a curric:KeyLearningPoint ;
  rdfs:label """Separable verbs are made up of a prefix and a main verb, e.g., 'vorbereiten' - 'to
  prepare, preparing'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.619621Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26303-3
  a curric:KeyLearningPoint ;
  rdfs:label """In the present tense, the prefix moves to the end of the clause, e.g., 'ich bereite
  eine Party vor'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.619626Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26303-4
  a curric:KeyLearningPoint ;
  rdfs:label """Many two-part separable verbs in German have single word English translations, e.g.,
  'einkaufen' - 'to shop'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.619630Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26303-5
  a curric:KeyLearningPoint ;
  rdfs:label """In present tense negative sentences with separable verbs, 'nicht' generally goes
  just before the separable prefix."""@en ;
  dcterms:modified "2026-06-07T15:30:29.619634Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26283-1
  a curric:KeyLearningPoint ;
  rdfs:label """Knowing the German sound-symbol correspondences well supports pronunciation and
  understanding of new words."""@en ;
  dcterms:modified "2026-06-07T15:30:29.620428Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26283-2
  a curric:KeyLearningPoint ;
  rdfs:label """Some famous German city names are different from English and need good pronunciation
  for recognition and clarity."""@en ;
  dcterms:modified "2026-06-07T15:30:29.620432Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26283-3
  a curric:KeyLearningPoint ;
  rdfs:label """The nominative case identifies the subject in a sentence, i.e., who is doing the
  action of a verb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.620436Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26283-4
  a curric:KeyLearningPoint ;
  rdfs:label "Words for 'the' and 'a' change according to the grammatical gender of the noun."@en ;
  dcterms:modified "2026-06-07T15:30:29.620440Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26283-5
  a curric:KeyLearningPoint ;
  rdfs:label """'Wie sagt man das auf Deutsch?' is a key question to ask the meaning of unknown
  words."""@en ;
  dcterms:modified "2026-06-07T15:30:29.620446Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26408-1
  a curric:KeyLearningPoint ;
  rdfs:label """[r] is a 'rolling', gentle vibration sound when at the start of a syllable, after a
  consonant or between two vowels."""@en ;
  dcterms:modified "2026-06-07T15:30:29.620631Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26408-2
  a curric:KeyLearningPoint ;
  rdfs:label """[r] is a gentle 'ah' sound after a long vowel and in '-er'. It sounds barely
  there."""@en ;
  dcterms:modified "2026-06-07T15:30:29.620635Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26408-3
  a curric:KeyLearningPoint ;
  rdfs:label """Some verbs are used with prepositions which affect the case of the noun that
  follows."""@en ;
  dcterms:modified "2026-06-07T15:30:29.620639Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26408-4
  a curric:KeyLearningPoint ;
  rdfs:label """Da-compounds are used to replace and refer back to inanimate (non-living) nouns
  which have already been mentioned."""@en ;
  dcterms:modified "2026-06-07T15:30:29.620643Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26408-5
  a curric:KeyLearningPoint ;
  rdfs:label """For animate things (people and animals), use an object pronoun instead of a
  da-compound to replace the noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.620650Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26282-1
  a curric:KeyLearningPoint ;
  rdfs:label """Use 'du' (you, singular) for a friend, family member, person you know well, and
  'Sie' for adults you address by surname."""@en ;
  dcterms:modified "2026-06-07T15:30:29.621215Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26282-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Sie' (you, formal) is written with a capital letter, but 'sie' (they) starts with
  lowercase."""@en ;
  dcterms:modified "2026-06-07T15:30:29.621219Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26282-3
  a curric:KeyLearningPoint ;
  rdfs:label """If 'Sie' begins a sentence (and hence has a capital letter) use other clues to help
  decide if 'Sie' means you or they."""@en ;
  dcterms:modified "2026-06-07T15:30:29.621223Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26282-4
  a curric:KeyLearningPoint ;
  rdfs:label """Modal verbs are followed by the infinitive, which goes to the end of the sentence.
  Other verbs use 'zu' plus infinitive."""@en ;
  dcterms:modified "2026-06-07T15:30:29.621227Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26282-5
  a curric:KeyLearningPoint ;
  rdfs:label """In 2-verb structures, the 2nd verb in the infinitive is at the end of the
  sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.621231Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26291-1
  a curric:KeyLearningPoint ;
  rdfs:label """When English ‘c’ is soft, German is often ‘z’, e.g., 'Zentrum', 'Zirkus',
  'Zelle'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.621235Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26291-2
  a curric:KeyLearningPoint ;
  rdfs:label """Spelling patterns like this help us identify cognates, which in turn support our
  understanding of German."""@en ;
  dcterms:modified "2026-06-07T15:30:29.621240Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26291-3
  a curric:KeyLearningPoint ;
  rdfs:label """For numbers 13-99, say the 2nd digit first, e.g., 'vierundzwanzig' = 24. For 21-99,
  add ‘und’ between the two numbers."""@en ;
  dcterms:modified "2026-06-07T15:30:29.621244Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26291-4
  a curric:KeyLearningPoint ;
  rdfs:label """German numbers are always written as one word, so some can be very long; break them
  down to understand them more easily."""@en ;
  dcterms:modified "2026-06-07T15:30:29.621248Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26291-5
  a curric:KeyLearningPoint ;
  rdfs:label """Strong verbs change the vowel in 'du' and 'er, sie, es' forms; verb endings have the
  same pattern as weak verbs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.621254Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26347-1
  a curric:KeyLearningPoint ;
  rdfs:label """Nouns are often the subject of a sentence. Sometimes, nouns are replaced by
  pronouns."""@en ;
  dcterms:modified "2026-06-07T15:30:29.621612Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26347-2
  a curric:KeyLearningPoint ;
  rdfs:label """Subject pronouns show the grammatical gender of the subject, e.g., ‘das Lied ist
  toll’ - ‘es ist toll’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.621618Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26347-3
  a curric:KeyLearningPoint ;
  rdfs:label """Object pronouns show the grammatical gender of the object, e.g., ‘ich sehe den Mann’
  - ‘ich sehe ihn’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.621623Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26347-4
  a curric:KeyLearningPoint ;
  rdfs:label "Use the accusative case with direct object pronouns, e.g., ‘ich sehe ihn’."@en ;
  dcterms:modified "2026-06-07T15:30:29.621627Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26211-1
  a curric:KeyLearningPoint ;
  rdfs:label """The subject and verb of a German sentence swap places to turn a statement into a
  yes/no question."""@en ;
  dcterms:modified "2026-06-07T15:30:29.621631Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26211-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Mein, 'meine', 'mein' means 'my'."@en ;
  dcterms:modified "2026-06-07T15:30:29.621635Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26211-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Kein' means 'not a' and is used with a nouns to say what you do not have."@en ;
  dcterms:modified "2026-06-07T15:30:29.621640Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26211-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Kein' behaves like the indefinite article 'ein'. The masculine changes to 'keinen'
  after 'haben'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.621644Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26211-5
  a curric:KeyLearningPoint ;
  rdfs:label "The prefix 'Lieblings-' can be added to a noun to mean 'favourite ...'."@en ;
  dcterms:modified "2026-06-07T15:30:29.621648Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26394-1
  a curric:KeyLearningPoint ;
  rdfs:label """Revisit sound-symbol correspondences to strengthen listening, speaking, reading
  aloud, and writing skills."""@en ;
  dcterms:modified "2026-06-07T15:30:29.622155Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26394-2
  a curric:KeyLearningPoint ;
  rdfs:label """Form the perfect tense with a present form of 'haben' or 'sein', plus a past
  participle, e.g., 'ich habe das gemacht'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.622159Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26394-3
  a curric:KeyLearningPoint ;
  rdfs:label """The past participle of many verbs is: ge- + verb stem + -t. Some strong verbs use
  ge- + verb stem + -en."""@en ;
  dcterms:modified "2026-06-07T15:30:29.622163Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26394-4
  a curric:KeyLearningPoint ;
  rdfs:label """Verbs that start with unstressed prefixes be-, ver-, ent-, er- do not add ge-, e.g.,
  ‘er hat besucht’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.622167Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26394-5
  a curric:KeyLearningPoint ;
  rdfs:label """The past participle ‘gefallen’ is used with ‘sein’ for ‘fallen’ (‘to fall’) and
  ‘haben’ for ‘gefallen’ (‘to please’)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.622173Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26410-1
  a curric:KeyLearningPoint ;
  rdfs:label """The German sound [qu] is pronounced as in ‘bequem’. It sounds like [k] and [w]
  together."""@en ;
  dcterms:modified "2026-06-07T15:30:29.622178Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26410-2
  a curric:KeyLearningPoint ;
  rdfs:label """Add the prefix un- to an adjective to make it negative, e.g., 'unmöglich' -
  'impossible'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.622184Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26410-3
  a curric:KeyLearningPoint ;
  rdfs:label """The verbs 'denken', 'glauben' and 'meinen' and the phrase 'meiner Meinung nach' can
  all be used to introduce opinions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.622188Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26410-4
  a curric:KeyLearningPoint ;
  rdfs:label """Use the conjunction 'dass' with word order 3, sending the verb to the end of the
  clause."""@en ;
  dcterms:modified "2026-06-07T15:30:29.622193Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26410-5
  a curric:KeyLearningPoint ;
  rdfs:label """The conversational word 'doch' is used to express disagreement with a negative or
  for emphasis."""@en ;
  dcterms:modified "2026-06-07T15:30:29.622197Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26279-1
  a curric:KeyLearningPoint ;
  rdfs:label """Past participles of strong verbs sandwich the stem with 'ge' and 'en' and the vowel
  often changes in the stem."""@en ;
  dcterms:modified "2026-06-07T15:30:29.622976Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26279-2
  a curric:KeyLearningPoint ;
  rdfs:label "[sch], [st-] and [sp] need to be practised to assist spelling and pronunciation."@en ;
  dcterms:modified "2026-06-07T15:30:29.622981Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26279-3
  a curric:KeyLearningPoint ;
  rdfs:label """The past participle of strong verbs needs to be recognised in contrast to the
  infinitive."""@en ;
  dcterms:modified "2026-06-07T15:30:29.622985Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26279-4
  a curric:KeyLearningPoint ;
  rdfs:label "The use of compound nouns enriches vocabulary."@en ;
  dcterms:modified "2026-06-07T15:30:29.622989Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26279-5
  a curric:KeyLearningPoint ;
  rdfs:label """'Haben' changes when talking about different people, but the past participle stays
  the same."""@en ;
  dcterms:modified "2026-06-07T15:30:29.622993Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26284-1
  a curric:KeyLearningPoint ;
  rdfs:label "Ask 'Wie schreibt man das?' to ask how to spell a word in German."@en ;
  dcterms:modified "2026-06-07T15:30:29.623638Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26284-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Wie heißt ...?' or 'Wie heißen ...?' (What is it/are they called?) are alternatives
  to 'Wie sagt man ...?'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.623643Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26284-3
  a curric:KeyLearningPoint ;
  rdfs:label """Definite articles - 'der, die, das, die' - and indefinite articles - 'ein, eine,
  ein' - are used before nouns."""@en ;
  dcterms:modified "2026-06-07T15:30:29.623647Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26284-4
  a curric:KeyLearningPoint ;
  rdfs:label "The accusative case shows us the direct object in a sentence."@en ;
  dcterms:modified "2026-06-07T15:30:29.623651Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26284-5
  a curric:KeyLearningPoint ;
  rdfs:label """Masculine articles change in the accusative case ('den; einen'). Feminine, neuter
  and plural articles do not change."""@en ;
  dcterms:modified "2026-06-07T15:30:29.623655Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26286-1
  a curric:KeyLearningPoint ;
  rdfs:label """When adjectives come before nouns, they have different endings for definite and
  indefinite articles."""@en ;
  dcterms:modified "2026-06-07T15:30:29.625409Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26286-2
  a curric:KeyLearningPoint ;
  rdfs:label """For plural nominative nouns, add '-en' to all adjectives with definite articles;
  without an article, the ending is '-e'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.625413Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26286-3
  a curric:KeyLearningPoint ;
  rdfs:label """When singular nouns are used without an article, the adjective ending is the same as
  for the indefinite article."""@en ;
  dcterms:modified "2026-06-07T15:30:29.625445Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26286-4
  a curric:KeyLearningPoint ;
  rdfs:label "Many verb infinitives can make neuter nouns; this is called nominalisation."@en ;
  dcterms:modified "2026-06-07T15:30:29.625544Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26286-5
  a curric:KeyLearningPoint ;
  rdfs:label """Knowledge of vocabulary and structures makes it possible to understand a poem and
  respond to it creatively in writing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.625556Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26387-1
  a curric:KeyLearningPoint ;
  rdfs:label "Revisit vocabulary often to help it stick in your memory."@en ;
  dcterms:modified "2026-06-07T15:30:29.625561Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26387-2
  a curric:KeyLearningPoint ;
  rdfs:label """Some conjunctions do not affect word order, e.g., 'und, oder, denn'. These are
  sometimes knows as word order 1 (WO1)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.625566Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26387-3
  a curric:KeyLearningPoint ;
  rdfs:label """Subordinating conjunctions (word order 3) send the conjugated verb to the end of the
  clause, e.g., 'weil, obwohl, dass'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.625582Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26387-4
  a curric:KeyLearningPoint ;
  rdfs:label """Modal verbs neeed a 2nd verb in the infinitive. In standard word order (WO1) the
  infinitive is at the end of the clause."""@en ;
  dcterms:modified "2026-06-07T15:30:29.625587Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26387-5
  a curric:KeyLearningPoint ;
  rdfs:label """In 2-verb structures with a subordinating conjunction (WO3), the conjugated verb is
  at the end, after the infinitive."""@en ;
  dcterms:modified "2026-06-07T15:30:29.625591Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26248-1
  a curric:KeyLearningPoint ;
  rdfs:label "Accurate pronunciation of words prevents misunderstandings."@en ;
  dcterms:modified "2026-06-07T15:30:29.627228Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26248-2
  a curric:KeyLearningPoint ;
  rdfs:label "Days of the week and times of day are nouns, e.g., 'am Montag' - 'on Monday'."@en ;
  dcterms:modified "2026-06-07T15:30:29.627232Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26248-3
  a curric:KeyLearningPoint ;
  rdfs:label "A time phrase is a multi-word phrase, such as ‘am Montag’."@en ;
  dcterms:modified "2026-06-07T15:30:29.627236Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26248-4
  a curric:KeyLearningPoint ;
  rdfs:label """To change a noun into an adverb, remove its capital letter and add '-s' to the end,
  e.g., 'dienstags' - 'on Tuesdays'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.627240Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26248-5
  a curric:KeyLearningPoint ;
  rdfs:label """Use noun forms of days to talk about one-off events and adverb forms to describe
  regular events."""@en ;
  dcterms:modified "2026-06-07T15:30:29.627244Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26275-1
  a curric:KeyLearningPoint ;
  rdfs:label """Knowing the grammatical gender of nouns is important for accurate grammar and clear
  communication."""@en ;
  dcterms:modified "2026-06-07T15:30:29.627467Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26275-2
  a curric:KeyLearningPoint ;
  rdfs:label """To say where something or someone is moving to, use ‘in’ ('into') and ‘auf’ ('onto')
  with the accusative case."""@en ;
  dcterms:modified "2026-06-07T15:30:29.627527Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26275-3
  a curric:KeyLearningPoint ;
  rdfs:label """To say where something or someone is located, use ‘in’ ('in') and ‘auf’ ('on') with
  the dative case."""@en ;
  dcterms:modified "2026-06-07T15:30:29.627534Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26275-4
  a curric:KeyLearningPoint ;
  rdfs:label "Texts, such as poems, can help us understand how language works in context."@en ;
  dcterms:modified "2026-06-07T15:30:29.627542Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26380-1
  a curric:KeyLearningPoint ;
  rdfs:label """German [d] at the beginning of a word or syllable sounds like English 'd'; [d] at
  the end of a syllable sounds like -t."""@en ;
  dcterms:modified "2026-06-07T15:30:29.628724Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26380-2
  a curric:KeyLearningPoint ;
  rdfs:label """Word mastery includes understanding and producing words without support in new
  contexts."""@en ;
  dcterms:modified "2026-06-07T15:30:29.628744Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26380-3
  a curric:KeyLearningPoint ;
  rdfs:label """Relative clauses add information about the noun in the main clause without starting
  another sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.628748Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26380-4
  a curric:KeyLearningPoint ;
  rdfs:label """English uses relative pronouns ‘who’, ‘that’, ‘which’, while German uses the
  definite article that matches the noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.628775Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26380-5
  a curric:KeyLearningPoint ;
  rdfs:label """In German, the relative pronoun kicks the verb to the end of the relative clause;
  this is called word order three (WO3)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.628779Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26384-1
  a curric:KeyLearningPoint ;
  rdfs:label """Months of the year are masculine and borrowed from English, but the stressed
  syllables are not the same."""@en ;
  dcterms:modified "2026-06-07T15:30:29.630298Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26384-2
  a curric:KeyLearningPoint ;
  rdfs:label """Modal verbs are used with a 2nd verb in the infinitive, which comes at the end of
  the sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.630302Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26384-3
  a curric:KeyLearningPoint ;
  rdfs:label """The imperfect tense of modal verbs is commonly used when speaking, as well as when
  writing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.630306Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26384-4
  a curric:KeyLearningPoint ;
  rdfs:label """Add -te to the verb stem of a modal verb for the 1st and 3rd person singular
  imperfect tense, e.g., 'er musste'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.630310Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26384-5
  a curric:KeyLearningPoint ;
  rdfs:label """Add -test to the verb stem of a modal verb for the 2nd person singular imperfect
  tense, e.g., 'du wolltest'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.630314Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26278-1
  a curric:KeyLearningPoint ;
  rdfs:label "The past participle comes at the end of a sentence in the perfect tense."@en ;
  dcterms:modified "2026-06-07T15:30:29.630675Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26278-2
  a curric:KeyLearningPoint ;
  rdfs:label "Time adverbials with adjectives use the accusative case."@en ;
  dcterms:modified "2026-06-07T15:30:29.630679Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26278-3
  a curric:KeyLearningPoint ;
  rdfs:label "Time adverbials at the beginning of the sentence trigger word order 2."@en ;
  dcterms:modified "2026-06-07T15:30:29.630683Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26278-4
  a curric:KeyLearningPoint ;
  rdfs:label "Describing location requires the dative."@en ;
  dcterms:modified "2026-06-07T15:30:29.630687Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26414-1
  a curric:KeyLearningPoint ;
  rdfs:label """Past participles of weak verbs sandwich the stem between ge- and -t; verbs with
  inseparable prefixes don't add ge-."""@en ;
  dcterms:modified "2026-06-07T15:30:29.630691Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26414-2
  a curric:KeyLearningPoint ;
  rdfs:label """Past participles of strong verbs sandwich the stem between ge- and -en; the stem
  vowel may change: 'singen', 'gesungen'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.630695Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26414-3
  a curric:KeyLearningPoint ;
  rdfs:label """The prefix 'mit' adds the meaning of 'taking part', or 'doing with' to verbs, e.g.,
  'mitmachen' - 'to join in'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.630699Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26414-4
  a curric:KeyLearningPoint ;
  rdfs:label """1st syllable stress is common in German; words with inseparable prefixes stress the
  2nd syllable, -ieren verbs the -ie."""@en ;
  dcterms:modified "2026-06-07T15:30:29.630703Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26414-5
  a curric:KeyLearningPoint ;
  rdfs:label """'Kein' (no, not any) negates nouns with indefinite articles, with 'ein' endings;
  'nicht' (not) negates everything else."""@en ;
  dcterms:modified "2026-06-07T15:30:29.630707Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26413-1
  a curric:KeyLearningPoint ;
  rdfs:label """Use imperfect modal verbs in speech and writing to say what you and others wanted,
  were able or had to do."""@en ;
  dcterms:modified "2026-06-07T15:30:29.631644Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26413-2
  a curric:KeyLearningPoint ;
  rdfs:label """Use present modal modal verbs to communicate present/future actions, e.g., Ich will
  in der Zukunft nach Rügen fahren.'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.631649Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26413-3
  a curric:KeyLearningPoint ;
  rdfs:label """Adverbs in a sentence follow the order time, manner, place (TMP); this word order
  applies in all tenses."""@en ;
  dcterms:modified "2026-06-07T15:30:29.631656Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26413-4
  a curric:KeyLearningPoint ;
  rdfs:label """Details of time, manner and place often co-occur in travel sentences – word order
  must follow TMP in main clauses."""@en ;
  dcterms:modified "2026-06-07T15:30:29.631661Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26403-1
  a curric:KeyLearningPoint ;
  rdfs:label """In sentences with 2 objects, if one is a pronoun, the pronoun is first, whether it
  is a direct or indirect pronoun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.631665Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26403-2
  a curric:KeyLearningPoint ;
  rdfs:label "If both objects are nouns, the indirect object precedes the direct object."@en ;
  dcterms:modified "2026-06-07T15:30:29.631669Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26403-3
  a curric:KeyLearningPoint ;
  rdfs:label "Use 'uns' ('to us', 'us') as both an indirect and direct object pronoun."@en ;
  dcterms:modified "2026-06-07T15:30:29.631674Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26403-4
  a curric:KeyLearningPoint ;
  rdfs:label """Use 'euch' ('to you', 'you' - plural) as both an indirect and direct object
  pronoun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.631678Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26314-1
  a curric:KeyLearningPoint ;
  rdfs:label "Care is needed with [zw] and [schw] when listening and speaking."@en ;
  dcterms:modified "2026-06-07T15:30:29.632166Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26314-2
  a curric:KeyLearningPoint ;
  rdfs:label """Reading longer texts can be a useful way to reinforce vocabulary recognition and
  understanding."""@en ;
  dcterms:modified "2026-06-07T15:30:29.632170Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26314-3
  a curric:KeyLearningPoint ;
  rdfs:label """‘Früher’ can be used with the perfect tense to say what used to happen, e.g., 'ich
  habe früher Bücher gelesen'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.632174Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26314-4
  a curric:KeyLearningPoint ;
  rdfs:label """‘Noch nicht’ can be used with the perfect tense to say what hasn’t yet happened,
  e.g., 'ich habe noch nicht gegessen'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.632179Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26314-5
  a curric:KeyLearningPoint ;
  rdfs:label """Identifying verb tenses and other important grammar points is a good strategy when
  translating into German."""@en ;
  dcterms:modified "2026-06-07T15:30:29.632183Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26349-1
  a curric:KeyLearningPoint ;
  rdfs:label """Cognates are pronounced in German with different syllable stress from their English
  equivalents."""@en ;
  dcterms:modified "2026-06-07T15:30:29.632373Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26349-2
  a curric:KeyLearningPoint ;
  rdfs:label """For present tense weak (regular) verbs, add -e, -st, -t to the stem for singular
  persons."""@en ;
  dcterms:modified "2026-06-07T15:30:29.632379Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26349-3
  a curric:KeyLearningPoint ;
  rdfs:label """For present tense verbs, the 'wir' (we), 'Sie' (formal you) and 'sie' (they) forms
  are the same as the infinitive."""@en ;
  dcterms:modified "2026-06-07T15:30:29.632384Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26349-4
  a curric:KeyLearningPoint ;
  rdfs:label """German has one present tense, with two English translations, simple or continuous
  present - I do or I am doing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.632388Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26349-5
  a curric:KeyLearningPoint ;
  rdfs:label """The German inversion question 'Spielst du?' can translate as either 'Do you play' or
  'Are you playing?'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.632445Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26320-1
  a curric:KeyLearningPoint ;
  rdfs:label """The 's' in [sp] and [st] sounds like [sch] at the start of a word, as part of a
  compound noun or after a prefix."""@en ;
  dcterms:modified "2026-06-07T15:30:29.632452Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26320-2
  a curric:KeyLearningPoint ;
  rdfs:label """The adverb 'lieber' means 'rather', and is used to say 'prefer' with a verb. The
  verb ‘lieben’ means ‘to love, loving’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.632456Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26320-3
  a curric:KeyLearningPoint ;
  rdfs:label "The conjunctions 'denn' and 'weil' both mean 'because'."@en ;
  dcterms:modified "2026-06-07T15:30:29.632461Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26320-4
  a curric:KeyLearningPoint ;
  rdfs:label """The verb follows the subject when using 'denn'. This is standard word order or word
  order 1 (WO1)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.632465Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26320-5
  a curric:KeyLearningPoint ;
  rdfs:label """The verb moves to the end of the clause when using 'weil'. This is word order 3
  (WO3)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.632469Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26416-1
  a curric:KeyLearningPoint ;
  rdfs:label """Add suffix -chen or -lein to create diminutive nouns with the English equivalent
  meaning ‘little’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.632513Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26416-2
  a curric:KeyLearningPoint ;
  rdfs:label "Use the imperfect tense in German to narrate past events, mainly in writing."@en ;
  dcterms:modified "2026-06-07T15:30:29.632517Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26416-3
  a curric:KeyLearningPoint ;
  rdfs:label """Singular weak imperfect verbs add -te to the stem for ‘ich’ and ‘er, sie, es’ and an
  additional -st for the ‘du’ form."""@en ;
  dcterms:modified "2026-06-07T15:30:29.632524Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26416-4
  a curric:KeyLearningPoint ;
  rdfs:label """Strong verbs have an irregular stem including a vowel change, and don’t add -te;
  ‘du’ forms add -st to the stem."""@en ;
  dcterms:modified "2026-06-07T15:30:29.632529Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26273-1
  a curric:KeyLearningPoint ;
  rdfs:label """'Der Bodensee' (Lake Constance) is a lake that borders Germany, Switzerland and
  Austria."""@en ;
  dcterms:modified "2026-06-07T15:30:29.632907Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26273-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Nach' means 'to' with place names, continents and most countries, and is never
  followed by a definite article ('the')."""@en ;
  dcterms:modified "2026-06-07T15:30:29.632915Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26273-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Zu' means 'to' when used with places with articles, e.g., 'Ich gehe zu dem Park.'.
  The article is in the dative case."""@en ;
  dcterms:modified "2026-06-07T15:30:29.632921Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26273-4
  a curric:KeyLearningPoint ;
  rdfs:label "Use 'zu' with people, professions and events, e.g., 'Ich gehe zu dem Lehrer.'."@en ;
  dcterms:modified "2026-06-07T15:30:29.632926Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26273-5
  a curric:KeyLearningPoint ;
  rdfs:label """'Zu' and 'dem' can be shortened to 'zum'. 'Zu' and 'der' can be shortened to
  'zur'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.632932Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26217-1
  a curric:KeyLearningPoint ;
  rdfs:label "Swap the verb and subject in a sentence to create a closed (yes/no) question."@en ;
  dcterms:modified "2026-06-07T15:30:29.633899Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26217-2
  a curric:KeyLearningPoint ;
  rdfs:label "An open question has a question word at the start."@en ;
  dcterms:modified "2026-06-07T15:30:29.633903Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26217-3
  a curric:KeyLearningPoint ;
  rdfs:label """Place a question word directly in front of the verb to change a closed question into
  an open one."""@en ;
  dcterms:modified "2026-06-07T15:30:29.633907Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26231-1
  a curric:KeyLearningPoint ;
  rdfs:label "[sch] is pronounced like the English 'sh'."@en ;
  dcterms:modified "2026-06-07T15:30:29.633947Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26231-2
  a curric:KeyLearningPoint ;
  rdfs:label "[sp] always starts with the English sound 'sh' before the 'p'."@en ;
  dcterms:modified "2026-06-07T15:30:29.633951Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26231-3
  a curric:KeyLearningPoint ;
  rdfs:label """1st and 3rd person singular forms of the verb 'mögen' are identical - 'ich mag' and
  'er/sie/es mag'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.633955Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26231-4
  a curric:KeyLearningPoint ;
  rdfs:label "To say 'them' in German, use the plural object pronoun 'sie' for all genders."@en ;
  dcterms:modified "2026-06-07T15:30:29.633959Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26231-5
  a curric:KeyLearningPoint ;
  rdfs:label "To say you don't like something, add 'nicht' at the end of the statement."@en ;
  dcterms:modified "2026-06-07T15:30:29.633963Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26304-1
  a curric:KeyLearningPoint ;
  rdfs:label """Separable verbs are made up of a prefix and a main verb, e.g., 'stattfinden' - 'to
  take place'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.634481Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26304-2
  a curric:KeyLearningPoint ;
  rdfs:label """We must remember the separable prefix, especially when English equivalents are
  single verbs, e.g. 'anfangen' - to start."""@en ;
  dcterms:modified "2026-06-07T15:30:29.634485Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26304-3
  a curric:KeyLearningPoint ;
  rdfs:label """Three placement verbs - 'stellen', 'setzen', 'legen' - describe putting something
  somewhere, and take the accusative."""@en ;
  dcterms:modified "2026-06-07T15:30:29.634489Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26304-4
  a curric:KeyLearningPoint ;
  rdfs:label """When items are already in position, we use equivalent position verbs 'stehen',
  'sitzen' and 'liegen'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.634493Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26304-5
  a curric:KeyLearningPoint ;
  rdfs:label """The word order 3 conjunction ‘während’ (while) is useful for referring to two things
  happening at the same time."""@en ;
  dcterms:modified "2026-06-07T15:30:29.634497Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26216-1
  a curric:KeyLearningPoint ;
  rdfs:label "[ch] can be either soft (as in 'ich') or hard (as in 'Buch')."@en ;
  dcterms:modified "2026-06-07T15:30:29.634868Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26216-2
  a curric:KeyLearningPoint ;
  rdfs:label """Remove 'en' from the infinitive, add 'st' for the 2nd person singular of most weak
  verbs in German."""@en ;
  dcterms:modified "2026-06-07T15:30:29.634872Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26216-3
  a curric:KeyLearningPoint ;
  rdfs:label "If the verb stem ends in 'z', add only '-t' for the 2nd person singular."@en ;
  dcterms:modified "2026-06-07T15:30:29.634876Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26204-1
  a curric:KeyLearningPoint ;
  rdfs:label """[z] is pronounced like 'Zug' and sounds like the English 'ts' at the end of the word
  'boots'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.635271Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26204-2
  a curric:KeyLearningPoint ;
  rdfs:label """The verb 'sein' means 'to be/being'. 'Ich bin' means 'I am' and 'du bist' means 'you
  are'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.635275Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26204-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Nicht' means 'not' when used before an adjective."@en ;
  dcterms:modified "2026-06-07T15:30:29.635279Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26204-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Kein' means 'not a' and is used to negate nouns; 'kein' for masculine/neuter nouns,
  'keine' for feminine nouns."""@en ;
  dcterms:modified "2026-06-07T15:30:29.635283Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26358-1
  a curric:KeyLearningPoint ;
  rdfs:label """Form the perfect tense with the present tense of 'haben' or 'sein', plus a past
  participle at the end of the statement."""@en ;
  dcterms:modified "2026-06-07T15:30:29.635473Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26358-2
  a curric:KeyLearningPoint ;
  rdfs:label """Form most past participles by adding 'ge-' and '-t' around the verb stem. '-ieren'
  verbs do not add 'ge-'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.635479Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26358-3
  a curric:KeyLearningPoint ;
  rdfs:label """Verbs with prefixes 'be-', 'ver-', 'er-' don't add 'ge-' to form past participles.
  Their prefixes are never stressed."""@en ;
  dcterms:modified "2026-06-07T15:30:29.635484Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26358-4
  a curric:KeyLearningPoint ;
  rdfs:label "The subject pronoun 'ihr' means 'you (familiar, plural)'."@en ;
  dcterms:modified "2026-06-07T15:30:29.635488Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26358-5
  a curric:KeyLearningPoint ;
  rdfs:label """Use the adverb 'früher' to translate 'used to' from English, e.g., 'Ich habe früher
  getanzt, aber jetzt nicht mehr.'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.635494Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26276-1
  a curric:KeyLearningPoint ;
  rdfs:label """Plural rule 1: most masculine and neuter nouns add ‘-e’ or ‘-e + umlaut’ to form a
  plural."""@en ;
  dcterms:modified "2026-06-07T15:30:29.635498Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26276-2
  a curric:KeyLearningPoint ;
  rdfs:label """Plural rule 2: masculine and neuter nouns ending in ‘-el’, ‘-en’, ‘-er’ are often
  the same in the plural."""@en ;
  dcterms:modified "2026-06-07T15:30:29.635502Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26276-3
  a curric:KeyLearningPoint ;
  rdfs:label "Plural rule 3: most feminine nouns add ‘-n’ or ‘-en’ to form a plural."@en ;
  dcterms:modified "2026-06-07T15:30:29.635506Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26276-4
  a curric:KeyLearningPoint ;
  rdfs:label """Plural rule 4: some masculine and neuter nouns add ‘-er’ at the end and an umlaut on
  the vowel to form a plural."""@en ;
  dcterms:modified "2026-06-07T15:30:29.635511Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26274-1
  a curric:KeyLearningPoint ;
  rdfs:label "German numbers 13-19 are simple sums, e.g., 'drei + zehn' = 'dreizehn'."@en ;
  dcterms:modified "2026-06-07T15:30:29.635864Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26274-2
  a curric:KeyLearningPoint ;
  rdfs:label "Numbers 21-99 say the second digit first, e.g., 'vierundzwanzig' = '24'."@en ;
  dcterms:modified "2026-06-07T15:30:29.635868Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26274-3
  a curric:KeyLearningPoint ;
  rdfs:label """An ordinal number tells you the order of something, e.g. 'first, second, third'. Use
  ordinal numbers for calendar dates."""@en ;
  dcterms:modified "2026-06-07T15:30:29.635872Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26274-4
  a curric:KeyLearningPoint ;
  rdfs:label """For 1-19, form ordinal numbers by adding '-te', e.g., 'fünfte'; add '-ste' to 20 and
  over, e.g., 'einundzwanzigste'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.635876Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26274-5
  a curric:KeyLearningPoint ;
  rdfs:label """'Am' means 'on the' and requires an '-n' to be added to the ordinal number, e.g.,
  'am zweiten März'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.635880Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26254-1
  a curric:KeyLearningPoint ;
  rdfs:label "Final [d] (a [d] at the end of a word) sounds the same as [t]."@en ;
  dcterms:modified "2026-06-07T15:30:29.636022Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26254-2
  a curric:KeyLearningPoint ;
  rdfs:label """Plurals indicate more than one of something and this is reflected in the form of the
  article, noun or verb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.636026Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26254-3
  a curric:KeyLearningPoint ;
  rdfs:label """Use adverbs to describe where, how or when something happens. In word order 2, the
  adverb comes first in the sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.636030Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26254-4
  a curric:KeyLearningPoint ;
  rdfs:label "In German, verbs change their endings to match who or what they refer to."@en ;
  dcterms:modified "2026-06-07T15:30:29.636034Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26254-5
  a curric:KeyLearningPoint ;
  rdfs:label """Subject pronouns (e.g., 'he', 'er') replace nouns. They match the noun they replace
  in gender and number."""@en ;
  dcterms:modified "2026-06-07T15:30:29.636038Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26327-1
  a curric:KeyLearningPoint ;
  rdfs:label """At the start or in the middle of German words, [d] sounds like English 'd'. At the
  end, it sounds like 't'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.636695Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26327-2
  a curric:KeyLearningPoint ;
  rdfs:label """Use time phrases, e.g., 'am Montag', with the present tense to refer to future
  plans."""@en ;
  dcterms:modified "2026-06-07T15:30:29.636699Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26327-3
  a curric:KeyLearningPoint ;
  rdfs:label """Emphasis on whatever is first in the sentence. You can use inversion (word order 2)
  to create this emphasis."""@en ;
  dcterms:modified "2026-06-07T15:30:29.636704Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26327-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Nach' means 'to' with place names, continents and most countries. 'Zu' means 'to'
  when used with places with articles."""@en ;
  dcterms:modified "2026-06-07T15:30:29.636708Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26327-5
  a curric:KeyLearningPoint ;
  rdfs:label "Use zu with people, professions and events, e.g., 'Ich gehe zu Oma.'."@en ;
  dcterms:modified "2026-06-07T15:30:29.636712Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26371-1
  a curric:KeyLearningPoint ;
  rdfs:label """Reading is a good way to strengthen word knowledge and can be done in a range of
  ways."""@en ;
  dcterms:modified "2026-06-07T15:30:29.637894Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26371-2
  a curric:KeyLearningPoint ;
  rdfs:label """The perfect tense is formed with a present tense part of 'haben' or 'sein' and a
  past participle."""@en ;
  dcterms:modified "2026-06-07T15:30:29.637933Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26371-3
  a curric:KeyLearningPoint ;
  rdfs:label """Many past participles are formed by adding ge- to the start of the verb stem and -t
  to the end."""@en ;
  dcterms:modified "2026-06-07T15:30:29.637939Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26371-4
  a curric:KeyLearningPoint ;
  rdfs:label """For verbs starting with be-, er- and ver- , the past participle does not have the
  prefix ge-."""@en ;
  dcterms:modified "2026-06-07T15:30:29.637943Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26371-5
  a curric:KeyLearningPoint ;
  rdfs:label """Strong verbs in the perfect tense form the past participle by adding -en; they often
  have a vowel change too."""@en ;
  dcterms:modified "2026-06-07T15:30:29.637947Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26285-1
  a curric:KeyLearningPoint ;
  rdfs:label """[ai] and [ei] can sound the same in German, but in words borrowed from English [ai]
  is pronounced as in English."""@en ;
  dcterms:modified "2026-06-07T15:30:29.637951Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26285-2
  a curric:KeyLearningPoint ;
  rdfs:label """In German, when adjectives come after the verb 'sein' (to be) they do not
  change."""@en ;
  dcterms:modified "2026-06-07T15:30:29.637955Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26285-3
  a curric:KeyLearningPoint ;
  rdfs:label """In German, adjectives in front of a noun add endings; this is called adjective
  agreement."""@en ;
  dcterms:modified "2026-06-07T15:30:29.637959Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26285-4
  a curric:KeyLearningPoint ;
  rdfs:label """Add '-e' for the singular nominative ending of all adjectives with definite
  articles."""@en ;
  dcterms:modified "2026-06-07T15:30:29.637963Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26285-5
  a curric:KeyLearningPoint ;
  rdfs:label """The singular nominative adjective endings for indefinite articles are -er
  (masculine), -e (feminine), and -es (neuter)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.637967Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26308-1
  a curric:KeyLearningPoint ;
  rdfs:label """Use the verbs 'denken' (to think), 'glauben' (to believe), and 'meinen' (to have the
  opinion) to say what you think."""@en ;
  dcterms:modified "2026-06-07T15:30:29.638629Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26308-2
  a curric:KeyLearningPoint ;
  rdfs:label """In German, there is always a comma after an opinion verb; e.g., 'Ich denke, Sport
  ist lustig.'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.638633Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26308-3
  a curric:KeyLearningPoint ;
  rdfs:label """Generally, the conjunction 'dass' (that) is used after opinion verbs; e.g., 'Ich
  denke, dass ...'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.638637Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26308-4
  a curric:KeyLearningPoint ;
  rdfs:label """The conjunction 'dass' is followed by word order 3 (WO3), where the verb goes to the
  end of the sentence or clause."""@en ;
  dcterms:modified "2026-06-07T15:30:29.638641Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26315-1
  a curric:KeyLearningPoint ;
  rdfs:label """Final [e] is not silent. It is a short [e] sound, as in 'Liebe'. Final [er] is a
  longer sound, as in 'lieber'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.638697Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26315-2
  a curric:KeyLearningPoint ;
  rdfs:label """Add '-er' to adjectives or adverbs to form the comparative. There are some
  exceptions, e.g., 'gut - besser'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.638705Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26315-3
  a curric:KeyLearningPoint ;
  rdfs:label """Use 'als' to mean 'than', e.g. 'besser als'. Where two things are the same, use 'so
  ... wie', e.g.. 'so gut wie',"""@en ;
  dcterms:modified "2026-06-07T15:30:29.638710Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26315-4
  a curric:KeyLearningPoint ;
  rdfs:label """Plural rule 5: some nouns add '–s'. They may end in in –a, -i,-o,-u-or –y and are
  usually 'borrowed' words."""@en ;
  dcterms:modified "2026-06-07T15:30:29.638714Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26315-5
  a curric:KeyLearningPoint ;
  rdfs:label "Make adjectives into plural nouns by capitalising the adjective and adding -en."@en ;
  dcterms:modified "2026-06-07T15:30:29.638718Z"^^xsd:dateTime .

# ----------------------------------------------------------------------
# Pupil Lesson Outcomes
# ----------------------------------------------------------------------

oakcurric:pupillessonoutcome-lesson-26309
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use the perfect tense with 'haben' to understand and narrate a short sequence
  of past events."""@en ;
  dcterms:modified "2026-06-07T15:30:41.063308Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-26296
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use the manner-place rule when talking about past travel: where I went and how
  I got there."""@en ;
  dcterms:modified "2026-06-07T15:30:41.063548Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-26305
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use verbs with direct and indirect object pronouns to talk about things we do
  to and for others."""@en ;
  dcterms:modified "2026-06-07T15:30:41.063837Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-26370
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use a range of pronouns and possessive adjectives to describe how people get
  on."""@en ;
  dcterms:modified "2026-06-07T15:30:41.063903Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-26306
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use the prepositions 'für' and 'von' and dative verbs to write about
  exchanging gifts with friends and family."""@en ;
  dcterms:modified "2026-06-07T15:30:41.063908Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-26287
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use adjectives before nouns in the accusative case to describe others'
  appearances."""@en ;
  dcterms:modified "2026-06-07T15:30:41.063913Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-26234
  a curric:PupilLessonOutcome ;
  rdfs:label """I can understand and summarise short texts in the present tense about
  German-speaking public figures."""@en ;
  dcterms:modified "2026-06-07T15:30:41.064200Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-26392
  a curric:PupilLessonOutcome ;
  rdfs:label """I can express likes and preferences using 'mögen' with a subject and 'gefallen' with
  an indirect object."""@en ;
  dcterms:modified "2026-06-07T15:30:41.064336Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-26356
  a curric:PupilLessonOutcome ;
  rdfs:label """I can explain what I see or don't see, using 'kein' or 'nicht' appropriately to
  negate words or sentences."""@en ;
  dcterms:modified "2026-06-07T15:30:41.064341Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-26299
  a curric:PupilLessonOutcome ;
  rdfs:label "I can say what I like and don't like doing using the adverb 'gern'."@en ;
  dcterms:modified "2026-06-07T15:30:41.064345Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-26294
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use the 12-hour clock and word order 2 to say what hour I did different
  activities, and use present and past (perfect) tenses to translate a message into German."""@en ;
  dcterms:modified "2026-06-07T15:30:41.064400Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-26281
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use the informal 'du' and formal 'Sie' correctly when talking to friends or
  adults on an exchange trip."""@en ;
  dcterms:modified "2026-06-07T15:30:41.064491Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-26259
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use the present tense and adverbs to ask and answer questions about what I do
  generally and what I am doing now."""@en ;
  dcterms:modified "2026-06-07T15:30:41.064587Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-26293
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use present and perfect tenses to talk about what we do and did on the last
  day in Berlin."""@en ;
  dcterms:modified "2026-06-07T15:30:41.064591Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-26417
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use wo- and da-compounds to ask and answer questions about fairy tale
  events."""@en ;
  dcterms:modified "2026-06-07T15:30:41.064596Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-26330
  a curric:PupilLessonOutcome ;
  rdfs:label """I can emphasise different parts of sentences by using inversion (word order two),
  and understand how to form sentences that use two verbs."""@en ;
  dcterms:modified "2026-06-07T15:30:41.064899Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-26209
  a curric:PupilLessonOutcome ;
  rdfs:label """I can say what I, you or she/he has and can use the indefinite and definite articles
  in the accusative case."""@en ;
  dcterms:modified "2026-06-07T15:30:41.064978Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-26207
  a curric:PupilLessonOutcome ;
  rdfs:label """I can say what I or someone else has using the verb 'haben' and the definite article
  'den'."""@en ;
  dcterms:modified "2026-06-07T15:30:41.065074Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-26229
  a curric:PupilLessonOutcome ;
  rdfs:label """I can ask and answer questions in speaking and writing about more than one thing,
  and build my own sentences from known vocabulary."""@en ;
  dcterms:modified "2026-06-07T15:30:41.065110Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-26382
  a curric:PupilLessonOutcome ;
  rdfs:label """I can form the perfect tense with 'sein' and can say calendar years in German, in
  the context of important people and dates."""@en ;
  dcterms:modified "2026-06-07T15:30:41.065146Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-26373
  a curric:PupilLessonOutcome ;
  rdfs:label "I can talk about routine activities and times using the 24-hour clock."@en ;
  dcterms:modified "2026-06-07T15:30:41.065506Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-26369
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use infinitives as nouns and know when to use 'zu' with infinitives in the
  context of important relationships with others."""@en ;
  dcterms:modified "2026-06-07T15:30:41.065670Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-26271
  a curric:PupilLessonOutcome ;
  rdfs:label """I can express my plans for the future by using time phrases with 'nächst-' and the
  present tense, in the 1st person singular and plural."""@en ;
  dcterms:modified "2026-06-07T15:30:41.065675Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-26258
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use the present tense forms of 'sein' and 'haben' when communicating with my
  friends."""@en ;
  dcterms:modified "2026-06-07T15:30:41.065791Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-26322
  a curric:PupilLessonOutcome ;
  rdfs:label "I can use object pronouns to talk about school."@en ;
  dcterms:modified "2026-06-07T15:30:41.065849Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-26237
  a curric:PupilLessonOutcome ;
  rdfs:label """I can distinguish English and German uses of the present tense and talk about what I
  do with others using the 1st person plural of weak verbs and of 'sein'."""@en ;
  dcterms:modified "2026-06-07T15:30:41.066262Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-26338
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use 'in', 'an', and 'auf' with the accusative and dative to say where I went
  or was on a past holiday, and I can understand the time past and to the hour."""@en ;
  dcterms:modified "2026-06-07T15:30:41.066330Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-26212
  a curric:PupilLessonOutcome ;
  rdfs:label """I can recognise the infinitive of a verb and can form the 3rd person singular from
  the infinitive in the context of school activities."""@en ;
  dcterms:modified "2026-06-07T15:30:41.066467Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-26224
  a curric:PupilLessonOutcome ;
  rdfs:label """I can recognise and use German plural rule 3 - add -(e)n to feminine nouns - and say
  what things are like using ‘ist’ and ‘sind’."""@en ;
  dcterms:modified "2026-06-07T15:30:41.066525Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-26241
  a curric:PupilLessonOutcome ;
  rdfs:label """I can identify compound nouns, label their grammatical gender and use familiar
  strong verbs in the 1st and 3rd person singular present tense to compare activities."""@en ;
  dcterms:modified "2026-06-07T15:30:41.066529Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-26324
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use dative prepositions ‘seit’ and ‘vor’ to say how long ago something
  happened, when it started, or how long it has been going on for."""@en ;
  dcterms:modified "2026-06-07T15:30:41.066732Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-26335
  a curric:PupilLessonOutcome ;
  rdfs:label """I can understand and use prepositions with dative articles and adjectives to say
  where specific things are located."""@en ;
  dcterms:modified "2026-06-07T15:30:41.066850Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-26239
  a curric:PupilLessonOutcome ;
  rdfs:label """I can say what I or others are unable to do by using 'nicht' or 'kein' with
  'können'."""@en ;
  dcterms:modified "2026-06-07T15:30:41.067002Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-26311
  a curric:PupilLessonOutcome ;
  rdfs:label """I can compare the past with now using the imperfect tense words ‘war’, ‘hatte’ and
  ‘es gab’."""@en ;
  dcterms:modified "2026-06-07T15:30:41.067043Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-26277
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use past and present tenses to understand about holiday experiences in
  German."""@en ;
  dcterms:modified "2026-06-07T15:30:41.067194Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-26256
  a curric:PupilLessonOutcome ;
  rdfs:label """I can choose the correct verb 'to go' for specific contexts, and identify how
  adverbs can describe location or movement."""@en ;
  dcterms:modified "2026-06-07T15:30:41.067290Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-26366
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use plural forms of 'werden' in two-verb structures to describe future
  plans."""@en ;
  dcterms:modified "2026-06-07T15:30:41.067294Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-26390
  a curric:PupilLessonOutcome ;
  rdfs:label """I can recognise higher numbers, make plural noun forms, and use 'mögen' to say what
  I like and would like."""@en ;
  dcterms:modified "2026-06-07T15:30:41.067441Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-26368
  a curric:PupilLessonOutcome ;
  rdfs:label """I can recognise infinitives and use them correctly in two-verb structures when
  talking about what is important to me."""@en ;
  dcterms:modified "2026-06-07T15:30:41.067449Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-26391
  a curric:PupilLessonOutcome ;
  rdfs:label """I can recognise and say calendar years and describe future work ambitions using
  'möcht-'."""@en ;
  dcterms:modified "2026-06-07T15:30:41.067610Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-26228
  a curric:PupilLessonOutcome ;
  rdfs:label """I can count to twelve in German, and recognise plurals of masculine, feminine and
  neuter nouns using four different plural rules."""@en ;
  dcterms:modified "2026-06-07T15:30:41.067643Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-26336
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use different prepositions to understand and say exactly where things are in
  my neighbourhood."""@en ;
  dcterms:modified "2026-06-07T15:30:41.067846Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-26365
  a curric:PupilLessonOutcome ;
  rdfs:label "I can express what I would like and what I would like to do using 'möcht-'."@en ;
  dcterms:modified "2026-06-07T15:30:41.067908Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-26333
  a curric:PupilLessonOutcome ;
  rdfs:label """I can describe the features and contents of a house using definite articles and
  nominative and accusative adjective endings."""@en ;
  dcterms:modified "2026-06-07T15:30:41.067969Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-26381
  a curric:PupilLessonOutcome ;
  rdfs:label """I can create adjectives from nouns adding the suffix -los, and I can use relative
  clauses to give further information about suspects and clues in the context of a murder
  mystery party."""@en ;
  dcterms:modified "2026-06-07T15:30:41.068164Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-26385
  a curric:PupilLessonOutcome ;
  rdfs:label """I can form the imperfect tense plural forms of the verbs 'haben' and 'sein', and use
  them in the context of childhood experiences."""@en ;
  dcterms:modified "2026-06-07T15:30:41.068192Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-26326
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use my developing vocabulary and grammar knowledge to infer the likely
  meanings of unfamiliar words in a news article."""@en ;
  dcterms:modified "2026-06-07T15:30:41.068343Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-26321
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use possessive adjectives 'unser' and 'ihr' to describe school experiences for
  different people."""@en ;
  dcterms:modified "2026-06-07T15:30:41.068355Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-26297
  a curric:PupilLessonOutcome ;
  rdfs:label "I can express what I or someone else did or has done on a past trip."@en ;
  dcterms:modified "2026-06-07T15:30:41.068368Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-26223
  a curric:PupilLessonOutcome ;
  rdfs:label """I can apply masculine and neuter plural rules 1 and 2 to build sentences with ‘es
  gibt’ and ‘viele’."""@en ;
  dcterms:modified "2026-06-07T15:30:41.068816Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-26355
  a curric:PupilLessonOutcome ;
  rdfs:label """I can understand and write about birthday experiences in past and present
  tenses."""@en ;
  dcterms:modified "2026-06-07T15:30:41.068820Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-26222
  a curric:PupilLessonOutcome ;
  rdfs:label """I can apply masculine and neuter plural rules 1 and 2 and understand some German
  Christmas traditions."""@en ;
  dcterms:modified "2026-06-07T15:30:41.068890Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-26420
  a curric:PupilLessonOutcome ;
  rdfs:label """I can understand and translate texts on past achievements and future goals, applying
  knowledge of perfect and present tenses, present and imperfect modals, and word order."""@en ;
  dcterms:modified "2026-06-07T15:30:41.068894Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-26255
  a curric:PupilLessonOutcome ;
  rdfs:label """I can describe someone else's day using a range of vocabulary, possessive adjectives
  and verbs in the present tense."""@en ;
  dcterms:modified "2026-06-07T15:30:41.069008Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-26226
  a curric:PupilLessonOutcome ;
  rdfs:label """I can say what something is like, identifying grammatical gender and using the
  correct word for ‘it’."""@en ;
  dcterms:modified "2026-06-07T15:30:41.069261Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-26270
  a curric:PupilLessonOutcome ;
