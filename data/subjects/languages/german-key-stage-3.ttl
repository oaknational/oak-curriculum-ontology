# ----------------------------------------------------------------------
# Keywords
# ----------------------------------------------------------------------

oakcurric:keyword-imperfect-tense
  a curric:Keyword ;
  schema:name "imperfect tense"@en ;
  schema:description "tense used to describe how things were or used to be in the past"@en ;
  dcterms:modified "2026-06-07T15:30:02.347280Z"^^xsd:dateTime .

oakcurric:keyword-sound-symbol-correspondence
  a curric:Keyword ;
  schema:name "sound-symbol correspondence"@en ;
  schema:description "relationship between letters and their sounds"@en ;
  dcterms:modified "2026-06-07T15:30:02.347335Z"^^xsd:dateTime .

oakcurric:keyword-modal-verb
  a curric:Keyword ;
  schema:name "modal verb"@en ;
  schema:description """verb of necessity or possibility used with a 2nd verb in infinitive e.g.
  must, can, want"""@en ;
  dcterms:modified "2026-06-07T15:30:02.347445Z"^^xsd:dateTime .

oakcurric:keyword-simple-present
  a curric:Keyword ;
  schema:name "simple present"@en ;
  schema:description "verb tense used to express habitual events in the present e.g. 'I do'"@en ;
  dcterms:modified "2026-06-07T15:30:02.347450Z"^^xsd:dateTime .

oakcurric:keyword-idiom
  a curric:Keyword ;
  schema:name "idiom"@en ;
