  dcterms:modified "2026-06-07T15:30:29.366401Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1195-4
  a curric:KeyLearningPoint ;
  rdfs:label "Objects are made from different materials depending on their use."@en ;
  dcterms:modified "2026-06-07T15:30:29.366405Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1140-1
  a curric:KeyLearningPoint ;
  rdfs:label "The human body is made up of lots of different parts."@en ;
  dcterms:modified "2026-06-07T15:30:29.366826Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1140-2
  a curric:KeyLearningPoint ;
  rdfs:label "Different body parts do different jobs."@en ;
  dcterms:modified "2026-06-07T15:30:29.366829Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1140-3
  a curric:KeyLearningPoint ;
  rdfs:label "Body parts can be recorded using drawing and labelling skills."@en ;
  dcterms:modified "2026-06-07T15:30:29.366833Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1146-1
  a curric:KeyLearningPoint ;
  rdfs:label "Different objects can be made from different materials."@en ;
  dcterms:modified "2026-06-07T15:30:29.369019Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1146-2
  a curric:KeyLearningPoint ;
  rdfs:label "Some materials can be recycled and used again."@en ;
  dcterms:modified "2026-06-07T15:30:29.369025Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1146-3
  a curric:KeyLearningPoint ;
  rdfs:label "Glass, paper, plastic, wood and metal can often be recycled."@en ;
  dcterms:modified "2026-06-07T15:30:29.369029Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1146-4
  a curric:KeyLearningPoint ;
  rdfs:label "Objects can be sorted into different materials by observing and comparing."@en ;
  dcterms:modified "2026-06-07T15:30:29.369033Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1146-5
  a curric:KeyLearningPoint ;
  rdfs:label "Recycling is important because it reduces waste and this helps the planet."@en ;
  dcterms:modified "2026-06-07T15:30:29.369037Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1164-1
  a curric:KeyLearningPoint ;
  rdfs:label "Everything in the world can be classified into living or non-living."@en ;
  dcterms:modified "2026-06-07T15:30:29.376472Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1164-2
  a curric:KeyLearningPoint ;
  rdfs:label "A living thing is something that is alive and needs food, water and air."@en ;
  dcterms:modified "2026-06-07T15:30:29.376476Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1164-3
  a curric:KeyLearningPoint ;
  rdfs:label "All living things share certain characteristics in common called life processes."@en ;
  dcterms:modified "2026-06-07T15:30:29.376480Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1164-4
  a curric:KeyLearningPoint ;
  rdfs:label """Living things can move by themselves to achieve a goal, and this is a sign
  of life."""@en ;
  dcterms:modified "2026-06-07T15:30:29.376486Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1159-1
  a curric:KeyLearningPoint ;
  rdfs:label "The weather is often different in each season."@en ;
  dcterms:modified "2026-06-07T15:30:29.377400Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1159-2
  a curric:KeyLearningPoint ;
  rdfs:label """Summer is the warmest season in the UK, although it can still be windy and
  rainy."""@en ;
  dcterms:modified "2026-06-07T15:30:29.377404Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1159-3
  a curric:KeyLearningPoint ;
  rdfs:label "Temperature is how hot or cold something is."@en ;
  dcterms:modified "2026-06-07T15:30:29.377408Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1159-4
  a curric:KeyLearningPoint ;
  rdfs:label "A thermometer can be used to measure the temperature of different seasons."@en ;
  dcterms:modified "2026-06-07T15:30:29.377412Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1194-1
  a curric:KeyLearningPoint ;
  rdfs:label "It is important for humans to have good hygiene in order to live a healthy life."@en ;
  dcterms:modified "2026-06-07T15:30:29.379511Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1194-2
  a curric:KeyLearningPoint ;
  rdfs:label """It is important for humans to exercise and eat the right amounts of different types
  of food."""@en ;
  dcterms:modified "2026-06-07T15:30:29.379515Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1194-3
  a curric:KeyLearningPoint ;
  rdfs:label "Scientists share important information by presenting it in different ways."@en ;
  dcterms:modified "2026-06-07T15:30:29.379519Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1149-1
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists think about why different materials are waterproof and not waterproof and
  how this can help us."""@en ;
  dcterms:modified "2026-06-07T15:30:29.386381Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1149-2
  a curric:KeyLearningPoint ;
  rdfs:label """The results of an investigation can tell us which materials are waterproof and not
  waterproof."""@en ;
  dcterms:modified "2026-06-07T15:30:29.386385Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1149-3
  a curric:KeyLearningPoint ;
  rdfs:label """Famous scientists in the past have helped us to learn about waterproof
  materials."""@en ;
  dcterms:modified "2026-06-07T15:30:29.386389Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1149-4
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists today and in the future help us to learn more about waterproof
  materials."""@en ;
