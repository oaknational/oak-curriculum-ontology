  healthy."""@en ;
  dcterms:modified "2026-06-07T15:30:29.364633Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1192-4
  a curric:KeyLearningPoint ;
  rdfs:label "Different types of food can be sorted into different groups."@en ;
  dcterms:modified "2026-06-07T15:30:29.364637Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1196-1
  a curric:KeyLearningPoint ;
  rdfs:label "Different objects can be made from different materials."@en ;
  dcterms:modified "2026-06-07T15:30:29.364671Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1196-2
  a curric:KeyLearningPoint ;
  rdfs:label """The material that an object is made from is usually the most suitable for
  its use."""@en ;
  dcterms:modified "2026-06-07T15:30:29.364675Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1196-3
  a curric:KeyLearningPoint ;
  rdfs:label """The properties of materials make them suitable or unsuitable for particular
  uses."""@en ;
  dcterms:modified "2026-06-07T15:30:29.364679Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1196-4
  a curric:KeyLearningPoint ;
  rdfs:label """Materials can be compared and sorted into either suitable or unsuitable, for
  different uses."""@en ;
  dcterms:modified "2026-06-07T15:30:29.364682Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1195-1
  a curric:KeyLearningPoint ;
  rdfs:label "A material is what an object is made from."@en ;
  dcterms:modified "2026-06-07T15:30:29.366393Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1195-2
  a curric:KeyLearningPoint ;
  rdfs:label """Some common materials are wood, metal, plastic, glass, brick, rock, paper, fabric
  and cardboard."""@en ;
  dcterms:modified "2026-06-07T15:30:29.366397Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1195-3
  a curric:KeyLearningPoint ;
