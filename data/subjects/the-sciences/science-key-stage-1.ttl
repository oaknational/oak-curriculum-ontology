# ----------------------------------------------------------------------
# Key Learning Points
# ----------------------------------------------------------------------

oakcurric:keylearningpoint-lesson-1186-1
  a curric:KeyLearningPoint ;
  rdfs:label "Animals, including humans need certain things in order to stay alive."@en ;
  dcterms:modified "2026-06-07T15:30:29.253515Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1186-2
  a curric:KeyLearningPoint ;
  rdfs:label "To survive means to continue to stay alive."@en ;
  dcterms:modified "2026-06-07T15:30:29.253520Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1186-3
  a curric:KeyLearningPoint ;
  rdfs:label "All animals need food and water to grow, remain healthy and stay alive."@en ;
  dcterms:modified "2026-06-07T15:30:29.253524Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1186-4
  a curric:KeyLearningPoint ;
  rdfs:label "All animals need air so that they can breathe and stay alive."@en ;
  dcterms:modified "2026-06-07T15:30:29.253528Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1137-1
  a curric:KeyLearningPoint ;
  rdfs:label """Fish are animals that live in water and have gills on the side of their head to help
  them breathe."""@en ;
  dcterms:modified "2026-06-07T15:30:29.254264Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1137-2
  a curric:KeyLearningPoint ;
  rdfs:label "Amphibians are animals that are able to live on land and in water."@en ;
  dcterms:modified "2026-06-07T15:30:29.254268Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1137-3
  a curric:KeyLearningPoint ;
  rdfs:label "Most fish have scales on their bodies, amphibians do not have scales."@en ;
  dcterms:modified "2026-06-07T15:30:29.254273Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1137-4
  a curric:KeyLearningPoint ;
  rdfs:label "Different fish and amphibians have different names."@en ;
  dcterms:modified "2026-06-07T15:30:29.254277Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1137-5
  a curric:KeyLearningPoint ;
  rdfs:label """Animals can be sorted into fish and amphibians using simple classification
  skills."""@en ;
  dcterms:modified "2026-06-07T15:30:29.254282Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1171-1
  a curric:KeyLearningPoint ;
  rdfs:label "Animals need food from plants and other animals to stay alive."@en ;
  dcterms:modified "2026-06-07T15:30:29.256003Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1171-2
  a curric:KeyLearningPoint ;
  rdfs:label """A food chain is used to show the order in which living things depend on each other
  for food."""@en ;
  dcterms:modified "2026-06-07T15:30:29.256008Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1171-3
  a curric:KeyLearningPoint ;
  rdfs:label "A food chain begins with a plant."@en ;
  dcterms:modified "2026-06-07T15:30:29.256012Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1025-1
  a curric:KeyLearningPoint ;
  rdfs:label "Some flowering plants grow naturally in the wild, such as in woods and meadows."@en ;
  dcterms:modified "2026-06-07T15:30:29.256372Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1025-2
  a curric:KeyLearningPoint ;
  rdfs:label "Wildflowers grow from seeds, often without any help from people."@en ;
  dcterms:modified "2026-06-07T15:30:29.256376Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1025-3
  a curric:KeyLearningPoint ;
  rdfs:label "Wildflowers can be looked at closely and compared using observation skills."@en ;
  dcterms:modified "2026-06-07T15:30:29.256380Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1025-4
  a curric:KeyLearningPoint ;
  rdfs:label """Wildflowers can be identified and named using simple secondary sources of
  information."""@en ;
  dcterms:modified "2026-06-07T15:30:29.256384Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9040-1
  a curric:KeyLearningPoint ;
  rdfs:label "Many plants form part of a healthy diet."@en ;
  dcterms:modified "2026-06-07T15:30:29.259961Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9040-2
  a curric:KeyLearningPoint ;
  rdfs:label "Often plants are grown as crops for people to eat."@en ;
  dcterms:modified "2026-06-07T15:30:29.259965Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9040-3
  a curric:KeyLearningPoint ;
  rdfs:label "Some crops can be grown locally, including in gardens and school grounds."@en ;
  dcterms:modified "2026-06-07T15:30:29.259968Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9040-4
  a curric:KeyLearningPoint ;
  rdfs:label """Sustainable crop growth occurs when a farmer or gardener makes sure that the soil
  and plants are cared for."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259972Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9040-5
  a curric:KeyLearningPoint ;
  rdfs:label "Sustainable crops in the UK include wheat, fruit, potatoes and other vegetables."@en ;
  dcterms:modified "2026-06-07T15:30:29.259976Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1184-1
  a curric:KeyLearningPoint ;
  rdfs:label "All animals grow and change from birth to being an  adult"@en ;
  dcterms:modified "2026-06-07T15:30:29.260274Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1184-2
  a curric:KeyLearningPoint ;
  rdfs:label """The journey of an animal from beginning until it is fully grown is called its life
  cycle"""@en ;
  dcterms:modified "2026-06-07T15:30:29.260278Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1184-3
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists can use observation skills to describe the stage an animal has reached in
  its life cycle"""@en ;
  dcterms:modified "2026-06-07T15:30:29.260283Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1134-1
  a curric:KeyLearningPoint ;
  rdfs:label """Animals are living things. They can move around and feed themselves by eating plants
  or other animals."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261354Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1134-2
  a curric:KeyLearningPoint ;
  rdfs:label """Different animals have different names. Some animals are more familiar to us than
  others."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261357Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1134-3
  a curric:KeyLearningPoint ;
  rdfs:label "Some animals are kept in the home as pets and looked after by humans."@en ;
  dcterms:modified "2026-06-07T15:30:29.261361Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1134-4
  a curric:KeyLearningPoint ;
  rdfs:label """Wild animals should not be kept as pets, they live freely in the wild and find their
  own food, water and shelter."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261364Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1134-5
  a curric:KeyLearningPoint ;
  rdfs:label "Familiar animals can be compared, sorted and grouped into pets and not pets."@en ;
  dcterms:modified "2026-06-07T15:30:29.261368Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1145-1
  a curric:KeyLearningPoint ;
  rdfs:label "An object is a thing that is not alive."@en ;
  dcterms:modified "2026-06-07T15:30:29.261386Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1145-2
  a curric:KeyLearningPoint ;
  rdfs:label "A material is what an object is made from."@en ;
  dcterms:modified "2026-06-07T15:30:29.261392Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1145-3
  a curric:KeyLearningPoint ;
  rdfs:label "Some common materials are plastic, wood, metal, glass, water and rock."@en ;
  dcterms:modified "2026-06-07T15:30:29.261396Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1145-4
  a curric:KeyLearningPoint ;
  rdfs:label "Different objects can be made from different materials."@en ;
  dcterms:modified "2026-06-07T15:30:29.261399Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1145-5
  a curric:KeyLearningPoint ;
  rdfs:label "Some objects can be made from more than one material."@en ;
  dcterms:modified "2026-06-07T15:30:29.261403Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1021-1
  a curric:KeyLearningPoint ;
  rdfs:label "Plants can be found in the local environment"@en ;
  dcterms:modified "2026-06-07T15:30:29.270041Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1021-2
  a curric:KeyLearningPoint ;
  rdfs:label "Things in the local environment can be classified as plants or not plants"@en ;
  dcterms:modified "2026-06-07T15:30:29.270045Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1021-3
  a curric:KeyLearningPoint ;
  rdfs:label "Plants grow and change throughout the year"@en ;
  dcterms:modified "2026-06-07T15:30:29.270048Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1021-4
  a curric:KeyLearningPoint ;
  rdfs:label "Scientists use observation skills to identify different plants"@en ;
  dcterms:modified "2026-06-07T15:30:29.270052Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1024-1
  a curric:KeyLearningPoint ;
  rdfs:label "Some plants have flowers."@en ;
  dcterms:modified "2026-06-07T15:30:29.273214Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1024-2
  a curric:KeyLearningPoint ;
  rdfs:label "Flowers can be different colours, shapes and sizes."@en ;
  dcterms:modified "2026-06-07T15:30:29.273218Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1024-3
  a curric:KeyLearningPoint ;
  rdfs:label "Flowering plants can be looked at closely and compared using observation skills."@en ;
  dcterms:modified "2026-06-07T15:30:29.273222Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1024-4
  a curric:KeyLearningPoint ;
  rdfs:label """Common flowering plants can be identified and named using simple secondary sources
  of information."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273226Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9016-1
  a curric:KeyLearningPoint ;
  rdfs:label "Recycling is one of the 3Rs: Reduce, Reuse, Recycle."@en ;
  dcterms:modified "2026-06-07T15:30:29.275428Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9016-2
  a curric:KeyLearningPoint ;
  rdfs:label "Rubbish needs to be sorted into different materials before it can be recycled."@en ;
  dcterms:modified "2026-06-07T15:30:29.275432Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9016-3
  a curric:KeyLearningPoint ;
  rdfs:label "Plastic, glass and wood can be recycled and made into new and useful things."@en ;
  dcterms:modified "2026-06-07T15:30:29.275435Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1154-1
  a curric:KeyLearningPoint ;
  rdfs:label "The weather is often different in each season."@en ;
  dcterms:modified "2026-06-07T15:30:29.275456Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1154-2
  a curric:KeyLearningPoint ;
  rdfs:label "The weather in winter turns colder, sometimes with snow, frost and ice."@en ;
  dcterms:modified "2026-06-07T15:30:29.275460Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1154-3
  a curric:KeyLearningPoint ;
  rdfs:label "A thermometer can be used to measure the temperature of different seasons."@en ;
  dcterms:modified "2026-06-07T15:30:29.275464Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1154-4
  a curric:KeyLearningPoint ;
  rdfs:label "We can make observations of the weather during winter."@en ;
  dcterms:modified "2026-06-07T15:30:29.275470Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1176-1
  a curric:KeyLearningPoint ;
  rdfs:label "A bulb is an underground bud or stem of a plant at resting stage."@en ;
  dcterms:modified "2026-06-07T15:30:29.279981Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1176-2
  a curric:KeyLearningPoint ;
  rdfs:label """Different types of plants can grow from different types of bulbs, such as some
  flowering plants and vegetables."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279985Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1176-3
  a curric:KeyLearningPoint ;
  rdfs:label """Inside of a bulb is a mini version of the plant waiting to grow, including flower,
  leaf and root parts."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279988Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1176-4
  a curric:KeyLearningPoint ;
  rdfs:label """The first stage of growth from a bulb is when a root grows downwards and a shoot
  grows upwards."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279994Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1176-5
  a curric:KeyLearningPoint ;
  rdfs:label "Bulbs can be observed growing into mature plants."@en ;
  dcterms:modified "2026-06-07T15:30:29.279998Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1027-1
  a curric:KeyLearningPoint ;
  rdfs:label "Trees are plants and are made up of different parts"@en ;
  dcterms:modified "2026-06-07T15:30:29.280017Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1027-2
  a curric:KeyLearningPoint ;
  rdfs:label "Trees have roots hidden under the ground"@en ;
  dcterms:modified "2026-06-07T15:30:29.280020Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1027-3
  a curric:KeyLearningPoint ;
  rdfs:label "The stem of a tree is often known as the trunk"@en ;
  dcterms:modified "2026-06-07T15:30:29.280024Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1027-4
  a curric:KeyLearningPoint ;
  rdfs:label "Branches and twigs grow out of the trunk to support leaves, flowers and fruit"@en ;
  dcterms:modified "2026-06-07T15:30:29.280028Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1027-5
  a curric:KeyLearningPoint ;
  rdfs:label "Different parts of trees can be identified and named using observation skills"@en ;
  dcterms:modified "2026-06-07T15:30:29.280034Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2748-1
  a curric:KeyLearningPoint ;
  rdfs:label "Different animals eat different types of food."@en ;
  dcterms:modified "2026-06-07T15:30:29.280193Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2748-2
  a curric:KeyLearningPoint ;
  rdfs:label """Some animals only eat meat, including the flesh of other animals. They are called
  carnivores."""@en ;
  dcterms:modified "2026-06-07T15:30:29.280197Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2748-3
  a curric:KeyLearningPoint ;
  rdfs:label "Some animals only eat plants or plant products. They are called herbivores."@en ;
  dcterms:modified "2026-06-07T15:30:29.280230Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2748-4
  a curric:KeyLearningPoint ;
  rdfs:label "Some animals eat both meat and plants. They are called omnivores."@en ;
  dcterms:modified "2026-06-07T15:30:29.280235Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2748-5
  a curric:KeyLearningPoint ;
  rdfs:label "Animals can be named and grouped according to what they eat."@en ;
  dcterms:modified "2026-06-07T15:30:29.280239Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1167-1
  a curric:KeyLearningPoint ;
  rdfs:label "A habitat is where a group of plants and animals live."@en ;
  dcterms:modified "2026-06-07T15:30:29.280242Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1167-2
  a curric:KeyLearningPoint ;
  rdfs:label "A habitat provides the things an animal or plant needs to survive."@en ;
  dcterms:modified "2026-06-07T15:30:29.280246Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1167-3
  a curric:KeyLearningPoint ;
  rdfs:label "Most living things live in habitats to which they are suited."@en ;
  dcterms:modified "2026-06-07T15:30:29.280249Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1167-4
  a curric:KeyLearningPoint ;
  rdfs:label "Different plants live in different habitats, depending on their basic needs."@en ;
  dcterms:modified "2026-06-07T15:30:29.280253Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1157-1
  a curric:KeyLearningPoint ;
  rdfs:label "The weather is often different in each season."@en ;
  dcterms:modified "2026-06-07T15:30:29.284052Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1157-2
  a curric:KeyLearningPoint ;
  rdfs:label "Common weather can be described as cold, cloudy, windy, rainy or sunny."@en ;
  dcterms:modified "2026-06-07T15:30:29.284056Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1157-3
  a curric:KeyLearningPoint ;
  rdfs:label "The weather in spring can be mixed, with periods of wind, rain and sunshine."@en ;
  dcterms:modified "2026-06-07T15:30:29.284062Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1157-4
  a curric:KeyLearningPoint ;
  rdfs:label "Rain can be collected and measured using a rain gauge."@en ;
  dcterms:modified "2026-06-07T15:30:29.284066Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1169-1
  a curric:KeyLearningPoint ;
  rdfs:label "A microhabitat is a smaller area where a plant or animal lives."@en ;
  dcterms:modified "2026-06-07T15:30:29.284069Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1169-2
  a curric:KeyLearningPoint ;
  rdfs:label """Some microhabitats are under threat because people are not looking after planet
  Earth."""@en ;
  dcterms:modified "2026-06-07T15:30:29.284075Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1169-3
  a curric:KeyLearningPoint ;
  rdfs:label """A wildlife-friendly garden can encourage plants and animals to live safely in
  microhabitats."""@en ;
  dcterms:modified "2026-06-07T15:30:29.284079Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1141-1
  a curric:KeyLearningPoint ;
  rdfs:label "The human body is made up of lots of different parts."@en ;
  dcterms:modified "2026-06-07T15:30:29.288530Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1141-2
  a curric:KeyLearningPoint ;
  rdfs:label "There are body parts on the inside of your body as well as on the outside."@en ;
  dcterms:modified "2026-06-07T15:30:29.288534Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1141-3
  a curric:KeyLearningPoint ;
  rdfs:label """Body parts on the inside can include the heart, the lungs, the stomach and the
  brain."""@en ;
  dcterms:modified "2026-06-07T15:30:29.288538Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1141-4
  a curric:KeyLearningPoint ;
  rdfs:label "Different body parts do different jobs."@en ;
  dcterms:modified "2026-06-07T15:30:29.288542Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1141-5
  a curric:KeyLearningPoint ;
  rdfs:label "Body parts can be recorded using drawing and labelling skills."@en ;
  dcterms:modified "2026-06-07T15:30:29.288547Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1180-1
  a curric:KeyLearningPoint ;
  rdfs:label "Plants are living things, they need water to grow, stay alive and keep healthy."@en ;
  dcterms:modified "2026-06-07T15:30:29.289660Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1180-2
  a curric:KeyLearningPoint ;
  rdfs:label """Without light, plants will grow taller at first, leaves lose their green colour and
  turn yellow or white."""@en ;
  dcterms:modified "2026-06-07T15:30:29.289664Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1180-3
  a curric:KeyLearningPoint ;
  rdfs:label "Changes in plant growth can be compared and described using observation skills."@en ;
  dcterms:modified "2026-06-07T15:30:29.289668Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1180-4
  a curric:KeyLearningPoint ;
  rdfs:label "Different plants grow in different places with different amounts of light."@en ;
  dcterms:modified "2026-06-07T15:30:29.289672Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1180-5
  a curric:KeyLearningPoint ;
  rdfs:label """Unhealthy plants without light can sometimes be recovered with light within a short
  period of time."""@en ;
  dcterms:modified "2026-06-07T15:30:29.289675Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9173-1
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists who study food and how it works in your body are called
  nutritionists."""@en ;
  dcterms:modified "2026-06-07T15:30:29.291593Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9173-2
  a curric:KeyLearningPoint ;
  rdfs:label "Nutritionists carry out tests and make observations of the food we eat."@en ;
  dcterms:modified "2026-06-07T15:30:29.291597Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9173-3
  a curric:KeyLearningPoint ;
  rdfs:label """Nutritionists share their results with food companies and schools to encourage
  healthy choices."""@en ;
  dcterms:modified "2026-06-07T15:30:29.291601Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1023-1
  a curric:KeyLearningPoint ;
  rdfs:label "Evergreen trees keep their green leaves all year round."@en ;
  dcterms:modified "2026-06-07T15:30:29.292820Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1023-2
  a curric:KeyLearningPoint ;
  rdfs:label "Deciduous trees lose their leaves in the autumn."@en ;
  dcterms:modified "2026-06-07T15:30:29.292824Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1023-3
  a curric:KeyLearningPoint ;
  rdfs:label "Trees can be compared throughout the year using observation skills."@en ;
  dcterms:modified "2026-06-07T15:30:29.292828Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1023-4
  a curric:KeyLearningPoint ;
  rdfs:label "In autumn and winter, trees can be identified as evergreen or deciduous."@en ;
  dcterms:modified "2026-06-07T15:30:29.292834Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1135-1
  a curric:KeyLearningPoint ;
  rdfs:label """Mammals are animals that have a backbone, breathe air, and grow hair at some point
  during their life."""@en ;
  dcterms:modified "2026-06-07T15:30:29.292874Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1135-2
  a curric:KeyLearningPoint ;
  rdfs:label "Mammals give birth to live young and feed them milk."@en ;
  dcterms:modified "2026-06-07T15:30:29.292878Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1135-3
  a curric:KeyLearningPoint ;
  rdfs:label "Mammals are warm blooded animals."@en ;
  dcterms:modified "2026-06-07T15:30:29.292882Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1135-4
  a curric:KeyLearningPoint ;
  rdfs:label "Different mammals have different names."@en ;
  dcterms:modified "2026-06-07T15:30:29.292886Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1135-5
  a curric:KeyLearningPoint ;
  rdfs:label """Animals can be sorted into mammals and not mammals using simple classification
  skills."""@en ;
  dcterms:modified "2026-06-07T15:30:29.292890Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1151-1
  a curric:KeyLearningPoint ;
  rdfs:label """The year can be divided into four seasons, each lasting approximately three
  months."""@en ;
  dcterms:modified "2026-06-07T15:30:29.292941Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1151-2
  a curric:KeyLearningPoint ;
  rdfs:label "The four seasons are winter, spring, summer and autumn."@en ;
  dcterms:modified "2026-06-07T15:30:29.292945Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1151-3
  a curric:KeyLearningPoint ;
  rdfs:label "The season of autumn happens in September, October and November."@en ;
  dcterms:modified "2026-06-07T15:30:29.292949Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1151-4
  a curric:KeyLearningPoint ;
  rdfs:label "The leaves of some trees begin to change colour in autumn."@en ;
  dcterms:modified "2026-06-07T15:30:29.292953Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1151-5
  a curric:KeyLearningPoint ;
  rdfs:label "We can use our skills to observe changes in autumn."@en ;
  dcterms:modified "2026-06-07T15:30:29.292957Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1183-1
  a curric:KeyLearningPoint ;
  rdfs:label "Offspring are young animals in relation to their parents"@en ;
  dcterms:modified "2026-06-07T15:30:29.300477Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1183-2
  a curric:KeyLearningPoint ;
  rdfs:label "Offspring change and grow into adults"@en ;
  dcterms:modified "2026-06-07T15:30:29.300481Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1183-3
  a curric:KeyLearningPoint ;
  rdfs:label """Animals at different stages of growth can be grouped by looking at what is similar
  and what is different"""@en ;
  dcterms:modified "2026-06-07T15:30:29.300487Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1183-4
  a curric:KeyLearningPoint ;
  rdfs:label """Animals at different stages of growth can be ordered correctly using observation
  skills"""@en ;
  dcterms:modified "2026-06-07T15:30:29.300491Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1150-1
  a curric:KeyLearningPoint ;
  rdfs:label """Some materials let all light pass through, these are called transparent materials
  and you can see through them clearly."""@en ;
  dcterms:modified "2026-06-07T15:30:29.302029Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1150-2
  a curric:KeyLearningPoint ;
  rdfs:label "Some materials do not let light through, these are called opaque materials."@en ;
  dcterms:modified "2026-06-07T15:30:29.302033Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1150-3
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists plan and carry out simple tests to find out which materials are
  transparent and opaque."""@en ;
  dcterms:modified "2026-06-07T15:30:29.302037Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1150-4
  a curric:KeyLearningPoint ;
  rdfs:label "The results of an investigation can be recorded in a simple table."@en ;
  dcterms:modified "2026-06-07T15:30:29.302041Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1026-1
  a curric:KeyLearningPoint ;
  rdfs:label "Plants are made up of different parts."@en ;
  dcterms:modified "2026-06-07T15:30:29.302081Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1026-2
  a curric:KeyLearningPoint ;
  rdfs:label "The parts of a plant are also known as the structure of a plant."@en ;
  dcterms:modified "2026-06-07T15:30:29.302086Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1026-3
  a curric:KeyLearningPoint ;
  rdfs:label "The main parts of a flowering plant are roots, stem, leaves and flower."@en ;
  dcterms:modified "2026-06-07T15:30:29.302090Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1026-4
  a curric:KeyLearningPoint ;
  rdfs:label "The parts of flowering plants can be looked at closely using observation skills."@en ;
  dcterms:modified "2026-06-07T15:30:29.302094Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1026-5
  a curric:KeyLearningPoint ;
  rdfs:label """The parts of a flowering plant may look different at different times of the
  year."""@en ;
  dcterms:modified "2026-06-07T15:30:29.302101Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1139-1
  a curric:KeyLearningPoint ;
  rdfs:label "Animals are living things that need food, water and air to stay alive."@en ;
  dcterms:modified "2026-06-07T15:30:29.305785Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1139-2
  a curric:KeyLearningPoint ;
  rdfs:label "Animals that have similar features can be grouped together."@en ;
  dcterms:modified "2026-06-07T15:30:29.305789Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1139-3
  a curric:KeyLearningPoint ;
  rdfs:label "Mammals, insects, reptiles, amphibians, fish and birds are all animals."@en ;
  dcterms:modified "2026-06-07T15:30:29.305793Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1139-4
  a curric:KeyLearningPoint ;
  rdfs:label """Humans are animals, with hair on their bodies, that belong to the group called
  mammals ."""@en ;
  dcterms:modified "2026-06-07T15:30:29.305796Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1152-1
  a curric:KeyLearningPoint ;
  rdfs:label "The weather is often different in each season."@en ;
  dcterms:modified "2026-06-07T15:30:29.306771Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1152-2
  a curric:KeyLearningPoint ;
  rdfs:label "Some types of weather can be described as cold, cloudy, windy, rainy or sunny."@en ;
  dcterms:modified "2026-06-07T15:30:29.306777Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1152-3
  a curric:KeyLearningPoint ;
  rdfs:label "The weather in autumn is often windy and rainy, and turns colder."@en ;
  dcterms:modified "2026-06-07T15:30:29.306781Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1152-4
  a curric:KeyLearningPoint ;
  rdfs:label "Temperature is how hot or cold something is."@en ;
  dcterms:modified "2026-06-07T15:30:29.306785Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1152-5
  a curric:KeyLearningPoint ;
  rdfs:label "A thermometer can be used to measure the temperature of different seasons."@en ;
  dcterms:modified "2026-06-07T15:30:29.306789Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1142-1
  a curric:KeyLearningPoint ;
  rdfs:label "The eyes are used for seeing."@en ;
  dcterms:modified "2026-06-07T15:30:29.308220Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1142-2
  a curric:KeyLearningPoint ;
  rdfs:label "The ears are used for hearing."@en ;
  dcterms:modified "2026-06-07T15:30:29.308224Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1142-3
  a curric:KeyLearningPoint ;
  rdfs:label "The tongue is used for tasting."@en ;
  dcterms:modified "2026-06-07T15:30:29.308228Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1142-4
  a curric:KeyLearningPoint ;
  rdfs:label "The nose is used for smelling."@en ;
  dcterms:modified "2026-06-07T15:30:29.308232Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1142-5
  a curric:KeyLearningPoint ;
  rdfs:label "The skin is used for touching."@en ;
  dcterms:modified "2026-06-07T15:30:29.308236Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1191-1
  a curric:KeyLearningPoint ;
  rdfs:label "It is important for humans to live a healthy life."@en ;
  dcterms:modified "2026-06-07T15:30:29.308252Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1191-2
  a curric:KeyLearningPoint ;
  rdfs:label "Exercise is one way for humans to become and stay healthy."@en ;
  dcterms:modified "2026-06-07T15:30:29.308256Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1191-3
  a curric:KeyLearningPoint ;
  rdfs:label """Exercise increases breathing rate, heart rate and can cause humans to sweat
  more."""@en ;
  dcterms:modified "2026-06-07T15:30:29.308260Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1191-4
  a curric:KeyLearningPoint ;
  rdfs:label "Exercise is known to improve your heart, lungs and muscle strength."@en ;
  dcterms:modified "2026-06-07T15:30:29.308264Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1188-1
  a curric:KeyLearningPoint ;
  rdfs:label "It is important for humans to live a healthy life."@en ;
  dcterms:modified "2026-06-07T15:30:29.311917Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1188-2
  a curric:KeyLearningPoint ;
  rdfs:label """Personal hygiene is the way we care for our bodies, including washing hands and
  bathing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.311921Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1188-3
  a curric:KeyLearningPoint ;
  rdfs:label "Invisible germs can be passed easily between humans."@en ;
  dcterms:modified "2026-06-07T15:30:29.311925Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1188-4
  a curric:KeyLearningPoint ;
  rdfs:label "Scientists investigate how germs spread and how this can be prevented."@en ;
  dcterms:modified "2026-06-07T15:30:29.311929Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1188-5
  a curric:KeyLearningPoint ;
  rdfs:label """Regular handwashing is one of the best ways to remove germs and prevent them
  spreading to others."""@en ;
  dcterms:modified "2026-06-07T15:30:29.311933Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1200-1
  a curric:KeyLearningPoint ;
  rdfs:label "Materials can be squashed by pressing on them to change their shape."@en ;
  dcterms:modified "2026-06-07T15:30:29.312408Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1200-2
  a curric:KeyLearningPoint ;
  rdfs:label """Materials can be bent by pushing or pulling a straight shape into a curve or an
  angle."""@en ;
  dcterms:modified "2026-06-07T15:30:29.312414Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1200-3
  a curric:KeyLearningPoint ;
  rdfs:label """Materials can be twisted by holding each end and turning them in opposite
  directions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.312418Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1200-4
  a curric:KeyLearningPoint ;
  rdfs:label "Materials can be stretched by pulling them to change their shape."@en ;
  dcterms:modified "2026-06-07T15:30:29.312422Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1200-5
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists can plan and test how squashing, bending, twisting and stretching can
  change the shape of some materials."""@en ;
  dcterms:modified "2026-06-07T15:30:29.312426Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2798-1
  a curric:KeyLearningPoint ;
  rdfs:label """The results of an investigation can tell us which materials are transparent and
  opaque."""@en ;
  dcterms:modified "2026-06-07T15:30:29.317962Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2798-2
  a curric:KeyLearningPoint ;
  rdfs:label "Materials can be sorted into transparent and opaque."@en ;
  dcterms:modified "2026-06-07T15:30:29.317966Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2798-3
  a curric:KeyLearningPoint ;
  rdfs:label "Scientists think about how transparent and opaque materials can be useful to us."@en ;
  dcterms:modified "2026-06-07T15:30:29.317970Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1147-1
  a curric:KeyLearningPoint ;
  rdfs:label "Different materials can be described in different ways."@en ;
  dcterms:modified "2026-06-07T15:30:29.319930Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1147-2
  a curric:KeyLearningPoint ;
  rdfs:label "The describing words we use for a material are called its properties."@en ;
  dcterms:modified "2026-06-07T15:30:29.319934Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1147-3
  a curric:KeyLearningPoint ;
  rdfs:label "We use our senses when describing properties of materials."@en ;
  dcterms:modified "2026-06-07T15:30:29.319938Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1147-4
  a curric:KeyLearningPoint ;
  rdfs:label "Materials can be compared and grouped on the basis of their simple properties."@en ;
  dcterms:modified "2026-06-07T15:30:29.319942Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1144-1
  a curric:KeyLearningPoint ;
  rdfs:label "There are five basic senses in humans: sight, hearing, touch, smell and taste."@en ;
  dcterms:modified "2026-06-07T15:30:29.320531Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1144-2
  a curric:KeyLearningPoint ;
  rdfs:label "Humans can use their senses to explore the world around them."@en ;
  dcterms:modified "2026-06-07T15:30:29.320537Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1144-3
  a curric:KeyLearningPoint ;
  rdfs:label "Humans use their tongue to identify taste."@en ;
  dcterms:modified "2026-06-07T15:30:29.320541Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1144-4
  a curric:KeyLearningPoint ;
  rdfs:label "Humans use their skin to identify touch."@en ;
  dcterms:modified "2026-06-07T15:30:29.320545Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1144-5
  a curric:KeyLearningPoint ;
  rdfs:label "We often use our other senses when touching and tasting."@en ;
  dcterms:modified "2026-06-07T15:30:29.320549Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1201-1
  a curric:KeyLearningPoint ;
  rdfs:label """Squashing, bending, twisting and stretching are ways in which some shapes of objects
  can be changed."""@en ;
  dcterms:modified "2026-06-07T15:30:29.321089Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1201-2
  a curric:KeyLearningPoint ;
  rdfs:label """The results of a test can show what happens when objects are squashed, bent, twisted
  and stretched."""@en ;
  dcterms:modified "2026-06-07T15:30:29.321093Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1201-3
  a curric:KeyLearningPoint ;
  rdfs:label """Some objects are made from materials whose shape cannot be changed when squashed,
  bent, twisted or stretched."""@en ;
  dcterms:modified "2026-06-07T15:30:29.321097Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1201-4
  a curric:KeyLearningPoint ;
  rdfs:label """Some materials do not change back to their original shape on their own after being
  squashed, bent, twisted or stretched."""@en ;
  dcterms:modified "2026-06-07T15:30:29.321103Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1175-1
  a curric:KeyLearningPoint ;
  rdfs:label "Plants are living things, just like humans and other animals."@en ;
  dcterms:modified "2026-06-07T15:30:29.325882Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1175-2
  a curric:KeyLearningPoint ;
  rdfs:label """Plants need water, light and a suitable temperature (warmth) in order to grow and
  stay healthy."""@en ;
  dcterms:modified "2026-06-07T15:30:29.325887Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1175-3
  a curric:KeyLearningPoint ;
  rdfs:label "Scientists ask questions and set up simple tests to find answers."@en ;
  dcterms:modified "2026-06-07T15:30:29.325890Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1175-4
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists investigate and observe what happens to plants if they do not get what
  they need."""@en ;
  dcterms:modified "2026-06-07T15:30:29.325894Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1197-1
  a curric:KeyLearningPoint ;
  rdfs:label """The properties of materials make them suitable or unsuitable for particular
  uses."""@en ;
  dcterms:modified "2026-06-07T15:30:29.327242Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1197-2
  a curric:KeyLearningPoint ;
  rdfs:label "Being absorbent is one such property of some materials."@en ;
  dcterms:modified "2026-06-07T15:30:29.327246Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1197-3
  a curric:KeyLearningPoint ;
  rdfs:label "If a material is absorbent, it soaks up something, often a liquid such as water."@en ;
  dcterms:modified "2026-06-07T15:30:29.327250Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1197-4
  a curric:KeyLearningPoint ;
  rdfs:label "Some materials are absorbent, and this makes them suitable for certain uses."@en ;
  dcterms:modified "2026-06-07T15:30:29.327254Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1197-5
  a curric:KeyLearningPoint ;
  rdfs:label "Scientists test materials to find out which are absorbent and which are not."@en ;
  dcterms:modified "2026-06-07T15:30:29.327258Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1163-1
  a curric:KeyLearningPoint ;
  rdfs:label "The world is made up of things that are living and not living (non-living)."@en ;
  dcterms:modified "2026-06-07T15:30:29.327303Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1163-2
  a curric:KeyLearningPoint ;
  rdfs:label "A living thing is something that is alive and needs food, water and air."@en ;
  dcterms:modified "2026-06-07T15:30:29.327307Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1163-3
  a curric:KeyLearningPoint ;
  rdfs:label """A thing that is not living does not need food, water and air because it is not
  alive."""@en ;
  dcterms:modified "2026-06-07T15:30:29.327313Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1163-4
  a curric:KeyLearningPoint ;
  rdfs:label """Living and non-living things can be compared and grouped by looking at what is the
  same and what is different."""@en ;
  dcterms:modified "2026-06-07T15:30:29.327317Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1148-1
  a curric:KeyLearningPoint ;
  rdfs:label """The properties of materials make them suitable or not suitable for different
  jobs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.332827Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1148-2
  a curric:KeyLearningPoint ;
  rdfs:label "Being waterproof is one type of simple property."@en ;
  dcterms:modified "2026-06-07T15:30:29.332833Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1148-3
  a curric:KeyLearningPoint ;
  rdfs:label "If a material is waterproof it does not let water pass through it."@en ;
  dcterms:modified "2026-06-07T15:30:29.332837Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1148-4
  a curric:KeyLearningPoint ;
  rdfs:label "Some materials are waterproof and some materials are not."@en ;
  dcterms:modified "2026-06-07T15:30:29.332841Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1148-5
  a curric:KeyLearningPoint ;
  rdfs:label "Scientists test materials to find out which are waterproof and which are not."@en ;
  dcterms:modified "2026-06-07T15:30:29.332845Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1190-1
  a curric:KeyLearningPoint ;
  rdfs:label "Personal hygiene is the way we care for our bodies including brushing our teeth."@en ;
  dcterms:modified "2026-06-07T15:30:29.332849Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1190-2
  a curric:KeyLearningPoint ;
  rdfs:label "Plaque is a sticky substance made up mostly of the germs that cause tooth decay."@en ;
  dcterms:modified "2026-06-07T15:30:29.332853Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1190-3
  a curric:KeyLearningPoint ;
  rdfs:label """Avoiding sugary food and visiting the dentist regularly helps to keep teeth
  healthy."""@en ;
  dcterms:modified "2026-06-07T15:30:29.332857Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1190-4
  a curric:KeyLearningPoint ;
  rdfs:label "To have healthy teeth and gums, we should brush our teeth twice a day."@en ;
  dcterms:modified "2026-06-07T15:30:29.332861Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1199-1
  a curric:KeyLearningPoint ;
  rdfs:label "Humans live on a planet called Earth."@en ;
  dcterms:modified "2026-06-07T15:30:29.332913Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1199-2
  a curric:KeyLearningPoint ;
  rdfs:label "Different materials come from different places."@en ;
  dcterms:modified "2026-06-07T15:30:29.332919Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1199-3
  a curric:KeyLearningPoint ;
  rdfs:label """Some materials may cause harm to the planet when they are made, or if they are not
  recycled."""@en ;
  dcterms:modified "2026-06-07T15:30:29.332926Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1199-4
  a curric:KeyLearningPoint ;
  rdfs:label """Some materials can be found naturally or they are grown, and these can cause less
  harm to planet Earth."""@en ;
  dcterms:modified "2026-06-07T15:30:29.332930Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1199-5
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists design and invent new materials that cause little or no harm to
  Earth."""@en ;
  dcterms:modified "2026-06-07T15:30:29.332934Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1193-1
  a curric:KeyLearningPoint ;
  rdfs:label "Different types of food can help our bodies in different ways."@en ;
  dcterms:modified "2026-06-07T15:30:29.337347Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1193-2
  a curric:KeyLearningPoint ;
  rdfs:label "It is important for humans to eat the right amounts of different types of food."@en ;
  dcterms:modified "2026-06-07T15:30:29.337351Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1193-3
  a curric:KeyLearningPoint ;
  rdfs:label """Amounts of food can be planned for using a circle or triangle divided into different
  portions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.337355Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1182-1
  a curric:KeyLearningPoint ;
  rdfs:label "Animals, including humans, have babies"@en ;
  dcterms:modified "2026-06-07T15:30:29.337492Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1182-2
  a curric:KeyLearningPoint ;
  rdfs:label """Offspring is used to describe the young version of a living thing in relation to its
  parents"""@en ;
  dcterms:modified "2026-06-07T15:30:29.337496Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1182-3
  a curric:KeyLearningPoint ;
  rdfs:label """Some offspring look similar to their parents and some offspring look different to
  their parents"""@en ;
  dcterms:modified "2026-06-07T15:30:29.337500Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1182-4
  a curric:KeyLearningPoint ;
  rdfs:label "Offspring can be matched to parent animals using simple observation skills"@en ;
  dcterms:modified "2026-06-07T15:30:29.337504Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1138-1
  a curric:KeyLearningPoint ;
  rdfs:label "Different animals have different parts to their bodies."@en ;
  dcterms:modified "2026-06-07T15:30:29.338984Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1138-2
  a curric:KeyLearningPoint ;
  rdfs:label "The parts of an animal's body is called its structure."@en ;
  dcterms:modified "2026-06-07T15:30:29.338988Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1138-3
  a curric:KeyLearningPoint ;
  rdfs:label "Different body parts help animals to do different things."@en ;
  dcterms:modified "2026-06-07T15:30:29.338992Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1138-4
  a curric:KeyLearningPoint ;
  rdfs:label "An animal can be described based on its structure."@en ;
  dcterms:modified "2026-06-07T15:30:29.338996Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1138-5
  a curric:KeyLearningPoint ;
  rdfs:label "Animals can be compared and put into groups based on their structure."@en ;
  dcterms:modified "2026-06-07T15:30:29.339001Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1185-1
  a curric:KeyLearningPoint ;
  rdfs:label "The life cycle of an animal shows how it grows and changes from birth"@en ;
  dcterms:modified "2026-06-07T15:30:29.339053Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1185-2
  a curric:KeyLearningPoint ;
  rdfs:label """Making observations over time helps scientists to describe changes in animals during
  their life cycle"""@en ;
  dcterms:modified "2026-06-07T15:30:29.339058Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1185-3
  a curric:KeyLearningPoint ;
  rdfs:label "The life cycle of animals can be recorded in different ways"@en ;
  dcterms:modified "2026-06-07T15:30:29.339062Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1178-1
  a curric:KeyLearningPoint ;
  rdfs:label """Plants are living things, they need water to grow, stay alive and and keep
  healthy."""@en ;
  dcterms:modified "2026-06-07T15:30:29.342169Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1178-2
  a curric:KeyLearningPoint ;
  rdfs:label """Without water, a plant can dry out, drop leaves, lose its strength and begin to
  wilt."""@en ;
  dcterms:modified "2026-06-07T15:30:29.342173Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1178-3
  a curric:KeyLearningPoint ;
  rdfs:label "Changes in plant growth can be compared and described using observation skills."@en ;
  dcterms:modified "2026-06-07T15:30:29.342176Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1178-4
  a curric:KeyLearningPoint ;
  rdfs:label "Different plants can survive without water for different amounts of time."@en ;
  dcterms:modified "2026-06-07T15:30:29.342180Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1178-5
  a curric:KeyLearningPoint ;
  rdfs:label """Unhealthy plants without water can sometimes be recovered with water within a short
  period of time."""@en ;
  dcterms:modified "2026-06-07T15:30:29.342185Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1198-1
  a curric:KeyLearningPoint ;
  rdfs:label """The properties of materials make them suitable or unsuitable for particular
  uses."""@en ;
  dcterms:modified "2026-06-07T15:30:29.345729Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1198-2
  a curric:KeyLearningPoint ;
  rdfs:label "Being stretchy is one such property of some materials."@en ;
  dcterms:modified "2026-06-07T15:30:29.345735Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1198-3
  a curric:KeyLearningPoint ;
  rdfs:label "If a material is stretchy, it is able to be pulled to change its shape."@en ;
  dcterms:modified "2026-06-07T15:30:29.345739Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1198-4
  a curric:KeyLearningPoint ;
  rdfs:label "Some materials are stretchy, and this makes them suitable for certain uses."@en ;
  dcterms:modified "2026-06-07T15:30:29.345743Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1198-5
  a curric:KeyLearningPoint ;
  rdfs:label "Scientists test materials to find out which are stretchy and which are not."@en ;
  dcterms:modified "2026-06-07T15:30:29.345747Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1153-1
  a curric:KeyLearningPoint ;
  rdfs:label "There are twelve months in one year"@en ;
  dcterms:modified "2026-06-07T15:30:29.350680Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1153-2
  a curric:KeyLearningPoint ;
  rdfs:label "The four seasons are winter, spring, summer and autumn."@en ;
  dcterms:modified "2026-06-07T15:30:29.350684Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1153-3
  a curric:KeyLearningPoint ;
  rdfs:label "The season of winter occurs in December, January and February."@en ;
  dcterms:modified "2026-06-07T15:30:29.350688Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1153-4
  a curric:KeyLearningPoint ;
  rdfs:label "Deciduous trees have no leaves or very few leaves in winter."@en ;
  dcterms:modified "2026-06-07T15:30:29.350692Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1153-5
  a curric:KeyLearningPoint ;
  rdfs:label "Changes in winter can be described using observation skills."@en ;
  dcterms:modified "2026-06-07T15:30:29.350696Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1170-1
  a curric:KeyLearningPoint ;
  rdfs:label "Animals need food in order to stay alive"@en ;
  dcterms:modified "2026-06-07T15:30:29.352381Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1170-2
  a curric:KeyLearningPoint ;
  rdfs:label """Different animals eat different types of food and they get this in different
  ways."""@en ;
  dcterms:modified "2026-06-07T15:30:29.352385Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1170-3
  a curric:KeyLearningPoint ;
  rdfs:label "Animals use their senses to find food in different ways."@en ;
  dcterms:modified "2026-06-07T15:30:29.352390Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1170-4
  a curric:KeyLearningPoint ;
  rdfs:label "Some animals hunt or find food around them, some animals are fed by humans."@en ;
  dcterms:modified "2026-06-07T15:30:29.352394Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1170-5
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists search for answers by looking for information in places like books or the
  internet. This is called research."""@en ;
  dcterms:modified "2026-06-07T15:30:29.352397Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1160-1
  a curric:KeyLearningPoint ;
  rdfs:label "The amount of light we see during the day changes throughout the year."@en ;
  dcterms:modified "2026-06-07T15:30:29.352444Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1160-2
  a curric:KeyLearningPoint ;
  rdfs:label """Day length is longer in the season of summer and this means that it is
  darker later."""@en ;
  dcterms:modified "2026-06-07T15:30:29.352448Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1160-3
  a curric:KeyLearningPoint ;
  rdfs:label "Day length can be investigated using observation skills."@en ;
  dcterms:modified "2026-06-07T15:30:29.352453Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1160-4
  a curric:KeyLearningPoint ;
  rdfs:label "A clock can be used to help record what time it becomes dark each evening."@en ;
  dcterms:modified "2026-06-07T15:30:29.352459Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1160-5
  a curric:KeyLearningPoint ;
  rdfs:label """The longest day, when we have the most amount of daylight, in the UK is June
  21st."""@en ;
  dcterms:modified "2026-06-07T15:30:29.352463Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1168-1
  a curric:KeyLearningPoint ;
  rdfs:label "A habitat is where a group of plants and animals live."@en ;
  dcterms:modified "2026-06-07T15:30:29.354795Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1168-2
  a curric:KeyLearningPoint ;
  rdfs:label "A habitat provides the things that an animal or plant needs to survive."@en ;
  dcterms:modified "2026-06-07T15:30:29.354799Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1168-3
  a curric:KeyLearningPoint ;
  rdfs:label "A microhabitat is a smaller area where a plant or animal lives."@en ;
  dcterms:modified "2026-06-07T15:30:29.354803Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1168-4
  a curric:KeyLearningPoint ;
  rdfs:label "Examples of microhabitats can be rock pools or a log."@en ;
  dcterms:modified "2026-06-07T15:30:29.354807Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1168-5
  a curric:KeyLearningPoint ;
  rdfs:label "Smaller plants and animals can be found living in microhabitats."@en ;
  dcterms:modified "2026-06-07T15:30:29.354811Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1165-1
  a curric:KeyLearningPoint ;
  rdfs:label """A living thing is something that is currently alive and needs food, air and water to
  stay alive."""@en ;
  dcterms:modified "2026-06-07T15:30:29.360347Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1165-2
  a curric:KeyLearningPoint ;
  rdfs:label "Something that is dead was once living but is no longer alive."@en ;
  dcterms:modified "2026-06-07T15:30:29.360351Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1165-3
  a curric:KeyLearningPoint ;
  rdfs:label "A non-living thing is something that has never been alive."@en ;
  dcterms:modified "2026-06-07T15:30:29.360354Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1165-4
  a curric:KeyLearningPoint ;
  rdfs:label "Things can be compared and grouped into alive, dead and never alive."@en ;
  dcterms:modified "2026-06-07T15:30:29.360360Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1022-1
  a curric:KeyLearningPoint ;
  rdfs:label "Trees are plants"@en ;
  dcterms:modified "2026-06-07T15:30:29.360373Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1022-2
  a curric:KeyLearningPoint ;
  rdfs:label "Different types of trees have different shaped and sized leaves"@en ;
  dcterms:modified "2026-06-07T15:30:29.360377Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1022-3
  a curric:KeyLearningPoint ;
  rdfs:label "Leaves can be looked at closely and compared using observation skills"@en ;
  dcterms:modified "2026-06-07T15:30:29.360380Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1022-4
  a curric:KeyLearningPoint ;
  rdfs:label "Trees can be identified using simple secondary sources of information"@en ;
  dcterms:modified "2026-06-07T15:30:29.360384Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1166-1
  a curric:KeyLearningPoint ;
  rdfs:label "A habitat is where a group of plants and animals live."@en ;
  dcterms:modified "2026-06-07T15:30:29.362383Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1166-2
  a curric:KeyLearningPoint ;
  rdfs:label "A habitat provides the things an animal or plant needs to survive."@en ;
  dcterms:modified "2026-06-07T15:30:29.362387Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1166-3
  a curric:KeyLearningPoint ;
  rdfs:label "Most living things live in habitats to which they are suited."@en ;
  dcterms:modified "2026-06-07T15:30:29.362391Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1166-4
  a curric:KeyLearningPoint ;
  rdfs:label "Different animals live in different habitats, depending on their basic needs."@en ;
  dcterms:modified "2026-06-07T15:30:29.362395Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9172-1
  a curric:KeyLearningPoint ;
  rdfs:label "Working in science is a job for everybody."@en ;
  dcterms:modified "2026-06-07T15:30:29.364567Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9172-2
  a curric:KeyLearningPoint ;
  rdfs:label """Some scientists investigate the properties of materials worn by people doing
  different jobs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.364571Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9172-3
  a curric:KeyLearningPoint ;
  rdfs:label """Materials can have properties including being waterproof and providing
  protection."""@en ;
  dcterms:modified "2026-06-07T15:30:29.364577Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9172-4
  a curric:KeyLearningPoint ;
  rdfs:label "Some jobs need special clothes, including firefighters and surgeons."@en ;
  dcterms:modified "2026-06-07T15:30:29.364581Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1177-1
  a curric:KeyLearningPoint ;
  rdfs:label """Plants need water, light and a suitable temperature (warmth) in order to grow and
  stay healthy."""@en ;
  dcterms:modified "2026-06-07T15:30:29.364605Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1177-2
  a curric:KeyLearningPoint ;
  rdfs:label """Healthy plants grow strong and upright. The leaves are firm and flowers fruit and
  root systems are well formed."""@en ;
  dcterms:modified "2026-06-07T15:30:29.364609Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1177-3
  a curric:KeyLearningPoint ;
  rdfs:label """An unhealthy plant can be dry, dull, brown or yellow in colour and unable to stand
  upright."""@en ;
  dcterms:modified "2026-06-07T15:30:29.364613Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1177-4
  a curric:KeyLearningPoint ;
  rdfs:label "The growth of plants over time can be observed and recorded in different ways."@en ;
  dcterms:modified "2026-06-07T15:30:29.364619Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1192-1
  a curric:KeyLearningPoint ;
  rdfs:label "Different types of food can help our bodies in different ways."@en ;
  dcterms:modified "2026-06-07T15:30:29.364623Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1192-2
  a curric:KeyLearningPoint ;
  rdfs:label "Food containing lots of fats and/or sugar can be unhealthy for humans."@en ;
  dcterms:modified "2026-06-07T15:30:29.364627Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1192-3
  a curric:KeyLearningPoint ;
