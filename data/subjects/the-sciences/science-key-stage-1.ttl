oakcurric:keylearningpoint-lesson-1136-1
  a curric:KeyLearningPoint ;
  rdfs:label "Birds are animals that have a backbone, wings and feathers, and lay eggs."@en ;
  dcterms:modified "2026-06-07T15:30:29.386403Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1136-2
  a curric:KeyLearningPoint ;
  rdfs:label """Reptiles are animals that have a backbone, a body covered with scales or hard parts,
  and are cold blooded."""@en ;
  dcterms:modified "2026-06-07T15:30:29.386407Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1136-3
  a curric:KeyLearningPoint ;
  rdfs:label "Different birds and reptiles have different names."@en ;
  dcterms:modified "2026-06-07T15:30:29.386410Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1136-4
  a curric:KeyLearningPoint ;
  rdfs:label """Animals can be sorted into birds and reptiles using simple classification
  skills."""@en ;
  dcterms:modified "2026-06-07T15:30:29.386414Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1156-1
  a curric:KeyLearningPoint ;
  rdfs:label """The year can be divided into four seasons, each lasting approximately three
  months."""@en ;
  dcterms:modified "2026-06-07T15:30:29.386418Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1156-2
  a curric:KeyLearningPoint ;
  rdfs:label "The four seasons are winter, spring, summer and autumn."@en ;
  dcterms:modified "2026-06-07T15:30:29.386424Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1156-3
  a curric:KeyLearningPoint ;
  rdfs:label "The season of spring occurs in March, April and May."@en ;
  dcterms:modified "2026-06-07T15:30:29.386428Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1156-4
  a curric:KeyLearningPoint ;
  rdfs:label """The first signs of spring are more birdsong, buds on trees, and early flowers such
  as tulips and daffodils."""@en ;
  dcterms:modified "2026-06-07T15:30:29.386432Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1156-5
  a curric:KeyLearningPoint ;
  rdfs:label "Changes in spring can be described using observation skills."@en ;
  dcterms:modified "2026-06-07T15:30:29.386436Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1173-1
  a curric:KeyLearningPoint ;
  rdfs:label """A food chain is used to show the order in which living things depend on each
  other"""@en ;
  dcterms:modified "2026-06-07T15:30:29.388310Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1173-2
  a curric:KeyLearningPoint ;
  rdfs:label "A plant or animal can be part of many different food chains"@en ;
  dcterms:modified "2026-06-07T15:30:29.388314Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1173-3
  a curric:KeyLearningPoint ;
  rdfs:label "Different food chains can be compared to look for what is the same and different"@en ;
  dcterms:modified "2026-06-07T15:30:29.388318Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1174-1
  a curric:KeyLearningPoint ;
  rdfs:label "Most plants produce seeds which grow into new plants."@en ;
  dcterms:modified "2026-06-07T15:30:29.388356Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1174-2
  a curric:KeyLearningPoint ;
  rdfs:label """Different types of plants can grow from different types of seeds, including trees,
  fruit and vegetables."""@en ;
  dcterms:modified "2026-06-07T15:30:29.388360Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1174-3
  a curric:KeyLearningPoint ;
  rdfs:label "Different types of seeds can be compared and grouped using observation skills."@en ;
  dcterms:modified "2026-06-07T15:30:29.388364Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1174-4
  a curric:KeyLearningPoint ;
  rdfs:label """The first stage of growth from a seed is when a root grows downwards and a shoot
  grows upwards."""@en ;
  dcterms:modified "2026-06-07T15:30:29.388368Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1174-5
  a curric:KeyLearningPoint ;
  rdfs:label "Seeds can be observed growing into mature plants."@en ;
  dcterms:modified "2026-06-07T15:30:29.388372Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1143-1
  a curric:KeyLearningPoint ;
  rdfs:label "There are five basic senses in humans: sight, hearing, touch, smell and taste."@en ;
  dcterms:modified "2026-06-07T15:30:29.389639Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1143-2
  a curric:KeyLearningPoint ;
  rdfs:label "Our eyes, nose and ears are used to identify sights, smells and sounds."@en ;
  dcterms:modified "2026-06-07T15:30:29.389642Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1143-3
  a curric:KeyLearningPoint ;
  rdfs:label """Our sense of sight, smell and sound can help us to react to things and warn us of
  dangers."""@en ;
  dcterms:modified "2026-06-07T15:30:29.389646Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1143-4
  a curric:KeyLearningPoint ;
  rdfs:label """To help us to identify sights, smells and sounds, we can compare our ideas with
  other people."""@en ;
  dcterms:modified "2026-06-07T15:30:29.389650Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1158-1
  a curric:KeyLearningPoint ;
  rdfs:label "There are twelve months in one year."@en ;
  dcterms:modified "2026-06-07T15:30:29.392542Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1158-2
  a curric:KeyLearningPoint ;
  rdfs:label "The four seasons are winter, spring, summer and autumn."@en ;
  dcterms:modified "2026-06-07T15:30:29.392546Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1158-3
  a curric:KeyLearningPoint ;
  rdfs:label "The season of summer occurs in June, July and August."@en ;
  dcterms:modified "2026-06-07T15:30:29.392550Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1158-4
  a curric:KeyLearningPoint ;
  rdfs:label """The summer is often full of bright colours, plants and trees are giving fruits, and
  flowers are blooming."""@en ;
  dcterms:modified "2026-06-07T15:30:29.392554Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1158-5
  a curric:KeyLearningPoint ;
  rdfs:label "Changes in summer can be described using observational skills."@en ;
  dcterms:modified "2026-06-07T15:30:29.392558Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1179-1
  a curric:KeyLearningPoint ;
  rdfs:label "Plants are living things, they need warmth to grow, stay alive and keep healthy."@en ;
  dcterms:modified "2026-06-07T15:30:29.395500Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1179-2
  a curric:KeyLearningPoint ;
  rdfs:label "A plant without warmth may not grow fully and could eventually die."@en ;
  dcterms:modified "2026-06-07T15:30:29.395504Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1179-3
  a curric:KeyLearningPoint ;
  rdfs:label "Changes in plant growth can be compared and described using observation skills."@en ;
  dcterms:modified "2026-06-07T15:30:29.395507Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1179-4
  a curric:KeyLearningPoint ;
  rdfs:label "Different plants grow in different temperatures around the world."@en ;
  dcterms:modified "2026-06-07T15:30:29.395511Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1179-5
  a curric:KeyLearningPoint ;
  rdfs:label """Unhealthy plants without warmth can sometimes be recovered within a short period of
  time."""@en ;
  dcterms:modified "2026-06-07T15:30:29.395515Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1155-1
  a curric:KeyLearningPoint ;
  rdfs:label "The amount of light we see each day changes throughout the year."@en ;
  dcterms:modified "2026-06-07T15:30:29.398186Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1155-2
  a curric:KeyLearningPoint ;
  rdfs:label """Day length is shorter in the season of winter and this means that it is darker for
  longer."""@en ;
  dcterms:modified "2026-06-07T15:30:29.398190Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1155-3
  a curric:KeyLearningPoint ;
  rdfs:label "Day length can be investigated using observation skills."@en ;
  dcterms:modified "2026-06-07T15:30:29.398194Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1155-4
  a curric:KeyLearningPoint ;
  rdfs:label "A clock can be used to help record what time it becomes dark each evening."@en ;
  dcterms:modified "2026-06-07T15:30:29.398198Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1155-5
  a curric:KeyLearningPoint ;
  rdfs:label """The shortest day, when we have the least amount of daylight, in the UK is December
  21st."""@en ;
  dcterms:modified "2026-06-07T15:30:29.398202Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1172-1
  a curric:KeyLearningPoint ;
  rdfs:label """A food chain is used to show the order in which living things depend on each other
  for food."""@en ;
  dcterms:modified "2026-06-07T15:30:29.403495Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1172-2
  a curric:KeyLearningPoint ;
  rdfs:label "Each plant and animal has an important part, or role, to play in a food chain."@en ;
  dcterms:modified "2026-06-07T15:30:29.403499Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1172-3
  a curric:KeyLearningPoint ;
  rdfs:label """Observations, books, the internet and experts provide information about what animals
  eat."""@en ;
  dcterms:modified "2026-06-07T15:30:29.403503Z"^^xsd:dateTime .

