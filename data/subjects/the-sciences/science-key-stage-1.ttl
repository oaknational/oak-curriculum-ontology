  dcterms:modified "2026-06-07T15:30:02.349052Z"^^xsd:dateTime .

oakcurric:keyword-stem
  a curric:Keyword ;
  schema:name "stem"@en ;
  schema:description "part of the verb that appears in all forms"@en ;
  dcterms:modified "2026-06-07T15:30:02.350048Z"^^xsd:dateTime .

oakcurric:keyword-stretch
  a curric:Keyword ;
  schema:name "stretch"@en ;
  schema:description "to make longer or fuller"@en ;
  dcterms:modified "2026-06-07T15:30:02.350888Z"^^xsd:dateTime .

oakcurric:keyword-temperature
  a curric:Keyword ;
  schema:name "temperature"@en ;
  schema:description """a measure of how hot a substance is; it is related to the kinetic energy of
  the individual particles"""@en ;
  dcterms:modified "2026-06-07T15:30:02.351318Z"^^xsd:dateTime .

oakcurric:keyword-label
  a curric:Keyword ;
  schema:name "label"@en ;
  schema:description """each piece of data is annotated with one or more labels which provide
  information about that data"""@en ;
  dcterms:modified "2026-06-07T15:30:02.351564Z"^^xsd:dateTime .

oakcurric:keyword-habitat
  a curric:Keyword ;
  schema:name "habitat"@en ;
  schema:description """A habitat is the place where an organism lives. It must provide food,
  shelter and a place to reproduce."""@en ;
  dcterms:modified "2026-06-07T15:30:02.351958Z"^^xsd:dateTime .

oakcurric:keyword-sustainable
  a curric:Keyword ;
  schema:name "sustainable"@en ;
  schema:description """development that meets the needs of people today without damaging the
  environment or reducing resources for future generations"""@en ;
  dcterms:modified "2026-06-07T15:30:02.352314Z"^^xsd:dateTime .

oakcurric:keyword-animals
  a curric:Keyword ;
  schema:name "animals"@en ;
  schema:description "An animal is a living thing that moves and eats other animals or plants."@en ;
  dcterms:modified "2026-06-07T15:30:02.352700Z"^^xsd:dateTime .

oakcurric:keyword-alive
  a curric:Keyword ;
  schema:name "alive"@en ;
  schema:description """Living things are alive. They move, respire, sense, grow, reproduce, excrete
  waste material and need nutrients."""@en ;
  dcterms:modified "2026-06-07T15:30:02.352708Z"^^xsd:dateTime .

oakcurric:keyword-survive
  a curric:Keyword ;
  schema:name "survive"@en ;
  schema:description "Survive means to continue to stay alive."@en ;
  dcterms:modified "2026-06-07T15:30:02.352713Z"^^xsd:dateTime .

oakcurric:keyword-basic-needs
  a curric:Keyword ;
  schema:name "basic needs"@en ;
  schema:description """A living thing's basic needs must be met in order for them to stay
  alive."""@en ;
  dcterms:modified "2026-06-07T15:30:02.352719Z"^^xsd:dateTime .

oakcurric:keyword-choice
  a curric:Keyword ;
  schema:name "choice"@en ;
  schema:description "the act of selecting from two or more options"@en ;
  dcterms:modified "2026-06-07T15:30:02.353141Z"^^xsd:dateTime .

oakcurric:keyword-fish
  a curric:Keyword ;
  schema:name "fish"@en ;
