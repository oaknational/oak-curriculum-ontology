  breathe underwater."""@en ;
  dcterms:modified "2026-06-07T15:30:02.353337Z"^^xsd:dateTime .

oakcurric:keyword-amphibian
  a curric:Keyword ;
  schema:name "amphibian"@en ;
  schema:description """An amphibian is a cold-blooded animal that has moist skin, lays eggs and can
  live on land and in water."""@en ;
  dcterms:modified "2026-06-07T15:30:02.353342Z"^^xsd:dateTime .

oakcurric:keyword-gills
  a curric:Keyword ;
  schema:name "gills"@en ;
  schema:description "A gill is what allows animals that live in water to breathe."@en ;
  dcterms:modified "2026-06-07T15:30:02.353346Z"^^xsd:dateTime .

oakcurric:keyword-scales
  a curric:Keyword ;
  schema:name "scales"@en ;
