  dcterms:modified "2026-06-07T15:30:02.353353Z"^^xsd:dateTime .

oakcurric:keyword-research
  a curric:Keyword ;
  schema:name "research"@en ;
  schema:description "the detailed study of a subject"@en ;
  dcterms:modified "2026-06-07T15:30:02.353589Z"^^xsd:dateTime .

oakcurric:keyword-animal
  a curric:Keyword ;
  schema:name "animal"@en ;
  schema:description """An animal is a living thing which moves and eats other animals or
  plants."""@en ;
  dcterms:modified "2026-06-07T15:30:02.354546Z"^^xsd:dateTime .

oakcurric:keyword-plant
  a curric:Keyword ;
  schema:name "plant"@en ;
  schema:description "A plant is a living thing that often has roots, stem and leaves."@en ;
