oakcurric:keyword-plants
  a curric:Keyword ;
  schema:name "plants"@en ;
  schema:description "A plant is a living thing that often has roots, stem and leaves."@en ;
  dcterms:modified "2026-06-07T15:30:02.354732Z"^^xsd:dateTime .

oakcurric:keyword-wildflowers
  a curric:Keyword ;
  schema:name "wildflowers"@en ;
  schema:description """A wildflower is any type of flower that grows naturally in the wild without
