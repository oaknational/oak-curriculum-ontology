  schema:name "virtual image"@en ;
  schema:description """a representation of an object seen where light appears to be coming from,
  not where light actually comes from"""@en ;
  dcterms:modified "2026-06-09T00:46:04.292168Z"^^xsd:dateTime .

oakcurric:keyword-accelerate
  a curric:Keyword ;
  schema:name "accelerate"@en ;
  schema:description "getting faster and faster as the race begins"@en ;
  dcterms:modified "2026-06-09T00:46:04.293034Z"^^xsd:dateTime .

oakcurric:keyword-coil-of-an-electromagnet
  a curric:Keyword ;
  schema:name "coil of an electromagnet"@en ;
  schema:description "An insulated wire wound into the shape of a spring."@en ;
  dcterms:modified "2026-06-09T00:46:04.293256Z"^^xsd:dateTime .

oakcurric:keyword-turn-of-wire
  a curric:Keyword ;
  schema:name "turn of wire"@en ;
  schema:description "A single loop of wire in a coil."@en ;
  dcterms:modified "2026-06-09T00:46:04.293261Z"^^xsd:dateTime .

oakcurric:keyword-soft-iron
  a curric:Keyword ;
  schema:name "soft iron"@en ;
  schema:description "Very pure iron that cannot be made into a permanent magnet."@en ;
  dcterms:modified "2026-06-09T00:46:04.293266Z"^^xsd:dateTime .

oakcurric:keyword-directly-proportional-to
  a curric:Keyword ;
  schema:name "directly proportional to"@en ;
  schema:description """Describes the relationship between two variables, in which doubling the
  value of one variable doubles the value of the other."""@en ;
  dcterms:modified "2026-06-09T00:46:04.293270Z"^^xsd:dateTime .

oakcurric:keyword-error-bars
  a curric:Keyword ;
  schema:name "error bars"@en ;
  schema:description "These show the accuracy of each measurement on a graph."@en ;
  dcterms:modified "2026-06-09T00:46:04.293275Z"^^xsd:dateTime .

oakcurric:keyword-dissipate
  a curric:Keyword ;
  schema:name "dissipate"@en ;
  schema:description """Friction or air resistance can cause energy to dissipate into the
  surroundings as heat."""@en ;
  dcterms:modified "2026-06-09T00:46:04.293538Z"^^xsd:dateTime .

oakcurric:keyword-gravitational-potential-energy
  a curric:Keyword ;
  schema:name "gravitational potential energy"@en ;
  schema:description """The energy an object has in its gravitational store is referred to as the
  object’s gravitational potential energy."""@en ;
  dcterms:modified "2026-06-09T00:46:04.293543Z"^^xsd:dateTime .

oakcurric:keyword-moon
  a curric:Keyword ;
  schema:name "Moon"@en ;
  schema:description "Our Moon is an object that travels around planet Earth."@en ;
  dcterms:modified "2026-06-09T00:46:04.294657Z"^^xsd:dateTime .

oakcurric:keyword-metal-ion
  a curric:Keyword ;
  schema:name "metal ion"@en ;
  schema:description """A metal ion is formed when a metal atom loses one or more electrons and has
  a positive charge."""@en ;
  dcterms:modified "2026-06-09T00:46:04.295608Z"^^xsd:dateTime .

oakcurric:keyword-non-contact-force
  a curric:Keyword ;
  schema:name "non-contact force"@en ;
  schema:description """A non-contact force is a force which occurs when objects are not touching
  each other."""@en ;
  dcterms:modified "2026-06-09T00:46:04.295787Z"^^xsd:dateTime .

oakcurric:keyword-solar-system
  a curric:Keyword ;
  schema:name "solar system"@en ;
  schema:description "The solar system is the name for our Sun and the planets that orbit it."@en ;
  dcterms:modified "2026-06-09T00:46:04.296406Z"^^xsd:dateTime .

oakcurric:keyword-period
  a curric:Keyword ;
  schema:name "period"@en ;
  schema:description """A period is a row on the periodic table that corresponds to the number of
  electron shells in an atom."""@en ;
  dcterms:modified "2026-06-09T00:46:04.296456Z"^^xsd:dateTime .

oakcurric:keyword-inverse
  a curric:Keyword ;
  schema:name "Inverse"@en ;
  schema:description "Inverse means the opposite in effect. The reverse of."@en ;
  dcterms:modified "2026-06-09T00:46:04.296813Z"^^xsd:dateTime .

oakcurric:keyword-thinking-distance
  a curric:Keyword ;
  schema:name "thinking distance"@en ;
  schema:description """is the distance a vehicle travels while a driver reacts; the vehicle does
  not slow during this time"""@en ;
  dcterms:modified "2026-06-09T00:46:04.296900Z"^^xsd:dateTime .

oakcurric:keyword-braking-distance
  a curric:Keyword ;
  schema:name "braking distance"@en ;
  schema:description """is the distance a vehicle travels between the brakes being applied and the
  vehicle coming to a stop"""@en ;
  dcterms:modified "2026-06-09T00:46:04.296905Z"^^xsd:dateTime .

oakcurric:keyword-stopping-distance
  a curric:Keyword ;
  schema:name "stopping distance"@en ;
  schema:description "is the sum of the thinking and braking distances"@en ;
  dcterms:modified "2026-06-09T00:46:04.296909Z"^^xsd:dateTime .

oakcurric:keyword-amplitude
  a curric:Keyword ;
  schema:name "amplitude"@en ;
  schema:description "a measure of how far particles vibrate in a sound wave"@en ;
  dcterms:modified "2026-06-09T00:46:04.297101Z"^^xsd:dateTime .

oakcurric:keyword-equilibrium
  a curric:Keyword ;
  schema:name "equilibrium"@en ;
  schema:description """The state of an object when there is no resultant force or moment acting on
  it."""@en ;
  dcterms:modified "2026-06-09T00:46:04.297106Z"^^xsd:dateTime .

oakcurric:keyword-moment
  a curric:Keyword ;
  schema:name "moment"@en ;
  schema:description "The turning effect of a force, measured in newton metres (Nm)."@en ;
  dcterms:modified "2026-06-09T00:46:04.297111Z"^^xsd:dateTime .

oakcurric:keyword-principle-of-moments
  a curric:Keyword ;
  schema:name "principle of moments"@en ;
  schema:description """An object will balance when the clockwise moments are equal to the
  anticlockwise moments."""@en ;
  dcterms:modified "2026-06-09T00:46:04.297116Z"^^xsd:dateTime .

oakcurric:keyword-elastic-deformation
  a curric:Keyword ;
  schema:name "elastic deformation"@en ;
  schema:description """The stretch of a spring that returns to its original shape when the
  stretching force is removed."""@en ;
  dcterms:modified "2026-06-09T00:46:04.297210Z"^^xsd:dateTime .

oakcurric:keyword-inelastic-deformation
  a curric:Keyword ;
  schema:name "inelastic deformation"@en ;
  schema:description "The stretch of a spring as it is permanently stretched out of shape."@en ;
  dcterms:modified "2026-06-09T00:46:04.297217Z"^^xsd:dateTime .

oakcurric:keyword-limit-of-proportionality
  a curric:Keyword ;
  schema:name "limit of proportionality"@en ;
  schema:description "The largest extension of a spring before it is stretched out of shape."@en ;
  dcterms:modified "2026-06-09T00:46:04.297224Z"^^xsd:dateTime .

oakcurric:keyword-axle
  a curric:Keyword ;
  schema:name "axle"@en ;
  schema:description """An axle is a rod that goes through the centre of the wheel to help it move
  and stay in place."""@en ;
  dcterms:modified "2026-06-09T00:46:04.298216Z"^^xsd:dateTime .

oakcurric:keyword-anomalous-result
  a curric:Keyword ;
  schema:name "anomalous result"@en ;
  schema:description """An anomalous result is a measurement that is significantly different from
  the others. It should be crossed out and not used in calculating the mean."""@en ;
  dcterms:modified "2026-06-09T00:46:04.299127Z"^^xsd:dateTime .

oakcurric:keyword-particles
  a curric:Keyword ;
  schema:name "particles"@en ;
  schema:description "atoms or molecules that make up matter"@en ;
  dcterms:modified "2026-06-09T00:46:04.300151Z"^^xsd:dateTime .

oakcurric:keyword-upthrust
  a curric:Keyword ;
  schema:name "upthrust"@en ;
  schema:description """a force acting upwards on an object in a liquid due to pressure differences
  between the top and bottom surface"""@en ;
  dcterms:modified "2026-06-09T00:46:04.300156Z"^^xsd:dateTime .

oakcurric:keyword-centripetal-force
  a curric:Keyword ;
  schema:name "centripetal force"@en ;
  schema:description """A centripetal force acts towards the centre of a circle and causes object to
  travel in circular paths."""@en ;
  dcterms:modified "2026-06-09T00:46:04.301279Z"^^xsd:dateTime .

oakcurric:keyword-parallel
  a curric:Keyword ;
  schema:name "parallel"@en ;
  schema:description "side by side alignment of the feet on landing"@en ;
  dcterms:modified "2026-06-09T00:46:04.301560Z"^^xsd:dateTime .

oakcurric:keyword-earthquake
  a curric:Keyword ;
  schema:name "earthquake"@en ;
  schema:description """An earthquake is caused by the sudden sliding movement of tectonic plates
  against each other."""@en ;
  dcterms:modified "2026-06-09T00:46:04.304145Z"^^xsd:dateTime .

oakcurric:keyword-s-wave
  a curric:Keyword ;
  schema:name "S wave"@en ;
  schema:description """S waves are transverse seismic waves that travel through solids but not
  liquids."""@en ;
  dcterms:modified "2026-06-09T00:46:04.304153Z"^^xsd:dateTime .

oakcurric:keyword-p-wave
  a curric:Keyword ;
  schema:name "P wave"@en ;
  schema:description """P waves are longitudinal seismic waves that travel at different speeds
  through solids and liquids."""@en ;
  dcterms:modified "2026-06-09T00:46:04.304160Z"^^xsd:dateTime .

oakcurric:keyword-transverse
  a curric:Keyword ;
  schema:name "transverse"@en ;
  schema:description """A transverse wave is where the wave oscillates perpendicular to the
  direction of travel."""@en ;
  dcterms:modified "2026-06-09T00:46:04.304165Z"^^xsd:dateTime .

oakcurric:keyword-longitudinal
  a curric:Keyword ;
  schema:name "longitudinal"@en ;
  schema:description """A longitudinal wave is where the wave oscillates along the direction of
  travel with areas of compression and rarefaction."""@en ;
  dcterms:modified "2026-06-09T00:46:04.304170Z"^^xsd:dateTime .

oakcurric:keyword-work
  a curric:Keyword ;
  schema:name "work"@en ;
  schema:description """Work is done whenever a force makes an object move. The amount of work is
  force multiplied by distance moved in the direction of the force."""@en ;
  dcterms:modified "2026-06-09T00:46:04.304831Z"^^xsd:dateTime .

oakcurric:keyword-joule-j
  a curric:Keyword ;
  schema:name "joule (J)"@en ;
  schema:description """The unit for measuring energy is the joule (J) which is the same as the unit
  for measuring energy."""@en ;
  dcterms:modified "2026-06-09T00:46:04.304836Z"^^xsd:dateTime .

oakcurric:keyword-kilojoule-kj
  a curric:Keyword ;
  schema:name "kilojoule (kJ)"@en ;
  schema:description "A thousand joules is called a kilojoule (kJ)."@en ;
  dcterms:modified "2026-06-09T00:46:04.304841Z"^^xsd:dateTime .

oakcurric:keyword-watts-w
  a curric:Keyword ;
  schema:name "watts (W)"@en ;
  schema:description "the unit of power"@en ;
  dcterms:modified "2026-06-09T00:46:04.307357Z"^^xsd:dateTime .

oakcurric:keyword-kilowatts-kw
  a curric:Keyword ;
  schema:name "kilowatts (kW)"@en ;
  schema:description "a larger unit of power; 1 kW = 1000 W"@en ;
  dcterms:modified "2026-06-09T00:46:04.307362Z"^^xsd:dateTime .

oakcurric:keyword-satellite
  a curric:Keyword ;
  schema:name "satellite"@en ;
  schema:description "The Moon is a satellite because it moves around the Earth."@en ;
  dcterms:modified "2026-06-09T00:46:04.313053Z"^^xsd:dateTime .

oakcurric:keyword-compress
  a curric:Keyword ;
  schema:name "compress"@en ;
  schema:description """To make something smaller using forces, e.g. a spring gets shorter when it
  is compressed."""@en ;
  dcterms:modified "2026-06-09T00:46:04.313227Z"^^xsd:dateTime .

oakcurric:keyword-spring-constant
  a curric:Keyword ;
  schema:name "spring constant"@en ;
  schema:description """A measure of how stiff a spring is and how hard it is to stretch or
  compress."""@en ;
  dcterms:modified "2026-06-09T00:46:04.313232Z"^^xsd:dateTime .

oakcurric:keyword-useful-output-energy-transfer
  a curric:Keyword ;
  schema:name "useful output energy transfer"@en ;
  schema:description """The amount of energy usefully transferred by an object or system is the
  useful output energy transfer."""@en ;
  dcterms:modified "2026-06-09T00:46:04.313512Z"^^xsd:dateTime .

oakcurric:keyword-total-input-energy-transfer
  a curric:Keyword ;
  schema:name "total input energy transfer"@en ;
  schema:description """The total amount of energy transferred to an object or system is the total
  input energy transfer."""@en ;
  dcterms:modified "2026-06-09T00:46:04.313520Z"^^xsd:dateTime .

oakcurric:keyword-galaxy
  a curric:Keyword ;
  schema:name "galaxy"@en ;
  schema:description "A galaxy is a group of billions of stars."@en ;
  dcterms:modified "2026-06-09T00:46:04.313574Z"^^xsd:dateTime .

oakcurric:keyword-contact-force
  a curric:Keyword ;
  schema:name "contact force"@en ;
  schema:description "Contact forces only act when objects are touching."@en ;
  dcterms:modified "2026-06-09T00:46:04.314509Z"^^xsd:dateTime .

oakcurric:keyword-specific-latent-heat
  a curric:Keyword ;
  schema:name "specific latent heat"@en ;
  schema:description "the change in energy when 1 kg of a substance changes state"@en ;
  dcterms:modified "2026-06-09T00:46:04.314558Z"^^xsd:dateTime .

oakcurric:keyword-crest
  a curric:Keyword ;
  schema:name "crest"@en ;
  schema:description "a symbol or design that represents a family, group, or community"@en ;
  dcterms:modified "2026-06-09T00:46:04.315165Z"^^xsd:dateTime .

oakcurric:keyword-longitudinal-wave
  a curric:Keyword ;
  schema:name "longitudinal wave"@en ;
  schema:description """a wave, such as a sound wave, where the vibrations are parallel to the
  direction of energy transfer"""@en ;
  dcterms:modified "2026-06-09T00:46:04.315515Z"^^xsd:dateTime .

oakcurric:keyword-ultrasound
  a curric:Keyword ;
  schema:name "ultrasound"@en ;
  schema:description """sound waves with a frequency above 20 000 Hz, that cannot be detected by
  human ears"""@en ;
  dcterms:modified "2026-06-09T00:46:04.316423Z"^^xsd:dateTime .

oakcurric:keyword-planet
  a curric:Keyword ;
  schema:name "planet"@en ;
  schema:description "A planet is a very large sphere of rock or gas that orbits a star."@en ;
  dcterms:modified "2026-06-09T00:46:04.317538Z"^^xsd:dateTime .

oakcurric:keyword-dwarf-planet
  a curric:Keyword ;
  schema:name "dwarf planet"@en ;
  schema:description """A dwarf planet is a large, round object that orbits a star but is not big
  enough to clear its orbital path of other debris."""@en ;
  dcterms:modified "2026-06-09T00:46:04.317544Z"^^xsd:dateTime .

oakcurric:keyword-ray
  a curric:Keyword ;
  schema:name "ray"@en ;
  schema:description """A ray is a straight line drawn to represent the direction that a light wave
  travels."""@en ;
  dcterms:modified "2026-06-09T00:46:04.318130Z"^^xsd:dateTime .

oakcurric:keyword-ohmic-conductor
  a curric:Keyword ;
  schema:name "ohmic conductor"@en ;
  schema:description "a conductor for which the current is directly proportional to the p.d."@en ;
  dcterms:modified "2026-06-09T00:46:04.318135Z"^^xsd:dateTime .

oakcurric:keyword-free-electron
  a curric:Keyword ;
  schema:name "free electron"@en ;
  schema:description """an electron from the outer shell of an atom that is free to move from ion to
  ion through a metal"""@en ;
  dcterms:modified "2026-06-09T00:46:04.318143Z"^^xsd:dateTime .

oakcurric:keyword-nucleon
  a curric:Keyword ;
  schema:name "nucleon"@en ;
  schema:description "the term for particles in a nucleus (protons and neutrons)"@en ;
  dcterms:modified "2026-06-09T00:46:04.318148Z"^^xsd:dateTime .

oakcurric:keyword-atomic-proton-number
  a curric:Keyword ;
  schema:name "atomic (proton) number"@en ;
  schema:description "the number of protons within a particular nucleus"@en ;
  dcterms:modified "2026-06-09T00:46:04.318153Z"^^xsd:dateTime .

oakcurric:keyword-mass-nucleon-number
  a curric:Keyword ;
  schema:name "mass (nucleon) number"@en ;
  schema:description """the total number of nucleons within a particular nucleus (protons +
  neutrons)"""@en ;
  dcterms:modified "2026-06-09T00:46:04.318158Z"^^xsd:dateTime .

oakcurric:keyword-isotopes
  a curric:Keyword ;
  schema:name "isotopes"@en ;
  schema:description "atoms of the same element with differing numbers of neutrons"@en ;
  dcterms:modified "2026-06-09T00:46:04.318163Z"^^xsd:dateTime .

oakcurric:keyword-reversebias
  a curric:Keyword ;
  schema:name "reverse–bias"@en ;
  schema:description "When a diode is reverse–biased, it prevents current from flowing."@en ;
  dcterms:modified "2026-06-09T00:46:04.318207Z"^^xsd:dateTime .

oakcurric:keyword-forwardbias
  a curric:Keyword ;
  schema:name "forward–bias"@en ;
  schema:description "When a diode is forward–biased, it allows current to flow."@en ;
  dcterms:modified "2026-06-09T00:46:04.318216Z"^^xsd:dateTime .

oakcurric:keyword-fuse
  a curric:Keyword ;
  schema:name "fuse"@en ;
  schema:description """A fuse is a component that has a wire that melts if the current is
  too high."""@en ;
  dcterms:modified "2026-06-09T00:46:04.318221Z"^^xsd:dateTime .

oakcurric:keyword-ion-lattice
  a curric:Keyword ;
  schema:name "ion lattice"@en ;
  schema:description """In a solid metal, the regular and repeating pattern that metal ions are
  arranged in is known as an ion lattice."""@en ;
  dcterms:modified "2026-06-09T00:46:04.318226Z"^^xsd:dateTime .

oakcurric:keyword-motor-coil
  a curric:Keyword ;
  schema:name "motor coil"@en ;
  schema:description """a coil of insulated wire that spins inside an electric motor when a current
  flows through it"""@en ;
  dcterms:modified "2026-06-09T00:46:04.318286Z"^^xsd:dateTime .

oakcurric:keyword-yoke
  a curric:Keyword ;
  schema:name "yoke"@en ;
  schema:description """in a motor kit, a U–shaped piece of iron that holds two magnets in place to
  create a uniform magnetic field"""@en ;
  dcterms:modified "2026-06-09T00:46:04.318293Z"^^xsd:dateTime .

oakcurric:keyword-scalar-quantity
  a curric:Keyword ;
  schema:name "scalar quantity"@en ;
  schema:description """Some quantities only have magnitude (size), and not direction. This includes
  distance and speed."""@en ;
  dcterms:modified "2026-06-09T00:46:04.318517Z"^^xsd:dateTime .

oakcurric:keyword-relative-speed
  a curric:Keyword ;
  schema:name "relative speed"@en ;
  schema:description """The relative speed of objects is the difference in their speeds taking into
  account direction of movement."""@en ;
  dcterms:modified "2026-06-09T00:46:04.318522Z"^^xsd:dateTime .

oakcurric:keyword-deceleration
  a curric:Keyword ;
  schema:name "deceleration"@en ;
  schema:description """Deceleration is used to describe a change in velocity where the object slows
  down."""@en ;
  dcterms:modified "2026-06-09T00:46:04.318709Z"^^xsd:dateTime .

oakcurric:keyword-trough
  a curric:Keyword ;
  schema:name "trough"@en ;
  schema:description "the trough of a wave is the lowest point of the wave."@en ;
  dcterms:modified "2026-06-09T00:46:04.318937Z"^^xsd:dateTime .

oakcurric:keyword-wavelength
  a curric:Keyword ;
  schema:name "wavelength"@en ;
  schema:description """wavelength of a transverse wave is the distance between one wave crest (or
  trough) and the next."""@en ;
  dcterms:modified "2026-06-09T00:46:04.318942Z"^^xsd:dateTime .

oakcurric:keyword-kilograms-per-cubic-metre
  a curric:Keyword ;
  schema:name "kilograms per cubic metre"@en ;
  schema:description """the unit for density when mass is measured in kilograms (kg) and volume in
  cubic metres (m³), written as kg/m³"""@en ;
  dcterms:modified "2026-06-09T00:46:04.318947Z"^^xsd:dateTime .

oakcurric:keyword-grams-per-cubic-centimetre
  a curric:Keyword ;
  schema:name "grams per cubic centimetre"@en ;
  schema:description """the unit for density when mass is measured in grams (g) and volume in cubic
  centimetres (cm³), written as g/cm³"""@en ;
  dcterms:modified "2026-06-09T00:46:04.318952Z"^^xsd:dateTime .

oakcurric:keyword-uniform-magnetic-field
  a curric:Keyword ;
  schema:name "uniform magnetic field"@en ;
  schema:description """has evenly spaced field lines and the strength of the magnetic field is the
  same everywhere"""@en ;
  dcterms:modified "2026-06-09T00:46:04.318960Z"^^xsd:dateTime .

oakcurric:keyword-flemings-left-hand-rule
  a curric:Keyword ;
  schema:name "Fleming’s left-hand rule"@en ;
  schema:description """indicates the direction a conducting wire is forced to move in a uniform
  magnetic field"""@en ;
  dcterms:modified "2026-06-09T00:46:04.318965Z"^^xsd:dateTime .

oakcurric:keyword-magnetic-flux-density-b
  a curric:Keyword ;
  schema:name "magnetic flux density, B"@en ;
  schema:description "is a measure of the strength of a magnetic field"@en ;
  dcterms:modified "2026-06-09T00:46:04.318971Z"^^xsd:dateTime .

oakcurric:keyword-tesla-t
  a curric:Keyword ;
  schema:name "tesla (T)"@en ;
  schema:description "is the unit that magnetic flux density is measured in"@en ;
  dcterms:modified "2026-06-09T00:46:04.318976Z"^^xsd:dateTime .

oakcurric:keyword-loudness
  a curric:Keyword ;
  schema:name "loudness"@en ;
  schema:description "the loudness of a sound wave is a measure of how loud it is."@en ;
  dcterms:modified "2026-06-09T00:46:04.319147Z"^^xsd:dateTime .

oakcurric:keyword-compensated-ramp
  a curric:Keyword ;
  schema:name "compensated ramp"@en ;
  schema:description "A ramp with a slope to counteract the effect of friction."@en ;
  dcterms:modified "2026-06-09T00:46:04.319262Z"^^xsd:dateTime .

oakcurric:keyword-final-velocity
  a curric:Keyword ;
  schema:name "final velocity"@en ;
  schema:description """The final velocity of an object is the velocity it finishes with after a
  phase of motion."""@en ;
  dcterms:modified "2026-06-09T00:46:04.319267Z"^^xsd:dateTime .

oakcurric:keyword-light-gate
  a curric:Keyword ;
  schema:name "light gate"@en ;
  schema:description """A light gate can be used to measure velocity. It uses an infrared beam to
  turn a timer on and off as an object passes through."""@en ;
  dcterms:modified "2026-06-09T00:46:04.319275Z"^^xsd:dateTime .

oakcurric:keyword-uniform-acceleration
  a curric:Keyword ;
  schema:name "uniform acceleration"@en ;
  schema:description """When the acceleration is constant, it is described as uniform
  acceleration."""@en ;
  dcterms:modified "2026-06-09T00:46:04.319280Z"^^xsd:dateTime .

oakcurric:keyword-coulombs-c
  a curric:Keyword ;
  schema:name "coulombs (C)"@en ;
  schema:description "the unit of electric charge"@en ;
  dcterms:modified "2026-06-09T00:46:04.319324Z"^^xsd:dateTime .

oakcurric:keyword-current
  a curric:Keyword ;
  schema:name "current"@en ;
  schema:description "the rate of flow of charge in a circuit"@en ;
  dcterms:modified "2026-06-09T00:46:04.319329Z"^^xsd:dateTime .

oakcurric:keyword-wave-speed
  a curric:Keyword ;
  schema:name "wave speed"@en ;
  schema:description """The speed of a wave through a medium. Given by the wave equation: wave speed
  = frequency × wavelength (v = f × λ)"""@en ;
  dcterms:modified "2026-06-09T00:46:04.319582Z"^^xsd:dateTime .

oakcurric:keyword-rarefaction
  a curric:Keyword ;
  schema:name "rarefaction"@en ;
  schema:description """part of a longitudinal wave in which parts of the wave are spaced further
  apart is called a rarefaction."""@en ;
  dcterms:modified "2026-06-09T00:46:04.319826Z"^^xsd:dateTime .

oakcurric:keyword-electromagnetic-wave
  a curric:Keyword ;
  schema:name "electromagnetic wave"@en ;
  schema:description """Electromagnetic waves are ripples/oscillations in the invisible electric and
  magnetic fields that are all around us."""@en ;
  dcterms:modified "2026-06-09T00:46:04.319979Z"^^xsd:dateTime .

oakcurric:keyword-refract
  a curric:Keyword ;
  schema:name "refract"@en ;
  schema:description """Waves are said to refract when they change direction upon entering a new
  medium."""@en ;
  dcterms:modified "2026-06-09T00:46:04.319987Z"^^xsd:dateTime .

oakcurric:keyword-gravitational-field-strength
  a curric:Keyword ;
  schema:name "gravitational field strength"@en ;
  schema:description "The force per kilogram caused by a gravitational field."@en ;
  dcterms:modified "2026-06-09T00:46:04.320000Z"^^xsd:dateTime .

oakcurric:keyword-real-image
  a curric:Keyword ;
  schema:name "real image"@en ;
  schema:description """When rays of light are brought to a focus a real image forms. A real image
  can be projected onto a screen."""@en ;
  dcterms:modified "2026-06-09T00:46:04.320097Z"^^xsd:dateTime .

oakcurric:keyword-virtual-ray
  a curric:Keyword ;
  schema:name "virtual ray"@en ;
  schema:description """Virtual rays are dashed lines drawn to represent where rays of light appear
  to have come from."""@en ;
  dcterms:modified "2026-06-09T00:46:04.320105Z"^^xsd:dateTime .

oakcurric:keyword-rate-of-change
  a curric:Keyword ;
  schema:name "Rate of change"@en ;
  schema:description """The rate of change is how quickly one variable changes in relation to
  another."""@en ;
  dcterms:modified "2026-06-09T00:46:04.320246Z"^^xsd:dateTime .

oakcurric:keyword-diminished
  a curric:Keyword ;
  schema:name "diminished"@en ;
  schema:description """Diminished means smaller than an object’s real size. It is the opposite of
  magnified."""@en ;
  dcterms:modified "2026-06-09T00:46:04.320279Z"^^xsd:dateTime .

oakcurric:keyword-convex
  a curric:Keyword ;
  schema:name "convex"@en ;
  schema:description "A convex shape bulges ‘out’ rather than bulging ‘in’ (concave)."@en ;
  dcterms:modified "2026-06-09T00:46:04.320284Z"^^xsd:dateTime .

oakcurric:keyword-lens-power
  a curric:Keyword ;
  schema:name "lens power"@en ;
  schema:description """The greater the power of a lens, the greater the angles through which light
  is refracted and the shorter the focal length."""@en ;
  dcterms:modified "2026-06-09T00:46:04.320290Z"^^xsd:dateTime .

oakcurric:keyword-specular-reflection
  a curric:Keyword ;
  schema:name "specular reflection"@en ;
  schema:description "Specular reflection is reflection from smooth surfaces in one direction."@en ;
  dcterms:modified "2026-06-09T00:46:04.320897Z"^^xsd:dateTime .

oakcurric:keyword-diffuse-reflection
  a curric:Keyword ;
  schema:name "diffuse reflection"@en ;
  schema:description """Diffuse reflection is reflection from rough surfaces in multiple
  directions."""@en ;
  dcterms:modified "2026-06-09T00:46:04.320902Z"^^xsd:dateTime .

oakcurric:keyword-positive-electric-charge
  a curric:Keyword ;
  schema:name "positive electric charge"@en ;
  schema:description "The type of charge produced when electrons are removed."@en ;
  dcterms:modified "2026-06-09T00:46:04.321050Z"^^xsd:dateTime .

oakcurric:keyword-negative-electric-charge
  a curric:Keyword ;
  schema:name "negative electric charge"@en ;
  schema:description "The type of charge produced when electrons are gained."@en ;
  dcterms:modified "2026-06-09T00:46:04.321058Z"^^xsd:dateTime .

oakcurric:keyword-van-de-graaff
  a curric:Keyword ;
  schema:name "Van de Graaff"@en ;
  schema:description """A device that produces electric charge and is used in electrostatic
  experiments."""@en ;
  dcterms:modified "2026-06-09T00:46:04.321063Z"^^xsd:dateTime .

oakcurric:keyword-vector-diagram
  a curric:Keyword ;
  schema:name "vector diagram"@en ;
  schema:description """is a drawing on which forces are drawn end to end and to scale, which can be
  used to find a resultant force."""@en ;
  dcterms:modified "2026-06-09T00:46:04.321086Z"^^xsd:dateTime .

oakcurric:keyword-component-of-a-force
  a curric:Keyword ;
  schema:name "component of a force"@en ;
  schema:description "is one of two perpendicular forces that add up to a single force."@en ;
  dcterms:modified "2026-06-09T00:46:04.321143Z"^^xsd:dateTime .

oakcurric:keyword-resolving-forces
  a curric:Keyword ;
  schema:name "resolving forces"@en ;
  schema:description "splits a force into two perpendicular forces that add up to that force."@en ;
  dcterms:modified "2026-06-09T00:46:04.321149Z"^^xsd:dateTime .

oakcurric:keyword-electrical-current
  a curric:Keyword ;
  schema:name "electrical current"@en ;
  schema:description "The amount of charge flowing past a given point in one second."@en ;
  dcterms:modified "2026-06-09T00:46:04.321293Z"^^xsd:dateTime .

oakcurric:keyword-ohms
  a curric:Keyword ;
  schema:name "ohms (Ω)"@en ;
  schema:description "The unit of resistance."@en ;
  dcterms:modified "2026-06-09T00:46:04.321298Z"^^xsd:dateTime .

oakcurric:keyword-hookes-law
  a curric:Keyword ;
  schema:name "Hooke’s Law"@en ;
  schema:description """For elastic deformations, extension (or compression) is directly
  proportional to the force applied."""@en ;
  dcterms:modified "2026-06-09T00:46:04.321489Z"^^xsd:dateTime .

oakcurric:keyword-particle-model
  a curric:Keyword ;
  schema:name "particle model"@en ;
  schema:description """the idea that all objects are made of tiny particles that are in constant
  motion"""@en ;
  dcterms:modified "2026-06-09T00:46:04.322797Z"^^xsd:dateTime .

oakcurric:keyword-converging
  a curric:Keyword ;
  schema:name "converging"@en ;
  schema:description """Light rays are converging if they are coming together to a point where they
  will meet."""@en ;
  dcterms:modified "2026-06-09T00:46:04.323522Z"^^xsd:dateTime .

oakcurric:keyword-induced-potential
  a curric:Keyword ;
  schema:name "induced potential"@en ;
  schema:description """The potential difference generated in a conductor moving relative to a
  magnetic field."""@en ;
  dcterms:modified "2026-06-09T00:46:04.323976Z"^^xsd:dateTime .

oakcurric:keyword-direct-current-dc
  a curric:Keyword ;
  schema:name "direct current (DC)"@en ;
  schema:description "An electric current that consistently flows in one direction."@en ;
  dcterms:modified "2026-06-09T00:46:04.323984Z"^^xsd:dateTime .

oakcurric:keyword-dynamo
  a curric:Keyword ;
  schema:name "dynamo"@en ;
  schema:description "A generator of direct current."@en ;
  dcterms:modified "2026-06-09T00:46:04.323989Z"^^xsd:dateTime .

oakcurric:keyword-alternating-current-ac
  a curric:Keyword ;
  schema:name "alternating current (AC)"@en ;
  schema:description "An electric current that repeatedly reverses direction."@en ;
  dcterms:modified "2026-06-09T00:46:04.323994Z"^^xsd:dateTime .

oakcurric:keyword-alternator
  a curric:Keyword ;
  schema:name "alternator"@en ;
  schema:description "A generator of alternating current."@en ;
  dcterms:modified "2026-06-09T00:46:04.323999Z"^^xsd:dateTime .

oakcurric:keyword-infrared-radiation
  a curric:Keyword ;
  schema:name "infrared radiation"@en ;
  schema:description """Infrared radiation means electromagnetic waves with frequencies in a range
  just lower than for red light."""@en ;
  dcterms:modified "2026-06-09T00:46:04.324694Z"^^xsd:dateTime .

oakcurric:keyword-space-telescope
  a curric:Keyword ;
  schema:name "space telescope"@en ;
  schema:description """is a telescope positioned in space to avoid atmospheric interference and
  observe parts of the spectrum which cannot reach the Earth’s surface"""@en ;
  dcterms:modified "2026-06-09T00:46:04.324810Z"^^xsd:dateTime .

oakcurric:keyword-redshift
  a curric:Keyword ;
  schema:name "redshift"@en ;
  schema:description """is the increase in the wavelength of light (and decrease in its frequency)
  cause by the movement of a star or galaxy away from us"""@en ;
  dcterms:modified "2026-06-09T00:46:04.324815Z"^^xsd:dateTime .

oakcurric:keyword-northseeking-pole
  a curric:Keyword ;
  schema:name "north–seeking pole"@en ;
  schema:description """The part of a magnet that is attracted to the south–seeking pole of another
  magnet, and to Earth's magnetic North Pole."""@en ;
  dcterms:modified "2026-06-09T00:46:04.326551Z"^^xsd:dateTime .

oakcurric:keyword-magnetic-material
  a curric:Keyword ;
  schema:name "magnetic material"@en ;
  schema:description """A material that is attracted to a magnet. The elements iron, cobalt and
  nickel, and their alloys (such as steel), are magnetic; non–metals and other metals are
  not magnetic."""@en ;
  dcterms:modified "2026-06-09T00:46:04.326557Z"^^xsd:dateTime .

oakcurric:keyword-compass-needle
  a curric:Keyword ;
  schema:name "compass needle"@en ;
