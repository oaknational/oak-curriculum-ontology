  dcterms:modified "2026-06-09T00:46:37.846622Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9135-5
  a curric:KeyLearningPoint ;
  rdfs:label "Gears can be used to transfer moments."@en ;
  dcterms:modified "2026-06-09T00:46:37.846628Z"^^xsd:dateTime .

