oakcurric:keyword-ampere
  a curric:Keyword ;
  schema:name "ampere"@en ;
  schema:description "The unit of electric current."@en ;
  dcterms:modified "2026-06-09T00:46:04.286071Z"^^xsd:dateTime .

oakcurric:keyword-pressure
  a curric:Keyword ;
