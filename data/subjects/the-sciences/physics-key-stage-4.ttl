# ----------------------------------------------------------------------
# Key Learning Points
# ----------------------------------------------------------------------

oakcurric:keylearningpoint-lesson-9908-1
  a curric:KeyLearningPoint ;
  rdfs:label "Acceleration is equal to the gradient of a velocity-time graph."@en ;
  dcterms:modified "2026-06-09T00:46:37.275024Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9908-2
  a curric:KeyLearningPoint ;
  rdfs:label """A falling line shows decreasing velocity called deceleration, which is a negative
  acceleration."""@en ;
  dcterms:modified "2026-06-09T00:46:37.275029Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9908-3
  a curric:KeyLearningPoint ;
  rdfs:label """Instantaneous speed at a point on a displacement-time graph equals the gradient of a
  tangent at that point."""@en ;
  dcterms:modified "2026-06-09T00:46:37.275033Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9908-4
  a curric:KeyLearningPoint ;
  rdfs:label "The distance travelled is equal to the area under a velocity-time graph."@en ;
  dcterms:modified "2026-06-09T00:46:37.275038Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9908-5
  a curric:KeyLearningPoint ;
  rdfs:label "Displacement is equal to the net positive area under a velocity-time graph."@en ;
  dcterms:modified "2026-06-09T00:46:37.275044Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4921-1
  a curric:KeyLearningPoint ;
  rdfs:label "Increasing a stopping force decreases the time it takes a moving object to stop."@en ;
  dcterms:modified "2026-06-09T00:46:37.275628Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4921-2
  a curric:KeyLearningPoint ;
  rdfs:label "Extending the time it takes to stop reduces the size of the stopping force."@en ;
  dcterms:modified "2026-06-09T00:46:37.275632Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4921-3
  a curric:KeyLearningPoint ;
  rdfs:label """Many safety devices crumple on impact to increase the time that forces act before
  stopping a moving object."""@en ;
  dcterms:modified "2026-06-09T00:46:37.275636Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4922-1
  a curric:KeyLearningPoint ;
  rdfs:label """The faster the particles of a substance are vibrating or moving, the higher the
  substance's temperature."""@en ;
  dcterms:modified "2026-06-09T00:46:37.276139Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4922-2
  a curric:KeyLearningPoint ;
  rdfs:label """In solids, energy is transferred by vibrating particles colliding with nearby
  particles, causing them to vibrate more."""@en ;
  dcterms:modified "2026-06-09T00:46:37.276143Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4922-3
  a curric:KeyLearningPoint ;
  rdfs:label """Metals are good conductors as their free electrons move through them more quickly
  when heated and transfer energy."""@en ;
  dcterms:modified "2026-06-09T00:46:37.276148Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4922-4
  a curric:KeyLearningPoint ;
  rdfs:label """Thermal conductors can feel cold because they transfer energy quickly away from
  their surface."""@en ;
  dcterms:modified "2026-06-09T00:46:37.276152Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4922-5
  a curric:KeyLearningPoint ;
  rdfs:label """Thermal insulators can feel warm because they do not transfer energy quickly from
  their surface."""@en ;
  dcterms:modified "2026-06-09T00:46:37.276156Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5045-1
  a curric:KeyLearningPoint ;
  rdfs:label "A displacement-time graph of a wave is a representation of a wave."@en ;
  dcterms:modified "2026-06-09T00:46:37.276282Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5045-2
  a curric:KeyLearningPoint ;
  rdfs:label """A displacement-time graph of a wave shows how the displacement at one point varies
  as the wave passes"""@en ;
  dcterms:modified "2026-06-09T00:46:37.276285Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5045-3
  a curric:KeyLearningPoint ;
  rdfs:label """The distance between two wave crests on a displacement-time graph is equal to the
  period of the wave"""@en ;
  dcterms:modified "2026-06-09T00:46:37.276289Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5045-4
  a curric:KeyLearningPoint ;
  rdfs:label "The period of a wave, T, is equal to the time of one complete oscillation"@en ;
  dcterms:modified "2026-06-09T00:46:37.276294Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5045-5
  a curric:KeyLearningPoint ;
  rdfs:label "Frequency is equal to 1 / period"@en ;
  dcterms:modified "2026-06-09T00:46:37.276298Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4923-1
  a curric:KeyLearningPoint ;
  rdfs:label """Different hot metals, of the same mass and starting temperature, heat a fixed amount
  of water by different amounts."""@en ;
  dcterms:modified "2026-06-09T00:46:37.277562Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4923-2
  a curric:KeyLearningPoint ;
  rdfs:label """The energy a material has because its particles are moving with forces between them
  can be labelled internal energy."""@en ;
  dcterms:modified "2026-06-09T00:46:37.277566Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4923-3
  a curric:KeyLearningPoint ;
  rdfs:label """The larger the specific heat capacity of a material, the more energy transferred to
  increase its temperature by 1ºC."""@en ;
  dcterms:modified "2026-06-09T00:46:37.277570Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4923-4
  a curric:KeyLearningPoint ;
  rdfs:label """The larger the specific heat capacity of a material, the more heating it does as its
  temperature falls by 1ºC."""@en ;
  dcterms:modified "2026-06-09T00:46:37.277574Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5084-1
  a curric:KeyLearningPoint ;
  rdfs:label """Refraction is when waves travel from one transparent medium to another, causing a
  change in direction."""@en ;
  dcterms:modified "2026-06-09T00:46:37.431319Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5084-2
  a curric:KeyLearningPoint ;
  rdfs:label """When waves slow down, they turn towards the normal line (angle of incidence > angle
  of refraction)."""@en ;
  dcterms:modified "2026-06-09T00:46:37.431326Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5084-3
  a curric:KeyLearningPoint ;
  rdfs:label """When waves speed up, they turn away from the normal line (angle of incidence < angle
  of refraction)."""@en ;
  dcterms:modified "2026-06-09T00:46:37.431334Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5084-4
  a curric:KeyLearningPoint ;
  rdfs:label """Refraction can be investigated using a clear rectangular block, ray box and narrow
  slit, pencil, paper and a protractor."""@en ;
  dcterms:modified "2026-06-09T00:46:37.431346Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5084-5
  a curric:KeyLearningPoint ;
  rdfs:label """Refraction occurs when one side of a wavefront enters the new medium before the
  other, causing a change in wave speed."""@en ;
  dcterms:modified "2026-06-09T00:46:37.431354Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9107-1
  a curric:KeyLearningPoint ;
  rdfs:label "The velocity of an object is equal to the gradient of a displacement-time graph."@en ;
  dcterms:modified "2026-06-09T00:46:37.433152Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9107-2
  a curric:KeyLearningPoint ;
  rdfs:label "A direction in which velocity and displacement are measured needs to be chosen."@en ;
  dcterms:modified "2026-06-09T00:46:37.433160Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9107-3
  a curric:KeyLearningPoint ;
  rdfs:label """A negative gradient on a displacement-time graph (sloping downwards) represents
  velocity in the opposite direction."""@en ;
  dcterms:modified "2026-06-09T00:46:37.433168Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9107-4
  a curric:KeyLearningPoint ;
  rdfs:label """A negative value for displacement represents a position ‘behind’ the starting
  position."""@en ;
  dcterms:modified "2026-06-09T00:46:37.433176Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9107-5
  a curric:KeyLearningPoint ;
  rdfs:label """Instantaneous velocity of an object is equal to the gradient of a tangent to a
  displacement-time curve."""@en ;
  dcterms:modified "2026-06-09T00:46:37.433183Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9907-1
  a curric:KeyLearningPoint ;
  rdfs:label "Acceleration is equal to the gradient of a velocity-time graph."@en ;
  dcterms:modified "2026-06-09T00:46:37.436465Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9907-2
  a curric:KeyLearningPoint ;
  rdfs:label """A falling line shows decreasing velocity called deceleration, which is a negative
  acceleration."""@en ;
  dcterms:modified "2026-06-09T00:46:37.436472Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9907-3
  a curric:KeyLearningPoint ;
  rdfs:label """Instantaneous speed at a point on a displacement-time graph equals the gradient of a
  tangent at that point."""@en ;
  dcterms:modified "2026-06-09T00:46:37.436479Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9907-4
  a curric:KeyLearningPoint ;
  rdfs:label "The distance travelled is equal to the area under a velocity-time graph."@en ;
  dcterms:modified "2026-06-09T00:46:37.436486Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9907-5
  a curric:KeyLearningPoint ;
  rdfs:label "Displacement is equal to the net positive area under a velocity-time graph."@en ;
  dcterms:modified "2026-06-09T00:46:37.436494Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9137-1
  a curric:KeyLearningPoint ;
  rdfs:label """Acceleration can be measured accurately using light gates or roughly measured using
  a stopwatch and ruler."""@en ;
  dcterms:modified "2026-06-09T00:46:37.437070Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9137-2
  a curric:KeyLearningPoint ;
  rdfs:label """The acceleration of an object is proportional to the resultant force acting on the
  object."""@en ;
  dcterms:modified "2026-06-09T00:46:37.437084Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9137-3
  a curric:KeyLearningPoint ;
  rdfs:label """The acceleration of an object is inversely proportional to the mass of the
  object."""@en ;
  dcterms:modified "2026-06-09T00:46:37.437092Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9137-4
  a curric:KeyLearningPoint ;
  rdfs:label "Newton's Second Law states that F = m × a."@en ;
  dcterms:modified "2026-06-09T00:46:37.437099Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6579-1
  a curric:KeyLearningPoint ;
  rdfs:label "A displacement–time graph shows how displacement changes with time."@en ;
  dcterms:modified "2026-06-09T00:46:37.438866Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6579-2
  a curric:KeyLearningPoint ;
  rdfs:label "A velocity–time graph shows how velocity changes with time."@en ;
  dcterms:modified "2026-06-09T00:46:37.438873Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6579-3
  a curric:KeyLearningPoint ;
  rdfs:label """Displacement–time and velocity–time graphs of the same motion have different
  shapes."""@en ;
  dcterms:modified "2026-06-09T00:46:37.438885Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6579-4
  a curric:KeyLearningPoint ;
  rdfs:label "Acceleration is equal to the gradient of a velocity–time graph."@en ;
  dcterms:modified "2026-06-09T00:46:37.438892Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6579-5
  a curric:KeyLearningPoint ;
  rdfs:label """A falling line shows deceleration (decreasing velocity) which is a negative
  acceleration."""@en ;
  dcterms:modified "2026-06-09T00:46:37.438900Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9906-1
  a curric:KeyLearningPoint ;
  rdfs:label "A displacement–time graph shows how displacement changes with time."@en ;
  dcterms:modified "2026-06-09T00:46:37.446281Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9906-2
  a curric:KeyLearningPoint ;
  rdfs:label "A velocity–time graph shows how velocity changes with time."@en ;
  dcterms:modified "2026-06-09T00:46:37.446287Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9906-3
  a curric:KeyLearningPoint ;
  rdfs:label """Displacement–time and velocity–time graphs of the same motion have different
  shapes."""@en ;
  dcterms:modified "2026-06-09T00:46:37.446293Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4920-1
  a curric:KeyLearningPoint ;
  rdfs:label """The momentum of an object is changed by a resultant force acting over a period of
  time."""@en ;
  dcterms:modified "2026-06-09T00:46:37.447497Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4920-2
  a curric:KeyLearningPoint ;
  rdfs:label "Force = rate of change of momentum, F = Δp ÷ t = (mv – mu) ÷ t"@en ;
  dcterms:modified "2026-06-09T00:46:37.447503Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4920-3
  a curric:KeyLearningPoint ;
  rdfs:label """The size of an impact force can be changed when the duration of the impact
  changes."""@en ;
  dcterms:modified "2026-06-09T00:46:37.447509Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6605-1
  a curric:KeyLearningPoint ;
  rdfs:label """An appropriate range of p.d. values includes 0 V and the maximum p.d. of the lamp
  and at least four other readings."""@en ;
  dcterms:modified "2026-06-09T00:46:37.463729Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6605-2
  a curric:KeyLearningPoint ;
  rdfs:label """For electricity investigations, it is good practice to take many more than the
  minimum number of measurements."""@en ;
  dcterms:modified "2026-06-09T00:46:37.463734Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6605-3
  a curric:KeyLearningPoint ;
  rdfs:label """After plotting a graph, extra readings could be taken to fill gaps or to check
  possible errors."""@en ;
  dcterms:modified "2026-06-09T00:46:37.463739Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6605-4
  a curric:KeyLearningPoint ;
  rdfs:label """Plots that lie off the best fit line are possible errors that need to be
  checked."""@en ;
  dcterms:modified "2026-06-09T00:46:37.463744Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6605-5
  a curric:KeyLearningPoint ;
  rdfs:label """The resistance of a filament lamp is calculated from an I–V graph using pairs of
  readings and the equation R = V ÷ I."""@en ;
  dcterms:modified "2026-06-09T00:46:37.463749Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27965-1
  a curric:KeyLearningPoint ;
  rdfs:label "Radioactive decay is a random process."@en ;
  dcterms:modified "2026-06-09T00:46:37.463754Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27965-2
  a curric:KeyLearningPoint ;
  rdfs:label """It is impossible to predict the moment that a particular unstable nucleus will
  decay."""@en ;
  dcterms:modified "2026-06-09T00:46:37.463759Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27965-3
  a curric:KeyLearningPoint ;
  rdfs:label """It is possible to predict how long it will take for half of a sample of a
  radioactive isotope to decay."""@en ;
  dcterms:modified "2026-06-09T00:46:37.463764Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27965-4
  a curric:KeyLearningPoint ;
  rdfs:label """Radioactive half-life is the time taken for half of a radioactive isotope to decay
  (or for its activity to halve)."""@en ;
  dcterms:modified "2026-06-09T00:46:37.463769Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27965-5
  a curric:KeyLearningPoint ;
  rdfs:label "Each radioactive isotope has its own half-life that is always the same."@en ;
  dcterms:modified "2026-06-09T00:46:37.463777Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4924-1
  a curric:KeyLearningPoint ;
  rdfs:label """Energy transferred to increase the temperature of a substance by heating by a fixed
  amount is proportional to mass."""@en ;
  dcterms:modified "2026-06-09T00:46:37.463860Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4924-2
  a curric:KeyLearningPoint ;
  rdfs:label """Energy transferred to a substance by heating a fixed amount is proportional to the
  increase in temperature."""@en ;
  dcterms:modified "2026-06-09T00:46:37.463865Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4924-3
  a curric:KeyLearningPoint ;
  rdfs:label """Energy transferred to increase the temperature of a substance by heating is
  proportional to its specific heat capacity."""@en ;
  dcterms:modified "2026-06-09T00:46:37.463870Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4924-4
  a curric:KeyLearningPoint ;
  rdfs:label """Specific heat capacity equals the energy transferred to or by 1 kg of a material
  when its temperature changes by 1ºC."""@en ;
  dcterms:modified "2026-06-09T00:46:37.463878Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4924-5
  a curric:KeyLearningPoint ;
  rdfs:label """Specific heat capacity, c, is measured in joules per kilogram per degree Celsius
  (J/kg ºC)."""@en ;
  dcterms:modified "2026-06-09T00:46:37.463883Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4925-1
  a curric:KeyLearningPoint ;
  rdfs:label """A joulemeter measures a total amount of energy transferred to an electric
  circuit."""@en ;
  dcterms:modified "2026-06-09T00:46:37.463889Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4925-2
  a curric:KeyLearningPoint ;
  rdfs:label """At equilibrium, a metal block is at the same temperature as the water bath
  it is in."""@en ;
  dcterms:modified "2026-06-09T00:46:37.463894Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4925-3
  a curric:KeyLearningPoint ;
  rdfs:label """Specific heat capacity, c, is measured in joules per kilogram per degree
  Celsius."""@en ;
  dcterms:modified "2026-06-09T00:46:37.463899Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6613-1
  a curric:KeyLearningPoint ;
  rdfs:label """An electromagnetic door lock uses an electromagnet to pull a magnetic bolt to unlock
  a door."""@en ;
  dcterms:modified "2026-06-09T00:46:37.466072Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6613-2
  a curric:KeyLearningPoint ;
  rdfs:label """An electric bell often contains an electromagnet that attracts and moves the
  striker, making it hit the bell."""@en ;
  dcterms:modified "2026-06-09T00:46:37.466077Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6613-3
  a curric:KeyLearningPoint ;
  rdfs:label """As an electromagnet moves the striker in an electric bell, it breaks its own circuit
  to let the striker spring back."""@en ;
  dcterms:modified "2026-06-09T00:46:37.466082Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6613-4
  a curric:KeyLearningPoint ;
  rdfs:label "A motor contains a spinning coil of wire that is an electromagnet."@en ;
  dcterms:modified "2026-06-09T00:46:37.466087Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6613-5
  a curric:KeyLearningPoint ;
  rdfs:label """When there is a current in the spinning coil of wire in a motor, other magnets
  around it will push it round."""@en ;
  dcterms:modified "2026-06-09T00:46:37.466092Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6603-1
  a curric:KeyLearningPoint ;
  rdfs:label """A random error is a chance difference between an observed value and the true
  value."""@en ;
  dcterms:modified "2026-06-09T00:46:37.466097Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6603-2
  a curric:KeyLearningPoint ;
  rdfs:label """Random errors can be caused by mistakes in taking readings, or by taking a reading
  at the wrong time."""@en ;
  dcterms:modified "2026-06-09T00:46:37.466102Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6603-3
  a curric:KeyLearningPoint ;
  rdfs:label "The temperature of a melting solid does not change as it heated."@en ;
  dcterms:modified "2026-06-09T00:46:37.466107Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6603-4
  a curric:KeyLearningPoint ;
  rdfs:label "The temperature of a boiling liquid does not change as it is heated."@en ;
  dcterms:modified "2026-06-09T00:46:37.466113Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4916-1
  a curric:KeyLearningPoint ;
  rdfs:label """An object that is dropped experiences a constant gravitational force towards the
  centre of Earth."""@en ;
  dcterms:modified "2026-06-09T00:46:37.467729Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4916-2
  a curric:KeyLearningPoint ;
  rdfs:label """For a falling object, drag acts in the opposite direction to the gravitational
  force."""@en ;
  dcterms:modified "2026-06-09T00:46:37.467735Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4916-3
  a curric:KeyLearningPoint ;
  rdfs:label "As a falling object speeds up, the air resistance pushing up on it increases."@en ;
  dcterms:modified "2026-06-09T00:46:37.467740Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4916-4
  a curric:KeyLearningPoint ;
  rdfs:label """When the resultant force on a falling object becomes zero, the object reaches
  terminal velocity."""@en ;
  dcterms:modified "2026-06-09T00:46:37.467745Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6598-1
  a curric:KeyLearningPoint ;
  rdfs:label """A dynamics trolley speeds up (accelerates) along the whole length of a steep
  ramp."""@en ;
  dcterms:modified "2026-06-09T00:46:37.467832Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6598-2
  a curric:KeyLearningPoint ;
  rdfs:label "Instantaneous speed is the average speed over a very short time period."@en ;
  dcterms:modified "2026-06-09T00:46:37.467837Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6598-3
  a curric:KeyLearningPoint ;
  rdfs:label "Taking measurements by reading the timing lines at eye level improves accuracy."@en ;
  dcterms:modified "2026-06-09T00:46:37.467842Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6598-4
  a curric:KeyLearningPoint ;
  rdfs:label "Repeated readings by different observers helps to check for systematic errors."@en ;
  dcterms:modified "2026-06-09T00:46:37.467847Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5039-1
  a curric:KeyLearningPoint ;
  rdfs:label """The p.d. across each branch of a parallel circuit is the same as the p.d. across the
  battery."""@en ;
  dcterms:modified "2026-06-09T00:46:37.469544Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5039-2
  a curric:KeyLearningPoint ;
  rdfs:label """The current through each branch of a parallel circuit adds up to the current through
  the battery."""@en ;
  dcterms:modified "2026-06-09T00:46:37.469552Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5039-3
  a curric:KeyLearningPoint ;
  rdfs:label """Adding a component in a new branch of a parallel circuit reduces the resistance of
  the circuit."""@en ;
  dcterms:modified "2026-06-09T00:46:37.469557Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5039-4
  a curric:KeyLearningPoint ;
  rdfs:label """Adding a component to an existing branch of a parallel circuit increases the
  resistance of the circuit."""@en ;
  dcterms:modified "2026-06-09T00:46:37.469565Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5039-5
  a curric:KeyLearningPoint ;
  rdfs:label """The p.d. across the terminals of a battery does not change when components are added
  to a circuit."""@en ;
  dcterms:modified "2026-06-09T00:46:37.469570Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5059-1
  a curric:KeyLearningPoint ;
  rdfs:label """An LDR is made of a semiconductor, and the brighter the light shining on it, the
  lower its resistance."""@en ;
  dcterms:modified "2026-06-09T00:46:37.470523Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5059-2
  a curric:KeyLearningPoint ;
  rdfs:label """Light transfers energy that enables electrons in a semiconductor to move as they do
  in a metal conductor."""@en ;
  dcterms:modified "2026-06-09T00:46:37.470528Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5059-3
  a curric:KeyLearningPoint ;
  rdfs:label """A thermistor is made of a semiconductor, and the hotter it is, the lower its
  resistance."""@en ;
  dcterms:modified "2026-06-09T00:46:37.470533Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5059-4
  a curric:KeyLearningPoint ;
  rdfs:label """Heating transfers energy that enables electrons in a semiconductor to move as they
  do in a metal conductor."""@en ;
  dcterms:modified "2026-06-09T00:46:37.470539Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5059-5
  a curric:KeyLearningPoint ;
  rdfs:label """A potential divider circuit can be set up with an LDR/thermistor to trigger a switch
  if it becomes too dark or too cold."""@en ;
  dcterms:modified "2026-06-09T00:46:37.470544Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6615-1
  a curric:KeyLearningPoint ;
  rdfs:label """Refraction is when waves travel from one transparent medium to another, causing a
  change in direction."""@en ;
  dcterms:modified "2026-06-09T00:46:37.471428Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6615-2
  a curric:KeyLearningPoint ;
  rdfs:label """When waves slow down, they turn towards the normal line (angle of incidence > angle
  of refraction)."""@en ;
  dcterms:modified "2026-06-09T00:46:37.471434Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6615-3
  a curric:KeyLearningPoint ;
  rdfs:label """When waves speed up, they turn away from the normal line (angle of incidence < angle
  of refraction)."""@en ;
  dcterms:modified "2026-06-09T00:46:37.471439Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6615-4
  a curric:KeyLearningPoint ;
  rdfs:label """Refraction can be investigated using a clear rectangular block, ray box and narrow
  slit, pencil, paper and a protractor."""@en ;
  dcterms:modified "2026-06-09T00:46:37.471444Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6615-5
  a curric:KeyLearningPoint ;
  rdfs:label "The greater the angle of incidence, the greater the angle of refraction."@en ;
  dcterms:modified "2026-06-09T00:46:37.471450Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8155-1
  a curric:KeyLearningPoint ;
  rdfs:label "Density is calculated using the equation: density = mass ÷ volume."@en ;
  dcterms:modified "2026-06-09T00:46:37.471506Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8155-2
  a curric:KeyLearningPoint ;
  rdfs:label """The volume of water displaced by a submerged object is equal to the volume of the
  object."""@en ;
  dcterms:modified "2026-06-09T00:46:37.471511Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8155-3
  a curric:KeyLearningPoint ;
  rdfs:label """The dimensions of a regular cuboid can be measured accurately with Vernier
  callipers."""@en ;
  dcterms:modified "2026-06-09T00:46:37.471516Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8155-4
  a curric:KeyLearningPoint ;
  rdfs:label """The volume of a regular cuboid is calculated using the equation: volume = length ×
  width × height."""@en ;
  dcterms:modified "2026-06-09T00:46:37.471524Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5035-1
  a curric:KeyLearningPoint ;
  rdfs:label "Two unlike electric charges attract each other."@en ;
  dcterms:modified "2026-06-09T00:46:37.473170Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5035-2
  a curric:KeyLearningPoint ;
  rdfs:label "Two like electric charges repel each other."@en ;
  dcterms:modified "2026-06-09T00:46:37.473176Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5035-3
  a curric:KeyLearningPoint ;
  rdfs:label """In an electric circuit, electrons are forced towards the positive terminal of a
  battery."""@en ;
  dcterms:modified "2026-06-09T00:46:37.473181Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5035-4
  a curric:KeyLearningPoint ;
  rdfs:label """Electric current is the amount of charge that passes a point in a circuit in each
  second."""@en ;
  dcterms:modified "2026-06-09T00:46:37.473189Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5035-5
  a curric:KeyLearningPoint ;
  rdfs:label "Current can be found using the equation: current = charge ÷ time."@en ;
  dcterms:modified "2026-06-09T00:46:37.473195Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5058-1
  a curric:KeyLearningPoint ;
  rdfs:label """The p.d. across a component in an electric circuit measures the size of push that is
  moving current through it."""@en ;
  dcterms:modified "2026-06-09T00:46:37.476495Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5058-2
  a curric:KeyLearningPoint ;
  rdfs:label """The p.d. across each component in a series circuit adds up to the p.d. across the
  battery."""@en ;
  dcterms:modified "2026-06-09T00:46:37.476541Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5058-3
  a curric:KeyLearningPoint ;
  rdfs:label "The current is the same through every component in a series circuit."@en ;
  dcterms:modified "2026-06-09T00:46:37.476547Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5058-4
  a curric:KeyLearningPoint ;
  rdfs:label """The larger the total resistance of a series circuit, the smaller the current through
  it."""@en ;
  dcterms:modified "2026-06-09T00:46:37.476552Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5058-5
  a curric:KeyLearningPoint ;
  rdfs:label """In a series circuit, the share of p.d. across each component is proportional to its
  resistance."""@en ;
  dcterms:modified "2026-06-09T00:46:37.476557Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4727-1
  a curric:KeyLearningPoint ;
  rdfs:label """A dynamics trolley speeds up (accelerates) along the whole length of a steep
  ramp."""@en ;
  dcterms:modified "2026-06-09T00:46:37.476562Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4727-2
  a curric:KeyLearningPoint ;
  rdfs:label "Instantaneous speed is the average speed over a very short time period."@en ;
  dcterms:modified "2026-06-09T00:46:37.476567Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4727-3
  a curric:KeyLearningPoint ;
  rdfs:label """Instantaneous speed can be estimated by measuring movement in a small time
  period."""@en ;
  dcterms:modified "2026-06-09T00:46:37.476573Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4727-4
  a curric:KeyLearningPoint ;
  rdfs:label """Anomalous readings should be repeated and replaced or removed from sets of repeat
  readings."""@en ;
  dcterms:modified "2026-06-09T00:46:37.476577Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4729-1
  a curric:KeyLearningPoint ;
  rdfs:label "The velocity of an object is equal to the gradient of a displacement-time graph."@en ;
  dcterms:modified "2026-06-09T00:46:37.476582Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4729-2
  a curric:KeyLearningPoint ;
  rdfs:label "A direction in which velocity and displacement are measured needs to be chosen."@en ;
  dcterms:modified "2026-06-09T00:46:37.476587Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4729-3
  a curric:KeyLearningPoint ;
  rdfs:label """A negative gradient on a displacement-time graph (sloping downwards) represents
  velocity in the opposite direction."""@en ;
  dcterms:modified "2026-06-09T00:46:37.476592Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4729-4
  a curric:KeyLearningPoint ;
  rdfs:label """A negative value for displacement represents a position ‘behind’ the starting
  position."""@en ;
  dcterms:modified "2026-06-09T00:46:37.476600Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5081-1
  a curric:KeyLearningPoint ;
  rdfs:label """A sound can be represented by an electronic signal changing in time to match the
  sound wave."""@en ;
  dcterms:modified "2026-06-09T00:46:37.476708Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5081-2
  a curric:KeyLearningPoint ;
  rdfs:label """Loudspeakers use the motor effect to convert electrical signals into sound
  waves."""@en ;
  dcterms:modified "2026-06-09T00:46:37.476713Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5081-3
  a curric:KeyLearningPoint ;
  rdfs:label """A moving–coil loudspeaker is made from a cone connected to a coil of wire that moves
  in relation to a fixed magnet."""@en ;
  dcterms:modified "2026-06-09T00:46:37.476718Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5081-4
  a curric:KeyLearningPoint ;
  rdfs:label """Microphones use the generator effect to convert sound waves into electrical
  signals."""@en ;
  dcterms:modified "2026-06-09T00:46:37.476723Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5081-5
  a curric:KeyLearningPoint ;
  rdfs:label """A moving–coil microphone is made from a diaphragm connected to a coil of wire that
  moves in relation to a fixed magnet."""@en ;
  dcterms:modified "2026-06-09T00:46:37.476728Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9123-1
  a curric:KeyLearningPoint ;
  rdfs:label """In a fair test, only the independent variable is changed so that no other changes
  could affect the results."""@en ;
  dcterms:modified "2026-06-09T00:46:37.477619Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9123-2
  a curric:KeyLearningPoint ;
  rdfs:label "The variables that are deliberately kept the same are called control variables."@en ;
  dcterms:modified "2026-06-09T00:46:37.477624Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9123-3
  a curric:KeyLearningPoint ;
  rdfs:label "A lid on a beaker prevents transfer of energy by convection currents."@en ;
  dcterms:modified "2026-06-09T00:46:37.477629Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9123-4
  a curric:KeyLearningPoint ;
  rdfs:label "Gas is a very poor thermal conductor."@en ;
  dcterms:modified "2026-06-09T00:46:37.477635Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6606-1
  a curric:KeyLearningPoint ;
  rdfs:label """The properties of a diode are different, depending on the direction of p.d. across
  it."""@en ;
  dcterms:modified "2026-06-09T00:46:37.477879Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6606-2
  a curric:KeyLearningPoint ;
  rdfs:label """An appropriate range of p.d. includes 0 V and the maximum voltage of the diode and
  at least four other readings."""@en ;
  dcterms:modified "2026-06-09T00:46:37.477884Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6606-3
  a curric:KeyLearningPoint ;
  rdfs:label """An appropriate range for a diode includes the maximum p.d. in both directions, with
  positive and negative values."""@en ;
  dcterms:modified "2026-06-09T00:46:37.477889Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6606-4
  a curric:KeyLearningPoint ;
  rdfs:label """For electricity investigations, it is good practice to take many more than the
  minimum number of measurements."""@en ;
  dcterms:modified "2026-06-09T00:46:37.477894Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6601-1
  a curric:KeyLearningPoint ;
  rdfs:label "Frequency of a wave can be measured indirectly from its speed and wavelength."@en ;
  dcterms:modified "2026-06-09T00:46:37.477899Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6601-2
  a curric:KeyLearningPoint ;
  rdfs:label """Wavelength of a wave can be measured by using a freeze frame of a wave moving along
  the length of a ruler."""@en ;
  dcterms:modified "2026-06-09T00:46:37.477904Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6601-3
  a curric:KeyLearningPoint ;
  rdfs:label """It is more accurate to measure the length of, e.g. ten waves and dividing by ten,
  than measuring one wavelength."""@en ;
  dcterms:modified "2026-06-09T00:46:37.477909Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6601-4
  a curric:KeyLearningPoint ;
  rdfs:label """Speed of a wave can be measured by recording the wave moving along a ruler with a
  timer in the frame."""@en ;
  dcterms:modified "2026-06-09T00:46:37.477914Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6601-5
  a curric:KeyLearningPoint ;
  rdfs:label """Accurate distance and time are measured by freezing the film, played back in slow
  motion, to track one wave crest."""@en ;
  dcterms:modified "2026-06-09T00:46:37.477922Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8154-1
  a curric:KeyLearningPoint ;
  rdfs:label """Particles in a gas move very quickly in random directions and have empty space
  between them."""@en ;
  dcterms:modified "2026-06-09T00:46:37.477927Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8154-2
  a curric:KeyLearningPoint ;
  rdfs:label """Heating a fluid increases the speed of particles and they push each other further
  apart."""@en ;
  dcterms:modified "2026-06-09T00:46:37.477932Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8154-3
  a curric:KeyLearningPoint ;
  rdfs:label "As a fluid is heated, it becomes less dense."@en ;
  dcterms:modified "2026-06-09T00:46:37.477937Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8154-4
  a curric:KeyLearningPoint ;
  rdfs:label "Hotter fluid rises through cooler fluid because it is less dense."@en ;
  dcterms:modified "2026-06-09T00:46:37.477943Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6604-1
  a curric:KeyLearningPoint ;
  rdfs:label """Energy transferred to increase the temperature of a substance by heating by a fixed
  amount is proportional to mass."""@en ;
  dcterms:modified "2026-06-09T00:46:37.482097Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6604-2
  a curric:KeyLearningPoint ;
  rdfs:label """Energy transferred to a substance by heating a fixed amount is proportional to the
  increase in temperature."""@en ;
  dcterms:modified "2026-06-09T00:46:37.482105Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6604-3
  a curric:KeyLearningPoint ;
  rdfs:label """Energy transferred to increase the temperature of a substance by heating is
  proportional to its specific heat capacity."""@en ;
  dcterms:modified "2026-06-09T00:46:37.482110Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6604-4
  a curric:KeyLearningPoint ;
  rdfs:label """Specific heat capacity equals the energy transferred to/by 1 kg of a material when
  its temperature changes by 1ºC."""@en ;
  dcterms:modified "2026-06-09T00:46:37.482115Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6604-5
  a curric:KeyLearningPoint ;
  rdfs:label """Specific heat capacity, c, is measured in joules per kilogram per degree Celsius
  (J/kg ºC)."""@en ;
  dcterms:modified "2026-06-09T00:46:37.482120Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9905-1
  a curric:KeyLearningPoint ;
  rdfs:label "A displacement–time graph shows how displacement changes with time."@en ;
  dcterms:modified "2026-06-09T00:46:37.487216Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9905-2
  a curric:KeyLearningPoint ;
  rdfs:label "A velocity–time graph shows how velocity changes with time."@en ;
  dcterms:modified "2026-06-09T00:46:37.487222Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9905-3
  a curric:KeyLearningPoint ;
  rdfs:label """Displacement–time and velocity–time graphs of the same motion have different
  shapes."""@en ;
  dcterms:modified "2026-06-09T00:46:37.487227Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9905-4
  a curric:KeyLearningPoint ;
  rdfs:label "Acceleration is equal to the gradient of a velocity–time graph."@en ;
  dcterms:modified "2026-06-09T00:46:37.487235Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9905-5
  a curric:KeyLearningPoint ;
  rdfs:label """A falling line shows deceleration (decreasing velocity) which is a negative
  acceleration."""@en ;
  dcterms:modified "2026-06-09T00:46:37.487243Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6616-1
  a curric:KeyLearningPoint ;
  rdfs:label """In cameras and the human eye, the required image distance < the object distance. The
  image is diminished and inverted."""@en ;
  dcterms:modified "2026-06-09T00:46:37.487369Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6616-2
  a curric:KeyLearningPoint ;
  rdfs:label """In projectors, the required image distance > the object distance. The image is
  magnified and inverted."""@en ;
  dcterms:modified "2026-06-09T00:46:37.487374Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6616-3
  a curric:KeyLearningPoint ;
  rdfs:label """A ray incident on a convex lens parallel to the principal axis is refracted to pass
  through principal focus."""@en ;
  dcterms:modified "2026-06-09T00:46:37.487379Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6616-4
  a curric:KeyLearningPoint ;
  rdfs:label "A ray incident on the centre of a convex lens is not refracted."@en ;
  dcterms:modified "2026-06-09T00:46:37.487384Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6616-5
  a curric:KeyLearningPoint ;
  rdfs:label """A ray incident on a convex lens from the principal focus is refracted so it becomes
  parallel to the principal axis."""@en ;
  dcterms:modified "2026-06-09T00:46:37.487389Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9890-1
  a curric:KeyLearningPoint ;
  rdfs:label """A dynamics trolley speeds up (accelerates) along the whole length of a steep
  ramp."""@en ;
  dcterms:modified "2026-06-09T00:46:37.487394Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9890-2
  a curric:KeyLearningPoint ;
  rdfs:label "Instantaneous speed is the average speed over a very short time period."@en ;
  dcterms:modified "2026-06-09T00:46:37.487399Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9890-3
  a curric:KeyLearningPoint ;
  rdfs:label """Instantaneous speed can be estimated by measuring movement in a small time
  period."""@en ;
  dcterms:modified "2026-06-09T00:46:37.487404Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9890-4
  a curric:KeyLearningPoint ;
  rdfs:label """Anomalous readings should be repeated and replaced or removed from sets of repeat
  readings."""@en ;
  dcterms:modified "2026-06-09T00:46:37.487409Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9127-1
  a curric:KeyLearningPoint ;
  rdfs:label "A wire heats up when a current flows and its temperature will vary over time."@en ;
  dcterms:modified "2026-06-09T00:46:37.488538Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9127-2
  a curric:KeyLearningPoint ;
  rdfs:label "A water bath helps to keep the temperature of a wire constant."@en ;
  dcterms:modified "2026-06-09T00:46:37.488543Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9127-3
  a curric:KeyLearningPoint ;
  rdfs:label "Turning a circuit on for a very short time reduces the heating effect in a wire."@en ;
  dcterms:modified "2026-06-09T00:46:37.488548Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9127-4
  a curric:KeyLearningPoint ;
  rdfs:label """In electricity investigations, it is often easy to take lots of readings rather than
  a few, repeated readings."""@en ;
  dcterms:modified "2026-06-09T00:46:37.488553Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9127-5
  a curric:KeyLearningPoint ;
  rdfs:label """The resistance of a wire is directly proportional to its length, at a constant
  temperature."""@en ;
  dcterms:modified "2026-06-09T00:46:37.488558Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6612-1
  a curric:KeyLearningPoint ;
  rdfs:label """A soft iron core increases the strength of an electromagnet because it becomes
  magnetised when it is turned on."""@en ;
  dcterms:modified "2026-06-09T00:46:37.490975Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6612-2
  a curric:KeyLearningPoint ;
  rdfs:label """The more tightly wound the coil of wire is in an electromagnet, the stronger its
  magnetic field."""@en ;
  dcterms:modified "2026-06-09T00:46:37.490980Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6612-3
  a curric:KeyLearningPoint ;
  rdfs:label """The greater the current through the coil of an electromagnet, the stronger its
  magnetic field."""@en ;
  dcterms:modified "2026-06-09T00:46:37.490987Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6612-4
  a curric:KeyLearningPoint ;
  rdfs:label """The strength of an electromagnet is directly proportional to the current
  through it."""@en ;
  dcterms:modified "2026-06-09T00:46:37.490995Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4910-1
  a curric:KeyLearningPoint ;
  rdfs:label "Energy cannot be created or destroyed."@en ;
  dcterms:modified "2026-06-09T00:46:37.491649Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4910-2
  a curric:KeyLearningPoint ;
  rdfs:label "In an ideal situation, no energy is dissipated."@en ;
  dcterms:modified "2026-06-09T00:46:37.491655Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4910-3
  a curric:KeyLearningPoint ;
  rdfs:label """As an object changes height, change in gravitational potential energy = change in
  kinetic energy."""@en ;
  dcterms:modified "2026-06-09T00:46:37.491660Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9140-1
  a curric:KeyLearningPoint ;
  rdfs:label """An object that is dropped experiences a constant gravitational force towards the
  centre of the Earth"""@en ;
  dcterms:modified "2026-06-09T00:46:37.494619Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9140-2
  a curric:KeyLearningPoint ;
  rdfs:label """For a falling object, air resistance acts in the opposite direction to the
  gravitational force"""@en ;
  dcterms:modified "2026-06-09T00:46:37.494624Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9140-3
  a curric:KeyLearningPoint ;
  rdfs:label "As a falling object speeds up, the air resistance pushing up on it increases"@en ;
  dcterms:modified "2026-06-09T00:46:37.494630Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9140-4
  a curric:KeyLearningPoint ;
  rdfs:label """When the resultant force on a falling object becomes zero, the object reaches
  terminal velocity."""@en ;
  dcterms:modified "2026-06-09T00:46:37.494637Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9136-1
  a curric:KeyLearningPoint ;
  rdfs:label "Moment = force × distance (M = Fd)"@en ;
  dcterms:modified "2026-06-09T00:46:37.502698Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9136-2
  a curric:KeyLearningPoint ;
  rdfs:label """If an object is balanced, the total clockwise moment about a pivot equals the total
  anticlockwise moment."""@en ;
  dcterms:modified "2026-06-09T00:46:37.502704Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9136-3
  a curric:KeyLearningPoint ;
  rdfs:label """An object is in equilibrium if it is balanced and there are no resultant forces
  acting."""@en ;
  dcterms:modified "2026-06-09T00:46:37.502709Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9939-1
  a curric:KeyLearningPoint ;
  rdfs:label "Stretching or compressing an object requires more than one force."@en ;
  dcterms:modified "2026-06-09T00:46:37.503052Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9939-2
  a curric:KeyLearningPoint ;
  rdfs:label """Below the limit of proportionality, a stretched spring is not stretched permanently
  out of shape."""@en ;
  dcterms:modified "2026-06-09T00:46:37.503057Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9939-3
  a curric:KeyLearningPoint ;
  rdfs:label """Above the limit of proportionality, a stretched spring is stretched permanently out
  of shape."""@en ;
  dcterms:modified "2026-06-09T00:46:37.503062Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5052-1
  a curric:KeyLearningPoint ;
  rdfs:label """The speed of water waves can be measured using measurements of distance travelled
  and time taken."""@en ;
  dcterms:modified "2026-06-09T00:46:37.509657Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5052-2
  a curric:KeyLearningPoint ;
  rdfs:label "Random errors are made when the method limits how accurate a measurement can be."@en ;
  dcterms:modified "2026-06-09T00:46:37.509662Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5052-3
  a curric:KeyLearningPoint ;
  rdfs:label """The effect of random errors can be reduced by repeating readings and calculating a
  mean."""@en ;
  dcterms:modified "2026-06-09T00:46:37.509667Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5052-4
  a curric:KeyLearningPoint ;
  rdfs:label """The uncertainty in a mean result is calculated from half the range of the repeat
  measurements."""@en ;
  dcterms:modified "2026-06-09T00:46:37.509672Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9094-1
  a curric:KeyLearningPoint ;
  rdfs:label """The pressure in a fluid increases with depth because the weight of fluid above
  pushes particles closer together."""@en ;
  dcterms:modified "2026-06-09T00:46:37.513190Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9094-2
  a curric:KeyLearningPoint ;
  rdfs:label """The pressure on an object in a fluid pushes with more force on the lower part of it
  and causes upthrust."""@en ;
  dcterms:modified "2026-06-09T00:46:37.513197Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9094-3
  a curric:KeyLearningPoint ;
  rdfs:label "An object floats in water if its density is less than that of water."@en ;
  dcterms:modified "2026-06-09T00:46:37.513204Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9094-4
  a curric:KeyLearningPoint ;
  rdfs:label """The density of a material increases with the mass of each particle and the closeness
  of its particles."""@en ;
  dcterms:modified "2026-06-09T00:46:37.513209Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9094-5
  a curric:KeyLearningPoint ;
  rdfs:label """Ice is less dense than water as its crystal structure fixes the particles further
  apart than they are in water."""@en ;
  dcterms:modified "2026-06-09T00:46:37.513213Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9892-1
  a curric:KeyLearningPoint ;
  rdfs:label "The velocity of an object is its speed in a given direction."@en ;
  dcterms:modified "2026-06-09T00:46:37.516834Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9892-2
  a curric:KeyLearningPoint ;
  rdfs:label """The displacement of an object is the distance it travels in a particular
  direction."""@en ;
  dcterms:modified "2026-06-09T00:46:37.516838Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9892-3
  a curric:KeyLearningPoint ;
  rdfs:label "Displacement and velocity are both vector quantities."@en ;
  dcterms:modified "2026-06-09T00:46:37.516845Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9892-4
  a curric:KeyLearningPoint ;
  rdfs:label """Velocity has a positive value in one direction and negative value in the opposite
  direction."""@en ;
  dcterms:modified "2026-06-09T00:46:37.516850Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9892-5
  a curric:KeyLearningPoint ;
  rdfs:label """Motion in a circle involves a centripetal force which constantly changes the
  velocity of an object."""@en ;
  dcterms:modified "2026-06-09T00:46:37.516854Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4728-1
  a curric:KeyLearningPoint ;
  rdfs:label "Velocity of an object is its speed in a given direction."@en ;
  dcterms:modified "2026-06-09T00:46:37.516925Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4728-2
  a curric:KeyLearningPoint ;
  rdfs:label "Displacement is distance in a particular direction."@en ;
  dcterms:modified "2026-06-09T00:46:37.516929Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4728-3
  a curric:KeyLearningPoint ;
  rdfs:label "Displacement and velocity are vectors."@en ;
  dcterms:modified "2026-06-09T00:46:37.516934Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4728-4
  a curric:KeyLearningPoint ;
  rdfs:label "Velocity is positive in one direction and negative in the opposite direction."@en ;
  dcterms:modified "2026-06-09T00:46:37.516938Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4728-5
  a curric:KeyLearningPoint ;
  rdfs:label "Movement around a circle at a steady speed involves a changing velocity."@en ;
  dcterms:modified "2026-06-09T00:46:37.516943Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20365-1
  a curric:KeyLearningPoint ;
  rdfs:label "Frequency of a wave can be measured indirectly from its speed and wavelength."@en ;
  dcterms:modified "2026-06-09T00:46:37.517216Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20365-2
  a curric:KeyLearningPoint ;
  rdfs:label """Wavelength of a wave can be measured by using a freeze frame of a wave moving along
  the length of a ruler."""@en ;
  dcterms:modified "2026-06-09T00:46:37.517222Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20365-3
  a curric:KeyLearningPoint ;
  rdfs:label """It is more accurate to measure the length of, e.g. ten waves and dividing by ten,
  than measuring one wavelength."""@en ;
  dcterms:modified "2026-06-09T00:46:37.517227Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20365-4
  a curric:KeyLearningPoint ;
  rdfs:label """Speed of a wave can be measured by recording the wave moving along a ruler with a
  timer in the frame."""@en ;
  dcterms:modified "2026-06-09T00:46:37.517232Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20365-5
  a curric:KeyLearningPoint ;
  rdfs:label """Accurate distance and time are measured by freezing the film, played back in slow
  motion, to track one wave crest."""@en ;
  dcterms:modified "2026-06-09T00:46:37.517236Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8142-1
  a curric:KeyLearningPoint ;
  rdfs:label "Earthquakes usually occur near to the edges of tectonic plates"@en ;
  dcterms:modified "2026-06-09T00:46:37.526128Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8142-2
  a curric:KeyLearningPoint ;
  rdfs:label """P waves and S waves are produced deep underground where tectonic plates slip and
  cause vibrations in rock"""@en ;
  dcterms:modified "2026-06-09T00:46:37.526133Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8142-3
  a curric:KeyLearningPoint ;
  rdfs:label "P waves are longitudinal waves and travel through liquid"@en ;
  dcterms:modified "2026-06-09T00:46:37.526137Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8142-4
  a curric:KeyLearningPoint ;
  rdfs:label """S waves are transverse waves and cannot travel through liquid layers inside
  Earth"""@en ;
  dcterms:modified "2026-06-09T00:46:37.526142Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8142-5
  a curric:KeyLearningPoint ;
  rdfs:label "P waves and S waves provide evidence for the internal structure of Earth"@en ;
  dcterms:modified "2026-06-09T00:46:37.526146Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9919-1
  a curric:KeyLearningPoint ;
  rdfs:label "Work done is the total amount of energy transferred."@en ;
  dcterms:modified "2026-06-09T00:46:37.528737Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9919-2
  a curric:KeyLearningPoint ;
  rdfs:label "Work done = force × distance (moved in the direction of the force)."@en ;
  dcterms:modified "2026-06-09T00:46:37.528741Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9919-3
  a curric:KeyLearningPoint ;
  rdfs:label "Work done is measured in joules (J)."@en ;
  dcterms:modified "2026-06-09T00:46:37.528746Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9894-1
  a curric:KeyLearningPoint ;
  rdfs:label "Velocity of an object is equal to the gradient of a displacement-time graph."@en ;
  dcterms:modified "2026-06-09T00:46:37.535931Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9894-2
  a curric:KeyLearningPoint ;
  rdfs:label "A direction in which velocity and displacement are measured needs to be chosen."@en ;
  dcterms:modified "2026-06-09T00:46:37.535936Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9894-3
  a curric:KeyLearningPoint ;
  rdfs:label """A negative gradient on a displacement-time graph (sloping downwards) represents
  velocity in the opposite direction."""@en ;
  dcterms:modified "2026-06-09T00:46:37.535940Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9894-4
  a curric:KeyLearningPoint ;
  rdfs:label """A negative value for displacement represents a position ‘behind’ the starting
  position."""@en ;
  dcterms:modified "2026-06-09T00:46:37.535945Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9895-1
  a curric:KeyLearningPoint ;
  rdfs:label "The velocity of an object is equal to the gradient of a displacement-time graph."@en ;
  dcterms:modified "2026-06-09T00:46:37.551719Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9895-2
  a curric:KeyLearningPoint ;
  rdfs:label "A direction in which velocity and displacement are measured needs to be chosen."@en ;
  dcterms:modified "2026-06-09T00:46:37.551725Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9895-3
  a curric:KeyLearningPoint ;
  rdfs:label """A negative gradient on a displacement-time graph (sloping downwards) represents
  velocity in the opposite direction."""@en ;
  dcterms:modified "2026-06-09T00:46:37.551732Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9895-4
  a curric:KeyLearningPoint ;
  rdfs:label """A negative value for displacement represents a position ‘behind’ the starting
  position."""@en ;
  dcterms:modified "2026-06-09T00:46:37.551736Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4909-1
  a curric:KeyLearningPoint ;
  rdfs:label """Doubling the stiffness of a spring doubles the energy it has because it is
  stretched."""@en ;
  dcterms:modified "2026-06-09T00:46:37.552242Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4909-2
  a curric:KeyLearningPoint ;
  rdfs:label "The spring constant is measured in newtons per metre (N/m)."@en ;
  dcterms:modified "2026-06-09T00:46:37.552246Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4909-3
  a curric:KeyLearningPoint ;
  rdfs:label """Doubling the extension of a spring increases the energy it has, because it is
  stretched, by four times."""@en ;
  dcterms:modified "2026-06-09T00:46:37.552250Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4909-4
  a curric:KeyLearningPoint ;
  rdfs:label """The energy a spring has because it is stretched equals 1/2 × spring constant ×
  (extension)²."""@en ;
  dcterms:modified "2026-06-09T00:46:37.552254Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9924-1
  a curric:KeyLearningPoint ;
  rdfs:label """Energy is dissipated due to friction which causes particles to vibrate more quickly
  and heats up the surroundings."""@en ;
  dcterms:modified "2026-06-09T00:46:37.553332Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9924-2
  a curric:KeyLearningPoint ;
  rdfs:label """Energy is dissipated due to drag which causes particles in the surroundings to move
  more quickly."""@en ;
  dcterms:modified "2026-06-09T00:46:37.553336Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9924-3
  a curric:KeyLearningPoint ;
  rdfs:label "Efficiency = useful output energy transfer / total input energy transfer"@en ;
  dcterms:modified "2026-06-09T00:46:37.553340Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9124-1
  a curric:KeyLearningPoint ;
  rdfs:label """Energy transferred to a solid at its melting point allows its particles to move
  further apart."""@en ;
  dcterms:modified "2026-06-09T00:46:37.556432Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9124-2
  a curric:KeyLearningPoint ;
  rdfs:label """Energy transferred to a liquid at its boiling point allows its particles to move
  fast enough to get even further apart."""@en ;
  dcterms:modified "2026-06-09T00:46:37.556436Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9124-3
  a curric:KeyLearningPoint ;
  rdfs:label """The energy transferred to melt a solid at its melting point is proportional to the
  mass of the solid."""@en ;
  dcterms:modified "2026-06-09T00:46:37.556441Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9124-4
  a curric:KeyLearningPoint ;
  rdfs:label """The energy transferred to melt 1 kg of a solid at its melting point is proportional
  to the solid’s specific latent heat."""@en ;
  dcterms:modified "2026-06-09T00:46:37.556445Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9124-5
  a curric:KeyLearningPoint ;
  rdfs:label """The energy transferred to boil 1 kg of a liquid at its boiling point is proportional
  to its specific latent heat."""@en ;
  dcterms:modified "2026-06-09T00:46:37.556449Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9893-1
  a curric:KeyLearningPoint ;
  rdfs:label "The velocity of an object is equal to the gradient of a displacement-time graph."@en ;
  dcterms:modified "2026-06-09T00:46:37.570061Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9893-2
  a curric:KeyLearningPoint ;
  rdfs:label "A direction in which velocity and displacement are measured needs to be chosen."@en ;
  dcterms:modified "2026-06-09T00:46:37.570066Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9893-3
  a curric:KeyLearningPoint ;
  rdfs:label """A negative gradient on a displacement-time graph (sloping downwards) represents
  velocity in the opposite direction."""@en ;
  dcterms:modified "2026-06-09T00:46:37.570070Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9893-4
  a curric:KeyLearningPoint ;
  rdfs:label """A negative value for displacement represents a position ‘behind’ the starting
  position."""@en ;
  dcterms:modified "2026-06-09T00:46:37.570074Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5056-1
  a curric:KeyLearningPoint ;
  rdfs:label """As the p.d. across a filament lamp increases, it gets hotter and current through it
  increases in a non-ohmic way."""@en ;
  dcterms:modified "2026-06-09T00:46:37.571012Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5056-2
  a curric:KeyLearningPoint ;
  rdfs:label "The greater the p.d. across a filament lamp, the greater its resistance."@en ;
  dcterms:modified "2026-06-09T00:46:37.571016Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5056-3
  a curric:KeyLearningPoint ;
  rdfs:label """A metal is made of a lattice of positively charged ions with negatively charged
  electrons between."""@en ;
  dcterms:modified "2026-06-09T00:46:37.571020Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5056-4
  a curric:KeyLearningPoint ;
  rdfs:label """As a current flows through metal, electrons moving through the ion lattice cause it
  to vibrate more vigorously."""@en ;
  dcterms:modified "2026-06-09T00:46:37.571024Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5056-5
  a curric:KeyLearningPoint ;
  rdfs:label """The more vigorously the ions (ion lattice) vibrate, the hotter the metal and the
  higher its resistance."""@en ;
  dcterms:modified "2026-06-09T00:46:37.571029Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5119-1
  a curric:KeyLearningPoint ;
  rdfs:label "Protons have a positive electric charge of +1 and a mass number of 1."@en ;
  dcterms:modified "2026-06-09T00:46:37.571033Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5119-2
  a curric:KeyLearningPoint ;
  rdfs:label "Neutrons have no electric charge and have a mass number of 1."@en ;
  dcterms:modified "2026-06-09T00:46:37.571038Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5119-3
  a curric:KeyLearningPoint ;
  rdfs:label """The atomic number of an element equals the number of protons in the nucleus of each
  atom of that element."""@en ;
  dcterms:modified "2026-06-09T00:46:37.571042Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5119-4
  a curric:KeyLearningPoint ;
  rdfs:label """The atomic number of an element equals the number of electrons in each atom of that
  element."""@en ;
  dcterms:modified "2026-06-09T00:46:37.571046Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5119-5
  a curric:KeyLearningPoint ;
  rdfs:label """Atoms of an element that have different numbers of neutrons in their nuclei are
  isotopes of the element."""@en ;
  dcterms:modified "2026-06-09T00:46:37.571050Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9130-1
  a curric:KeyLearningPoint ;
  rdfs:label """In forward–bias, a diode has a very small resistance when the p.d. is larger than
  the threshold voltage."""@en ;
  dcterms:modified "2026-06-09T00:46:37.571184Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9130-2
  a curric:KeyLearningPoint ;
  rdfs:label """In reverse–bias, a diode has a very large resistance and very little current can
  flow."""@en ;
  dcterms:modified "2026-06-09T00:46:37.571189Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9130-3
  a curric:KeyLearningPoint ;
  rdfs:label """The greater the p.d. across a component, the larger the push on electric charges in
  the component."""@en ;
  dcterms:modified "2026-06-09T00:46:37.571193Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9130-4
  a curric:KeyLearningPoint ;
  rdfs:label """The resistance of a component is calculated from an I–V graph using pairs of
  readings and the equation R = V ÷ I."""@en ;
  dcterms:modified "2026-06-09T00:46:37.571197Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9130-5
  a curric:KeyLearningPoint ;
  rdfs:label """The greater the current through a component, the larger the heating effect
  on it."""@en ;
  dcterms:modified "2026-06-09T00:46:37.571201Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5077-1
  a curric:KeyLearningPoint ;
  rdfs:label "Wire in a motor is insulated so that the current flows around the coil"@en ;
  dcterms:modified "2026-06-09T00:46:37.571241Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5077-2
  a curric:KeyLearningPoint ;
  rdfs:label "Connections in a motor slide over each other to prevent tangled wires"@en ;
  dcterms:modified "2026-06-09T00:46:37.571245Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5077-3
  a curric:KeyLearningPoint ;
  rdfs:label """When the coil in a motor kit is horizontal it is connected and a force acts on the
  sides 90 deg. to the magnetic field"""@en ;
  dcterms:modified "2026-06-09T00:46:37.571252Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5077-4
  a curric:KeyLearningPoint ;
  rdfs:label """Every half–turn, the coil connections in a motor kit swap over and change the
  direction of current through the coil"""@en ;
  dcterms:modified "2026-06-09T00:46:37.571256Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5077-5
  a curric:KeyLearningPoint ;
  rdfs:label """Each side of a coil in a motor kit at 90º to the magnetic field is pushed
  alternatively up then down every half turn"""@en ;
  dcterms:modified "2026-06-09T00:46:37.571261Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9889-1
  a curric:KeyLearningPoint ;
  rdfs:label "Average speed = distance / time."@en ;
  dcterms:modified "2026-06-09T00:46:37.572375Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9889-2
  a curric:KeyLearningPoint ;
  rdfs:label "The speed of sound in air is about 330 m/s."@en ;
  dcterms:modified "2026-06-09T00:46:37.572380Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9889-3
  a curric:KeyLearningPoint ;
  rdfs:label "Scalar quantities have magnitude only."@en ;
  dcterms:modified "2026-06-09T00:46:37.572384Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9889-4
  a curric:KeyLearningPoint ;
  rdfs:label "Speed and distance are scalar quantities."@en ;
  dcterms:modified "2026-06-09T00:46:37.572388Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9889-5
  a curric:KeyLearningPoint ;
  rdfs:label """Relative speed is the speed an object is moving towards or away from another object,
  which may also be moving."""@en ;
  dcterms:modified "2026-06-09T00:46:37.572392Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4726-1
  a curric:KeyLearningPoint ;
  rdfs:label "Average speed = distance/time"@en ;
  dcterms:modified "2026-06-09T00:46:37.573032Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4726-2
  a curric:KeyLearningPoint ;
  rdfs:label "The speed of sound in air is about 330 m/s."@en ;
  dcterms:modified "2026-06-09T00:46:37.573036Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4726-3
  a curric:KeyLearningPoint ;
  rdfs:label "Scalar quantities have magnitude only."@en ;
  dcterms:modified "2026-06-09T00:46:37.573041Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4726-4
  a curric:KeyLearningPoint ;
  rdfs:label "Speed and distance are scalar quantities."@en ;
  dcterms:modified "2026-06-09T00:46:37.573045Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4726-5
  a curric:KeyLearningPoint ;
  rdfs:label """Relative speed is the speed an object is moving towards or away from another object,
  which may also be moving."""@en ;
  dcterms:modified "2026-06-09T00:46:37.573049Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9903-1
  a curric:KeyLearningPoint ;
  rdfs:label "A velocity-time graph shows how velocity changes with time."@en ;
  dcterms:modified "2026-06-09T00:46:37.573073Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9903-2
  a curric:KeyLearningPoint ;
  rdfs:label "Acceleration is equal to the gradient of a velocity-time graph."@en ;
  dcterms:modified "2026-06-09T00:46:37.573078Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9903-3
  a curric:KeyLearningPoint ;
  rdfs:label """A falling line shows decreasing velocity called deceleration, which is a negative
  acceleration."""@en ;
  dcterms:modified "2026-06-09T00:46:37.573082Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5044-1
  a curric:KeyLearningPoint ;
  rdfs:label """Displacement at a point of a wave is the distance that the wave medium is from its
  rest position at that point."""@en ;
  dcterms:modified "2026-06-09T00:46:37.573947Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5044-2
  a curric:KeyLearningPoint ;
  rdfs:label "Amplitude is the maximum displacement of a wave (up or down, or side to side)."@en ;
  dcterms:modified "2026-06-09T00:46:37.573952Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5044-3
  a curric:KeyLearningPoint ;
  rdfs:label "A displacement-distance graph of a wave is not a picture of the wave."@en ;
  dcterms:modified "2026-06-09T00:46:37.573956Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5044-4
  a curric:KeyLearningPoint ;
  rdfs:label """The distance between two wave crests on a displacement-distance graph is equal to
  one wavelength."""@en ;
  dcterms:modified "2026-06-09T00:46:37.573960Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5044-5
  a curric:KeyLearningPoint ;
  rdfs:label """A positive (or negative) displacement shows part of the wave above (or below) the
  equilibrium position."""@en ;
  dcterms:modified "2026-06-09T00:46:37.573964Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8153-1
  a curric:KeyLearningPoint ;
  rdfs:label "Density is calculated using the equation: density = mass ÷ volume."@en ;
  dcterms:modified "2026-06-09T00:46:37.573969Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8153-2
  a curric:KeyLearningPoint ;
  rdfs:label "Density is measured in kg/m³ or g/cm³."@en ;
  dcterms:modified "2026-06-09T00:46:37.573973Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8153-3
  a curric:KeyLearningPoint ;
  rdfs:label """The volume of water displaced by a submerged object is equal to the volume of the
  object."""@en ;
  dcterms:modified "2026-06-09T00:46:37.573977Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8153-4
  a curric:KeyLearningPoint ;
  rdfs:label """The dimensions of a regular cuboid can be measured accurately with Vernier
  callipers."""@en ;
  dcterms:modified "2026-06-09T00:46:37.573981Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8153-5
  a curric:KeyLearningPoint ;
  rdfs:label """The volume of a regular cuboid is calculated using the equation: volume = length ×
  width × height."""@en ;
  dcterms:modified "2026-06-09T00:46:37.573986Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5074-1
  a curric:KeyLearningPoint ;
  rdfs:label "The magnetic field lines around a current-carrying wire are concentric circles"@en ;
  dcterms:modified "2026-06-09T00:46:37.573990Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5074-2
  a curric:KeyLearningPoint ;
  rdfs:label "In a uniform magnetic field, a current carrying wire is forced in one direction"@en ;
  dcterms:modified "2026-06-09T00:46:37.573994Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5074-3
  a curric:KeyLearningPoint ;
  rdfs:label """Fleming’s left–hand rule can be used to predict the direction of movement of a
  current–carrying wire in a magnetic field"""@en ;
  dcterms:modified "2026-06-09T00:46:37.573998Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5074-4
  a curric:KeyLearningPoint ;
  rdfs:label """The force on a current–carrying conductor at right angles to a magnetic field, F, is
  found using F = B I l."""@en ;
  dcterms:modified "2026-06-09T00:46:37.574003Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5074-5
  a curric:KeyLearningPoint ;
  rdfs:label """Opposite sides of a conducting coil in a uniform magnetic field are forced to move
  in opposite directions"""@en ;
  dcterms:modified "2026-06-09T00:46:37.574007Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5047-1
  a curric:KeyLearningPoint ;
  rdfs:label "An oscilloscope is a displacement-time graph of a wave"@en ;
  dcterms:modified "2026-06-09T00:46:37.575267Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5047-2
  a curric:KeyLearningPoint ;
  rdfs:label """Connected to a microphone, an oscilloscope shows a displacement-time graph of a
  sound wave"""@en ;
  dcterms:modified "2026-06-09T00:46:37.575272Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5047-3
  a curric:KeyLearningPoint ;
  rdfs:label """The distance between two wave crests on an oscilloscope’s graph is equal to the
  period of the wave"""@en ;
  dcterms:modified "2026-06-09T00:46:37.575276Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5047-4
  a curric:KeyLearningPoint ;
  rdfs:label """The time period is measured most accurately by measuring the time for, say, 10 waves
  and dividing time by 10"""@en ;
  dcterms:modified "2026-06-09T00:46:37.575280Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5047-5
  a curric:KeyLearningPoint ;
  rdfs:label "The bigger the amplitude of a sound wave, the louder the sound"@en ;
  dcterms:modified "2026-06-09T00:46:37.575284Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9108-1
  a curric:KeyLearningPoint ;
  rdfs:label "A velocity-time graph shows how velocity changes with time."@en ;
  dcterms:modified "2026-06-09T00:46:37.575760Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9108-2
  a curric:KeyLearningPoint ;
  rdfs:label "Acceleration is equal to the gradient of a velocity-time graph."@en ;
  dcterms:modified "2026-06-09T00:46:37.575765Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9108-3
  a curric:KeyLearningPoint ;
  rdfs:label """A falling line shows decreasing velocity called deceleration, which is a negative
  acceleration."""@en ;
  dcterms:modified "2026-06-09T00:46:37.575769Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4731-1
  a curric:KeyLearningPoint ;
  rdfs:label "A dynamics trolley has a steady acceleration down a steep ramp."@en ;
  dcterms:modified "2026-06-09T00:46:37.575773Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4731-2
  a curric:KeyLearningPoint ;
  rdfs:label """Acceleration = change of velocity ÷ time and change in velocity = final velocity –
  initial velocity"""@en ;
  dcterms:modified "2026-06-09T00:46:37.575777Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4731-3
  a curric:KeyLearningPoint ;
  rdfs:label """Light gates can improve accuracy of measurement of instantaneous velocity and
  reduces random errors."""@en ;
  dcterms:modified "2026-06-09T00:46:37.575782Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4731-4
  a curric:KeyLearningPoint ;
  rdfs:label "For a fair test, total mass of the system must be kept constant."@en ;
  dcterms:modified "2026-06-09T00:46:37.575786Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4731-5
  a curric:KeyLearningPoint ;
  rdfs:label "A compensated ramp can counteract the effect of friction."@en ;
  dcterms:modified "2026-06-09T00:46:37.575790Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9153-1
  a curric:KeyLearningPoint ;
  rdfs:label "Electric charge, Q, is measured in coulombs (C)."@en ;
  dcterms:modified "2026-06-09T00:46:37.576000Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9153-2
  a curric:KeyLearningPoint ;
  rdfs:label """Electric current is a measure of the rate of flow of electric charge, calculated
  using: I = Q ÷ t."""@en ;
  dcterms:modified "2026-06-09T00:46:37.576005Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9153-3
  a curric:KeyLearningPoint ;
  rdfs:label """Potential difference is a measure of the energy transferred by each coulomb of
  charge, calculated using: V = E ÷ Q."""@en ;
  dcterms:modified "2026-06-09T00:46:37.576009Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9153-4
  a curric:KeyLearningPoint ;
  rdfs:label """Combining I = Q ÷ t and V = E ÷ Q gives the equation: E ÷ t = I × V. This is
  equivalent to P = I × V."""@en ;
  dcterms:modified "2026-06-09T00:46:37.576013Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9153-5
  a curric:KeyLearningPoint ;
  rdfs:label """Unknown variables in the power equation can often be calculated using: I = V
  ÷ R."""@en ;
  dcterms:modified "2026-06-09T00:46:37.576018Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9112-1
  a curric:KeyLearningPoint ;
  rdfs:label """Current can be calculated using the equation: current = p.d. ÷ resistance (I = V ÷
  R)."""@en ;
  dcterms:modified "2026-06-09T00:46:37.576022Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9112-2
  a curric:KeyLearningPoint ;
  rdfs:label """The rules of current and p.d. for a parallel circuit can be applied to find some
  missing values of current and p.d."""@en ;
  dcterms:modified "2026-06-09T00:46:37.576026Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9112-3
  a curric:KeyLearningPoint ;
  rdfs:label """The equation I = V ÷ R can be rearranged so that either p.d. or R is the subject of
  the equation."""@en ;
  dcterms:modified "2026-06-09T00:46:37.576030Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9112-4
  a curric:KeyLearningPoint ;
  rdfs:label """If any two values in the equation I = V ÷ R are known, the third can be
  calculated."""@en ;
  dcterms:modified "2026-06-09T00:46:37.576034Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9112-5
  a curric:KeyLearningPoint ;
  rdfs:label """If only one value in I = V ÷ R is shown for a component, circuit rules need to be
  applied to the rest of the circuit."""@en ;
  dcterms:modified "2026-06-09T00:46:37.576038Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4908-1
  a curric:KeyLearningPoint ;
  rdfs:label """Doubling the stiffness of a spring doubles the energy it has because it is
  stretched."""@en ;
  dcterms:modified "2026-06-09T00:46:37.576299Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4908-2
  a curric:KeyLearningPoint ;
  rdfs:label "The spring constant is measured in newtons per metre (N/m)."@en ;
  dcterms:modified "2026-06-09T00:46:37.576303Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4908-3
  a curric:KeyLearningPoint ;
  rdfs:label """Doubling the extension of a spring increases the energy it has because, it is
  stretched, by four times."""@en ;
  dcterms:modified "2026-06-09T00:46:37.576307Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4908-4
  a curric:KeyLearningPoint ;
  rdfs:label """The energy a spring has because it is stretched equals 1/2 × spring constant ×
  (extension)²."""@en ;
  dcterms:modified "2026-06-09T00:46:37.576311Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5097-1
  a curric:KeyLearningPoint ;
  rdfs:label """Power is the amount of energy transferred per second and is measured in
  watts (W)."""@en ;
  dcterms:modified "2026-06-09T00:46:37.576316Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5097-2
  a curric:KeyLearningPoint ;
  rdfs:label """Power can be calculated using the equation: power = current × potential difference
  (P = I V)."""@en ;
  dcterms:modified "2026-06-09T00:46:37.576320Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5097-3
  a curric:KeyLearningPoint ;
  rdfs:label """At a constant p.d., a larger electric current transfers energy more quickly than a
  smaller current."""@en ;
  dcterms:modified "2026-06-09T00:46:37.576324Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5097-4
  a curric:KeyLearningPoint ;
  rdfs:label """Domestic appliances plugged into the mains supply in the UK have a p.d. of 230 V
  across them."""@en ;
  dcterms:modified "2026-06-09T00:46:37.576328Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5097-5
  a curric:KeyLearningPoint ;
  rdfs:label """The fuse with the smallest rating for the required current (calculated using the
  equation: P = I² R) should be used."""@en ;
  dcterms:modified "2026-06-09T00:46:37.576332Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5050-1
  a curric:KeyLearningPoint ;
  rdfs:label "The speed of wave can be caluated using wave speed = frequency × wavelength."@en ;
  dcterms:modified "2026-06-09T00:46:37.576917Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5050-2
  a curric:KeyLearningPoint ;
  rdfs:label "The speed of a wave can be caluated using wave speed = distance ÷ time."@en ;
  dcterms:modified "2026-06-09T00:46:37.576921Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5050-3
  a curric:KeyLearningPoint ;
  rdfs:label """The choice of equation to use to caluate wave speed depends on the information
  provided in the question."""@en ;
  dcterms:modified "2026-06-09T00:46:37.576925Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5050-4
  a curric:KeyLearningPoint ;
  rdfs:label "Prefixes can be used with units to show very large or very small values."@en ;
  dcterms:modified "2026-06-09T00:46:37.576929Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5050-5
  a curric:KeyLearningPoint ;
  rdfs:label """The frequency of a wave does not change as it crosses a boundary from one wave
  medium into another."""@en ;
  dcterms:modified "2026-06-09T00:46:37.576934Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4918-1
  a curric:KeyLearningPoint ;
  rdfs:label """Stopping distance is the distance travelled both as a drive reacts and then for the
  brakes to bring a vehicle to a stop"""@en ;
  dcterms:modified "2026-06-09T00:46:37.576976Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4918-2
  a curric:KeyLearningPoint ;
  rdfs:label """Reaction time of a drive can be affected by tiredness, drugs, alcohol or
  distractions"""@en ;
  dcterms:modified "2026-06-09T00:46:37.576980Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4918-3
  a curric:KeyLearningPoint ;
  rdfs:label """Braking distance can be affected by adverse road and weather conditions and the
  condition of the vehicle"""@en ;
  dcterms:modified "2026-06-09T00:46:37.576984Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4918-4
  a curric:KeyLearningPoint ;
  rdfs:label "When braking, work is done on the brakes that heats them up"@en ;
  dcterms:modified "2026-06-09T00:46:37.576991Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4918-5
  a curric:KeyLearningPoint ;
  rdfs:label """If brakes overheat they can stop working effectively and lead to a loss of
  control"""@en ;
  dcterms:modified "2026-06-09T00:46:37.577009Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5046-1
  a curric:KeyLearningPoint ;
  rdfs:label """In a longitudinal wave, the oscillations / vibrations are in the same direction in
  which the wave travels."""@en ;
  dcterms:modified "2026-06-09T00:46:37.577564Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5046-2
  a curric:KeyLearningPoint ;
  rdfs:label """Displacement is the distance one part of a wave is moved away from its rest
  position."""@en ;
  dcterms:modified "2026-06-09T00:46:37.577568Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5046-3
  a curric:KeyLearningPoint ;
  rdfs:label """In a longitudinal wave, forwards displacement is positive and backwards displacement
  is negative."""@en ;
  dcterms:modified "2026-06-09T00:46:37.577572Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5046-4
  a curric:KeyLearningPoint ;
  rdfs:label """Wavelength of a longitudinal wave is the distance between one compression (or
  rarefaction) and the next."""@en ;
  dcterms:modified "2026-06-09T00:46:37.577576Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5087-1
  a curric:KeyLearningPoint ;
  rdfs:label """The different colours of light are electromagnetic waves with different frequencies
  and wavelengths."""@en ;
  dcterms:modified "2026-06-09T00:46:37.578317Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5087-2
  a curric:KeyLearningPoint ;
  rdfs:label """A triangular prism can produce a colour spectrum from white light, showing it is a
  mixture of all visible wavelengths."""@en ;
  dcterms:modified "2026-06-09T00:46:37.578324Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5087-3
  a curric:KeyLearningPoint ;
  rdfs:label """From red to violet in the spectrum, frequency increases and wavelength decreases.
  Higher frequencies refract further."""@en ;
  dcterms:modified "2026-06-09T00:46:37.578328Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5087-4
  a curric:KeyLearningPoint ;
  rdfs:label """Opaque objects transmit no incident light. Their colour depends on which wavelengths
  of incident light are reflected."""@en ;
  dcterms:modified "2026-06-09T00:46:37.578333Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5087-5
  a curric:KeyLearningPoint ;
  rdfs:label """Colour filters only transmit some wavelengths. The filter colour depends on the
  transmitted wavelengths."""@en ;
  dcterms:modified "2026-06-09T00:46:37.578337Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9095-1
  a curric:KeyLearningPoint ;
  rdfs:label """The particles in liquids and gases move very quickly and randomly in every
  direction; they are both fluids."""@en ;
  dcterms:modified "2026-06-09T00:46:37.578575Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9095-2
  a curric:KeyLearningPoint ;
  rdfs:label """Particles in liquids are very close together; the gaps between particles in gases
  are much larger than the particles."""@en ;
  dcterms:modified "2026-06-09T00:46:37.578579Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9095-3
  a curric:KeyLearningPoint ;
  rdfs:label "The pressure at any point in a fluid is the same size in every direction."@en ;
  dcterms:modified "2026-06-09T00:46:37.578583Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9095-4
  a curric:KeyLearningPoint ;
  rdfs:label "The particles in a fluid exert pressure on a surface by colliding with it."@en ;
  dcterms:modified "2026-06-09T00:46:37.578590Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9095-5
  a curric:KeyLearningPoint ;
  rdfs:label "Pressure is calculated using the equation: pressure = force ÷ surface area."@en ;
  dcterms:modified "2026-06-09T00:46:37.578595Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20342-1
  a curric:KeyLearningPoint ;
  rdfs:label "A dynamics trolley has a steady acceleration down a steep ramp."@en ;
  dcterms:modified "2026-06-09T00:46:37.578599Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20342-2
  a curric:KeyLearningPoint ;
  rdfs:label """Acceleration = change of velocity ÷ time and change in velocity = final velocity –
  initial velocity"""@en ;
  dcterms:modified "2026-06-09T00:46:37.578603Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20342-3
  a curric:KeyLearningPoint ;
  rdfs:label """Light gates can improve accuracy of measurement of instantaneous velocity and
  reduces random errors."""@en ;
  dcterms:modified "2026-06-09T00:46:37.578607Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20342-4
  a curric:KeyLearningPoint ;
  rdfs:label "For a fair test, total mass of the system must be kept constant."@en ;
  dcterms:modified "2026-06-09T00:46:37.578612Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20342-5
  a curric:KeyLearningPoint ;
  rdfs:label "A compensated ramp can counteract the effect of friction."@en ;
  dcterms:modified "2026-06-09T00:46:37.578616Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6584-1
  a curric:KeyLearningPoint ;
  rdfs:label """When rays of light are brought to a focus a real image forms. A real image can be
  projected onto a screen."""@en ;
  dcterms:modified "2026-06-09T00:46:37.578653Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6584-2
  a curric:KeyLearningPoint ;
  rdfs:label """Virtual images occur at points where rays appear to (but do not actually) originate
  from. They cannot form on a screen."""@en ;
  dcterms:modified "2026-06-09T00:46:37.578657Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6584-3
  a curric:KeyLearningPoint ;
  rdfs:label """The size and position of a virtual image is found by drawing virtual rays to find
  where rays appear to originate from."""@en ;
  dcterms:modified "2026-06-09T00:46:37.578661Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6584-4
  a curric:KeyLearningPoint ;
  rdfs:label """Upright virtual images are produced by concave lenses, and objects within a focal
  length of a convex lens."""@en ;
  dcterms:modified "2026-06-09T00:46:37.578673Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6584-5
  a curric:KeyLearningPoint ;
  rdfs:label """Convex lenses fix long sight by shortening the focus. Concave lenses fix short sight
  by lengthening the focus."""@en ;
  dcterms:modified "2026-06-09T00:46:37.578678Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5098-1
  a curric:KeyLearningPoint ;
  rdfs:label "Electric charge, Q, is measured in coulombs (C)."@en ;
  dcterms:modified "2026-06-09T00:46:37.578685Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5098-2
  a curric:KeyLearningPoint ;
  rdfs:label """Electric current is a measure of the rate of flow of electric charge, calculated
  using: I = Q ÷ t."""@en ;
  dcterms:modified "2026-06-09T00:46:37.578689Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5098-3
  a curric:KeyLearningPoint ;
  rdfs:label """Potential difference is a measure of the energy transferred by each coulomb of
  charge, calculated using: V = E ÷ Q."""@en ;
  dcterms:modified "2026-06-09T00:46:37.578694Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5098-4
  a curric:KeyLearningPoint ;
  rdfs:label """Combining I = Q ÷ t and V = E ÷ Q gives the equation: E ÷ t = I × V. This is
  equivalent to P = I × V."""@en ;
  dcterms:modified "2026-06-09T00:46:37.578698Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5098-5
  a curric:KeyLearningPoint ;
  rdfs:label """Unknown variables in the power equation can often be calculated using: I = V
  ÷ R."""@en ;
  dcterms:modified "2026-06-09T00:46:37.578702Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5088-1
  a curric:KeyLearningPoint ;
  rdfs:label "Convex lenses can produce an inverted image on a screen by refracting light."@en ;
  dcterms:modified "2026-06-09T00:46:37.579444Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5088-2
  a curric:KeyLearningPoint ;
  rdfs:label """Rays parallel to the principal axis are refracted to the principal focus, located at
  the focal length of a convex lens."""@en ;
  dcterms:modified "2026-06-09T00:46:37.579448Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5088-3
  a curric:KeyLearningPoint ;
  rdfs:label """The image distance and size (magnification) depend on the power of the lens and the
  object distance."""@en ;
  dcterms:modified "2026-06-09T00:46:37.579452Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5088-4
  a curric:KeyLearningPoint ;
  rdfs:label """As the object distance decreases, the image distance and size both increase, until
  the object reaches the focal length."""@en ;
  dcterms:modified "2026-06-09T00:46:37.579456Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5088-5
  a curric:KeyLearningPoint ;
  rdfs:label """If the object is too close to the lens, the rays leaving the lens are
  parallel/diverging, images can't form on a screen."""@en ;
  dcterms:modified "2026-06-09T00:46:37.579461Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9902-1
  a curric:KeyLearningPoint ;
  rdfs:label "A dynamics trolley has a steady acceleration down a steep ramp."@en ;
  dcterms:modified "2026-06-09T00:46:37.580084Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9902-2
  a curric:KeyLearningPoint ;
  rdfs:label """Acceleration = change of velocity ÷ time and change in velocity = final velocity –
  initial velocity"""@en ;
  dcterms:modified "2026-06-09T00:46:37.580088Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9902-3
  a curric:KeyLearningPoint ;
  rdfs:label """Light gates can improve accuracy of measurement of instantaneous velocity and
  reduces random errors."""@en ;
  dcterms:modified "2026-06-09T00:46:37.580092Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9902-4
  a curric:KeyLearningPoint ;
  rdfs:label "For a fair test, total mass of the system must be kept constant."@en ;
  dcterms:modified "2026-06-09T00:46:37.580097Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9902-5
  a curric:KeyLearningPoint ;
  rdfs:label "A compensated ramp can counteract the effect of friction."@en ;
  dcterms:modified "2026-06-09T00:46:37.580101Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6583-1
  a curric:KeyLearningPoint ;
  rdfs:label """In cameras and the human eye, the required image distance < the object distance so
  the image is diminished and inverted."""@en ;
  dcterms:modified "2026-06-09T00:46:37.580865Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6583-2
  a curric:KeyLearningPoint ;
  rdfs:label """In projectors, the required image distance > the object distance so the image is
  magnified and inverted."""@en ;
  dcterms:modified "2026-06-09T00:46:37.580869Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6583-3
  a curric:KeyLearningPoint ;
  rdfs:label """A ray incident on a convex lens parallel to the principal axis is refracted to pass
  through principal focus."""@en ;
  dcterms:modified "2026-06-09T00:46:37.580873Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6583-4
  a curric:KeyLearningPoint ;
  rdfs:label "A ray incident on the centre of a convex lens is not refracted."@en ;
  dcterms:modified "2026-06-09T00:46:37.580879Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6583-5
  a curric:KeyLearningPoint ;
  rdfs:label """A ray incident on a convex lens from the principal focus is refracted so it becomes
  parallel to the principal axis."""@en ;
  dcterms:modified "2026-06-09T00:46:37.580884Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9106-1
  a curric:KeyLearningPoint ;
  rdfs:label "The velocity of an object is equal to the gradient of a displacement-time graph."@en ;
  dcterms:modified "2026-06-09T00:46:37.581765Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9106-2
  a curric:KeyLearningPoint ;
  rdfs:label "A direction in which velocity and displacement are measured needs to be chosen."@en ;
  dcterms:modified "2026-06-09T00:46:37.581771Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9106-3
  a curric:KeyLearningPoint ;
  rdfs:label """A negative gradient on a displacement-time graph (sloping downwards) represents
  velocity in the opposite direction."""@en ;
  dcterms:modified "2026-06-09T00:46:37.581776Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9106-4
  a curric:KeyLearningPoint ;
  rdfs:label """A negative value for displacement represents a position ‘behind’ the starting
  position."""@en ;
  dcterms:modified "2026-06-09T00:46:37.581782Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9109-1
  a curric:KeyLearningPoint ;
  rdfs:label "A velocity-time graph shows how velocity changes with time."@en ;
  dcterms:modified "2026-06-09T00:46:37.582147Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9109-2
  a curric:KeyLearningPoint ;
  rdfs:label "Acceleration is equal to the gradient of a velocity-time graph."@en ;
  dcterms:modified "2026-06-09T00:46:37.582151Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9109-3
  a curric:KeyLearningPoint ;
  rdfs:label """A falling line shows decreasing velocity called deceleration, which is a negative
  acceleration."""@en ;
  dcterms:modified "2026-06-09T00:46:37.582155Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9109-4
  a curric:KeyLearningPoint ;
  rdfs:label "The gradient of the line gives the instantaneous acceleration."@en ;
  dcterms:modified "2026-06-09T00:46:37.582160Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9109-5
  a curric:KeyLearningPoint ;
  rdfs:label "The distance travelled is equal to the area under a velocity-time graph."@en ;
  dcterms:modified "2026-06-09T00:46:37.582164Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9147-1
  a curric:KeyLearningPoint ;
  rdfs:label "Specular reflection is reflection from a smooth surface in a single direction."@en ;
  dcterms:modified "2026-06-09T00:46:37.582746Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9147-2
  a curric:KeyLearningPoint ;
  rdfs:label "Diffuse reflection is reflection from a rough surface in multiple directions."@en ;
  dcterms:modified "2026-06-09T00:46:37.582750Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9147-3
  a curric:KeyLearningPoint ;
  rdfs:label """The angle of incidence equals the angle of reflection. Angles are measured from the
  normal."""@en ;
  dcterms:modified "2026-06-09T00:46:37.582757Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9147-4
  a curric:KeyLearningPoint ;
  rdfs:label "Light can be thought of as a wave (ripples) in electric and magnetic fields."@en ;
  dcterms:modified "2026-06-09T00:46:37.582761Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9147-5
  a curric:KeyLearningPoint ;
  rdfs:label "Like all waves, light can be represented using rays or wavefronts."@en ;
  dcterms:modified "2026-06-09T00:46:37.582765Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5034-1
  a curric:KeyLearningPoint ;
  rdfs:label "Two unlike electric charges attract each other."@en ;
  dcterms:modified "2026-06-09T00:46:37.583335Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5034-2
  a curric:KeyLearningPoint ;
  rdfs:label "Two like electric charges repel each other."@en ;
  dcterms:modified "2026-06-09T00:46:37.583341Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5034-3
  a curric:KeyLearningPoint ;
  rdfs:label "There is an electric field radiating out from an electric charge."@en ;
  dcterms:modified "2026-06-09T00:46:37.583345Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5034-4
  a curric:KeyLearningPoint ;
  rdfs:label "Electric field lines show the direction of force on a positive electric charge."@en ;
  dcterms:modified "2026-06-09T00:46:37.583349Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5034-5
  a curric:KeyLearningPoint ;
  rdfs:label """The closer electric field lines are to each other, the stronger the electric
  field."""@en ;
  dcterms:modified "2026-06-09T00:46:37.583354Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9897-1
  a curric:KeyLearningPoint ;
  rdfs:label "The velocity of an object is equal to the gradient of a displacement-time graph."@en ;
  dcterms:modified "2026-06-09T00:46:37.583358Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9897-2
  a curric:KeyLearningPoint ;
  rdfs:label "A direction in which velocity and displacement are measured needs to be chosen."@en ;
  dcterms:modified "2026-06-09T00:46:37.583362Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9897-3
  a curric:KeyLearningPoint ;
  rdfs:label """A negative gradient on a displacement-time graph (sloping downwards) represents
  velocity in the opposite direction."""@en ;
  dcterms:modified "2026-06-09T00:46:37.583366Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9897-4
  a curric:KeyLearningPoint ;
  rdfs:label """A negative value for displacement represents a position ‘behind’ the starting
  position."""@en ;
  dcterms:modified "2026-06-09T00:46:37.583370Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4914-1
  a curric:KeyLearningPoint ;
  rdfs:label "A free body diagram shows all of the forces acting on a single object"@en ;
  dcterms:modified "2026-06-09T00:46:37.583450Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4914-2
  a curric:KeyLearningPoint ;
  rdfs:label """The resultant of two forces can be determined by adding individual forces on a
  vector diagram"""@en ;
  dcterms:modified "2026-06-09T00:46:37.583455Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4914-3
  a curric:KeyLearningPoint ;
  rdfs:label """The resultant of two perpendicular forces is in a different direction from either of
  these forces"""@en ;
  dcterms:modified "2026-06-09T00:46:37.583459Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4914-4
  a curric:KeyLearningPoint ;
  rdfs:label """A single force can be resolved into two components acting at right angles to each
  other"""@en ;
  dcterms:modified "2026-06-09T00:46:37.583463Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4914-5
  a curric:KeyLearningPoint ;
  rdfs:label "The two component forces together have the same effect as the single force"@en ;
  dcterms:modified "2026-06-09T00:46:37.583467Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5038-1
  a curric:KeyLearningPoint ;
  rdfs:label """Current can be calculated using the equation: current = p.d. ÷ resistance (I = V ÷
  R)."""@en ;
  dcterms:modified "2026-06-09T00:46:37.584098Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5038-2
  a curric:KeyLearningPoint ;
  rdfs:label """The rules of current and p.d. for a series circuit can be applied to find some
  missing values of current and p.d."""@en ;
  dcterms:modified "2026-06-09T00:46:37.584102Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5038-3
  a curric:KeyLearningPoint ;
  rdfs:label """The equation I = V ÷ R can be rearranged so that either V or R is the subject of the
  equation."""@en ;
  dcterms:modified "2026-06-09T00:46:37.584106Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5038-4
  a curric:KeyLearningPoint ;
  rdfs:label """If any two values in the equation I = V ÷ R are known, the third can be
  calculated."""@en ;
  dcterms:modified "2026-06-09T00:46:37.584110Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5038-5
  a curric:KeyLearningPoint ;
  rdfs:label """If only one value in the equation I = V ÷ R is known, rules for current or p.d. need
  to be applied to find a second."""@en ;
  dcterms:modified "2026-06-09T00:46:37.584115Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5040-1
  a curric:KeyLearningPoint ;
  rdfs:label """Current can be calculated using the equation: current = p.d. ÷ resistance (I = V ÷
  R)."""@en ;
  dcterms:modified "2026-06-09T00:46:37.584119Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5040-2
  a curric:KeyLearningPoint ;
  rdfs:label """The rules of current and p.d. for a parallel circuit can be applied to find some
  missing values of current and p.d."""@en ;
  dcterms:modified "2026-06-09T00:46:37.584123Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5040-3
  a curric:KeyLearningPoint ;
  rdfs:label """The equation I = V ÷ R can be rearranged so that either p.d. or R is the subject of
  the equation."""@en ;
  dcterms:modified "2026-06-09T00:46:37.584127Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5040-4
  a curric:KeyLearningPoint ;
  rdfs:label """If any two values in the equation I = V ÷ R are known, the third can be
  calculated."""@en ;
  dcterms:modified "2026-06-09T00:46:37.584131Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5040-5
  a curric:KeyLearningPoint ;
  rdfs:label """If only one value in I = V ÷ R is shown for a component, circuit rules need to be
  applied to the rest of the circuit."""@en ;
  dcterms:modified "2026-06-09T00:46:37.584135Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4905-1
  a curric:KeyLearningPoint ;
  rdfs:label """A spring is elastically deformed if it returns to its original shape after the
  applied force is removed"""@en ;
  dcterms:modified "2026-06-09T00:46:37.584946Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4905-2
  a curric:KeyLearningPoint ;
  rdfs:label """A spring is inelastically deformed if it does not return to its original shape after
  the applied force is removed"""@en ;
  dcterms:modified "2026-06-09T00:46:37.584950Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4905-3
  a curric:KeyLearningPoint ;
  rdfs:label """Elastic deformation is proportional to the force applied to stretch or compress a
  spring"""@en ;
  dcterms:modified "2026-06-09T00:46:37.584956Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4905-4
  a curric:KeyLearningPoint ;
  rdfs:label """The spring constant (k) is the force needed to extend or compress an elastic object
  by one metre"""@en ;
  dcterms:modified "2026-06-09T00:46:37.584962Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4905-5
  a curric:KeyLearningPoint ;
  rdfs:label "Force on a spring = spring constant × extension"@en ;
  dcterms:modified "2026-06-09T00:46:37.584967Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9941-1
  a curric:KeyLearningPoint ;
  rdfs:label """A spring is elastically deformed if it returns to its original shape after the
  applied force is removed"""@en ;
  dcterms:modified "2026-06-09T00:46:37.587140Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9941-2
  a curric:KeyLearningPoint ;
  rdfs:label """A spring is inelastically deformed if it does not return to its original shape after
  the applied force is removed"""@en ;
  dcterms:modified "2026-06-09T00:46:37.587144Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9941-3
  a curric:KeyLearningPoint ;
  rdfs:label """Elastic deformation is proportional to the force applied to stretch or compress a
  spring"""@en ;
  dcterms:modified "2026-06-09T00:46:37.587150Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9941-4
  a curric:KeyLearningPoint ;
  rdfs:label """The spring constant (k) is the force needed to extend or compress an elastic object
  by one metre"""@en ;
  dcterms:modified "2026-06-09T00:46:37.587157Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9941-5
  a curric:KeyLearningPoint ;
  rdfs:label "Force on a spring = spring constant × extension"@en ;
  dcterms:modified "2026-06-09T00:46:37.587161Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9118-1
  a curric:KeyLearningPoint ;
  rdfs:label """Doubling the stiffness of a spring doubles the energy it has because it is
  stretched."""@en ;
  dcterms:modified "2026-06-09T00:46:37.589130Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9118-2
  a curric:KeyLearningPoint ;
  rdfs:label "The spring constant is measured in newtons per metre (N/m)."@en ;
  dcterms:modified "2026-06-09T00:46:37.589136Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9118-3
  a curric:KeyLearningPoint ;
  rdfs:label """Doubling the extension of a spring increases the energy it has, because it is
  stretched, by four times."""@en ;
  dcterms:modified "2026-06-09T00:46:37.589141Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9118-4
  a curric:KeyLearningPoint ;
  rdfs:label """The energy a spring has because it is stretched equals 1/2 × spring constant ×
  (extension)²."""@en ;
  dcterms:modified "2026-06-09T00:46:37.589147Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5091-1
  a curric:KeyLearningPoint ;
  rdfs:label """When rays of light are brought to a focus a real image forms. A real image can be
  projected onto a screen."""@en ;
  dcterms:modified "2026-06-09T00:46:37.592785Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5091-2
  a curric:KeyLearningPoint ;
  rdfs:label """Virtual images occur at points where rays appear to (but do not actually) originate
  from. They cannot form on a screen."""@en ;
  dcterms:modified "2026-06-09T00:46:37.592790Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5091-3
  a curric:KeyLearningPoint ;
  rdfs:label """The size and position of a virtual image is found by drawing virtual rays to find
  where rays appear to originate from."""@en ;
  dcterms:modified "2026-06-09T00:46:37.592794Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5091-4
  a curric:KeyLearningPoint ;
  rdfs:label """Upright virtual images are produced by diverging lenses, and objects within a focal
  length of a converging lens."""@en ;
  dcterms:modified "2026-06-09T00:46:37.592798Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5091-5
  a curric:KeyLearningPoint ;
  rdfs:label """Converging lenses fix long sight by shortening the focus. Diverging lenses fix short
  sight by lengthening the focus."""@en ;
  dcterms:modified "2026-06-09T00:46:37.592802Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4906-1
  a curric:KeyLearningPoint ;
  rdfs:label """A spring is elastically deformed if it returns to its original shape after the
  applied force is removed"""@en ;
  dcterms:modified "2026-06-09T00:46:37.592806Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4906-2
  a curric:KeyLearningPoint ;
  rdfs:label """A spring is inelastically deformed if it does not return to its original shape after
  the applied force is removed"""@en ;
  dcterms:modified "2026-06-09T00:46:37.592810Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4906-3
  a curric:KeyLearningPoint ;
  rdfs:label """Elastic deformation is proportional to the force applied to stretch or compress a
  spring"""@en ;
  dcterms:modified "2026-06-09T00:46:37.592814Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4906-4
  a curric:KeyLearningPoint ;
  rdfs:label """The spring constant (k) is the force needed to extend or compress an elastic object
  by one metre"""@en ;
  dcterms:modified "2026-06-09T00:46:37.592821Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4906-5
  a curric:KeyLearningPoint ;
  rdfs:label "Force on a spring = spring constant × extension"@en ;
  dcterms:modified "2026-06-09T00:46:37.592828Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9904-1
  a curric:KeyLearningPoint ;
  rdfs:label "A velocity-time graph shows how velocity changes with time."@en ;
  dcterms:modified "2026-06-09T00:46:37.593340Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9904-2
  a curric:KeyLearningPoint ;
  rdfs:label "Acceleration is equal to the gradient of a velocity-time graph."@en ;
  dcterms:modified "2026-06-09T00:46:37.593344Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9904-3
  a curric:KeyLearningPoint ;
  rdfs:label """A falling line shows decreasing velocity called deceleration, which is a negative
  acceleration."""@en ;
  dcterms:modified "2026-06-09T00:46:37.593350Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9904-4
  a curric:KeyLearningPoint ;
  rdfs:label "The gradient of the line gives the instantaneous acceleration."@en ;
  dcterms:modified "2026-06-09T00:46:37.593354Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9904-5
  a curric:KeyLearningPoint ;
  rdfs:label "The distance travelled is equal to the area under a velocity-time graph."@en ;
  dcterms:modified "2026-06-09T00:46:37.593359Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9149-1
  a curric:KeyLearningPoint ;
  rdfs:label "Converging lenses can produce an inverted image on a screen by refracting light."@en ;
  dcterms:modified "2026-06-09T00:46:37.596062Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9149-2
  a curric:KeyLearningPoint ;
  rdfs:label """Rays parallel to the principal axis are refracted to the principal focus of a
  converging lens (at the focal length)."""@en ;
  dcterms:modified "2026-06-09T00:46:37.596066Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9149-3
  a curric:KeyLearningPoint ;
  rdfs:label """The image distance and size (magnification) depend on the power of the lens and the
  object distance."""@en ;
  dcterms:modified "2026-06-09T00:46:37.596071Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9149-4
  a curric:KeyLearningPoint ;
  rdfs:label """As the object distance decreases, the image distance and size both increase, until
  the object reaches the focal length."""@en ;
  dcterms:modified "2026-06-09T00:46:37.596075Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9149-5
  a curric:KeyLearningPoint ;
  rdfs:label """If the object is too close to the lens, the rays leaving the lens are
  parallel/diverging, images can't form on a screen."""@en ;
  dcterms:modified "2026-06-09T00:46:37.596080Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5080-1
  a curric:KeyLearningPoint ;
  rdfs:label """Rotating a conducting loop in a uniform magnetic field induces a potential across
  the ends of the loop."""@en ;
  dcterms:modified "2026-06-09T00:46:37.597859Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5080-2
  a curric:KeyLearningPoint ;
  rdfs:label "An electrical generator can be made in the same way as an electric motor."@en ;
  dcterms:modified "2026-06-09T00:46:37.597864Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5080-3
  a curric:KeyLearningPoint ;
  rdfs:label "A DC generator (dynamo) generates a varying DC current."@en ;
  dcterms:modified "2026-06-09T00:46:37.597869Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5080-4
  a curric:KeyLearningPoint ;
  rdfs:label """The connections in an AC generator (an alternator) are different to those of a
  dynamo."""@en ;
  dcterms:modified "2026-06-09T00:46:37.597874Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5080-5
  a curric:KeyLearningPoint ;
  rdfs:label """An alternator makes an alternating current that repeatedly reverses direction as the
  coil spins round."""@en ;
  dcterms:modified "2026-06-09T00:46:37.597878Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6585-1
  a curric:KeyLearningPoint ;
  rdfs:label "In a fair test, only the (independent) variable being investigated is changed"@en ;
  dcterms:modified "2026-06-09T00:46:37.599660Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6585-2
  a curric:KeyLearningPoint ;
  rdfs:label """The dependent variable is measured to investigate the effect of changing the
  independent variable"""@en ;
  dcterms:modified "2026-06-09T00:46:37.599664Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6585-3
  a curric:KeyLearningPoint ;
  rdfs:label """Control variables are other factors that could be changed, but are kept the same in
  order not to affect the results"""@en ;
  dcterms:modified "2026-06-09T00:46:37.599669Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6585-4
  a curric:KeyLearningPoint ;
  rdfs:label """The greater the intensity of black ink, the more easily a surface absorbs
  infrared"""@en ;
  dcterms:modified "2026-06-09T00:46:37.599673Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28181-1
  a curric:KeyLearningPoint ;
  rdfs:label """Telescopes extended what was visible after their invention in the seventeenth
  century."""@en ;
  dcterms:modified "2026-06-09T00:46:37.600117Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28181-2
  a curric:KeyLearningPoint ;
  rdfs:label """Images detected by telescopes in space are not distorted by effects of the Earth’s
  atmosphere."""@en ;
  dcterms:modified "2026-06-09T00:46:37.600121Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28181-3
  a curric:KeyLearningPoint ;
  rdfs:label """A galaxy is a group of hundreds of billions of stars, and there are many galaxies
  spread across the universe."""@en ;
  dcterms:modified "2026-06-09T00:46:37.600125Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28181-4
  a curric:KeyLearningPoint ;
  rdfs:label """A visible spectrum of light emitted from stars or galaxies shows dark lines of
  frequencies of light."""@en ;
  dcterms:modified "2026-06-09T00:46:37.600130Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28181-5
  a curric:KeyLearningPoint ;
  rdfs:label """Red shift is the movement of hydrogen lines towards the red end of the visible
  spectrum."""@en ;
  dcterms:modified "2026-06-09T00:46:37.600134Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8169-1
  a curric:KeyLearningPoint ;
  rdfs:label "A free body diagram shows all of the forces acting on a single object."@en ;
  dcterms:modified "2026-06-09T00:46:37.603914Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8169-2
  a curric:KeyLearningPoint ;
  rdfs:label """The resultant of two forces can be determined by adding individual forces on a
  vector diagram."""@en ;
  dcterms:modified "2026-06-09T00:46:37.603918Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8169-3
  a curric:KeyLearningPoint ;
  rdfs:label """The resultant of two perpendicular forces is in a different direction from either of
  these forces."""@en ;
  dcterms:modified "2026-06-09T00:46:37.603922Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6617-1
  a curric:KeyLearningPoint ;
  rdfs:label """When rays of light are brought to a focus a real image forms. A real image can be
  projected onto a screen."""@en ;
  dcterms:modified "2026-06-09T00:46:37.609283Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6617-2
  a curric:KeyLearningPoint ;
  rdfs:label """Virtual images occur at points where rays appear to (but do not actually) originate
  from. They cannot form on a screen."""@en ;
  dcterms:modified "2026-06-09T00:46:37.609287Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6617-3
  a curric:KeyLearningPoint ;
  rdfs:label """The size and position of a virtual image is found by drawing virtual rays to find
  where rays appear to originate from."""@en ;
  dcterms:modified "2026-06-09T00:46:37.609291Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6617-4
  a curric:KeyLearningPoint ;
  rdfs:label """Upright virtual images are produced by concave lenses, and objects within a focal
  length of a convex lens."""@en ;
  dcterms:modified "2026-06-09T00:46:37.609296Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6617-5
  a curric:KeyLearningPoint ;
  rdfs:label """Convex lenses fix long sight by shortening the focus. Concave lenses fix short sight
  by lengthening the focus."""@en ;
  dcterms:modified "2026-06-09T00:46:37.609300Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6609-1
  a curric:KeyLearningPoint ;
  rdfs:label "All magnets have a north–seeking pole and a south–seeking pole."@en ;
  dcterms:modified "2026-06-09T00:46:37.610018Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6609-2
  a curric:KeyLearningPoint ;
  rdfs:label """Unlike magnetic poles attract each other, and like magnetic poles repel each
  other."""@en ;
  dcterms:modified "2026-06-09T00:46:37.610023Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6609-3
  a curric:KeyLearningPoint ;
  rdfs:label """Just three metal elements (iron, cobalt and nickel) are magnetic; other metals and
  non–metals are not magnetic."""@en ;
  dcterms:modified "2026-06-09T00:46:37.610027Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6609-4
  a curric:KeyLearningPoint ;
  rdfs:label "The needle of a plotting compass lines up with the magnetic field of a magnet."@en ;
  dcterms:modified "2026-06-09T00:46:37.610031Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6609-5
  a curric:KeyLearningPoint ;
  rdfs:label """Arrows on magnetic field lines show the direction in which the north–seeking pole of
  another magnet would be forced."""@en ;
  dcterms:modified "2026-06-09T00:46:37.610035Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4732-1
  a curric:KeyLearningPoint ;
  rdfs:label "Acceleration is equal to the gradient of a velocity-time graph."@en ;
  dcterms:modified "2026-06-09T00:46:37.610090Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4732-2
  a curric:KeyLearningPoint ;
  rdfs:label """A falling line shows decreasing velocity called deceleration, which is a negative
  acceleration."""@en ;
  dcterms:modified "2026-06-09T00:46:37.610097Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4732-3
  a curric:KeyLearningPoint ;
  rdfs:label """Instantaneous speed at a point on a displacement-time graph equals the gradient of a
  tangent at that point ."""@en ;
  dcterms:modified "2026-06-09T00:46:37.610101Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4732-4
  a curric:KeyLearningPoint ;
  rdfs:label "The distance travelled is equal to the area under a velocity-time graph."@en ;
  dcterms:modified "2026-06-09T00:46:37.610106Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4732-5
  a curric:KeyLearningPoint ;
  rdfs:label "Displacement is equal to the net positive area under a velocity-time graph."@en ;
  dcterms:modified "2026-06-09T00:46:37.610110Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5089-1
  a curric:KeyLearningPoint ;
  rdfs:label "Convex lenses can produce an inverted image on a screen by refracting light."@en ;
  dcterms:modified "2026-06-09T00:46:37.610573Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5089-2
  a curric:KeyLearningPoint ;
  rdfs:label """Rays parallel to the principal axis are refracted to the principal focus, located at
  the focal length of a convex lens."""@en ;
  dcterms:modified "2026-06-09T00:46:37.610577Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5089-3
  a curric:KeyLearningPoint ;
  rdfs:label """The image distance and size (magnification) depend on the power of the lens and the
  object distance."""@en ;
  dcterms:modified "2026-06-09T00:46:37.610583Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5089-4
  a curric:KeyLearningPoint ;
  rdfs:label """As the object distance decreases, the image distance and size both increase, until
  the object reaches the focal length."""@en ;
  dcterms:modified "2026-06-09T00:46:37.610588Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5089-5
  a curric:KeyLearningPoint ;
  rdfs:label """If the object is too close to the lens, the rays leaving the lens are
  parallel/diverging, images can't form on a screen."""@en ;
  dcterms:modified "2026-06-09T00:46:37.610592Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27963-1
  a curric:KeyLearningPoint ;
  rdfs:label """The fission of uranium-235 produces two daughter nuclei, two or more neutrons and
  gamma radiation."""@en ;
  dcterms:modified "2026-06-09T00:46:37.613633Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27963-2
  a curric:KeyLearningPoint ;
  rdfs:label """In a nuclear power station, control rods absorb neutrons to control the rate at
  which U-235 fissions."""@en ;
  dcterms:modified "2026-06-09T00:46:37.613637Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27963-3
  a curric:KeyLearningPoint ;
  rdfs:label """In a nuclear power station, a moderator absorbs the energy from gamma radiation and
  heats up."""@en ;
  dcterms:modified "2026-06-09T00:46:37.613644Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27963-4
  a curric:KeyLearningPoint ;
  rdfs:label "Heating by the moderator, via a coolant, boils pure water turning it to steam."@en ;
  dcterms:modified "2026-06-09T00:46:37.613648Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27963-5
  a curric:KeyLearningPoint ;
  rdfs:label """The expansion of pure water turning to steam creates a driving force that spins a
  turbine."""@en ;
  dcterms:modified "2026-06-09T00:46:37.613652Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28166-1
  a curric:KeyLearningPoint ;
  rdfs:label """A nuclear equation shows the particles in a nuclear decay, including the electric
  charge and mass number of each one."""@en ;
  dcterms:modified "2026-06-09T00:46:37.613656Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28166-2
  a curric:KeyLearningPoint ;
  rdfs:label """An alpha particle consists of two protons and two neutrons, has a mass of 4 and
  charge of +2."""@en ;
  dcterms:modified "2026-06-09T00:46:37.613661Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28166-3
  a curric:KeyLearningPoint ;
  rdfs:label "The protons and neutrons in an alpha particle are held together very strongly."@en ;
  dcterms:modified "2026-06-09T00:46:37.613665Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28166-4
  a curric:KeyLearningPoint ;
  rdfs:label "After an alpha or beta decay, a nucleus usually emits some gamma radiation."@en ;
  dcterms:modified "2026-06-09T00:46:37.613669Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28166-5
  a curric:KeyLearningPoint ;
  rdfs:label """A beta particle is an electron emitted at a high speed from a nucleus, its mass is
  close to zero and charge of –1."""@en ;
  dcterms:modified "2026-06-09T00:46:37.613673Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20346-1
  a curric:KeyLearningPoint ;
  rdfs:label "All EM waves can transfer energy, from a source to an absorber."@en ;
  dcterms:modified "2026-06-09T00:46:37.613678Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20346-2
  a curric:KeyLearningPoint ;
  rdfs:label """Only UV, X-ray and gamma frequencies of EM wave cause ionisation. The higher the
  frequency, the more ionising."""@en ;
  dcterms:modified "2026-06-09T00:46:37.613682Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20346-3
  a curric:KeyLearningPoint ;
  rdfs:label """Ionising radiation can damage cells, cause genes to mutate and increase the risk of
  cancer."""@en ;
  dcterms:modified "2026-06-09T00:46:37.613686Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20346-4
  a curric:KeyLearningPoint ;
  rdfs:label """UV is used in lighting and to disinfect water. It causes tanning/sunburn. It
  increases the risk of skin cancer."""@en ;
  dcterms:modified "2026-06-09T00:46:37.613690Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20346-5
  a curric:KeyLearningPoint ;
  rdfs:label """X- and gamma rays are used in medical imaging. Gamma rays are used to kill cancer
  cells and to sterilise food/equipment."""@en ;
  dcterms:modified "2026-06-09T00:46:37.613694Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27967-1
  a curric:KeyLearningPoint ;
  rdfs:label """The amount (or activity) of a radioactive isotope repeatedly falls by half in equal
  amounts of time."""@en ;
  dcterms:modified "2026-06-09T00:46:37.613769Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27967-2
  a curric:KeyLearningPoint ;
  rdfs:label """A radioactive half-life graph shows the amount (or activity) of a radioactive
  isotope plotted against time."""@en ;
  dcterms:modified "2026-06-09T00:46:37.613773Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27967-3
  a curric:KeyLearningPoint ;
  rdfs:label """In 2 half-lives the amount (or activity) of a radioactive isotope falls to ½ × ½ = ¼
  as much."""@en ;
  dcterms:modified "2026-06-09T00:46:37.613777Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27967-4
  a curric:KeyLearningPoint ;
  rdfs:label """In 3 half-lives the amount (or activity) of a radioactive isotope falls to ½ × ½ × ½
  = 1/8 as much, and so on."""@en ;
  dcterms:modified "2026-06-09T00:46:37.613782Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27967-5
  a curric:KeyLearningPoint ;
  rdfs:label """Radioactive isotopes with short half-lives decay quickly, emitting most radiation
  over a short period of time."""@en ;
  dcterms:modified "2026-06-09T00:46:37.613786Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9901-1
  a curric:KeyLearningPoint ;
  rdfs:label "A dynamics trolley has a steady acceleration down a steep ramp."@en ;
  dcterms:modified "2026-06-09T00:46:37.613790Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9901-2
  a curric:KeyLearningPoint ;
  rdfs:label """Acceleration = change of velocity / time and change in velocity = final velocity -
  initial velocity"""@en ;
  dcterms:modified "2026-06-09T00:46:37.613794Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9901-3
  a curric:KeyLearningPoint ;
  rdfs:label """Light gates can improve accuracy of measurement of instantaneous velocity and
  reduces random errors."""@en ;
  dcterms:modified "2026-06-09T00:46:37.613798Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9901-4
  a curric:KeyLearningPoint ;
  rdfs:label """Using video recording will allow for accurate measurement of small time
  intervals."""@en ;
  dcterms:modified "2026-06-09T00:46:37.613805Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4730-1
  a curric:KeyLearningPoint ;
  rdfs:label "Acceleration is equal to the amount that velocity changes in one second."@en ;
  dcterms:modified "2026-06-09T00:46:37.615153Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4730-2
  a curric:KeyLearningPoint ;
  rdfs:label "Acceleration is the rate of change of velocity."@en ;
  dcterms:modified "2026-06-09T00:46:37.615159Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4730-3
  a curric:KeyLearningPoint ;
  rdfs:label "Average acceleration = change of velocity / time (a = Δv/t)"@en ;
  dcterms:modified "2026-06-09T00:46:37.615164Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4730-4
  a curric:KeyLearningPoint ;
  rdfs:label "An object that is slowing down is decelerating."@en ;
  dcterms:modified "2026-06-09T00:46:37.615168Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4730-5
  a curric:KeyLearningPoint ;
  rdfs:label "An object that is decelerating has a negative acceleration."@en ;
  dcterms:modified "2026-06-09T00:46:37.615172Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4907-1
  a curric:KeyLearningPoint ;
  rdfs:label """Doubling the stiffness of a spring doubles the energy it has because it is
  stretched."""@en ;
  dcterms:modified "2026-06-09T00:46:37.615371Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4907-2
  a curric:KeyLearningPoint ;
  rdfs:label "The spring constant is measured in newtons per metre (N/m)."@en ;
  dcterms:modified "2026-06-09T00:46:37.615375Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4907-3
  a curric:KeyLearningPoint ;
  rdfs:label """Doubling the extension of a spring increases the energy it has because it is
  stretched by four times."""@en ;
  dcterms:modified "2026-06-09T00:46:37.615380Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4907-4
  a curric:KeyLearningPoint ;
  rdfs:label """The energy a spring has because it is stretched equals 1/2 × spring constant ×
  (extension)²."""@en ;
  dcterms:modified "2026-06-09T00:46:37.615384Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9944-1
  a curric:KeyLearningPoint ;
  rdfs:label "Energy cannot be created or destroyed."@en ;
  dcterms:modified "2026-06-09T00:46:37.617867Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9944-2
  a curric:KeyLearningPoint ;
  rdfs:label "In an ideal situation, no energy is dissipated."@en ;
  dcterms:modified "2026-06-09T00:46:37.617872Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9944-3
  a curric:KeyLearningPoint ;
  rdfs:label """As an object changes height, change in gravitational potential energy = change in
  kinetic energy."""@en ;
  dcterms:modified "2026-06-09T00:46:37.617876Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5036-1
  a curric:KeyLearningPoint ;
  rdfs:label "The current in a series circuit is the same everywhere."@en ;
  dcterms:modified "2026-06-09T00:46:37.633167Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5036-2
  a curric:KeyLearningPoint ;
  rdfs:label """The p.d. across each component in a series electric circuit adds up to the p.d. of
  the battery."""@en ;
  dcterms:modified "2026-06-09T00:46:37.633171Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5036-3
  a curric:KeyLearningPoint ;
  rdfs:label """The greater the resistance in a series circuit, the lower the current (current is
  inversely proportional to resistance)."""@en ;
  dcterms:modified "2026-06-09T00:46:37.633178Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5036-4
  a curric:KeyLearningPoint ;
  rdfs:label """The greater the battery p.d. in series circuit, the larger the current (current is
  directly proportional to p.d.)."""@en ;
  dcterms:modified "2026-06-09T00:46:37.633182Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5036-5
  a curric:KeyLearningPoint ;
  rdfs:label """Current, p.d. or resistance can be calculated with the equation: current =
  p.d./resistance."""@en ;
  dcterms:modified "2026-06-09T00:46:37.633187Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5051-1
  a curric:KeyLearningPoint ;
  rdfs:label "The speed of sound in air is about 340 m/s."@en ;
  dcterms:modified "2026-06-09T00:46:37.633191Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5051-2
  a curric:KeyLearningPoint ;
  rdfs:label """The speed of sound in air can be measured using an echo method and using speed =
  distance/time."""@en ;
  dcterms:modified "2026-06-09T00:46:37.633195Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5051-3
  a curric:KeyLearningPoint ;
  rdfs:label """The speed of sound in a metal rod can be found by measuring the length and the
  frequency produced when struck."""@en ;
  dcterms:modified "2026-06-09T00:46:37.633201Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5051-4
  a curric:KeyLearningPoint ;
  rdfs:label "A result is accurate if it is close to the true value."@en ;
  dcterms:modified "2026-06-09T00:46:37.633206Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5051-5
  a curric:KeyLearningPoint ;
  rdfs:label """A result can be considered accurate if it is repeatable, reproducible and if
  systematic errors have been checked for."""@en ;
  dcterms:modified "2026-06-09T00:46:37.633210Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6610-1
  a curric:KeyLearningPoint ;
  rdfs:label """When there is an electric current in a wire, there is a magnetic field around the
  wire."""@en ;
  dcterms:modified "2026-06-09T00:46:37.633214Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6610-2
  a curric:KeyLearningPoint ;
  rdfs:label """An electromagnet is a magnet that can be turned on with an electric current, and
  turned off."""@en ;
  dcterms:modified "2026-06-09T00:46:37.633218Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6610-3
  a curric:KeyLearningPoint ;
  rdfs:label """The magnetic field of an electromagnet is similar to the field around a bar
  magnet."""@en ;
  dcterms:modified "2026-06-09T00:46:37.633222Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6610-4
  a curric:KeyLearningPoint ;
  rdfs:label """A soft iron core in an electromagnet becomes magnetised and adds to the strength of
  field when the electromagnet is on."""@en ;
  dcterms:modified "2026-06-09T00:46:37.633227Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6610-5
  a curric:KeyLearningPoint ;
  rdfs:label """When there is an electric current in a coil of wire, the magnetic field around each
  loop adds to make a stronger field."""@en ;
  dcterms:modified "2026-06-09T00:46:37.633231Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27966-1
  a curric:KeyLearningPoint ;
  rdfs:label """The amount (or activity) of a radioactive isotope repeatedly falls by half in equal
  amounts of time."""@en ;
  dcterms:modified "2026-06-09T00:46:37.636078Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27966-2
  a curric:KeyLearningPoint ;
  rdfs:label """A radioactive half-life graph shows the amount (or activity) of a radioactive
  isotope plotted against time."""@en ;
  dcterms:modified "2026-06-09T00:46:37.636083Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27966-3
  a curric:KeyLearningPoint ;
  rdfs:label """In 2 half-lives the amount (or activity) of a radioactive isotope falls to ½ × ½ = ¼
  as much."""@en ;
  dcterms:modified "2026-06-09T00:46:37.636087Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27966-4
  a curric:KeyLearningPoint ;
  rdfs:label """In 3 half-lives the amount (or activity) of a radioactive isotope falls to ½ × ½ × ½
  = 1/8 as much, and so on."""@en ;
  dcterms:modified "2026-06-09T00:46:37.636091Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27966-5
  a curric:KeyLearningPoint ;
  rdfs:label """Radioactive isotopes with short half-lives decay quickly, emitting most radiation
  over a short period of time."""@en ;
  dcterms:modified "2026-06-09T00:46:37.636095Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4936-1
  a curric:KeyLearningPoint ;
  rdfs:label """The Sun is a medium sized star that emits radiation as a result of nuclear fusion
  reactions in its core."""@en ;
  dcterms:modified "2026-06-09T00:46:37.636099Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4936-2
  a curric:KeyLearningPoint ;
  rdfs:label """A star is formed from a cloud (nebula) of dust and gas pulled together by
  gravitational attraction."""@en ;
  dcterms:modified "2026-06-09T00:46:37.636104Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4936-3
  a curric:KeyLearningPoint ;
  rdfs:label """Dust in a nebula is any sort of fine particle, such as specks of rock, and most of
  the gas in space is hydrogen."""@en ;
  dcterms:modified "2026-06-09T00:46:37.636108Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4936-4
  a curric:KeyLearningPoint ;
  rdfs:label """As a star forms, dust and gas accelerate towards its centre over a very long time,
  creating very high temperatures."""@en ;
  dcterms:modified "2026-06-09T00:46:37.636112Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4936-5
  a curric:KeyLearningPoint ;
  rdfs:label """A star forms when hydrogen nuclei in a protostar fuse together converting mass into
  gamma radiation that causes heating."""@en ;
  dcterms:modified "2026-06-09T00:46:37.636116Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28014-1
  a curric:KeyLearningPoint ;
  rdfs:label """A potential difference that causes a current to flow in the primary coil magnetises
  the iron core."""@en ;
  dcterms:modified "2026-06-09T00:46:37.637325Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28014-2
  a curric:KeyLearningPoint ;
  rdfs:label """When the iron core is magnetised, it induces a potential difference across the
  secondary coil."""@en ;
  dcterms:modified "2026-06-09T00:46:37.637332Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28014-3
  a curric:KeyLearningPoint ;
  rdfs:label """An AC gives the changing magnetic field needed to induce a potential difference
  across the secondary coil."""@en ;
  dcterms:modified "2026-06-09T00:46:37.637336Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28014-4
  a curric:KeyLearningPoint ;
  rdfs:label """Transformers are almost 100% efficient so the power output is equal to the power
  input."""@en ;
  dcterms:modified "2026-06-09T00:46:37.637340Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28014-5
  a curric:KeyLearningPoint ;
  rdfs:label """The ratio of the number of turns on the coils is equal to the ratio of the potential
  differences across them."""@en ;
  dcterms:modified "2026-06-09T00:46:37.637344Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27962-1
  a curric:KeyLearningPoint ;
  rdfs:label "The products and by–products of nuclear fission are often radioactive."@en ;
  dcterms:modified "2026-06-09T00:46:37.637360Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27962-2
  a curric:KeyLearningPoint ;
  rdfs:label """The products and by–products of nuclear fission need to be safely stored for very
  long periods of time."""@en ;
  dcterms:modified "2026-06-09T00:46:37.637364Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27962-3
  a curric:KeyLearningPoint ;
  rdfs:label """Nuclear reactors do not emit carbon dioxide and risks of catastrophic failure are
  very small."""@en ;
  dcterms:modified "2026-06-09T00:46:37.637368Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27962-4
  a curric:KeyLearningPoint ;
  rdfs:label """Nuclear fusion requires extremely high temperatures such as those found in the
  centre of stars."""@en ;
  dcterms:modified "2026-06-09T00:46:37.637373Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27962-5
  a curric:KeyLearningPoint ;
  rdfs:label """Nuclear fusion power stations would create very little radioactive waste, but have
  not yet been developed."""@en ;
  dcterms:modified "2026-06-09T00:46:37.637377Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5094-1
  a curric:KeyLearningPoint ;
  rdfs:label """Mains electricity has a p.d. of 230 V between a live wire connection (230 V) and a
  neutral wire connection (0 V)."""@en ;
  dcterms:modified "2026-06-09T00:46:37.637687Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5094-2
  a curric:KeyLearningPoint ;
  rdfs:label "Mains electricity has alternating current at a frequency of 50 Hz."@en ;
  dcterms:modified "2026-06-09T00:46:37.637691Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5094-3
  a curric:KeyLearningPoint ;
  rdfs:label """Electric current passing through a person’s body can damage living tissue and/or
  stop their heart pumping blood."""@en ;
  dcterms:modified "2026-06-09T00:46:37.637695Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5094-4
  a curric:KeyLearningPoint ;
  rdfs:label """The size of current from a shock depends on the p.d. across the person and the
  resistance of their skin (I = V ÷ R)."""@en ;
  dcterms:modified "2026-06-09T00:46:37.637699Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5094-5
  a curric:KeyLearningPoint ;
  rdfs:label """Wet skin has a much lower resistance than dry skin, and a smaller p.d. can cause a
  bigger current from a shock."""@en ;
  dcterms:modified "2026-06-09T00:46:37.637704Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9920-1
  a curric:KeyLearningPoint ;
  rdfs:label "Work done is the total amount of energy transferred."@en ;
  dcterms:modified "2026-06-09T00:46:37.640251Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9920-2
  a curric:KeyLearningPoint ;
  rdfs:label "Work done = force x distance (moved in the direction of the force)."@en ;
  dcterms:modified "2026-06-09T00:46:37.640255Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9920-3
  a curric:KeyLearningPoint ;
  rdfs:label "Work done is measured in Joule (J)."@en ;
  dcterms:modified "2026-06-09T00:46:37.640259Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9891-1
  a curric:KeyLearningPoint ;
  rdfs:label """A dynamics trolley speeds up (accelerates) along the whole length of a steep
  ramp."""@en ;
  dcterms:modified "2026-06-09T00:46:37.640265Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9891-2
  a curric:KeyLearningPoint ;
  rdfs:label "Instantaneous speed is the average speed over a very short time period."@en ;
  dcterms:modified "2026-06-09T00:46:37.640270Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9891-3
  a curric:KeyLearningPoint ;
  rdfs:label "Instantaneous speed is the average speed over a very short time period."@en ;
  dcterms:modified "2026-06-09T00:46:37.640274Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9891-4
  a curric:KeyLearningPoint ;
  rdfs:label "Repeated readings by different observers helps to check for systematic errors."@en ;
  dcterms:modified "2026-06-09T00:46:37.640278Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9138-1
  a curric:KeyLearningPoint ;
  rdfs:label """Acceleration can be measured accurately using light gates or roughly measured using
  a stopwatch and ruler."""@en ;
  dcterms:modified "2026-06-09T00:46:37.640282Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9138-2
  a curric:KeyLearningPoint ;
  rdfs:label """The acceleration of an object is proportional to the resultant force acting on the
  object."""@en ;
  dcterms:modified "2026-06-09T00:46:37.640286Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9138-3
  a curric:KeyLearningPoint ;
  rdfs:label """The acceleration of an object is inversely proportional to the mass of the
  object."""@en ;
  dcterms:modified "2026-06-09T00:46:37.640292Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9138-4
  a curric:KeyLearningPoint ;
  rdfs:label "Newton's Second Law states that F = m × a."@en ;
  dcterms:modified "2026-06-09T00:46:37.640296Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9898-1
  a curric:KeyLearningPoint ;
  rdfs:label "Acceleration is equal to the amount that velocity changes in one second."@en ;
  dcterms:modified "2026-06-09T00:46:37.640952Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9898-2
  a curric:KeyLearningPoint ;
  rdfs:label "Acceleration is the rate of change of velocity."@en ;
  dcterms:modified "2026-06-09T00:46:37.640956Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9898-3
  a curric:KeyLearningPoint ;
  rdfs:label "Average acceleration = change of velocity/time [a = (v-u)/t]"@en ;
  dcterms:modified "2026-06-09T00:46:37.640960Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9898-4
  a curric:KeyLearningPoint ;
  rdfs:label "An object that is slowing down is decelerating."@en ;
  dcterms:modified "2026-06-09T00:46:37.640964Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9898-5
  a curric:KeyLearningPoint ;
  rdfs:label "An object that is decelerating has a negative acceleration."@en ;
  dcterms:modified "2026-06-09T00:46:37.640968Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4937-1
  a curric:KeyLearningPoint ;
  rdfs:label "Radiation pressure from nuclear fusion pushes out from the centre of a star."@en ;
  dcterms:modified "2026-06-09T00:46:37.641988Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4937-2
  a curric:KeyLearningPoint ;
  rdfs:label "Gravitational force pulls in towards the centre of a star."@en ;
  dcterms:modified "2026-06-09T00:46:37.641992Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4937-3
  a curric:KeyLearningPoint ;
  rdfs:label """When a star is in balance, forces from radiation pressure are equal in size to
  gravitational forces."""@en ;
  dcterms:modified "2026-06-09T00:46:37.641998Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4937-4
  a curric:KeyLearningPoint ;
  rdfs:label """A main sequence star is a star in balance for millions of years, until it no can
  longer fuse hydrogen nuclei."""@en ;
  dcterms:modified "2026-06-09T00:46:37.642003Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4937-5
  a curric:KeyLearningPoint ;
  rdfs:label """After all available hydrogen has been fused, gravity contracts a star raising
  temperature until other nuclei can fuse."""@en ;
  dcterms:modified "2026-06-09T00:46:37.642007Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20341-1
  a curric:KeyLearningPoint ;
  rdfs:label "A dynamics trolley has a steady acceleration down a steep ramp."@en ;
  dcterms:modified "2026-06-09T00:46:37.642069Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20341-2
  a curric:KeyLearningPoint ;
  rdfs:label """Acceleration = change of velocity / time and change in velocity = final velocity -
  initial velocity"""@en ;
  dcterms:modified "2026-06-09T00:46:37.642073Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20341-3
  a curric:KeyLearningPoint ;
  rdfs:label """Light gates can improve accuracy of measurement of instantaneous velocity and
  reduces random errors."""@en ;
  dcterms:modified "2026-06-09T00:46:37.642080Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20341-4
  a curric:KeyLearningPoint ;
  rdfs:label """Using video recording will allow for accurate measurement of small time
  intervals."""@en ;
  dcterms:modified "2026-06-09T00:46:37.642084Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9942-1
  a curric:KeyLearningPoint ;
  rdfs:label "Energy cannot be created or destroyed."@en ;
  dcterms:modified "2026-06-09T00:46:37.818024Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9942-2
  a curric:KeyLearningPoint ;
  rdfs:label "In an ideal situation, no energy is dissipated."@en ;
  dcterms:modified "2026-06-09T00:46:37.818031Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9942-3
  a curric:KeyLearningPoint ;
  rdfs:label """As an object changes height, change in gravitational potential energy = change in
  kinetic energy."""@en ;
  dcterms:modified "2026-06-09T00:46:37.818039Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28013-1
  a curric:KeyLearningPoint ;
  rdfs:label """Energy transferred to a solid at its melting point allows its particles to move
  further apart."""@en ;
  dcterms:modified "2026-06-09T00:46:37.820094Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28013-2
  a curric:KeyLearningPoint ;
  rdfs:label """Energy transferred to a liquid at its boiling point allows its particles to move
  fast enough to get even further apart."""@en ;
  dcterms:modified "2026-06-09T00:46:37.820102Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28013-3
  a curric:KeyLearningPoint ;
  rdfs:label """The energy transferred to melt a solid at its melting point is proportional to the
  mass of the solid."""@en ;
  dcterms:modified "2026-06-09T00:46:37.820109Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28013-4
  a curric:KeyLearningPoint ;
  rdfs:label """The energy transferred to melt 1 kg of a solid at its melting point is proportional
  to the solid’s specific latent heat."""@en ;
  dcterms:modified "2026-06-09T00:46:37.820117Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28013-5
  a curric:KeyLearningPoint ;
  rdfs:label """The energy transferred to boil 1 kg of a liquid at its boiling point is proportional
  to it’s specific latent heat."""@en ;
  dcterms:modified "2026-06-09T00:46:37.820125Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4926-1
  a curric:KeyLearningPoint ;
  rdfs:label """Energy transferred to a solid at its melting point allows its particles to move
  further apart."""@en ;
  dcterms:modified "2026-06-09T00:46:37.820238Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4926-2
  a curric:KeyLearningPoint ;
  rdfs:label """Energy transferred to a liquid at its boiling point allows its particles to move
  fast enough to get even further apart."""@en ;
  dcterms:modified "2026-06-09T00:46:37.820246Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4926-3
  a curric:KeyLearningPoint ;
  rdfs:label """The energy transferred to melt a solid at its melting point is proportional to the
  mass of the solid."""@en ;
  dcterms:modified "2026-06-09T00:46:37.820254Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4926-4
  a curric:KeyLearningPoint ;
  rdfs:label """The energy transferred to melt 1 kg of a solid at its melting point is proportional
  to the solid’s specific latent heat."""@en ;
  dcterms:modified "2026-06-09T00:46:37.820262Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4926-5
  a curric:KeyLearningPoint ;
  rdfs:label """The energy transferred to boil 1 kg of a liquid at its boiling point is proportional
  to its specific latent heat."""@en ;
  dcterms:modified "2026-06-09T00:46:37.820270Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5096-1
  a curric:KeyLearningPoint ;
  rdfs:label """Power is transferred by electricity from power stations to consumers using the
  National Grid."""@en ;
  dcterms:modified "2026-06-09T00:46:37.822279Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5096-2
  a curric:KeyLearningPoint ;
  rdfs:label """Step-up transformers increase the transmission voltage from a power station to the
  transmission line."""@en ;
  dcterms:modified "2026-06-09T00:46:37.822286Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5096-3
  a curric:KeyLearningPoint ;
  rdfs:label """Step-down transformers decrease the transmission voltage from a transmission line to
  the consumer."""@en ;
  dcterms:modified "2026-06-09T00:46:37.822294Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5096-4
  a curric:KeyLearningPoint ;
  rdfs:label "Transmission lines dissipate some energy by heating (P = I²R)."@en ;
  dcterms:modified "2026-06-09T00:46:37.822301Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5096-5
  a curric:KeyLearningPoint ;
  rdfs:label """A very high transmission voltage reduces transmission current and the heating of
  transmission lines."""@en ;
  dcterms:modified "2026-06-09T00:46:37.822308Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28182-1
  a curric:KeyLearningPoint ;
  rdfs:label """Light from nearly all galaxies is redshifted, showing they're moving away, with
  distant galaxies receding faster."""@en ;
  dcterms:modified "2026-06-09T00:46:37.822346Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28182-2
  a curric:KeyLearningPoint ;
  rdfs:label """Evidence shows that galaxies were all in the same place about 14 billion years ago,
  showing their movement apart since."""@en ;
  dcterms:modified "2026-06-09T00:46:37.822353Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28182-3
  a curric:KeyLearningPoint ;
  rdfs:label """The Big Bang Theory suggests that the universe began from a very small region that
  was extremely hot and dense."""@en ;
  dcterms:modified "2026-06-09T00:46:37.822364Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28182-4
  a curric:KeyLearningPoint ;
  rdfs:label """A scientific theory is our best understanding based on all evidence and is subject
  to rigorous testing."""@en ;
  dcterms:modified "2026-06-09T00:46:37.822372Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28182-5
  a curric:KeyLearningPoint ;
  rdfs:label "We do not fully understand dark matter or dark energy."@en ;
  dcterms:modified "2026-06-09T00:46:37.822379Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4919-1
  a curric:KeyLearningPoint ;
  rdfs:label "Momentum = mass × velocity, p = mv"@en ;
  dcterms:modified "2026-06-09T00:46:37.822850Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4919-2
  a curric:KeyLearningPoint ;
  rdfs:label """In a closed system, the total momentum before an event equals the total momentum
  after the event."""@en ;
  dcterms:modified "2026-06-09T00:46:37.822861Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9168-1
  a curric:KeyLearningPoint ;
  rdfs:label "Average velocity = distance travelled ÷ time"@en ;
  dcterms:modified "2026-06-09T00:46:37.822869Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9168-2
  a curric:KeyLearningPoint ;
  rdfs:label "Average acceleration = change in velocity ÷ time"@en ;
  dcterms:modified "2026-06-09T00:46:37.822876Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9168-3
  a curric:KeyLearningPoint ;
  rdfs:label "Average velocity = (initial velocity + final velocity) ÷ 2"@en ;
  dcterms:modified "2026-06-09T00:46:37.822883Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9168-4
  a curric:KeyLearningPoint ;
  rdfs:label """Combining equations for average acceleration and average velocity leads to the
  equation v² – u² = 2 as"""@en ;
  dcterms:modified "2026-06-09T00:46:37.822891Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9168-5
  a curric:KeyLearningPoint ;
  rdfs:label """Different motion equations can be used to analyse motion based on information
  provided."""@en ;
  dcterms:modified "2026-06-09T00:46:37.822899Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6578-1
  a curric:KeyLearningPoint ;
  rdfs:label "The velocity of an object is its speed in a given direction."@en ;
  dcterms:modified "2026-06-09T00:46:37.823376Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6578-2
  a curric:KeyLearningPoint ;
  rdfs:label """The displacement of an object is the distance it travels in a particular
  direction."""@en ;
  dcterms:modified "2026-06-09T00:46:37.823384Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6578-3
  a curric:KeyLearningPoint ;
  rdfs:label "Displacement and velocity are both vector quantities."@en ;
  dcterms:modified "2026-06-09T00:46:37.823394Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6578-4
  a curric:KeyLearningPoint ;
  rdfs:label """Velocity has a positive value in one direction and negative value in the opposite
  direction."""@en ;
  dcterms:modified "2026-06-09T00:46:37.823403Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9111-1
  a curric:KeyLearningPoint ;
  rdfs:label """Current can be calculated using the equation: current = p.d. ÷ resistance (I = V ÷
  R)."""@en ;
  dcterms:modified "2026-06-09T00:46:37.824060Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9111-2
  a curric:KeyLearningPoint ;
  rdfs:label """The rules of current and p.d. for a series circuit can be applied to find some
  missing values of current and p.d."""@en ;
  dcterms:modified "2026-06-09T00:46:37.824068Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9111-3
  a curric:KeyLearningPoint ;
  rdfs:label """The equation I = V ÷ R can be rearranged so that either V or R is the subject of the
  equation."""@en ;
  dcterms:modified "2026-06-09T00:46:37.824079Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9111-4
  a curric:KeyLearningPoint ;
  rdfs:label """If any two values in the equation I = V ÷ R are known, the third can be
  calculated."""@en ;
  dcterms:modified "2026-06-09T00:46:37.824087Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9111-5
  a curric:KeyLearningPoint ;
  rdfs:label """If only one value in the equation I = V ÷ R is known, rules for current or p.d. need
  to be applied to find a second."""@en ;
  dcterms:modified "2026-06-09T00:46:37.824094Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5048-1
  a curric:KeyLearningPoint ;
  rdfs:label """To find standing wave frequencies, increase the frequency of the oscillator until a
  standing wave pattern is seen."""@en ;
  dcterms:modified "2026-06-09T00:46:37.824101Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5048-2
  a curric:KeyLearningPoint ;
  rdfs:label """The wavelength of the waves can be found from the length of the oscillating string
  and the standing wave pattern"""@en ;
  dcterms:modified "2026-06-09T00:46:37.824109Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5048-3
  a curric:KeyLearningPoint ;
  rdfs:label """The speed of waves on a string only depends on the properties of the wave medium
  (the string)."""@en ;
  dcterms:modified "2026-06-09T00:46:37.824116Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5048-4
  a curric:KeyLearningPoint ;
  rdfs:label "For waves on a string, frequency and wavelength are inversely proportional"@en ;
  dcterms:modified "2026-06-09T00:46:37.824123Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5048-5
  a curric:KeyLearningPoint ;
  rdfs:label """Control variables are the quantities that must be kept the same during experiments
  so they don’t affect results."""@en ;
  dcterms:modified "2026-06-09T00:46:37.824131Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9114-1
  a curric:KeyLearningPoint ;
  rdfs:label "Power is equal to the rate at which work is done."@en ;
  dcterms:modified "2026-06-09T00:46:37.825807Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9114-2
  a curric:KeyLearningPoint ;
  rdfs:label "Power is equal to the rate at which energy is transferred."@en ;
  dcterms:modified "2026-06-09T00:46:37.825815Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9114-3
  a curric:KeyLearningPoint ;
  rdfs:label "Power = work done ÷ time."@en ;
  dcterms:modified "2026-06-09T00:46:37.825825Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9114-4
  a curric:KeyLearningPoint ;
  rdfs:label "Power is measured in watts (W)."@en ;
  dcterms:modified "2026-06-09T00:46:37.825832Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28016-1
  a curric:KeyLearningPoint ;
  rdfs:label "A non–renewable energy resource cannot be replenished as it is used."@en ;
  dcterms:modified "2026-06-09T00:46:37.825840Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28016-2
  a curric:KeyLearningPoint ;
  rdfs:label """Non-renewable energy resources include fossil fuels (coal, oil and gas) and nuclear
  fuels."""@en ;
  dcterms:modified "2026-06-09T00:46:37.825850Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28016-3
  a curric:KeyLearningPoint ;
  rdfs:label "A renewable energy resource can be replenished as it is used."@en ;
  dcterms:modified "2026-06-09T00:46:37.825857Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28016-4
  a curric:KeyLearningPoint ;
  rdfs:label """Renewable energy resources include biofuels, wind, hydroelectricity, geothermal,
  tidal, solar and water waves."""@en ;
  dcterms:modified "2026-06-09T00:46:37.825864Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28016-5
  a curric:KeyLearningPoint ;
  rdfs:label """Science can identify environmental issues, but political, social, ethical and
  economic considerations determine action."""@en ;
  dcterms:modified "2026-06-09T00:46:37.825871Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9165-1
  a curric:KeyLearningPoint ;
  rdfs:label """The solar system includes the Sun, eight planets, dwarf planets and bands of smaller
  rocks."""@en ;
  dcterms:modified "2026-06-09T00:46:37.825878Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9165-2
  a curric:KeyLearningPoint ;
  rdfs:label """The planets, dwarf planets and bands of smaller rocks all move the same way around
  the Sun as they orbit it."""@en ;
  dcterms:modified "2026-06-09T00:46:37.825885Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9165-3
  a curric:KeyLearningPoint ;
  rdfs:label "Most planets in the solar system are orbited by one or more moons."@en ;
  dcterms:modified "2026-06-09T00:46:37.825892Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9165-4
  a curric:KeyLearningPoint ;
  rdfs:label """Each moon orbits a planet because of the gravitational attraction between it and the
  planet."""@en ;
  dcterms:modified "2026-06-09T00:46:37.825899Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9165-5
  a curric:KeyLearningPoint ;
  rdfs:label """Each planet in the solar system orbits the Sun because of the gravitational
  attraction between it and the Sun."""@en ;
  dcterms:modified "2026-06-09T00:46:37.825905Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20350-1
  a curric:KeyLearningPoint ;
  rdfs:label """Radio waves, microwaves, IR and visible light are non–ionising EM radiation. They
  can harm cells by heating."""@en ;
  dcterms:modified "2026-06-09T00:46:37.825946Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20350-2
  a curric:KeyLearningPoint ;
  rdfs:label """Radio waves are produced by oscillations of current. When absorbed, they may produce
  oscillations of current."""@en ;
  dcterms:modified "2026-06-09T00:46:37.825953Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20350-3
  a curric:KeyLearningPoint ;
  rdfs:label """Radio waves and microwaves are used for long distance communication, broadcasting
  and data transmission."""@en ;
  dcterms:modified "2026-06-09T00:46:37.825960Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20350-4
  a curric:KeyLearningPoint ;
  rdfs:label """Microwaves are absorbed by water, so can be used to cook food from within. IR
  radiation cooks the surface of food."""@en ;
  dcterms:modified "2026-06-09T00:46:37.825967Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20350-5
  a curric:KeyLearningPoint ;
  rdfs:label """IR is used for heating and thermal imaging. Visible light and IR are used for data
  transmission in optical fibres."""@en ;
  dcterms:modified "2026-06-09T00:46:37.825977Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5095-1
  a curric:KeyLearningPoint ;
  rdfs:label """A short circuit happens when a wire becomes loose and touches the wrong part of a
  circuit, or makes a new circuit."""@en ;
  dcterms:modified "2026-06-09T00:46:37.825985Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5095-2
  a curric:KeyLearningPoint ;
  rdfs:label """If a live wire touches the inside of a metal case, the metal case may become
  live."""@en ;
  dcterms:modified "2026-06-09T00:46:37.825992Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5095-3
  a curric:KeyLearningPoint ;
  rdfs:label """If there is too much current in an appliance, a fuse on the live wire in its plug
  melts and turns it off."""@en ;
  dcterms:modified "2026-06-09T00:46:37.825999Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5095-4
  a curric:KeyLearningPoint ;
  rdfs:label """From a live metal case, current flows along an earth and live wire, melts a fuse and
  turns the electricity off."""@en ;
  dcterms:modified "2026-06-09T00:46:37.826006Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5095-5
  a curric:KeyLearningPoint ;
  rdfs:label """Domestic circuits with excessive current are turned off by circuit breakers in a
  consumer box to prevent fire."""@en ;
  dcterms:modified "2026-06-09T00:46:37.826013Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27964-1
  a curric:KeyLearningPoint ;
  rdfs:label """Background radiation is caused by unstable nuclei that are around us all of the
  time."""@en ;
  dcterms:modified "2026-06-09T00:46:37.826020Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27964-2
  a curric:KeyLearningPoint ;
  rdfs:label "Atoms are very small with a radius of about 1 × 10⁻¹⁰ m."@en ;
  dcterms:modified "2026-06-09T00:46:37.826027Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27964-3
  a curric:KeyLearningPoint ;
  rdfs:label """The alpha particle scattering experiment (Rutherford, 1909) provides evidence for
  the size and nature of atomic nuclei."""@en ;
  dcterms:modified "2026-06-09T00:46:37.826034Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27964-4
  a curric:KeyLearningPoint ;
  rdfs:label "An atomic nucleus has a radius about 10 000 times smaller than that of an atom."@en ;
  dcterms:modified "2026-06-09T00:46:37.826041Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27964-5
  a curric:KeyLearningPoint ;
  rdfs:label "Most of the mass of an atom is in its nucleus."@en ;
  dcterms:modified "2026-06-09T00:46:37.826048Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4913-1
  a curric:KeyLearningPoint ;
  rdfs:label """A single resultant force has the same effect as several forces acting on an
  object"""@en ;
  dcterms:modified "2026-06-09T00:46:37.826132Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4913-2
  a curric:KeyLearningPoint ;
  rdfs:label """If there is no resultant force on an object, it remains still or continues to move
  at a steady speed in a straight line"""@en ;
  dcterms:modified "2026-06-09T00:46:37.826139Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4913-3
  a curric:KeyLearningPoint ;
  rdfs:label """If there is a resultant force on an object, it will accelerate in the direction of
  the force"""@en ;
  dcterms:modified "2026-06-09T00:46:37.826146Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4913-4
  a curric:KeyLearningPoint ;
  rdfs:label """A resultant force acting in the opposite direction to movement will decelerate (slow
  down) an object"""@en ;
  dcterms:modified "2026-06-09T00:46:37.826157Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9922-1
  a curric:KeyLearningPoint ;
  rdfs:label "Power is equal to the rate at which work is done."@en ;
  dcterms:modified "2026-06-09T00:46:37.827329Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9922-2
  a curric:KeyLearningPoint ;
  rdfs:label "Power is equal to the rate at which energy is transferred."@en ;
  dcterms:modified "2026-06-09T00:46:37.827335Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9922-3
  a curric:KeyLearningPoint ;
  rdfs:label "Power = work done ÷ time."@en ;
  dcterms:modified "2026-06-09T00:46:37.827345Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9922-4
  a curric:KeyLearningPoint ;
  rdfs:label "Power is measured in watts (W)."@en ;
  dcterms:modified "2026-06-09T00:46:37.827356Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9139-1
  a curric:KeyLearningPoint ;
  rdfs:label "Resultant force = mass × acceleration, F = m × a."@en ;
  dcterms:modified "2026-06-09T00:46:37.827467Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9139-2
  a curric:KeyLearningPoint ;
  rdfs:label """An object that is thrown in the air experiences a constant gravitational force
  towards the centre of the Earth."""@en ;
  dcterms:modified "2026-06-09T00:46:37.827477Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9139-3
  a curric:KeyLearningPoint ;
  rdfs:label """An object that is thrown in the air is constantly accelerating towards the centre of
  the Earth."""@en ;
  dcterms:modified "2026-06-09T00:46:37.827485Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9139-4
  a curric:KeyLearningPoint ;
  rdfs:label """Inertial mass is a measure of how hard it is to change the velocity of an
  object."""@en ;
  dcterms:modified "2026-06-09T00:46:37.827491Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9139-5
  a curric:KeyLearningPoint ;
  rdfs:label "Inertial mass = force ÷ acceleration, m = F ÷ a."@en ;
  dcterms:modified "2026-06-09T00:46:37.827501Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5085-1
  a curric:KeyLearningPoint ;
  rdfs:label """At a boundary to a medium where the wave speed increases, waves are refracted away
  from the normal."""@en ;
  dcterms:modified "2026-06-09T00:46:37.828337Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5085-2
  a curric:KeyLearningPoint ;
  rdfs:label """If the angle of incidence is too big the waves will undergo total internal
  reflection."""@en ;
  dcterms:modified "2026-06-09T00:46:37.828343Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5085-3
  a curric:KeyLearningPoint ;
  rdfs:label """For a glass–air boundary, the total internal reflection occurs when the angle of
  incidence is 42° or greater."""@en ;
  dcterms:modified "2026-06-09T00:46:37.828350Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28176-1
  a curric:KeyLearningPoint ;
  rdfs:label "Radioactive contamination is the presence of unwanted radioactive atoms."@en ;
  dcterms:modified "2026-06-09T00:46:37.828356Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28176-2
  a curric:KeyLearningPoint ;
  rdfs:label """A material being exposed to iodising radiation is being irradiated and does not
  become radioactive."""@en ;
  dcterms:modified "2026-06-09T00:46:37.828362Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28176-3
  a curric:KeyLearningPoint ;
  rdfs:label """Radioactive isotopes with short half-lives decay quickly, emitting most radiation
  over a short period of time."""@en ;
  dcterms:modified "2026-06-09T00:46:37.828369Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27968-1
  a curric:KeyLearningPoint ;
  rdfs:label """Nuclear fission is the splitting of a large and unstable nucleus such as uranium or
  plutonium."""@en ;
  dcterms:modified "2026-06-09T00:46:37.828825Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27968-2
  a curric:KeyLearningPoint ;
  rdfs:label """A neutron fired at a uranium nucleus can cause nuclear fission that splits the
  nucleus and emits 2 or 3 more neutrons."""@en ;
  dcterms:modified "2026-06-09T00:46:37.828831Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27968-3
  a curric:KeyLearningPoint ;
  rdfs:label """The motion of all the particles shot out from a nuclear fission can cause heating by
  making other particles move faster."""@en ;
  dcterms:modified "2026-06-09T00:46:37.828838Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27968-4
  a curric:KeyLearningPoint ;
  rdfs:label """Neutrons shot out from a nuclear fission can split more uranium nuclei in a chain
  reaction."""@en ;
  dcterms:modified "2026-06-09T00:46:37.828844Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27968-5
  a curric:KeyLearningPoint ;
  rdfs:label """Nuclear fusion is the joining of two light nuclei to form a heavier nucleus with the
  creation of gamma radiation."""@en ;
  dcterms:modified "2026-06-09T00:46:37.828850Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4941-1
  a curric:KeyLearningPoint ;
  rdfs:label """Artificial satellites orbit Earth because of the gravitational attraction between
  them."""@en ;
  dcterms:modified "2026-06-09T00:46:37.828856Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4941-2
  a curric:KeyLearningPoint ;
  rdfs:label "The speed of a satellite along its orbit around Earth is constant."@en ;
  dcterms:modified "2026-06-09T00:46:37.828863Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4941-3
  a curric:KeyLearningPoint ;
  rdfs:label """The velocity of a satellite along its orbit around Earth constantly changes as it
  changes direction."""@en ;
  dcterms:modified "2026-06-09T00:46:37.828872Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4941-4
  a curric:KeyLearningPoint ;
  rdfs:label """The gravitational force on a satellite makes it accelerate and change direction, but
  not speed."""@en ;
  dcterms:modified "2026-06-09T00:46:37.828879Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9909-1
  a curric:KeyLearningPoint ;
  rdfs:label "Average velocity = distance travelled ÷ time"@en ;
  dcterms:modified "2026-06-09T00:46:37.830864Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9909-2
  a curric:KeyLearningPoint ;
  rdfs:label "Average acceleration = change in velocity ÷ time"@en ;
  dcterms:modified "2026-06-09T00:46:37.830871Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9909-3
  a curric:KeyLearningPoint ;
  rdfs:label "Average velocity = (initial velocity + final velocity) ÷ 2"@en ;
  dcterms:modified "2026-06-09T00:46:37.830877Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9909-4
  a curric:KeyLearningPoint ;
  rdfs:label """Combining equations for average acceleration and average velocity leads to the
  equation v² – u² = 2ax"""@en ;
  dcterms:modified "2026-06-09T00:46:37.830884Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9909-5
  a curric:KeyLearningPoint ;
  rdfs:label """Different motion equations can be used to analyse motion based on information
  provided."""@en ;
  dcterms:modified "2026-06-09T00:46:37.830890Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4915-1
  a curric:KeyLearningPoint ;
  rdfs:label "Resultant force = mass × acceleration, F = m × a"@en ;
  dcterms:modified "2026-06-09T00:46:37.831048Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4915-2
  a curric:KeyLearningPoint ;
  rdfs:label """An object that is thrown in the air experiences a constant gravitational force
  towards the centre of Earth."""@en ;
  dcterms:modified "2026-06-09T00:46:37.831054Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4915-3
  a curric:KeyLearningPoint ;
  rdfs:label """An object that is thrown in the air is constantly accelerating towards the centre of
  Earth."""@en ;
  dcterms:modified "2026-06-09T00:46:37.831060Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4935-1
  a curric:KeyLearningPoint ;
  rdfs:label """Artificial satellites orbit Earth because of the gravitational attraction between
  them."""@en ;
  dcterms:modified "2026-06-09T00:46:37.831067Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4935-2
  a curric:KeyLearningPoint ;
  rdfs:label "The speed of a satellite along its orbit around Earth is constant."@en ;
  dcterms:modified "2026-06-09T00:46:37.831073Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4935-3
  a curric:KeyLearningPoint ;
  rdfs:label """The velocity of a satellite along its orbit around Earth constantly changes as it
  changes direction."""@en ;
  dcterms:modified "2026-06-09T00:46:37.831079Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4935-4
  a curric:KeyLearningPoint ;
  rdfs:label """The centripetal force on a satellite makes it accelerate and change direction, but
  not speed."""@en ;
  dcterms:modified "2026-06-09T00:46:37.831088Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4935-5
  a curric:KeyLearningPoint ;
  rdfs:label """To orbit in a stable orbit, the orbital radius of a satellite must change if its
  speed changes."""@en ;
  dcterms:modified "2026-06-09T00:46:37.831094Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5049-1
  a curric:KeyLearningPoint ;
  rdfs:label "The speed of a wave depends on the medium it is travelling through"@en ;
  dcterms:modified "2026-06-09T00:46:37.831101Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5049-2
  a curric:KeyLearningPoint ;
  rdfs:label "The speed of a wave does not depend on its frequency"@en ;
  dcterms:modified "2026-06-09T00:46:37.831107Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5049-3
  a curric:KeyLearningPoint ;
  rdfs:label "For a given wave speed, the higher the frequency, the shorter the wavelength"@en ;
  dcterms:modified "2026-06-09T00:46:37.831113Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5049-4
  a curric:KeyLearningPoint ;
  rdfs:label "For a given wave speed, the longer the wavelength, the lower the frequency"@en ;
  dcterms:modified "2026-06-09T00:46:37.831120Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5049-5
  a curric:KeyLearningPoint ;
  rdfs:label "Wave speed = frequency x wavelength"@en ;
  dcterms:modified "2026-06-09T00:46:37.831126Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9932-1
  a curric:KeyLearningPoint ;
  rdfs:label "When an object moves upwards, work is done against the gravitational force."@en ;
  dcterms:modified "2026-06-09T00:46:37.832210Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9932-2
  a curric:KeyLearningPoint ;
  rdfs:label """The gravitational force acting on an object does work to speed it up when it is
  falling."""@en ;
  dcterms:modified "2026-06-09T00:46:37.832216Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9932-3
  a curric:KeyLearningPoint ;
  rdfs:label "Weight = mass x gravitational field strength, W = mg"@en ;
  dcterms:modified "2026-06-09T00:46:37.832222Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9932-4
  a curric:KeyLearningPoint ;
  rdfs:label """Change in gravitational potential energy of an object = mass × gravitational field
  strength × change in height"""@en ;
  dcterms:modified "2026-06-09T00:46:37.832228Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5122-1
  a curric:KeyLearningPoint ;
  rdfs:label """Radioactive particles can emit radiation in the form of particles or gamma
  radiation."""@en ;
  dcterms:modified "2026-06-09T00:46:37.832535Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5122-2
  a curric:KeyLearningPoint ;
  rdfs:label """Ionising radiation forces electrons from atoms, leaving an atom with a positive
  charge called an ion."""@en ;
  dcterms:modified "2026-06-09T00:46:37.832541Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5122-3
  a curric:KeyLearningPoint ;
  rdfs:label """Alpha particles are more ionising than beta or gamma because they have a bigger
  charge and stronger electric field."""@en ;
  dcterms:modified "2026-06-09T00:46:37.832547Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20348-1
  a curric:KeyLearningPoint ;
  rdfs:label """Radio waves, microwaves, IR and visible light are non–ionising EM radiation. They
  can harm cells by heating."""@en ;
  dcterms:modified "2026-06-09T00:46:37.832809Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20348-2
  a curric:KeyLearningPoint ;
  rdfs:label """Radio waves and microwaves are used for long distance communication, broadcasting
  and data transmission."""@en ;
  dcterms:modified "2026-06-09T00:46:37.832816Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20348-3
  a curric:KeyLearningPoint ;
  rdfs:label """Microwaves are absorbed by water, so can be used to cook food from within. IR
  radiation cooks the surface of food."""@en ;
  dcterms:modified "2026-06-09T00:46:37.832822Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20348-4
  a curric:KeyLearningPoint ;
  rdfs:label """IR is used for heating and thermal imaging. Visible light and IR are used for data
  transmission in optical fibres."""@en ;
  dcterms:modified "2026-06-09T00:46:37.832828Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20344-1
  a curric:KeyLearningPoint ;
  rdfs:label """All bodies (objects) of all temperatures emit and absorb infrared radiation. Hotter
  bodies emit more IR in a set time."""@en ;
  dcterms:modified "2026-06-09T00:46:37.834075Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20344-2
  a curric:KeyLearningPoint ;
  rdfs:label """The range of wavelengths emitted, and their intensities, depend on an object’s
  temperature."""@en ;
  dcterms:modified "2026-06-09T00:46:37.834080Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20344-3
  a curric:KeyLearningPoint ;
  rdfs:label """Good absorbers (e.g. dark and dull surfaces) are also good emitters. Shiny metal
  surfaces are poor absorbers/emitters."""@en ;
  dcterms:modified "2026-06-09T00:46:37.834086Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20344-4
  a curric:KeyLearningPoint ;
  rdfs:label """A black body is a theoretical object that absorbs all of the radiation that falls on
  it."""@en ;
  dcterms:modified "2026-06-09T00:46:37.834092Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20344-5
  a curric:KeyLearningPoint ;
  rdfs:label """The temperature of a body depends on the rates at which radiation is absorbed and
  emitted."""@en ;
  dcterms:modified "2026-06-09T00:46:37.834098Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5090-1
  a curric:KeyLearningPoint ;
  rdfs:label """In cameras and the human eye, the required image distance < the object distance. The
  image is diminished and inverted."""@en ;
  dcterms:modified "2026-06-09T00:46:37.834612Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5090-2
  a curric:KeyLearningPoint ;
  rdfs:label """In projectors, the required image distance > the object distance. The image is
  magnified and inverted."""@en ;
  dcterms:modified "2026-06-09T00:46:37.834620Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5090-3
  a curric:KeyLearningPoint ;
  rdfs:label """A ray incident on a converging lens parallel to the principal axis is refracted to
  pass through principal focus."""@en ;
  dcterms:modified "2026-06-09T00:46:37.834626Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5090-4
  a curric:KeyLearningPoint ;
  rdfs:label "A ray incident on the centre of a converging lens is not refracted."@en ;
  dcterms:modified "2026-06-09T00:46:37.834632Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5090-5
  a curric:KeyLearningPoint ;
  rdfs:label """A ray incident on a converging lens from the principal focus is refracted so it
  becomes parallel to the principal axis."""@en ;
  dcterms:modified "2026-06-09T00:46:37.834637Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9117-1
  a curric:KeyLearningPoint ;
  rdfs:label """A spring is elastically deformed if it returns to its original shape after the
  applied force is removed"""@en ;
  dcterms:modified "2026-06-09T00:46:37.834643Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9117-2
  a curric:KeyLearningPoint ;
  rdfs:label """A spring is inelastically deformed if it does not return to its original shape after
  the applied force is removed"""@en ;
  dcterms:modified "2026-06-09T00:46:37.834651Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9117-3
  a curric:KeyLearningPoint ;
  rdfs:label """Elastic deformation is proportional to the force applied to stretch or compress a
  spring"""@en ;
  dcterms:modified "2026-06-09T00:46:37.834658Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9117-4
  a curric:KeyLearningPoint ;
  rdfs:label """The spring constant (k) is the force needed to extend or compress an elastic object
  by one metre"""@en ;
  dcterms:modified "2026-06-09T00:46:37.834663Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9117-5
  a curric:KeyLearningPoint ;
  rdfs:label "Force on a spring = spring constant × extension"@en ;
  dcterms:modified "2026-06-09T00:46:37.834669Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4912-1
  a curric:KeyLearningPoint ;
  rdfs:label "Some forces require contact between objects, while others do not."@en ;
  dcterms:modified "2026-06-09T00:46:37.835178Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4912-2
  a curric:KeyLearningPoint ;
  rdfs:label "Forces are vectors and can be drawn as arrows on diagrams."@en ;
  dcterms:modified "2026-06-09T00:46:37.835184Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4912-3
  a curric:KeyLearningPoint ;
  rdfs:label "A free body diagram shows all of the forces acting on a single object."@en ;
  dcterms:modified "2026-06-09T00:46:37.835192Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4912-4
  a curric:KeyLearningPoint ;
  rdfs:label "For every force there is an equal sized force acting in the opposite direction."@en ;
  dcterms:modified "2026-06-09T00:46:37.835198Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4912-5
  a curric:KeyLearningPoint ;
  rdfs:label """Force pairs have the same magnitude and type, and act in opposite directions between
  two objects."""@en ;
  dcterms:modified "2026-06-09T00:46:37.835207Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8158-1
  a curric:KeyLearningPoint ;
  rdfs:label """The pressure in a fluid increases with depth because the weight of fluid above
  pushes particles closer together."""@en ;
  dcterms:modified "2026-06-09T00:46:37.835714Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8158-2
  a curric:KeyLearningPoint ;
  rdfs:label """The pressure on an object in a fluid pushes with more force on the lower part of it
  and causes upthrust."""@en ;
  dcterms:modified "2026-06-09T00:46:37.835719Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8158-3
  a curric:KeyLearningPoint ;
  rdfs:label "An object floats in water if its density is less than that of water."@en ;
  dcterms:modified "2026-06-09T00:46:37.835725Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8158-4
  a curric:KeyLearningPoint ;
  rdfs:label """The density of a material increases with the mass of each particle and the closeness
  of its particles."""@en ;
  dcterms:modified "2026-06-09T00:46:37.835730Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8158-5
  a curric:KeyLearningPoint ;
  rdfs:label """Ice is less dense than water as its crystal structure fixes the particles further
  apart than they are in water."""@en ;
  dcterms:modified "2026-06-09T00:46:37.835736Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6580-1
  a curric:KeyLearningPoint ;
  rdfs:label "Some forces require contact between objects, while others do not."@en ;
  dcterms:modified "2026-06-09T00:46:37.835938Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6580-2
  a curric:KeyLearningPoint ;
  rdfs:label "Forces are vectors and can be drawn as arrows on diagrams."@en ;
  dcterms:modified "2026-06-09T00:46:37.835944Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6580-3
  a curric:KeyLearningPoint ;
  rdfs:label """A free body diagram shows all of the individual forces acting on a single
  object."""@en ;
  dcterms:modified "2026-06-09T00:46:37.835949Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6580-4
  a curric:KeyLearningPoint ;
  rdfs:label "For every force there is an equal sized force acting in the opposite direction."@en ;
  dcterms:modified "2026-06-09T00:46:37.835958Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6580-5
  a curric:KeyLearningPoint ;
  rdfs:label """Force pairs have the same magnitude and type and act in opposite directions between
  two objects."""@en ;
  dcterms:modified "2026-06-09T00:46:37.835966Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5086-1
  a curric:KeyLearningPoint ;
  rdfs:label """At a boundary to a medium where the wave speed increases, waves are refracted away
  from the normal."""@en ;
  dcterms:modified "2026-06-09T00:46:37.836794Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5086-2
  a curric:KeyLearningPoint ;
  rdfs:label """If the angle of incidence is too big (bigger than the critical angle) the waves will
  undergo total internal reflection."""@en ;
  dcterms:modified "2026-06-09T00:46:37.836800Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5086-3
  a curric:KeyLearningPoint ;
  rdfs:label """The critical angle is the greatest angle of incidence before total internal
  reflection occurs."""@en ;
  dcterms:modified "2026-06-09T00:46:37.836806Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5086-4
  a curric:KeyLearningPoint ;
  rdfs:label "For a glass–air boundary, the critical angle (c) is about 42°."@en ;
  dcterms:modified "2026-06-09T00:46:37.836811Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8141-1
  a curric:KeyLearningPoint ;
  rdfs:label """Human hearing involves the transmission of sound waves through different parts of
  the ear."""@en ;
  dcterms:modified "2026-06-09T00:46:37.836816Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8141-2
  a curric:KeyLearningPoint ;
  rdfs:label """Wave transmission to a new medium can be limited by the wave amplitude or the wave
  frequency."""@en ;
  dcterms:modified "2026-06-09T00:46:37.836822Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8141-3
  a curric:KeyLearningPoint ;
  rdfs:label """The range of human hearing is 20 Hz to 20 000 Hz. Frequencies above and below this
  are called ultrasound and infrasound."""@en ;
  dcterms:modified "2026-06-09T00:46:37.836827Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8141-4
  a curric:KeyLearningPoint ;
  rdfs:label """The highest frequency you can hear reduces with age as cells of the cochlea and
  auditory nerve become damaged over time."""@en ;
  dcterms:modified "2026-06-09T00:46:37.836833Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9116-1
  a curric:KeyLearningPoint ;
  rdfs:label "When an object moves upwards, work is done against the gravitational force."@en ;
  dcterms:modified "2026-06-09T00:46:37.837049Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9116-2
  a curric:KeyLearningPoint ;
  rdfs:label """The gravitational force acting on an object does work to speed it up when it is
  falling."""@en ;
  dcterms:modified "2026-06-09T00:46:37.837055Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9116-3
  a curric:KeyLearningPoint ;
  rdfs:label "Weight = mass x gravitational field strength, W = mg"@en ;
  dcterms:modified "2026-06-09T00:46:37.837061Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9116-4
  a curric:KeyLearningPoint ;
  rdfs:label """Gravitational potential energy of an object = mass × gravitational field strength ×
  height"""@en ;
  dcterms:modified "2026-06-09T00:46:37.837066Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4902-1
  a curric:KeyLearningPoint ;
  rdfs:label "Work done is the total amount of energy transferred."@en ;
  dcterms:modified "2026-06-09T00:46:37.838378Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4902-2
  a curric:KeyLearningPoint ;
  rdfs:label "Work done = force x distance (moved in the direction of the force)."@en ;
  dcterms:modified "2026-06-09T00:46:37.838383Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4902-3
  a curric:KeyLearningPoint ;
  rdfs:label "Work done is measured in Joule (J)."@en ;
  dcterms:modified "2026-06-09T00:46:37.838389Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9896-1
  a curric:KeyLearningPoint ;
  rdfs:label "The velocity of an object is equal to the gradient of a displacement-time graph."@en ;
  dcterms:modified "2026-06-09T00:46:37.838394Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9896-2
  a curric:KeyLearningPoint ;
  rdfs:label "A direction in which velocity and displacement are measured needs to be chosen."@en ;
  dcterms:modified "2026-06-09T00:46:37.838402Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9896-3
  a curric:KeyLearningPoint ;
  rdfs:label """A negative gradient on a displacement-time graph (sloping downwards) represents
  velocity in the opposite direction."""@en ;
  dcterms:modified "2026-06-09T00:46:37.838410Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9896-4
  a curric:KeyLearningPoint ;
  rdfs:label """A negative value for displacement represents a position ‘behind’ the starting
  position."""@en ;
  dcterms:modified "2026-06-09T00:46:37.838415Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20370-1
  a curric:KeyLearningPoint ;
  rdfs:label """Electromagnetic waves/radiation are transverse oscillations (ripples) in electric
  and magnetic fields."""@en ;
  dcterms:modified "2026-06-09T00:46:37.839218Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20370-2
  a curric:KeyLearningPoint ;
  rdfs:label """The visible spectrum shows the range of different frequencies (colours) of visible
  light waves (visible EM radiation)."""@en ;
  dcterms:modified "2026-06-09T00:46:37.839223Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20370-3
  a curric:KeyLearningPoint ;
  rdfs:label """In the visible spectrum, violet light has the highest frequency and refracts more
  than red as it slows more in glass."""@en ;
  dcterms:modified "2026-06-09T00:46:37.839228Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20370-4
  a curric:KeyLearningPoint ;
  rdfs:label """The EM spectrum shows the range of frequencies that EM waves can have (radio,
  microwave, IR, visible, UV, X-ray, gamma)."""@en ;
  dcterms:modified "2026-06-09T00:46:37.839233Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20370-5
  a curric:KeyLearningPoint ;
  rdfs:label """EM waves in different frequency ranges have the same speed in air, but interact
  differently with different materials."""@en ;
  dcterms:modified "2026-06-09T00:46:37.839239Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9933-1
  a curric:KeyLearningPoint ;
  rdfs:label "When an object moves upwards, work is done against the gravitational force."@en ;
  dcterms:modified "2026-06-09T00:46:37.840182Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9933-2
  a curric:KeyLearningPoint ;
  rdfs:label """The gravitational force acting on an object does work to speed it up when it is
  falling."""@en ;
  dcterms:modified "2026-06-09T00:46:37.840187Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9933-3
  a curric:KeyLearningPoint ;
  rdfs:label "Weight = mass x gravitational field strength, W = mg"@en ;
  dcterms:modified "2026-06-09T00:46:37.840193Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9933-4
  a curric:KeyLearningPoint ;
  rdfs:label """Gravitational potential energy of an object = mass × gravitational field strength ×
  height"""@en ;
  dcterms:modified "2026-06-09T00:46:37.840201Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4904-1
  a curric:KeyLearningPoint ;
  rdfs:label "Energy is measured in joules (J)."@en ;
  dcterms:modified "2026-06-09T00:46:37.840419Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4904-2
  a curric:KeyLearningPoint ;
  rdfs:label """Doubling the mass of a moving object doubles the energy it has in its
  kinetic store."""@en ;
  dcterms:modified "2026-06-09T00:46:37.840426Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4904-3
  a curric:KeyLearningPoint ;
  rdfs:label """Doubling the speed of an object increases the energy it has in its kinetic store by
  four times."""@en ;
  dcterms:modified "2026-06-09T00:46:37.840432Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4904-4
  a curric:KeyLearningPoint ;
  rdfs:label """The energy an object has in its kinetic store of energy is found using the equation
  Ek = ½ mv²."""@en ;
  dcterms:modified "2026-06-09T00:46:37.840437Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9900-1
  a curric:KeyLearningPoint ;
  rdfs:label "Acceleration is equal to the amount that velocity changes in one second."@en ;
  dcterms:modified "2026-06-09T00:46:37.840470Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9900-2
  a curric:KeyLearningPoint ;
  rdfs:label "Acceleration is the rate of change of velocity."@en ;
  dcterms:modified "2026-06-09T00:46:37.840475Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9900-3
  a curric:KeyLearningPoint ;
  rdfs:label "Average acceleration = change of velocity/time [a = (v-u)/t]"@en ;
  dcterms:modified "2026-06-09T00:46:37.840480Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9900-4
  a curric:KeyLearningPoint ;
  rdfs:label "An object that is slowing down is decelerating."@en ;
  dcterms:modified "2026-06-09T00:46:37.840485Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9900-5
  a curric:KeyLearningPoint ;
  rdfs:label "An object that is decelerating has a negative acceleration."@en ;
  dcterms:modified "2026-06-09T00:46:37.840490Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9931-1
  a curric:KeyLearningPoint ;
  rdfs:label "Energy is measured in joules (J)."@en ;
  dcterms:modified "2026-06-09T00:46:37.841813Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9931-2
  a curric:KeyLearningPoint ;
  rdfs:label """Doubling the mass of a moving object doubles the energy it has in its
  kinetic store."""@en ;
  dcterms:modified "2026-06-09T00:46:37.841818Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9931-3
  a curric:KeyLearningPoint ;
  rdfs:label """Doubling the speed of an object increases the energy it has in its kinetic store by
  four times."""@en ;
  dcterms:modified "2026-06-09T00:46:37.841824Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9931-4
  a curric:KeyLearningPoint ;
  rdfs:label """The energy an object has in its kinetic store of energy is found using the equation
  E = ½ mv²."""@en ;
  dcterms:modified "2026-06-09T00:46:37.841832Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20079-1
  a curric:KeyLearningPoint ;
  rdfs:label "The velocity of an object is its speed in a given direction."@en ;
  dcterms:modified "2026-06-09T00:46:37.842985Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20079-2
  a curric:KeyLearningPoint ;
  rdfs:label """The displacement of an object is the distance it travels in a particular
  direction."""@en ;
  dcterms:modified "2026-06-09T00:46:37.842993Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20079-3
  a curric:KeyLearningPoint ;
  rdfs:label "Displacement and velocity are both vector quantities."@en ;
  dcterms:modified "2026-06-09T00:46:37.842999Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20079-4
  a curric:KeyLearningPoint ;
  rdfs:label """Velocity has a positive value in one direction and negative value in the opposite
  direction."""@en ;
  dcterms:modified "2026-06-09T00:46:37.843004Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20008-1
  a curric:KeyLearningPoint ;
  rdfs:label """Energy is dissipated due to friction which causes particles to vibrate more quickly
  and heats up the surroundings."""@en ;
  dcterms:modified "2026-06-09T00:46:37.844603Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20008-2
  a curric:KeyLearningPoint ;
  rdfs:label """Energy is dissipated due to drag which causes particles in the surroundings to move
  more quickly."""@en ;
  dcterms:modified "2026-06-09T00:46:37.844611Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20008-3
  a curric:KeyLearningPoint ;
  rdfs:label "Efficiency = useful output energy transfer / total input energy transfer"@en ;
  dcterms:modified "2026-06-09T00:46:37.844616Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20008-4
  a curric:KeyLearningPoint ;
  rdfs:label "Efficiency = useful power output / total power input"@en ;
  dcterms:modified "2026-06-09T00:46:37.844621Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20008-5
  a curric:KeyLearningPoint ;
  rdfs:label "Efficiency can be increased by lubrication, bearings or wheels."@en ;
  dcterms:modified "2026-06-09T00:46:37.844629Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4903-1
  a curric:KeyLearningPoint ;
  rdfs:label """Energy is dissipated due to friction which causes particles to vibrate more quickly
  and heats up the surroundings."""@en ;
  dcterms:modified "2026-06-09T00:46:37.844686Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4903-2
  a curric:KeyLearningPoint ;
  rdfs:label """Energy is dissipated due to drag which causes particles in the surroundings to move
  more quickly."""@en ;
  dcterms:modified "2026-06-09T00:46:37.844691Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4903-3
  a curric:KeyLearningPoint ;
  rdfs:label """Efficiency = (useful energy transferred by the device)/(total energy supplied to the
  device)"""@en ;
  dcterms:modified "2026-06-09T00:46:37.844696Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8166-1
  a curric:KeyLearningPoint ;
  rdfs:label """The pressure of a gas in a container increases if the temperature or amount of gas
  increases, or volume decreases."""@en ;
  dcterms:modified "2026-06-09T00:46:37.845265Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8166-2
  a curric:KeyLearningPoint ;
  rdfs:label "Increasing temperature increases the speed of particles in a gas."@en ;
  dcterms:modified "2026-06-09T00:46:37.845273Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8166-3
  a curric:KeyLearningPoint ;
  rdfs:label "Pressure × volume = constant (pV = constant)."@en ;
  dcterms:modified "2026-06-09T00:46:37.845278Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8166-4
  a curric:KeyLearningPoint ;
  rdfs:label "When a gas expands, its particles do work on the surrounding air."@en ;
  dcterms:modified "2026-06-09T00:46:37.845284Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9926-1
  a curric:KeyLearningPoint ;
  rdfs:label """Energy is dissipated due to friction which causes particles to vibrate more quickly
  and heats up the surroundings."""@en ;
  dcterms:modified "2026-06-09T00:46:37.845309Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9926-2
  a curric:KeyLearningPoint ;
  rdfs:label """Energy is dissipated due to drag which causes particles in the surroundings to move
  more quickly."""@en ;
  dcterms:modified "2026-06-09T00:46:37.845314Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9926-3
  a curric:KeyLearningPoint ;
  rdfs:label """Efficiency = (useful energy transferred by the device)/(total energy supplied to the
  device)"""@en ;
  dcterms:modified "2026-06-09T00:46:37.845319Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9926-4
  a curric:KeyLearningPoint ;
  rdfs:label "Efficiency can be increased by lubrication, bearings or wheels."@en ;
  dcterms:modified "2026-06-09T00:46:37.845325Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9925-1
  a curric:KeyLearningPoint ;
  rdfs:label """Energy is dissipated due to friction which causes particles to vibrate more quickly
  and heats up the surroundings."""@en ;
  dcterms:modified "2026-06-09T00:46:37.845330Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9925-2
  a curric:KeyLearningPoint ;
  rdfs:label """Energy is dissipated due to drag which causes particles in the surroundings to move
  more quickly."""@en ;
  dcterms:modified "2026-06-09T00:46:37.845335Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9925-3
  a curric:KeyLearningPoint ;
  rdfs:label "Efficiency = useful output energy transfer / total input energy transfer"@en ;
  dcterms:modified "2026-06-09T00:46:37.845340Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9925-4
  a curric:KeyLearningPoint ;
  rdfs:label "Efficiency can be increased by lubrication, bearings or wheels"@en ;
  dcterms:modified "2026-06-09T00:46:37.845345Z"^^xsd:dateTime .

