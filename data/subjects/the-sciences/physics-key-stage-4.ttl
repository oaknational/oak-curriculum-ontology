  schema:description "The mass per cubic metre (m³) or cubic centimetre (cm³) of a material."@en ;
  dcterms:modified "2026-06-09T00:46:04.285383Z"^^xsd:dateTime .

oakcurric:keyword-displacement-can
  a curric:Keyword ;
  schema:name "displacement can"@en ;
