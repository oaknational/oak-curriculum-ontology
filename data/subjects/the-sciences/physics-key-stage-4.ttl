  dcterms:modified "2026-06-09T00:46:04.287498Z"^^xsd:dateTime .

oakcurric:keyword-control-experiments
  a curric:Keyword ;
  schema:name "control experiments"@en ;
  schema:description """These are done to find a baseline set of results to which others can be
  compared."""@en ;
  dcterms:modified "2026-06-09T00:46:04.287613Z"^^xsd:dateTime .

oakcurric:keyword-control-variables
  a curric:Keyword ;
  schema:name "control variables"@en ;
  schema:description """These are factors that need to be kept constant in an experiment for the
  test to be fair."""@en ;
  dcterms:modified "2026-06-09T00:46:04.287618Z"^^xsd:dateTime .

oakcurric:keyword-diode
  a curric:Keyword ;
  schema:name "diode"@en ;
  schema:description """an electrical component that is used to prevent current flow in one
  direction"""@en ;
  dcterms:modified "2026-06-09T00:46:04.287731Z"^^xsd:dateTime .

oakcurric:keyword-threshold-pd
  a curric:Keyword ;
  schema:name "threshold p.d."@en ;
