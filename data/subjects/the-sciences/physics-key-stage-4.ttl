oakcurric:priorknowledge-453-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Speed measures how quickly an object is moving."@en ;
  dcterms:modified "2026-06-09T00:45:27.669449Z"^^xsd:dateTime .

oakcurric:priorknowledge-453-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Speed = distance / time."@en ;
  dcterms:modified "2026-06-09T00:45:27.669463Z"^^xsd:dateTime .

oakcurric:priorknowledge-453-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Speed is measured in m/s or km/h or miles/h."@en ;
  dcterms:modified "2026-06-09T00:45:27.669469Z"^^xsd:dateTime .

oakcurric:priorknowledge-453-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "m/s is the number of metres travelled each second."@en ;
  dcterms:modified "2026-06-09T00:45:27.669473Z"^^xsd:dateTime .

oakcurric:priorknowledge-453-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Counting down ‘3, 2, 1, go’ helps start a stopwatch at the right moment."@en ;
  dcterms:modified "2026-06-09T00:45:27.669479Z"^^xsd:dateTime .

oakcurric:priorknowledge-453-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Observing with eyes in line with the finish line helps stop a stopwatch at the right
  moment."""@en ;
  dcterms:modified "2026-06-09T00:45:27.669484Z"^^xsd:dateTime .

oakcurric:priorknowledge-453-7
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "A level line on a distance-time graph shows no movement."@en ;
  dcterms:modified "2026-06-09T00:45:27.669488Z"^^xsd:dateTime .

oakcurric:priorknowledge-453-8
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "The steeper the line on a distance-time graph, the faster the movement."@en ;
  dcterms:modified "2026-06-09T00:45:27.669493Z"^^xsd:dateTime .

oakcurric:priorknowledge-477-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "The bigger the resultant force, the bigger the change on an object."@en ;
  dcterms:modified "2026-06-09T00:45:27.718511Z"^^xsd:dateTime .

oakcurric:priorknowledge-477-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "The moment of a force causes turning."@en ;
  dcterms:modified "2026-06-09T00:45:27.718523Z"^^xsd:dateTime .

oakcurric:priorknowledge-477-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Levers are force multipliers or distance multipliers."@en ;
  dcterms:modified "2026-06-09T00:45:27.718528Z"^^xsd:dateTime .

oakcurric:priorknowledge-477-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Objects that are harder to stop have a bigger momentum."@en ;
  dcterms:modified "2026-06-09T00:45:27.718533Z"^^xsd:dateTime .

oakcurric:priorknowledge-477-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Work done is the total amount of energy transferred."@en ;
  dcterms:modified "2026-06-09T00:45:27.718537Z"^^xsd:dateTime .

oakcurric:priorknowledge-477-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Work done is measured in joules (J)."@en ;
  dcterms:modified "2026-06-09T00:45:27.718546Z"^^xsd:dateTime .

oakcurric:priorknowledge-477-7
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Doubling the mass of a moving object doubles the energy it has because it is
  moving."""@en ;
  dcterms:modified "2026-06-09T00:45:27.718551Z"^^xsd:dateTime .

oakcurric:priorknowledge-477-8
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Doubling the speed of an object increases the energy it has because it is moving by
  four times."""@en ;
  dcterms:modified "2026-06-09T00:45:27.718556Z"^^xsd:dateTime .

oakcurric:priorknowledge-477-9
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The gravitational force acting on an object does work to speed the object up when it
  is falling."""@en ;
  dcterms:modified "2026-06-09T00:45:27.718560Z"^^xsd:dateTime .

oakcurric:priorknowledge-477-10
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Gravitational force (weight) = mass × gravitational field strength, W = mg."@en ;
  dcterms:modified "2026-06-09T00:45:27.718564Z"^^xsd:dateTime .

oakcurric:priorknowledge-478-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "The temperature along a thermal conductor increases quickly when it is heated."@en ;
  dcterms:modified "2026-06-09T00:45:27.785607Z"^^xsd:dateTime .

oakcurric:priorknowledge-478-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The temperature along a thermal insulator increases very slowly when it is
  heated."""@en ;
  dcterms:modified "2026-06-09T00:45:27.785620Z"^^xsd:dateTime .

oakcurric:priorknowledge-478-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """In thermal conductors, vibrating particles quickly cause the particles near to them
  to vibrate as well."""@en ;
  dcterms:modified "2026-06-09T00:45:27.785625Z"^^xsd:dateTime .

oakcurric:priorknowledge-478-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The faster the particles in something are vibrating or moving, the higher its
  temperature."""@en ;
  dcterms:modified "2026-06-09T00:45:27.785629Z"^^xsd:dateTime .

oakcurric:priorknowledge-478-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The more energy something has because its particles are vibrating or moving, the
  more it can heat something else."""@en ;
  dcterms:modified "2026-06-09T00:45:27.785640Z"^^xsd:dateTime .

oakcurric:priorknowledge-478-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "It is easier to increase the temperature of some materials than others."@en ;
  dcterms:modified "2026-06-09T00:45:27.785644Z"^^xsd:dateTime .

oakcurric:priorknowledge-478-7
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The same amount of different materials at the same temperature can cause different
  amounts of heating."""@en ;
  dcterms:modified "2026-06-09T00:45:27.785648Z"^^xsd:dateTime .

oakcurric:priorknowledge-478-8
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The particles and the bonds between particles are different in different
  substances."""@en ;
  dcterms:modified "2026-06-09T00:45:27.785653Z"^^xsd:dateTime .

oakcurric:priorknowledge-490-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "As a water wave moves forwards, each bit of water moves up and down."@en ;
  dcterms:modified "2026-06-09T00:45:27.818429Z"^^xsd:dateTime .

oakcurric:priorknowledge-490-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Water does not move forwards with a wave."@en ;
  dcterms:modified "2026-06-09T00:45:27.818447Z"^^xsd:dateTime .

oakcurric:priorknowledge-490-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "A water wave is a transverse wave."@en ;
  dcterms:modified "2026-06-09T00:45:27.818453Z"^^xsd:dateTime .

oakcurric:priorknowledge-490-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "The frequency of a water wave does not affect its speed."@en ;
  dcterms:modified "2026-06-09T00:45:27.818459Z"^^xsd:dateTime .

oakcurric:priorknowledge-490-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "The amplitude of a water wave does not affect its speed."@en ;
  dcterms:modified "2026-06-09T00:45:27.818465Z"^^xsd:dateTime .

oakcurric:priorknowledge-490-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The bigger the amplitude of a wave, the greater the amount of energy it
  transfers."""@en ;
  dcterms:modified "2026-06-09T00:45:27.818470Z"^^xsd:dateTime .

oakcurric:priorknowledge-490-7
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The higher the frequency of a wave, the greater the amount of energy it
  transfers."""@en ;
  dcterms:modified "2026-06-09T00:45:27.818475Z"^^xsd:dateTime .

oakcurric:priorknowledge-490-8
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "As a sound wave moves forwards, each bit of air moves forward and backward."@en ;
  dcterms:modified "2026-06-09T00:45:27.818480Z"^^xsd:dateTime .

oakcurric:priorknowledge-490-9
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Air does not move forwards with a sound wave."@en ;
  dcterms:modified "2026-06-09T00:45:27.818500Z"^^xsd:dateTime .

oakcurric:priorknowledge-490-10
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "A sound wave is a longitudinal wave."@en ;
  dcterms:modified "2026-06-09T00:45:27.818506Z"^^xsd:dateTime .

oakcurric:priorknowledge-494-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The visible spectrum comprises red, orange, yellow, green, blue, indigo and violet
  light."""@en ;
  dcterms:modified "2026-06-09T00:45:28.126389Z"^^xsd:dateTime .

oakcurric:priorknowledge-494-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "A glass prism can split sunlight up into colours of the visible spectrum."@en ;
  dcterms:modified "2026-06-09T00:45:28.126406Z"^^xsd:dateTime .

oakcurric:priorknowledge-494-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "A ray of light bends at the surface as it enters glass (or water) from air."@en ;
  dcterms:modified "2026-06-09T00:45:28.126412Z"^^xsd:dateTime .

oakcurric:priorknowledge-494-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """A ray of light bends in the opposite direction at the surface as it leaves glass (or
  water) into air."""@en ;
  dcterms:modified "2026-06-09T00:45:28.126417Z"^^xsd:dateTime .

oakcurric:priorknowledge-494-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "The speed of a wave depends on the medium it is travelling through."@en ;
  dcterms:modified "2026-06-09T00:45:28.126422Z"^^xsd:dateTime .

oakcurric:priorknowledge-494-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "The speed of a wave does not depend on its amplitude or its frequency."@en ;
  dcterms:modified "2026-06-09T00:45:28.126432Z"^^xsd:dateTime .

oakcurric:priorknowledge-494-7
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "For a given wave speed, the higher the frequency, the shorter the wavelength."@en ;
  dcterms:modified "2026-06-09T00:45:28.126437Z"^^xsd:dateTime .

oakcurric:priorknowledge-494-8
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "For a given waves speed, the longer the wavelength, the lower the frequency."@en ;
  dcterms:modified "2026-06-09T00:45:28.126443Z"^^xsd:dateTime .

oakcurric:priorknowledge-494-9
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Wave speed = frequency x wavelength."@en ;
  dcterms:modified "2026-06-09T00:45:28.126448Z"^^xsd:dateTime .

oakcurric:priorknowledge-491-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "The current in a series circuit is the same everywhere."@en ;
  dcterms:modified "2026-06-09T00:45:29.046437Z"^^xsd:dateTime .

oakcurric:priorknowledge-491-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Adding a component to a series circuit changes the current everywhere, on both sides
  of the component."""@en ;
  dcterms:modified "2026-06-09T00:45:29.046448Z"^^xsd:dateTime .

oakcurric:priorknowledge-491-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The potential difference across each component in a series electric circuit adds up
  to the potential difference of the battery."""@en ;
  dcterms:modified "2026-06-09T00:45:29.046455Z"^^xsd:dateTime .

oakcurric:priorknowledge-491-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The potential difference across each branch of a parallel circuit is the same as the
  potential difference across the battery."""@en ;
  dcterms:modified "2026-06-09T00:45:29.046459Z"^^xsd:dateTime .

oakcurric:priorknowledge-491-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The current through each branch of a parallel circuit adds up to the current through
  the battery."""@en ;
  dcterms:modified "2026-06-09T00:45:29.046464Z"^^xsd:dateTime .

oakcurric:priorknowledge-491-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Current = potential difference / resistance"@en ;
  dcterms:modified "2026-06-09T00:45:29.046468Z"^^xsd:dateTime .

oakcurric:priorknowledge-497-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Atoms are the smallest parts that each element can be broken up into."@en ;
  dcterms:modified "2026-06-09T00:45:29.052487Z"^^xsd:dateTime .

oakcurric:priorknowledge-497-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Atoms used to be thought of as tiny spheres that could not be divided."@en ;
  dcterms:modified "2026-06-09T00:45:29.052499Z"^^xsd:dateTime .

oakcurric:priorknowledge-497-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The discovery of the electron (in 1897) led to the plum pudding model of the atom,
  for just a few years before new evidence led to a nuclear model of atoms."""@en ;
  dcterms:modified "2026-06-09T00:45:29.052505Z"^^xsd:dateTime .

oakcurric:priorknowledge-497-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "The atoms of each element are different."@en ;
  dcterms:modified "2026-06-09T00:45:29.052510Z"^^xsd:dateTime .

oakcurric:priorknowledge-497-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """An atom has a positively charged nucleus surrounded by negatively charged
  electrons."""@en ;
  dcterms:modified "2026-06-09T00:45:29.052515Z"^^xsd:dateTime .

oakcurric:priorknowledge-497-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "The radius of an atomic nucleus is much smaller than the radius of an atom."@en ;
  dcterms:modified "2026-06-09T00:45:29.052520Z"^^xsd:dateTime .

oakcurric:priorknowledge-497-7
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "An atomic nucleus consists of protons and neutrons."@en ;
  dcterms:modified "2026-06-09T00:45:29.052524Z"^^xsd:dateTime .

oakcurric:priorknowledge-497-8
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The atomic number of an element is equal to the number of protons in the nuclei of
  its atoms and the number of electrons in each atom."""@en ;
  dcterms:modified "2026-06-09T00:45:29.052529Z"^^xsd:dateTime .

oakcurric:priorknowledge-497-9
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The mass number of an atom is approximately equal to the number of protons added to
  the number of neutrons in its nucleus."""@en ;
  dcterms:modified "2026-06-09T00:45:29.052533Z"^^xsd:dateTime .

oakcurric:priorknowledge-497-10
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Isotopes of an element all have the same number of protons and electrons, but
  different numbers of neutrons."""@en ;
  dcterms:modified "2026-06-09T00:45:29.052538Z"^^xsd:dateTime .

oakcurric:priorknowledge-493-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Arrows on magnetic field lines show the direction in which the north-seeking pole of
  another magnet would be forced."""@en ;
  dcterms:modified "2026-06-09T00:45:29.150972Z"^^xsd:dateTime .

oakcurric:priorknowledge-493-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Where a magnetic field is stronger, the field lines are closer together."@en ;
  dcterms:modified "2026-06-09T00:45:29.150983Z"^^xsd:dateTime .

oakcurric:priorknowledge-493-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """When there is an electric current in a wire, there is a magnetic field around the
  wire."""@en ;
  dcterms:modified "2026-06-09T00:45:29.150989Z"^^xsd:dateTime .

oakcurric:priorknowledge-493-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """When there is an electric current in a coil of wire, the magnetic field around each
  loop adds to make a stronger field."""@en ;
  dcterms:modified "2026-06-09T00:45:29.150994Z"^^xsd:dateTime .

oakcurric:priorknowledge-493-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "An electromagnet is made by wrapping a coil of wire around a core."@en ;
  dcterms:modified "2026-06-09T00:45:29.150999Z"^^xsd:dateTime .

oakcurric:priorknowledge-493-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """An electromagnet is a magnet that can be turned on with an electric current, and
  turned off."""@en ;
  dcterms:modified "2026-06-09T00:45:29.151003Z"^^xsd:dateTime .

oakcurric:priorknowledge-493-7
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The more loops of wire in the coil of an electromagnet, the stronger its magnetic
  field."""@en ;
  dcterms:modified "2026-06-09T00:45:29.151007Z"^^xsd:dateTime .

oakcurric:priorknowledge-493-8
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The larger the current through the coil of an electromagnet, the stronger its
  magnetic field."""@en ;
  dcterms:modified "2026-06-09T00:45:29.151012Z"^^xsd:dateTime .

oakcurric:priorknowledge-493-9
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The more tightly wound the coil of wire is in an electromagnet, the stronger its
  magnetic field."""@en ;
  dcterms:modified "2026-06-09T00:45:29.151016Z"^^xsd:dateTime .

oakcurric:priorknowledge-493-10
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """A soft iron core increases the strength of an electromagnet because it becomes
  magnetised when it is turned on."""@en ;
  dcterms:modified "2026-06-09T00:45:29.151020Z"^^xsd:dateTime .

oakcurric:priorknowledge-489-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Electric current is measured in amps (A) with an ammeter."@en ;
  dcterms:modified "2026-06-09T00:45:29.269512Z"^^xsd:dateTime .

oakcurric:priorknowledge-489-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Potential difference (voltage) is measured in volts (V) with a voltmeter."@en ;
  dcterms:modified "2026-06-09T00:45:29.269523Z"^^xsd:dateTime .

oakcurric:priorknowledge-489-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "The current in a series circuit is the same everywhere."@en ;
  dcterms:modified "2026-06-09T00:45:29.269528Z"^^xsd:dateTime .

oakcurric:priorknowledge-489-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Adding a component to a series circuit changes the current everywhere, on both sides
  of the component."""@en ;
  dcterms:modified "2026-06-09T00:45:29.269533Z"^^xsd:dateTime .

oakcurric:priorknowledge-489-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The voltage across each component in a series electric circuit adds up to the
  voltage of the battery."""@en ;
  dcterms:modified "2026-06-09T00:45:29.269537Z"^^xsd:dateTime .

oakcurric:priorknowledge-489-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Resistance is a measure of how hard it is for current to flow."@en ;
  dcterms:modified "2026-06-09T00:45:29.269541Z"^^xsd:dateTime .

oakcurric:priorknowledge-489-7
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Resistance is measured in ohms (Ω)."@en ;
  dcterms:modified "2026-06-09T00:45:29.269546Z"^^xsd:dateTime .

oakcurric:priorknowledge-489-8
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The voltage across each branch of a parallel circuit is the same as the voltage
  across the battery."""@en ;
  dcterms:modified "2026-06-09T00:45:29.269550Z"^^xsd:dateTime .

oakcurric:priorknowledge-489-9
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Each loop in a parallel circuit is equivalent to a series circuit connected to the
  same battery."""@en ;
  dcterms:modified "2026-06-09T00:45:29.269559Z"^^xsd:dateTime .

oakcurric:priorknowledge-489-10
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The current through each branch of a parallel circuit adds up to the current through
  the battery."""@en ;
  dcterms:modified "2026-06-09T00:45:29.269564Z"^^xsd:dateTime .

oakcurric:priorknowledge-928-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Almost everything is made of particles."@en ;
  dcterms:modified "2026-06-09T00:45:29.325937Z"^^xsd:dateTime .

oakcurric:priorknowledge-928-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """In a solid, particles are very close together, have a regular arrangement, are
  vibrating and are bonded together."""@en ;
  dcterms:modified "2026-06-09T00:45:29.325954Z"^^xsd:dateTime .

oakcurric:priorknowledge-928-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """In a liquid, particles are close together, they do not have a regular arrangement
  and can move over each other, they are loosely bonded together."""@en ;
  dcterms:modified "2026-06-09T00:45:29.325960Z"^^xsd:dateTime .

oakcurric:priorknowledge-928-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """In a gas, particles are spaced apart and move quickly in straight lines, bouncing
  off other particles or the walls of their container."""@en ;
  dcterms:modified "2026-06-09T00:45:29.325966Z"^^xsd:dateTime .

oakcurric:priorknowledge-928-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Between particles there is empty space."@en ;
  dcterms:modified "2026-06-09T00:45:29.325972Z"^^xsd:dateTime .

oakcurric:priorknowledge-928-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Heating a solid makes its particles vibrate more quickly."@en ;
  dcterms:modified "2026-06-09T00:45:29.325977Z"^^xsd:dateTime .

oakcurric:priorknowledge-928-7
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Heating a liquid or gas makes its particles move around more quickly."@en ;
  dcterms:modified "2026-06-09T00:45:29.325982Z"^^xsd:dateTime .

oakcurric:priorknowledge-928-8
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Heating a solid, liquid or gas causes it to expand."@en ;
  dcterms:modified "2026-06-09T00:45:29.325987Z"^^xsd:dateTime .

oakcurric:priorknowledge-928-9
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The faster the particles in something are vibrating or moving, the higher its
  temperature."""@en ;
  dcterms:modified "2026-06-09T00:45:29.326000Z"^^xsd:dateTime .

oakcurric:priorknowledge-476-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Objects can have energy because they are: moving, raised, hot, squashed & springy,
  or contain chemicals that can react."""@en ;
  dcterms:modified "2026-06-09T00:45:29.789569Z"^^xsd:dateTime .

oakcurric:priorknowledge-476-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Energy can be transferred by forces that change the properties of an object (or
  system)."""@en ;
  dcterms:modified "2026-06-09T00:45:29.789581Z"^^xsd:dateTime .

oakcurric:priorknowledge-476-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Friction and drag act to continually reduce the speed of an unpropelled object."@en ;
  dcterms:modified "2026-06-09T00:45:29.789587Z"^^xsd:dateTime .

oakcurric:priorknowledge-476-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Streamlining reduces drag."@en ;
  dcterms:modified "2026-06-09T00:45:29.789591Z"^^xsd:dateTime .

oakcurric:priorknowledge-476-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Streamlining reduces how much a fluid needs to be pushed out of the way for an
  object to move through it."""@en ;
  dcterms:modified "2026-06-09T00:45:29.789596Z"^^xsd:dateTime .

oakcurric:priorknowledge-476-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Gravity pulls down with a steady force."@en ;
  dcterms:modified "2026-06-09T00:45:29.789600Z"^^xsd:dateTime .

oakcurric:priorknowledge-476-7
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "A gravitational force of about 10 N is needed to life one kg on the Earth."@en ;
  dcterms:modified "2026-06-09T00:45:29.789604Z"^^xsd:dateTime .

oakcurric:priorknowledge-476-8
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Gravitational force (weight), W = m × g"@en ;
  dcterms:modified "2026-06-09T00:45:29.789609Z"^^xsd:dateTime .

oakcurric:priorknowledge-476-9
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Work done = force × distance"@en ;
  dcterms:modified "2026-06-09T00:45:29.789613Z"^^xsd:dateTime .

oakcurric:priorknowledge-495-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Current = p.d. / resistance (I=V/R)."@en ;
  dcterms:modified "2026-06-09T00:45:30.704836Z"^^xsd:dateTime .

oakcurric:priorknowledge-495-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The rules of current and p.d. for a series circuit can be applied to find some
  missing values of current and p.d."""@en ;
  dcterms:modified "2026-06-09T00:45:30.704847Z"^^xsd:dateTime .

oakcurric:priorknowledge-495-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The rules of current and p.d. for a series circuit can be applied to find some
  missing values of current and p.d."""@en ;
  dcterms:modified "2026-06-09T00:45:30.704853Z"^^xsd:dateTime .

oakcurric:priorknowledge-495-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The equation I=V/R can be rearranged so that either p.d. or R is the subject of the
  equation."""@en ;
  dcterms:modified "2026-06-09T00:45:30.704857Z"^^xsd:dateTime .

oakcurric:priorknowledge-495-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "If any two values in the equation I=V/R are known, the third can be calculated."@en ;
  dcterms:modified "2026-06-09T00:45:30.704862Z"^^xsd:dateTime .

oakcurric:priorknowledge-495-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """If only one value in the equation I=V/R is known, rules for current or p.d. need to
  be applied to find a second."""@en ;
  dcterms:modified "2026-06-09T00:45:30.704871Z"^^xsd:dateTime .

oakcurric:priorknowledge-495-7
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Power = work done / time."@en ;
  dcterms:modified "2026-06-09T00:45:30.704876Z"^^xsd:dateTime .

oakcurric:priorknowledge-495-8
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Power is measured in Watt (W)."@en ;
  dcterms:modified "2026-06-09T00:45:30.704880Z"^^xsd:dateTime .

oakcurric:priorknowledge-479-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The Solar System contains the Sun, eight planets, lots of moons, several dwarf
  planets and many smaller pieces of rock."""@en ;
  dcterms:modified "2026-06-09T00:45:30.863901Z"^^xsd:dateTime .

oakcurric:priorknowledge-479-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Planets further from the Sun take longer to orbit."@en ;
  dcterms:modified "2026-06-09T00:45:30.863912Z"^^xsd:dateTime .

oakcurric:priorknowledge-479-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Gravitational force of the Earth pulls objects towards the centre of the Earth."@en ;
  dcterms:modified "2026-06-09T00:45:30.863917Z"^^xsd:dateTime .

oakcurric:priorknowledge-479-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Gravitational force of a planet is bigger for planets with more mass."@en ;
  dcterms:modified "2026-06-09T00:45:30.863922Z"^^xsd:dateTime .

oakcurric:priorknowledge-479-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "A sun is a star because, like all stars, it creates its own light."@en ;
  dcterms:modified "2026-06-09T00:45:30.863926Z"^^xsd:dateTime .

oakcurric:priorknowledge-479-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """There are stars in every direction, but they are too faint to be seen during the day
  amidst the bright sunlight."""@en ;
  dcterms:modified "2026-06-09T00:45:30.863930Z"^^xsd:dateTime .

oakcurric:priorknowledge-479-7
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Stars are found in groups called galaxies with billions of stars in each one."@en ;
  dcterms:modified "2026-06-09T00:45:30.863934Z"^^xsd:dateTime .

oakcurric:priorknowledge-479-8
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """It takes light about four years to travel from our nearest star, it is about four
  light years away."""@en ;
  dcterms:modified "2026-06-09T00:45:30.863943Z"^^xsd:dateTime .

