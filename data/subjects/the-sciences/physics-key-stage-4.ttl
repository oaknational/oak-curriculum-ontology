oakcurric:keylearningpoint-lesson-5078-1
  a curric:KeyLearningPoint ;
  rdfs:label """A magnet moving relative to a wire connected in a complete circuit can cause a
  current to flow in the wire."""@en ;
  dcterms:modified "2026-06-09T00:46:37.848804Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5078-2
  a curric:KeyLearningPoint ;
  rdfs:label """A magnet moving in the opposite direction relative to a wire induces a current in
  the opposite direction."""@en ;
  dcterms:modified "2026-06-09T00:46:37.848809Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5078-3
  a curric:KeyLearningPoint ;
  rdfs:label """A magnet moving relative to a wire can cause a potential difference across the wire
  called the induced potential."""@en ;
  dcterms:modified "2026-06-09T00:46:37.848816Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5078-4
  a curric:KeyLearningPoint ;
  rdfs:label """Induced potential is proportional to mag. field strength and the relative speed of
  movement between a wire and a magnet."""@en ;
  dcterms:modified "2026-06-09T00:46:37.848823Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5078-5
  a curric:KeyLearningPoint ;
  rdfs:label """For a magnet moving relative to a coil, the induced potential is proportional to the
  number of turns of wire in a coil."""@en ;
  dcterms:modified "2026-06-09T00:46:37.848829Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9098-1
  a curric:KeyLearningPoint ;
  rdfs:label """The pressure of a gas in a container increases if the temperature or amount of gas
  increases, or volume decreases."""@en ;
  dcterms:modified "2026-06-09T00:46:37.850255Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9098-2
  a curric:KeyLearningPoint ;
  rdfs:label "Increasing temperature increases the speed of particles in a gas."@en ;
  dcterms:modified "2026-06-09T00:46:37.850260Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9098-3
  a curric:KeyLearningPoint ;
  rdfs:label "Pressure × volume = constant (pV = constant)."@en ;
  dcterms:modified "2026-06-09T00:46:37.850265Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9098-4
  a curric:KeyLearningPoint ;
  rdfs:label "When a gas expands, its particles do work on the surrounding air."@en ;
  dcterms:modified "2026-06-09T00:46:37.850270Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9098-5
  a curric:KeyLearningPoint ;
  rdfs:label "Doing work on a gas can increase its temperature."@en ;
  dcterms:modified "2026-06-09T00:46:37.850276Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9934-1
  a curric:KeyLearningPoint ;
  rdfs:label "When an object moves upwards, work is done against the gravitational force."@en ;
  dcterms:modified "2026-06-09T00:46:37.850311Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9934-2
  a curric:KeyLearningPoint ;
  rdfs:label """The gravitational force acting on an object does work to speed it up when it is
  falling."""@en ;
  dcterms:modified "2026-06-09T00:46:37.850316Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9934-3
  a curric:KeyLearningPoint ;
  rdfs:label "Weight = mass x gravitational field strength, W = mg"@en ;
  dcterms:modified "2026-06-09T00:46:37.850321Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9934-4
  a curric:KeyLearningPoint ;
  rdfs:label """Gravitational potential energy of an object = mass × gravitational field strength ×
