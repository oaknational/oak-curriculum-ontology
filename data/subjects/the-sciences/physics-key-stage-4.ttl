  use the measurements to calculate and plot graphs of displacement, velocity and
  acceleration."""@en ;
  dcterms:modified "2026-06-09T00:46:04.287232Z"^^xsd:dateTime .

oakcurric:keyword-oscilloscope
  a curric:Keyword ;
  schema:name "oscilloscope"@en ;
  schema:description "A piece of equipment that can display a representation of a sound wave."@en ;
  dcterms:modified "2026-06-09T00:46:04.287249Z"^^xsd:dateTime .

oakcurric:keyword-motor-effect
  a curric:Keyword ;
  schema:name "motor effect"@en ;
  schema:description "The effect of causing movement between a magnet and an electromagnet."@en ;
  dcterms:modified "2026-06-09T00:46:04.287254Z"^^xsd:dateTime .

oakcurric:keyword-moving-coil-loudspeaker
  a curric:Keyword ;
  schema:name "moving-coil loudspeaker"@en ;
  schema:description "A loudspeaker that produces sound using the motor effect."@en ;
  dcterms:modified "2026-06-09T00:46:04.287261Z"^^xsd:dateTime .

oakcurric:keyword-generator-effect
  a curric:Keyword ;
  schema:name "generator effect"@en ;
  schema:description """The effect of inducing a current by the relative movement of a circuit and a
  magnetic field."""@en ;
  dcterms:modified "2026-06-09T00:46:04.287266Z"^^xsd:dateTime .

oakcurric:keyword-moving-coil-microphone
  a curric:Keyword ;
  schema:name "moving-coil microphone"@en ;
  schema:description """A microphone that produces an electric signal from sound using the generator
  effect."""@en ;
  dcterms:modified "2026-06-09T00:46:04.287271Z"^^xsd:dateTime .

oakcurric:keyword-branch
  a curric:Keyword ;
  schema:name "branch"@en ;
