oakcurric:keyword-dynamics-trolley
  a curric:Keyword ;
  schema:name "dynamics trolley"@en ;
  schema:description """A dynamics trolley is a wheeled device used in experiments to study motion,
  designed to move smoothly over flat surfaces."""@en ;
  dcterms:modified "2026-06-09T00:46:04.287213Z"^^xsd:dateTime .

oakcurric:keyword-average-speed
  a curric:Keyword ;
  schema:name "average speed"@en ;
  schema:description """The average speed of an object is the total distance travelled divided by
