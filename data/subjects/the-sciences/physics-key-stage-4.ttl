# ----------------------------------------------------------------------
# Keywords
# ----------------------------------------------------------------------

oakcurric:keyword-range
  a curric:Keyword ;
  schema:name "range"@en ;
  schema:description "the range of pitches that an instrument is capable of playing"@en ;
  dcterms:modified "2026-06-09T00:46:04.263948Z"^^xsd:dateTime .

oakcurric:keyword-gravitational-force
  a curric:Keyword ;
  schema:name "gravitational force"@en ;
  schema:description "The gravitational force on something pulls it downwards, towards Earth."@en ;
  dcterms:modified "2026-06-09T00:46:04.265282Z"^^xsd:dateTime .

oakcurric:keyword-resultant-force
  a curric:Keyword ;
  schema:name "resultant force"@en ;
  schema:description """A resultant force is the overall effect of a set of forces on an object,
  taking their directions into account."""@en ;
  dcterms:modified "2026-06-09T00:46:04.265292Z"^^xsd:dateTime .

oakcurric:keyword-terminal-velocity
  a curric:Keyword ;
  schema:name "terminal velocity"@en ;
  schema:description """An object reaches a terminal velocity when the drag and gravitational forces
  are equal."""@en ;
  dcterms:modified "2026-06-09T00:46:04.265304Z"^^xsd:dateTime .

oakcurric:keyword-prefix
  a curric:Keyword ;
  schema:name "prefix"@en ;
  schema:description """a letter or group of letters added to the start of a root word to change its
  meaning"""@en ;
  dcterms:modified "2026-06-09T00:46:04.265659Z"^^xsd:dateTime .

oakcurric:keyword-displacement-time-graph
  a curric:Keyword ;
  schema:name "displacement-time graph"@en ;
  schema:description """A displacement–time graph shows the displacement of an object over a period
  of time."""@en ;
  dcterms:modified "2026-06-09T00:46:04.266357Z"^^xsd:dateTime .

oakcurric:keyword-velocity-time-graph
  a curric:Keyword ;
  schema:name "velocity-time graph"@en ;
  schema:description """A velocity–time graph shows the velocity of an object over a period
  of time."""@en ;
  dcterms:modified "2026-06-09T00:46:04.266364Z"^^xsd:dateTime .

oakcurric:keyword-velocity
  a curric:Keyword ;
  schema:name "velocity"@en ;
  schema:description """The acceleration of an object is the rate of change of velocity. This is how
  much the velocity changes per second."""@en ;
  dcterms:modified "2026-06-09T00:46:04.266369Z"^^xsd:dateTime .

oakcurric:keyword-acceleration
  a curric:Keyword ;
  schema:name "acceleration"@en ;
  schema:description """The acceleration of an object is the rate of change of velocity. This is how
  much the velocity changes per second."""@en ;
  dcterms:modified "2026-06-09T00:46:04.266374Z"^^xsd:dateTime .

oakcurric:keyword-stopping-forces
  a curric:Keyword ;
  schema:name "stopping forces"@en ;
  schema:description "Forces used to bring moving objects to a stop."@en ;
  dcterms:modified "2026-06-09T00:46:04.266819Z"^^xsd:dateTime .

oakcurric:keyword-stopping-time
  a curric:Keyword ;
  schema:name "stopping time"@en ;
  schema:description "The time taken for a moving object to stop."@en ;
  dcterms:modified "2026-06-09T00:46:04.266824Z"^^xsd:dateTime .

oakcurric:keyword-momentum
  a curric:Keyword ;
  schema:name "momentum"@en ;
  schema:description "The product of the mass and velocity of a moving object, p = m × v."@en ;
  dcterms:modified "2026-06-09T00:46:04.266831Z"^^xsd:dateTime .

oakcurric:keyword-crumple-zones
  a curric:Keyword ;
  schema:name "crumple zones"@en ;
  schema:description """Parts of a car designed to crumple during impacts, increasing the stopping
  time and reducing the stopping forces."""@en ;
  dcterms:modified "2026-06-09T00:46:04.266838Z"^^xsd:dateTime .

oakcurric:keyword-airbags
  a curric:Keyword ;
  schema:name "airbags"@en ;
  schema:description """These inflate rapidly in collisions and protect passengers from impacts with
  hard surfaces."""@en ;
  dcterms:modified "2026-06-09T00:46:04.266843Z"^^xsd:dateTime .

oakcurric:keyword-accurate
  a curric:Keyword ;
  schema:name "accurate"@en ;
  schema:description "Accurate measurements are those that are close to the true value."@en ;
  dcterms:modified "2026-06-09T00:46:04.266978Z"^^xsd:dateTime .

oakcurric:keyword-atom
  a curric:Keyword ;
  schema:name "atom"@en ;
  schema:description "An atom is the building block of all matter."@en ;
  dcterms:modified "2026-06-09T00:46:04.267263Z"^^xsd:dateTime .

oakcurric:keyword-heating
  a curric:Keyword ;
  schema:name "heating"@en ;
  schema:description "causes the particles of a substance to move or vibrate more rapidly"@en ;
  dcterms:modified "2026-06-09T00:46:04.267307Z"^^xsd:dateTime .

oakcurric:keyword-thermal-conduction
  a curric:Keyword ;
  schema:name "thermal conduction"@en ;
  schema:description """the transfer of energy through a material due to collisions between moving
  or vibrating particles"""@en ;
  dcterms:modified "2026-06-09T00:46:04.267312Z"^^xsd:dateTime .

oakcurric:keyword-thermal-insulation
  a curric:Keyword ;
  schema:name "thermal insulation"@en ;
  schema:description "reduces the transfer of energy by thermal conduction"@en ;
  dcterms:modified "2026-06-09T00:46:04.267317Z"^^xsd:dateTime .

oakcurric:keyword-thermal-conductors
  a curric:Keyword ;
  schema:name "thermal conductors"@en ;
  schema:description "substances that transfer energy by thermal conduction quickly"@en ;
  dcterms:modified "2026-06-09T00:46:04.267321Z"^^xsd:dateTime .

oakcurric:keyword-thermal-insulators
  a curric:Keyword ;
  schema:name "thermal insulators"@en ;
  schema:description """substances that transfer energy by thermal conduction slowly or not
  at all"""@en ;
  dcterms:modified "2026-06-09T00:46:04.267326Z"^^xsd:dateTime .

oakcurric:keyword-star
  a curric:Keyword ;
  schema:name "star"@en ;
  schema:description """the arrangement (usually physical) of a network where devices are connected
  through a central point"""@en ;
  dcterms:modified "2026-06-09T00:46:04.267408Z"^^xsd:dateTime .

oakcurric:keyword-wave-medium
  a curric:Keyword ;
  schema:name "wave medium"@en ;
  schema:description "the wave medium is the material that a wave can move through."@en ;
  dcterms:modified "2026-06-09T00:46:04.267435Z"^^xsd:dateTime .

oakcurric:keyword-displacement
  a curric:Keyword ;
  schema:name "displacement"@en ;
  schema:description """displacement at a point of a wave is the distance that the wave medium is
  from its rest position."""@en ;
  dcterms:modified "2026-06-09T00:46:04.267440Z"^^xsd:dateTime .

oakcurric:keyword-period-of-a-wave
  a curric:Keyword ;
  schema:name "period (of a wave)"@en ;
  schema:description """period (of a wave), T, is the time for a complete wave to pass any point,
  which is the same as the time to make one complete wave."""@en ;
  dcterms:modified "2026-06-09T00:46:04.267444Z"^^xsd:dateTime .

oakcurric:keyword-frequency
  a curric:Keyword ;
  schema:name "frequency"@en ;
  schema:description """frequency is the number of waves produced each second. Frequency is measured
  in Hertz (Hz)."""@en ;
  dcterms:modified "2026-06-09T00:46:04.267449Z"^^xsd:dateTime .

oakcurric:keyword-power
  a curric:Keyword ;
  schema:name "power"@en ;
  schema:description "having control or authority over something or someone"@en ;
  dcterms:modified "2026-06-09T00:46:04.267836Z"^^xsd:dateTime .

oakcurric:keyword-temperature
  a curric:Keyword ;
  schema:name "temperature"@en ;
  schema:description """a measure of how hot a substance is; it is related to the kinetic energy of
  the individual particles"""@en ;
  dcterms:modified "2026-06-09T00:46:04.268055Z"^^xsd:dateTime .

oakcurric:keyword-specific-heat-capacity
  a curric:Keyword ;
  schema:name "specific heat capacity"@en ;
  schema:description """the change in internal energy when the temperature of 1 kg of the material
  changes by 1°C"""@en ;
  dcterms:modified "2026-06-09T00:46:04.268060Z"^^xsd:dateTime .

oakcurric:keyword-internal-energy
  a curric:Keyword ;
  schema:name "internal energy"@en ;
  schema:description """the sum of the kinetic energy and potential energy of the particles
  something is made of"""@en ;
  dcterms:modified "2026-06-09T00:46:04.268065Z"^^xsd:dateTime .

oakcurric:keyword-kinetic-energy
  a curric:Keyword ;
  schema:name "kinetic energy"@en ;
  schema:description "the energy an object has because of it's motion"@en ;
  dcterms:modified "2026-06-09T00:46:04.268070Z"^^xsd:dateTime .

oakcurric:keyword-potential-energy
  a curric:Keyword ;
  schema:name "potential energy"@en ;
  schema:description """the energy an object has because of its position and the forces
  acting on it"""@en ;
  dcterms:modified "2026-06-09T00:46:04.268075Z"^^xsd:dateTime .

oakcurric:keyword-fossil-fuels
  a curric:Keyword ;
  schema:name "fossil fuels"@en ;
  schema:description """coal, oil, and natural gas, formed from the remains of ancient plants and
  animals over millions of years"""@en ;
  dcterms:modified "2026-06-09T00:46:04.268367Z"^^xsd:dateTime .

oakcurric:keyword-carbon-emissions
  a curric:Keyword ;
  schema:name "carbon emissions"@en ;
  schema:description "volume of carbon produced contributing to global warming"@en ;
  dcterms:modified "2026-06-09T00:46:04.268383Z"^^xsd:dateTime .

oakcurric:keyword-nucleus
  a curric:Keyword ;
  schema:name "nucleus"@en ;
  schema:description """A nucleus is found in the centre of an atom. It consists of protons and
  neutrons. It is significantly smaller in size than the atom."""@en ;
  dcterms:modified "2026-06-09T00:46:04.268934Z"^^xsd:dateTime .

oakcurric:keyword-refraction
  a curric:Keyword ;
  schema:name "refraction"@en ;
  schema:description """Refraction occurs when waves travel from one transparent medium to another,
  causing a change in wave speed and direction."""@en ;
  dcterms:modified "2026-06-09T00:46:04.269518Z"^^xsd:dateTime .

oakcurric:keyword-normal
  a curric:Keyword ;
  schema:name "normal"@en ;
  schema:description "The normal is an imaginary line drawn at 90° to a surface."@en ;
  dcterms:modified "2026-06-09T00:46:04.269523Z"^^xsd:dateTime .

oakcurric:keyword-angle-of-incidence
  a curric:Keyword ;
  schema:name "angle of incidence"@en ;
  schema:description """The angle of incidence is the angle between the incident ray and the
  normal."""@en ;
  dcterms:modified "2026-06-09T00:46:04.269528Z"^^xsd:dateTime .

oakcurric:keyword-angle-of-refraction
  a curric:Keyword ;
  schema:name "angle of refraction"@en ;
  schema:description """The angle of refraction is the angle between the refracted ray and the
  normal."""@en ;
  dcterms:modified "2026-06-09T00:46:04.269537Z"^^xsd:dateTime .

oakcurric:keyword-wavefront
  a curric:Keyword ;
  schema:name "wavefront"@en ;
  schema:description "Wavefronts are lines drawn to represent the peaks of a wave."@en ;
  dcterms:modified "2026-06-09T00:46:04.269543Z"^^xsd:dateTime .

oakcurric:keyword-efficiency
  a curric:Keyword ;
  schema:name "efficiency"@en ;
  schema:description "working in an organised way that doesn't waste time and resources"@en ;
  dcterms:modified "2026-06-09T00:46:04.269725Z"^^xsd:dateTime .

oakcurric:keyword-gradient
  a curric:Keyword ;
  schema:name "gradient"@en ;
  schema:description """The gradient on a displacement-time graph gives the instantaneous
  velocity."""@en ;
  dcterms:modified "2026-06-09T00:46:04.270401Z"^^xsd:dateTime .

oakcurric:keyword-tangent
  a curric:Keyword ;
  schema:name "tangent"@en ;
  schema:description """A tangent drawn to the gradient on a curving displacement-time graph will
  give the instantaneous velocity."""@en ;
  dcterms:modified "2026-06-09T00:46:04.270406Z"^^xsd:dateTime .

oakcurric:keyword-instantaneous-velocity
  a curric:Keyword ;
  schema:name "instantaneous velocity"@en ;
  schema:description """The instantaneous velocity is the velocity of an object at a particular
  moment in time."""@en ;
  dcterms:modified "2026-06-09T00:46:04.270410Z"^^xsd:dateTime .

oakcurric:keyword-proportion
  a curric:Keyword ;
  schema:name "proportion"@en ;
  schema:description "the size relationship between different elements of a design"@en ;
  dcterms:modified "2026-06-09T00:46:04.270665Z"^^xsd:dateTime .

oakcurric:keyword-reaction-time
  a curric:Keyword ;
  schema:name "reaction time"@en ;
  schema:description """the time taken to initiate a response to a stimulus, i.e. the time from the
  initiation of the stimulus"""@en ;
  dcterms:modified "2026-06-09T00:46:04.271006Z"^^xsd:dateTime .

oakcurric:keyword-tension
  a curric:Keyword ;
  schema:name "tension"@en ;
  schema:description "a feeling of nervousness that makes you unable to relax"@en ;
  dcterms:modified "2026-06-09T00:46:04.271202Z"^^xsd:dateTime .

oakcurric:keyword-air-track
  a curric:Keyword ;
  schema:name "air track"@en ;
  schema:description """A track which uses a cushion of air to reduce frictional forces in
  experiments."""@en ;
  dcterms:modified "2026-06-09T00:46:04.271791Z"^^xsd:dateTime .

oakcurric:keyword-directly-proportional
  a curric:Keyword ;
  schema:name "directly proportional"@en ;
  schema:description """A relationship where one value is a constant multiple of the other,
  represented by y ∝ x."""@en ;
  dcterms:modified "2026-06-09T00:46:04.271796Z"^^xsd:dateTime .

oakcurric:keyword-inversely-proportional
  a curric:Keyword ;
  schema:name "inversely proportional"@en ;
  schema:description """A relationship where one value is a constant multiple of the other,
  represented by y ∝ 1/x."""@en ;
  dcterms:modified "2026-06-09T00:46:04.271800Z"^^xsd:dateTime .

oakcurric:keyword-newtons-second-law-of-motion
  a curric:Keyword ;
  schema:name "Newton's Second Law of Motion"@en ;
  schema:description """Newton's Second Law of motion states that the acceleration of an object is
  directly proportional to the resultant force acting on it and inversely proportional to
  its mass."""@en ;
  dcterms:modified "2026-06-09T00:46:04.271805Z"^^xsd:dateTime .

oakcurric:keyword-displacementtime-graph
  a curric:Keyword ;
  schema:name "displacement–time graph"@en ;
  schema:description """A displacement–time graph shows the displacement of an object over a period
  of time."""@en ;
  dcterms:modified "2026-06-09T00:46:04.272174Z"^^xsd:dateTime .

oakcurric:keyword-velocitytime-graph
  a curric:Keyword ;
  schema:name "velocity–time graph"@en ;
  schema:description """A velocity–time graph shows the velocity of an object over a period
  of time."""@en ;
  dcterms:modified "2026-06-09T00:46:04.272179Z"^^xsd:dateTime .

oakcurric:keyword-energy-transfer
  a curric:Keyword ;
  schema:name "energy transfer"@en ;
  schema:description """An energy transfer takes place when the amount of energy in some stores
  decreases and increases in others."""@en ;
  dcterms:modified "2026-06-09T00:46:04.274506Z"^^xsd:dateTime .

oakcurric:keyword-rate
  a curric:Keyword ;
  schema:name "rate"@en ;
  schema:description "a measure of how much change occurs per unit of time"@en ;
  dcterms:modified "2026-06-09T00:46:04.274727Z"^^xsd:dateTime .

oakcurric:keyword-control-variable
  a curric:Keyword ;
  schema:name "control variable"@en ;
  schema:description "a factor that is kept the same during an experiment"@en ;
  dcterms:modified "2026-06-09T00:46:04.274751Z"^^xsd:dateTime .

oakcurric:keyword-magnitude
  a curric:Keyword ;
  schema:name "magnitude"@en ;
  schema:description "a measure of the energy released by an earthquake"@en ;
  dcterms:modified "2026-06-09T00:46:04.275585Z"^^xsd:dateTime .

oakcurric:keyword-resistance
  a curric:Keyword ;
  schema:name "resistance"@en ;
  schema:description "the opposition to the flow of current"@en ;
  dcterms:modified "2026-06-09T00:46:04.275777Z"^^xsd:dateTime .

oakcurric:keyword-initial-velocity-u
  a curric:Keyword ;
  schema:name "initial velocity, u"@en ;
  schema:description """is the velocity of an object at the start of a phase of motion, represented
  by u"""@en ;
  dcterms:modified "2026-06-09T00:46:04.276142Z"^^xsd:dateTime .

oakcurric:keyword-final-velocity-v
  a curric:Keyword ;
  schema:name "final velocity, v"@en ;
  schema:description """is the velocity of an object at the end of a phase of motion, represented by
  v"""@en ;
  dcterms:modified "2026-06-09T00:46:04.276149Z"^^xsd:dateTime .

oakcurric:keyword-rate-of-change-of-momentum
  a curric:Keyword ;
  schema:name "rate of change of momentum"@en ;
  schema:description """is the change in momentum per second, this is equal to the resultant force
  acting on an object"""@en ;
  dcterms:modified "2026-06-09T00:46:04.276154Z"^^xsd:dateTime .

oakcurric:keyword-kinetic-store
  a curric:Keyword ;
  schema:name "kinetic store"@en ;
  schema:description "Objects that are moving have a kinetic store of energy."@en ;
  dcterms:modified "2026-06-09T00:46:04.276247Z"^^xsd:dateTime .

oakcurric:keyword-gravitational-store
  a curric:Keyword ;
  schema:name "gravitational store"@en ;
  schema:description "Objects that are raised up have a gravitational store of energy."@en ;
  dcterms:modified "2026-06-09T00:46:04.276251Z"^^xsd:dateTime .

oakcurric:keyword-elastic-store
  a curric:Keyword ;
  schema:name "elastic store"@en ;
  schema:description "Objects that are stretched or squashed have an elastic store of energy."@en ;
  dcterms:modified "2026-06-09T00:46:04.276256Z"^^xsd:dateTime .

oakcurric:keyword-particle
  a curric:Keyword ;
  schema:name "particle"@en ;
  schema:description "the smallest part of a substance"@en ;
  dcterms:modified "2026-06-09T00:46:04.276945Z"^^xsd:dateTime .

oakcurric:keyword-mass
  a curric:Keyword ;
  schema:name "mass"@en ;
  schema:description "Mass is the amount of matter in an object, usually measured in grams."@en ;
  dcterms:modified "2026-06-09T00:46:04.277888Z"^^xsd:dateTime .

oakcurric:keyword-absorption
  a curric:Keyword ;
  schema:name "absorption"@en ;
  schema:description """Absorption is the process of moving nutrients from the digestive system into
  the blood."""@en ;
  dcterms:modified "2026-06-09T00:46:04.277999Z"^^xsd:dateTime .

oakcurric:keyword-significant-figures
  a curric:Keyword ;
  schema:name "Significant figures"@en ;
  schema:description """Significant figures are the digits in a number that contribute to the
  accuracy of the number."""@en ;
  dcterms:modified "2026-06-09T00:46:04.278463Z"^^xsd:dateTime .

oakcurric:keyword-compression
  a curric:Keyword ;
  schema:name "compression"@en ;
  schema:description "the process of reducing file size"@en ;
  dcterms:modified "2026-06-09T00:46:04.278853Z"^^xsd:dateTime .

oakcurric:keyword-electrostatic-force
  a curric:Keyword ;
  schema:name "electrostatic force"@en ;
  schema:description "The electrostatic force is a force that acts between charges."@en ;
  dcterms:modified "2026-06-09T00:46:04.279944Z"^^xsd:dateTime .

oakcurric:keyword-weight
  a curric:Keyword ;
  schema:name "weight"@en ;
  schema:description """the measure of how heavy an individual is, typically influenced by factors
  such as body composition and overall health"""@en ;
  dcterms:modified "2026-06-09T00:46:04.280250Z"^^xsd:dateTime .

oakcurric:keyword-fluid
  a curric:Keyword ;
  schema:name "fluid"@en ;
  schema:description """Something that is fluid does not have a fixed shape or pattern and flows
  freely."""@en ;
  dcterms:modified "2026-06-09T00:46:04.281564Z"^^xsd:dateTime .

oakcurric:keyword-independent-variable
  a curric:Keyword ;
  schema:name "independent variable"@en ;
  schema:description "the single variable that is changed in an investigation"@en ;
  dcterms:modified "2026-06-09T00:46:04.282336Z"^^xsd:dateTime .

oakcurric:keyword-dependent-variable
  a curric:Keyword ;
  schema:name "dependent variable"@en ;
  schema:description "the single variable that is measured or observed in an investigation"@en ;
  dcterms:modified "2026-06-09T00:46:04.282343Z"^^xsd:dateTime .

oakcurric:keyword-filament-lamp
  a curric:Keyword ;
  schema:name "filament lamp"@en ;
  schema:description "a type of lamp that uses a hot wire to emit light"@en ;
  dcterms:modified "2026-06-09T00:46:04.282394Z"^^xsd:dateTime .

oakcurric:keyword-variable-resistor
  a curric:Keyword ;
  schema:name "variable resistor"@en ;
  schema:description "a resistor that can be easily changed to any value in its range"@en ;
  dcterms:modified "2026-06-09T00:46:04.282399Z"^^xsd:dateTime .

oakcurric:keyword-repeat-reading
  a curric:Keyword ;
  schema:name "repeat reading"@en ;
  schema:description "when a measurement is taken again to improve the experiment"@en ;
  dcterms:modified "2026-06-09T00:46:04.282404Z"^^xsd:dateTime .

oakcurric:keyword-best-fit-line
  a curric:Keyword ;
  schema:name "best fit line"@en ;
  schema:description """a line that shows the underlying trend of a set of results on a graph, it
  can be straight or curved"""@en ;
  dcterms:modified "2026-06-09T00:46:04.282408Z"^^xsd:dateTime .

oakcurric:keyword-random
  a curric:Keyword ;
  schema:name "random"@en ;
  schema:description "to happen entirely by chance"@en ;
  dcterms:modified "2026-06-09T00:46:04.282413Z"^^xsd:dateTime .

oakcurric:keyword-radioactive-decay
  a curric:Keyword ;
  schema:name "radioactive decay"@en ;
  schema:description "a random process by which unstable nuclei emit radiation"@en ;
  dcterms:modified "2026-06-09T00:46:04.282417Z"^^xsd:dateTime .

oakcurric:keyword-decay-curve
  a curric:Keyword ;
  schema:name "decay curve"@en ;
  schema:description """shows the pattern in radioactive decay for a large set of identical unstable
  nuclei"""@en ;
  dcterms:modified "2026-06-09T00:46:04.282422Z"^^xsd:dateTime .

oakcurric:keyword-radioactive-half-life
  a curric:Keyword ;
  schema:name "radioactive half-life"@en ;
  schema:description "the time taken for half the nuclei of a radioactive isotope to decay"@en ;
  dcterms:modified "2026-06-09T00:46:04.282490Z"^^xsd:dateTime .

oakcurric:keyword-joules-kilogram-degrees-c
  a curric:Keyword ;
  schema:name "joules / kilogram degrees C"@en ;
  schema:description "The unit for the specific heat capacity of a material (J/kg ºC)."@en ;
  dcterms:modified "2026-06-09T00:46:04.282565Z"^^xsd:dateTime .

oakcurric:keyword-immersion-heater
  a curric:Keyword ;
  schema:name "immersion heater"@en ;
  schema:description """An electrical heating element which can be submerged in liquid to
  heat it."""@en ;
  dcterms:modified "2026-06-09T00:46:04.282572Z"^^xsd:dateTime .

oakcurric:keyword-joulemeter
  a curric:Keyword ;
  schema:name "joulemeter"@en ;
  schema:description "A meter which measures the energy transferred by an electric current."@en ;
  dcterms:modified "2026-06-09T00:46:04.282577Z"^^xsd:dateTime .

oakcurric:keyword-conservation-of-energy
  a curric:Keyword ;
  schema:name "conservation of energy"@en ;
  schema:description """A principle which states that the total amount of energy is the same before
  and after any transfer."""@en ;
  dcterms:modified "2026-06-09T00:46:04.282581Z"^^xsd:dateTime .

oakcurric:keyword-electromagnet
  a curric:Keyword ;
  schema:name "electromagnet"@en ;
  schema:description """A magnet made by running current through a coil of wire round an
  iron core."""@en ;
  dcterms:modified "2026-06-09T00:46:04.283460Z"^^xsd:dateTime .

oakcurric:keyword-temporary-magnet
  a curric:Keyword ;
  schema:name "temporary magnet"@en ;
  schema:description """An electromagnet that loses its magnetism when current stops flowing through
  it."""@en ;
  dcterms:modified "2026-06-09T00:46:04.283465Z"^^xsd:dateTime .

oakcurric:keyword-electric-lock
  a curric:Keyword ;
  schema:name "electric lock"@en ;
  schema:description "A lock that can be opened with an electromagnet when a switch is closed."@en ;
  dcterms:modified "2026-06-09T00:46:04.283470Z"^^xsd:dateTime .

oakcurric:keyword-electric-bell
  a curric:Keyword ;
  schema:name "electric bell"@en ;
  schema:description """A bell that uses an electromagnet to strike a clapper on the bell and which
  resets itself to keep ringing."""@en ;
  dcterms:modified "2026-06-09T00:46:04.283474Z"^^xsd:dateTime .

oakcurric:keyword-electric-motor
  a curric:Keyword ;
  schema:name "electric motor"@en ;
  schema:description "A motor that uses a magnetic field to produce a force."@en ;
  dcterms:modified "2026-06-09T00:46:04.283487Z"^^xsd:dateTime .

oakcurric:keyword-melting
  a curric:Keyword ;
  schema:name "melting"@en ;
  schema:description """the change of state from a solid to a liquid that happens at a fixed
  temperature for pure substances"""@en ;
  dcterms:modified "2026-06-09T00:46:04.283492Z"^^xsd:dateTime .

oakcurric:keyword-boiling
  a curric:Keyword ;
  schema:name "boiling"@en ;
  schema:description """the change of state from a liquid to a gas that happens at a fixed
  temperature for pure substances"""@en ;
  dcterms:modified "2026-06-09T00:46:04.283497Z"^^xsd:dateTime .

oakcurric:keyword-change-of-state
  a curric:Keyword ;
  schema:name "change of state"@en ;
  schema:description "changing from a solid to a liquid or liquid to gas (or the reverse)"@en ;
  dcterms:modified "2026-06-09T00:46:04.283501Z"^^xsd:dateTime .

oakcurric:keyword-mean
  a curric:Keyword ;
  schema:name "mean"@en ;
  schema:description """A measure of average where all values are added together and divided by the
  number of repeat measurements that have been taken."""@en ;
  dcterms:modified "2026-06-09T00:46:04.283734Z"^^xsd:dateTime .

oakcurric:keyword-drag
  a curric:Keyword ;
  schema:name "drag"@en ;
  schema:description """is a force of a fluid on an object moving through it, in the opposite
  direction to the object’s motion"""@en ;
  dcterms:modified "2026-06-09T00:46:04.284229Z"^^xsd:dateTime .

oakcurric:keyword-repeatable
  a curric:Keyword ;
  schema:name "repeatable"@en ;
  schema:description """A measurement is repeatable if the same (or similar) results are obtained
  when the same person repeats the investigation using the same method."""@en ;
  dcterms:modified "2026-06-09T00:46:04.284257Z"^^xsd:dateTime .

oakcurric:keyword-reproducible
  a curric:Keyword ;
  schema:name "reproducible"@en ;
  schema:description """A measurement is reproducible if the same (or similar) results are obtained
  when the same person repeats it using a different method, or a different person repeats it
  using the same method."""@en ;
  dcterms:modified "2026-06-09T00:46:04.284262Z"^^xsd:dateTime .

oakcurric:keyword-instantaneous-speed
  a curric:Keyword ;
  schema:name "instantaneous speed"@en ;
  schema:description """The instantaneous speed of an object is its speed at a particular moment in
  time."""@en ;
  dcterms:modified "2026-06-09T00:46:04.284267Z"^^xsd:dateTime .

oakcurric:keyword-uncertainty
  a curric:Keyword ;
  schema:name "uncertainty"@en ;
  schema:description """is the range of measurements within which the true value can be expected to
  be found. On apparatus, it is half the value of one resolution marking."""@en ;
  dcterms:modified "2026-06-09T00:46:04.284309Z"^^xsd:dateTime .

oakcurric:keyword-electric-charge
  a curric:Keyword ;
  schema:name "electric charge"@en ;
  schema:description "an electrical property; it can either be positive or negative"@en ;
  dcterms:modified "2026-06-09T00:46:04.284731Z"^^xsd:dateTime .

oakcurric:keyword-parallel-circuit
  a curric:Keyword ;
  schema:name "parallel circuit"@en ;
  schema:description "a circuit with separate branches connected to the battery"@en ;
  dcterms:modified "2026-06-09T00:46:04.284735Z"^^xsd:dateTime .

oakcurric:keyword-electric-field
  a curric:Keyword ;
  schema:name "electric field"@en ;
  schema:description """the invisible field around a charged object that causes other charges to
  experience a force"""@en ;
  dcterms:modified "2026-06-09T00:46:04.284740Z"^^xsd:dateTime .

oakcurric:keyword-potential-difference-pd
  a curric:Keyword ;
  schema:name "potential difference (p.d.)"@en ;
  schema:description "the voltage or a measure of the ‘push’ on electrons in a circuit"@en ;
  dcterms:modified "2026-06-09T00:46:04.284747Z"^^xsd:dateTime .

oakcurric:keyword-electric-current
  a curric:Keyword ;
  schema:name "electric current"@en ;
  schema:description "a measure of the amount of charge passing a given point in one second"@en ;
  dcterms:modified "2026-06-09T00:46:04.284754Z"^^xsd:dateTime .

oakcurric:keyword-extension
  a curric:Keyword ;
  schema:name "extension"@en ;
  schema:description "stretched and pointed fingers and toes"@en ;
  dcterms:modified "2026-06-09T00:46:04.284888Z"^^xsd:dateTime .

oakcurric:keyword-light-dependent-resistor
  a curric:Keyword ;
  schema:name "light-dependent resistor"@en ;
  schema:description """a semiconducting component with a resistance that gets lower in increasingly
  bright light"""@en ;
  dcterms:modified "2026-06-09T00:46:04.285077Z"^^xsd:dateTime .

oakcurric:keyword-semiconductor
  a curric:Keyword ;
  schema:name "semiconductor"@en ;
