  dcterms:modified "2026-06-09T00:46:04.287222Z"^^xsd:dateTime .

oakcurric:keyword-anomalous-reading
  a curric:Keyword ;
  schema:name "anomalous reading"@en ;
  schema:description """An anomalous reading is a result that is significantly outside the expected
  pattern in a set of results."""@en ;
  dcterms:modified "2026-06-09T00:46:04.287227Z"^^xsd:dateTime .

oakcurric:keyword-motion-sensor
  a curric:Keyword ;
