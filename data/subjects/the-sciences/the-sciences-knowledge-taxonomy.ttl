# ----------------------------------------------------------------------
# Ontology Declaration
# ----------------------------------------------------------------------

<https://w3id.org/uk/oak/curriculum/nationalcurriculum/the-sciences-knowledge-taxonomy>
  rdf:type owl:Ontology ;

  rdfs:label "National Curriculum for England - The Sciences Knowledge Taxonomy"@en ;
  dc:title "National Curriculum for England - The Sciences Knowledge Taxonomy"@en ;
  rdfs:comment """The Sciences knowledge taxonomy defining the hierarchical organisation of content
  from strands through to sub-content descriptors."""@en ;

  owl:versionInfo "0.1.1" ;
  owl:versionIRI <https://w3id.org/uk/oak/curriculum/nationalcurriculum/the-sciences-knowledge-taxonomy/0.1.1> ;

  dcterms:description """This file defines the The Sciences knowledge taxonomy for the National
  Curriculum in England, organising content through strands, sub-strands, content
  descriptors, and sub-content descriptors."""@en ;
  dc:creator "Department for Education" ;
  dcterms:created "2026-05-13T23:49:26Z"^^xsd:dateTime ;
  dcterms:modified "2026-05-13T23:49:26Z"^^xsd:dateTime ;
  dcterms:issued "2026-05-13T23:49:26Z"^^xsd:dateTime ;

  # OGL 3.0 License
  dcterms:license <http://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/> ;
  dcterms:rights "Crown Copyright"@en ;

  rdfs:seeAlso <https://w3id.org/uk/oak/curriculum/ontology> ;

  vann:preferredNamespacePrefix "natcurric" ;
  vann:preferredNamespaceUri "https://w3id.org/uk/oak/curriculum/nationalcurriculum/" ;

  owl:imports <https://w3id.org/uk/oak/curriculum/ontology> ;
  owl:imports <https://w3id.org/uk/oak/curriculum/nationalcurriculum/the-sciences-programme-structure> .

# ----------------------------------------------------------------------
# Knowledge Taxonomy
# ----------------------------------------------------------------------

natcurric:knowledge-taxonomy
  a skos:ConceptScheme ;
  skos:prefLabel "National Curriculum for England Knowledge Taxonomy"@en ;
  skos:hasTopConcept natcurric:discipline-the-sciences ;
  dcterms:modified "2026-05-13T23:49:26Z"^^xsd:dateTime .

# ----------------------------------------------------------------------
# Disciplines
# ----------------------------------------------------------------------

natcurric:discipline-the-sciences
  a skos:Concept, curric:Discipline ;
  skos:prefLabel "The Sciences"@en ;
  skos:topConceptOf natcurric:knowledge-taxonomy ;
  skos:narrower
    natcurric:strand-working-scientifically ,
    natcurric:strand-biology ,
    natcurric:strand-chemistry ,
    natcurric:strand-physics ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-05-13T23:49:26Z"^^xsd:dateTime .

