  dcterms:modified "2026-06-07T15:30:02.351626Z"^^xsd:dateTime .

oakcurric:keyword-adaptation
  a curric:Keyword ;
  schema:name "adaptation"@en ;
  schema:description """An adaptation is a feature that organisms have to help them live in a
  particular place."""@en ;
  dcterms:modified "2026-06-07T15:30:02.351940Z"^^xsd:dateTime .

oakcurric:keyword-ecosystem
  a curric:Keyword ;
