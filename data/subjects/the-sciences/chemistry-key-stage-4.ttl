  schema:description """The chromosomes that determine the reproductive and secondary sexual
  characteristics (i.e. X and Y)."""@en ;
  dcterms:modified "2026-06-07T15:30:02.416771Z"^^xsd:dateTime .

oakcurric:keyword-sex-hormone
  a curric:Keyword ;
