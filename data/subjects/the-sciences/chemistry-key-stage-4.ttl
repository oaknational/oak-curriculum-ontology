# ----------------------------------------------------------------------
# Keywords
# ----------------------------------------------------------------------

oakcurric:keyword-resolution
  a curric:Keyword ;
  schema:name "resolution"@en ;
  schema:description "the process of solving or ending a problem or disagreement"@en ;
  dcterms:modified "2026-06-09T00:46:04.264489Z"^^xsd:dateTime .

oakcurric:keyword-evaluate
  a curric:Keyword ;
  schema:name "evaluate"@en ;
  schema:description """to examine something closely and make a judgement about its
  effectiveness"""@en ;
  dcterms:modified "2026-06-09T00:46:04.264504Z"^^xsd:dateTime .

oakcurric:keyword-conclusion
  a curric:Keyword ;
  schema:name "conclusion"@en ;
  schema:description "the closing paragraph of a non-fiction text"@en ;
  dcterms:modified "2026-06-09T00:46:04.264961Z"^^xsd:dateTime .

oakcurric:keyword-atmosphere
  a curric:Keyword ;
  schema:name "atmosphere"@en ;
  schema:description "the mood created in a section or whole of a text"@en ;
  dcterms:modified "2026-06-09T00:46:04.265092Z"^^xsd:dateTime .

oakcurric:keyword-accuracy
  a curric:Keyword ;
  schema:name "accuracy"@en ;
  schema:description "being correct and precise"@en ;
  dcterms:modified "2026-06-09T00:46:04.265249Z"^^xsd:dateTime .

oakcurric:keyword-structure
  a curric:Keyword ;
  schema:name "structure"@en ;
  schema:description "how a piece of writing is sequenced"@en ;
  dcterms:modified "2026-06-09T00:46:04.265779Z"^^xsd:dateTime .

oakcurric:keyword-fraction
  a curric:Keyword ;
  schema:name "fraction"@en ;
  schema:description "A fraction shows us how many equal parts in a whole."@en ;
  dcterms:modified "2026-06-09T00:46:04.265913Z"^^xsd:dateTime .

oakcurric:keyword-subjective
  a curric:Keyword ;
  schema:name "subjective"@en ;
  schema:description """describes something that's based on a person's opinions, individual
  experiences, and biased influences"""@en ;
  dcterms:modified "2026-06-09T00:46:04.266170Z"^^xsd:dateTime .

oakcurric:keyword-qualitative-data
  a curric:Keyword ;
  schema:name "qualitative data"@en ;
  schema:description "descriptive, non-numerical information focusing on opinions"@en ;
  dcterms:modified "2026-06-09T00:46:04.266907Z"^^xsd:dateTime .

oakcurric:keyword-quantitative-data
  a curric:Keyword ;
  schema:name "quantitative data"@en ;
  schema:description "numerical information that can be measured or counted"@en ;
  dcterms:modified "2026-06-09T00:46:04.266911Z"^^xsd:dateTime .

oakcurric:keyword-rate-of-reaction
  a curric:Keyword ;
  schema:name "rate of reaction"@en ;
  schema:description """Rate of reaction is the speed with which a chemical reaction takes place,
  measured by the amount of a reactant used or amount of product formed in a given time."""@en ;
  dcterms:modified "2026-06-09T00:46:04.266969Z"^^xsd:dateTime .

oakcurric:keyword-volume
  a curric:Keyword ;
  schema:name "volume"@en ;
  schema:description """Volume is how much 3D space matter occupies. It is usually measured
  in cm³."""@en ;
  dcterms:modified "2026-06-09T00:46:04.266974Z"^^xsd:dateTime .

oakcurric:keyword-accurate
  a curric:Keyword ;
  schema:name "accurate"@en ;
  schema:description "Accurate measurements are those that are close to the true value."@en ;
  dcterms:modified "2026-06-09T00:46:04.266978Z"^^xsd:dateTime .

oakcurric:keyword-precise
  a curric:Keyword ;
  schema:name "precise"@en ;
  schema:description """Precise measurements have very little spread from the mean value. They are
  values that lie close to each other."""@en ;
  dcterms:modified "2026-06-09T00:46:04.266983Z"^^xsd:dateTime .

oakcurric:keyword-atom
  a curric:Keyword ;
  schema:name "atom"@en ;
  schema:description "An atom is the building block of all matter."@en ;
  dcterms:modified "2026-06-09T00:46:04.267263Z"^^xsd:dateTime .

oakcurric:keyword-element
  a curric:Keyword ;
  schema:name "element"@en ;
  schema:description "Each element is made up of only one type of atom."@en ;
  dcterms:modified "2026-06-09T00:46:04.267272Z"^^xsd:dateTime .

oakcurric:keyword-empirical-formula
  a curric:Keyword ;
  schema:name "empirical formula"@en ;
  schema:description "The simplest whole number ratio of atoms of each element in a compound."@en ;
  dcterms:modified "2026-06-09T00:46:04.267286Z"^^xsd:dateTime .

oakcurric:keyword-polyatomic-ions
  a curric:Keyword ;
  schema:name "polyatomic ions"@en ;
  schema:description "Ions that are made up of more than one type of atom."@en ;
  dcterms:modified "2026-06-09T00:46:04.267291Z"^^xsd:dateTime .

oakcurric:keyword-ide
  a curric:Keyword ;
  schema:name "\"–ide\""@en ;
  schema:description """The name ending for a compound with a metal and non–metal present, for
  example, potassium iodide (KI)."""@en ;
  dcterms:modified "2026-06-09T00:46:04.267298Z"^^xsd:dateTime .

oakcurric:keyword-ate
  a curric:Keyword ;
  schema:name "\"–ate\""@en ;
  schema:description """The name ending for a compound with three or more elements present (one of
  which is oxygen), for example, potassium sulfate (K₂SO₄)."""@en ;
  dcterms:modified "2026-06-09T00:46:04.267303Z"^^xsd:dateTime .

oakcurric:keyword-compound
  a curric:Keyword ;
  schema:name "compound"@en ;
  schema:description """A compound is made of two or more different elements chemically bonded
  together."""@en ;
  dcterms:modified "2026-06-09T00:46:04.267356Z"^^xsd:dateTime .

oakcurric:keyword-chemical-formula
  a curric:Keyword ;
  schema:name "chemical formula"@en ;
  schema:description """The chemical formula of a molecule is a shorthand way of listing the type
  and number of atoms in a compound."""@en ;
  dcterms:modified "2026-06-09T00:46:04.267363Z"^^xsd:dateTime .

oakcurric:keyword-chemical-composition
  a curric:Keyword ;
  schema:name "chemical composition"@en ;
  schema:description """The chemical composition tells you the different types of atoms in a
  chemical."""@en ;
  dcterms:modified "2026-06-09T00:46:04.267368Z"^^xsd:dateTime .

oakcurric:keyword-mixture
  a curric:Keyword ;
  schema:name "mixture"@en ;
  schema:description """A mixture is a material that contains two or more different substances that
  can be physically separated."""@en ;
  dcterms:modified "2026-06-09T00:46:04.267375Z"^^xsd:dateTime .

oakcurric:keyword-separate
  a curric:Keyword ;
  schema:name "separate"@en ;
  schema:description """In chemistry, to separate something is to extract and isolate a substance
  from a mixture."""@en ;
  dcterms:modified "2026-06-09T00:46:04.267380Z"^^xsd:dateTime .

oakcurric:keyword-property
  a curric:Keyword ;
  schema:name "property"@en ;
  schema:description """A property is a feature or characteristic of a substance that can be used to
  classify it or describe how it behaves."""@en ;
  dcterms:modified "2026-06-09T00:46:04.267384Z"^^xsd:dateTime .

oakcurric:keyword-displacement
  a curric:Keyword ;
  schema:name "displacement"@en ;
  schema:description """displacement at a point of a wave is the distance that the wave medium is
  from its rest position."""@en ;
  dcterms:modified "2026-06-09T00:46:04.267440Z"^^xsd:dateTime .

oakcurric:keyword-dna
  a curric:Keyword ;
  schema:name "DNA"@en ;
  schema:description """DNA is the chemical substance that genetic material is made out of; it
