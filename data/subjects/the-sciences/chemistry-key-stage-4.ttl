oakcurric:priorknowledge-972-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Redox reactions may be viewed in terms of gain or loss of oxygen or hydrogen, but
  also gain and loss of electrons."""@en ;
  dcterms:modified "2026-06-09T00:45:28.240417Z"^^xsd:dateTime .

oakcurric:priorknowledge-972-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Carbon can be used to extract some metals (e.g. iron and copper) from their ores,
  e.g. copper oxide plus carbon makes copper and carbon dioxide."""@en ;
  dcterms:modified "2026-06-09T00:45:28.240423Z"^^xsd:dateTime .

oakcurric:priorknowledge-972-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Hydrogen used in fuel cells can be extracted from fossil fuels or produced by
