  schema:description """a chemical that speeds up the rate of a reaction without itself being used
  up."""@en ;
  dcterms:modified "2026-06-09T00:46:04.300734Z"^^xsd:dateTime .

oakcurric:keyword-avogadros-constant
  a curric:Keyword ;
  schema:name "Avogadro's constant"@en ;
  schema:description """Avogadro's constant is the number of particles in one mole of a substance
  (6.02 × 10²³ mol⁻¹)"""@en ;
  dcterms:modified "2026-06-09T00:46:04.300857Z"^^xsd:dateTime .

oakcurric:keyword-limiting-reactant
  a curric:Keyword ;
