  dcterms:modified "2026-06-09T00:46:04.296796Z"^^xsd:dateTime .

oakcurric:keyword-raw-material
  a curric:Keyword ;
  schema:name "raw material"@en ;
  schema:description "a natural material in its original state"@en ;
  dcterms:modified "2026-06-09T00:46:04.296928Z"^^xsd:dateTime .

oakcurric:keyword-bonding
  a curric:Keyword ;
  schema:name "bonding"@en ;
