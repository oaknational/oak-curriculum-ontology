  dcterms:modified "2026-06-09T00:46:04.299354Z"^^xsd:dateTime .

oakcurric:keyword-meniscus
  a curric:Keyword ;
  schema:name "meniscus"@en ;
  schema:description """the curve that exists on the surface of a liquid when it is in a
  container"""@en ;
  dcterms:modified "2026-06-09T00:46:04.299411Z"^^xsd:dateTime .

oakcurric:keyword-transition-metal
  a curric:Keyword ;
