  dcterms:modified "2026-06-07T15:30:02.351617Z"^^xsd:dateTime .

oakcurric:keyword-reproducibility
  a curric:Keyword ;
  schema:name "reproducibility"@en ;
  schema:description """Similar results are obtained when an investigation is repeated by another
  person or group using different equipment."""@en ;
  dcterms:modified "2026-06-07T15:30:02.351621Z"^^xsd:dateTime .

oakcurric:keyword-fossil-fuels
