  dcterms:modified "2026-06-07T15:30:02.352054Z"^^xsd:dateTime .

oakcurric:keyword-electron
  a curric:Keyword ;
  schema:name "electron"@en ;
  schema:description """An electron is a subatomic particle with a negative charge and a very small
  relative mass of 1/1835 (negligible)."""@en ;
  dcterms:modified "2026-06-07T15:30:02.352163Z"^^xsd:dateTime .

oakcurric:keyword-proton
  a curric:Keyword ;
  schema:name "proton"@en ;
  schema:description """A proton is a subatomic particle with a positive charge and a relative
  atomic mass of 1."""@en ;
  dcterms:modified "2026-06-07T15:30:02.352167Z"^^xsd:dateTime .

oakcurric:keyword-neutron
  a curric:Keyword ;
  schema:name "neutron"@en ;
  schema:description """A neutron is a subatomic particle with no charge and a relative atomic mass
  of 1."""@en ;
  dcterms:modified "2026-06-07T15:30:02.352172Z"^^xsd:dateTime .

oakcurric:keyword-nucleus
  a curric:Keyword ;
  schema:name "nucleus"@en ;
  schema:description """A nucleus is found in the centre of an atom. It consists of protons and
  neutrons. It is significantly smaller in size than the atom."""@en ;
  dcterms:modified "2026-06-07T15:30:02.352176Z"^^xsd:dateTime .

oakcurric:keyword-subatomic
