  schema:description """A unit used to measure very small distances, equal to 10⁻⁹ metres or one
  billionth of a metre."""@en ;
  dcterms:modified "2026-06-07T15:30:02.416725Z"^^xsd:dateTime .

oakcurric:keyword-nanoparticle
  a curric:Keyword ;
