  rdfs:label "The particle model shows how solids, liquids and gases are organised together"@en ;
  dcterms:modified "2026-06-07T15:29:24.846048Z"^^xsd:dateTime .

oakcurric:priorknowledge-963-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Some acids are corrosive and can burn skin."@en ;
  dcterms:modified "2026-06-07T15:29:24.858000Z"^^xsd:dateTime .

oakcurric:priorknowledge-963-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """A base is a substance that reacts with acids and neutralises them to stop them being
  acidic."""@en ;
  dcterms:modified "2026-06-07T15:29:24.858016Z"^^xsd:dateTime .

oakcurric:priorknowledge-963-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "An alkali is a base that is dissolved in water."@en ;
  dcterms:modified "2026-06-07T15:29:24.858022Z"^^xsd:dateTime .

oakcurric:priorknowledge-963-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "The neutralisation reaction is: acid + base → salt + water"@en ;
  dcterms:modified "2026-06-07T15:29:24.858028Z"^^xsd:dateTime .

oakcurric:priorknowledge-963-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "When hydrochloric acid is neutralised, a chloride salt is formed."@en ;
  dcterms:modified "2026-06-07T15:29:24.858033Z"^^xsd:dateTime .

oakcurric:priorknowledge-963-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "When sulphuric acid is neutralised, a sulfate salt is formed."@en ;
  dcterms:modified "2026-06-07T15:29:24.858039Z"^^xsd:dateTime .

oakcurric:priorknowledge-963-7
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "When nitric acid is neutralised, a nitrate salt is formed."@en ;
  dcterms:modified "2026-06-07T15:29:24.858044Z"^^xsd:dateTime .

oakcurric:priorknowledge-963-8
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Metal + acid → salt + hydrogen"@en ;
  dcterms:modified "2026-06-07T15:29:24.858049Z"^^xsd:dateTime .

oakcurric:priorknowledge-963-9
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Metal hydroxide / metal oxide + acid → salt + water"@en ;
  dcterms:modified "2026-06-07T15:29:24.858054Z"^^xsd:dateTime .

oakcurric:priorknowledge-963-10
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Metal carbonate + acid → salt + water + carbon dioxide"@en ;
  dcterms:modified "2026-06-07T15:29:24.858059Z"^^xsd:dateTime .

oakcurric:priorknowledge-1149-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "An exothermic chemical reaction causes an increase in temperature."@en ;
  dcterms:modified "2026-06-07T15:29:24.859771Z"^^xsd:dateTime .

oakcurric:priorknowledge-1149-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "An endothermic chemical reaction causes a decrease in temperature."@en ;
  dcterms:modified "2026-06-07T15:29:24.859784Z"^^xsd:dateTime .

oakcurric:priorknowledge-1149-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "An exothermic reaction transfers energy from the reactants to the surroundings."@en ;
  dcterms:modified "2026-06-07T15:29:24.859790Z"^^xsd:dateTime .

oakcurric:priorknowledge-1149-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "An endothermic reaction transfers energy from the surroundings to the products."@en ;
  dcterms:modified "2026-06-07T15:29:24.859795Z"^^xsd:dateTime .

oakcurric:priorknowledge-1149-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Characteristics of chemical reactions include changes in colour, bubbling, or a
  change of temperature."""@en ;
  dcterms:modified "2026-06-07T15:29:24.859801Z"^^xsd:dateTime .

oakcurric:priorknowledge-1149-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """When a metal reacts with acid bubbles may form, the temperature rise and the metal
  reduce in size or disappear."""@en ;
  dcterms:modified "2026-06-07T15:29:24.859806Z"^^xsd:dateTime .

oakcurric:priorknowledge-1149-7
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "The neutralisation reaction is: base + acid ⭢ salt + water"@en ;
  dcterms:modified "2026-06-07T15:29:24.859811Z"^^xsd:dateTime .

oakcurric:priorknowledge-491-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "The current in a series circuit is the same everywhere."@en ;
  dcterms:modified "2026-06-07T15:29:24.861395Z"^^xsd:dateTime .

oakcurric:priorknowledge-491-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Adding a component to a series circuit changes the current everywhere, on both sides
  of the component."""@en ;
  dcterms:modified "2026-06-07T15:29:24.861407Z"^^xsd:dateTime .

oakcurric:priorknowledge-491-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The potential difference across each component in a series electric circuit adds up
  to the potential difference of the battery."""@en ;
  dcterms:modified "2026-06-07T15:29:24.861414Z"^^xsd:dateTime .

oakcurric:priorknowledge-491-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The potential difference across each branch of a parallel circuit is the same as the
  potential difference across the battery."""@en ;
  dcterms:modified "2026-06-07T15:29:24.861419Z"^^xsd:dateTime .

oakcurric:priorknowledge-491-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The current through each branch of a parallel circuit adds up to the current through
  the battery."""@en ;
  dcterms:modified "2026-06-07T15:29:24.861424Z"^^xsd:dateTime .

oakcurric:priorknowledge-491-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Current = potential difference / resistance"@en ;
  dcterms:modified "2026-06-07T15:29:24.861429Z"^^xsd:dateTime .

oakcurric:priorknowledge-497-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Atoms are the smallest parts that each element can be broken up into."@en ;
  dcterms:modified "2026-06-07T15:29:24.863061Z"^^xsd:dateTime .

oakcurric:priorknowledge-497-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Atoms used to be thought of as tiny spheres that could not be divided."@en ;
  dcterms:modified "2026-06-07T15:29:24.863080Z"^^xsd:dateTime .

oakcurric:priorknowledge-497-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The discovery of the electron (in 1897) led to the plum pudding model of the atom,
  for just a few years before new evidence led to a nuclear model of atoms."""@en ;
  dcterms:modified "2026-06-07T15:29:24.863087Z"^^xsd:dateTime .

oakcurric:priorknowledge-497-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "The atoms of each element are different."@en ;
  dcterms:modified "2026-06-07T15:29:24.863093Z"^^xsd:dateTime .

oakcurric:priorknowledge-497-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """An atom has a positively charged nucleus surrounded by negatively charged
  electrons."""@en ;
  dcterms:modified "2026-06-07T15:29:24.863099Z"^^xsd:dateTime .

oakcurric:priorknowledge-497-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "The radius of an atomic nucleus is much smaller than the radius of an atom."@en ;
  dcterms:modified "2026-06-07T15:29:24.863107Z"^^xsd:dateTime .

oakcurric:priorknowledge-497-7
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "An atomic nucleus consists of protons and neutrons."@en ;
  dcterms:modified "2026-06-07T15:29:24.863112Z"^^xsd:dateTime .

oakcurric:priorknowledge-497-8
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The atomic number of an element is equal to the number of protons in the nuclei of
  its atoms and the number of electrons in each atom."""@en ;
  dcterms:modified "2026-06-07T15:29:24.863117Z"^^xsd:dateTime .

oakcurric:priorknowledge-497-9
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The mass number of an atom is approximately equal to the number of protons added to
  the number of neutrons in its nucleus."""@en ;
  dcterms:modified "2026-06-07T15:29:24.863123Z"^^xsd:dateTime .

oakcurric:priorknowledge-497-10
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Isotopes of an element all have the same number of protons and electrons, but
  different numbers of neutrons."""@en ;
  dcterms:modified "2026-06-07T15:29:24.863128Z"^^xsd:dateTime .

oakcurric:priorknowledge-1073-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "All organisms are made up of one or more cells."@en ;
  dcterms:modified "2026-06-07T15:29:24.936077Z"^^xsd:dateTime .

oakcurric:priorknowledge-1073-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Organisms can be unicellular or multicellular."@en ;
  dcterms:modified "2026-06-07T15:29:24.936092Z"^^xsd:dateTime .

oakcurric:priorknowledge-1073-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The hierarchical organisation of multicellular organisms from cells to tissues to
  organs to systems to organisms."""@en ;
  dcterms:modified "2026-06-07T15:29:24.936098Z"^^xsd:dateTime .

oakcurric:priorknowledge-1073-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Similarities and differences between plant and animal cells."@en ;
  dcterms:modified "2026-06-07T15:29:24.936102Z"^^xsd:dateTime .

oakcurric:priorknowledge-1073-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The functions of the cell wall, cell membrane, cytoplasm, nucleus, vacuole,
  mitochondria and chloroplasts."""@en ;
  dcterms:modified "2026-06-07T15:29:24.936107Z"^^xsd:dateTime .

oakcurric:priorknowledge-493-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Arrows on magnetic field lines show the direction in which the north-seeking pole of
  another magnet would be forced."""@en ;
  dcterms:modified "2026-06-07T15:29:24.968704Z"^^xsd:dateTime .

oakcurric:priorknowledge-493-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Where a magnetic field is stronger, the field lines are closer together."@en ;
  dcterms:modified "2026-06-07T15:29:24.968719Z"^^xsd:dateTime .

oakcurric:priorknowledge-493-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """When there is an electric current in a wire, there is a magnetic field around the
  wire."""@en ;
  dcterms:modified "2026-06-07T15:29:24.968726Z"^^xsd:dateTime .

oakcurric:priorknowledge-493-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """When there is an electric current in a coil of wire, the magnetic field around each
  loop adds to make a stronger field."""@en ;
  dcterms:modified "2026-06-07T15:29:24.968732Z"^^xsd:dateTime .

oakcurric:priorknowledge-493-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "An electromagnet is made by wrapping a coil of wire around a core."@en ;
  dcterms:modified "2026-06-07T15:29:24.968737Z"^^xsd:dateTime .

oakcurric:priorknowledge-493-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """An electromagnet is a magnet that can be turned on with an electric current, and
  turned off."""@en ;
  dcterms:modified "2026-06-07T15:29:24.968742Z"^^xsd:dateTime .

oakcurric:priorknowledge-493-7
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The more loops of wire in the coil of an electromagnet, the stronger its magnetic
  field."""@en ;
  dcterms:modified "2026-06-07T15:29:24.968747Z"^^xsd:dateTime .

oakcurric:priorknowledge-493-8
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The larger the current through the coil of an electromagnet, the stronger its
  magnetic field."""@en ;
  dcterms:modified "2026-06-07T15:29:24.968753Z"^^xsd:dateTime .

oakcurric:priorknowledge-493-9
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The more tightly wound the coil of wire is in an electromagnet, the stronger its
  magnetic field."""@en ;
  dcterms:modified "2026-06-07T15:29:24.968758Z"^^xsd:dateTime .

oakcurric:priorknowledge-493-10
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """A soft iron core increases the strength of an electromagnet because it becomes
  magnetised when it is turned on."""@en ;
  dcterms:modified "2026-06-07T15:29:24.968763Z"^^xsd:dateTime .

oakcurric:priorknowledge-573-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Some substances can move into and out of cell by diffusing through the cell
  membrane."""@en ;
  dcterms:modified "2026-06-07T15:29:25.068181Z"^^xsd:dateTime .

oakcurric:priorknowledge-573-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Water moves between the blood and cells by osmosis, a type of diffusion."@en ;
  dcterms:modified "2026-06-07T15:29:25.068194Z"^^xsd:dateTime .

oakcurric:priorknowledge-573-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The net movement of particles by diffusion and osmosis is along a concentration
  gradient."""@en ;
  dcterms:modified "2026-06-07T15:29:25.068200Z"^^xsd:dateTime .

oakcurric:priorknowledge-573-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Enzymes are the catalysts for many chemical reactions in the body."@en ;
  dcterms:modified "2026-06-07T15:29:25.068206Z"^^xsd:dateTime .

oakcurric:priorknowledge-573-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Enzymes work best in optimum conditions and less well when conditions change away
  from the optimum."""@en ;
  dcterms:modified "2026-06-07T15:29:25.068211Z"^^xsd:dateTime .

oakcurric:priorknowledge-573-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Humans have a nervous system that that enables us to sense and respond quickly to
  changes outside and inside the body."""@en ;
  dcterms:modified "2026-06-07T15:29:25.068216Z"^^xsd:dateTime .

oakcurric:priorknowledge-573-7
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The human body has an endocrine system that uses hormones to control changes in the
  body."""@en ;
  dcterms:modified "2026-06-07T15:29:25.068226Z"^^xsd:dateTime .

oakcurric:priorknowledge-573-8
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The human endocrine and nervous systems work together to maintain a constant
  environment in the body."""@en ;
  dcterms:modified "2026-06-07T15:29:25.068231Z"^^xsd:dateTime .

oakcurric:priorknowledge-566-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Carbohydrates (including sugars), proteins and lipids/fats are the major food
  groups."""@en ;
  dcterms:modified "2026-06-07T15:29:25.069951Z"^^xsd:dateTime .

oakcurric:priorknowledge-566-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Photosynthesis in producers makes glucose, a type of carbohydrate."@en ;
  dcterms:modified "2026-06-07T15:29:25.069963Z"^^xsd:dateTime .

oakcurric:priorknowledge-566-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Producers use the glucose made by photosynthesis to make biomass for growth and
  repair, and as a fuel for cellular respiration to provide energy for life processes."""@en ;
  dcterms:modified "2026-06-07T15:29:25.069970Z"^^xsd:dateTime .

oakcurric:priorknowledge-566-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Consumers depend upon producers to make biomass, which consumers eat as food."@en ;
  dcterms:modified "2026-06-07T15:29:25.069975Z"^^xsd:dateTime .

oakcurric:priorknowledge-566-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Consumers use the food they eat to make biomass for growth and repair, and as a fuel
  for cellular respiration to provide energy for life processes."""@en ;
  dcterms:modified "2026-06-07T15:29:25.069981Z"^^xsd:dateTime .

oakcurric:priorknowledge-970-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The rate of a chemical reaction is equal to the amount of product formed per unit
  time."""@en ;
  dcterms:modified "2026-06-07T15:29:25.077056Z"^^xsd:dateTime .

oakcurric:priorknowledge-970-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The gradient of a rate of reaction graph can be calculated from a tangent drawn at a
  point on the curve."""@en ;
  dcterms:modified "2026-06-07T15:29:25.077070Z"^^xsd:dateTime .

oakcurric:priorknowledge-970-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """A catalyst affects the rate of a chemical reaction, but is not a reactant or a
  product of the reaction."""@en ;
  dcterms:modified "2026-06-07T15:29:25.077076Z"^^xsd:dateTime .

oakcurric:priorknowledge-970-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Ceramics are made from soft substances, which when heated become hard and
  brittle."""@en ;
  dcterms:modified "2026-06-07T15:29:25.077081Z"^^xsd:dateTime .

oakcurric:priorknowledge-970-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Plastics are made from polymers and there are many types of plastics with very
  different properties."""@en ;
  dcterms:modified "2026-06-07T15:29:25.077086Z"^^xsd:dateTime .

oakcurric:priorknowledge-970-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Some polymers are made of a single long chain of atoms, and other have many chains
  branching off each other."""@en ;
  dcterms:modified "2026-06-07T15:29:25.077097Z"^^xsd:dateTime .

oakcurric:priorknowledge-970-7
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The properties of a composite material can be predicted or designed based on the
  properties of the materials it contains."""@en ;
  dcterms:modified "2026-06-07T15:29:25.077102Z"^^xsd:dateTime .

oakcurric:priorknowledge-970-8
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Transition metals can be located in the centre of the periodic table, and have
  typical properties of metals"""@en ;
  dcterms:modified "2026-06-07T15:29:25.077107Z"^^xsd:dateTime .

oakcurric:priorknowledge-489-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Electric current is measured in amps (A) with an ammeter."@en ;
  dcterms:modified "2026-06-07T15:29:25.102822Z"^^xsd:dateTime .

oakcurric:priorknowledge-489-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Potential difference (voltage) is measured in volts (V) with a voltmeter."@en ;
  dcterms:modified "2026-06-07T15:29:25.102840Z"^^xsd:dateTime .

oakcurric:priorknowledge-489-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "The current in a series circuit is the same everywhere."@en ;
  dcterms:modified "2026-06-07T15:29:25.102847Z"^^xsd:dateTime .

oakcurric:priorknowledge-489-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Adding a component to a series circuit changes the current everywhere, on both sides
  of the component."""@en ;
  dcterms:modified "2026-06-07T15:29:25.102853Z"^^xsd:dateTime .

oakcurric:priorknowledge-489-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The voltage across each component in a series electric circuit adds up to the
  voltage of the battery."""@en ;
  dcterms:modified "2026-06-07T15:29:25.102859Z"^^xsd:dateTime .

oakcurric:priorknowledge-489-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Resistance is a measure of how hard it is for current to flow."@en ;
  dcterms:modified "2026-06-07T15:29:25.102864Z"^^xsd:dateTime .

oakcurric:priorknowledge-489-7
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Resistance is measured in ohms (Ω)."@en ;
  dcterms:modified "2026-06-07T15:29:25.102869Z"^^xsd:dateTime .

oakcurric:priorknowledge-489-8
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The voltage across each branch of a parallel circuit is the same as the voltage
  across the battery."""@en ;
  dcterms:modified "2026-06-07T15:29:25.102874Z"^^xsd:dateTime .

oakcurric:priorknowledge-489-9
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Each loop in a parallel circuit is equivalent to a series circuit connected to the
  same battery."""@en ;
  dcterms:modified "2026-06-07T15:29:25.102879Z"^^xsd:dateTime .

oakcurric:priorknowledge-489-10
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The current through each branch of a parallel circuit adds up to the current through
  the battery."""@en ;
  dcterms:modified "2026-06-07T15:29:25.102884Z"^^xsd:dateTime .

oakcurric:priorknowledge-900-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Genetic material stored in cells provides instructions for growth and other life
  processes."""@en ;
  dcterms:modified "2026-06-07T15:29:25.153972Z"^^xsd:dateTime .

oakcurric:priorknowledge-900-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The genetic material of all organisms is made of a chemical substance called
  DNA."""@en ;
  dcterms:modified "2026-06-07T15:29:25.153985Z"^^xsd:dateTime .

oakcurric:priorknowledge-900-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Some of an organism’s characteristics are determined only by instructions in its
  genome (e.g. eye colour)."""@en ;
  dcterms:modified "2026-06-07T15:29:25.153992Z"^^xsd:dateTime .

oakcurric:priorknowledge-900-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Most of an organism’s characteristics are influenced by the organisms’ genome and
  interaction with its environment."""@en ;
  dcterms:modified "2026-06-07T15:29:25.153997Z"^^xsd:dateTime .

oakcurric:priorknowledge-900-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Humans and plants can reproduce sexually to have offspring that inherit some, but
  not all, of the characteristics of the parents."""@en ;
  dcterms:modified "2026-06-07T15:29:25.154002Z"^^xsd:dateTime .

oakcurric:priorknowledge-900-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """During sexual reproduction, male and female gametes fuse in process called
  fertilisation."""@en ;
  dcterms:modified "2026-06-07T15:29:25.154007Z"^^xsd:dateTime .

oakcurric:priorknowledge-565-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """[Y1] The basic parts of the human body and which part of the body is associated with
  each sense."""@en ;
  dcterms:modified "2026-06-07T15:29:25.157753Z"^^xsd:dateTime .

oakcurric:priorknowledge-565-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Humans are multicellular organisms – they are made up of millions of living
  cells."""@en ;
  dcterms:modified "2026-06-07T15:29:25.157766Z"^^xsd:dateTime .

oakcurric:priorknowledge-565-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Specialised cells in animals have shapes, sizes and structures that are adapted for
  the jobs the cells do."""@en ;
  dcterms:modified "2026-06-07T15:29:25.157773Z"^^xsd:dateTime .

oakcurric:priorknowledge-928-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Almost everything is made of particles."@en ;
  dcterms:modified "2026-06-07T15:29:25.159390Z"^^xsd:dateTime .

oakcurric:priorknowledge-928-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """In a solid, particles are very close together, have a regular arrangement, are
  vibrating and are bonded together."""@en ;
  dcterms:modified "2026-06-07T15:29:25.159402Z"^^xsd:dateTime .

oakcurric:priorknowledge-928-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """In a liquid, particles are close together, they do not have a regular arrangement
  and can move over each other, they are loosely bonded together."""@en ;
  dcterms:modified "2026-06-07T15:29:25.159408Z"^^xsd:dateTime .

oakcurric:priorknowledge-928-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """In a gas, particles are spaced apart and move quickly in straight lines, bouncing
  off other particles or the walls of their container."""@en ;
  dcterms:modified "2026-06-07T15:29:25.159413Z"^^xsd:dateTime .

oakcurric:priorknowledge-928-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Between particles there is empty space."@en ;
  dcterms:modified "2026-06-07T15:29:25.159419Z"^^xsd:dateTime .

oakcurric:priorknowledge-928-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Heating a solid makes its particles vibrate more quickly."@en ;
  dcterms:modified "2026-06-07T15:29:25.159424Z"^^xsd:dateTime .

oakcurric:priorknowledge-928-7
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Heating a liquid or gas makes its particles move around more quickly."@en ;
  dcterms:modified "2026-06-07T15:29:25.159429Z"^^xsd:dateTime .

oakcurric:priorknowledge-928-8
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Heating a solid, liquid or gas causes it to expand."@en ;
  dcterms:modified "2026-06-07T15:29:25.159433Z"^^xsd:dateTime .

oakcurric:priorknowledge-928-9
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The faster the particles in something are vibrating or moving, the higher its
  temperature."""@en ;
  dcterms:modified "2026-06-07T15:29:25.159438Z"^^xsd:dateTime .

oakcurric:priorknowledge-572-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Living organisms are made up of one or more cells."@en ;
  dcterms:modified "2026-06-07T15:29:25.338588Z"^^xsd:dateTime .

oakcurric:priorknowledge-572-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Animal, plant and other eukaryotic cells contain mitochondria that use food as a
  fuel for cellular respiration to provide energy for life processes."""@en ;
  dcterms:modified "2026-06-07T15:29:25.338598Z"^^xsd:dateTime .

oakcurric:priorknowledge-572-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Differences between breathing and cellular respiration."@en ;
  dcterms:modified "2026-06-07T15:29:25.338603Z"^^xsd:dateTime .

oakcurric:priorknowledge-572-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """In humans, the circulatory system transports substances from the gas exchange and
  digestive systems to cells for cellular respiration, and transports the waste products
  away."""@en ;
  dcterms:modified "2026-06-07T15:29:25.338608Z"^^xsd:dateTime .

oakcurric:priorknowledge-572-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Word equations for aerobic and anaerobic cellular respiration in humans."@en ;
  dcterms:modified "2026-06-07T15:29:25.338612Z"^^xsd:dateTime .

oakcurric:priorknowledge-572-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Word equations for anaerobic cellular respiration in humans and in
  microorganisms."""@en ;
  dcterms:modified "2026-06-07T15:29:25.338616Z"^^xsd:dateTime .

oakcurric:priorknowledge-572-7
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Humans use anaerobic cellular respiration (fermentation) in microorganisms to make
  useful products such as bread, yogurt and alcoholic drinks."""@en ;
  dcterms:modified "2026-06-07T15:29:25.338621Z"^^xsd:dateTime .

oakcurric:priorknowledge-960-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Ions are a form of atom that have either lost or gained electrons"@en ;
  dcterms:modified "2026-06-07T15:29:25.380014Z"^^xsd:dateTime .

oakcurric:priorknowledge-960-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Metals form positive ions and non metals form negative ions"@en ;
  dcterms:modified "2026-06-07T15:29:25.380027Z"^^xsd:dateTime .

oakcurric:priorknowledge-960-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Most ionic substances are soluble"@en ;
  dcterms:modified "2026-06-07T15:29:25.380033Z"^^xsd:dateTime .

oakcurric:priorknowledge-960-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Reactions that produce insoluble solids are called precipitation reactions"@en ;
  dcterms:modified "2026-06-07T15:29:25.380038Z"^^xsd:dateTime .

oakcurric:priorknowledge-960-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Ionic equations show only the species of a chemical reaction that have changed"@en ;
  dcterms:modified "2026-06-07T15:29:25.380044Z"^^xsd:dateTime .

oakcurric:priorknowledge-476-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Objects can have energy because they are: moving, raised, hot, squashed & springy,
  or contain chemicals that can react."""@en ;
  dcterms:modified "2026-06-07T15:29:25.595825Z"^^xsd:dateTime .

oakcurric:priorknowledge-476-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Energy can be transferred by forces that change the properties of an object (or
  system)."""@en ;
  dcterms:modified "2026-06-07T15:29:25.595835Z"^^xsd:dateTime .

oakcurric:priorknowledge-476-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Friction and drag act to continually reduce the speed of an unpropelled object."@en ;
  dcterms:modified "2026-06-07T15:29:25.595841Z"^^xsd:dateTime .

oakcurric:priorknowledge-476-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Streamlining reduces drag."@en ;
  dcterms:modified "2026-06-07T15:29:25.595845Z"^^xsd:dateTime .

oakcurric:priorknowledge-476-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Streamlining reduces how much a fluid needs to be pushed out of the way for an
  object to move through it."""@en ;
  dcterms:modified "2026-06-07T15:29:25.595855Z"^^xsd:dateTime .

oakcurric:priorknowledge-476-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Gravity pulls down with a steady force."@en ;
  dcterms:modified "2026-06-07T15:29:25.595859Z"^^xsd:dateTime .

oakcurric:priorknowledge-476-7
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "A gravitational force of about 10 N is needed to life one kg on the Earth."@en ;
  dcterms:modified "2026-06-07T15:29:25.595864Z"^^xsd:dateTime .

oakcurric:priorknowledge-476-8
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Gravitational force (weight), W = m × g"@en ;
  dcterms:modified "2026-06-07T15:29:25.595868Z"^^xsd:dateTime .

oakcurric:priorknowledge-476-9
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Work done = force × distance"@en ;
  dcterms:modified "2026-06-07T15:29:25.595872Z"^^xsd:dateTime .

oakcurric:priorknowledge-968-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Coal is a sedimentary rock that burns because it is made mostly of carbon, with some
  impurities."""@en ;
  dcterms:modified "2026-06-07T15:29:25.629649Z"^^xsd:dateTime .

oakcurric:priorknowledge-968-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "The organic matter that formed oil and gas decomposed into hydrocarbons."@en ;
  dcterms:modified "2026-06-07T15:29:25.629660Z"^^xsd:dateTime .

oakcurric:priorknowledge-968-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """When fuels containing carbon are burned it is common for carbon dioxide to
  be made."""@en ;
  dcterms:modified "2026-06-07T15:29:25.629671Z"^^xsd:dateTime .

oakcurric:priorknowledge-968-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Less than 1% of the Earth’s atmosphere is carbon dioxide."@en ;
  dcterms:modified "2026-06-07T15:29:25.629676Z"^^xsd:dateTime .

oakcurric:priorknowledge-968-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Carbon dioxide is a greenhouse gas."@en ;
  dcterms:modified "2026-06-07T15:29:25.629680Z"^^xsd:dateTime .

oakcurric:priorknowledge-968-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """In the atmosphere, some gases are greenhouse gases and have properties that enable
  its temperature to rise over time."""@en ;
  dcterms:modified "2026-06-07T15:29:25.629685Z"^^xsd:dateTime .

oakcurric:priorknowledge-968-7
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Combustion increases the amount of carbon dioxide in the atmosphere."@en ;
  dcterms:modified "2026-06-07T15:29:25.629689Z"^^xsd:dateTime .

oakcurric:priorknowledge-1146-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Covalent bonds form when non-metal atoms share electrons."@en ;
  dcterms:modified "2026-06-07T15:29:25.810693Z"^^xsd:dateTime .

oakcurric:priorknowledge-1146-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Non-metal, covalent molecules form simple molecules or giant covalent
  (macromolecular) structures."""@en ;
  dcterms:modified "2026-06-07T15:29:25.810705Z"^^xsd:dateTime .

oakcurric:priorknowledge-1146-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Non-metals atoms in group 5 can form three covalent bonds; those in group 4, four
  covalent bonds."""@en ;
  dcterms:modified "2026-06-07T15:29:25.810710Z"^^xsd:dateTime .

oakcurric:priorknowledge-1146-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Simple molecules have low melting and boiling points because the intermolecular
  forces between them are weak, requiring little energy."""@en ;
  dcterms:modified "2026-06-07T15:29:25.810715Z"^^xsd:dateTime .

oakcurric:priorknowledge-1146-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Giant covalent structures have high melting and boiling points because the strong
  covalent bonds need a lot of energy to be broken."""@en ;
  dcterms:modified "2026-06-07T15:29:25.810720Z"^^xsd:dateTime .

oakcurric:priorknowledge-971-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "In a chemical reaction, atoms rearrange themselves to form new substances."@en ;
  dcterms:modified "2026-06-07T15:29:26.231783Z"^^xsd:dateTime .

oakcurric:priorknowledge-971-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Water is often formed in chemical reactions if oxygen and hydrogen atoms are
  present."""@en ;
  dcterms:modified "2026-06-07T15:29:26.231793Z"^^xsd:dateTime .

oakcurric:priorknowledge-971-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Carbon dioxide is often formed in chemical reactions if oxygen and carbon atoms are
  present."""@en ;
  dcterms:modified "2026-06-07T15:29:26.231798Z"^^xsd:dateTime .

oakcurric:priorknowledge-971-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Chemical formulae represent the numbers of each type of atoms in a reactant or
  product."""@en ;
  dcterms:modified "2026-06-07T15:29:26.231803Z"^^xsd:dateTime .

oakcurric:priorknowledge-971-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The displayed formula for a molecule shows all the atoms, with all the bonds between
  them."""@en ;
  dcterms:modified "2026-06-07T15:29:26.231807Z"^^xsd:dateTime .

oakcurric:priorknowledge-971-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The general formula for an alkane is CnH2n+2; the general formula for alkenes is
  CnH2n."""@en ;
  dcterms:modified "2026-06-07T15:29:26.231811Z"^^xsd:dateTime .

oakcurric:priorknowledge-971-7
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Alkanes can be burnt for heating and produce carbon dioxide and water."@en ;
  dcterms:modified "2026-06-07T15:29:26.231816Z"^^xsd:dateTime .

oakcurric:priorknowledge-971-8
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Smaller hydrocarbon molecules have lower boiling points and evaporate more easily
  making them more flammable."""@en ;
  dcterms:modified "2026-06-07T15:29:26.231820Z"^^xsd:dateTime .

oakcurric:priorknowledge-971-9
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Smaller hydrocarbon molecules with double bonds are very reactive and useful for
  making other products like polymers."""@en ;
  dcterms:modified "2026-06-07T15:29:26.231824Z"^^xsd:dateTime .

oakcurric:priorknowledge-971-10
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Bromine water changes from orange/brown to colourless in the presence of an
  alkene."""@en ;
  dcterms:modified "2026-06-07T15:29:26.231829Z"^^xsd:dateTime .

oakcurric:priorknowledge-667-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Food chain diagrams show transfers of biomass."@en ;
  dcterms:modified "2026-06-07T15:29:26.248333Z"^^xsd:dateTime .

oakcurric:priorknowledge-667-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Food web diagrams represent several interconnected food chains within a community of
  organisms."""@en ;
  dcterms:modified "2026-06-07T15:29:26.248344Z"^^xsd:dateTime .

oakcurric:priorknowledge-667-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Trophic levels are the stages in a food chain."@en ;
  dcterms:modified "2026-06-07T15:29:26.248349Z"^^xsd:dateTime .

oakcurric:priorknowledge-667-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Biomass is the amount of living or recently living matter."@en ;
  dcterms:modified "2026-06-07T15:29:26.248354Z"^^xsd:dateTime .

oakcurric:priorknowledge-667-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Biodiversity is a measure of the range of living organisms."@en ;
  dcterms:modified "2026-06-07T15:29:26.248358Z"^^xsd:dateTime .

oakcurric:priorknowledge-667-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "It is important to preserve biodiversity to maintain a healthy environment."@en ;
  dcterms:modified "2026-06-07T15:29:26.248363Z"^^xsd:dateTime .

oakcurric:priorknowledge-667-7
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pollinating insects are important in producing crops."@en ;
  dcterms:modified "2026-06-07T15:29:26.248367Z"^^xsd:dateTime .

oakcurric:priorknowledge-667-8
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "The relationship between genes, chromosomes and DNA."@en ;
  dcterms:modified "2026-06-07T15:29:26.248376Z"^^xsd:dateTime .

oakcurric:priorknowledge-667-9
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "The products of combustion."@en ;
  dcterms:modified "2026-06-07T15:29:26.248381Z"^^xsd:dateTime .

oakcurric:priorknowledge-667-10
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Which fuels are fossil fuels."@en ;
  dcterms:modified "2026-06-07T15:29:26.248385Z"^^xsd:dateTime .

oakcurric:priorknowledge-899-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "All organisms are made up of one or more cells."@en ;
  dcterms:modified "2026-06-07T15:29:26.387815Z"^^xsd:dateTime .

oakcurric:priorknowledge-899-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Genetic material stored in cells provides instructions for growth and other life
  processes."""@en ;
  dcterms:modified "2026-06-07T15:29:26.387828Z"^^xsd:dateTime .

oakcurric:priorknowledge-899-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The genetic material of all organisms is made of a chemical substance called
  DNA."""@en ;
  dcterms:modified "2026-06-07T15:29:26.387833Z"^^xsd:dateTime .

oakcurric:priorknowledge-967-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Non-renewable energy resources cannot be replaced in our lifetime once they are used
  up."""@en ;
  dcterms:modified "2026-06-07T15:29:26.464706Z"^^xsd:dateTime .

oakcurric:priorknowledge-967-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "There is a limited supply of non-renewable energy resources."@en ;
  dcterms:modified "2026-06-07T15:29:26.464718Z"^^xsd:dateTime .

oakcurric:priorknowledge-967-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "A chemical that is oxidised either gains oxygen or loses electrons."@en ;
  dcterms:modified "2026-06-07T15:29:26.464730Z"^^xsd:dateTime .

oakcurric:priorknowledge-967-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "A chemical that is reduced either loses oxygen or gains electrons."@en ;
  dcterms:modified "2026-06-07T15:29:26.464735Z"^^xsd:dateTime .

oakcurric:priorknowledge-967-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "A redox reaction is one in which both oxidation and reduction take place."@en ;
  dcterms:modified "2026-06-07T15:29:26.464740Z"^^xsd:dateTime .

oakcurric:priorknowledge-967-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The reactivity series for metals shows how vigorously metals react, compared to each
  other."""@en ;
  dcterms:modified "2026-06-07T15:29:26.464744Z"^^xsd:dateTime .

oakcurric:priorknowledge-967-7
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The higher the position of a metal in the reactivity series, the more vigorously it
  is likely to react."""@en ;
  dcterms:modified "2026-06-07T15:29:26.464748Z"^^xsd:dateTime .

oakcurric:priorknowledge-967-8
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """A metal ore is typically rock that contains a metal in a form that can be
  extracted."""@en ;
  dcterms:modified "2026-06-07T15:29:26.464752Z"^^xsd:dateTime .

oakcurric:priorknowledge-967-9
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Carbon can be used to extract some metals from their ores."@en ;
  dcterms:modified "2026-06-07T15:29:26.464757Z"^^xsd:dateTime .

oakcurric:priorknowledge-967-10
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Carbon is more reactive than copper or zinc, but less reactive than aluminium or
  magnesium."""@en ;
  dcterms:modified "2026-06-07T15:29:26.464761Z"^^xsd:dateTime .

oakcurric:priorknowledge-495-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Current = p.d. / resistance (I=V/R)."@en ;
  dcterms:modified "2026-06-07T15:29:26.494197Z"^^xsd:dateTime .

oakcurric:priorknowledge-495-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The rules of current and p.d. for a series circuit can be applied to find some
  missing values of current and p.d."""@en ;
  dcterms:modified "2026-06-07T15:29:26.494217Z"^^xsd:dateTime .

oakcurric:priorknowledge-495-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The rules of current and p.d. for a series circuit can be applied to find some
  missing values of current and p.d."""@en ;
  dcterms:modified "2026-06-07T15:29:26.494224Z"^^xsd:dateTime .

oakcurric:priorknowledge-495-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The equation I=V/R can be rearranged so that either p.d. or R is the subject of the
  equation."""@en ;
  dcterms:modified "2026-06-07T15:29:26.494230Z"^^xsd:dateTime .

oakcurric:priorknowledge-495-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "If any two values in the equation I=V/R are known, the third can be calculated."@en ;
  dcterms:modified "2026-06-07T15:29:26.494235Z"^^xsd:dateTime .

oakcurric:priorknowledge-495-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """If only one value in the equation I=V/R is known, rules for current or p.d. need to
  be applied to find a second."""@en ;
  dcterms:modified "2026-06-07T15:29:26.494241Z"^^xsd:dateTime .

oakcurric:priorknowledge-495-7
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Power = work done / time."@en ;
  dcterms:modified "2026-06-07T15:29:26.494246Z"^^xsd:dateTime .

oakcurric:priorknowledge-495-8
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Power is measured in Watt (W)."@en ;
  dcterms:modified "2026-06-07T15:29:26.494251Z"^^xsd:dateTime .

oakcurric:priorknowledge-903-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The genetic material of all organisms is made of DNA, wound up into structures
  called chromosomes."""@en ;
  dcterms:modified "2026-06-07T15:29:26.617831Z"^^xsd:dateTime .

oakcurric:priorknowledge-903-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Sections of chromosomes are called genes, which store instructions for making
  proteins (including enzymes)."""@en ;
  dcterms:modified "2026-06-07T15:29:26.617843Z"^^xsd:dateTime .

oakcurric:priorknowledge-903-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """There are usually two versions of each gene in a pair of chromosomes; the two
  versions of a gene are called alleles."""@en ;
  dcterms:modified "2026-06-07T15:29:26.617856Z"^^xsd:dateTime .

oakcurric:priorknowledge-903-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Some alleles are associated with conditions that affect people’s health (e.g. cystic
  fibrosis)."""@en ;
  dcterms:modified "2026-06-07T15:29:26.617861Z"^^xsd:dateTime .

oakcurric:priorknowledge-903-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Consumers, including humans, are dependent upon crop plants to maintain our food
  security."""@en ;
  dcterms:modified "2026-06-07T15:29:26.617866Z"^^xsd:dateTime .

oakcurric:priorknowledge-903-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Plants can be infected by communicable diseases."@en ;
  dcterms:modified "2026-06-07T15:29:26.617870Z"^^xsd:dateTime .

oakcurric:priorknowledge-903-7
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Earth’s climate is changing as a result of human actions."@en ;
  dcterms:modified "2026-06-07T15:29:26.617875Z"^^xsd:dateTime .

oakcurric:priorknowledge-901-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "[Y5] Growth and reproduction are part of the life cycle of all living organisms."@en ;
  dcterms:modified "2026-06-07T15:29:26.665246Z"^^xsd:dateTime .

oakcurric:priorknowledge-901-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "All organisms are made up of one or more cells."@en ;
  dcterms:modified "2026-06-07T15:29:26.665258Z"^^xsd:dateTime .

oakcurric:priorknowledge-901-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Chromosomes stored in cells provide instructions for growth and other life
  processes."""@en ;
  dcterms:modified "2026-06-07T15:29:26.665264Z"^^xsd:dateTime .

oakcurric:priorknowledge-901-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Humans and plants can reproduce sexually to have offspring that inherit some, but
  not all, of the characteristics of the parents."""@en ;
  dcterms:modified "2026-06-07T15:29:26.665269Z"^^xsd:dateTime .

oakcurric:priorknowledge-901-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """During sexual reproduction, male and female gametes fuse in process called
  fertilisation."""@en ;
  dcterms:modified "2026-06-07T15:29:26.665275Z"^^xsd:dateTime .

oakcurric:priorknowledge-568-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Humans are multicellular organisms – they are made up of millions of living
  cells."""@en ;
  dcterms:modified "2026-06-07T15:29:26.800043Z"^^xsd:dateTime .

oakcurric:priorknowledge-568-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Specialised cells in animals have shapes, sizes and structures that are adapted for
  the jobs the cells do."""@en ;
  dcterms:modified "2026-06-07T15:29:26.800056Z"^^xsd:dateTime .

oakcurric:priorknowledge-568-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "The circulatory system transports substances around the body in the blood."@en ;
  dcterms:modified "2026-06-07T15:29:26.800062Z"^^xsd:dateTime .

oakcurric:priorknowledge-568-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The human body has a nervous system that enables us to sense and respond quickly to
  changes outside and inside the body."""@en ;
  dcterms:modified "2026-06-07T15:29:26.800067Z"^^xsd:dateTime .

oakcurric:priorknowledge-568-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Receptors detect stimuli."@en ;
  dcterms:modified "2026-06-07T15:29:26.800072Z"^^xsd:dateTime .

oakcurric:priorknowledge-568-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Sensory neurons transmit nerve impulses from receptors to processing centres such as
  the brain in the CNS."""@en ;
  dcterms:modified "2026-06-07T15:29:26.800076Z"^^xsd:dateTime .

oakcurric:priorknowledge-568-7
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Motor neurons transmit nerve impulses from the CNS to effectors that carry out
  responses."""@en ;
  dcterms:modified "2026-06-07T15:29:26.800080Z"^^xsd:dateTime .

oakcurric:priorknowledge-669-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Fossils provide evidence about organisms that lived and died from 10,000 to billions
  of years ago and their habitats."""@en ;
  dcterms:modified "2026-06-07T15:29:26.805339Z"^^xsd:dateTime .

oakcurric:priorknowledge-669-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Fossils show that the features of some species have changed over time."@en ;
  dcterms:modified "2026-06-07T15:29:26.805351Z"^^xsd:dateTime .

oakcurric:priorknowledge-669-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Species have adaptations which make them well suited to survive in their
  environment."""@en ;
  dcterms:modified "2026-06-07T15:29:26.805357Z"^^xsd:dateTime .

oakcurric:priorknowledge-669-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Due to variation, some individuals within a species have features that make them
  better adapted to complete and survive in their environment."""@en ;
  dcterms:modified "2026-06-07T15:29:26.805361Z"^^xsd:dateTime .

oakcurric:priorknowledge-669-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Better adapted individuals are more likely to reproduce and pass heritable
  adaptations (caused by genetic variation) on to the next generation."""@en ;
  dcterms:modified "2026-06-07T15:29:26.805366Z"^^xsd:dateTime .

oakcurric:priorknowledge-669-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """This ‘natural selection’ of better adapted individuals causes advantageous features
  to become more common in each generation of offspring."""@en ;
  dcterms:modified "2026-06-07T15:29:26.805371Z"^^xsd:dateTime .

oakcurric:priorknowledge-669-7
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Natural selection can cause the common features of a species to change (evolve) over
  generations."""@en ;
  dcterms:modified "2026-06-07T15:29:26.805382Z"^^xsd:dateTime .

oakcurric:priorknowledge-762-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Disease is a cause of ill health."@en ;
  dcterms:modified "2026-06-07T15:29:26.810126Z"^^xsd:dateTime .

oakcurric:priorknowledge-762-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Lifestyle factors can cause or increase the risk of disease."@en ;
  dcterms:modified "2026-06-07T15:29:26.810138Z"^^xsd:dateTime .

oakcurric:priorknowledge-762-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Communicable diseases are caused by pathogens including viruses, bacteria, protists
  and fungi."""@en ;
  dcterms:modified "2026-06-07T15:29:26.810144Z"^^xsd:dateTime .

oakcurric:priorknowledge-762-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Ways in which pathogens can be spread."@en ;
  dcterms:modified "2026-06-07T15:29:26.810149Z"^^xsd:dateTime .

oakcurric:priorknowledge-762-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Some common communicable diseases caused by viruses, bacteria, protists and
  fungi."""@en ;
  dcterms:modified "2026-06-07T15:29:26.810155Z"^^xsd:dateTime .

oakcurric:priorknowledge-905-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "The structures and functions of the human male and female reproductive systems."@en ;
  dcterms:modified "2026-06-07T15:29:26.818952Z"^^xsd:dateTime .

oakcurric:priorknowledge-905-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The human body has an endocrine system that uses hormones to control changes in the
  body."""@en ;
  dcterms:modified "2026-06-07T15:29:26.818963Z"^^xsd:dateTime .

oakcurric:priorknowledge-905-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """During puberty the male and female human bodies undergo changes, which are brought
  about by sex hormones."""@en ;
  dcterms:modified "2026-06-07T15:29:26.818969Z"^^xsd:dateTime .

oakcurric:priorknowledge-905-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Adult human females have a menstrual cycle that prepares them for sexual
  reproduction."""@en ;
  dcterms:modified "2026-06-07T15:29:26.818973Z"^^xsd:dateTime .

oakcurric:priorknowledge-905-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "The roles of ovulation and fertilisation in sexual reproduction in humans."@en ;
  dcterms:modified "2026-06-07T15:29:26.818978Z"^^xsd:dateTime .

oakcurric:priorknowledge-658-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Organisms can be classified into groups based on similarities and differences in
  their observable characteristics at the macroscopic level."""@en ;
  dcterms:modified "2026-06-07T15:29:26.820178Z"^^xsd:dateTime .

oakcurric:priorknowledge-658-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Scientists classify every organism into a group, including a species and a
  genus."""@en ;
  dcterms:modified "2026-06-07T15:29:26.820188Z"^^xsd:dateTime .

oakcurric:priorknowledge-658-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Organisms can be classified into groups within larger groups, from species up to
  kingdom."""@en ;
  dcterms:modified "2026-06-07T15:29:26.820193Z"^^xsd:dateTime .

oakcurric:priorknowledge-658-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "The common structures of animal and plant cells."@en ;
  dcterms:modified "2026-06-07T15:29:26.820197Z"^^xsd:dateTime .

oakcurric:priorknowledge-658-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Organisms can be classified into groups based on their characteristics at the
  microscopic, cellular level."""@en ;
  dcterms:modified "2026-06-07T15:29:26.820202Z"^^xsd:dateTime .

oakcurric:priorknowledge-670-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "The genome is the entire genetic material of an organism."@en ;
  dcterms:modified "2026-06-07T15:29:26.840667Z"^^xsd:dateTime .

oakcurric:priorknowledge-670-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The genome, and its interaction with the environment, influence the phenotype
  (characteristics) of an organism."""@en ;
  dcterms:modified "2026-06-07T15:29:26.840677Z"^^xsd:dateTime .

oakcurric:priorknowledge-670-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "There is variation in the features of individuals of the same species."@en ;
  dcterms:modified "2026-06-07T15:29:26.840683Z"^^xsd:dateTime .

oakcurric:priorknowledge-670-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Variation can be caused by information in the genome and by the environment, but
  only variation caused by information in the genome is heritable (can be passed on to
  offspring)."""@en ;
  dcterms:modified "2026-06-07T15:29:26.840687Z"^^xsd:dateTime .

oakcurric:priorknowledge-670-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Due to variation, some individuals within a species have features that make them
  better adapted to complete and survive in their environment."""@en ;
  dcterms:modified "2026-06-07T15:29:26.840697Z"^^xsd:dateTime .

oakcurric:priorknowledge-670-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Better adapted individuals are more likely to reproduce and pass heritable
  adaptations (caused by genetic variation) on to the next generation."""@en ;
  dcterms:modified "2026-06-07T15:29:26.840702Z"^^xsd:dateTime .

oakcurric:priorknowledge-670-7
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """This ‘natural selection’ of better adapted individuals causes advantageous features
  to become more common in each generation of offspring."""@en ;
  dcterms:modified "2026-06-07T15:29:26.840707Z"^^xsd:dateTime .

oakcurric:priorknowledge-670-8
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Natural selection can cause the common features of a species to change (evolve) over
  generations."""@en ;
  dcterms:modified "2026-06-07T15:29:26.840711Z"^^xsd:dateTime .

oakcurric:priorknowledge-670-9
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Natural selection can cause the common features of a population to change (evolve)
  over generations, and eventually to become so different that we classify the population as
  a new species."""@en ;
  dcterms:modified "2026-06-07T15:29:26.840716Z"^^xsd:dateTime .

