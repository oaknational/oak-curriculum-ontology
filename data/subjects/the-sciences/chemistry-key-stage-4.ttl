  keep using them because they cannot be regenerated or replaced within our lifetime."""@en ;
  dcterms:modified "2026-06-07T15:30:02.417682Z"^^xsd:dateTime .

oakcurric:keyword-synthetic-products
  a curric:Keyword ;
