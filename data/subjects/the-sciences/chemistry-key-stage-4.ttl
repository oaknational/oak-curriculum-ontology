  dcterms:modified "2026-06-09T00:46:37.493821Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9709-2
  a curric:KeyLearningPoint ;
  rdfs:label "A more reactive halogen can displace a less reactive one from a compound."@en ;
  dcterms:modified "2026-06-09T00:46:37.493826Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9709-3
  a curric:KeyLearningPoint ;
  rdfs:label "Group 7 elements react with Group 1 and 2 metals to form salts."@en ;
  dcterms:modified "2026-06-09T00:46:37.493831Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9709-4
  a curric:KeyLearningPoint ;
  rdfs:label """The chemical test for chlorine involves passing the gas over damp blue
  litmus paper."""@en ;
  dcterms:modified "2026-06-09T00:46:37.493836Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9653-1
  a curric:KeyLearningPoint ;
  rdfs:label """Data can be analysed to assess the purity of water samples containing dissolved
  solids."""@en ;
  dcterms:modified "2026-06-09T00:46:37.496304Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9653-2
  a curric:KeyLearningPoint ;
  rdfs:label "Evaporation set-ups can be used to collect dissolved solids from a water sample."@en ;
  dcterms:modified "2026-06-09T00:46:37.496309Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27911-1
  a curric:KeyLearningPoint ;
  rdfs:label """Unique tests for each substance help minimise errors and ensure correct
  identification."""@en ;
  dcterms:modified "2026-06-09T00:46:37.502421Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27911-2
  a curric:KeyLearningPoint ;
  rdfs:label "Gas tests can be used to identify carbon dioxide, oxygen, hydrogen and ammonia."@en ;
  dcterms:modified "2026-06-09T00:46:37.502426Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27911-3
  a curric:KeyLearningPoint ;
  rdfs:label """Observations and results should be recorded accurately for analysis during the
  practical."""@en ;
  dcterms:modified "2026-06-09T00:46:37.502430Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27911-4
  a curric:KeyLearningPoint ;
  rdfs:label """Flow charts break down complex activities into ordered sets of simpler steps,
  crucial for efficient ion identification."""@en ;
  dcterms:modified "2026-06-09T00:46:37.502438Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9684-1
  a curric:KeyLearningPoint ;
  rdfs:label "There are three different types of bonding (covalent, ionic, metallic)."@en ;
  dcterms:modified "2026-06-09T00:46:37.502556Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9684-2
  a curric:KeyLearningPoint ;
  rdfs:label "There are only two types of structure (simple and giant)."@en ;
  dcterms:modified "2026-06-09T00:46:37.502561Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9684-3
  a curric:KeyLearningPoint ;
  rdfs:label "The type of bonding and structure are what lead to properties of substances."@en ;
  dcterms:modified "2026-06-09T00:46:37.502566Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9684-4
  a curric:KeyLearningPoint ;
  rdfs:label """Melting/boiling points are linked to intermolecular forces (simple) and bond
  strength (giant)."""@en ;
  dcterms:modified "2026-06-09T00:46:37.502571Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9684-5
  a curric:KeyLearningPoint ;
  rdfs:label "Conductivity is linked to whether there are free moving charge carriers."@en ;
  dcterms:modified "2026-06-09T00:46:37.502576Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9705-1
  a curric:KeyLearningPoint ;
  rdfs:label "Heating sodium hydrogencarbonate in a crucible leads to its decomposition."@en ;
  dcterms:modified "2026-06-09T00:46:37.503127Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9705-2
  a curric:KeyLearningPoint ;
  rdfs:label "The risk involved with heating sodium hydrogencarbonate is low."@en ;
  dcterms:modified "2026-06-09T00:46:37.503132Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9705-3
  a curric:KeyLearningPoint ;
  rdfs:label "The stoichiometry for a reaction can be calculated given experimental data."@en ;
  dcterms:modified "2026-06-09T00:46:37.503137Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9705-4
  a curric:KeyLearningPoint ;
