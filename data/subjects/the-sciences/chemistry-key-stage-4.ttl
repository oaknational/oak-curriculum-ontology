oakcurric:keyword-nanoparticulate
  a curric:Keyword ;
  schema:name "nanoparticulate"@en ;
  schema:description "A material composed of nanoparticles."@en ;
  dcterms:modified "2026-06-07T15:30:02.416736Z"^^xsd:dateTime .

oakcurric:keyword-allotrope
  a curric:Keyword ;
