  schema:description """Reaction profiles are diagrams that show the energy of the reactants and
  products in a chemical reaction."""@en ;
  dcterms:modified "2026-06-07T15:30:02.417024Z"^^xsd:dateTime .

oakcurric:keyword-buckminsterfullerene
