  take in water and nutrients for the plant."""@en ;
  dcterms:modified "2026-06-07T15:30:02.371307Z"^^xsd:dateTime .

oakcurric:keyword-conductor
  a curric:Keyword ;
  schema:name "conductor"@en ;
