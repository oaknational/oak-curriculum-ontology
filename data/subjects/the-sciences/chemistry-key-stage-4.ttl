  schema:description """Conservation of mass means that the combined mass of the starting reactants
  equals the combined mass of the products formed."""@en ;
  dcterms:modified "2026-06-09T00:46:04.301610Z"^^xsd:dateTime .

oakcurric:keyword-reactant
  a curric:Keyword ;
  schema:name "reactant"@en ;
  schema:description "Reactants are the elements or compounds before a reaction takes place."@en ;
  dcterms:modified "2026-06-09T00:46:04.301615Z"^^xsd:dateTime .

oakcurric:keyword-solute
  a curric:Keyword ;
  schema:name "solute"@en ;
  schema:description "A solute is a substance that has dissolved into a solvent."@en ;
  dcterms:modified "2026-06-09T00:46:04.301788Z"^^xsd:dateTime .

oakcurric:keyword-alcohol
  a curric:Keyword ;
  schema:name "alcohol"@en ;
  schema:description """Ethanol is a type of alcohol that has a higher evaporation rate than
  water."""@en ;
  dcterms:modified "2026-06-09T00:46:04.302628Z"^^xsd:dateTime .

oakcurric:keyword-altitude
  a curric:Keyword ;
