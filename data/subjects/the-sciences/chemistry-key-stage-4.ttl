  dcterms:modified "2026-06-07T15:30:02.349711Z"^^xsd:dateTime .

oakcurric:keyword-acceleration
  a curric:Keyword ;
  schema:name "acceleration"@en ;
  schema:description """The acceleration of an object is the rate of change of velocity. This is how
  much the velocity changes per second."""@en ;
  dcterms:modified "2026-06-07T15:30:02.349718Z"^^xsd:dateTime .

oakcurric:keyword-antigen
  a curric:Keyword ;
  schema:name "antigen"@en ;
