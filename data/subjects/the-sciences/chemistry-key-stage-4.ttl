  schema:description """Chemical messengers, secreted by glands, that help to control the
  reproductive and secondary sexual characteristics."""@en ;
  dcterms:modified "2026-06-07T15:30:02.416777Z"^^xsd:dateTime .

oakcurric:keyword-reflex-response
  a curric:Keyword ;
  schema:name "reflex response"@en ;
  schema:description "An involuntary, fast neural response to a situation."@en ;
  dcterms:modified "2026-06-07T15:30:02.416782Z"^^xsd:dateTime .

oakcurric:keyword-reflex-arc
  a curric:Keyword ;
  schema:name "reflex arc"@en ;
  schema:description "The fixed neural pathway that controls the reflex response."@en ;
  dcterms:modified "2026-06-07T15:30:02.416787Z"^^xsd:dateTime .

oakcurric:keyword-relay-neurone
  a curric:Keyword ;
  schema:name "relay neurone"@en ;
  schema:description "An intermediate neurone that sits within the central nervous system."@en ;
  dcterms:modified "2026-06-07T15:30:02.416792Z"^^xsd:dateTime .

oakcurric:keyword-radiation
  a curric:Keyword ;
  schema:name "radiation"@en ;
  schema:description """The process of emitting energy, often in the form of infrared waves, from an
  object."""@en ;
  dcterms:modified "2026-06-07T15:30:02.416798Z"^^xsd:dateTime .

oakcurric:keyword-genes
  a curric:Keyword ;
  schema:name "genes"@en ;
  schema:description """Short sections of DNA that code for a specific characteristic or
  protein."""@en ;
  dcterms:modified "2026-06-07T15:30:02.416803Z"^^xsd:dateTime .

oakcurric:keyword-turgid
  a curric:Keyword ;
  schema:name "turgid"@en ;
  schema:description "a cell which is swollen with water and firm"@en ;
  dcterms:modified "2026-06-07T15:30:02.416941Z"^^xsd:dateTime .

oakcurric:keyword-flaccid
  a curric:Keyword ;
  schema:name "flaccid"@en ;
  schema:description "a cell which has lost a lot of water and is soft and limp"@en ;
  dcterms:modified "2026-06-07T15:30:02.416948Z"^^xsd:dateTime .

oakcurric:keyword-internal-body-temperature
  a curric:Keyword ;
