  dcterms:modified "2026-06-09T00:46:37.483968Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8321-1
  a curric:KeyLearningPoint ;
  rdfs:label """A 'pure substance' in chemistry is a single element or compound not mixed with any
  other substance."""@en ;
  dcterms:modified "2026-06-09T00:46:37.487952Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8321-2
  a curric:KeyLearningPoint ;
  rdfs:label "The definition of 'pure' means something different in its everyday usage."@en ;
  dcterms:modified "2026-06-09T00:46:37.487957Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8321-3
  a curric:KeyLearningPoint ;
  rdfs:label "Pure elements and compounds have specific melting and boiling points."@en ;
  dcterms:modified "2026-06-09T00:46:37.487962Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8321-4
  a curric:KeyLearningPoint ;
  rdfs:label """Melting point data can be used to recognise substances with specific melting points
  as pure substances."""@en ;
  dcterms:modified "2026-06-09T00:46:37.487967Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9744-1
  a curric:KeyLearningPoint ;
  rdfs:label """Some metal ions form coloured precipitates in a reaction with sodium hydroxide
