  dcterms:modified "2026-06-09T00:46:04.304277Z"^^xsd:dateTime .

oakcurric:keyword-standard-form
  a curric:Keyword ;
  schema:name "Standard form"@en ;
  schema:description """Standard form is when a number is written in the form A × 10n, (where 1 ≤ A
  < 10 and n is an integer)."""@en ;
  dcterms:modified "2026-06-09T00:46:04.304358Z"^^xsd:dateTime .

oakcurric:keyword-fertiliser
  a curric:Keyword ;
