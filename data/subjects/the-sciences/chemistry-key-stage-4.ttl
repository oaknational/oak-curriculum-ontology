  schema:description """a positively charged electrode, in an electrolysis cell, to which the
  cations are attracted"""@en ;
  dcterms:modified "2026-06-09T00:46:04.270747Z"^^xsd:dateTime .

oakcurric:keyword-electrolyte
  a curric:Keyword ;
