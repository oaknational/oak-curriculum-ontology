# ----------------------------------------------------------------------
# Key Learning Points
# ----------------------------------------------------------------------

oakcurric:keylearningpoint-lesson-9718-1
  a curric:KeyLearningPoint ;
  rdfs:label """Choosing the correct equipment is crucial for obtaining accurate and reliable
  results."""@en ;
  dcterms:modified "2026-06-09T00:46:37.275769Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9718-2
  a curric:KeyLearningPoint ;
  rdfs:label """An upturned measuring cylinder is suitable for reactions producing large volumes of
  gas at moderate rates."""@en ;
  dcterms:modified "2026-06-09T00:46:37.275773Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9718-3
  a curric:KeyLearningPoint ;
  rdfs:label "Gas syringes are ideal for measuring small volumes of gas with high precision."@en ;
  dcterms:modified "2026-06-09T00:46:37.275778Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9718-4
  a curric:KeyLearningPoint ;
  rdfs:label """The size of the measuring equipment should be close to the expected volume of gas
  produced."""@en ;
  dcterms:modified "2026-06-09T00:46:37.275784Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9718-5
  a curric:KeyLearningPoint ;
  rdfs:label """Light sensors can be used to measure the percentage of light transmitted through a
  reaction producing a precipitate."""@en ;
  dcterms:modified "2026-06-09T00:46:37.275788Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9626-1
  a curric:KeyLearningPoint ;
  rdfs:label """An empirical formula is the simplest whole number ratio of atoms of each element in
  a compound."""@en ;
  dcterms:modified "2026-06-09T00:46:37.276116Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9626-2
  a curric:KeyLearningPoint ;
  rdfs:label """The formula of an ionic compound is an empirical formula, as there is no definite
  quantity of each ion."""@en ;
  dcterms:modified "2026-06-09T00:46:37.276120Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9626-3
  a curric:KeyLearningPoint ;
  rdfs:label "Ionic compounds ending with \"–ide\" only contain a metal and a non–metal ion."@en ;
  dcterms:modified "2026-06-09T00:46:37.276126Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9626-4
  a curric:KeyLearningPoint ;
  rdfs:label "Polyatomic ions are ions that are made up of more than one type of atom."@en ;
  dcterms:modified "2026-06-09T00:46:37.276131Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9626-5
  a curric:KeyLearningPoint ;
  rdfs:label """Ionic compounds ending with \"–ate\" always contain at least three elements, one of
  which is oxygen."""@en ;
  dcterms:modified "2026-06-09T00:46:37.276135Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9620-1
  a curric:KeyLearningPoint ;
  rdfs:label "Atoms of every element consist of the same three subatomic particles."@en ;
  dcterms:modified "2026-06-09T00:46:37.276180Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9620-2
  a curric:KeyLearningPoint ;
  rdfs:label """All elements consist of their own atoms, with a unique number of protons defining
  the element."""@en ;
  dcterms:modified "2026-06-09T00:46:37.276187Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9620-3
  a curric:KeyLearningPoint ;
  rdfs:label """Everything around us is made of different combinations of atoms, either on their
  own, or in compound form."""@en ;
  dcterms:modified "2026-06-09T00:46:37.276191Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9620-4
  a curric:KeyLearningPoint ;
  rdfs:label """We use element symbols in formulae as a common language to share chemical
  compositions."""@en ;
  dcterms:modified "2026-06-09T00:46:37.276196Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9945-1
  a curric:KeyLearningPoint ;
  rdfs:label """A mixture consists of two or more elements and/or compounds not chemically combined
  together"""@en ;
  dcterms:modified "2026-06-09T00:46:37.276200Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9945-2
  a curric:KeyLearningPoint ;
  rdfs:label "Chemical properties of each substance in a mixture remain unchanged"@en ;
  dcterms:modified "2026-06-09T00:46:37.276204Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9945-3
  a curric:KeyLearningPoint ;
  rdfs:label "There are multiple physical processes for separating mixtures"@en ;
  dcterms:modified "2026-06-09T00:46:37.276208Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9945-4
  a curric:KeyLearningPoint ;
  rdfs:label """Melting point data can be used to distinguish between pure substances and
  mixtures"""@en ;
  dcterms:modified "2026-06-09T00:46:37.276212Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9947-1
  a curric:KeyLearningPoint ;
  rdfs:label """Electrons have a relative charge of -1 and roughly a relative atomic mass of 1/1835
  (negligible)."""@en ;
  dcterms:modified "2026-06-09T00:46:37.428956Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9947-2
  a curric:KeyLearningPoint ;
  rdfs:label """Protons are found in the atomic nucleus, have a relative electric charge of +1, and
  a relative mass of 1."""@en ;
  dcterms:modified "2026-06-09T00:46:37.428964Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9947-3
  a curric:KeyLearningPoint ;
  rdfs:label """Neutrons are found in the atomic nucleus, have no electric charge, and a relative
  mass of 1."""@en ;
  dcterms:modified "2026-06-09T00:46:37.428977Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9947-4
  a curric:KeyLearningPoint ;
  rdfs:label """An atom has no electric charge as it contains equal numbers of protons and electrons
  to balance the charge."""@en ;
  dcterms:modified "2026-06-09T00:46:37.428986Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9947-5
  a curric:KeyLearningPoint ;
  rdfs:label """The atom has a nucleus surrounded by electrons, with the nuclear radius much smaller
  than that of the atom."""@en ;
  dcterms:modified "2026-06-09T00:46:37.428995Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9641-1
  a curric:KeyLearningPoint ;
  rdfs:label """Filtration is a technique used to separate insoluble substances from a mixture with
  a liquid."""@en ;
  dcterms:modified "2026-06-09T00:46:37.434001Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9641-2
  a curric:KeyLearningPoint ;
  rdfs:label "Separation in filtration occurs due to the difference in size of particles."@en ;
  dcterms:modified "2026-06-09T00:46:37.434008Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9641-3
  a curric:KeyLearningPoint ;
  rdfs:label """The terms 'filtrate' and 'residue' describe the components separated by the process
  of filtration."""@en ;
  dcterms:modified "2026-06-09T00:46:37.434016Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8441-1
  a curric:KeyLearningPoint ;
  rdfs:label """Multiple types of positive ions are in competition at the negative electrode
  (cathode)."""@en ;
  dcterms:modified "2026-06-09T00:46:37.434053Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8441-2
  a curric:KeyLearningPoint ;
  rdfs:label """Multiple types of negative ions are in competition at the positive electrode
  (anode)."""@en ;
  dcterms:modified "2026-06-09T00:46:37.434061Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8441-3
  a curric:KeyLearningPoint ;
  rdfs:label "There are rules for which substances are discharged at the anode and cathode."@en ;
  dcterms:modified "2026-06-09T00:46:37.434069Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8441-4
  a curric:KeyLearningPoint ;
  rdfs:label "The gases produced during electrolysis can be collected and tested."@en ;
  dcterms:modified "2026-06-09T00:46:37.434077Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8441-5
  a curric:KeyLearningPoint ;
  rdfs:label "Hydrogen may be formed at the cathode"@en ;
  dcterms:modified "2026-06-09T00:46:37.434089Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8437-1
  a curric:KeyLearningPoint ;
  rdfs:label """Electrolysis: the process in which an electrolyte is broken down by electricity;
  it's not a physical separation method."""@en ;
  dcterms:modified "2026-06-09T00:46:37.434552Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8437-2
  a curric:KeyLearningPoint ;
  rdfs:label "The cathode is the negative electrode, where positive particles gain electrons."@en ;
  dcterms:modified "2026-06-09T00:46:37.434560Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8437-3
  a curric:KeyLearningPoint ;
  rdfs:label "The anode is the positive electrode, where negative particles lose electrons."@en ;
  dcterms:modified "2026-06-09T00:46:37.434568Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8437-4
  a curric:KeyLearningPoint ;
  rdfs:label """An electrolyte contains freely moving ions, and these are attracted to the charged
  electrodes."""@en ;
  dcterms:modified "2026-06-09T00:46:37.434579Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8437-5
  a curric:KeyLearningPoint ;
  rdfs:label "Electrolysis allowed Davy and Faraday to make their scientific discoveries."@en ;
  dcterms:modified "2026-06-09T00:46:37.434587Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9651-1
  a curric:KeyLearningPoint ;
  rdfs:label """There are many sources of wastewater and each introduces different types of
  contaminants."""@en ;
  dcterms:modified "2026-06-09T00:46:37.439910Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9651-2
  a curric:KeyLearningPoint ;
  rdfs:label """There are sequential steps involved in making wastewater safe before disposal into
  the environment."""@en ;
  dcterms:modified "2026-06-09T00:46:37.439917Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9651-3
  a curric:KeyLearningPoint ;
  rdfs:label "Multiple types of waste need to be removed from different kinds of wastewater."@en ;
  dcterms:modified "2026-06-09T00:46:37.439924Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9651-4
  a curric:KeyLearningPoint ;
  rdfs:label """Releasing untreated wastewater into the environment could impact an ecosystem's
  health."""@en ;
  dcterms:modified "2026-06-09T00:46:37.439931Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9651-5
  a curric:KeyLearningPoint ;
  rdfs:label """Sludge can be anaerobically treated, producing materials that can be used as a
  fertiliser or fuel."""@en ;
  dcterms:modified "2026-06-09T00:46:37.439938Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20085-1
  a curric:KeyLearningPoint ;
  rdfs:label """The relative atomic mass is the mean mass of an atom compared to 1/12 of the mass of
  a carbon-12 atom."""@en ;
  dcterms:modified "2026-06-09T00:46:37.441606Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20085-2
  a curric:KeyLearningPoint ;
  rdfs:label """The relative formula mass (RFM or Mr) is the sum of the relative atomic masses of
  all the atoms in a chemical formula."""@en ;
  dcterms:modified "2026-06-09T00:46:37.441612Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20085-3
  a curric:KeyLearningPoint ;
  rdfs:label """%mass of an element in a compound = (relative mass of element in compound ÷ RFM of
  compound) × 100"""@en ;
  dcterms:modified "2026-06-09T00:46:37.441619Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9662-1
  a curric:KeyLearningPoint ;
  rdfs:label """Empirical formula is the simplest whole number ratio of atoms of each element in a
  compound."""@en ;
  dcterms:modified "2026-06-09T00:46:37.444401Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9662-2
  a curric:KeyLearningPoint ;
  rdfs:label """Using the masses of elements reacted together, or their percentage compositions,
  calculate the empirical formula."""@en ;
  dcterms:modified "2026-06-09T00:46:37.444407Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9662-3
  a curric:KeyLearningPoint ;
  rdfs:label """Knowing the relative formula mass of a substance, and its empirical formula,
  calculate the molecular formula."""@en ;
  dcterms:modified "2026-06-09T00:46:37.444413Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9662-4
  a curric:KeyLearningPoint ;
  rdfs:label "Know that we are using moles, and molar ratios to calculate formulae"@en ;
  dcterms:modified "2026-06-09T00:46:37.444420Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8318-1
  a curric:KeyLearningPoint ;
  rdfs:label """Group 0 elements are called noble gases (or inert gases) and are very unreactive
  with other elements."""@en ;
  dcterms:modified "2026-06-09T00:46:37.446388Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8318-2
  a curric:KeyLearningPoint ;
  rdfs:label """Group 0 elements can be described as having either full or empty outer electron
  shells."""@en ;
  dcterms:modified "2026-06-09T00:46:37.446394Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8318-3
  a curric:KeyLearningPoint ;
  rdfs:label "Moving down Group 0 elements density and boiling points increase."@en ;
  dcterms:modified "2026-06-09T00:46:37.446400Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8318-4
  a curric:KeyLearningPoint ;
  rdfs:label """Noble gases emit coloured light when a high voltage is applied across them, and they
  do not decompose."""@en ;
  dcterms:modified "2026-06-09T00:46:37.446406Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8315-1
  a curric:KeyLearningPoint ;
  rdfs:label """The atomic number of an element states the number of protons in the nucleus of every
  atom of that element."""@en ;
  dcterms:modified "2026-06-09T00:46:37.451998Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8315-2
  a curric:KeyLearningPoint ;
  rdfs:label """The number of electrons in an atom is equal to the number of protons in the nucleus
  of the atom."""@en ;
  dcterms:modified "2026-06-09T00:46:37.452004Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8315-3
  a curric:KeyLearningPoint ;
  rdfs:label """The mass number of an element is about equal to the number of protons and neutrons
  in atoms of that element."""@en ;
  dcterms:modified "2026-06-09T00:46:37.452009Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9699-1
  a curric:KeyLearningPoint ;
  rdfs:label """An investigation can measure the temperature change through continuous heating of a
  substance."""@en ;
  dcterms:modified "2026-06-09T00:46:37.463581Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9699-2
  a curric:KeyLearningPoint ;
  rdfs:label "Heating curve observations are best presented in a table and graphically."@en ;
  dcterms:modified "2026-06-09T00:46:37.463586Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9699-3
  a curric:KeyLearningPoint ;
  rdfs:label """Reliable data can be collected by taking repeat measurements, identifying anomalies
  and calculating a mean."""@en ;
  dcterms:modified "2026-06-09T00:46:37.463591Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9699-4
  a curric:KeyLearningPoint ;
  rdfs:label "Heating curves can be used to determine the melting point of a substance."@en ;
  dcterms:modified "2026-06-09T00:46:37.463596Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9753-1
  a curric:KeyLearningPoint ;
  rdfs:label """Electrolysis involves the decomposition / break-down of a substance by passing an
  electric current."""@en ;
  dcterms:modified "2026-06-09T00:46:37.463601Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9753-2
  a curric:KeyLearningPoint ;
  rdfs:label "Two types of positive ions are in competition at the negative electrode"@en ;
  dcterms:modified "2026-06-09T00:46:37.463606Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9753-3
  a curric:KeyLearningPoint ;
  rdfs:label "Two types of negative ions are in competition at the positive electrode"@en ;
  dcterms:modified "2026-06-09T00:46:37.463611Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9753-4
  a curric:KeyLearningPoint ;
  rdfs:label "There are rules for which substances are discharged at the anode and cathode"@en ;
  dcterms:modified "2026-06-09T00:46:37.463616Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9753-5
  a curric:KeyLearningPoint ;
  rdfs:label "The gases produced during electrolysis can be collected and tested"@en ;
  dcterms:modified "2026-06-09T00:46:37.463621Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9672-1
  a curric:KeyLearningPoint ;
  rdfs:label """When powdered hydroxide/oxide (base) is added to an acidic solution there is an
  increase in pH."""@en ;
  dcterms:modified "2026-06-09T00:46:37.463653Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9672-2
  a curric:KeyLearningPoint ;
  rdfs:label "pH changes quickly around the neutralisation point."@en ;
  dcterms:modified "2026-06-09T00:46:37.463658Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9672-3
  a curric:KeyLearningPoint ;
  rdfs:label """Indicators, such as Universal Indicator paper, can be used to collect quantitative
  data on pH."""@en ;
  dcterms:modified "2026-06-09T00:46:37.463663Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9672-4
  a curric:KeyLearningPoint ;
  rdfs:label """pH can be plotted on a graph to find the quantity of base required to neutralise an
  acid."""@en ;
  dcterms:modified "2026-06-09T00:46:37.463671Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9688-1
  a curric:KeyLearningPoint ;
  rdfs:label "Changes in heat energy accompany salts dissolving in water."@en ;
  dcterms:modified "2026-06-09T00:46:37.463679Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9688-2
  a curric:KeyLearningPoint ;
  rdfs:label """Changes in heat energy accompany neutralisation, displacement and precipitation
  reactions."""@en ;
  dcterms:modified "2026-06-09T00:46:37.463685Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9688-3
  a curric:KeyLearningPoint ;
  rdfs:label "Exothermic and endothermic reactions have everyday uses."@en ;
  dcterms:modified "2026-06-09T00:46:37.463690Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9688-4
  a curric:KeyLearningPoint ;
  rdfs:label """When reactions take place in solution, temperature changes can be measured to
  reflect the energy changes."""@en ;
  dcterms:modified "2026-06-09T00:46:37.463695Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9720-1
  a curric:KeyLearningPoint ;
  rdfs:label """Increasing temperature generally increases rate by boosting the energy and frequency
  of collisions between particles."""@en ;
  dcterms:modified "2026-06-09T00:46:37.463850Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9720-2
  a curric:KeyLearningPoint ;
  rdfs:label """Cooling a reactant decreases its reaction rate by reducing collision energy and
  frequency."""@en ;
  dcterms:modified "2026-06-09T00:46:37.463855Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8376-1
  a curric:KeyLearningPoint ;
  rdfs:label """The changing rate of a chemical reaction can be represented by a graph of mass of
  gas produced against time."""@en ;
  dcterms:modified "2026-06-09T00:46:37.464087Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8376-2
  a curric:KeyLearningPoint ;
  rdfs:label """When reacting excess marble chips with acid, the same mass of gas is produced for
  all surface areas of chips."""@en ;
  dcterms:modified "2026-06-09T00:46:37.464092Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8376-3
  a curric:KeyLearningPoint ;
  rdfs:label "The mean rate of reaction = total mass of gas produced ÷ total time of reaction"@en ;
  dcterms:modified "2026-06-09T00:46:37.464100Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8376-4
  a curric:KeyLearningPoint ;
  rdfs:label "The instantaneous rate of reaction is equal to the gradient of the graph."@en ;
  dcterms:modified "2026-06-09T00:46:37.464106Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8376-5
  a curric:KeyLearningPoint ;
  rdfs:label """The gradient of a rate of reaction graph can be calculated from a tangent drawn at a
  point on the curve."""@en ;
  dcterms:modified "2026-06-09T00:46:37.464111Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8355-1
  a curric:KeyLearningPoint ;
  rdfs:label """Reacting a metal oxide with an appropriate acid can form a desired salt and
  water."""@en ;
  dcterms:modified "2026-06-09T00:46:37.467705Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8355-2
  a curric:KeyLearningPoint ;
  rdfs:label """Adding metal oxide to excess ensures that the acid fully reacts to form salt and
  water."""@en ;
  dcterms:modified "2026-06-09T00:46:37.467711Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8355-3
  a curric:KeyLearningPoint ;
  rdfs:label """Excess metal oxide can be removed by filtration so that the filtrate contains only
  salt and water."""@en ;
  dcterms:modified "2026-06-09T00:46:37.467716Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8355-4
  a curric:KeyLearningPoint ;
  rdfs:label "Water can be removed from the salt by evaporation."@en ;
  dcterms:modified "2026-06-09T00:46:37.467721Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9703-1
  a curric:KeyLearningPoint ;
  rdfs:label """Manipulating apparatus correctly ensures both accurate results and safety in the
  lab."""@en ;
  dcterms:modified "2026-06-09T00:46:37.467981Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9703-2
  a curric:KeyLearningPoint ;
  rdfs:label """Interconversion between units like grams, moles, volume, density and particles is
  fundamental in chemical calculations."""@en ;
  dcterms:modified "2026-06-09T00:46:37.467986Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9703-3
  a curric:KeyLearningPoint ;
  rdfs:label "Successful interconversion is only possible if the units match."@en ;
  dcterms:modified "2026-06-09T00:46:37.467991Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9703-4
  a curric:KeyLearningPoint ;
  rdfs:label """Using the appropriate apparatus for a required measurement can help to reduce
  uncertainty."""@en ;
  dcterms:modified "2026-06-09T00:46:37.467996Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9727-1
  a curric:KeyLearningPoint ;
  rdfs:label "At equilibrium, both reactants and products are formed at the same rate."@en ;
  dcterms:modified "2026-06-09T00:46:37.468911Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9727-2
  a curric:KeyLearningPoint ;
  rdfs:label "Amounts of reactants and products remain constant at equilibrium."@en ;
  dcterms:modified "2026-06-09T00:46:37.468916Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9727-3
  a curric:KeyLearningPoint ;
  rdfs:label "Equilibrium can only occur in a closed system."@en ;
  dcterms:modified "2026-06-09T00:46:37.468921Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9713-1
  a curric:KeyLearningPoint ;
  rdfs:label "The pH scale ranges from 0 to 14, indicating how acidic or basic a substance is."@en ;
  dcterms:modified "2026-06-09T00:46:37.470570Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9713-2
  a curric:KeyLearningPoint ;
  rdfs:label """Universal indicator provides a full range of colours corresponding to different pH
  levels, and this can be a limitation."""@en ;
  dcterms:modified "2026-06-09T00:46:37.470575Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9713-3
  a curric:KeyLearningPoint ;
  rdfs:label "Phenolphthalein changes from colourless to pink in alkaline conditions."@en ;
  dcterms:modified "2026-06-09T00:46:37.470581Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9713-4
  a curric:KeyLearningPoint ;
  rdfs:label """Methyl orange shifts from red in acidic conditions to yellow in basic
  conditions."""@en ;
  dcterms:modified "2026-06-09T00:46:37.470586Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9713-5
  a curric:KeyLearningPoint ;
  rdfs:label """Litmus paper turns red in acidic conditions and blue in basic conditions, the
  solution will be purple when neutral."""@en ;
  dcterms:modified "2026-06-09T00:46:37.470592Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27910-1
  a curric:KeyLearningPoint ;
  rdfs:label """The pH of water samples can be determined using appropriate methods and/or
  instruments e.g pH meter."""@en ;
  dcterms:modified "2026-06-09T00:46:37.470777Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27910-2
  a curric:KeyLearningPoint ;
  rdfs:label "pH data can be analysed to assess if water contains impurities."@en ;
  dcterms:modified "2026-06-09T00:46:37.470782Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27910-3
  a curric:KeyLearningPoint ;
  rdfs:label "Different substances dissolve in different types of water."@en ;
  dcterms:modified "2026-06-09T00:46:37.470788Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27910-4
  a curric:KeyLearningPoint ;
  rdfs:label """The substances that dissolve in different waters can affect the water's acidity or
  alkalinity (i.e. its pH)."""@en ;
  dcterms:modified "2026-06-09T00:46:37.470795Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27910-5
  a curric:KeyLearningPoint ;
  rdfs:label "Pure water is necessary for laboratory tests; it must be neutral (i.e. pH 7)."@en ;
  dcterms:modified "2026-06-09T00:46:37.470801Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8379-1
  a curric:KeyLearningPoint ;
  rdfs:label """The reaction between sodium thiosulfate solution and hydrochloric acid produces a
  cloudy precipitate."""@en ;
  dcterms:modified "2026-06-09T00:46:37.471235Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8379-2
  a curric:KeyLearningPoint ;
  rdfs:label """At the end point of the disappearing cross experiment, each reaction has produced
  the same amount of product."""@en ;
  dcterms:modified "2026-06-09T00:46:37.471240Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8379-3
  a curric:KeyLearningPoint ;
  rdfs:label """At the end point of the disappearing cross experiment, the chemical reaction may not
  be complete."""@en ;
  dcterms:modified "2026-06-09T00:46:37.471245Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8379-4
  a curric:KeyLearningPoint ;
  rdfs:label """Increasing concentration of a reacting solution introduces more reactant particles,
  so they collide more frequently."""@en ;
  dcterms:modified "2026-06-09T00:46:37.471251Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9717-1
  a curric:KeyLearningPoint ;
  rdfs:label """Neutralisation reactions involve an acid reacting with a base to form salt and
  water."""@en ;
  dcterms:modified "2026-06-09T00:46:37.471351Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9717-2
  a curric:KeyLearningPoint ;
  rdfs:label "Exothermic reactions release energy to the surroundings, often through heating."@en ;
  dcterms:modified "2026-06-09T00:46:37.471356Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9717-3
  a curric:KeyLearningPoint ;
  rdfs:label "Methods must be detailed and replicable for reliable data collection."@en ;
  dcterms:modified "2026-06-09T00:46:37.471362Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9717-4
  a curric:KeyLearningPoint ;
  rdfs:label """The initial and final temperatures of the reaction mixture need to be recorded to
  calculate energy change."""@en ;
  dcterms:modified "2026-06-09T00:46:37.471367Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9717-5
  a curric:KeyLearningPoint ;
  rdfs:label """Line graphs can illustrate relationships between continuous variables in
  experiments."""@en ;
  dcterms:modified "2026-06-09T00:46:37.471373Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27587-1
  a curric:KeyLearningPoint ;
  rdfs:label """Sublimation is the change from solid to gas; deposition is the change from gas to
  solid, both bypass the liquid state."""@en ;
  dcterms:modified "2026-06-09T00:46:37.473855Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27587-2
  a curric:KeyLearningPoint ;
  rdfs:label """Sublimation and deposition occur at specific conditions of temperature and
  pressure."""@en ;
  dcterms:modified "2026-06-09T00:46:37.473860Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27587-3
  a curric:KeyLearningPoint ;
  rdfs:label """Energy changes in sublimation/deposition are similar to melting/freezing but happen
  directly between solid and gas."""@en ;
  dcterms:modified "2026-06-09T00:46:37.473866Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27587-4
  a curric:KeyLearningPoint ;
  rdfs:label """Evaporation is when a liquid changes to gas at the surface as particles gain enough
  energy to overcome forces."""@en ;
  dcterms:modified "2026-06-09T00:46:37.473871Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9645-1
  a curric:KeyLearningPoint ;
  rdfs:label "Chromatograms can identify unknown substances through comparison or Rf values."@en ;
  dcterms:modified "2026-06-09T00:46:37.475242Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9645-2
  a curric:KeyLearningPoint ;
  rdfs:label """Appropriate equipment should be used during comparisons, and calculations should
  consider significant figures."""@en ;
  dcterms:modified "2026-06-09T00:46:37.475247Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9645-3
  a curric:KeyLearningPoint ;
  rdfs:label """A fair comparison of chromatograms depends on stationary and mobile phase choices,
  sample concentration and temperature."""@en ;
  dcterms:modified "2026-06-09T00:46:37.475252Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9645-4
  a curric:KeyLearningPoint ;
  rdfs:label "Chromatograms can be used to identify pure and impure substances."@en ;
  dcterms:modified "2026-06-09T00:46:37.475257Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9678-1
  a curric:KeyLearningPoint ;
  rdfs:label """In a titration, a trial investigation helps estimate the amount of acid needed to
  neutralise the alkali."""@en ;
  dcterms:modified "2026-06-09T00:46:37.479219Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9678-2
  a curric:KeyLearningPoint ;
  rdfs:label """Near the end point, add the acid drop by drop whilst swirling the solution in the
  conical flask to mix."""@en ;
  dcterms:modified "2026-06-09T00:46:37.479224Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9678-3
  a curric:KeyLearningPoint ;
  rdfs:label """Placing a white tile under the conical flask enhances the visibility of the colour
  change and accuracy of readings."""@en ;
  dcterms:modified "2026-06-09T00:46:37.479229Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9678-4
  a curric:KeyLearningPoint ;
  rdfs:label "Volume readings should be taken at eye level from the bottom of the meniscus."@en ;
  dcterms:modified "2026-06-09T00:46:37.479234Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9678-5
  a curric:KeyLearningPoint ;
  rdfs:label "Concordant titres are typically within ±0.10 cm³."@en ;
  dcterms:modified "2026-06-09T00:46:37.479239Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9647-1
  a curric:KeyLearningPoint ;
  rdfs:label """Appropriate equipment should be used to separate substances in a mixture of
  inks."""@en ;
  dcterms:modified "2026-06-09T00:46:37.479613Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9647-2
  a curric:KeyLearningPoint ;
  rdfs:label "Inks are a mixture of substances that can be separated using distillation."@en ;
  dcterms:modified "2026-06-09T00:46:37.479619Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9647-3
  a curric:KeyLearningPoint ;
  rdfs:label "Care should be taken when heating substances to their boiling points."@en ;
  dcterms:modified "2026-06-09T00:46:37.479624Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9647-4
  a curric:KeyLearningPoint ;
  rdfs:label "Simple distillation completed in the school lab has limitations."@en ;
  dcterms:modified "2026-06-09T00:46:37.479629Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8375-1
  a curric:KeyLearningPoint ;
  rdfs:label """The changing rate of a reaction can be found by measuring the mass of gas produced
  as the reaction progresses."""@en ;
  dcterms:modified "2026-06-09T00:46:37.479689Z"^^xsd:dateTime .

