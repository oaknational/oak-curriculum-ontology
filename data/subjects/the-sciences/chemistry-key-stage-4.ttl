oakcurric:priorknowledge-963-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Some acids are corrosive and can burn skin."@en ;
  dcterms:modified "2026-06-09T00:45:29.036618Z"^^xsd:dateTime .

oakcurric:priorknowledge-963-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """A base is a substance that reacts with acids and neutralises them to stop them being
  acidic."""@en ;
  dcterms:modified "2026-06-09T00:45:29.036629Z"^^xsd:dateTime .

oakcurric:priorknowledge-963-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "An alkali is a base that is dissolved in water."@en ;
  dcterms:modified "2026-06-09T00:45:29.036635Z"^^xsd:dateTime .

oakcurric:priorknowledge-963-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "The neutralisation reaction is: acid + base → salt + water"@en ;
  dcterms:modified "2026-06-09T00:45:29.036640Z"^^xsd:dateTime .

oakcurric:priorknowledge-963-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "When hydrochloric acid is neutralised, a chloride salt is formed."@en ;
  dcterms:modified "2026-06-09T00:45:29.036645Z"^^xsd:dateTime .

oakcurric:priorknowledge-963-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "When sulphuric acid is neutralised, a sulfate salt is formed."@en ;
  dcterms:modified "2026-06-09T00:45:29.036654Z"^^xsd:dateTime .

oakcurric:priorknowledge-963-7
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "When nitric acid is neutralised, a nitrate salt is formed."@en ;
  dcterms:modified "2026-06-09T00:45:29.036659Z"^^xsd:dateTime .

oakcurric:priorknowledge-963-8
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Metal + acid → salt + hydrogen"@en ;
  dcterms:modified "2026-06-09T00:45:29.036664Z"^^xsd:dateTime .

oakcurric:priorknowledge-963-9
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Metal hydroxide / metal oxide + acid → salt + water"@en ;
  dcterms:modified "2026-06-09T00:45:29.036669Z"^^xsd:dateTime .

oakcurric:priorknowledge-963-10
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Metal carbonate + acid → salt + water + carbon dioxide"@en ;
  dcterms:modified "2026-06-09T00:45:29.036676Z"^^xsd:dateTime .

oakcurric:priorknowledge-1149-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "An exothermic chemical reaction causes an increase in temperature."@en ;
  dcterms:modified "2026-06-09T00:45:29.041466Z"^^xsd:dateTime .

oakcurric:priorknowledge-1149-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "An endothermic chemical reaction causes a decrease in temperature."@en ;
  dcterms:modified "2026-06-09T00:45:29.041477Z"^^xsd:dateTime .

oakcurric:priorknowledge-1149-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "An exothermic reaction transfers energy from the reactants to the surroundings."@en ;
  dcterms:modified "2026-06-09T00:45:29.041482Z"^^xsd:dateTime .

oakcurric:priorknowledge-1149-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "An endothermic reaction transfers energy from the surroundings to the products."@en ;
  dcterms:modified "2026-06-09T00:45:29.041487Z"^^xsd:dateTime .

oakcurric:priorknowledge-1149-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Characteristics of chemical reactions include changes in colour, bubbling, or a
  change of temperature."""@en ;
  dcterms:modified "2026-06-09T00:45:29.041491Z"^^xsd:dateTime .

oakcurric:priorknowledge-1149-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """When a metal reacts with acid bubbles may form, the temperature rise and the metal
  reduce in size or disappear."""@en ;
  dcterms:modified "2026-06-09T00:45:29.041495Z"^^xsd:dateTime .

oakcurric:priorknowledge-1149-7
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "The neutralisation reaction is: base + acid ⭢ salt + water"@en ;
  dcterms:modified "2026-06-09T00:45:29.041500Z"^^xsd:dateTime .

oakcurric:priorknowledge-970-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The rate of a chemical reaction is equal to the amount of product formed per unit
  time."""@en ;
  dcterms:modified "2026-06-09T00:45:29.247687Z"^^xsd:dateTime .

oakcurric:priorknowledge-970-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The gradient of a rate of reaction graph can be calculated from a tangent drawn at a
  point on the curve."""@en ;
  dcterms:modified "2026-06-09T00:45:29.247699Z"^^xsd:dateTime .

oakcurric:priorknowledge-970-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """A catalyst affects the rate of a chemical reaction, but is not a reactant or a
  product of the reaction."""@en ;
  dcterms:modified "2026-06-09T00:45:29.247704Z"^^xsd:dateTime .

oakcurric:priorknowledge-970-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Ceramics are made from soft substances, which when heated become hard and
  brittle."""@en ;
  dcterms:modified "2026-06-09T00:45:29.247709Z"^^xsd:dateTime .

oakcurric:priorknowledge-970-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Plastics are made from polymers and there are many types of plastics with very
  different properties."""@en ;
  dcterms:modified "2026-06-09T00:45:29.247713Z"^^xsd:dateTime .

oakcurric:priorknowledge-970-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Some polymers are made of a single long chain of atoms, and other have many chains
  branching off each other."""@en ;
  dcterms:modified "2026-06-09T00:45:29.247722Z"^^xsd:dateTime .

oakcurric:priorknowledge-970-7
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The properties of a composite material can be predicted or designed based on the
  properties of the materials it contains."""@en ;
  dcterms:modified "2026-06-09T00:45:29.247726Z"^^xsd:dateTime .

oakcurric:priorknowledge-970-8
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Transition metals can be located in the centre of the periodic table, and have
  typical properties of metals"""@en ;
  dcterms:modified "2026-06-09T00:45:29.247731Z"^^xsd:dateTime .

oakcurric:priorknowledge-960-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Ions are a form of atom that have either lost or gained electrons"@en ;
  dcterms:modified "2026-06-09T00:45:29.580885Z"^^xsd:dateTime .

oakcurric:priorknowledge-960-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Metals form positive ions and non metals form negative ions"@en ;
  dcterms:modified "2026-06-09T00:45:29.580896Z"^^xsd:dateTime .

oakcurric:priorknowledge-960-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Most ionic substances are soluble"@en ;
  dcterms:modified "2026-06-09T00:45:29.580902Z"^^xsd:dateTime .

oakcurric:priorknowledge-960-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Reactions that produce insoluble solids are called precipitation reactions"@en ;
  dcterms:modified "2026-06-09T00:45:29.580906Z"^^xsd:dateTime .

oakcurric:priorknowledge-960-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Ionic equations show only the species of a chemical reaction that have changed"@en ;
  dcterms:modified "2026-06-09T00:45:29.580911Z"^^xsd:dateTime .

oakcurric:priorknowledge-968-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Coal is a sedimentary rock that burns because it is made mostly of carbon, with some
  impurities."""@en ;
  dcterms:modified "2026-06-09T00:45:29.823716Z"^^xsd:dateTime .

oakcurric:priorknowledge-968-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "The organic matter that formed oil and gas decomposed into hydrocarbons."@en ;
  dcterms:modified "2026-06-09T00:45:29.823728Z"^^xsd:dateTime .

oakcurric:priorknowledge-968-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """When fuels containing carbon are burned it is common for carbon dioxide to
  be made."""@en ;
  dcterms:modified "2026-06-09T00:45:29.823733Z"^^xsd:dateTime .

oakcurric:priorknowledge-968-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Less than 1% of the Earth’s atmosphere is carbon dioxide."@en ;
  dcterms:modified "2026-06-09T00:45:29.823738Z"^^xsd:dateTime .

oakcurric:priorknowledge-968-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Carbon dioxide is a greenhouse gas."@en ;
  dcterms:modified "2026-06-09T00:45:29.823742Z"^^xsd:dateTime .

oakcurric:priorknowledge-968-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """In the atmosphere, some gases are greenhouse gases and have properties that enable
  its temperature to rise over time."""@en ;
  dcterms:modified "2026-06-09T00:45:29.823747Z"^^xsd:dateTime .

oakcurric:priorknowledge-968-7
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Combustion increases the amount of carbon dioxide in the atmosphere."@en ;
  dcterms:modified "2026-06-09T00:45:29.823751Z"^^xsd:dateTime .

oakcurric:priorknowledge-1146-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Covalent bonds form when non-metal atoms share electrons."@en ;
  dcterms:modified "2026-06-09T00:45:29.985811Z"^^xsd:dateTime .

oakcurric:priorknowledge-1146-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Non-metal, covalent molecules form simple molecules or giant covalent
  (macromolecular) structures."""@en ;
  dcterms:modified "2026-06-09T00:45:29.985822Z"^^xsd:dateTime .

oakcurric:priorknowledge-1146-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Non-metals atoms in group 5 can form three covalent bonds; those in group 4, four
  covalent bonds."""@en ;
  dcterms:modified "2026-06-09T00:45:29.985827Z"^^xsd:dateTime .

oakcurric:priorknowledge-1146-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Simple molecules have low melting and boiling points because the intermolecular
  forces between them are weak, requiring little energy."""@en ;
  dcterms:modified "2026-06-09T00:45:29.985832Z"^^xsd:dateTime .

oakcurric:priorknowledge-1146-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Giant covalent structures have high melting and boiling points because the strong
  covalent bonds need a lot of energy to be broken."""@en ;
  dcterms:modified "2026-06-09T00:45:29.985836Z"^^xsd:dateTime .

oakcurric:priorknowledge-971-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "In a chemical reaction, atoms rearrange themselves to form new substances."@en ;
  dcterms:modified "2026-06-09T00:45:30.422965Z"^^xsd:dateTime .

oakcurric:priorknowledge-971-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Water is often formed in chemical reactions if oxygen and hydrogen atoms are
  present."""@en ;
  dcterms:modified "2026-06-09T00:45:30.422976Z"^^xsd:dateTime .

oakcurric:priorknowledge-971-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Carbon dioxide is often formed in chemical reactions if oxygen and carbon atoms are
  present."""@en ;
  dcterms:modified "2026-06-09T00:45:30.422981Z"^^xsd:dateTime .

oakcurric:priorknowledge-971-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Chemical formulae represent the numbers of each type of atoms in a reactant or
  product."""@en ;
  dcterms:modified "2026-06-09T00:45:30.422986Z"^^xsd:dateTime .

oakcurric:priorknowledge-971-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The displayed formula for a molecule shows all the atoms, with all the bonds between
  them."""@en ;
  dcterms:modified "2026-06-09T00:45:30.422990Z"^^xsd:dateTime .

oakcurric:priorknowledge-971-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The general formula for an alkane is CnH2n+2; the general formula for alkenes is
  CnH2n."""@en ;
  dcterms:modified "2026-06-09T00:45:30.422995Z"^^xsd:dateTime .

oakcurric:priorknowledge-971-7
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Alkanes can be burnt for heating and produce carbon dioxide and water."@en ;
  dcterms:modified "2026-06-09T00:45:30.422999Z"^^xsd:dateTime .

oakcurric:priorknowledge-971-8
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Smaller hydrocarbon molecules have lower boiling points and evaporate more easily
  making them more flammable."""@en ;
  dcterms:modified "2026-06-09T00:45:30.423004Z"^^xsd:dateTime .

oakcurric:priorknowledge-971-9
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Smaller hydrocarbon molecules with double bonds are very reactive and useful for
  making other products like polymers."""@en ;
  dcterms:modified "2026-06-09T00:45:30.423008Z"^^xsd:dateTime .

oakcurric:priorknowledge-971-10
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Bromine water changes from orange/brown to colourless in the presence of an
  alkene."""@en ;
  dcterms:modified "2026-06-09T00:45:30.423012Z"^^xsd:dateTime .

oakcurric:priorknowledge-967-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Non-renewable energy resources cannot be replaced in our lifetime once they are used
  up."""@en ;
  dcterms:modified "2026-06-09T00:45:30.679568Z"^^xsd:dateTime .

oakcurric:priorknowledge-967-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "There is a limited supply of non-renewable energy resources."@en ;
  dcterms:modified "2026-06-09T00:45:30.679581Z"^^xsd:dateTime .

oakcurric:priorknowledge-967-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "A chemical that is oxidised either gains oxygen or loses electrons."@en ;
  dcterms:modified "2026-06-09T00:45:30.679587Z"^^xsd:dateTime .

oakcurric:priorknowledge-967-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "A chemical that is reduced either loses oxygen or gains electrons."@en ;
  dcterms:modified "2026-06-09T00:45:30.679592Z"^^xsd:dateTime .

oakcurric:priorknowledge-967-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "A redox reaction is one in which both oxidation and reduction take place."@en ;
  dcterms:modified "2026-06-09T00:45:30.679597Z"^^xsd:dateTime .

oakcurric:priorknowledge-967-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The reactivity series for metals shows how vigorously metals react, compared to each
  other."""@en ;
  dcterms:modified "2026-06-09T00:45:30.679601Z"^^xsd:dateTime .

oakcurric:priorknowledge-967-7
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The higher the position of a metal in the reactivity series, the more vigorously it
  is likely to react."""@en ;
  dcterms:modified "2026-06-09T00:45:30.679606Z"^^xsd:dateTime .

oakcurric:priorknowledge-967-8
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """A metal ore is typically rock that contains a metal in a form that can be
  extracted."""@en ;
  dcterms:modified "2026-06-09T00:45:30.679610Z"^^xsd:dateTime .

oakcurric:priorknowledge-967-9
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Carbon can be used to extract some metals from their ores."@en ;
  dcterms:modified "2026-06-09T00:45:30.679615Z"^^xsd:dateTime .

oakcurric:priorknowledge-967-10
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Carbon is more reactive than copper or zinc, but less reactive than aluminium or
  magnesium."""@en ;
  dcterms:modified "2026-06-09T00:45:30.679620Z"^^xsd:dateTime .

