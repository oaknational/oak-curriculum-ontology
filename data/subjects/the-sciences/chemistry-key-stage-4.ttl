  dcterms:modified "2026-06-09T00:46:37.515197Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9725-3
  a curric:KeyLearningPoint ;
  rdfs:label "Transition metals are often catalysts that speed up chemical reactions."@en ;
  dcterms:modified "2026-06-09T00:46:37.515201Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9725-4
  a curric:KeyLearningPoint ;
  rdfs:label """Transition metals can form ions with different charges and their compounds often
  exhibit vibrant colours."""@en ;
  dcterms:modified "2026-06-09T00:46:37.515206Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8333-1
  a curric:KeyLearningPoint ;
