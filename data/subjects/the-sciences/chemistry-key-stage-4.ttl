  schema:description "a compound used in the smelting of aluminium to lower the melting point"@en ;
  dcterms:modified "2026-06-07T15:30:02.417056Z"^^xsd:dateTime .

oakcurric:keyword-physical-change
  a curric:Keyword ;
  schema:name "physical change"@en ;
  schema:description """A change in which no new substances are formed, such as a change in state,
  e.g. melting."""@en ;
  dcterms:modified "2026-06-07T15:30:02.417061Z"^^xsd:dateTime .

oakcurric:keyword-chemical-change
  a curric:Keyword ;
  schema:name "chemical change"@en ;
  schema:description """Occurs when a reaction takes place and atoms or ions in the reactants are
