  dcterms:modified "2026-06-07T15:30:02.350292Z"^^xsd:dateTime .

oakcurric:keyword-volume
  a curric:Keyword ;
  schema:name "volume"@en ;
  schema:description """Volume is how much 3D space matter occupies. It is usually measured
  in cm³."""@en ;
  dcterms:modified "2026-06-07T15:30:02.350297Z"^^xsd:dateTime .

oakcurric:keyword-accurate
  a curric:Keyword ;
  schema:name "accurate"@en ;
  schema:description "Accurate measurements are those that are close to the true value."@en ;
  dcterms:modified "2026-06-07T15:30:02.350302Z"^^xsd:dateTime .

oakcurric:keyword-precise
  a curric:Keyword ;
  schema:name "precise"@en ;
  schema:description """Precise measurements have very little spread from the mean value. They are
  values that lie close to each other."""@en ;
  dcterms:modified "2026-06-07T15:30:02.350309Z"^^xsd:dateTime .

oakcurric:keyword-embryonic-stem-cell
  a curric:Keyword ;
  schema:name "embryonic stem cell"@en ;
  schema:description """A cell taken from the embryo that can differentiate into any type of
  specialised cell."""@en ;
  dcterms:modified "2026-06-07T15:30:02.350313Z"^^xsd:dateTime .

oakcurric:keyword-adult-stem-cell
  a curric:Keyword ;
