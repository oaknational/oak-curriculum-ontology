  schema:description """A form of contraception that prevents pregnancy by blocking the sperm
  reaching the egg, and can also stop the spread of sexually transmitted infections."""@en ;
  dcterms:modified "2026-06-07T15:30:02.417109Z"^^xsd:dateTime .

oakcurric:keyword-lambda
  a curric:Keyword ;
  schema:name "lambda"@en ;
  schema:description "(λ) the symbol used for the wavelength of a wave"@en ;
  dcterms:modified "2026-06-07T15:30:02.417242Z"^^xsd:dateTime .

oakcurric:keyword-balanced-equation
  a curric:Keyword ;
