  dcterms:modified "2026-06-07T15:30:02.364515Z"^^xsd:dateTime .

oakcurric:keyword-phloem
  a curric:Keyword ;
  schema:name "phloem"@en ;
  schema:description """specialised vessels in plants that transport sugar, amino acids and other
  nutrients"""@en ;
  dcterms:modified "2026-06-07T15:30:02.364522Z"^^xsd:dateTime .

oakcurric:keyword-glucose
  a curric:Keyword ;
  schema:name "glucose"@en ;
  schema:description "a type of sugar, which is a simple carbohydrate"@en ;
  dcterms:modified "2026-06-07T15:30:02.364527Z"^^xsd:dateTime .

oakcurric:keyword-starch
  a curric:Keyword ;
  schema:name "starch"@en ;
  schema:description """a complex carbohydrate, made of many glucose molecules joined together to
  form a polymer"""@en ;
  dcterms:modified "2026-06-07T15:30:02.364534Z"^^xsd:dateTime .

oakcurric:keyword-iodine-solution
  a curric:Keyword ;
  schema:name "iodine solution"@en ;
  schema:description "a reagent that can be used to test for the presence of starch"@en ;
  dcterms:modified "2026-06-07T15:30:02.364539Z"^^xsd:dateTime .

oakcurric:keyword-independent-variable
  a curric:Keyword ;
  schema:name "independent variable"@en ;
  schema:description "the single variable that is changed in an investigation"@en ;
  dcterms:modified "2026-06-07T15:30:02.364551Z"^^xsd:dateTime .

oakcurric:keyword-dependent-variable
  a curric:Keyword ;
  schema:name "dependent variable"@en ;
  schema:description "the single variable that is measured or observed in an investigation"@en ;
  dcterms:modified "2026-06-07T15:30:02.364556Z"^^xsd:dateTime .

oakcurric:keyword-electrolysed
  a curric:Keyword ;
  schema:name "electrolysed"@en ;
  schema:description "when a substance has been broken down by electrolysis"@en ;
  dcterms:modified "2026-06-07T15:30:02.364560Z"^^xsd:dateTime .

oakcurric:keyword-ph
  a curric:Keyword ;
  schema:name "pH"@en ;
  schema:description "A measure of the hydrogen ion (H⁺) concentration in a solution."@en ;
  dcterms:modified "2026-06-07T15:30:02.364572Z"^^xsd:dateTime .

oakcurric:keyword-neutralisation
  a curric:Keyword ;
  schema:name "neutralisation"@en ;
  schema:description """A chemical reaction between an acid and base to produce a neutral solution
  of a metal salt and water."""@en ;
  dcterms:modified "2026-06-07T15:30:02.364576Z"^^xsd:dateTime .

oakcurric:keyword-base
  a curric:Keyword ;
  schema:name "base"@en ;
  schema:description "A substance that neutralises an acid to form a salt and water."@en ;
  dcterms:modified "2026-06-07T15:30:02.364583Z"^^xsd:dateTime .

oakcurric:keyword-quantitative
  a curric:Keyword ;
  schema:name "quantitative"@en ;
  schema:description "Refers to a measurement of quantity. A numerical value."@en ;
  dcterms:modified "2026-06-07T15:30:02.364588Z"^^xsd:dateTime .

oakcurric:keyword-calorimetry
  a curric:Keyword ;
  schema:name "calorimetry"@en ;
  schema:description """Calorimetry is an experiment than can be used to measure an energy change
  during a reaction."""@en ;
  dcterms:modified "2026-06-07T15:30:02.364593Z"^^xsd:dateTime .

oakcurric:keyword-lens
  a curric:Keyword ;
  schema:name "lens"@en ;
  schema:description "Glass or plastic disc that refracts light to increase magnification."@en ;
  dcterms:modified "2026-06-07T15:30:02.364597Z"^^xsd:dateTime .

oakcurric:keyword-filament-lamp
  a curric:Keyword ;
  schema:name "filament lamp"@en ;
  schema:description "a type of lamp that uses a hot wire to emit light"@en ;
  dcterms:modified "2026-06-07T15:30:02.364602Z"^^xsd:dateTime .

oakcurric:keyword-variable-resistor
  a curric:Keyword ;
  schema:name "variable resistor"@en ;
  schema:description "a resistor that can be easily changed to any value in its range"@en ;
  dcterms:modified "2026-06-07T15:30:02.364609Z"^^xsd:dateTime .

oakcurric:keyword-repeat-reading
  a curric:Keyword ;
  schema:name "repeat reading"@en ;
  schema:description "when a measurement is taken again to improve the experiment"@en ;
  dcterms:modified "2026-06-07T15:30:02.364614Z"^^xsd:dateTime .

oakcurric:keyword-best-fit-line
  a curric:Keyword ;
  schema:name "best fit line"@en ;
  schema:description """a line that shows the underlying trend of a set of results on a graph, it
  can be straight or curved"""@en ;
  dcterms:modified "2026-06-07T15:30:02.364618Z"^^xsd:dateTime .

oakcurric:keyword-random
  a curric:Keyword ;
  schema:name "random"@en ;
  schema:description "to happen entirely by chance"@en ;
  dcterms:modified "2026-06-07T15:30:02.364623Z"^^xsd:dateTime .

oakcurric:keyword-radioactive-decay
  a curric:Keyword ;
  schema:name "radioactive decay"@en ;
  schema:description "a random process by which unstable nuclei emit radiation"@en ;
  dcterms:modified "2026-06-07T15:30:02.364628Z"^^xsd:dateTime .

oakcurric:keyword-decay-curve
  a curric:Keyword ;
  schema:name "decay curve"@en ;
  schema:description """shows the pattern in radioactive decay for a large set of identical unstable
  nuclei"""@en ;
  dcterms:modified "2026-06-07T15:30:02.364632Z"^^xsd:dateTime .

oakcurric:keyword-radioactive-half-life
  a curric:Keyword ;
  schema:name "radioactive half-life"@en ;
  schema:description "the time taken for half the nuclei of a radioactive isotope to decay"@en ;
  dcterms:modified "2026-06-07T15:30:02.364637Z"^^xsd:dateTime .

oakcurric:keyword-collision-theory
  a curric:Keyword ;
  schema:name "collision theory"@en ;
  schema:description """The collision theory is that particles must collide, and with sufficient
  energy, in order to react."""@en ;
  dcterms:modified "2026-06-07T15:30:02.364661Z"^^xsd:dateTime .

oakcurric:keyword-activation-energy
  a curric:Keyword ;
  schema:name "activation energy"@en ;
  schema:description """The minimum energy that the particles must have in order to react is known
  as the activation energy."""@en ;
  dcterms:modified "2026-06-07T15:30:02.364665Z"^^xsd:dateTime .

oakcurric:keyword-end-point-method
  a curric:Keyword ;
  schema:name "end-point method"@en ;
  schema:description """An end-point method is used to measure the progress of a reaction until it
  has reached completion or a desirable point, e.g. a colour change."""@en ;
  dcterms:modified "2026-06-07T15:30:02.364670Z"^^xsd:dateTime .

oakcurric:keyword-joules-kilogram-degrees-c
  a curric:Keyword ;
  schema:name "joules / kilogram degrees C"@en ;
  schema:description "The unit for the specific heat capacity of a material (J/kg ºC)."@en ;
  dcterms:modified "2026-06-07T15:30:02.364677Z"^^xsd:dateTime .

oakcurric:keyword-immersion-heater
  a curric:Keyword ;
  schema:name "immersion heater"@en ;
  schema:description """An electrical heating element which can be submerged in liquid to
  heat it."""@en ;
  dcterms:modified "2026-06-07T15:30:02.364682Z"^^xsd:dateTime .

oakcurric:keyword-joulemeter
  a curric:Keyword ;
  schema:name "joulemeter"@en ;
  schema:description "A meter which measures the energy transferred by an electric current."@en ;
  dcterms:modified "2026-06-07T15:30:02.364689Z"^^xsd:dateTime .

oakcurric:keyword-conservation-of-energy
  a curric:Keyword ;
  schema:name "conservation of energy"@en ;
  schema:description """A principle which states that the total amount of energy is the same before
  and after any transfer."""@en ;
  dcterms:modified "2026-06-07T15:30:02.364694Z"^^xsd:dateTime .

oakcurric:keyword-mean-rate-of-reaction
  a curric:Keyword ;
  schema:name "mean rate of reaction"@en ;
  schema:description """The mean rate of reaction is the average rate at which reactants are
  converted into products in a given time."""@en ;
  dcterms:modified "2026-06-07T15:30:02.364724Z"^^xsd:dateTime .

oakcurric:keyword-instantaneous-rate-of-reaction
  a curric:Keyword ;
  schema:name "instantaneous rate of reaction"@en ;
  schema:description """The instantaneous rate of reaction is the rate at which reactants are
  converted into products at a specific moment in time."""@en ;
  dcterms:modified "2026-06-07T15:30:02.364731Z"^^xsd:dateTime .

oakcurric:keyword-transpiration
  a curric:Keyword ;
  schema:name "transpiration"@en ;
  schema:description "the loss of water from a plant’s leaves"@en ;
  dcterms:modified "2026-06-07T15:30:02.364764Z"^^xsd:dateTime .

oakcurric:keyword-potometer
  a curric:Keyword ;
  schema:name "potometer"@en ;
  schema:description "a piece of equipment used to measure the rate of water uptake by a plant"@en ;
  dcterms:modified "2026-06-07T15:30:02.364773Z"^^xsd:dateTime .

oakcurric:keyword-prokaryotic
  a curric:Keyword ;
  schema:name "prokaryotic"@en ;
  schema:description """A type of cell with no membrane bound nucleus; DNA is free floating in the
  cytoplasm."""@en ;
  dcterms:modified "2026-06-07T15:30:02.365145Z"^^xsd:dateTime .

oakcurric:keyword-plasmid
  a curric:Keyword ;
  schema:name "plasmid"@en ;
  schema:description "Small ring of DNA found in the cytoplasm of prokaryotic cells."@en ;
  dcterms:modified "2026-06-07T15:30:02.365150Z"^^xsd:dateTime .

oakcurric:keyword-binary-fission
  a curric:Keyword ;
  schema:name "binary fission"@en ;
  schema:description "The form of cell division that bacteria use to replicate."@en ;
  dcterms:modified "2026-06-07T15:30:02.365155Z"^^xsd:dateTime .

oakcurric:keyword-eukaryotic
  a curric:Keyword ;
  schema:name "eukaryotic"@en ;
  schema:description """A type of cell that contains a membrane bound nucleus; the DNA is usually
  found inside."""@en ;
  dcterms:modified "2026-06-07T15:30:02.365162Z"^^xsd:dateTime .

oakcurric:keyword-shoot
  a curric:Keyword ;
  schema:name "shoot"@en ;
  schema:description "to try to score points by sending the ball towards the target"@en ;
  dcterms:modified "2026-06-07T15:30:02.365169Z"^^xsd:dateTime .

oakcurric:keyword-adapt
  a curric:Keyword ;
  schema:name "adapt"@en ;
  schema:description "to change, or to alter something, to suit different conditions."@en ;
  dcterms:modified "2026-06-07T15:30:02.365488Z"^^xsd:dateTime .

oakcurric:keyword-electromagnet
  a curric:Keyword ;
  schema:name "electromagnet"@en ;
  schema:description """A magnet made by running current through a coil of wire round an
  iron core."""@en ;
  dcterms:modified "2026-06-07T15:30:02.365563Z"^^xsd:dateTime .

oakcurric:keyword-temporary-magnet
  a curric:Keyword ;
  schema:name "temporary magnet"@en ;
  schema:description """An electromagnet that loses its magnetism when current stops flowing through
  it."""@en ;
  dcterms:modified "2026-06-07T15:30:02.365570Z"^^xsd:dateTime .

oakcurric:keyword-electric-lock
  a curric:Keyword ;
  schema:name "electric lock"@en ;
  schema:description "A lock that can be opened with an electromagnet when a switch is closed."@en ;
  dcterms:modified "2026-06-07T15:30:02.365575Z"^^xsd:dateTime .

oakcurric:keyword-electric-bell
  a curric:Keyword ;
  schema:name "electric bell"@en ;
  schema:description """A bell that uses an electromagnet to strike a clapper on the bell and which
  resets itself to keep ringing."""@en ;
  dcterms:modified "2026-06-07T15:30:02.365580Z"^^xsd:dateTime .

oakcurric:keyword-electric-motor
  a curric:Keyword ;
  schema:name "electric motor"@en ;
  schema:description "A motor that uses a magnetic field to produce a force."@en ;
  dcterms:modified "2026-06-07T15:30:02.365584Z"^^xsd:dateTime .

oakcurric:keyword-melting
  a curric:Keyword ;
  schema:name "melting"@en ;
  schema:description """the change of state from a solid to a liquid that happens at a fixed
  temperature for pure substances"""@en ;
  dcterms:modified "2026-06-07T15:30:02.365589Z"^^xsd:dateTime .

oakcurric:keyword-boiling
  a curric:Keyword ;
  schema:name "boiling"@en ;
  schema:description """the change of state from a liquid to a gas that happens at a fixed
  temperature for pure substances"""@en ;
  dcterms:modified "2026-06-07T15:30:02.365596Z"^^xsd:dateTime .

oakcurric:keyword-change-of-state
  a curric:Keyword ;
  schema:name "change of state"@en ;
  schema:description "changing from a solid to a liquid or liquid to gas (or the reverse)"@en ;
  dcterms:modified "2026-06-07T15:30:02.365601Z"^^xsd:dateTime .

oakcurric:keyword-landfill
  a curric:Keyword ;
  schema:name "landfill"@en ;
  schema:description "Landfill is where we get rid of waste by burying it in the ground."@en ;
  dcterms:modified "2026-06-07T15:30:02.365606Z"^^xsd:dateTime .

oakcurric:keyword-puberty
  a curric:Keyword ;
  schema:name "puberty"@en ;
  schema:description """Puberty is a time when human bodies go through changes to become adults that
  are able to reproduce."""@en ;
  dcterms:modified "2026-06-07T15:30:02.365661Z"^^xsd:dateTime .

oakcurric:keyword-mean
  a curric:Keyword ;
  schema:name "mean"@en ;
  schema:description """A measure of average where all values are added together and divided by the
  number of repeat measurements that have been taken."""@en ;
  dcterms:modified "2026-06-07T15:30:02.365830Z"^^xsd:dateTime .

oakcurric:keyword-cell
  a curric:Keyword ;
  schema:name "cell"@en ;
  schema:description "a rectangular box in a spreadsheet used to store data"@en ;
  dcterms:modified "2026-06-07T15:30:02.366326Z"^^xsd:dateTime .

oakcurric:keyword-soluble
  a curric:Keyword ;
  schema:name "soluble"@en ;
  schema:description """When a substance dissolves in a liquid, it is described as soluble in that
  liquid."""@en ;
  dcterms:modified "2026-06-07T15:30:02.366384Z"^^xsd:dateTime .

oakcurric:keyword-excess-reactant
  a curric:Keyword ;
  schema:name "excess reactant"@en ;
  schema:description """any reactant present in a greater amount than is necessary to completely
  react with the limiting reactant"""@en ;
  dcterms:modified "2026-06-07T15:30:02.366388Z"^^xsd:dateTime .

oakcurric:keyword-crystallisation
  a curric:Keyword ;
  schema:name "crystallisation"@en ;
  schema:description """a process that forms solid crystals from a saturated solution by evaporating
  the solvent"""@en ;
  dcterms:modified "2026-06-07T15:30:02.366393Z"^^xsd:dateTime .

oakcurric:keyword-drag
  a curric:Keyword ;
  schema:name "drag"@en ;
  schema:description """is a force of a fluid on an object moving through it, in the opposite
  direction to the object’s motion"""@en ;
  dcterms:modified "2026-06-07T15:30:02.366398Z"^^xsd:dateTime .

oakcurric:keyword-repeatable
  a curric:Keyword ;
  schema:name "repeatable"@en ;
  schema:description """A measurement is repeatable if the same (or similar) results are obtained
  when the same person repeats the investigation using the same method."""@en ;
  dcterms:modified "2026-06-07T15:30:02.366425Z"^^xsd:dateTime .

oakcurric:keyword-reproducible
  a curric:Keyword ;
  schema:name "reproducible"@en ;
  schema:description """A measurement is reproducible if the same (or similar) results are obtained
  when the same person repeats it using a different method, or a different person repeats it
  using the same method."""@en ;
  dcterms:modified "2026-06-07T15:30:02.366430Z"^^xsd:dateTime .

oakcurric:keyword-instantaneous-speed
  a curric:Keyword ;
  schema:name "instantaneous speed"@en ;
  schema:description """The instantaneous speed of an object is its speed at a particular moment in
  time."""@en ;
  dcterms:modified "2026-06-07T15:30:02.366435Z"^^xsd:dateTime .

oakcurric:keyword-interconversion
  a curric:Keyword ;
  schema:name "interconversion"@en ;
  schema:description "is the ability to change between units of measurement."@en ;
  dcterms:modified "2026-06-07T15:30:02.366474Z"^^xsd:dateTime .

oakcurric:keyword-uncertainty
  a curric:Keyword ;
  schema:name "uncertainty"@en ;
  schema:description """is the range of measurements within which the true value can be expected to
  be found. On apparatus, it is half the value of one resolution marking."""@en ;
  dcterms:modified "2026-06-07T15:30:02.366478Z"^^xsd:dateTime .

oakcurric:keyword-optimum
  a curric:Keyword ;
  schema:name "optimum"@en ;
  schema:description "The conditions under which the maximum rate of reaction occurs."@en ;
  dcterms:modified "2026-06-07T15:30:02.366504Z"^^xsd:dateTime .

oakcurric:keyword-denatured
  a curric:Keyword ;
  schema:name "denatured"@en ;
  schema:description """A permanent change in the shape of an enzyme that stops it from working
  properly."""@en ;
  dcterms:modified "2026-06-07T15:30:02.366508Z"^^xsd:dateTime .

oakcurric:keyword-dynamic-equilibrium
  a curric:Keyword ;
  schema:name "dynamic equilibrium"@en ;
  schema:description """occurs in a closed system when the forward and backward reactions of a
  reversible chemical reaction occur at the same rate; and the concentrations of reactants
  and products remain constant."""@en ;
  dcterms:modified "2026-06-07T15:30:02.366513Z"^^xsd:dateTime .

oakcurric:keyword-reaction-rate
  a curric:Keyword ;
  schema:name "reaction rate"@en ;
  schema:description """is the speed with which a chemical reaction takes place, measured by the
  amount of a reactant used or amount of product formed in a given time."""@en ;
  dcterms:modified "2026-06-07T15:30:02.366522Z"^^xsd:dateTime .

oakcurric:keyword-closed-system
  a curric:Keyword ;
  schema:name "closed system"@en ;
  schema:description """is one in which matter cannot enter or leave the observed environment,
  allowing only energy transfer between the system and its surrounding environment."""@en ;
  dcterms:modified "2026-06-07T15:30:02.366527Z"^^xsd:dateTime .

oakcurric:keyword-reagent
  a curric:Keyword ;
  schema:name "reagent"@en ;
  schema:description "A chemical used to test for a type of biological molecule."@en ;
  dcterms:modified "2026-06-07T15:30:02.366532Z"^^xsd:dateTime .

oakcurric:keyword-qualitative
  a curric:Keyword ;
  schema:name "qualitative"@en ;
  schema:description "A test in which the result is based on an observation."@en ;
  dcterms:modified "2026-06-07T15:30:02.366585Z"^^xsd:dateTime .

oakcurric:keyword-electric-charge
  a curric:Keyword ;
  schema:name "electric charge"@en ;
  schema:description "an electrical property; it can either be positive or negative"@en ;
  dcterms:modified "2026-06-07T15:30:02.366895Z"^^xsd:dateTime .

oakcurric:keyword-parallel-circuit
  a curric:Keyword ;
  schema:name "parallel circuit"@en ;
  schema:description "a circuit with separate branches connected to the battery"@en ;
  dcterms:modified "2026-06-07T15:30:02.366899Z"^^xsd:dateTime .

oakcurric:keyword-electric-field
  a curric:Keyword ;
  schema:name "electric field"@en ;
  schema:description """the invisible field around a charged object that causes other charges to
  experience a force"""@en ;
  dcterms:modified "2026-06-07T15:30:02.366906Z"^^xsd:dateTime .

oakcurric:keyword-potential-difference-pd
  a curric:Keyword ;
  schema:name "potential difference (p.d.)"@en ;
  schema:description "the voltage or a measure of the ‘push’ on electrons in a circuit"@en ;
  dcterms:modified "2026-06-07T15:30:02.366911Z"^^xsd:dateTime .

oakcurric:keyword-electric-current
  a curric:Keyword ;
  schema:name "electric current"@en ;
  schema:description "a measure of the amount of charge passing a given point in one second"@en ;
  dcterms:modified "2026-06-07T15:30:02.366918Z"^^xsd:dateTime .

oakcurric:keyword-extension
  a curric:Keyword ;
  schema:name "extension"@en ;
  schema:description "stretched and pointed fingers and toes"@en ;
  dcterms:modified "2026-06-07T15:30:02.367057Z"^^xsd:dateTime .

oakcurric:keyword-fractional-distillation
  a curric:Keyword ;
  schema:name "fractional distillation"@en ;
  schema:description "separating component parts of a mixture"@en ;
  dcterms:modified "2026-06-07T15:30:02.367204Z"^^xsd:dateTime .

oakcurric:keyword-light-dependent-resistor
  a curric:Keyword ;
  schema:name "light-dependent resistor"@en ;
  schema:description """a semiconducting component with a resistance that gets lower in increasingly
  bright light"""@en ;
  dcterms:modified "2026-06-07T15:30:02.367247Z"^^xsd:dateTime .

oakcurric:keyword-semiconductor
  a curric:Keyword ;
  schema:name "semiconductor"@en ;
  schema:description "a material that has both metallic and non-metallic properties"@en ;
  dcterms:modified "2026-06-07T15:30:02.367253Z"^^xsd:dateTime .

oakcurric:keyword-thermistor
  a curric:Keyword ;
  schema:name "thermistor"@en ;
  schema:description """a semiconducting component with a resistance that gets lower in increasingly
  high temperatures"""@en ;
  dcterms:modified "2026-06-07T15:30:02.367257Z"^^xsd:dateTime .

oakcurric:keyword-potential-divider
  a curric:Keyword ;
  schema:name "potential divider"@en ;
  schema:description """a series circuit that divides the p.d. across a power supply into two or
  more smaller voltages"""@en ;
  dcterms:modified "2026-06-07T15:30:02.367262Z"^^xsd:dateTime .

oakcurric:keyword-ph-scale
  a curric:Keyword ;
  schema:name "pH scale"@en ;
  schema:description """a scale of acidity or alkalinity, often shown to be between values of 0 and
  14"""@en ;
  dcterms:modified "2026-06-07T15:30:02.367276Z"^^xsd:dateTime .

oakcurric:keyword-indicator
  a curric:Keyword ;
  schema:name "indicator"@en ;
  schema:description """a solution or paper which will change a different colour depending on pH of
  a solution"""@en ;
  dcterms:modified "2026-06-07T15:30:02.367282Z"^^xsd:dateTime .

oakcurric:keyword-ph-meter
  a curric:Keyword ;
  schema:name "pH meter"@en ;
  schema:description """an electric device which measures pH and provides a value after being
  calibrated with reference samples"""@en ;
  dcterms:modified "2026-06-07T15:30:02.367287Z"^^xsd:dateTime .

oakcurric:keyword-acidity
  a curric:Keyword ;
  schema:name "acidity"@en ;
  schema:description """the concentration of hydrogen ions (H⁺) present in a solution; acids have a
  pH value less than 7"""@en ;
  dcterms:modified "2026-06-07T15:30:02.367291Z"^^xsd:dateTime .

oakcurric:keyword-alkalinity
  a curric:Keyword ;
  schema:name "alkalinity"@en ;
  schema:description """the concentration of hydroxide ions (OH⁻) present in a solution; alkalis
  have a pH value greater than 7"""@en ;
  dcterms:modified "2026-06-07T15:30:02.367296Z"^^xsd:dateTime .

oakcurric:keyword-quadrat
  a curric:Keyword ;
  schema:name "quadrat"@en ;
  schema:description """A quadrat is a square frame used to sample populations of plants or
  slow-moving animals."""@en ;
  dcterms:modified "2026-06-07T15:30:02.367315Z"^^xsd:dateTime .

oakcurric:keyword-abundance
  a curric:Keyword ;
  schema:name "abundance"@en ;
  schema:description """Abundance is the number of organisms of a species found within a
  habitat."""@en ;
  dcterms:modified "2026-06-07T15:30:02.367322Z"^^xsd:dateTime .

oakcurric:keyword-dissolve
  a curric:Keyword ;
  schema:name "dissolve"@en ;
  schema:description """When a substance's particles separate and spread throughout the particles of
  a solvent resulting in it no longer being seen."""@en ;
  dcterms:modified "2026-06-07T15:30:02.367367Z"^^xsd:dateTime .

oakcurric:keyword-recessive
  a curric:Keyword ;
  schema:name "recessive"@en ;
  schema:description """two alleles must be present in the genotype for the characteristic to be
  expressed in the phenotype"""@en ;
  dcterms:modified "2026-06-07T15:30:02.367463Z"^^xsd:dateTime .

oakcurric:keyword-precipitate
  a curric:Keyword ;
  schema:name "precipitate"@en ;
  schema:description """A precipitate is an insoluble solid formed when two solutions react
  together."""@en ;
  dcterms:modified "2026-06-07T15:30:02.367468Z"^^xsd:dateTime .

oakcurric:keyword-fair-test
  a curric:Keyword ;
  schema:name "fair test"@en ;
  schema:description """In a fair test variables are controlled so that only one change affects the
  dependent variable."""@en ;
  dcterms:modified "2026-06-07T15:30:02.367473Z"^^xsd:dateTime .

oakcurric:keyword-evaporation
  a curric:Keyword ;
  schema:name "evaporation"@en ;
  schema:description "a change of state from a liquid to a gas"@en ;
  dcterms:modified "2026-06-07T15:30:02.367520Z"^^xsd:dateTime .

oakcurric:keyword-method
  a curric:Keyword ;
  schema:name "method"@en ;
  schema:description """A method describes how an experiment is carried out; it is a step-by-step
  procedure."""@en ;
  dcterms:modified "2026-06-07T15:30:02.367532Z"^^xsd:dateTime .

oakcurric:keyword-line-graph
  a curric:Keyword ;
  schema:name "line graph"@en ;
  schema:description """A line graph involves two continuous variables being plotted to show if a
  relationship exists between them. Any trends in the data are shown with the addition of a
  line of best fit."""@en ;
  dcterms:modified "2026-06-07T15:30:02.367537Z"^^xsd:dateTime .

oakcurric:keyword-density
  a curric:Keyword ;
  schema:name "density"@en ;
  schema:description "The mass per cubic metre (m³) or cubic centimetre (cm³) of a material."@en ;
  dcterms:modified "2026-06-07T15:30:02.367555Z"^^xsd:dateTime .

oakcurric:keyword-displacement-can
  a curric:Keyword ;
  schema:name "displacement can"@en ;
  schema:description "A can with a spout used to measure the volume of a submerged object."@en ;
  dcterms:modified "2026-06-07T15:30:02.367560Z"^^xsd:dateTime .

oakcurric:keyword-vernier-callipers
  a curric:Keyword ;
  schema:name "Vernier callipers"@en ;
  schema:description "A device used to measure length precisely."@en ;
  dcterms:modified "2026-06-07T15:30:02.367564Z"^^xsd:dateTime .

oakcurric:keyword-micrometer
  a curric:Keyword ;
  schema:name "micrometer"@en ;
  schema:description "A device to measure length to very high precision."@en ;
  dcterms:modified "2026-06-07T15:30:02.367571Z"^^xsd:dateTime .

oakcurric:keyword-excess
  a curric:Keyword ;
  schema:name "excess"@en ;
  schema:description "If you have an excess of something, you have more than is necessary."@en ;
  dcterms:modified "2026-06-07T15:30:02.367741Z"^^xsd:dateTime .

oakcurric:keyword-reliability
  a curric:Keyword ;
  schema:name "reliability"@en ;
  schema:description """being dependable and consistent in performing your role, ensuring that
  teammates can count on you during competition"""@en ;
  dcterms:modified "2026-06-07T15:30:02.367867Z"^^xsd:dateTime .

oakcurric:keyword-light-source
  a curric:Keyword ;
  schema:name "light source"@en ;
  schema:description "Something that is a light source produces its own light."@en ;
  dcterms:modified "2026-06-07T15:30:02.368072Z"^^xsd:dateTime .

oakcurric:keyword-van-de-graaff-generator
  a curric:Keyword ;
  schema:name "Van de Graaff generator"@en ;
  schema:description """A device that produces electric charge and is used in electrostatic
  experiments."""@en ;
  dcterms:modified "2026-06-07T15:30:02.368168Z"^^xsd:dateTime .

oakcurric:keyword-charge
  a curric:Keyword ;
  schema:name "charge"@en ;
  schema:description "An electrical property; it can either be positive or negative."@en ;
  dcterms:modified "2026-06-07T15:30:02.368172Z"^^xsd:dateTime .

oakcurric:keyword-coulomb
  a curric:Keyword ;
  schema:name "coulomb"@en ;
  schema:description "The unit of electric charge."@en ;
  dcterms:modified "2026-06-07T15:30:02.368176Z"^^xsd:dateTime .

oakcurric:keyword-ampere
  a curric:Keyword ;
  schema:name "ampere"@en ;
  schema:description "The unit of electric current."@en ;
  dcterms:modified "2026-06-07T15:30:02.368181Z"^^xsd:dateTime .

oakcurric:keyword-sublimation
  a curric:Keyword ;
  schema:name "sublimation"@en ;
  schema:description """a change of state of a substance from a solid directly to a gas; e.g.
  iodine."""@en ;
  dcterms:modified "2026-06-07T15:30:02.368386Z"^^xsd:dateTime .

oakcurric:keyword-ecosystem-services
  a curric:Keyword ;
  schema:name "ecosystem services"@en ;
  schema:description """benefits gained from the day-to-day functioning of the world's ecosystems
  that support human life"""@en ;
  dcterms:modified "2026-06-07T15:30:02.368398Z"^^xsd:dateTime .

oakcurric:keyword-analysis
  a curric:Keyword ;
  schema:name "analysis"@en ;
  schema:description "the process of examining the elements or structure of something"@en ;
  dcterms:modified "2026-06-07T15:30:02.368456Z"^^xsd:dateTime .

oakcurric:keyword-solvent-front
  a curric:Keyword ;
  schema:name "solvent front"@en ;
  schema:description """The solvent front is the furthest distance the solvent travels along the
  stationary phase during chromatography."""@en ;
  dcterms:modified "2026-06-07T15:30:02.368770Z"^^xsd:dateTime .

oakcurric:keyword-sample-line
  a curric:Keyword ;
  schema:name "sample line"@en ;
  schema:description """The sample line is where the sample undergoing chromatography is placed on
  the stationary phase."""@en ;
  dcterms:modified "2026-06-07T15:30:02.368774Z"^^xsd:dateTime .

oakcurric:keyword-rf-value
  a curric:Keyword ;
  schema:name "Rf value"@en ;
  schema:description """The Rf value is a ratio describing the distance a component of a sample
  travelled, in relation to the distance the solvent travelled under the same conditions."""@en ;
  dcterms:modified "2026-06-07T15:30:02.368779Z"^^xsd:dateTime .

oakcurric:keyword-chromatogram
  a curric:Keyword ;
  schema:name "chromatogram"@en ;
  schema:description """A chromatogram is the resultant pattern on the stationary phase after
  chromatography has been carried out."""@en ;
  dcterms:modified "2026-06-07T15:30:02.368783Z"^^xsd:dateTime .

oakcurric:keyword-malnutrition
  a curric:Keyword ;
  schema:name "malnutrition"@en ;
  schema:description """intakes of energy and/or nutrients below or in excess of needs for long
  periods of time"""@en ;
  dcterms:modified "2026-06-07T15:30:02.369053Z"^^xsd:dateTime .

oakcurric:keyword-coronary-heart-disease
  a curric:Keyword ;
  schema:name "coronary heart disease"@en ;
  schema:description """a health condition caused by the narrowing of the blood vessels to
  the heart"""@en ;
  dcterms:modified "2026-06-07T15:30:02.369067Z"^^xsd:dateTime .

oakcurric:keyword-pressure
  a curric:Keyword ;
  schema:name "pressure"@en ;
  schema:description "applying defensive intensity to an opponent in possession of the ball"@en ;
  dcterms:modified "2026-06-07T15:30:02.369223Z"^^xsd:dateTime .

oakcurric:keyword-series-circuit
  a curric:Keyword ;
  schema:name "series circuit"@en ;
  schema:description "an electrical circuit with a single loop"@en ;
  dcterms:modified "2026-06-07T15:30:02.369290Z"^^xsd:dateTime .

oakcurric:keyword-dynamics-trolley
  a curric:Keyword ;
  schema:name "dynamics trolley"@en ;
  schema:description """A dynamics trolley is a wheeled device used in experiments to study motion,
  designed to move smoothly over flat surfaces."""@en ;
  dcterms:modified "2026-06-07T15:30:02.369295Z"^^xsd:dateTime .

oakcurric:keyword-average-speed
  a curric:Keyword ;
  schema:name "average speed"@en ;
  schema:description """The average speed of an object is the total distance travelled divided by
  the total time taken for a journey."""@en ;
  dcterms:modified "2026-06-07T15:30:02.369300Z"^^xsd:dateTime .

oakcurric:keyword-anomalous-reading
  a curric:Keyword ;
  schema:name "anomalous reading"@en ;
  schema:description """An anomalous reading is a result that is significantly outside the expected
  pattern in a set of results."""@en ;
  dcterms:modified "2026-06-07T15:30:02.369309Z"^^xsd:dateTime .

oakcurric:keyword-motion-sensor
  a curric:Keyword ;
  schema:name "motion sensor"@en ;
  schema:description """A motion sensor measures the distance between itself and an object. We can
  use the measurements to calculate and plot graphs of displacement, velocity and
  acceleration."""@en ;
  dcterms:modified "2026-06-07T15:30:02.369314Z"^^xsd:dateTime .

oakcurric:keyword-oscilloscope
  a curric:Keyword ;
  schema:name "oscilloscope"@en ;
  schema:description "A piece of equipment that can display a representation of a sound wave."@en ;
  dcterms:modified "2026-06-07T15:30:02.369330Z"^^xsd:dateTime .

oakcurric:keyword-species
  a curric:Keyword ;
  schema:name "species"@en ;
  schema:description """A species is a group of animals or plants that are similar and can have
  babies together."""@en ;
  dcterms:modified "2026-06-07T15:30:02.369570Z"^^xsd:dateTime .

oakcurric:keyword-branch
  a curric:Keyword ;
  schema:name "branch"@en ;
  schema:description "a separate loop in a parallel circuit"@en ;
  dcterms:modified "2026-06-07T15:30:02.369589Z"^^xsd:dateTime .

oakcurric:keyword-molecule
  a curric:Keyword ;
  schema:name "molecule"@en ;
  schema:description """Made up of two or more atoms chemically bonded together. These are usually
  non-metal atoms."""@en ;
  dcterms:modified "2026-06-07T15:30:02.369641Z"^^xsd:dateTime .

oakcurric:keyword-oxidation
  a curric:Keyword ;
  schema:name "oxidation"@en ;
  schema:description "A type of reaction in which oxygen bonds to elements of the reactants."@en ;
  dcterms:modified "2026-06-07T15:30:02.369655Z"^^xsd:dateTime .

oakcurric:keyword-chromatography
  a curric:Keyword ;
  schema:name "chromatography"@en ;
  schema:description """Chromatography is a technique that separates a mixture into its different
  parts and the results can be analysed."""@en ;
  dcterms:modified "2026-06-07T15:30:02.369664Z"^^xsd:dateTime .

oakcurric:keyword-control-experiments
  a curric:Keyword ;
  schema:name "control experiments"@en ;
  schema:description """These are done to find a baseline set of results to which others can be
  compared."""@en ;
  dcterms:modified "2026-06-07T15:30:02.369702Z"^^xsd:dateTime .

oakcurric:keyword-control-variables
  a curric:Keyword ;
  schema:name "control variables"@en ;
  schema:description """These are factors that need to be kept constant in an experiment for the
  test to be fair."""@en ;
  dcterms:modified "2026-06-07T15:30:02.369707Z"^^xsd:dateTime .

oakcurric:keyword-diode
  a curric:Keyword ;
  schema:name "diode"@en ;
  schema:description """an electrical component that is used to prevent current flow in one
  direction"""@en ;
  dcterms:modified "2026-06-07T15:30:02.369821Z"^^xsd:dateTime .

oakcurric:keyword-threshold-pd
  a curric:Keyword ;
  schema:name "threshold p.d."@en ;
  schema:description "the potential difference at which a diode allows current to flow"@en ;
  dcterms:modified "2026-06-07T15:30:02.369828Z"^^xsd:dateTime .

oakcurric:keyword-reversebiased
  a curric:Keyword ;
  schema:name "reverse–biased"@en ;
  schema:description "when a diode is reverse–biased, it prevents current from flowing"@en ;
  dcterms:modified "2026-06-07T15:30:02.369833Z"^^xsd:dateTime .

oakcurric:keyword-forwardbiased
  a curric:Keyword ;
  schema:name "forward–biased"@en ;
  schema:description "when a diode is forward–biased, it allows current to flow"@en ;
  dcterms:modified "2026-06-07T15:30:02.369838Z"^^xsd:dateTime .

oakcurric:keyword-ripple-tank
  a curric:Keyword ;
  schema:name "ripple tank"@en ;
  schema:description """A vibrating beam in a ripple tank creates water waves in a clear bottomed
  container that makes the waves easier to observe."""@en ;
  dcterms:modified "2026-06-07T15:30:02.369843Z"^^xsd:dateTime .

oakcurric:keyword-slow-motion
  a curric:Keyword ;
  schema:name "slow motion"@en ;
  schema:description """A film played back in slow motion shows everything happening slowly,
  including the speed of a timer shown in the film."""@en ;
  dcterms:modified "2026-06-07T15:30:02.369847Z"^^xsd:dateTime .

oakcurric:keyword-wave-equation
  a curric:Keyword ;
  schema:name "wave equation"@en ;
  schema:description "The wave equation is: wave speed = frequency × wavelength, v = f × λ."@en ;
  dcterms:modified "2026-06-07T15:30:02.369852Z"^^xsd:dateTime .

oakcurric:keyword-random-motion
  a curric:Keyword ;
  schema:name "random motion"@en ;
  schema:description """Describes the movement of particles in a fluid that travels at a range of
  speeds in all directions."""@en ;
  dcterms:modified "2026-06-07T15:30:02.369860Z"^^xsd:dateTime .

oakcurric:keyword-convection-current
  a curric:Keyword ;
  schema:name "convection current"@en ;
  schema:description """The movement of fluids caused by differences in density within the fluid,
  which allows energy to be transferred as the hotter fluid rises to cooler areas."""@en ;
  dcterms:modified "2026-06-07T15:30:02.369864Z"^^xsd:dateTime .

oakcurric:keyword-respirometer
  a curric:Keyword ;
  schema:name "respirometer"@en ;
  schema:description "Apparatus used to measure the rate of respiration in small organisms."@en ;
  dcterms:modified "2026-06-07T15:30:02.370062Z"^^xsd:dateTime .

oakcurric:keyword-random-error
  a curric:Keyword ;
  schema:name "random error"@en ;
  schema:description """Causes results to differ by different amounts due to a factor other than the
  independent variable (the factor we changed)."""@en ;
  dcterms:modified "2026-06-07T15:30:02.370155Z"^^xsd:dateTime .

oakcurric:keyword-systematic-error
  a curric:Keyword ;
  schema:name "systematic error"@en ;
  schema:description """Causes measurements to differ from the true value by the same amount each
  time they are taken."""@en ;
  dcterms:modified "2026-06-07T15:30:02.370159Z"^^xsd:dateTime .

oakcurric:keyword-titrant
  a curric:Keyword ;
  schema:name "titrant"@en ;
  schema:description "the solution of known concentration added from the burette in titration"@en ;
  dcterms:modified "2026-06-07T15:30:02.370164Z"^^xsd:dateTime .

oakcurric:keyword-analyte
  a curric:Keyword ;
  schema:name "analyte"@en ;
  schema:description "the solution of unknown concentration in the conical flask in titration"@en ;
  dcterms:modified "2026-06-07T15:30:02.370169Z"^^xsd:dateTime .

oakcurric:keyword-concordant
  a curric:Keyword ;
  schema:name "concordant"@en ;
  schema:description """readings within a certain range; for titrations, these usually need to be
  within ±0.10 cm³ of each other"""@en ;
  dcterms:modified "2026-06-07T15:30:02.370173Z"^^xsd:dateTime .

oakcurric:keyword-titre
  a curric:Keyword ;
  schema:name "titre"@en ;
  schema:description "the volume of titrant needed to reach the end point in a titration"@en ;
  dcterms:modified "2026-06-07T15:30:02.370178Z"^^xsd:dateTime .

oakcurric:keyword-distillation
  a curric:Keyword ;
  schema:name "distillation"@en ;
  schema:description """a separation technique that uses boiling and condensation to remove and
  isolate a liquid component of a mixture"""@en ;
  dcterms:modified "2026-06-07T15:30:02.370319Z"^^xsd:dateTime .

oakcurric:keyword-delivery-tube
  a curric:Keyword ;
  schema:name "delivery tube"@en ;
  schema:description """a thin tube used to transfer (i.e. \"deliver\") a substance (usually in the
  gas state) from one container to another"""@en ;
  dcterms:modified "2026-06-07T15:30:02.370326Z"^^xsd:dateTime .

oakcurric:keyword-condenser
  a curric:Keyword ;
  schema:name "condenser"@en ;
  schema:description """a piece of apparatus composed of a tube surrounded by a cold layer, usually
  cold water"""@en ;
  dcterms:modified "2026-06-07T15:30:02.370331Z"^^xsd:dateTime .

oakcurric:keyword-distillate
  a curric:Keyword ;
  schema:name "distillate"@en ;
  schema:description "the liquid that is condensed from the gas state during distillation"@en ;
  dcterms:modified "2026-06-07T15:30:02.370335Z"^^xsd:dateTime .

oakcurric:keyword-amylase
  a curric:Keyword ;
  schema:name "amylase"@en ;
  schema:description "An enzyme that breaks down starch into maltose (a type of sugar)."@en ;
  dcterms:modified "2026-06-07T15:30:02.370708Z"^^xsd:dateTime .

oakcurric:keyword-continuous-sampling
  a curric:Keyword ;
  schema:name "continuous sampling"@en ;
  schema:description "A method that involves taking regular and frequent samples."@en ;
  dcterms:modified "2026-06-07T15:30:02.370713Z"^^xsd:dateTime .

oakcurric:keyword-flame-test
  a curric:Keyword ;
  schema:name "flame test"@en ;
  schema:description """A test where a chemical put into a flame produces a characteristic colour
  (tests for metal ions)."""@en ;
  dcterms:modified "2026-06-07T15:30:02.370718Z"^^xsd:dateTime .

oakcurric:keyword-spectroscope
  a curric:Keyword ;
  schema:name "spectroscope"@en ;
  schema:description "An instrument that separates light into its component wavelengths."@en ;
  dcterms:modified "2026-06-07T15:30:02.370724Z"^^xsd:dateTime .

oakcurric:keyword-ion
  a curric:Keyword ;
  schema:name "ion"@en ;
  schema:description """An ion is an atom or group of atoms with a positive or negative charge due
  to the loss or gain of electrons."""@en ;
  dcterms:modified "2026-06-07T15:30:02.370729Z"^^xsd:dateTime .

oakcurric:keyword-calibration-curve
  a curric:Keyword ;
  schema:name "calibration curve"@en ;
  schema:description "A graph used to determine the concentration of a substance in a sample."@en ;
  dcterms:modified "2026-06-07T15:30:02.370733Z"^^xsd:dateTime .

oakcurric:keyword-ammonia
  a curric:Keyword ;
  schema:name "ammonia"@en ;
  schema:description """a simple molecular substance, with the formula NH₃, is a soluble, toxic,
  pungent gas at room temperature."""@en ;
  dcterms:modified "2026-06-07T15:30:02.370741Z"^^xsd:dateTime .

oakcurric:keyword-alkaline
  a curric:Keyword ;
  schema:name "alkaline"@en ;
  schema:description "a base that dissolves in water; these solutions have a pH greater than 7"@en ;
  dcterms:modified "2026-06-07T15:30:02.370748Z"^^xsd:dateTime .

oakcurric:keyword-pungent
  a curric:Keyword ;
  schema:name "pungent"@en ;
  schema:description "a description of a substance that has a sharply strong smell"@en ;
  dcterms:modified "2026-06-07T15:30:02.370754Z"^^xsd:dateTime .

oakcurric:keyword-corrosive
  a curric:Keyword ;
  schema:name "corrosive"@en ;
  schema:description """a substance that causes damage by chemical action, often resulting in severe
  injury or destruction"""@en ;
  dcterms:modified "2026-06-07T15:30:02.370759Z"^^xsd:dateTime .

oakcurric:keyword-minerals
  a curric:Keyword ;
  schema:name "minerals"@en ;
  schema:description "Plants need chemicals called minerals to stay healthy and grow."@en ;
  dcterms:modified "2026-06-07T15:30:02.370861Z"^^xsd:dateTime .

oakcurric:keyword-solubility
  a curric:Keyword ;
  schema:name "solubility"@en ;
  schema:description """The ability of a substance to dissolve in a particular solvent creating a
  solution; how well a solute dissolves in a solvent."""@en ;
  dcterms:modified "2026-06-07T15:30:02.371141Z"^^xsd:dateTime .

oakcurric:keyword-salt
  a curric:Keyword ;
  schema:name "salt"@en ;
  schema:description """An ionic compound, usually formed by neutralisation of an acid by a
  base."""@en ;
  dcterms:modified "2026-06-07T15:30:02.371146Z"^^xsd:dateTime .

oakcurric:keyword-insoluble
  a curric:Keyword ;
  schema:name "insoluble"@en ;
  schema:description """When a substance does not dissolve in a liquid, it is described as insoluble
  in that liquid."""@en ;
  dcterms:modified "2026-06-07T15:30:02.371151Z"^^xsd:dateTime .

oakcurric:keyword-bar-chart
  a curric:Keyword ;
  schema:name "bar chart"@en ;
  schema:description """A bar chart (bar graph) is a graph consisting of bars visually representing
  the frequency of objects or groups."""@en ;
  dcterms:modified "2026-06-07T15:30:02.371172Z"^^xsd:dateTime .

oakcurric:keyword-vector
  a curric:Keyword ;
  schema:name "vector"@en ;
  schema:description """graphics made up of paths defined by mathematical equations, scalable
  without losing quality"""@en ;
  dcterms:modified "2026-06-07T15:30:02.371219Z"^^xsd:dateTime .

oakcurric:keyword-root
  a curric:Keyword ;
  schema:name "root"@en ;
