  schema:description """the reactant that completely reacts, thereby determining the maximum amount
  of product that can be formed in a chemical reaction. All other reactants will be present
  in excess"""@en ;
  dcterms:modified "2026-06-09T00:46:04.300933Z"^^xsd:dateTime .

oakcurric:keyword-formulation
  a curric:Keyword ;
  schema:name "formulation"@en ;
  schema:description """A formulation is a designed mixture, with each component serving a specific
  purpose in the desired product."""@en ;
  dcterms:modified "2026-06-09T00:46:04.301169Z"^^xsd:dateTime .

oakcurric:keyword-fossil-fuel
  a curric:Keyword ;
  schema:name "fossil fuel"@en ;
  schema:description """natural substances that were formed over millions of years ago from the
  buried remains of ancient organisms. They include coal, oil and gas"""@en ;
  dcterms:modified "2026-06-09T00:46:04.301286Z"^^xsd:dateTime .

oakcurric:keyword-saturated-solution
  a curric:Keyword ;
  schema:name "saturated solution"@en ;
  schema:description """A saturated solution is one in which no more solute can dissolve in the
  solvent at a given temperature."""@en ;
  dcterms:modified "2026-06-09T00:46:04.301549Z"^^xsd:dateTime .

oakcurric:keyword-conservation-of-mass
  a curric:Keyword ;
