  dcterms:modified "2026-06-09T00:46:37.515432Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8333-2
  a curric:KeyLearningPoint ;
  rdfs:label """One mole of particles of a substance is defined as the Avogadro constant number of
  particles."""@en ;
  dcterms:modified "2026-06-09T00:46:37.515437Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8333-3
  a curric:KeyLearningPoint ;
  rdfs:label """The number of particles (atoms, ions, molecules etc.) in one mole of a substance is
  always the same."""@en ;
  dcterms:modified "2026-06-09T00:46:37.515441Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8333-4
  a curric:KeyLearningPoint ;
  rdfs:label """Use of Avogadro's number to calculate the number of particles of substance when
  number of moles is known and vice versa."""@en ;
  dcterms:modified "2026-06-09T00:46:37.515446Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8333-5
  a curric:KeyLearningPoint ;
