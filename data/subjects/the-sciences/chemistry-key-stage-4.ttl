oakcurric:priorknowledge-898-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Disease is a cause of ill health."@en ;
  dcterms:modified "2026-06-07T15:29:23.385625Z"^^xsd:dateTime .

oakcurric:priorknowledge-898-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Lifestyle factors can cause or increase the risk of disease."@en ;
  dcterms:modified "2026-06-07T15:29:23.385636Z"^^xsd:dateTime .

oakcurric:priorknowledge-898-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Communicable diseases are caused by pathogens including viruses, bacteria, protists
  and fungi."""@en ;
  dcterms:modified "2026-06-07T15:29:23.385642Z"^^xsd:dateTime .

oakcurric:priorknowledge-898-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Ways in which pathogens can be spread."@en ;
  dcterms:modified "2026-06-07T15:29:23.385647Z"^^xsd:dateTime .

oakcurric:priorknowledge-898-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Some common communicable diseases caused by viruses, bacteria, protists and
  fungi."""@en ;
  dcterms:modified "2026-06-07T15:29:23.385652Z"^^xsd:dateTime .

oakcurric:priorknowledge-453-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Speed measures how quickly an object is moving."@en ;
  dcterms:modified "2026-06-07T15:29:23.451791Z"^^xsd:dateTime .

oakcurric:priorknowledge-453-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Speed = distance / time."@en ;
  dcterms:modified "2026-06-07T15:29:23.451806Z"^^xsd:dateTime .

oakcurric:priorknowledge-453-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Speed is measured in m/s or km/h or miles/h."@en ;
  dcterms:modified "2026-06-07T15:29:23.451812Z"^^xsd:dateTime .

oakcurric:priorknowledge-453-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "m/s is the number of metres travelled each second."@en ;
  dcterms:modified "2026-06-07T15:29:23.451817Z"^^xsd:dateTime .

oakcurric:priorknowledge-453-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Counting down ‘3, 2, 1, go’ helps start a stopwatch at the right moment."@en ;
  dcterms:modified "2026-06-07T15:29:23.451822Z"^^xsd:dateTime .

oakcurric:priorknowledge-453-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Observing with eyes in line with the finish line helps stop a stopwatch at the right
  moment."""@en ;
  dcterms:modified "2026-06-07T15:29:23.451828Z"^^xsd:dateTime .

oakcurric:priorknowledge-453-7
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "A level line on a distance-time graph shows no movement."@en ;
  dcterms:modified "2026-06-07T15:29:23.451839Z"^^xsd:dateTime .

oakcurric:priorknowledge-453-8
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "The steeper the line on a distance-time graph, the faster the movement."@en ;
  dcterms:modified "2026-06-07T15:29:23.451844Z"^^xsd:dateTime .

oakcurric:priorknowledge-477-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "The bigger the resultant force, the bigger the change on an object."@en ;
  dcterms:modified "2026-06-07T15:29:23.503479Z"^^xsd:dateTime .

oakcurric:priorknowledge-477-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "The moment of a force causes turning."@en ;
  dcterms:modified "2026-06-07T15:29:23.503497Z"^^xsd:dateTime .

oakcurric:priorknowledge-477-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Levers are force multipliers or distance multipliers."@en ;
  dcterms:modified "2026-06-07T15:29:23.503503Z"^^xsd:dateTime .

oakcurric:priorknowledge-477-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Objects that are harder to stop have a bigger momentum."@en ;
  dcterms:modified "2026-06-07T15:29:23.503509Z"^^xsd:dateTime .

oakcurric:priorknowledge-477-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Work done is the total amount of energy transferred."@en ;
  dcterms:modified "2026-06-07T15:29:23.503514Z"^^xsd:dateTime .

oakcurric:priorknowledge-477-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Work done is measured in joules (J)."@en ;
  dcterms:modified "2026-06-07T15:29:23.503519Z"^^xsd:dateTime .

oakcurric:priorknowledge-477-7
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Doubling the mass of a moving object doubles the energy it has because it is
  moving."""@en ;
  dcterms:modified "2026-06-07T15:29:23.503524Z"^^xsd:dateTime .

oakcurric:priorknowledge-477-8
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Doubling the speed of an object increases the energy it has because it is moving by
  four times."""@en ;
  dcterms:modified "2026-06-07T15:29:23.503529Z"^^xsd:dateTime .

oakcurric:priorknowledge-477-9
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The gravitational force acting on an object does work to speed the object up when it
  is falling."""@en ;
  dcterms:modified "2026-06-07T15:29:23.503534Z"^^xsd:dateTime .

oakcurric:priorknowledge-477-10
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Gravitational force (weight) = mass × gravitational field strength, W = mg."@en ;
  dcterms:modified "2026-06-07T15:29:23.503593Z"^^xsd:dateTime .

oakcurric:priorknowledge-965-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "The neutralisation reaction is: base + acid ⭢ salt + water"@en ;
  dcterms:modified "2026-06-07T15:29:23.520435Z"^^xsd:dateTime .

oakcurric:priorknowledge-965-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Metal carbonate + acid ⭢ salt + water + carbon dioxide"@en ;
  dcterms:modified "2026-06-07T15:29:23.520449Z"^^xsd:dateTime .

oakcurric:priorknowledge-965-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Oxygen gas has a mass, as all gases do."@en ;
  dcterms:modified "2026-06-07T15:29:23.520456Z"^^xsd:dateTime .

oakcurric:priorknowledge-965-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """When a metal reacts with acid bubbles may form, the temperature rise and the metal
  reduce in size or disappear."""@en ;
  dcterms:modified "2026-06-07T15:29:23.520461Z"^^xsd:dateTime .

oakcurric:priorknowledge-965-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Characteristics of chemical reactions include changes in colour, bubbling, or a
  change of temperature."""@en ;
  dcterms:modified "2026-06-07T15:29:23.520467Z"^^xsd:dateTime .

oakcurric:priorknowledge-965-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Bubbles appear when a gas is produced in a chemical reaction."@en ;
  dcterms:modified "2026-06-07T15:29:23.520472Z"^^xsd:dateTime .

oakcurric:priorknowledge-902-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "All organisms are made up of one or more cells."@en ;
  dcterms:modified "2026-06-07T15:29:23.521966Z"^^xsd:dateTime .

oakcurric:priorknowledge-902-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Multicellular organisms grow by making new cells."@en ;
  dcterms:modified "2026-06-07T15:29:23.521979Z"^^xsd:dateTime .

oakcurric:priorknowledge-902-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "New cells are made when existing cells divide by mitosis."@en ;
  dcterms:modified "2026-06-07T15:29:23.521985Z"^^xsd:dateTime .

oakcurric:priorknowledge-902-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Specialised cells in multicellular organisms (including humans and plants) have
  shapes, sizes and structures that are adapted for the jobs the cells do."""@en ;
  dcterms:modified "2026-06-07T15:29:23.521990Z"^^xsd:dateTime .

oakcurric:priorknowledge-902-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The genetic material of all organisms is made of DNA, wound up into structures
  called chromosomes."""@en ;
  dcterms:modified "2026-06-07T15:29:23.521996Z"^^xsd:dateTime .

oakcurric:priorknowledge-902-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Sections of chromosomes are called genes, which store instructions for making
  proteins (including enzymes)."""@en ;
  dcterms:modified "2026-06-07T15:29:23.522001Z"^^xsd:dateTime .

oakcurric:priorknowledge-902-7
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The proteins that are made are used to build other structures and control chemical
  reactions."""@en ;
  dcterms:modified "2026-06-07T15:29:23.522006Z"^^xsd:dateTime .

oakcurric:priorknowledge-570-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Plants are multicellular organisms – they are made up of millions of living
  cells."""@en ;
  dcterms:modified "2026-06-07T15:29:23.542730Z"^^xsd:dateTime .

oakcurric:priorknowledge-570-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Plants do not have a circulatory system (they do not have blood, blood vessels or a
  heart)."""@en ;
  dcterms:modified "2026-06-07T15:29:23.542748Z"^^xsd:dateTime .

oakcurric:priorknowledge-570-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Cells need to be supplied with nutrients including carbohydrates, proteins, lipids
  and water for growth and repair."""@en ;
  dcterms:modified "2026-06-07T15:29:23.542755Z"^^xsd:dateTime .

oakcurric:priorknowledge-570-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Cells need to be supplied with oxygen and glucose for cellular respiration to
  provide energy for life processes."""@en ;
  dcterms:modified "2026-06-07T15:29:23.542761Z"^^xsd:dateTime .

oakcurric:priorknowledge-570-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Cells with chloroplasts need to be supplied with carbon dioxide and water for
  photosynthesis."""@en ;
  dcterms:modified "2026-06-07T15:29:23.542767Z"^^xsd:dateTime .

oakcurric:priorknowledge-570-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Particles of substances move by diffusion into and out of cells through
  selectively-permeable cell membranes."""@en ;
  dcterms:modified "2026-06-07T15:29:23.542772Z"^^xsd:dateTime .

oakcurric:priorknowledge-570-7
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Exchange surfaces are adapted to maximise the surface area for diffusion of
  particles across membranes."""@en ;
  dcterms:modified "2026-06-07T15:29:23.542777Z"^^xsd:dateTime .

oakcurric:priorknowledge-570-8
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """In humans, the circulatory system transports essential substances around the body
  and minimises the distance they have to diffuse so cells can be supplied quickly."""@en ;
  dcterms:modified "2026-06-07T15:29:23.542782Z"^^xsd:dateTime .

oakcurric:priorknowledge-962-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Each element is made up of just one sort of atom"@en ;
  dcterms:modified "2026-06-07T15:29:23.570562Z"^^xsd:dateTime .

oakcurric:priorknowledge-962-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Each element has specific physical properties"@en ;
  dcterms:modified "2026-06-07T15:29:23.570584Z"^^xsd:dateTime .

oakcurric:priorknowledge-962-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Each element has specific chemical properties"@en ;
  dcterms:modified "2026-06-07T15:29:23.570595Z"^^xsd:dateTime .

oakcurric:priorknowledge-962-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Many non-metals are in the gas state at room temperature"@en ;
  dcterms:modified "2026-06-07T15:29:23.570603Z"^^xsd:dateTime .

oakcurric:priorknowledge-962-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Some non-metals form diatomic molecules that contain two atoms"@en ;
  dcterms:modified "2026-06-07T15:29:23.570612Z"^^xsd:dateTime .

oakcurric:priorknowledge-962-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """A compound is made of two or more different elements chemically bonded through a
  chemical reaction"""@en ;
  dcterms:modified "2026-06-07T15:29:23.570652Z"^^xsd:dateTime .

oakcurric:priorknowledge-962-7
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """A compound may have different properties to each of the elements that it is made
  from"""@en ;
  dcterms:modified "2026-06-07T15:29:23.570684Z"^^xsd:dateTime .

oakcurric:priorknowledge-962-8
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Some compounds contain the same elements that are bonded together in
  different ways"""@en ;
  dcterms:modified "2026-06-07T15:29:23.570693Z"^^xsd:dateTime .

oakcurric:priorknowledge-478-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "The temperature along a thermal conductor increases quickly when it is heated."@en ;
  dcterms:modified "2026-06-07T15:29:23.581449Z"^^xsd:dateTime .

oakcurric:priorknowledge-478-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The temperature along a thermal insulator increases very slowly when it is
  heated."""@en ;
  dcterms:modified "2026-06-07T15:29:23.581468Z"^^xsd:dateTime .

oakcurric:priorknowledge-478-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """In thermal conductors, vibrating particles quickly cause the particles near to them
  to vibrate as well."""@en ;
  dcterms:modified "2026-06-07T15:29:23.581476Z"^^xsd:dateTime .

oakcurric:priorknowledge-478-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The faster the particles in something are vibrating or moving, the higher its
  temperature."""@en ;
  dcterms:modified "2026-06-07T15:29:23.581482Z"^^xsd:dateTime .

oakcurric:priorknowledge-478-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The more energy something has because its particles are vibrating or moving, the
  more it can heat something else."""@en ;
  dcterms:modified "2026-06-07T15:29:23.581487Z"^^xsd:dateTime .

oakcurric:priorknowledge-478-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "It is easier to increase the temperature of some materials than others."@en ;
  dcterms:modified "2026-06-07T15:29:23.581492Z"^^xsd:dateTime .

oakcurric:priorknowledge-478-7
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The same amount of different materials at the same temperature can cause different
  amounts of heating."""@en ;
  dcterms:modified "2026-06-07T15:29:23.581497Z"^^xsd:dateTime .

oakcurric:priorknowledge-478-8
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The particles and the bonds between particles are different in different
  substances."""@en ;
  dcterms:modified "2026-06-07T15:29:23.581502Z"^^xsd:dateTime .

oakcurric:priorknowledge-959-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "All matter is made up of atoms."@en ;
  dcterms:modified "2026-06-07T15:29:23.589249Z"^^xsd:dateTime .

oakcurric:priorknowledge-959-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Each element is made up of just one sort of atom."@en ;
  dcterms:modified "2026-06-07T15:29:23.589269Z"^^xsd:dateTime .

oakcurric:priorknowledge-959-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Each element is made of a different type of atom."@en ;
  dcterms:modified "2026-06-07T15:29:23.589280Z"^^xsd:dateTime .

oakcurric:priorknowledge-959-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Each element has a chemical symbol of which the first letter is always a
  capital."""@en ;
  dcterms:modified "2026-06-07T15:29:23.589289Z"^^xsd:dateTime .

oakcurric:priorknowledge-959-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Group 0 elements are called noble gases and do not react."@en ;
  dcterms:modified "2026-06-07T15:29:23.589298Z"^^xsd:dateTime .

oakcurric:priorknowledge-959-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "The elements in Group 1 are all soft metals that float on water."@en ;
  dcterms:modified "2026-06-07T15:29:23.589307Z"^^xsd:dateTime .

oakcurric:priorknowledge-959-7
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Group 1 metals get more reactive as you go down the group."@en ;
  dcterms:modified "2026-06-07T15:29:23.589316Z"^^xsd:dateTime .

oakcurric:priorknowledge-959-8
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """As you go down Group 7, the state of the elements at room temperature change from
  gas to solid."""@en ;
  dcterms:modified "2026-06-07T15:29:23.589325Z"^^xsd:dateTime .

oakcurric:priorknowledge-959-9
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Group 7 elements get less reactive as you go down the group."@en ;
  dcterms:modified "2026-06-07T15:29:23.589334Z"^^xsd:dateTime .

oakcurric:priorknowledge-959-10
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "The transition metals in the middle of the periodic table are not very reactive."@en ;
  dcterms:modified "2026-06-07T15:29:23.589343Z"^^xsd:dateTime .

oakcurric:priorknowledge-1145-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "There are three states of matter: solid, liquid and gas"@en ;
  dcterms:modified "2026-06-07T15:29:23.591977Z"^^xsd:dateTime .

oakcurric:priorknowledge-1145-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Changes of state can be achieved by heating or cooling"@en ;
  dcterms:modified "2026-06-07T15:29:23.591997Z"^^xsd:dateTime .

oakcurric:priorknowledge-1145-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Solids, liquids and gases have different properties"@en ;
  dcterms:modified "2026-06-07T15:29:23.592008Z"^^xsd:dateTime .

oakcurric:priorknowledge-1145-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Only gases can be compressed, so gases can have different pressures"@en ;
  dcterms:modified "2026-06-07T15:29:23.592017Z"^^xsd:dateTime .

oakcurric:priorknowledge-1145-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Fluids fill the container they’re in"@en ;
  dcterms:modified "2026-06-07T15:29:23.592026Z"^^xsd:dateTime .

oakcurric:priorknowledge-1145-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Fluids can be poured (they can flow)"@en ;
  dcterms:modified "2026-06-07T15:29:23.592035Z"^^xsd:dateTime .

oakcurric:priorknowledge-1145-7
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "The particle model shows how solids, liquids and gases are organised together"@en ;
  dcterms:modified "2026-06-07T15:29:23.592044Z"^^xsd:dateTime .

oakcurric:priorknowledge-490-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "As a water wave moves forwards, each bit of water moves up and down."@en ;
  dcterms:modified "2026-06-07T15:29:23.605653Z"^^xsd:dateTime .

oakcurric:priorknowledge-490-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Water does not move forwards with a wave."@en ;
  dcterms:modified "2026-06-07T15:29:23.605671Z"^^xsd:dateTime .

oakcurric:priorknowledge-490-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "A water wave is a transverse wave."@en ;
  dcterms:modified "2026-06-07T15:29:23.605678Z"^^xsd:dateTime .

oakcurric:priorknowledge-490-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "The frequency of a water wave does not affect its speed."@en ;
  dcterms:modified "2026-06-07T15:29:23.605684Z"^^xsd:dateTime .

oakcurric:priorknowledge-490-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "The amplitude of a water wave does not affect its speed."@en ;
  dcterms:modified "2026-06-07T15:29:23.605689Z"^^xsd:dateTime .

oakcurric:priorknowledge-490-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The bigger the amplitude of a wave, the greater the amount of energy it
  transfers."""@en ;
  dcterms:modified "2026-06-07T15:29:23.605694Z"^^xsd:dateTime .

oakcurric:priorknowledge-490-7
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The higher the frequency of a wave, the greater the amount of energy it
  transfers."""@en ;
  dcterms:modified "2026-06-07T15:29:23.605699Z"^^xsd:dateTime .

oakcurric:priorknowledge-490-8
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "As a sound wave moves forwards, each bit of air moves forward and backward."@en ;
  dcterms:modified "2026-06-07T15:29:23.605704Z"^^xsd:dateTime .

oakcurric:priorknowledge-490-9
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Air does not move forwards with a sound wave."@en ;
  dcterms:modified "2026-06-07T15:29:23.605709Z"^^xsd:dateTime .

oakcurric:priorknowledge-490-10
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "A sound wave is a longitudinal wave."@en ;
  dcterms:modified "2026-06-07T15:29:23.605714Z"^^xsd:dateTime .

oakcurric:priorknowledge-574-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Producers, including plants, use a chemical process called photosynthesis to make
  their own food in the form of glucose (a type of carbohydrate)."""@en ;
  dcterms:modified "2026-06-07T15:29:23.762900Z"^^xsd:dateTime .

oakcurric:priorknowledge-574-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """A balanced symbol equation to summarise the chemical reactants and products of the
  process of photosynthesis."""@en ;
  dcterms:modified "2026-06-07T15:29:23.762917Z"^^xsd:dateTime .

oakcurric:priorknowledge-574-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Plant leaves are adapted for photosynthesis; they have stomata for gas exchange, to
  absorb carbon dioxide and release waste oxygen."""@en ;
  dcterms:modified "2026-06-07T15:29:23.762924Z"^^xsd:dateTime .

oakcurric:priorknowledge-574-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Photosynthesis takes place in chloroplasts in cells that make up the aerial parts of
  plants."""@en ;
  dcterms:modified "2026-06-07T15:29:23.762929Z"^^xsd:dateTime .

oakcurric:priorknowledge-574-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Chloroplasts contain a pigment called chlorophyll that absorbs light."@en ;
  dcterms:modified "2026-06-07T15:29:23.762935Z"^^xsd:dateTime .

oakcurric:priorknowledge-574-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Light is not a chemical reactant, but transfers energy to chlorophyll to enable
  photosynthesis to take place."""@en ;
  dcterms:modified "2026-06-07T15:29:23.762941Z"^^xsd:dateTime .

oakcurric:priorknowledge-574-7
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Enzymes are the catalysts for many chemical reactions in living organisms."@en ;
  dcterms:modified "2026-06-07T15:29:23.762946Z"^^xsd:dateTime .

oakcurric:priorknowledge-574-8
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Photosynthesis involves many chemical reactions, catalysed by enzymes."@en ;
  dcterms:modified "2026-06-07T15:29:23.762951Z"^^xsd:dateTime .

oakcurric:priorknowledge-574-9
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Enzymes work best in optimum conditions and less well when conditions change away
  from the optimum."""@en ;
  dcterms:modified "2026-06-07T15:29:23.762956Z"^^xsd:dateTime .

oakcurric:priorknowledge-494-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The visible spectrum comprises red, orange, yellow, green, blue, indigo and violet
  light."""@en ;
  dcterms:modified "2026-06-07T15:29:23.918621Z"^^xsd:dateTime .

oakcurric:priorknowledge-494-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "A glass prism can split sunlight up into colours of the visible spectrum."@en ;
  dcterms:modified "2026-06-07T15:29:23.918634Z"^^xsd:dateTime .

oakcurric:priorknowledge-494-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "A ray of light bends at the surface as it enters glass (or water) from air."@en ;
  dcterms:modified "2026-06-07T15:29:23.918641Z"^^xsd:dateTime .

oakcurric:priorknowledge-494-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """A ray of light bends in the opposite direction at the surface as it leaves glass (or
  water) into air."""@en ;
  dcterms:modified "2026-06-07T15:29:23.918646Z"^^xsd:dateTime .

oakcurric:priorknowledge-494-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "The speed of a wave depends on the medium it is travelling through."@en ;
  dcterms:modified "2026-06-07T15:29:23.918651Z"^^xsd:dateTime .

oakcurric:priorknowledge-494-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "The speed of a wave does not depend on its amplitude or its frequency."@en ;
  dcterms:modified "2026-06-07T15:29:23.918656Z"^^xsd:dateTime .

oakcurric:priorknowledge-494-7
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "For a given wave speed, the higher the frequency, the shorter the wavelength."@en ;
  dcterms:modified "2026-06-07T15:29:23.918662Z"^^xsd:dateTime .

oakcurric:priorknowledge-494-8
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "For a given waves speed, the longer the wavelength, the lower the frequency."@en ;
  dcterms:modified "2026-06-07T15:29:23.918677Z"^^xsd:dateTime .

oakcurric:priorknowledge-494-9
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Wave speed = frequency x wavelength."@en ;
  dcterms:modified "2026-06-07T15:29:23.918683Z"^^xsd:dateTime .

oakcurric:priorknowledge-972-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "A chemical that is oxidised either gains oxygen or loses electrons."@en ;
  dcterms:modified "2026-06-07T15:29:24.035078Z"^^xsd:dateTime .

oakcurric:priorknowledge-972-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "A chemical that is reduced either loses oxygen or gains electrons."@en ;
  dcterms:modified "2026-06-07T15:29:24.035092Z"^^xsd:dateTime .

oakcurric:priorknowledge-972-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "A redox reaction is one in which both oxidation and reduction take place."@en ;
  dcterms:modified "2026-06-07T15:29:24.035098Z"^^xsd:dateTime .

oakcurric:priorknowledge-972-4
  a curric:PriorKnowledgeRequirement ;
