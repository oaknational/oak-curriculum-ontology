  dcterms:modified "2026-06-09T00:46:04.310210Z"^^xsd:dateTime .

oakcurric:keyword-sterilisation
  a curric:Keyword ;
  schema:name "sterilisation"@en ;
  schema:description """the process of having a medical operation to make it impossible to have
  children"""@en ;
  dcterms:modified "2026-06-09T00:46:04.310673Z"^^xsd:dateTime .

oakcurric:keyword-risk-assessment
  a curric:Keyword ;
