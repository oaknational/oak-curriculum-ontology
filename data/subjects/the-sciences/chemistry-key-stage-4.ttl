  schema:description "the optimal internal temperature of our body, which is about 37°C"@en ;
  dcterms:modified "2026-06-07T15:30:02.416954Z"^^xsd:dateTime .

oakcurric:keyword-homeostasis
  a curric:Keyword ;
  schema:name "homeostasis"@en ;
  schema:description """the regulation of the internal conditions to maintain optimum conditions for
  enzyme action and all cell functions"""@en ;
  dcterms:modified "2026-06-07T15:30:02.416962Z"^^xsd:dateTime .

oakcurric:keyword-common-ancestor
  a curric:Keyword ;
