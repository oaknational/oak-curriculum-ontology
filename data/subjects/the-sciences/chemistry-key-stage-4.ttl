  structures, and calculate relative atomic masses."""@en ;
  dcterms:modified "2026-06-07T15:30:41.118155Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-9943
  a curric:PupilLessonOutcome ;
  rdfs:label """I can use the principle of conservation of energy to calculate changes in energy of
  moving objects."""@en ;
  dcterms:modified "2026-06-07T15:30:41.118364Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-20080
  a curric:PupilLessonOutcome ;
