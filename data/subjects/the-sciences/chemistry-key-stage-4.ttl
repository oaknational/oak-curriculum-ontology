  dcterms:modified "2026-06-07T15:30:02.416752Z"^^xsd:dateTime .

oakcurric:keyword-farm-animal
  a curric:Keyword ;
  schema:name "Farm animal"@en ;
  schema:description "Animals that are kept on farms for food or work."@en ;
  dcterms:modified "2026-06-07T15:30:02.416758Z"^^xsd:dateTime .

oakcurric:keyword-biological-sex
  a curric:Keyword ;
