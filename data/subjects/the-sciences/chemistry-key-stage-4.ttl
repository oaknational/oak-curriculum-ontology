<https://w3id.org/uk/oak/curriculum/oakcurriculum/chemistry-key-stage-4>
  rdf:type owl:Ontology ;

  rdfs:label "Oak Curriculum Data - Chemistry Key Stage 4 Instance Data"@en ;
  dc:title "Oak Curriculum Data - Chemistry Key Stage 4 Instance Data"@en ;
  rdfs:comment """Instance data defining the Oak National Academy Curriculum
  programmes for Chemistry Key Stage 4."""@en ;

  owl:versionInfo "0.1.1" ;
  owl:versionIRI <https://w3id.org/uk/oak/curriculum/oakcurriculum/chemistry-key-stage-4/0.1.1> ;
  owl:priorVersion <https://w3id.org/uk/oak/curriculum/oakcurriculum/chemistry-key-stage-4/0.1.0> ;

  dcterms:description """This file contains Programme, Unit, Unit Variant, and Lesson instances for
  Chemistry Key Stage 4, including exam board-specific unit variants and lesson sequences."""@en ;
  dc:creator "Oak National Academy" ;
  dcterms:created "2026-05-25T00:00:00Z"^^xsd:dateTime ;
  dcterms:modified "2026-06-07T15:30:46.389713Z"^^xsd:dateTime ;
