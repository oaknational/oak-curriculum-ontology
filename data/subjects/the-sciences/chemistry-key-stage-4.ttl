  schema:description """A system that regulates body conditions; glands secrete hormones into the
  blood that target specific organs."""@en ;
  dcterms:modified "2026-06-07T15:30:02.417077Z"^^xsd:dateTime .

oakcurric:keyword-contraception
  a curric:Keyword ;
