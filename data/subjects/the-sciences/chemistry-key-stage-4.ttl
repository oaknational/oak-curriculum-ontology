  schema:description """a manufacturing method made up of discrete stages, rather than a product
  being constantly produced"""@en ;
  dcterms:modified "2026-06-07T15:30:02.417378Z"^^xsd:dateTime .

oakcurric:keyword-continuous-process
  a curric:Keyword ;
