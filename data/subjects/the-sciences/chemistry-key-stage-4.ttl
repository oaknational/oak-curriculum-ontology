  schema:description """A point at which we cannot use the model to help us explain a scientific
  phenomena."""@en ;
  dcterms:modified "2026-06-07T15:30:02.417072Z"^^xsd:dateTime .

oakcurric:keyword-endocrine-system
  a curric:Keyword ;
