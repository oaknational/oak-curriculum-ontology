  dcterms:modified "2026-06-07T15:29:24.380724Z"^^xsd:dateTime .

oakcurric:priorknowledge-1147-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Group 7 elements get less reactive as you go down the group."@en ;
  dcterms:modified "2026-06-07T15:29:24.380730Z"^^xsd:dateTime .

oakcurric:priorknowledge-659-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Food chains show the transfer of biomass from producers to consumers, and from prey
  to predators."""@en ;
  dcterms:modified "2026-06-07T15:29:24.546761Z"^^xsd:dateTime .

oakcurric:priorknowledge-659-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Food web diagrams represent several interconnected food chains within a community of
  organisms."""@en ;
  dcterms:modified "2026-06-07T15:29:24.546773Z"^^xsd:dateTime .

oakcurric:priorknowledge-659-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """A change in the size of a population will affect other populations in the same
  community."""@en ;
  dcterms:modified "2026-06-07T15:29:24.546779Z"^^xsd:dateTime .

oakcurric:priorknowledge-659-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Habitats are where plants and animals live and they contain living (biotic) and
  non-living (abiotic) parts."""@en ;
  dcterms:modified "2026-06-07T15:29:24.546784Z"^^xsd:dateTime .

oakcurric:priorknowledge-659-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Organisms interact with the environment in which they live."@en ;
  dcterms:modified "2026-06-07T15:29:24.546789Z"^^xsd:dateTime .

oakcurric:priorknowledge-659-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "All species have features which make them suited to their environment."@en ;
  dcterms:modified "2026-06-07T15:29:24.546794Z"^^xsd:dateTime .

oakcurric:priorknowledge-659-7
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Changes to the environment may make it harder for organisms to survive in a
  particular habitat."""@en ;
  dcterms:modified "2026-06-07T15:29:24.546798Z"^^xsd:dateTime .

oakcurric:priorknowledge-659-8
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Plants undergo both photosynthesis and respiration."@en ;
  dcterms:modified "2026-06-07T15:29:24.546803Z"^^xsd:dateTime .

oakcurric:priorknowledge-659-9
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Carbon is stored in fossil fuels such as coal, oil and peat."@en ;
  dcterms:modified "2026-06-07T15:29:24.546808Z"^^xsd:dateTime .

oakcurric:priorknowledge-659-10
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "The size of populations of organisms can be estimated using sampling techniques."@en ;
  dcterms:modified "2026-06-07T15:29:24.546812Z"^^xsd:dateTime .

oakcurric:priorknowledge-567-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """[Y6] The basic functions of the heart, blood vessels and blood of the human
  circulatory system."""@en ;
  dcterms:modified "2026-06-07T15:29:24.680772Z"^^xsd:dateTime .

oakcurric:priorknowledge-567-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Humans are multicellular organisms – they are made up of millions of living
  cells."""@en ;
  dcterms:modified "2026-06-07T15:29:24.680783Z"^^xsd:dateTime .

oakcurric:priorknowledge-567-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Cells need to be supplied with nutrients including carbohydrates, proteins, lipids
  and water for growth and repair."""@en ;
  dcterms:modified "2026-06-07T15:29:24.680789Z"^^xsd:dateTime .

oakcurric:priorknowledge-567-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Cells need to be supplied with oxygen and glucose for cellular respiration to
  provide energy for life processes."""@en ;
  dcterms:modified "2026-06-07T15:29:24.680793Z"^^xsd:dateTime .

oakcurric:priorknowledge-567-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Nutrients, glucose and water are absorbed from the digestive system."@en ;
  dcterms:modified "2026-06-07T15:29:24.680798Z"^^xsd:dateTime .

oakcurric:priorknowledge-567-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Oxygen is absorbed from air in the lungs, which are part of the gas exchange
  system."""@en ;
  dcterms:modified "2026-06-07T15:29:24.680802Z"^^xsd:dateTime .

oakcurric:priorknowledge-567-7
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Particles of substances move by diffusion into and out of cells through
  selectively-permeable cell membranes."""@en ;
  dcterms:modified "2026-06-07T15:29:24.680806Z"^^xsd:dateTime .

oakcurric:priorknowledge-569-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Plants are multicellular organisms – they are made up of millions of living
  cells."""@en ;
  dcterms:modified "2026-06-07T15:29:24.833217Z"^^xsd:dateTime .

oakcurric:priorknowledge-569-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Plants do not take in food; they are producers that make their own food in the form
  of carbohydrate by photosynthesis."""@en ;
  dcterms:modified "2026-06-07T15:29:24.833245Z"^^xsd:dateTime .

oakcurric:priorknowledge-569-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "The chemical reactants of photosynthesis are water and carbon dioxide."@en ;
  dcterms:modified "2026-06-07T15:29:24.833259Z"^^xsd:dateTime .

oakcurric:priorknowledge-569-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Photosynthesis can only happen in the light."@en ;
  dcterms:modified "2026-06-07T15:29:24.833269Z"^^xsd:dateTime .

oakcurric:priorknowledge-569-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The chemical products of photosynthesis are oxygen and glucose (a type of
  carbohydrate)."""@en ;
  dcterms:modified "2026-06-07T15:29:24.833279Z"^^xsd:dateTime .

oakcurric:priorknowledge-569-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Photosynthesis involves many chemical reactions; a word summary of the reactants and
  products is a model of the process."""@en ;
  dcterms:modified "2026-06-07T15:29:24.833297Z"^^xsd:dateTime .

oakcurric:priorknowledge-569-7
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Plant leaves are adapted for photosynthesis; they have stomata for gas exchange, to
  absorb carbon dioxide and release waste oxygen; and they have a large surface area to
  absorb light."""@en ;
  dcterms:modified "2026-06-07T15:29:24.833306Z"^^xsd:dateTime .

oakcurric:priorknowledge-569-8
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The cells that make up leaves have chloroplasts that contain chlorophyll, where
  photosynthesis takes place."""@en ;
  dcterms:modified "2026-06-07T15:29:24.833312Z"^^xsd:dateTime .

