# ----------------------------------------------------------------------
# Key Learning Points
# ----------------------------------------------------------------------

oakcurric:keylearningpoint-lesson-7967-1
  a curric:KeyLearningPoint ;
  rdfs:label """Plants and microorganisms provide new medicines; many others are synthesised in labs
  to target pathogens and host cells."""@en ;
  dcterms:modified "2026-06-07T15:30:29.001336Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7967-2
  a curric:KeyLearningPoint ;
  rdfs:label """Preclinical trials: the medicine is tested for safety and effectiveness on cultured
  human cells and on live animals."""@en ;
  dcterms:modified "2026-06-07T15:30:29.001340Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7967-3
  a curric:KeyLearningPoint ;
  rdfs:label """Clinical trials: the medicine is tested for safety in people without the
  disease."""@en ;
  dcterms:modified "2026-06-07T15:30:29.001347Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7967-4
  a curric:KeyLearningPoint ;
  rdfs:label """Clinical trials: the medicine is tested for safety and effectiveness in people with
  the disease."""@en ;
  dcterms:modified "2026-06-07T15:30:29.001352Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7967-5
  a curric:KeyLearningPoint ;
  rdfs:label """Use of placebos in clinical trials, and use of blind and double blind trials prevent
  to bias in the results."""@en ;
  dcterms:modified "2026-06-07T15:30:29.001356Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7963-1
  a curric:KeyLearningPoint ;
  rdfs:label """Antibiotics are medicines that can only be used to treat bacterial infections; they
  do not work against viruses."""@en ;
  dcterms:modified "2026-06-07T15:30:29.001558Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7963-2
  a curric:KeyLearningPoint ;
  rdfs:label "Some antibiotics work by stopping bacteria developing a cell wall."@en ;
  dcterms:modified "2026-06-07T15:30:29.001563Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7963-3
  a curric:KeyLearningPoint ;
  rdfs:label """Bacteria can become resistant to antibiotics, and resistance can spread if
  antibiotics are not used correctly."""@en ;
  dcterms:modified "2026-06-07T15:30:29.001567Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7963-4
  a curric:KeyLearningPoint ;
  rdfs:label "Antibiotics must only be taken when they are prescribed by a doctor."@en ;
  dcterms:modified "2026-06-07T15:30:29.001571Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7963-5
  a curric:KeyLearningPoint ;
  rdfs:label """Do not take antibiotics for the wrong reasons and always complete the prescribed
  course."""@en ;
  dcterms:modified "2026-06-07T15:30:29.001576Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9908-1
  a curric:KeyLearningPoint ;
  rdfs:label "Acceleration is equal to the gradient of a velocity-time graph."@en ;
  dcterms:modified "2026-06-07T15:30:29.001822Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9908-2
  a curric:KeyLearningPoint ;
  rdfs:label """A falling line shows decreasing velocity called deceleration, which is a negative
  acceleration."""@en ;
  dcterms:modified "2026-06-07T15:30:29.001828Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9908-3
  a curric:KeyLearningPoint ;
  rdfs:label """Instantaneous speed at a point on a displacement-time graph equals the gradient of a
  tangent at that point."""@en ;
  dcterms:modified "2026-06-07T15:30:29.001834Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9908-4
  a curric:KeyLearningPoint ;
  rdfs:label "The distance travelled is equal to the area under a velocity-time graph."@en ;
  dcterms:modified "2026-06-07T15:30:29.001839Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9908-5
  a curric:KeyLearningPoint ;
  rdfs:label "Displacement is equal to the net positive area under a velocity-time graph."@en ;
  dcterms:modified "2026-06-07T15:30:29.001843Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4921-1
  a curric:KeyLearningPoint ;
  rdfs:label "Increasing a stopping force decreases the time it takes a moving object to stop."@en ;
  dcterms:modified "2026-06-07T15:30:29.002460Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4921-2
  a curric:KeyLearningPoint ;
  rdfs:label "Extending the time it takes to stop reduces the size of the stopping force."@en ;
  dcterms:modified "2026-06-07T15:30:29.002467Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4921-3
  a curric:KeyLearningPoint ;
  rdfs:label """Many safety devices crumple on impact to increase the time that forces act before
  stopping a moving object."""@en ;
  dcterms:modified "2026-06-07T15:30:29.002471Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9718-1
  a curric:KeyLearningPoint ;
  rdfs:label """Choosing the correct equipment is crucial for obtaining accurate and reliable
  results."""@en ;
  dcterms:modified "2026-06-07T15:30:29.002645Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9718-2
  a curric:KeyLearningPoint ;
  rdfs:label """An upturned measuring cylinder is suitable for reactions producing large volumes of
  gas at moderate rates."""@en ;
  dcterms:modified "2026-06-07T15:30:29.002650Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9718-3
  a curric:KeyLearningPoint ;
  rdfs:label "Gas syringes are ideal for measuring small volumes of gas with high precision."@en ;
  dcterms:modified "2026-06-07T15:30:29.002656Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9718-4
  a curric:KeyLearningPoint ;
  rdfs:label """The size of the measuring equipment should be close to the expected volume of gas
  produced."""@en ;
  dcterms:modified "2026-06-07T15:30:29.002661Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9718-5
  a curric:KeyLearningPoint ;
  rdfs:label """Light sensors can be used to measure the percentage of light transmitted through a
  reaction producing a precipitate."""@en ;
  dcterms:modified "2026-06-07T15:30:29.002665Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8104-1
  a curric:KeyLearningPoint ;
  rdfs:label """Embryonic and adult stem cells can be used in treatments to make new specialised
  cells to replace damaged ones."""@en ;
  dcterms:modified "2026-06-07T15:30:29.002671Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8104-2
  a curric:KeyLearningPoint ;
  rdfs:label """Examples include using stem cells to treat type 1 diabetes and bone marrow
  transplants for leukaemia."""@en ;
  dcterms:modified "2026-06-07T15:30:29.002676Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8104-3
  a curric:KeyLearningPoint ;
  rdfs:label """Transplanting stem cells into a patient has risks (e.g. immune rejection, cancer
  from uncontrolled division, infection)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.002680Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8104-4
  a curric:KeyLearningPoint ;
  rdfs:label "Ethical objections to harvesting embryos as a source of embryonic stem cells."@en ;
  dcterms:modified "2026-06-07T15:30:29.002701Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8104-5
  a curric:KeyLearningPoint ;
  rdfs:label "Debating benefits versus risks and ethical issues."@en ;
  dcterms:modified "2026-06-07T15:30:29.002705Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5583-1
  a curric:KeyLearningPoint ;
  rdfs:label """Plants need water for support (to remain turgid) because they don’t have bones, and
  for photosynthesis in cells."""@en ;
  dcterms:modified "2026-06-07T15:30:29.002951Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5583-2
  a curric:KeyLearningPoint ;
  rdfs:label """Plants need mineral ions for growth and repair, including nitrate ions as a source
  of nitrogen to make proteins."""@en ;
  dcterms:modified "2026-06-07T15:30:29.002955Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5583-3
  a curric:KeyLearningPoint ;
  rdfs:label """Particles of water are absorbed by osmosis, a type of diffusion, into plant root
  hair cells."""@en ;
  dcterms:modified "2026-06-07T15:30:29.002959Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5583-4
  a curric:KeyLearningPoint ;
  rdfs:label """Nitrate ions are absorbed into plant root hair cells by active transport, which
  requires energy."""@en ;
  dcterms:modified "2026-06-07T15:30:29.002963Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5583-5
  a curric:KeyLearningPoint ;
  rdfs:label """Root hair cells are adapted to increase the surface area of membrane for osmosis and
  active transport."""@en ;
  dcterms:modified "2026-06-07T15:30:29.002970Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9626-1
  a curric:KeyLearningPoint ;
  rdfs:label """An empirical formula is the simplest whole number ratio of atoms of each element in
  a compound."""@en ;
  dcterms:modified "2026-06-07T15:30:29.003287Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9626-2
  a curric:KeyLearningPoint ;
  rdfs:label """The formula of an ionic compound is an empirical formula, as there is no definite
  quantity of each ion."""@en ;
  dcterms:modified "2026-06-07T15:30:29.003307Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9626-3
  a curric:KeyLearningPoint ;
  rdfs:label "Ionic compounds ending with \"–ide\" only contain a metal and a non–metal ion."@en ;
  dcterms:modified "2026-06-07T15:30:29.003314Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9626-4
  a curric:KeyLearningPoint ;
  rdfs:label "Polyatomic ions are ions that are made up of more than one type of atom."@en ;
  dcterms:modified "2026-06-07T15:30:29.003322Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9626-5
  a curric:KeyLearningPoint ;
  rdfs:label """Ionic compounds ending with \"–ate\" always contain at least three elements, one of
  which is oxygen."""@en ;
  dcterms:modified "2026-06-07T15:30:29.003331Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4922-1
  a curric:KeyLearningPoint ;
  rdfs:label """The faster the particles of a substance are vibrating or moving, the higher the
  substance's temperature."""@en ;
  dcterms:modified "2026-06-07T15:30:29.003378Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4922-2
  a curric:KeyLearningPoint ;
  rdfs:label """In solids, energy is transferred by vibrating particles colliding with nearby
  particles, causing them to vibrate more."""@en ;
  dcterms:modified "2026-06-07T15:30:29.003394Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4922-3
  a curric:KeyLearningPoint ;
  rdfs:label """Metals are good conductors as their free electrons move through them more quickly
  when heated and transfer energy."""@en ;
  dcterms:modified "2026-06-07T15:30:29.003400Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4922-4
  a curric:KeyLearningPoint ;
  rdfs:label """Thermal conductors can feel cold because they transfer energy quickly away from
  their surface."""@en ;
  dcterms:modified "2026-06-07T15:30:29.003405Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4922-5
  a curric:KeyLearningPoint ;
  rdfs:label """Thermal insulators can feel warm because they do not transfer energy quickly from
  their surface."""@en ;
  dcterms:modified "2026-06-07T15:30:29.003409Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9620-1
  a curric:KeyLearningPoint ;
  rdfs:label "Atoms of every element consist of the same three subatomic particles."@en ;
  dcterms:modified "2026-06-07T15:30:29.003441Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9620-2
  a curric:KeyLearningPoint ;
  rdfs:label """All elements consist of their own atoms, with a unique number of protons defining
  the element."""@en ;
  dcterms:modified "2026-06-07T15:30:29.003445Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9620-3
  a curric:KeyLearningPoint ;
  rdfs:label """Everything around us is made of different combinations of atoms, either on their
  own, or in compound form."""@en ;
  dcterms:modified "2026-06-07T15:30:29.003450Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9620-4
  a curric:KeyLearningPoint ;
  rdfs:label """We use element symbols in formulae as a common language to share chemical
  compositions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.003456Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9945-1
  a curric:KeyLearningPoint ;
  rdfs:label """A mixture consists of two or more elements and/or compounds not chemically combined
  together"""@en ;
  dcterms:modified "2026-06-07T15:30:29.003461Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9945-2
  a curric:KeyLearningPoint ;
  rdfs:label "Chemical properties of each substance in a mixture remain unchanged"@en ;
  dcterms:modified "2026-06-07T15:30:29.003465Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9945-3
  a curric:KeyLearningPoint ;
  rdfs:label "There are multiple physical processes for separating mixtures"@en ;
  dcterms:modified "2026-06-07T15:30:29.003469Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9945-4
  a curric:KeyLearningPoint ;
  rdfs:label """Melting point data can be used to distinguish between pure substances and
  mixtures"""@en ;
  dcterms:modified "2026-06-07T15:30:29.003476Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5045-1
  a curric:KeyLearningPoint ;
  rdfs:label "A displacement-time graph of a wave is a representation of a wave."@en ;
  dcterms:modified "2026-06-07T15:30:29.003562Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5045-2
  a curric:KeyLearningPoint ;
  rdfs:label """A displacement-time graph of a wave shows how the displacement at one point varies
  as the wave passes"""@en ;
  dcterms:modified "2026-06-07T15:30:29.003566Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5045-3
  a curric:KeyLearningPoint ;
  rdfs:label """The distance between two wave crests on a displacement-time graph is equal to the
  period of the wave"""@en ;
  dcterms:modified "2026-06-07T15:30:29.003570Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5045-4
  a curric:KeyLearningPoint ;
  rdfs:label "The period of a wave, T, is equal to the time of one complete oscillation"@en ;
  dcterms:modified "2026-06-07T15:30:29.003574Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5045-5
  a curric:KeyLearningPoint ;
  rdfs:label "Frequency is equal to 1 / period"@en ;
  dcterms:modified "2026-06-07T15:30:29.003578Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4923-1
  a curric:KeyLearningPoint ;
  rdfs:label """Different hot metals, of the same mass and starting temperature, heat a fixed amount
  of water by different amounts."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004870Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4923-2
  a curric:KeyLearningPoint ;
  rdfs:label """The energy a material has because its particles are moving with forces between them
  can be labelled internal energy."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004874Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4923-3
  a curric:KeyLearningPoint ;
  rdfs:label """The larger the specific heat capacity of a material, the more energy transferred to
  increase its temperature by 1ºC."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004880Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4923-4
  a curric:KeyLearningPoint ;
  rdfs:label """The larger the specific heat capacity of a material, the more heating it does as its
  temperature falls by 1ºC."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004884Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27997-1
  a curric:KeyLearningPoint ;
  rdfs:label """Process data and plot a graph of appropriate results to identify and describe
  patterns or trends in the results."""@en ;
  dcterms:modified "2026-06-07T15:30:29.251327Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27997-2
  a curric:KeyLearningPoint ;
  rdfs:label """Explain the results using ideas about the requirement of light for
  photosynthesis."""@en ;
  dcterms:modified "2026-06-07T15:30:29.251335Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27997-3
  a curric:KeyLearningPoint ;
  rdfs:label """Identify sources of systematic and random error that could affect the accuracy of
  the measurements."""@en ;
  dcterms:modified "2026-06-07T15:30:29.251343Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27997-4
  a curric:KeyLearningPoint ;
  rdfs:label """Suggest improvements (e.g. ways to measure the pH change and/or the rate more
  accurately)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.251348Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27997-5
  a curric:KeyLearningPoint ;
  rdfs:label "Evaluate the precision, repeatability and reproducibility of the results."@en ;
  dcterms:modified "2026-06-07T15:30:29.251353Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9947-1
  a curric:KeyLearningPoint ;
  rdfs:label """Electrons have a relative charge of -1 and roughly a relative atomic mass of 1/1835
  (negligible)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252375Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9947-2
  a curric:KeyLearningPoint ;
  rdfs:label """Protons are found in the atomic nucleus, have a relative electric charge of +1, and
  a relative mass of 1."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252380Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9947-3
  a curric:KeyLearningPoint ;
  rdfs:label """Neutrons are found in the atomic nucleus, have no electric charge, and a relative
  mass of 1."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252385Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9947-4
  a curric:KeyLearningPoint ;
  rdfs:label """An atom has no electric charge as it contains equal numbers of protons and electrons
  to balance the charge."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252390Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9947-5
  a curric:KeyLearningPoint ;
  rdfs:label """The atom has a nucleus surrounded by electrons, with the nuclear radius much smaller
  than that of the atom."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252397Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5084-1
  a curric:KeyLearningPoint ;
  rdfs:label """Refraction is when waves travel from one transparent medium to another, causing a
  change in direction."""@en ;
  dcterms:modified "2026-06-07T15:30:29.253564Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5084-2
  a curric:KeyLearningPoint ;
  rdfs:label """When waves slow down, they turn towards the normal line (angle of incidence > angle
  of refraction)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.253569Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5084-3
  a curric:KeyLearningPoint ;
  rdfs:label """When waves speed up, they turn away from the normal line (angle of incidence < angle
  of refraction)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.253573Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5084-4
  a curric:KeyLearningPoint ;
  rdfs:label """Refraction can be investigated using a clear rectangular block, ray box and narrow
  slit, pencil, paper and a protractor."""@en ;
  dcterms:modified "2026-06-07T15:30:29.253579Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5084-5
  a curric:KeyLearningPoint ;
  rdfs:label """Refraction occurs when one side of a wavefront enters the new medium before the
  other, causing a change in wave speed."""@en ;
  dcterms:modified "2026-06-07T15:30:29.253584Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9107-1
  a curric:KeyLearningPoint ;
  rdfs:label "The velocity of an object is equal to the gradient of a displacement-time graph."@en ;
  dcterms:modified "2026-06-07T15:30:29.254633Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9107-2
  a curric:KeyLearningPoint ;
  rdfs:label "A direction in which velocity and displacement are measured needs to be chosen."@en ;
  dcterms:modified "2026-06-07T15:30:29.254638Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9107-3
  a curric:KeyLearningPoint ;
  rdfs:label """A negative gradient on a displacement-time graph (sloping downwards) represents
  velocity in the opposite direction."""@en ;
  dcterms:modified "2026-06-07T15:30:29.254644Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9107-4
  a curric:KeyLearningPoint ;
  rdfs:label """A negative value for displacement represents a position ‘behind’ the starting
  position."""@en ;
  dcterms:modified "2026-06-07T15:30:29.254649Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9107-5
  a curric:KeyLearningPoint ;
  rdfs:label """Instantaneous velocity of an object is equal to the gradient of a tangent to a
  displacement-time curve."""@en ;
  dcterms:modified "2026-06-07T15:30:29.254653Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9641-1
  a curric:KeyLearningPoint ;
  rdfs:label """Filtration is a technique used to separate insoluble substances from a mixture with
  a liquid."""@en ;
  dcterms:modified "2026-06-07T15:30:29.255106Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9641-2
  a curric:KeyLearningPoint ;
  rdfs:label "Separation in filtration occurs due to the difference in size of particles."@en ;
  dcterms:modified "2026-06-07T15:30:29.255110Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9641-3
  a curric:KeyLearningPoint ;
  rdfs:label """The terms 'filtrate' and 'residue' describe the components separated by the process
  of filtration."""@en ;
  dcterms:modified "2026-06-07T15:30:29.255114Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8441-1
  a curric:KeyLearningPoint ;
  rdfs:label """Multiple types of positive ions are in competition at the negative electrode
  (cathode)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.255132Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8441-2
  a curric:KeyLearningPoint ;
  rdfs:label """Multiple types of negative ions are in competition at the positive electrode
  (anode)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.255136Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8441-3
  a curric:KeyLearningPoint ;
  rdfs:label "There are rules for which substances are discharged at the anode and cathode."@en ;
  dcterms:modified "2026-06-07T15:30:29.255141Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8441-4
  a curric:KeyLearningPoint ;
  rdfs:label "The gases produced during electrolysis can be collected and tested."@en ;
  dcterms:modified "2026-06-07T15:30:29.255145Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8441-5
  a curric:KeyLearningPoint ;
  rdfs:label "Hydrogen may be formed at the cathode"@en ;
  dcterms:modified "2026-06-07T15:30:29.255150Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8437-1
  a curric:KeyLearningPoint ;
  rdfs:label """Electrolysis: the process in which an electrolyte is broken down by electricity;
  it's not a physical separation method."""@en ;
  dcterms:modified "2026-06-07T15:30:29.255421Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8437-2
  a curric:KeyLearningPoint ;
  rdfs:label "The cathode is the negative electrode, where positive particles gain electrons."@en ;
  dcterms:modified "2026-06-07T15:30:29.255425Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8437-3
  a curric:KeyLearningPoint ;
  rdfs:label "The anode is the positive electrode, where negative particles lose electrons."@en ;
  dcterms:modified "2026-06-07T15:30:29.255429Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8437-4
  a curric:KeyLearningPoint ;
  rdfs:label """An electrolyte contains freely moving ions, and these are attracted to the charged
  electrodes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.255434Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8437-5
  a curric:KeyLearningPoint ;
  rdfs:label "Electrolysis allowed Davy and Faraday to make their scientific discoveries."@en ;
  dcterms:modified "2026-06-07T15:30:29.255438Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9907-1
  a curric:KeyLearningPoint ;
  rdfs:label "Acceleration is equal to the gradient of a velocity-time graph."@en ;
  dcterms:modified "2026-06-07T15:30:29.256435Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9907-2
  a curric:KeyLearningPoint ;
  rdfs:label """A falling line shows decreasing velocity called deceleration, which is a negative
  acceleration."""@en ;
  dcterms:modified "2026-06-07T15:30:29.256439Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9907-3
  a curric:KeyLearningPoint ;
  rdfs:label """Instantaneous speed at a point on a displacement-time graph equals the gradient of a
  tangent at that point."""@en ;
  dcterms:modified "2026-06-07T15:30:29.256443Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9907-4
  a curric:KeyLearningPoint ;
  rdfs:label "The distance travelled is equal to the area under a velocity-time graph."@en ;
  dcterms:modified "2026-06-07T15:30:29.256450Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9907-5
  a curric:KeyLearningPoint ;
  rdfs:label "Displacement is equal to the net positive area under a velocity-time graph."@en ;
  dcterms:modified "2026-06-07T15:30:29.256454Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9137-1
  a curric:KeyLearningPoint ;
  rdfs:label """Acceleration can be measured accurately using light gates or roughly measured using
  a stopwatch and ruler."""@en ;
  dcterms:modified "2026-06-07T15:30:29.256782Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9137-2
  a curric:KeyLearningPoint ;
  rdfs:label """The acceleration of an object is proportional to the resultant force acting on the
  object."""@en ;
  dcterms:modified "2026-06-07T15:30:29.256786Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9137-3
  a curric:KeyLearningPoint ;
  rdfs:label """The acceleration of an object is inversely proportional to the mass of the
  object."""@en ;
  dcterms:modified "2026-06-07T15:30:29.256791Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9137-4
  a curric:KeyLearningPoint ;
  rdfs:label "Newton's Second Law states that F = m × a."@en ;
  dcterms:modified "2026-06-07T15:30:29.256797Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7159-1
  a curric:KeyLearningPoint ;
  rdfs:label """Risk factors affect the chance that a person will develop a non-communicable
  disease."""@en ;
  dcterms:modified "2026-06-07T15:30:29.256925Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7159-2
  a curric:KeyLearningPoint ;
  rdfs:label """Risk factors can be lifestyle factors, e.g. diet, smoking, environmental, e.g. air
  pollution, or genetic, e.g. alleles."""@en ;
  dcterms:modified "2026-06-07T15:30:29.256929Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7159-3
  a curric:KeyLearningPoint ;
  rdfs:label """Experiencing multiple factors can increase the likelihood a person will develop a
  particular disease."""@en ;
  dcterms:modified "2026-06-07T15:30:29.256933Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7159-4
  a curric:KeyLearningPoint ;
  rdfs:label """Interpreting data on non-communicable diseases and risk factors at local, national
  and global levels."""@en ;
  dcterms:modified "2026-06-07T15:30:29.256937Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7159-5
  a curric:KeyLearningPoint ;
  rdfs:label """The importance of peer review and communicating research on risk factors to a range
  of audiences."""@en ;
  dcterms:modified "2026-06-07T15:30:29.256941Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6579-1
  a curric:KeyLearningPoint ;
  rdfs:label "A displacement–time graph shows how displacement changes with time."@en ;
  dcterms:modified "2026-06-07T15:30:29.257543Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6579-2
  a curric:KeyLearningPoint ;
  rdfs:label "A velocity–time graph shows how velocity changes with time."@en ;
  dcterms:modified "2026-06-07T15:30:29.257547Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6579-3
  a curric:KeyLearningPoint ;
  rdfs:label """Displacement–time and velocity–time graphs of the same motion have different
  shapes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.257551Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6579-4
  a curric:KeyLearningPoint ;
  rdfs:label "Acceleration is equal to the gradient of a velocity–time graph."@en ;
  dcterms:modified "2026-06-07T15:30:29.257555Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6579-5
  a curric:KeyLearningPoint ;
  rdfs:label """A falling line shows deceleration (decreasing velocity) which is a negative
  acceleration."""@en ;
  dcterms:modified "2026-06-07T15:30:29.257561Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9651-1
  a curric:KeyLearningPoint ;
  rdfs:label """There are many sources of wastewater and each introduces different types of
  contaminants."""@en ;
  dcterms:modified "2026-06-07T15:30:29.258125Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9651-2
  a curric:KeyLearningPoint ;
  rdfs:label """There are sequential steps involved in making wastewater safe before disposal into
  the environment."""@en ;
  dcterms:modified "2026-06-07T15:30:29.258130Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9651-3
  a curric:KeyLearningPoint ;
  rdfs:label "Multiple types of waste need to be removed from different kinds of wastewater."@en ;
  dcterms:modified "2026-06-07T15:30:29.258133Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9651-4
  a curric:KeyLearningPoint ;
  rdfs:label """Releasing untreated wastewater into the environment could impact an ecosystem's
  health."""@en ;
  dcterms:modified "2026-06-07T15:30:29.258137Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9651-5
  a curric:KeyLearningPoint ;
  rdfs:label """Sludge can be anaerobically treated, producing materials that can be used as a
  fertiliser or fuel."""@en ;
  dcterms:modified "2026-06-07T15:30:29.258141Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20085-1
  a curric:KeyLearningPoint ;
  rdfs:label """The relative atomic mass is the mean mass of an atom compared to 1/12 of the mass of
  a carbon-12 atom."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259105Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20085-2
  a curric:KeyLearningPoint ;
  rdfs:label """The relative formula mass (RFM or Mr) is the sum of the relative atomic masses of
  all the atoms in a chemical formula."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259108Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20085-3
  a curric:KeyLearningPoint ;
  rdfs:label """%mass of an element in a compound = (relative mass of element in compound ÷ RFM of
  compound) × 100"""@en ;
  dcterms:modified "2026-06-07T15:30:29.259112Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27992-1
  a curric:KeyLearningPoint ;
  rdfs:label """Pondweed is a plant that photosynthesises in the light, releasing oxygen gas as a
  waste product."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260147Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27992-2
  a curric:KeyLearningPoint ;
  rdfs:label """Planning an investigation into the effect of light intensity on the rate of
  photosynthesis in pondweed."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260151Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27992-3
  a curric:KeyLearningPoint ;
  rdfs:label """Identifying the independent variable (light intensity) and planning how to
  vary it."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260154Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27992-4
  a curric:KeyLearningPoint ;
  rdfs:label """Identifying factors that should be controlled and how they could be controlled (e.g.
  temperature)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260158Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27992-5
  a curric:KeyLearningPoint ;
  rdfs:label """Planning methods to measure the dependent variable (number of bubbles and volume of
  gas given off)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260162Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9662-1
  a curric:KeyLearningPoint ;
  rdfs:label """Empirical formula is the simplest whole number ratio of atoms of each element in a
  compound."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260712Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9662-2
  a curric:KeyLearningPoint ;
  rdfs:label """Using the masses of elements reacted together, or their percentage compositions,
  calculate the empirical formula."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260715Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9662-3
  a curric:KeyLearningPoint ;
  rdfs:label """Knowing the relative formula mass of a substance, and its empirical formula,
  calculate the molecular formula."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260719Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9662-4
  a curric:KeyLearningPoint ;
  rdfs:label "Know that we are using moles, and molar ratios to calculate formulae"@en ;
  dcterms:modified "2026-06-07T15:30:29.260723Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9906-1
  a curric:KeyLearningPoint ;
  rdfs:label "A displacement–time graph shows how displacement changes with time."@en ;
  dcterms:modified "2026-06-07T15:30:29.261814Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9906-2
  a curric:KeyLearningPoint ;
  rdfs:label "A velocity–time graph shows how velocity changes with time."@en ;
  dcterms:modified "2026-06-07T15:30:29.261818Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9906-3
  a curric:KeyLearningPoint ;
  rdfs:label """Displacement–time and velocity–time graphs of the same motion have different
  shapes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261822Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8318-1
  a curric:KeyLearningPoint ;
  rdfs:label """Group 0 elements are called noble gases (or inert gases) and are very unreactive
  with other elements."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261878Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8318-2
  a curric:KeyLearningPoint ;
  rdfs:label """Group 0 elements can be described as having either full or empty outer electron
  shells."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261882Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8318-3
  a curric:KeyLearningPoint ;
  rdfs:label "Moving down Group 0 elements density and boiling points increase."@en ;
  dcterms:modified "2026-06-07T15:30:29.261885Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8318-4
  a curric:KeyLearningPoint ;
  rdfs:label """Noble gases emit coloured light when a high voltage is applied across them, and they
  do not decompose."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261889Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4920-1
  a curric:KeyLearningPoint ;
  rdfs:label """The momentum of an object is changed by a resultant force acting over a period of
  time."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262551Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4920-2
  a curric:KeyLearningPoint ;
  rdfs:label "Force = rate of change of momentum, F = Δp ÷ t = (mv – mu) ÷ t"@en ;
  dcterms:modified "2026-06-07T15:30:29.262555Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4920-3
  a curric:KeyLearningPoint ;
  rdfs:label """The size of an impact force can be changed when the duration of the impact
  changes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262559Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8315-1
  a curric:KeyLearningPoint ;
  rdfs:label """The atomic number of an element states the number of protons in the nucleus of every
  atom of that element."""@en ;
  dcterms:modified "2026-06-07T15:30:29.265689Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8315-2
  a curric:KeyLearningPoint ;
  rdfs:label """The number of electrons in an atom is equal to the number of protons in the nucleus
  of the atom."""@en ;
  dcterms:modified "2026-06-07T15:30:29.265693Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8315-3
  a curric:KeyLearningPoint ;
  rdfs:label """The mass number of an element is about equal to the number of protons and neutrons
  in atoms of that element."""@en ;
  dcterms:modified "2026-06-07T15:30:29.265697Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6298-1
  a curric:KeyLearningPoint ;
  rdfs:label "Carbon is found in the atmosphere as carbon dioxide."@en ;
  dcterms:modified "2026-06-07T15:30:29.265908Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6298-2
  a curric:KeyLearningPoint ;
  rdfs:label """The carbon cycle shows how carbon is recycled between organisms and the
  atmosphere."""@en ;
  dcterms:modified "2026-06-07T15:30:29.265912Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6298-3
  a curric:KeyLearningPoint ;
  rdfs:label """Carbon dioxide can be removed from the atmosphere by plants, who use it during the
  process of photosynthesis."""@en ;
  dcterms:modified "2026-06-07T15:30:29.265916Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6298-4
  a curric:KeyLearningPoint ;
  rdfs:label """Carbon is returned to the atmosphere by the burning of fossil fuels and the decay of
  dead plant and animal material."""@en ;
  dcterms:modified "2026-06-07T15:30:29.265919Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5562-1
  a curric:KeyLearningPoint ;
  rdfs:label "Blood contains blood cells suspended in a fluid called plasma."@en ;
  dcterms:modified "2026-06-07T15:30:29.269271Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5562-2
  a curric:KeyLearningPoint ;
  rdfs:label """Red blood cells transport oxygen, and have a structure adapted to carry as much
  oxygen as possible."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269277Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5562-3
  a curric:KeyLearningPoint ;
  rdfs:label """Plasma transports water, glucose and other nutrients, and waste products including
  carbon dioxide and urea."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269281Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5562-4
  a curric:KeyLearningPoint ;
  rdfs:label """Arteries carry blood away from the heart; capillaries carry blood to/from cells;
  veins carry blood back to the heart."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269285Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5562-5
  a curric:KeyLearningPoint ;
  rdfs:label """Arteries, capillaries and veins have structures adapted to their functions,
  including different vessel walls and valves."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269289Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5560-1
  a curric:KeyLearningPoint ;
  rdfs:label """Humans are multicellular organisms; the human body is made up of millions of living
  cells."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269418Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5560-2
  a curric:KeyLearningPoint ;
  rdfs:label """Every cell must be supplied with substances for respiration, growth and repair;
  waste products must be removed."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269422Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5560-3
  a curric:KeyLearningPoint ;
  rdfs:label """The circulatory system transports substances between cells and the gas exchange,
  digestive and excretory systems."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269426Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5560-4
  a curric:KeyLearningPoint ;
  rdfs:label "The circulatory system is made up of the heart, blood vessels and blood."@en ;
  dcterms:modified "2026-06-07T15:30:29.269430Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5561-1
  a curric:KeyLearningPoint ;
  rdfs:label "Substances are transported around the body in the blood."@en ;
  dcterms:modified "2026-06-07T15:30:29.269436Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5561-2
  a curric:KeyLearningPoint ;
  rdfs:label "Blood is pumped through blood vessels by an organ called the heart."@en ;
  dcterms:modified "2026-06-07T15:30:29.269440Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5561-3
  a curric:KeyLearningPoint ;
  rdfs:label """The heart is made of cardiac muscle, which continually contracts and relaxes to pump
  blood."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269444Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5561-4
  a curric:KeyLearningPoint ;
  rdfs:label """The heart has four chambers with valves, which keep oxygenated and deoxygenated
  blood separate."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269447Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5561-5
  a curric:KeyLearningPoint ;
  rdfs:label """We have a double circulatory system; blood is pumped to the lungs for gas exchange
  then around the rest of the body."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269453Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5564-1
  a curric:KeyLearningPoint ;
  rdfs:label """Particles of substances move into and out of the blood through selectively-permeable
  cell membranes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269534Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5564-2
  a curric:KeyLearningPoint ;
  rdfs:label """Oxygen, carbon dioxide and other small particles move into and out of the blood by
  diffusion."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269537Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5564-3
  a curric:KeyLearningPoint ;
  rdfs:label "Water moves into and out of the blood by osmosis, a type of diffusion."@en ;
  dcterms:modified "2026-06-07T15:30:29.269541Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5564-4
  a curric:KeyLearningPoint ;
  rdfs:label """The net movement of particles by diffusion and osmosis is down a concentration
  gradient."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269545Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5564-5
  a curric:KeyLearningPoint ;
  rdfs:label """Large particles are moved into and out of the blood by active transport, which
  requires energy."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269549Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5567-1
  a curric:KeyLearningPoint ;
  rdfs:label """Consequences for living organisms of relationship between surface area:volume ratio
  and diffusion time."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269605Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5567-2
  a curric:KeyLearningPoint ;
  rdfs:label """Reasons why a small surface area (relative to volume) could be a disadvantage to
  living organisms."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269608Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5567-3
  a curric:KeyLearningPoint ;
  rdfs:label """The circulatory system minimises diffusion distance for oxygen and food molecules so
  cells can be supplied quickly."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269612Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5567-4
  a curric:KeyLearningPoint ;
  rdfs:label """Examples of exchange surfaces in humans (e.g. alveoli in lungs, villi in digestive
  system)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269615Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5567-5
  a curric:KeyLearningPoint ;
  rdfs:label """The exchange surfaces are adapted to maximise surface area for diffusion of
  particles of essential substances and waste."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269619Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28985-1
  a curric:KeyLearningPoint ;
  rdfs:label """Substances are transported around the body in the blood, which is pumped through
  vessels by an organ called the heart."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271856Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28985-2
  a curric:KeyLearningPoint ;
  rdfs:label """The heart is made of cardiac muscle, which continually contracts and relaxes to pump
  blood."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271860Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28985-3
  a curric:KeyLearningPoint ;
  rdfs:label """The heart has four chambers with valves, which keep oxygenated and deoxygenated
  blood separate."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271863Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28985-4
  a curric:KeyLearningPoint ;
  rdfs:label """Cardiac output can be calculated using: cardiac output = stroke volume ×
  heart rate."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271867Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28985-5
  a curric:KeyLearningPoint ;
  rdfs:label """We have a double circulatory system; blood is pumped to the lungs for gas exchange
  then around the rest of the body."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271871Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9193-1
  a curric:KeyLearningPoint ;
  rdfs:label "The parts of a light microscope and their functions."@en ;
  dcterms:modified "2026-06-07T15:30:29.273443Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9193-2
  a curric:KeyLearningPoint ;
  rdfs:label """The method for using a light microscope to observe xylem and phloem, including
  changing the magnification and focus."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273447Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9193-3
  a curric:KeyLearningPoint ;
  rdfs:label """Light microscopy can be used to observe xylem and phloem in a cross-section of a
  plant shoot, root or leaf."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273451Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9193-4
  a curric:KeyLearningPoint ;
  rdfs:label """The magnification and actual size of structures observed with a microscope can be
  calculated."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273455Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5578-1
  a curric:KeyLearningPoint ;
  rdfs:label """Some of the glucose made by photosynthesis is converted into starch and stored in
  starch grains in leaf cells."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273501Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5578-2
  a curric:KeyLearningPoint ;
  rdfs:label """Iodine solution can be used to test plant leaf tissue for the presence of
  starch."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273505Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5578-3
  a curric:KeyLearningPoint ;
  rdfs:label """A scientific prediction is a testable statement about a possible outcome, which can
  be tested in an experiment."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273508Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5578-4
  a curric:KeyLearningPoint ;
  rdfs:label """Predicting the iodine test result for destarched leaves kept in various conditions,
  and explaining the predictions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273512Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5578-5
  a curric:KeyLearningPoint ;
  rdfs:label """Observing the iodine test result for destarched leaves kept in various conditions,
  and explaining the observations."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273516Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9699-1
  a curric:KeyLearningPoint ;
  rdfs:label """An investigation can measure the temperature change through continuous heating of a
  substance."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273556Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9699-2
  a curric:KeyLearningPoint ;
  rdfs:label "Heating curve observations are best presented in a table and graphically."@en ;
  dcterms:modified "2026-06-07T15:30:29.273560Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9699-3
  a curric:KeyLearningPoint ;
  rdfs:label """Reliable data can be collected by taking repeat measurements, identifying anomalies
  and calculating a mean."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273566Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9699-4
  a curric:KeyLearningPoint ;
  rdfs:label "Heating curves can be used to determine the melting point of a substance."@en ;
  dcterms:modified "2026-06-07T15:30:29.273570Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9753-1
  a curric:KeyLearningPoint ;
  rdfs:label """Electrolysis involves the decomposition / break-down of a substance by passing an
  electric current."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273576Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9753-2
  a curric:KeyLearningPoint ;
  rdfs:label "Two types of positive ions are in competition at the negative electrode"@en ;
  dcterms:modified "2026-06-07T15:30:29.273580Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9753-3
  a curric:KeyLearningPoint ;
  rdfs:label "Two types of negative ions are in competition at the positive electrode"@en ;
  dcterms:modified "2026-06-07T15:30:29.273584Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9753-4
  a curric:KeyLearningPoint ;
  rdfs:label "There are rules for which substances are discharged at the anode and cathode"@en ;
  dcterms:modified "2026-06-07T15:30:29.273587Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9753-5
  a curric:KeyLearningPoint ;
  rdfs:label "The gases produced during electrolysis can be collected and tested"@en ;
  dcterms:modified "2026-06-07T15:30:29.273591Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9672-1
  a curric:KeyLearningPoint ;
  rdfs:label """When powdered hydroxide/oxide (base) is added to an acidic solution there is an
  increase in pH."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273614Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9672-2
  a curric:KeyLearningPoint ;
  rdfs:label "pH changes quickly around the neutralisation point."@en ;
  dcterms:modified "2026-06-07T15:30:29.273618Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9672-3
  a curric:KeyLearningPoint ;
  rdfs:label """Indicators, such as Universal Indicator paper, can be used to collect quantitative
  data on pH."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273622Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9672-4
  a curric:KeyLearningPoint ;
  rdfs:label """pH can be plotted on a graph to find the quantity of base required to neutralise an
  acid."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273625Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9688-1
  a curric:KeyLearningPoint ;
  rdfs:label "Changes in heat energy accompany salts dissolving in water."@en ;
  dcterms:modified "2026-06-07T15:30:29.273629Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9688-2
  a curric:KeyLearningPoint ;
  rdfs:label """Changes in heat energy accompany neutralisation, displacement and precipitation
  reactions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273633Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9688-3
  a curric:KeyLearningPoint ;
  rdfs:label "Exothermic and endothermic reactions have everyday uses."@en ;
  dcterms:modified "2026-06-07T15:30:29.273639Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9688-4
  a curric:KeyLearningPoint ;
  rdfs:label """When reactions take place in solution, temperature changes can be measured to
  reflect the energy changes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273643Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5563-1
  a curric:KeyLearningPoint ;
  rdfs:label """The parts of a light microscope and their functions, and the sequence of steps for
  setting up a light microscope."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273647Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5563-2
  a curric:KeyLearningPoint ;
  rdfs:label "A light microscope can be used to observe blood cells on a prepared slide."@en ;
  dcterms:modified "2026-06-07T15:30:29.273650Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5563-3
  a curric:KeyLearningPoint ;
  rdfs:label """Observations from a light microscope can be recorded in a labelled scientific line
  drawing with an indication of scale."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273654Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5563-4
  a curric:KeyLearningPoint ;
  rdfs:label """A light microscope can be used to observe sections of blood vessels and differences
  in the structures of their walls."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273658Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5563-5
  a curric:KeyLearningPoint ;
  rdfs:label """Explaining observations from microscopy of differences in the walls of different
  blood vessels."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273662Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6605-1
  a curric:KeyLearningPoint ;
  rdfs:label """An appropriate range of p.d. values includes 0 V and the maximum p.d. of the lamp
  and at least four other readings."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273665Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6605-2
  a curric:KeyLearningPoint ;
  rdfs:label """For electricity investigations, it is good practice to take many more than the
  minimum number of measurements."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273669Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6605-3
  a curric:KeyLearningPoint ;
  rdfs:label """After plotting a graph, extra readings could be taken to fill gaps or to check
  possible errors."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273673Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6605-4
  a curric:KeyLearningPoint ;
  rdfs:label """Plots that lie off the best fit line are possible errors that need to be
  checked."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273677Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6605-5
  a curric:KeyLearningPoint ;
  rdfs:label """The resistance of a filament lamp is calculated from an I–V graph using pairs of
  readings and the equation R = V ÷ I."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273680Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27965-1
  a curric:KeyLearningPoint ;
  rdfs:label "Radioactive decay is a random process."@en ;
  dcterms:modified "2026-06-07T15:30:29.273684Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27965-2
  a curric:KeyLearningPoint ;
  rdfs:label """It is impossible to predict the moment that a particular unstable nucleus will
  decay."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273688Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27965-3
  a curric:KeyLearningPoint ;
  rdfs:label """It is possible to predict how long it will take for half of a sample of a
  radioactive isotope to decay."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273691Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27965-4
  a curric:KeyLearningPoint ;
  rdfs:label """Radioactive half-life is the time taken for half of a radioactive isotope to decay
  (or for its activity to halve)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273697Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27965-5
  a curric:KeyLearningPoint ;
  rdfs:label "Each radioactive isotope has its own half-life that is always the same."@en ;
  dcterms:modified "2026-06-07T15:30:29.273701Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27993-1
  a curric:KeyLearningPoint ;
  rdfs:label """Following an appropriate method to vary light intensity and measure the gas given
  off"""@en ;
  dcterms:modified "2026-06-07T15:30:29.273705Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27993-2
  a curric:KeyLearningPoint ;
  rdfs:label """Accurate measurement of variables (distance, time, amount of gas) and control of
  variables that might affect the results"""@en ;
  dcterms:modified "2026-06-07T15:30:29.273711Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27993-3
  a curric:KeyLearningPoint ;
  rdfs:label "Counting bubbles and measuring volume of gas given off"@en ;
  dcterms:modified "2026-06-07T15:30:29.273715Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27993-4
  a curric:KeyLearningPoint ;
  rdfs:label "Record results in an appropriate table"@en ;
  dcterms:modified "2026-06-07T15:30:29.273719Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9720-1
  a curric:KeyLearningPoint ;
  rdfs:label """Increasing temperature generally increases rate by boosting the energy and frequency
  of collisions between particles."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273759Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9720-2
  a curric:KeyLearningPoint ;
  rdfs:label """Cooling a reactant decreases its reaction rate by reducing collision energy and
  frequency."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273764Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4924-1
  a curric:KeyLearningPoint ;
  rdfs:label """Energy transferred to increase the temperature of a substance by heating by a fixed
  amount is proportional to mass."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273767Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4924-2
  a curric:KeyLearningPoint ;
  rdfs:label """Energy transferred to a substance by heating a fixed amount is proportional to the
  increase in temperature."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273771Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4924-3
  a curric:KeyLearningPoint ;
  rdfs:label """Energy transferred to increase the temperature of a substance by heating is
  proportional to its specific heat capacity."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273775Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4924-4
  a curric:KeyLearningPoint ;
  rdfs:label """Specific heat capacity equals the energy transferred to or by 1 kg of a material
  when its temperature changes by 1ºC."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273779Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4924-5
  a curric:KeyLearningPoint ;
  rdfs:label """Specific heat capacity, c, is measured in joules per kilogram per degree Celsius
  (J/kg ºC)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273782Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4925-1
  a curric:KeyLearningPoint ;
  rdfs:label """A joulemeter measures a total amount of energy transferred to an electric
  circuit."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273789Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4925-2
  a curric:KeyLearningPoint ;
  rdfs:label """At equilibrium, a metal block is at the same temperature as the water bath
  it is in."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273793Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4925-3
  a curric:KeyLearningPoint ;
  rdfs:label """Specific heat capacity, c, is measured in joules per kilogram per degree
  Celsius."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273796Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8376-1
  a curric:KeyLearningPoint ;
  rdfs:label """The changing rate of a chemical reaction can be represented by a graph of mass of
  gas produced against time."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273931Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8376-2
  a curric:KeyLearningPoint ;
  rdfs:label """When reacting excess marble chips with acid, the same mass of gas is produced for
  all surface areas of chips."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273934Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8376-3
  a curric:KeyLearningPoint ;
  rdfs:label "The mean rate of reaction = total mass of gas produced ÷ total time of reaction"@en ;
  dcterms:modified "2026-06-07T15:30:29.273938Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8376-4
  a curric:KeyLearningPoint ;
  rdfs:label "The instantaneous rate of reaction is equal to the gradient of the graph."@en ;
  dcterms:modified "2026-06-07T15:30:29.273942Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8376-5
  a curric:KeyLearningPoint ;
  rdfs:label """The gradient of a rate of reaction graph can be calculated from a tangent drawn at a
  point on the curve."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273946Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27995-1
  a curric:KeyLearningPoint ;
  rdfs:label """Algae are living organisms that photosynthesise in the light, carbon dioxide is a
  reactant."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273971Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27995-2
  a curric:KeyLearningPoint ;
  rdfs:label """Planning an investigation into the effect of light intensity on the rate of
  photosynthesis in algae."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273975Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27995-3
  a curric:KeyLearningPoint ;
  rdfs:label """Identifying the independent variable (light intensity) and planning how to
  vary it."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273979Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27995-4
  a curric:KeyLearningPoint ;
  rdfs:label """Identifying factors that should be controlled and how they could be (e.g.
  temperature)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273982Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27995-5
  a curric:KeyLearningPoint ;
  rdfs:label """Planning a method to measure the dependent variable (colour change of
  indicator)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273986Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5587-1
  a curric:KeyLearningPoint ;
  rdfs:label """Practical demonstration of the use of a simple potometer to measure water uptake by
  a leafy shoot."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274134Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5587-2
  a curric:KeyLearningPoint ;
  rdfs:label "Use of a light source to vary light intensity."@en ;
  dcterms:modified "2026-06-07T15:30:29.274138Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5587-3
  a curric:KeyLearningPoint ;
  rdfs:label """Use of appropriate apparatus to control temperature (e.g. a water tank as a heat
  shield between light and plant)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274142Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5587-4
  a curric:KeyLearningPoint ;
  rdfs:label """Use of a simple potometer to measure water uptake by a plant at a range of light
  intensities."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274146Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5587-5
  a curric:KeyLearningPoint ;
  rdfs:label """Rate of water uptake = change in volume of water ÷ time taken for volume to
  change"""@en ;
  dcterms:modified "2026-06-07T15:30:29.274149Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9163-1
  a curric:KeyLearningPoint ;
  rdfs:label "Bacteria are prokaryotic organisms."@en ;
  dcterms:modified "2026-06-07T15:30:29.274810Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9163-2
  a curric:KeyLearningPoint ;
  rdfs:label """Common features of prokaryotic cells include the cell membrane, cytoplasm and cell
  wall."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274814Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9163-3
  a curric:KeyLearningPoint ;
  rdfs:label """Prokaryotic cells do not have a nucleus; they store their genetic material in the
  cell cytoplasm."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274818Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9163-4
  a curric:KeyLearningPoint ;
  rdfs:label "The genetic material is stored in one looped chromosome."@en ;
  dcterms:modified "2026-06-07T15:30:29.274821Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9163-5
  a curric:KeyLearningPoint ;
  rdfs:label "Extra genetic material can be stored in small loops called plasmids."@en ;
  dcterms:modified "2026-06-07T15:30:29.274828Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6613-1
  a curric:KeyLearningPoint ;
  rdfs:label """An electromagnetic door lock uses an electromagnet to pull a magnetic bolt to unlock
  a door."""@en ;
  dcterms:modified "2026-06-07T15:30:29.275392Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6613-2
  a curric:KeyLearningPoint ;
  rdfs:label """An electric bell often contains an electromagnet that attracts and moves the
  striker, making it hit the bell."""@en ;
  dcterms:modified "2026-06-07T15:30:29.275398Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6613-3
  a curric:KeyLearningPoint ;
  rdfs:label """As an electromagnet moves the striker in an electric bell, it breaks its own circuit
  to let the striker spring back."""@en ;
  dcterms:modified "2026-06-07T15:30:29.275402Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6613-4
  a curric:KeyLearningPoint ;
  rdfs:label "A motor contains a spinning coil of wire that is an electromagnet."@en ;
  dcterms:modified "2026-06-07T15:30:29.275405Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6613-5
  a curric:KeyLearningPoint ;
  rdfs:label """When there is a current in the spinning coil of wire in a motor, other magnets
  around it will push it round."""@en ;
  dcterms:modified "2026-06-07T15:30:29.275409Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6603-1
  a curric:KeyLearningPoint ;
  rdfs:label """A random error is a chance difference between an observed value and the true
  value."""@en ;
  dcterms:modified "2026-06-07T15:30:29.275413Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6603-2
  a curric:KeyLearningPoint ;
  rdfs:label """Random errors can be caused by mistakes in taking readings, or by taking a reading
  at the wrong time."""@en ;
  dcterms:modified "2026-06-07T15:30:29.275417Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6603-3
  a curric:KeyLearningPoint ;
  rdfs:label "The temperature of a melting solid does not change as it heated."@en ;
  dcterms:modified "2026-06-07T15:30:29.275420Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6603-4
  a curric:KeyLearningPoint ;
  rdfs:label "The temperature of a boiling liquid does not change as it is heated."@en ;
  dcterms:modified "2026-06-07T15:30:29.275424Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8355-1
  a curric:KeyLearningPoint ;
  rdfs:label """Reacting a metal oxide with an appropriate acid can form a desired salt and
  water."""@en ;
  dcterms:modified "2026-06-07T15:30:29.276587Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8355-2
  a curric:KeyLearningPoint ;
  rdfs:label """Adding metal oxide to excess ensures that the acid fully reacts to form salt and
  water."""@en ;
  dcterms:modified "2026-06-07T15:30:29.276591Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8355-3
  a curric:KeyLearningPoint ;
  rdfs:label """Excess metal oxide can be removed by filtration so that the filtrate contains only
  salt and water."""@en ;
  dcterms:modified "2026-06-07T15:30:29.276597Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8355-4
  a curric:KeyLearningPoint ;
  rdfs:label "Water can be removed from the salt by evaporation."@en ;
  dcterms:modified "2026-06-07T15:30:29.276601Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4916-1
  a curric:KeyLearningPoint ;
  rdfs:label """An object that is dropped experiences a constant gravitational force towards the
  centre of Earth."""@en ;
  dcterms:modified "2026-06-07T15:30:29.276605Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4916-2
  a curric:KeyLearningPoint ;
  rdfs:label """For a falling object, drag acts in the opposite direction to the gravitational
  force."""@en ;
  dcterms:modified "2026-06-07T15:30:29.276608Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4916-3
  a curric:KeyLearningPoint ;
  rdfs:label "As a falling object speeds up, the air resistance pushing up on it increases."@en ;
  dcterms:modified "2026-06-07T15:30:29.276612Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4916-4
  a curric:KeyLearningPoint ;
  rdfs:label """When the resultant force on a falling object becomes zero, the object reaches
  terminal velocity."""@en ;
  dcterms:modified "2026-06-07T15:30:29.276618Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6598-1
  a curric:KeyLearningPoint ;
  rdfs:label """A dynamics trolley speeds up (accelerates) along the whole length of a steep
  ramp."""@en ;
  dcterms:modified "2026-06-07T15:30:29.276682Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6598-2
  a curric:KeyLearningPoint ;
  rdfs:label "Instantaneous speed is the average speed over a very short time period."@en ;
  dcterms:modified "2026-06-07T15:30:29.276688Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6598-3
  a curric:KeyLearningPoint ;
  rdfs:label "Taking measurements by reading the timing lines at eye level improves accuracy."@en ;
  dcterms:modified "2026-06-07T15:30:29.276692Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6598-4
  a curric:KeyLearningPoint ;
  rdfs:label "Repeated readings by different observers helps to check for systematic errors."@en ;
  dcterms:modified "2026-06-07T15:30:29.276696Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9703-1
  a curric:KeyLearningPoint ;
  rdfs:label """Manipulating apparatus correctly ensures both accurate results and safety in the
  lab."""@en ;
  dcterms:modified "2026-06-07T15:30:29.276794Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9703-2
  a curric:KeyLearningPoint ;
  rdfs:label """Interconversion between units like grams, moles, volume, density and particles is
  fundamental in chemical calculations."""@en ;
  dcterms:modified "2026-06-07T15:30:29.276798Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9703-3
  a curric:KeyLearningPoint ;
  rdfs:label "Successful interconversion is only possible if the units match."@en ;
  dcterms:modified "2026-06-07T15:30:29.276801Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9703-4
  a curric:KeyLearningPoint ;
  rdfs:label """Using the appropriate apparatus for a required measurement can help to reduce
  uncertainty."""@en ;
  dcterms:modified "2026-06-07T15:30:29.276805Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5605-1
  a curric:KeyLearningPoint ;
  rdfs:label """Water diffuses into and out of cells by osmosis; net movement is from a more dilute
  solution to a more concentrated one."""@en ;
  dcterms:modified "2026-06-07T15:30:29.277291Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5605-2
  a curric:KeyLearningPoint ;
  rdfs:label """Investigating the effect of sucrose solution concentration on the mass of potato
  chips."""@en ;
  dcterms:modified "2026-06-07T15:30:29.277296Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5605-3
  a curric:KeyLearningPoint ;
  rdfs:label "Use of appropriate apparatus to measure volumes, masses and times accurately."@en ;
  dcterms:modified "2026-06-07T15:30:29.277300Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5605-4
  a curric:KeyLearningPoint ;
  rdfs:label "Safe use of materials and apparatus."@en ;
  dcterms:modified "2026-06-07T15:30:29.277304Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5605-5
  a curric:KeyLearningPoint ;
  rdfs:label "Control of variables that might affect the results (e.g. temperature)."@en ;
  dcterms:modified "2026-06-07T15:30:29.277308Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5554-1
  a curric:KeyLearningPoint ;
  rdfs:label """The rate of a reaction is the amount of change (e.g. substrate broken down or
  product made) per unit of time."""@en ;
  dcterms:modified "2026-06-07T15:30:29.277331Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5554-2
  a curric:KeyLearningPoint ;
  rdfs:label """Enzyme reaction rate increases as substrate concentration increases, until an
  optimum when all active sites are full."""@en ;
  dcterms:modified "2026-06-07T15:30:29.277338Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5554-3
  a curric:KeyLearningPoint ;
  rdfs:label """Enzyme reaction rate increases with temperature due to more collisions, until an
  optimum when all active sites are full."""@en ;
  dcterms:modified "2026-06-07T15:30:29.277342Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5554-4
  a curric:KeyLearningPoint ;
  rdfs:label """Enzyme reaction rate decreases as temperature increases above the optimum, as the
  active site becomes denatured."""@en ;
  dcterms:modified "2026-06-07T15:30:29.277346Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5554-5
  a curric:KeyLearningPoint ;
  rdfs:label """Interpretation of graphs showing effects of substrate concentration and temperature
  on enzyme reaction rate."""@en ;
  dcterms:modified "2026-06-07T15:30:29.277352Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9727-1
  a curric:KeyLearningPoint ;
  rdfs:label "At equilibrium, both reactants and products are formed at the same rate."@en ;
  dcterms:modified "2026-06-07T15:30:29.277356Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9727-2
  a curric:KeyLearningPoint ;
  rdfs:label "Amounts of reactants and products remain constant at equilibrium."@en ;
  dcterms:modified "2026-06-07T15:30:29.277360Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9727-3
  a curric:KeyLearningPoint ;
  rdfs:label "Equilibrium can only occur in a closed system."@en ;
  dcterms:modified "2026-06-07T15:30:29.277363Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5551-1
  a curric:KeyLearningPoint ;
  rdfs:label """A reagent called Benedict’s solution is used to test for reducing sugars, including
  glucose."""@en ;
  dcterms:modified "2026-06-07T15:30:29.277407Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5551-2
  a curric:KeyLearningPoint ;
  rdfs:label """A reagent called iodine solution is used to test for starch, a type of
  carbohydrate."""@en ;
  dcterms:modified "2026-06-07T15:30:29.277415Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5551-3
  a curric:KeyLearningPoint ;
  rdfs:label "A reagent called Biuret solution is used to test for protein."@en ;
  dcterms:modified "2026-06-07T15:30:29.277419Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5551-4
  a curric:KeyLearningPoint ;
  rdfs:label "Ethanol (a type of alcohol) is used to test for lipids."@en ;
  dcterms:modified "2026-06-07T15:30:29.277423Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5551-5
  a curric:KeyLearningPoint ;
  rdfs:label "Interpretation of qualitative food test results."@en ;
  dcterms:modified "2026-06-07T15:30:29.277428Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5039-1
  a curric:KeyLearningPoint ;
  rdfs:label """The p.d. across each branch of a parallel circuit is the same as the p.d. across the
  battery."""@en ;
  dcterms:modified "2026-06-07T15:30:29.277817Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5039-2
  a curric:KeyLearningPoint ;
  rdfs:label """The current through each branch of a parallel circuit adds up to the current through
  the battery."""@en ;
  dcterms:modified "2026-06-07T15:30:29.277821Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5039-3
  a curric:KeyLearningPoint ;
  rdfs:label """Adding a component in a new branch of a parallel circuit reduces the resistance of
  the circuit."""@en ;
  dcterms:modified "2026-06-07T15:30:29.277825Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5039-4
  a curric:KeyLearningPoint ;
  rdfs:label """Adding a component to an existing branch of a parallel circuit increases the
  resistance of the circuit."""@en ;
  dcterms:modified "2026-06-07T15:30:29.277829Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5039-5
  a curric:KeyLearningPoint ;
  rdfs:label """The p.d. across the terminals of a battery does not change when components are added
  to a circuit."""@en ;
  dcterms:modified "2026-06-07T15:30:29.277834Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5059-1
  a curric:KeyLearningPoint ;
  rdfs:label """An LDR is made of a semiconductor, and the brighter the light shining on it, the
  lower its resistance."""@en ;
  dcterms:modified "2026-06-07T15:30:29.278396Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5059-2
  a curric:KeyLearningPoint ;
  rdfs:label """Light transfers energy that enables electrons in a semiconductor to move as they do
  in a metal conductor."""@en ;
  dcterms:modified "2026-06-07T15:30:29.278400Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5059-3
  a curric:KeyLearningPoint ;
  rdfs:label """A thermistor is made of a semiconductor, and the hotter it is, the lower its
  resistance."""@en ;
  dcterms:modified "2026-06-07T15:30:29.278403Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5059-4
  a curric:KeyLearningPoint ;
  rdfs:label """Heating transfers energy that enables electrons in a semiconductor to move as they
  do in a metal conductor."""@en ;
  dcterms:modified "2026-06-07T15:30:29.278409Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5059-5
  a curric:KeyLearningPoint ;
  rdfs:label """A potential divider circuit can be set up with an LDR/thermistor to trigger a switch
  if it becomes too dark or too cold."""@en ;
  dcterms:modified "2026-06-07T15:30:29.278413Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9713-1
  a curric:KeyLearningPoint ;
  rdfs:label "The pH scale ranges from 0 to 14, indicating how acidic or basic a substance is."@en ;
  dcterms:modified "2026-06-07T15:30:29.278432Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9713-2
  a curric:KeyLearningPoint ;
  rdfs:label """Universal indicator provides a full range of colours corresponding to different pH
  levels, and this can be a limitation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.278436Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9713-3
  a curric:KeyLearningPoint ;
  rdfs:label "Phenolphthalein changes from colourless to pink in alkaline conditions."@en ;
  dcterms:modified "2026-06-07T15:30:29.278440Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9713-4
  a curric:KeyLearningPoint ;
  rdfs:label """Methyl orange shifts from red in acidic conditions to yellow in basic
  conditions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.278443Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9713-5
  a curric:KeyLearningPoint ;
  rdfs:label """Litmus paper turns red in acidic conditions and blue in basic conditions, the
  solution will be purple when neutral."""@en ;
  dcterms:modified "2026-06-07T15:30:29.278447Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6293-1
  a curric:KeyLearningPoint ;
  rdfs:label "Quadrats can be used to sample an area to estimate population size (abundance)."@en ;
  dcterms:modified "2026-06-07T15:30:29.278480Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6293-2
  a curric:KeyLearningPoint ;
  rdfs:label "Quadrats are used to sample plants and small, slow-moving animals."@en ;
  dcterms:modified "2026-06-07T15:30:29.278486Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6293-3
  a curric:KeyLearningPoint ;
  rdfs:label "Quadrats can be placed at random to help avoid bias."@en ;
  dcterms:modified "2026-06-07T15:30:29.278490Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6293-4
  a curric:KeyLearningPoint ;
  rdfs:label "Using quadrats to estimate population size (species abundance) in an area."@en ;
  dcterms:modified "2026-06-07T15:30:29.278494Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6293-5
  a curric:KeyLearningPoint ;
  rdfs:label """Using quadrats to investigate the population size of a plant species using random
  sampling."""@en ;
  dcterms:modified "2026-06-07T15:30:29.278498Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5565-1
  a curric:KeyLearningPoint ;
  rdfs:label "The concepts of surface area, volume, and surface area to volume ratio."@en ;
  dcterms:modified "2026-06-07T15:30:29.278502Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5565-2
  a curric:KeyLearningPoint ;
  rdfs:label """Calculation of the surface areas, volumes and surface area to volume ratios of cubes
  of different sizes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.278505Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5565-3
  a curric:KeyLearningPoint ;
  rdfs:label """Use of coloured agar cubes of different sizes to observe time taken for acid to
  diffuse to the centre of each cube."""@en ;
  dcterms:modified "2026-06-07T15:30:29.278509Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5565-4
  a curric:KeyLearningPoint ;
  rdfs:label """Interpretation of results and explanation using ideas about surface area to volume
  ratio and diffusion."""@en ;
  dcterms:modified "2026-06-07T15:30:29.278513Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27910-1
  a curric:KeyLearningPoint ;
  rdfs:label """The pH of water samples can be determined using appropriate methods and/or
  instruments e.g pH meter."""@en ;
  dcterms:modified "2026-06-07T15:30:29.278582Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27910-2
  a curric:KeyLearningPoint ;
  rdfs:label "pH data can be analysed to assess if water contains impurities."@en ;
  dcterms:modified "2026-06-07T15:30:29.278586Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27910-3
  a curric:KeyLearningPoint ;
  rdfs:label "Different substances dissolve in different types of water."@en ;
  dcterms:modified "2026-06-07T15:30:29.278590Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27910-4
  a curric:KeyLearningPoint ;
  rdfs:label """The substances that dissolve in different waters can affect the water's acidity or
  alkalinity (i.e. its pH)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.278594Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27910-5
  a curric:KeyLearningPoint ;
  rdfs:label "Pure water is necessary for laboratory tests; it must be neutral (i.e. pH 7)."@en ;
  dcterms:modified "2026-06-07T15:30:29.278598Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8379-1
  a curric:KeyLearningPoint ;
  rdfs:label """The reaction between sodium thiosulfate solution and hydrochloric acid produces a
  cloudy precipitate."""@en ;
  dcterms:modified "2026-06-07T15:30:29.278905Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8379-2
  a curric:KeyLearningPoint ;
  rdfs:label """At the end point of the disappearing cross experiment, each reaction has produced
  the same amount of product."""@en ;
  dcterms:modified "2026-06-07T15:30:29.278911Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8379-3
  a curric:KeyLearningPoint ;
  rdfs:label """At the end point of the disappearing cross experiment, the chemical reaction may not
  be complete."""@en ;
  dcterms:modified "2026-06-07T15:30:29.278915Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8379-4
  a curric:KeyLearningPoint ;
  rdfs:label """Increasing concentration of a reacting solution introduces more reactant particles,
  so they collide more frequently."""@en ;
  dcterms:modified "2026-06-07T15:30:29.278919Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9717-1
  a curric:KeyLearningPoint ;
  rdfs:label """Neutralisation reactions involve an acid reacting with a base to form salt and
  water."""@en ;
  dcterms:modified "2026-06-07T15:30:29.278992Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9717-2
  a curric:KeyLearningPoint ;
  rdfs:label "Exothermic reactions release energy to the surroundings, often through heating."@en ;
  dcterms:modified "2026-06-07T15:30:29.278996Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9717-3
  a curric:KeyLearningPoint ;
  rdfs:label "Methods must be detailed and replicable for reliable data collection."@en ;
  dcterms:modified "2026-06-07T15:30:29.279000Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9717-4
  a curric:KeyLearningPoint ;
  rdfs:label """The initial and final temperatures of the reaction mixture need to be recorded to
  calculate energy change."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279003Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9717-5
  a curric:KeyLearningPoint ;
  rdfs:label """Line graphs can illustrate relationships between continuous variables in
  experiments."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279007Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5542-1
  a curric:KeyLearningPoint ;
  rdfs:label """Some factors affect human reaction time (e.g. the time taken to catch a ruler after
  it is dropped)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279011Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5542-2
  a curric:KeyLearningPoint ;
  rdfs:label """Writing a testable prediction or hypothesis about the effect of a factor on human
  reaction time."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279014Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5542-3
  a curric:KeyLearningPoint ;
  rdfs:label """Identifying independent and dependent variables, range of values to test, and which
  factors to control and how."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279018Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5542-4
  a curric:KeyLearningPoint ;
  rdfs:label "Safe use of apparatus, and safe and ethical use of human test subjects."@en ;
  dcterms:modified "2026-06-07T15:30:29.279022Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5542-5
  a curric:KeyLearningPoint ;
  rdfs:label "Interpret data from measurements of human reaction time."@en ;
  dcterms:modified "2026-06-07T15:30:29.279025Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6615-1
  a curric:KeyLearningPoint ;
  rdfs:label """Refraction is when waves travel from one transparent medium to another, causing a
  change in direction."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279043Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6615-2
  a curric:KeyLearningPoint ;
  rdfs:label """When waves slow down, they turn towards the normal line (angle of incidence > angle
  of refraction)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279047Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6615-3
  a curric:KeyLearningPoint ;
  rdfs:label """When waves speed up, they turn away from the normal line (angle of incidence < angle
  of refraction)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279053Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6615-4
  a curric:KeyLearningPoint ;
  rdfs:label """Refraction can be investigated using a clear rectangular block, ray box and narrow
  slit, pencil, paper and a protractor."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279057Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6615-5
  a curric:KeyLearningPoint ;
  rdfs:label "The greater the angle of incidence, the greater the angle of refraction."@en ;
  dcterms:modified "2026-06-07T15:30:29.279063Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8155-1
  a curric:KeyLearningPoint ;
  rdfs:label "Density is calculated using the equation: density = mass ÷ volume."@en ;
  dcterms:modified "2026-06-07T15:30:29.279101Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8155-2
  a curric:KeyLearningPoint ;
  rdfs:label """The volume of water displaced by a submerged object is equal to the volume of the
  object."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279104Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8155-3
  a curric:KeyLearningPoint ;
  rdfs:label """The dimensions of a regular cuboid can be measured accurately with Vernier
  callipers."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279108Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8155-4
  a curric:KeyLearningPoint ;
  rdfs:label """The volume of a regular cuboid is calculated using the equation: volume = length ×
  width × height."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279114Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5035-1
  a curric:KeyLearningPoint ;
  rdfs:label "Two unlike electric charges attract each other."@en ;
  dcterms:modified "2026-06-07T15:30:29.280301Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5035-2
  a curric:KeyLearningPoint ;
  rdfs:label "Two like electric charges repel each other."@en ;
  dcterms:modified "2026-06-07T15:30:29.280305Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5035-3
  a curric:KeyLearningPoint ;
  rdfs:label """In an electric circuit, electrons are forced towards the positive terminal of a
  battery."""@en ;
  dcterms:modified "2026-06-07T15:30:29.280309Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5035-4
  a curric:KeyLearningPoint ;
  rdfs:label """Electric current is the amount of charge that passes a point in a circuit in each
  second."""@en ;
  dcterms:modified "2026-06-07T15:30:29.280313Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5035-5
  a curric:KeyLearningPoint ;
  rdfs:label "Current can be found using the equation: current = charge ÷ time."@en ;
  dcterms:modified "2026-06-07T15:30:29.280316Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27587-1
  a curric:KeyLearningPoint ;
  rdfs:label """Sublimation is the change from solid to gas; deposition is the change from gas to
  solid, both bypass the liquid state."""@en ;
  dcterms:modified "2026-06-07T15:30:29.280800Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27587-2
  a curric:KeyLearningPoint ;
  rdfs:label """Sublimation and deposition occur at specific conditions of temperature and
  pressure."""@en ;
  dcterms:modified "2026-06-07T15:30:29.280806Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27587-3
  a curric:KeyLearningPoint ;
  rdfs:label """Energy changes in sublimation/deposition are similar to melting/freezing but happen
  directly between solid and gas."""@en ;
  dcterms:modified "2026-06-07T15:30:29.280810Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27587-4
  a curric:KeyLearningPoint ;
  rdfs:label """Evaporation is when a liquid changes to gas at the surface as particles gain enough
  energy to overcome forces."""@en ;
  dcterms:modified "2026-06-07T15:30:29.280814Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9645-1
  a curric:KeyLearningPoint ;
  rdfs:label "Chromatograms can identify unknown substances through comparison or Rf values."@en ;
  dcterms:modified "2026-06-07T15:30:29.281885Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9645-2
  a curric:KeyLearningPoint ;
  rdfs:label """Appropriate equipment should be used during comparisons, and calculations should
  consider significant figures."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281889Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9645-3
  a curric:KeyLearningPoint ;
  rdfs:label """A fair comparison of chromatograms depends on stationary and mobile phase choices,
  sample concentration and temperature."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281893Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9645-4
  a curric:KeyLearningPoint ;
  rdfs:label "Chromatograms can be used to identify pure and impure substances."@en ;
  dcterms:modified "2026-06-07T15:30:29.281897Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5058-1
  a curric:KeyLearningPoint ;
  rdfs:label """The p.d. across a component in an electric circuit measures the size of push that is
  moving current through it."""@en ;
  dcterms:modified "2026-06-07T15:30:29.283080Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5058-2
  a curric:KeyLearningPoint ;
  rdfs:label """The p.d. across each component in a series circuit adds up to the p.d. across the
  battery."""@en ;
  dcterms:modified "2026-06-07T15:30:29.283084Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5058-3
  a curric:KeyLearningPoint ;
  rdfs:label "The current is the same through every component in a series circuit."@en ;
  dcterms:modified "2026-06-07T15:30:29.283090Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5058-4
  a curric:KeyLearningPoint ;
  rdfs:label """The larger the total resistance of a series circuit, the smaller the current through
  it."""@en ;
  dcterms:modified "2026-06-07T15:30:29.283096Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5058-5
  a curric:KeyLearningPoint ;
  rdfs:label """In a series circuit, the share of p.d. across each component is proportional to its
  resistance."""@en ;
  dcterms:modified "2026-06-07T15:30:29.283100Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4727-1
  a curric:KeyLearningPoint ;
  rdfs:label """A dynamics trolley speeds up (accelerates) along the whole length of a steep
  ramp."""@en ;
  dcterms:modified "2026-06-07T15:30:29.283104Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4727-2
  a curric:KeyLearningPoint ;
  rdfs:label "Instantaneous speed is the average speed over a very short time period."@en ;
  dcterms:modified "2026-06-07T15:30:29.283108Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4727-3
  a curric:KeyLearningPoint ;
  rdfs:label """Instantaneous speed can be estimated by measuring movement in a small time
  period."""@en ;
  dcterms:modified "2026-06-07T15:30:29.283111Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4727-4
  a curric:KeyLearningPoint ;
  rdfs:label """Anomalous readings should be repeated and replaced or removed from sets of repeat
  readings."""@en ;
  dcterms:modified "2026-06-07T15:30:29.283115Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4729-1
  a curric:KeyLearningPoint ;
  rdfs:label "The velocity of an object is equal to the gradient of a displacement-time graph."@en ;
  dcterms:modified "2026-06-07T15:30:29.283119Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4729-2
  a curric:KeyLearningPoint ;
  rdfs:label "A direction in which velocity and displacement are measured needs to be chosen."@en ;
  dcterms:modified "2026-06-07T15:30:29.283123Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4729-3
  a curric:KeyLearningPoint ;
  rdfs:label """A negative gradient on a displacement-time graph (sloping downwards) represents
  velocity in the opposite direction."""@en ;
  dcterms:modified "2026-06-07T15:30:29.283126Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4729-4
  a curric:KeyLearningPoint ;
  rdfs:label """A negative value for displacement represents a position ‘behind’ the starting
  position."""@en ;
  dcterms:modified "2026-06-07T15:30:29.283132Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9123-1
  a curric:KeyLearningPoint ;
  rdfs:label """In a fair test, only the independent variable is changed so that no other changes
  could affect the results."""@en ;
  dcterms:modified "2026-06-07T15:30:29.283889Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9123-2
  a curric:KeyLearningPoint ;
  rdfs:label "The variables that are deliberately kept the same are called control variables."@en ;
  dcterms:modified "2026-06-07T15:30:29.283893Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9123-3
  a curric:KeyLearningPoint ;
  rdfs:label "A lid on a beaker prevents transfer of energy by convection currents."@en ;
  dcterms:modified "2026-06-07T15:30:29.283897Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9123-4
  a curric:KeyLearningPoint ;
  rdfs:label "Gas is a very poor thermal conductor."@en ;
  dcterms:modified "2026-06-07T15:30:29.283900Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6606-1
  a curric:KeyLearningPoint ;
  rdfs:label """The properties of a diode are different, depending on the direction of p.d. across
  it."""@en ;
  dcterms:modified "2026-06-07T15:30:29.284083Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6606-2
  a curric:KeyLearningPoint ;
  rdfs:label """An appropriate range of p.d. includes 0 V and the maximum voltage of the diode and
  at least four other readings."""@en ;
  dcterms:modified "2026-06-07T15:30:29.284087Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6606-3
  a curric:KeyLearningPoint ;
  rdfs:label """An appropriate range for a diode includes the maximum p.d. in both directions, with
  positive and negative values."""@en ;
  dcterms:modified "2026-06-07T15:30:29.284090Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6606-4
  a curric:KeyLearningPoint ;
  rdfs:label """For electricity investigations, it is good practice to take many more than the
  minimum number of measurements."""@en ;
  dcterms:modified "2026-06-07T15:30:29.284094Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6601-1
  a curric:KeyLearningPoint ;
  rdfs:label "Frequency of a wave can be measured indirectly from its speed and wavelength."@en ;
  dcterms:modified "2026-06-07T15:30:29.284098Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6601-2
  a curric:KeyLearningPoint ;
  rdfs:label """Wavelength of a wave can be measured by using a freeze frame of a wave moving along
  the length of a ruler."""@en ;
  dcterms:modified "2026-06-07T15:30:29.284102Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6601-3
  a curric:KeyLearningPoint ;
  rdfs:label """It is more accurate to measure the length of, e.g. ten waves and dividing by ten,
  than measuring one wavelength."""@en ;
  dcterms:modified "2026-06-07T15:30:29.284105Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6601-4
  a curric:KeyLearningPoint ;
  rdfs:label """Speed of a wave can be measured by recording the wave moving along a ruler with a
  timer in the frame."""@en ;
  dcterms:modified "2026-06-07T15:30:29.284109Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6601-5
  a curric:KeyLearningPoint ;
  rdfs:label """Accurate distance and time are measured by freezing the film, played back in slow
  motion, to track one wave crest."""@en ;
  dcterms:modified "2026-06-07T15:30:29.284112Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8154-1
  a curric:KeyLearningPoint ;
  rdfs:label """Particles in a gas move very quickly in random directions and have empty space
  between them."""@en ;
  dcterms:modified "2026-06-07T15:30:29.284116Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8154-2
  a curric:KeyLearningPoint ;
  rdfs:label """Heating a fluid increases the speed of particles and they push each other further
  apart."""@en ;
  dcterms:modified "2026-06-07T15:30:29.284120Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8154-3
  a curric:KeyLearningPoint ;
  rdfs:label "As a fluid is heated, it becomes less dense."@en ;
  dcterms:modified "2026-06-07T15:30:29.284124Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8154-4
  a curric:KeyLearningPoint ;
  rdfs:label "Hotter fluid rises through cooler fluid because it is less dense."@en ;
  dcterms:modified "2026-06-07T15:30:29.284129Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5600-1
  a curric:KeyLearningPoint ;
  rdfs:label """Effect of temperature on aerobic cellular respiration investigated in small living
  organisms (e.g. germinating peas)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.284698Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5600-2
  a curric:KeyLearningPoint ;
  rdfs:label """The oxygen used by the respiring organisms in a set time can be measured using a
  simple respirometer."""@en ;
  dcterms:modified "2026-06-07T15:30:29.284704Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5600-3
  a curric:KeyLearningPoint ;
  rdfs:label """Identifying independent and dependent variables, and variables to control to
  increase the validity of the results."""@en ;
  dcterms:modified "2026-06-07T15:30:29.284708Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5600-4
  a curric:KeyLearningPoint ;
  rdfs:label """The height of coloured liquid in the capillary tube of the respirometer is measured
  at the start & end of the set time."""@en ;
  dcterms:modified "2026-06-07T15:30:29.284712Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5600-5
  a curric:KeyLearningPoint ;
  rdfs:label """Collecting repeat measurements at each temperature, and collecting data at different
  temperatures."""@en ;
  dcterms:modified "2026-06-07T15:30:29.284715Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5601-1
  a curric:KeyLearningPoint ;
  rdfs:label """Living yeast cells immobilised in alginate beads will carry out cellular respiration
  and produce carbon dioxide gas."""@en ;
  dcterms:modified "2026-06-07T15:30:29.284996Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5601-2
  a curric:KeyLearningPoint ;
  rdfs:label """The gas can be collected and the volume of gas measured using an upturned measuring
  cylinder under water."""@en ;
  dcterms:modified "2026-06-07T15:30:29.285000Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5601-3
  a curric:KeyLearningPoint ;
  rdfs:label """Identifying independent and dependent variables, and variables to control to
  increase the validity of the results."""@en ;
  dcterms:modified "2026-06-07T15:30:29.285004Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5601-4
  a curric:KeyLearningPoint ;
  rdfs:label """How to read the volume of gas from the meniscus in the measuring cylinder after a
  set time."""@en ;
  dcterms:modified "2026-06-07T15:30:29.285009Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5601-5
  a curric:KeyLearningPoint ;
  rdfs:label """Collecting repeat measurements for each substrate, and collecting data for different
  substrates."""@en ;
  dcterms:modified "2026-06-07T15:30:29.285013Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9678-1
  a curric:KeyLearningPoint ;
  rdfs:label """In a titration, a trial investigation helps estimate the amount of acid needed to
  neutralise the alkali."""@en ;
  dcterms:modified "2026-06-07T15:30:29.285087Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9678-2
  a curric:KeyLearningPoint ;
  rdfs:label """Near the end point, add the acid drop by drop whilst swirling the solution in the
  conical flask to mix."""@en ;
  dcterms:modified "2026-06-07T15:30:29.285090Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9678-3
  a curric:KeyLearningPoint ;
  rdfs:label """Placing a white tile under the conical flask enhances the visibility of the colour
  change and accuracy of readings."""@en ;
  dcterms:modified "2026-06-07T15:30:29.285094Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9678-4
  a curric:KeyLearningPoint ;
  rdfs:label "Volume readings should be taken at eye level from the bottom of the meniscus."@en ;
  dcterms:modified "2026-06-07T15:30:29.285098Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9678-5
  a curric:KeyLearningPoint ;
  rdfs:label "Concordant titres are typically within ±0.10 cm³."@en ;
  dcterms:modified "2026-06-07T15:30:29.285101Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9647-1
  a curric:KeyLearningPoint ;
  rdfs:label """Appropriate equipment should be used to separate substances in a mixture of
  inks."""@en ;
  dcterms:modified "2026-06-07T15:30:29.285510Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9647-2
  a curric:KeyLearningPoint ;
  rdfs:label "Inks are a mixture of substances that can be separated using distillation."@en ;
  dcterms:modified "2026-06-07T15:30:29.285514Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9647-3
  a curric:KeyLearningPoint ;
  rdfs:label "Care should be taken when heating substances to their boiling points."@en ;
  dcterms:modified "2026-06-07T15:30:29.285519Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9647-4
  a curric:KeyLearningPoint ;
  rdfs:label "Simple distillation completed in the school lab has limitations."@en ;
  dcterms:modified "2026-06-07T15:30:29.285525Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8375-1
  a curric:KeyLearningPoint ;
  rdfs:label """The changing rate of a reaction can be found by measuring the mass of gas produced
  as the reaction progresses."""@en ;
  dcterms:modified "2026-06-07T15:30:29.285696Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8375-2
  a curric:KeyLearningPoint ;
  rdfs:label """Smaller marble chips have a larger surface area than larger chips of the
  same mass."""@en ;
  dcterms:modified "2026-06-07T15:30:29.285704Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8375-3
  a curric:KeyLearningPoint ;
  rdfs:label "The larger the surface area, the faster the rate of reaction."@en ;
  dcterms:modified "2026-06-07T15:30:29.285725Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5556-1
  a curric:KeyLearningPoint ;
  rdfs:label "Safe use of materials and apparatus."@en ;
  dcterms:modified "2026-06-07T15:30:29.286258Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5556-2
  a curric:KeyLearningPoint ;
  rdfs:label "Accurate measurement of reactants and reagents."@en ;
  dcterms:modified "2026-06-07T15:30:29.286262Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5556-3
  a curric:KeyLearningPoint ;
  rdfs:label "Control of temperature using a water bath or electric heater."@en ;
  dcterms:modified "2026-06-07T15:30:29.286266Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5556-4
  a curric:KeyLearningPoint ;
  rdfs:label """Continuous sampling of reaction mixture and testing with iodine for the presence of
  starch."""@en ;
  dcterms:modified "2026-06-07T15:30:29.286270Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5556-5
  a curric:KeyLearningPoint ;
  rdfs:label "Sampling at accurately timed intervals."@en ;
  dcterms:modified "2026-06-07T15:30:29.286275Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8324-1
  a curric:KeyLearningPoint ;
  rdfs:label """Positive ions burn with distinct colours that are visible when heated above a blue
  Bunsen flame."""@en ;
  dcterms:modified "2026-06-07T15:30:29.286279Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8324-2
  a curric:KeyLearningPoint ;
  rdfs:label "Unique flame emission spectra are produced for each positive metal ion."@en ;
  dcterms:modified "2026-06-07T15:30:29.286283Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8324-3
  a curric:KeyLearningPoint ;
  rdfs:label """Instrumental methods are accurate, sensitive, and rapid for detecting and
  identifying elements and compounds."""@en ;
  dcterms:modified "2026-06-07T15:30:29.286287Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8324-4
  a curric:KeyLearningPoint ;
  rdfs:label "A spectrometer can split light from coloured flames into flame emission spectra."@en ;
  dcterms:modified "2026-06-07T15:30:29.286291Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8324-5
  a curric:KeyLearningPoint ;
  rdfs:label """A spectrometer can measure more than one metal ion in a single solution and the
  concentration of each."""@en ;
  dcterms:modified "2026-06-07T15:30:29.286295Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8420-1
  a curric:KeyLearningPoint ;
  rdfs:label """Ammonia can be synthesised in the lab by heating a mixture of NH₄Cl and NaOH,
  producing NH₃ gas and other by-products."""@en ;
  dcterms:modified "2026-06-07T15:30:29.286298Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8420-2
  a curric:KeyLearningPoint ;
  rdfs:label """Ammonia is an alkaline gas that reacts readily with water to form a corrosive, basic
  solution."""@en ;
  dcterms:modified "2026-06-07T15:30:29.286302Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8420-3
  a curric:KeyLearningPoint ;
  rdfs:label "Ammonia gas turns moist red litmus paper blue, indicating its alkaline nature."@en ;
  dcterms:modified "2026-06-07T15:30:29.286306Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8420-4
  a curric:KeyLearningPoint ;
  rdfs:label """Ammonia gas is soluble, toxic, and has a pungent smell, requiring careful
  handling."""@en ;
  dcterms:modified "2026-06-07T15:30:29.286310Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8420-5
  a curric:KeyLearningPoint ;
  rdfs:label """Ammonia reacts with hydrogen chloride (from concentrated hydrochloric acid) to form
  white fumes of ammonium chloride."""@en ;
  dcterms:modified "2026-06-07T15:30:29.286315Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8377-1
  a curric:KeyLearningPoint ;
  rdfs:label """The changing rate of a reaction can be found by measuring the amount of gas produced
  as the reaction progresses."""@en ;
  dcterms:modified "2026-06-07T15:30:29.287404Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8377-2
  a curric:KeyLearningPoint ;
  rdfs:label """Increasing concentration of a reacting solution introduces more reactant particles,
  so they collide more frequently."""@en ;
  dcterms:modified "2026-06-07T15:30:29.287408Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8377-3
  a curric:KeyLearningPoint ;
  rdfs:label """When reacting excess acid with equal amounts of magnesium, the same volume is
  produced for all concentrations of acid."""@en ;
  dcterms:modified "2026-06-07T15:30:29.287413Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6604-1
  a curric:KeyLearningPoint ;
  rdfs:label """Energy transferred to increase the temperature of a substance by heating by a fixed
  amount is proportional to mass."""@en ;
  dcterms:modified "2026-06-07T15:30:29.287546Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6604-2
  a curric:KeyLearningPoint ;
  rdfs:label """Energy transferred to a substance by heating a fixed amount is proportional to the
  increase in temperature."""@en ;
  dcterms:modified "2026-06-07T15:30:29.287550Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6604-3
  a curric:KeyLearningPoint ;
  rdfs:label """Energy transferred to increase the temperature of a substance by heating is
  proportional to its specific heat capacity."""@en ;
  dcterms:modified "2026-06-07T15:30:29.287554Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6604-4
  a curric:KeyLearningPoint ;
  rdfs:label """Specific heat capacity equals the energy transferred to/by 1 kg of a material when
  its temperature changes by 1ºC."""@en ;
  dcterms:modified "2026-06-07T15:30:29.287559Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6604-5
  a curric:KeyLearningPoint ;
  rdfs:label """Specific heat capacity, c, is measured in joules per kilogram per degree Celsius
  (J/kg ºC)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.287563Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9673-1
  a curric:KeyLearningPoint ;
  rdfs:label """There are a list of general rules which describe the solubility of common types of
  substances in water."""@en ;
  dcterms:modified "2026-06-07T15:30:29.287607Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9673-2
  a curric:KeyLearningPoint ;
  rdfs:label """Reactions that form insoluble products are called precipitation reactions; the
  solids formed are called the precipitate."""@en ;
  dcterms:modified "2026-06-07T15:30:29.287611Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9673-3
  a curric:KeyLearningPoint ;
  rdfs:label """When two soluble salts are mixed together, sometimes they will rearrange to create
  an insoluble salt."""@en ;
  dcterms:modified "2026-06-07T15:30:29.287615Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9673-4
  a curric:KeyLearningPoint ;
  rdfs:label """Solubility rules can be used to identify which two solutions are needed to mix in
  order to create an insoluble salt."""@en ;
  dcterms:modified "2026-06-07T15:30:29.287618Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27996-1
  a curric:KeyLearningPoint ;
  rdfs:label """Following an appropriate method to vary light intensity and measure the colour
  change of indicator."""@en ;
  dcterms:modified "2026-06-07T15:30:29.288871Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27996-2
  a curric:KeyLearningPoint ;
  rdfs:label """Accurate measurement of variables (distance, time, colour change); control of
  variables that might affect the results."""@en ;
  dcterms:modified "2026-06-07T15:30:29.288877Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27996-3
  a curric:KeyLearningPoint ;
  rdfs:label "Comparison of indicator colour to a chart to determine pH."@en ;
  dcterms:modified "2026-06-07T15:30:29.288881Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27996-4
  a curric:KeyLearningPoint ;
  rdfs:label "Record results in an appropriate table."@en ;
  dcterms:modified "2026-06-07T15:30:29.288885Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9729-1
  a curric:KeyLearningPoint ;
  rdfs:label """Different types of arrows (→, ⇌) are used in chemical equations to indicate the
  nature of the reaction."""@en ;
  dcterms:modified "2026-06-07T15:30:29.288904Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9729-2
  a curric:KeyLearningPoint ;
  rdfs:label """Reversible reactions are symbolised using the double-headed arrow (⇌) in chemical
  equations."""@en ;
  dcterms:modified "2026-06-07T15:30:29.288908Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9729-3
  a curric:KeyLearningPoint ;
  rdfs:label """In a reversible reaction, both the forward and reverse reactions can occur under the
  right conditions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.288911Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9729-4
  a curric:KeyLearningPoint ;
  rdfs:label "hydrated copper sulfate (blue) ⇌ anhydrous copper sulfate (white) + water"@en ;
  dcterms:modified "2026-06-07T15:30:29.288915Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9729-5
  a curric:KeyLearningPoint ;
  rdfs:label "ammonium chloride ⇌ ammonia + hydrogen chloride"@en ;
  dcterms:modified "2026-06-07T15:30:29.288919Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9905-1
  a curric:KeyLearningPoint ;
  rdfs:label "A displacement–time graph shows how displacement changes with time."@en ;
  dcterms:modified "2026-06-07T15:30:29.291511Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9905-2
  a curric:KeyLearningPoint ;
  rdfs:label "A velocity–time graph shows how velocity changes with time."@en ;
  dcterms:modified "2026-06-07T15:30:29.291517Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9905-3
  a curric:KeyLearningPoint ;
  rdfs:label """Displacement–time and velocity–time graphs of the same motion have different
  shapes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.291522Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9905-4
  a curric:KeyLearningPoint ;
  rdfs:label "Acceleration is equal to the gradient of a velocity–time graph."@en ;
  dcterms:modified "2026-06-07T15:30:29.291526Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9905-5
  a curric:KeyLearningPoint ;
  rdfs:label """A falling line shows deceleration (decreasing velocity) which is a negative
  acceleration."""@en ;
  dcterms:modified "2026-06-07T15:30:29.291530Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9890-1
  a curric:KeyLearningPoint ;
  rdfs:label """A dynamics trolley speeds up (accelerates) along the whole length of a steep
  ramp."""@en ;
  dcterms:modified "2026-06-07T15:30:29.291655Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9890-2
  a curric:KeyLearningPoint ;
  rdfs:label "Instantaneous speed is the average speed over a very short time period."@en ;
  dcterms:modified "2026-06-07T15:30:29.291659Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9890-3
  a curric:KeyLearningPoint ;
  rdfs:label """Instantaneous speed can be estimated by measuring movement in a small time
  period."""@en ;
  dcterms:modified "2026-06-07T15:30:29.291663Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9890-4
  a curric:KeyLearningPoint ;
  rdfs:label """Anomalous readings should be repeated and replaced or removed from sets of repeat
  readings."""@en ;
  dcterms:modified "2026-06-07T15:30:29.291667Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8321-1
  a curric:KeyLearningPoint ;
  rdfs:label """A 'pure substance' in chemistry is a single element or compound not mixed with any
  other substance."""@en ;
  dcterms:modified "2026-06-07T15:30:29.292079Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8321-2
  a curric:KeyLearningPoint ;
  rdfs:label "The definition of 'pure' means something different in its everyday usage."@en ;
  dcterms:modified "2026-06-07T15:30:29.292085Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8321-3
  a curric:KeyLearningPoint ;
  rdfs:label "Pure elements and compounds have specific melting and boiling points."@en ;
  dcterms:modified "2026-06-07T15:30:29.292089Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8321-4
  a curric:KeyLearningPoint ;
  rdfs:label """Melting point data can be used to recognise substances with specific melting points
  as pure substances."""@en ;
  dcterms:modified "2026-06-07T15:30:29.292093Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9127-1
  a curric:KeyLearningPoint ;
  rdfs:label "A wire heats up when a current flows and its temperature will vary over time."@en ;
  dcterms:modified "2026-06-07T15:30:29.292546Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9127-2
  a curric:KeyLearningPoint ;
  rdfs:label "A water bath helps to keep the temperature of a wire constant."@en ;
  dcterms:modified "2026-06-07T15:30:29.292553Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9127-3
  a curric:KeyLearningPoint ;
  rdfs:label "Turning a circuit on for a very short time reduces the heating effect in a wire."@en ;
  dcterms:modified "2026-06-07T15:30:29.292557Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9127-4
  a curric:KeyLearningPoint ;
  rdfs:label """In electricity investigations, it is often easy to take lots of readings rather than
  a few, repeated readings."""@en ;
  dcterms:modified "2026-06-07T15:30:29.292561Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9127-5
  a curric:KeyLearningPoint ;
  rdfs:label """The resistance of a wire is directly proportional to its length, at a constant
  temperature."""@en ;
  dcterms:modified "2026-06-07T15:30:29.292565Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6612-1
  a curric:KeyLearningPoint ;
  rdfs:label """A soft iron core increases the strength of an electromagnet because it becomes
  magnetised when it is turned on."""@en ;
  dcterms:modified "2026-06-07T15:30:29.294486Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6612-2
  a curric:KeyLearningPoint ;
  rdfs:label """The more tightly wound the coil of wire is in an electromagnet, the stronger its
  magnetic field."""@en ;
  dcterms:modified "2026-06-07T15:30:29.294490Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6612-3
  a curric:KeyLearningPoint ;
  rdfs:label """The greater the current through the coil of an electromagnet, the stronger its
  magnetic field."""@en ;
  dcterms:modified "2026-06-07T15:30:29.294494Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6612-4
  a curric:KeyLearningPoint ;
  rdfs:label """The strength of an electromagnet is directly proportional to the current
  through it."""@en ;
  dcterms:modified "2026-06-07T15:30:29.294498Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4910-1
  a curric:KeyLearningPoint ;
  rdfs:label "Energy cannot be created or destroyed."@en ;
  dcterms:modified "2026-06-07T15:30:29.295025Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4910-2
  a curric:KeyLearningPoint ;
  rdfs:label "In an ideal situation, no energy is dissipated."@en ;
  dcterms:modified "2026-06-07T15:30:29.295029Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4910-3
  a curric:KeyLearningPoint ;
  rdfs:label """As an object changes height, change in gravitational potential energy = change in
  kinetic energy."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295033Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9744-1
  a curric:KeyLearningPoint ;
  rdfs:label """Some metal ions form coloured precipitates in a reaction with sodium hydroxide
  solution."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295195Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9744-2
  a curric:KeyLearningPoint ;
  rdfs:label """Ammonium ions can be identified by heating with NaOH and using damp red litmus
  paper, which turns blue if positive."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295199Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9744-3
  a curric:KeyLearningPoint ;
  rdfs:label """A dilute acid is usually added before testing for carbonates, sulfates or halides to
  avoid false positives."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295205Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9744-4
  a curric:KeyLearningPoint ;
  rdfs:label """Halide ions produce different coloured precipitates when silver nitrate is added to
  a solution containing them."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295209Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9744-5
  a curric:KeyLearningPoint ;
  rdfs:label """A white precipitate is formed when barium chloride is added to an acidified solution
  containing sulfate ions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295213Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9743-1
  a curric:KeyLearningPoint ;
  rdfs:label """Positive ions burn with distinct colours that are visible when heated above a blue
  Bunsen flame."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295880Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9743-2
  a curric:KeyLearningPoint ;
  rdfs:label """Instrumental methods are accurate, sensitive, and rapid for detecting and
  identifying elements and compounds."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295884Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9743-3
  a curric:KeyLearningPoint ;
  rdfs:label "Unique flame emission spectra are produced for each positive metal ion."@en ;
  dcterms:modified "2026-06-07T15:30:29.295888Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9743-4
  a curric:KeyLearningPoint ;
  rdfs:label "A spectrometer can split light from coloured flames into flame emission spectra."@en ;
  dcterms:modified "2026-06-07T15:30:29.295892Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9743-5
  a curric:KeyLearningPoint ;
  rdfs:label """A spectrometer can measure more than one metal ion in a single solution and the
  concentration of each."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295896Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8400-1
  a curric:KeyLearningPoint ;
  rdfs:label "The pH of rain water is naturally below 7."@en ;
  dcterms:modified "2026-06-07T15:30:29.296655Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8400-2
  a curric:KeyLearningPoint ;
  rdfs:label """Chemical reactions between certain pollutants and water in the atmosphere may cause
  a decrease in the pH of rainwater."""@en ;
  dcterms:modified "2026-06-07T15:30:29.296659Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8400-3
  a curric:KeyLearningPoint ;
  rdfs:label """Acid rain is not as acidic as vinegar or citric acid that is found in lemons and
  oranges."""@en ;
  dcterms:modified "2026-06-07T15:30:29.296665Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8400-4
  a curric:KeyLearningPoint ;
  rdfs:label """Acid rain chemically reacts with carbonates that form many rocks to produce a salt,
  water and carbon dioxide."""@en ;
  dcterms:modified "2026-06-07T15:30:29.296670Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8400-5
  a curric:KeyLearningPoint ;
  rdfs:label "Acid rain can have long term effects on habitats and ecosystems."@en ;
  dcterms:modified "2026-06-07T15:30:29.296674Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9716-1
  a curric:KeyLearningPoint ;
  rdfs:label """Displacement reactions involve a more reactive element replacing another in a
  compound."""@en ;
  dcterms:modified "2026-06-07T15:30:29.296733Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9716-2
  a curric:KeyLearningPoint ;
  rdfs:label "Exothermic reactions release energy to the surroundings, often through heating."@en ;
  dcterms:modified "2026-06-07T15:30:29.296739Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9716-3
  a curric:KeyLearningPoint ;
  rdfs:label """The initial and final temperatures of the reaction mixture need to be recorded to
  calculate energy change."""@en ;
  dcterms:modified "2026-06-07T15:30:29.296743Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9716-4
  a curric:KeyLearningPoint ;
  rdfs:label "Hypotheses guide predictions about the effect of variables in experiments."@en ;
  dcterms:modified "2026-06-07T15:30:29.296747Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9716-5
  a curric:KeyLearningPoint ;
  rdfs:label "Bar charts can visually represent collected results to help analyse data."@en ;
  dcterms:modified "2026-06-07T15:30:29.296751Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9709-1
  a curric:KeyLearningPoint ;
  rdfs:label "Halogens can be dissolved in water to form acidic solutions."@en ;
  dcterms:modified "2026-06-07T15:30:29.296755Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9709-2
  a curric:KeyLearningPoint ;
  rdfs:label "A more reactive halogen can displace a less reactive one from a compound."@en ;
  dcterms:modified "2026-06-07T15:30:29.296761Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9709-3
  a curric:KeyLearningPoint ;
  rdfs:label "Group 7 elements react with Group 1 and 2 metals to form salts."@en ;
  dcterms:modified "2026-06-07T15:30:29.296765Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9709-4
  a curric:KeyLearningPoint ;
  rdfs:label """The chemical test for chlorine involves passing the gas over damp blue
  litmus paper."""@en ;
  dcterms:modified "2026-06-07T15:30:29.296770Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9653-1
  a curric:KeyLearningPoint ;
  rdfs:label """Data can be analysed to assess the purity of water samples containing dissolved
  solids."""@en ;
  dcterms:modified "2026-06-07T15:30:29.298759Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9653-2
  a curric:KeyLearningPoint ;
  rdfs:label "Evaporation set-ups can be used to collect dissolved solids from a water sample."@en ;
  dcterms:modified "2026-06-07T15:30:29.298765Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4917-1
  a curric:KeyLearningPoint ;
  rdfs:label """Stopping distance is the distance travelled, both as a driver reacts and as the
  brakes to bring a vehicle to a stop."""@en ;
  dcterms:modified "2026-06-07T15:30:29.303658Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4917-2
  a curric:KeyLearningPoint ;
  rdfs:label """The reaction time of a driver can be affected by tiredness, drugs, alcohol or
  distractions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.303662Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4917-3
  a curric:KeyLearningPoint ;
  rdfs:label """The braking distance can be affected by adverse road and weather conditions and the
  condition of the vehicle."""@en ;
  dcterms:modified "2026-06-07T15:30:29.303666Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4917-4
  a curric:KeyLearningPoint ;
  rdfs:label "When braking, work is done on the brakes that heats them up."@en ;
  dcterms:modified "2026-06-07T15:30:29.303673Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4917-5
  a curric:KeyLearningPoint ;
  rdfs:label """If brakes overheat they can stop working effectively and lead to a loss of
  control."""@en ;
  dcterms:modified "2026-06-07T15:30:29.303678Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27911-1
  a curric:KeyLearningPoint ;
  rdfs:label """Unique tests for each substance help minimise errors and ensure correct
  identification."""@en ;
  dcterms:modified "2026-06-07T15:30:29.303964Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27911-2
  a curric:KeyLearningPoint ;
  rdfs:label "Gas tests can be used to identify carbon dioxide, oxygen, hydrogen and ammonia."@en ;
  dcterms:modified "2026-06-07T15:30:29.303968Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27911-3
  a curric:KeyLearningPoint ;
  rdfs:label """Observations and results should be recorded accurately for analysis during the
  practical."""@en ;
  dcterms:modified "2026-06-07T15:30:29.303972Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27911-4
  a curric:KeyLearningPoint ;
  rdfs:label """Flow charts break down complex activities into ordered sets of simpler steps,
  crucial for efficient ion identification."""@en ;
  dcterms:modified "2026-06-07T15:30:29.303976Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9684-1
  a curric:KeyLearningPoint ;
  rdfs:label "There are three different types of bonding (covalent, ionic, metallic)."@en ;
  dcterms:modified "2026-06-07T15:30:29.304071Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9684-2
  a curric:KeyLearningPoint ;
  rdfs:label "There are only two types of structure (simple and giant)."@en ;
  dcterms:modified "2026-06-07T15:30:29.304075Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9684-3
  a curric:KeyLearningPoint ;
  rdfs:label "The type of bonding and structure are what lead to properties of substances."@en ;
  dcterms:modified "2026-06-07T15:30:29.304079Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9684-4
  a curric:KeyLearningPoint ;
  rdfs:label """Melting/boiling points are linked to intermolecular forces (simple) and bond
  strength (giant)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.304083Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9684-5
  a curric:KeyLearningPoint ;
  rdfs:label "Conductivity is linked to whether there are free moving charge carriers."@en ;
  dcterms:modified "2026-06-07T15:30:29.304087Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9939-1
  a curric:KeyLearningPoint ;
  rdfs:label "Stretching or compressing an object requires more than one force."@en ;
  dcterms:modified "2026-06-07T15:30:29.304466Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9939-2
  a curric:KeyLearningPoint ;
  rdfs:label """Below the limit of proportionality, a stretched spring is not stretched permanently
  out of shape."""@en ;
  dcterms:modified "2026-06-07T15:30:29.304470Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9939-3
  a curric:KeyLearningPoint ;
  rdfs:label """Above the limit of proportionality, a stretched spring is stretched permanently out
  of shape."""@en ;
  dcterms:modified "2026-06-07T15:30:29.304474Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9705-1
  a curric:KeyLearningPoint ;
  rdfs:label "Heating sodium hydrogencarbonate in a crucible leads to its decomposition."@en ;
  dcterms:modified "2026-06-07T15:30:29.304525Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9705-2
  a curric:KeyLearningPoint ;
  rdfs:label "The risk involved with heating sodium hydrogencarbonate is low."@en ;
  dcterms:modified "2026-06-07T15:30:29.304531Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9705-3
  a curric:KeyLearningPoint ;
  rdfs:label "The stoichiometry for a reaction can be calculated given experimental data."@en ;
  dcterms:modified "2026-06-07T15:30:29.304536Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9705-4
  a curric:KeyLearningPoint ;
  rdfs:label """Because a gas is not a reactant in this reaction, the crucible lid remains closed
  throughout the heating process."""@en ;
  dcterms:modified "2026-06-07T15:30:29.304540Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5052-1
  a curric:KeyLearningPoint ;
  rdfs:label """The speed of water waves can be measured using measurements of distance travelled
  and time taken."""@en ;
  dcterms:modified "2026-06-07T15:30:29.309500Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5052-2
  a curric:KeyLearningPoint ;
  rdfs:label "Random errors are made when the method limits how accurate a measurement can be."@en ;
  dcterms:modified "2026-06-07T15:30:29.309504Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5052-3
  a curric:KeyLearningPoint ;
  rdfs:label """The effect of random errors can be reduced by repeating readings and calculating a
  mean."""@en ;
  dcterms:modified "2026-06-07T15:30:29.309508Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5052-4
  a curric:KeyLearningPoint ;
  rdfs:label """The uncertainty in a mean result is calculated from half the range of the repeat
  measurements."""@en ;
  dcterms:modified "2026-06-07T15:30:29.309512Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8326-1
  a curric:KeyLearningPoint ;
  rdfs:label """Positive ions burn with distinct colours that are visible when heated above a blue
  Bunsen flame."""@en ;
  dcterms:modified "2026-06-07T15:30:29.310091Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8326-2
  a curric:KeyLearningPoint ;
  rdfs:label """Instrumental methods are accurate, sensitive, and rapid for detecting and
  identifying elements and compounds."""@en ;
  dcterms:modified "2026-06-07T15:30:29.310095Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8326-3
  a curric:KeyLearningPoint ;
  rdfs:label "Unique flame emission spectra are produced for each positive metal ion."@en ;
  dcterms:modified "2026-06-07T15:30:29.310099Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8326-4
  a curric:KeyLearningPoint ;
  rdfs:label "A spectrometer can split light from coloured flames into flame emission spectra."@en ;
  dcterms:modified "2026-06-07T15:30:29.310103Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8326-5
  a curric:KeyLearningPoint ;
  rdfs:label """A spectrometer can measure more than one metal ion in a single solution and the
  concentration of each."""@en ;
  dcterms:modified "2026-06-07T15:30:29.310107Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9677-1
  a curric:KeyLearningPoint ;
  rdfs:label """Titration is a method used to completely neutralise an acid with a soluble base
  (alkali)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.310329Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9677-2
  a curric:KeyLearningPoint ;
  rdfs:label """Titrations are performed using strong acids and strong alkalis to accurately
  determine reacting volumes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.310333Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9677-3
  a curric:KeyLearningPoint ;
  rdfs:label "Strong acids and alkalis are completely ionised in an aqueous solution."@en ;
  dcterms:modified "2026-06-07T15:30:29.310336Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9677-4
  a curric:KeyLearningPoint ;
  rdfs:label "Each piece of apparatus in a titration has a specific and essential function."@en ;
  dcterms:modified "2026-06-07T15:30:29.310340Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9677-5
  a curric:KeyLearningPoint ;
  rdfs:label """A suitable indicator (not universal indicator) is used to identify the end point of
  the titration."""@en ;
  dcterms:modified "2026-06-07T15:30:29.310344Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9094-1
  a curric:KeyLearningPoint ;
  rdfs:label """The pressure in a fluid increases with depth because the weight of fluid above
  pushes particles closer together."""@en ;
  dcterms:modified "2026-06-07T15:30:29.312635Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9094-2
  a curric:KeyLearningPoint ;
  rdfs:label """The pressure on an object in a fluid pushes with more force on the lower part of it
  and causes upthrust."""@en ;
  dcterms:modified "2026-06-07T15:30:29.312639Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9094-3
  a curric:KeyLearningPoint ;
  rdfs:label "An object floats in water if its density is less than that of water."@en ;
  dcterms:modified "2026-06-07T15:30:29.312643Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9094-4
  a curric:KeyLearningPoint ;
  rdfs:label """The density of a material increases with the mass of each particle and the closeness
  of its particles."""@en ;
  dcterms:modified "2026-06-07T15:30:29.312649Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9094-5
  a curric:KeyLearningPoint ;
  rdfs:label """Ice is less dense than water as its crystal structure fixes the particles further
  apart than they are in water."""@en ;
  dcterms:modified "2026-06-07T15:30:29.312654Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9725-1
  a curric:KeyLearningPoint ;
  rdfs:label """Transition metals are generally stronger, harder, more dense and have higher melting
  points than Group 1 metals."""@en ;
  dcterms:modified "2026-06-07T15:30:29.314351Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9725-2
  a curric:KeyLearningPoint ;
  rdfs:label "Transition metals react slowly with water or don’t react with it at all."@en ;
  dcterms:modified "2026-06-07T15:30:29.314355Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9725-3
  a curric:KeyLearningPoint ;
  rdfs:label "Transition metals are often catalysts that speed up chemical reactions."@en ;
  dcterms:modified "2026-06-07T15:30:29.314359Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9725-4
  a curric:KeyLearningPoint ;
  rdfs:label """Transition metals can form ions with different charges and their compounds often
  exhibit vibrant colours."""@en ;
  dcterms:modified "2026-06-07T15:30:29.314365Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8333-1
  a curric:KeyLearningPoint ;
  rdfs:label "Chemical amounts are measured in moles (mol)."@en ;
  dcterms:modified "2026-06-07T15:30:29.314581Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8333-2
  a curric:KeyLearningPoint ;
  rdfs:label """One mole of particles of a substance is defined as the Avogadro constant number of
  particles."""@en ;
  dcterms:modified "2026-06-07T15:30:29.314585Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8333-3
  a curric:KeyLearningPoint ;
  rdfs:label """The number of particles (atoms, ions, molecules etc.) in one mole of a substance is
  always the same."""@en ;
  dcterms:modified "2026-06-07T15:30:29.314589Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8333-4
  a curric:KeyLearningPoint ;
  rdfs:label """Use of Avogadro's number to calculate the number of particles of substance when
  number of moles is known and vice versa."""@en ;
  dcterms:modified "2026-06-07T15:30:29.314593Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8333-5
  a curric:KeyLearningPoint ;
  rdfs:label """The mass of one mole of a monatomic element is equal to the relative atomic mass of
  that element measured in grams."""@en ;
  dcterms:modified "2026-06-07T15:30:29.314597Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9660-1
  a curric:KeyLearningPoint ;
  rdfs:label "Heating magnesium in a crucible will react it with oxygen."@en ;
  dcterms:modified "2026-06-07T15:30:29.314691Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9660-2
  a curric:KeyLearningPoint ;
  rdfs:label """The crucible must be opened periodically to ensure enough oxygen enters the vessel
  to completely oxidise the magnesium."""@en ;
  dcterms:modified "2026-06-07T15:30:29.314695Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9660-3
  a curric:KeyLearningPoint ;
  rdfs:label "Opening the crucible too much will cause mass/product loss."@en ;
  dcterms:modified "2026-06-07T15:30:29.314700Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9660-4
  a curric:KeyLearningPoint ;
  rdfs:label """Safety precautions should be taken when burning magnesium because of the bright
  light produced."""@en ;
  dcterms:modified "2026-06-07T15:30:29.314704Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9660-5
  a curric:KeyLearningPoint ;
  rdfs:label "The stoichiometry for a reaction can be calculated given experimental data."@en ;
  dcterms:modified "2026-06-07T15:30:29.314708Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9188-1
  a curric:KeyLearningPoint ;
  rdfs:label "Plant health can be affected by pathogens."@en ;
  dcterms:modified "2026-06-07T15:30:29.314858Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9188-2
  a curric:KeyLearningPoint ;
  rdfs:label "Chalara ash dieback is an example of a disease in plants caused by a fungus."@en ;
  dcterms:modified "2026-06-07T15:30:29.314862Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9188-3
  a curric:KeyLearningPoint ;
  rdfs:label """Ways in which plant diseases can be spread, and ways in which the spread can be
  reduced."""@en ;
  dcterms:modified "2026-06-07T15:30:29.314866Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9188-4
  a curric:KeyLearningPoint ;
  rdfs:label "Impacts of ash dieback on biodiversity, including through habitat destruction."@en ;
  dcterms:modified "2026-06-07T15:30:29.314870Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9639-1
  a curric:KeyLearningPoint ;
  rdfs:label """A mixture consists of two or more elements and/or compounds, not chemically combined
  together."""@en ;
  dcterms:modified "2026-06-07T15:30:29.315311Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9639-2
  a curric:KeyLearningPoint ;
  rdfs:label "Chemical properties of each substance in a mixture remain unchanged."@en ;
  dcterms:modified "2026-06-07T15:30:29.315315Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9639-3
  a curric:KeyLearningPoint ;
  rdfs:label "There are multiple physical processes for separating mixtures."@en ;
  dcterms:modified "2026-06-07T15:30:29.315319Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9639-4
  a curric:KeyLearningPoint ;
  rdfs:label """Melting point data can be used to distinguish between pure substances and
  mixtures."""@en ;
  dcterms:modified "2026-06-07T15:30:29.315323Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9639-5
  a curric:KeyLearningPoint ;
  rdfs:label """A formulation is a designed mixture, with each component serving a specific
  purpose."""@en ;
  dcterms:modified "2026-06-07T15:30:29.315327Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9892-1
  a curric:KeyLearningPoint ;
  rdfs:label "The velocity of an object is its speed in a given direction."@en ;
  dcterms:modified "2026-06-07T15:30:29.315939Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9892-2
  a curric:KeyLearningPoint ;
  rdfs:label """The displacement of an object is the distance it travels in a particular
  direction."""@en ;
  dcterms:modified "2026-06-07T15:30:29.315943Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9892-3
  a curric:KeyLearningPoint ;
  rdfs:label "Displacement and velocity are both vector quantities."@en ;
  dcterms:modified "2026-06-07T15:30:29.315947Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9892-4
  a curric:KeyLearningPoint ;
  rdfs:label """Velocity has a positive value in one direction and negative value in the opposite
  direction."""@en ;
  dcterms:modified "2026-06-07T15:30:29.315951Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9892-5
  a curric:KeyLearningPoint ;
  rdfs:label """Motion in a circle involves a centripetal force which constantly changes the
  velocity of an object."""@en ;
  dcterms:modified "2026-06-07T15:30:29.315955Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4728-1
  a curric:KeyLearningPoint ;
  rdfs:label "Velocity of an object is its speed in a given direction."@en ;
  dcterms:modified "2026-06-07T15:30:29.316059Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4728-2
  a curric:KeyLearningPoint ;
  rdfs:label "Displacement is distance in a particular direction."@en ;
  dcterms:modified "2026-06-07T15:30:29.316063Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4728-3
  a curric:KeyLearningPoint ;
  rdfs:label "Displacement and velocity are vectors."@en ;
  dcterms:modified "2026-06-07T15:30:29.316069Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4728-4
  a curric:KeyLearningPoint ;
  rdfs:label "Velocity is positive in one direction and negative in the opposite direction."@en ;
  dcterms:modified "2026-06-07T15:30:29.316074Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4728-5
  a curric:KeyLearningPoint ;
  rdfs:label "Movement around a circle at a steady speed involves a changing velocity."@en ;
  dcterms:modified "2026-06-07T15:30:29.316078Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20365-1
  a curric:KeyLearningPoint ;
  rdfs:label "Frequency of a wave can be measured indirectly from its speed and wavelength."@en ;
  dcterms:modified "2026-06-07T15:30:29.316334Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20365-2
  a curric:KeyLearningPoint ;
  rdfs:label """Wavelength of a wave can be measured by using a freeze frame of a wave moving along
  the length of a ruler."""@en ;
  dcterms:modified "2026-06-07T15:30:29.316338Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20365-3
  a curric:KeyLearningPoint ;
  rdfs:label """It is more accurate to measure the length of, e.g. ten waves and dividing by ten,
  than measuring one wavelength."""@en ;
  dcterms:modified "2026-06-07T15:30:29.316342Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20365-4
  a curric:KeyLearningPoint ;
  rdfs:label """Speed of a wave can be measured by recording the wave moving along a ruler with a
  timer in the frame."""@en ;
  dcterms:modified "2026-06-07T15:30:29.316346Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20365-5
  a curric:KeyLearningPoint ;
  rdfs:label """Accurate distance and time are measured by freezing the film, played back in slow
  motion, to track one wave crest."""@en ;
  dcterms:modified "2026-06-07T15:30:29.316350Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8329-1
  a curric:KeyLearningPoint ;
  rdfs:label """Atoms are the building blocks that can be combined in different ways to form
  different substances."""@en ;
  dcterms:modified "2026-06-07T15:30:29.317818Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8329-2
  a curric:KeyLearningPoint ;
  rdfs:label """It is impossible for any atom to be changed into a different type of atom by a
  chemical reaction."""@en ;
  dcterms:modified "2026-06-07T15:30:29.317822Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8329-3
  a curric:KeyLearningPoint ;
  rdfs:label """All of the atoms in the reactants of a chemical reaction are reorganised to form all
  of the products of the reaction."""@en ;
  dcterms:modified "2026-06-07T15:30:29.317826Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8329-4
  a curric:KeyLearningPoint ;
  rdfs:label """It is impossible to make a particular product without all the atoms that it
  needs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.317830Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8329-5
  a curric:KeyLearningPoint ;
  rdfs:label """The law of conservation of mass can be applied to a closed system, or a non-enclosed
  system that takes in/gives out gas."""@en ;
  dcterms:modified "2026-06-07T15:30:29.317834Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8142-1
  a curric:KeyLearningPoint ;
  rdfs:label "Earthquakes usually occur near to the edges of tectonic plates"@en ;
  dcterms:modified "2026-06-07T15:30:29.324420Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8142-2
  a curric:KeyLearningPoint ;
  rdfs:label """P waves and S waves are produced deep underground where tectonic plates slip and
  cause vibrations in rock"""@en ;
  dcterms:modified "2026-06-07T15:30:29.324423Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8142-3
  a curric:KeyLearningPoint ;
  rdfs:label "P waves are longitudinal waves and travel through liquid"@en ;
  dcterms:modified "2026-06-07T15:30:29.324427Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8142-4
  a curric:KeyLearningPoint ;
  rdfs:label """S waves are transverse waves and cannot travel through liquid layers inside
  Earth"""@en ;
  dcterms:modified "2026-06-07T15:30:29.324431Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8142-5
  a curric:KeyLearningPoint ;
  rdfs:label "P waves and S waves provide evidence for the internal structure of Earth"@en ;
  dcterms:modified "2026-06-07T15:30:29.324435Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9919-1
  a curric:KeyLearningPoint ;
  rdfs:label "Work done is the total amount of energy transferred."@en ;
  dcterms:modified "2026-06-07T15:30:29.326690Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9919-2
  a curric:KeyLearningPoint ;
  rdfs:label "Work done = force × distance (moved in the direction of the force)."@en ;
  dcterms:modified "2026-06-07T15:30:29.326694Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9919-3
  a curric:KeyLearningPoint ;
  rdfs:label "Work done is measured in joules (J)."@en ;
  dcterms:modified "2026-06-07T15:30:29.326698Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8330-1
  a curric:KeyLearningPoint ;
  rdfs:label """In a chemical reaction the + symbol can be read as ‘and’ and the arrow as ‘changes
  into’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.330932Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8330-2
  a curric:KeyLearningPoint ;
  rdfs:label "In an oxidation reaction a reactant combines with oxygen."@en ;
  dcterms:modified "2026-06-07T15:30:29.330936Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8330-3
  a curric:KeyLearningPoint ;
  rdfs:label "In a decomposition reaction a reactant splits into two or more new substances."@en ;
  dcterms:modified "2026-06-07T15:30:29.330940Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8330-4
  a curric:KeyLearningPoint ;
  rdfs:label "In a precipitation reaction an insoluble salt is formed."@en ;
  dcterms:modified "2026-06-07T15:30:29.330944Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9204-1
  a curric:KeyLearningPoint ;
  rdfs:label """Calculate the rate of respiration by dividing the distance moved up the capillary
  tube of a respirometer by the time."""@en ;
  dcterms:modified "2026-06-07T15:30:29.331646Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9204-2
  a curric:KeyLearningPoint ;
  rdfs:label "Use appropriate units for the rate of cellular respiration."@en ;
  dcterms:modified "2026-06-07T15:30:29.331650Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9204-3
  a curric:KeyLearningPoint ;
  rdfs:label "Compare the rate of respiration in small organisms at different temperatures."@en ;
  dcterms:modified "2026-06-07T15:30:29.331656Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9204-4
  a curric:KeyLearningPoint ;
  rdfs:label "Describe trends in the data."@en ;
  dcterms:modified "2026-06-07T15:30:29.331661Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9204-5
  a curric:KeyLearningPoint ;
  rdfs:label """Use ideas about enzymes and rate of chemical reactions to explain the effect of
  temperature on the rate of respiration."""@en ;
  dcterms:modified "2026-06-07T15:30:29.331668Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9894-1
  a curric:KeyLearningPoint ;
  rdfs:label "Velocity of an object is equal to the gradient of a displacement-time graph."@en ;
  dcterms:modified "2026-06-07T15:30:29.333550Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9894-2
  a curric:KeyLearningPoint ;
  rdfs:label "A direction in which velocity and displacement are measured needs to be chosen."@en ;
  dcterms:modified "2026-06-07T15:30:29.333554Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9894-3
  a curric:KeyLearningPoint ;
  rdfs:label """A negative gradient on a displacement-time graph (sloping downwards) represents
  velocity in the opposite direction."""@en ;
  dcterms:modified "2026-06-07T15:30:29.333559Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9894-4
  a curric:KeyLearningPoint ;
  rdfs:label """A negative value for displacement represents a position ‘behind’ the starting
  position."""@en ;
  dcterms:modified "2026-06-07T15:30:29.333564Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27912-1
  a curric:KeyLearningPoint ;
  rdfs:label """Unique tests for each substance help minimise errors and ensure correct
  identification."""@en ;
  dcterms:modified "2026-06-07T15:30:29.333603Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27912-2
  a curric:KeyLearningPoint ;
  rdfs:label "Gas tests can be used to identify carbon dioxide, oxygen, hydrogen and ammonia."@en ;
  dcterms:modified "2026-06-07T15:30:29.333607Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27912-3
  a curric:KeyLearningPoint ;
  rdfs:label """Observations and results should be recorded accurately for analysis during the
  practical."""@en ;
  dcterms:modified "2026-06-07T15:30:29.333613Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27912-4
  a curric:KeyLearningPoint ;
  rdfs:label """Flow charts break down complex activities into ordered sets of simpler steps,
  crucial for efficient ion identification."""@en ;
  dcterms:modified "2026-06-07T15:30:29.333617Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8328-1
  a curric:KeyLearningPoint ;
  rdfs:label """Unique tests for each substance help minimise errors and ensure correct
  identification."""@en ;
  dcterms:modified "2026-06-07T15:30:29.333698Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8328-2
  a curric:KeyLearningPoint ;
  rdfs:label """Flow charts break down complex activities into ordered sets of simpler steps,
  crucial for efficient ion identification."""@en ;
  dcterms:modified "2026-06-07T15:30:29.333702Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8328-3
  a curric:KeyLearningPoint ;
  rdfs:label """Observations and results should be recorded accurately for analysis during the
  practical."""@en ;
  dcterms:modified "2026-06-07T15:30:29.333706Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20359-1
  a curric:KeyLearningPoint ;
  rdfs:label "Heating magnesium in a crucible will react it with oxygen."@en ;
  dcterms:modified "2026-06-07T15:30:29.333775Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20359-2
  a curric:KeyLearningPoint ;
  rdfs:label """The crucible must be opened periodically to ensure enough oxygen enters the vessel
  to completely oxidise the magnesium."""@en ;
  dcterms:modified "2026-06-07T15:30:29.333782Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20359-3
  a curric:KeyLearningPoint ;
  rdfs:label "Opening the crucible too much will cause mass/product loss."@en ;
  dcterms:modified "2026-06-07T15:30:29.333786Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20359-4
  a curric:KeyLearningPoint ;
  rdfs:label """Safety precautions should be taken when burning magnesium because of the bright
  light produced."""@en ;
  dcterms:modified "2026-06-07T15:30:29.333790Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20359-5
  a curric:KeyLearningPoint ;
  rdfs:label "The stoichiometry for a reaction can be calculated given experimental data."@en ;
  dcterms:modified "2026-06-07T15:30:29.333794Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8325-1
  a curric:KeyLearningPoint ;
  rdfs:label """Some metal ions form coloured precipitates in a reaction with sodium hydroxide
  solution."""@en ;
  dcterms:modified "2026-06-07T15:30:29.343269Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8325-2
  a curric:KeyLearningPoint ;
  rdfs:label """Ammonium ions can be identified by heating with NaOH and using damp red litmus
  paper, which turns blue if positive."""@en ;
  dcterms:modified "2026-06-07T15:30:29.343273Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8325-3
  a curric:KeyLearningPoint ;
  rdfs:label """A dilute acid is usually added before testing for carbonates, sulfates or halides to
  avoid false positives."""@en ;
  dcterms:modified "2026-06-07T15:30:29.343276Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8325-4
  a curric:KeyLearningPoint ;
  rdfs:label """Halide ions produce different coloured precipitates when silver nitrate is added to
  a solution containing them."""@en ;
  dcterms:modified "2026-06-07T15:30:29.343280Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8325-5
  a curric:KeyLearningPoint ;
  rdfs:label """A white precipitate is formed when barium chloride is added to an acidified solution
  containing sulfate ions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.343284Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27994-1
  a curric:KeyLearningPoint ;
  rdfs:label """Process data and plot a graph of appropriate results to identify and describe
  patterns or trends in the results."""@en ;
  dcterms:modified "2026-06-07T15:30:29.343407Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27994-2
  a curric:KeyLearningPoint ;
  rdfs:label """Explaining the results using ideas about the requirement of light for
  photosynthesis."""@en ;
  dcterms:modified "2026-06-07T15:30:29.343411Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27994-3
  a curric:KeyLearningPoint ;
  rdfs:label """Identifying sources of systematic and random error that could affect the accuracy of
  the measurements."""@en ;
  dcterms:modified "2026-06-07T15:30:29.343415Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27994-4
  a curric:KeyLearningPoint ;
  rdfs:label """Suggesting improvements (e.g. ways to measure the amount of gas more
  accurately)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.343419Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27994-5
  a curric:KeyLearningPoint ;
  rdfs:label "Evaluating the precision, repeatability and reproducibility of the results."@en ;
  dcterms:modified "2026-06-07T15:30:29.343423Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9748-1
  a curric:KeyLearningPoint ;
  rdfs:label "The uses of polymers are related to their properties."@en ;
  dcterms:modified "2026-06-07T15:30:29.345526Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9748-2
  a curric:KeyLearningPoint ;
  rdfs:label """There are many problems associated with polymers (e.g. availability of raw
  materials, landfill, combustion)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.345530Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9748-3
  a curric:KeyLearningPoint ;
  rdfs:label """There are many advantages and disadvantages to recycling polymers (e.g. economical
  and environmental)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.345534Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9747-1
  a curric:KeyLearningPoint ;
  rdfs:label "A chemical test can identify the differences between alkanes and alkenes."@en ;
  dcterms:modified "2026-06-07T15:30:29.345538Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9747-2
  a curric:KeyLearningPoint ;
  rdfs:label """Data from calorimetry and viscosity experiments can be used to predict the chain
  length of alkanes, alkenes & alcohols."""@en ;
  dcterms:modified "2026-06-07T15:30:29.345542Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9747-3
  a curric:KeyLearningPoint ;
  rdfs:label "As chain length increases, more energy is released during combustion."@en ;
  dcterms:modified "2026-06-07T15:30:29.345546Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9747-4
  a curric:KeyLearningPoint ;
  rdfs:label """As chain length increases, the viscosity of alkanes, alkenes and alcohols
  increases."""@en ;
  dcterms:modified "2026-06-07T15:30:29.345550Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7935-1
  a curric:KeyLearningPoint ;
  rdfs:label "Light waves spread out as they travel from a light source."@en ;
  dcterms:modified "2026-06-07T15:30:29.345839Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7935-2
  a curric:KeyLearningPoint ;
  rdfs:label """Further away from the light source, the same amount of light is spread out over a
  greater area."""@en ;
  dcterms:modified "2026-06-07T15:30:29.345843Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7935-3
  a curric:KeyLearningPoint ;
  rdfs:label """This means the light intensity decreases with increasing distance from a light
  source."""@en ;
  dcterms:modified "2026-06-07T15:30:29.345847Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7935-4
  a curric:KeyLearningPoint ;
  rdfs:label """Light intensity is inversely proportional to the square of the distance from a light
  source (inverse square law)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.345853Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8428-1
  a curric:KeyLearningPoint ;
  rdfs:label """Alcohols can react, at their functional group -OH, with sodium, oxygen, water, or an
  oxidising agent."""@en ;
  dcterms:modified "2026-06-07T15:30:29.346055Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8428-2
  a curric:KeyLearningPoint ;
  rdfs:label "Alcohols need less oxygen than equivalent alkanes in order to burn completely."@en ;
  dcterms:modified "2026-06-07T15:30:29.346059Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8428-3
  a curric:KeyLearningPoint ;
  rdfs:label "Alcohols are good solvents which also mix with water."@en ;
  dcterms:modified "2026-06-07T15:30:29.346065Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8428-4
  a curric:KeyLearningPoint ;
  rdfs:label "The boiling point of ethanol is much higher than the boiling point of ethane."@en ;
  dcterms:modified "2026-06-07T15:30:29.346069Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8428-5
  a curric:KeyLearningPoint ;
  rdfs:label """Ethanol can be formed via fermentation of glucose (renewable) or via hydration of
  ethene (non-renewable)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.346075Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6384-1
  a curric:KeyLearningPoint ;
  rdfs:label """Increasing human population size requires increased land use for resources
  (including food and fuels) and urbanisation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.347394Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6384-2
  a curric:KeyLearningPoint ;
  rdfs:label """Increased land use by humans leads to habitat destruction, e.g. deforestation and
  biodiversity loss."""@en ;
  dcterms:modified "2026-06-07T15:30:29.347398Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6384-3
  a curric:KeyLearningPoint ;
  rdfs:label """Increasing human population size increases production of waste and pollution,
  leading to biodiversity loss."""@en ;
  dcterms:modified "2026-06-07T15:30:29.347402Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6384-4
  a curric:KeyLearningPoint ;
  rdfs:label """Release of greenhouse gases contributes to climate change, including global warming,
  leading to biodiversity loss."""@en ;
  dcterms:modified "2026-06-07T15:30:29.347406Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6384-5
  a curric:KeyLearningPoint ;
  rdfs:label """There is very strong evidence linking human release of greenhouse gases to global
  climate change."""@en ;
  dcterms:modified "2026-06-07T15:30:29.347410Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9895-1
  a curric:KeyLearningPoint ;
  rdfs:label "The velocity of an object is equal to the gradient of a displacement-time graph."@en ;
  dcterms:modified "2026-06-07T15:30:29.348663Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9895-2
  a curric:KeyLearningPoint ;
  rdfs:label "A direction in which velocity and displacement are measured needs to be chosen."@en ;
  dcterms:modified "2026-06-07T15:30:29.348667Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9895-3
  a curric:KeyLearningPoint ;
  rdfs:label """A negative gradient on a displacement-time graph (sloping downwards) represents
  velocity in the opposite direction."""@en ;
  dcterms:modified "2026-06-07T15:30:29.348671Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9895-4
  a curric:KeyLearningPoint ;
  rdfs:label """A negative value for displacement represents a position ‘behind’ the starting
  position."""@en ;
  dcterms:modified "2026-06-07T15:30:29.348676Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4909-1
  a curric:KeyLearningPoint ;
  rdfs:label """Doubling the stiffness of a spring doubles the energy it has because it is
  stretched."""@en ;
  dcterms:modified "2026-06-07T15:30:29.349273Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4909-2
  a curric:KeyLearningPoint ;
  rdfs:label "The spring constant is measured in newtons per metre (N/m)."@en ;
  dcterms:modified "2026-06-07T15:30:29.349277Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4909-3
  a curric:KeyLearningPoint ;
  rdfs:label """Doubling the extension of a spring increases the energy it has, because it is
  stretched, by four times."""@en ;
  dcterms:modified "2026-06-07T15:30:29.349281Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4909-4
  a curric:KeyLearningPoint ;
  rdfs:label """The energy a spring has because it is stretched equals 1/2 × spring constant ×
  (extension)²."""@en ;
  dcterms:modified "2026-06-07T15:30:29.349285Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8427-1
  a curric:KeyLearningPoint ;
  rdfs:label "Reactions of an alkene happen at its functional group, C=C."@en ;
  dcterms:modified "2026-06-07T15:30:29.349394Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8427-2
  a curric:KeyLearningPoint ;
  rdfs:label "Reactions of an alkene change it from an unsaturated to a saturated molecule."@en ;
  dcterms:modified "2026-06-07T15:30:29.349398Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8427-3
  a curric:KeyLearningPoint ;
  rdfs:label "Larger alkenes have higher boiling points and are less flammable."@en ;
  dcterms:modified "2026-06-07T15:30:29.349402Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8427-4
  a curric:KeyLearningPoint ;
  rdfs:label "Alkenes tend to burn with smoky flames due to incomplete combustion."@en ;
  dcterms:modified "2026-06-07T15:30:29.349406Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8427-5
  a curric:KeyLearningPoint ;
  rdfs:label """Isomers are structures with the same molecular formula, but different arrangement of
  atoms in space."""@en ;
  dcterms:modified "2026-06-07T15:30:29.349410Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9924-1
  a curric:KeyLearningPoint ;
  rdfs:label """Energy is dissipated due to friction which causes particles to vibrate more quickly
  and heats up the surroundings."""@en ;
  dcterms:modified "2026-06-07T15:30:29.350381Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9924-2
  a curric:KeyLearningPoint ;
  rdfs:label """Energy is dissipated due to drag which causes particles in the surroundings to move
  more quickly."""@en ;
  dcterms:modified "2026-06-07T15:30:29.350385Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9924-3
  a curric:KeyLearningPoint ;
  rdfs:label "Efficiency = useful output energy transfer / total input energy transfer"@en ;
  dcterms:modified "2026-06-07T15:30:29.350389Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27586-1
  a curric:KeyLearningPoint ;
  rdfs:label """Growing food helps feed the increasing human population, but can have negative
  impacts on ecosystems and biodiversity."""@en ;
  dcterms:modified "2026-06-07T15:30:29.350471Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27586-2
  a curric:KeyLearningPoint ;
  rdfs:label "Fish farming and animal welfare as examples of positive and negative impacts."@en ;
  dcterms:modified "2026-06-07T15:30:29.350475Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27586-3
  a curric:KeyLearningPoint ;
  rdfs:label "Eutrophication as an example of a negative impact."@en ;
  dcterms:modified "2026-06-07T15:30:29.350479Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27586-4
  a curric:KeyLearningPoint ;
  rdfs:label "The introduction of non-indigenous species as an example of a negative impact."@en ;
  dcterms:modified "2026-06-07T15:30:29.350483Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27586-5
  a curric:KeyLearningPoint ;
  rdfs:label "Ways of mitigating some of these negative impacts."@en ;
  dcterms:modified "2026-06-07T15:30:29.350488Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8429-1
  a curric:KeyLearningPoint ;
  rdfs:label "Carboxylic acids have a -COOH functional group."@en ;
  dcterms:modified "2026-06-07T15:30:29.352302Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8429-2
  a curric:KeyLearningPoint ;
  rdfs:label "Carboxylic acids are weak acids."@en ;
  dcterms:modified "2026-06-07T15:30:29.352306Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8429-3
  a curric:KeyLearningPoint ;
  rdfs:label "When ethanol is oxidised, ethanoic acid is formed."@en ;
  dcterms:modified "2026-06-07T15:30:29.352312Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8429-4
  a curric:KeyLearningPoint ;
  rdfs:label """Carboxylic acids react with carbonates to produce a metal salt, carbon dioxide and
  water."""@en ;
  dcterms:modified "2026-06-07T15:30:29.352338Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8429-5
  a curric:KeyLearningPoint ;
  rdfs:label """Carboxylic acid can react with alcohol to produce esters (such as ethyl
  ethanoate)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.352342Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8430-1
  a curric:KeyLearningPoint ;
  rdfs:label """A polymer is a substance of high average relative molecular mass made up of small
  repeating units."""@en ;
  dcterms:modified "2026-06-07T15:30:29.352347Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8430-2
  a curric:KeyLearningPoint ;
  rdfs:label """In addition polymerisation only one molecule is formed, e.g. addition polymerisation
  of ethene forms poly(ethene)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.352351Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8430-3
  a curric:KeyLearningPoint ;
  rdfs:label "Polymers have a specific displayed formula to show repeat units."@en ;
  dcterms:modified "2026-06-07T15:30:29.352355Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8430-4
  a curric:KeyLearningPoint ;
  rdfs:label "A polymer's monomer can be deduced from its structure and vice versa."@en ;
  dcterms:modified "2026-06-07T15:30:29.352359Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8430-5
  a curric:KeyLearningPoint ;
  rdfs:label """Addition polymers can be made by combining together a variety of monomer molecules
  containing C=C."""@en ;
  dcterms:modified "2026-06-07T15:30:29.352363Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9124-1
  a curric:KeyLearningPoint ;
  rdfs:label """Energy transferred to a solid at its melting point allows its particles to move
  further apart."""@en ;
  dcterms:modified "2026-06-07T15:30:29.353361Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9124-2
  a curric:KeyLearningPoint ;
  rdfs:label """Energy transferred to a liquid at its boiling point allows its particles to move
  fast enough to get even further apart."""@en ;
  dcterms:modified "2026-06-07T15:30:29.353365Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9124-3
  a curric:KeyLearningPoint ;
  rdfs:label """The energy transferred to melt a solid at its melting point is proportional to the
  mass of the solid."""@en ;
  dcterms:modified "2026-06-07T15:30:29.353369Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9124-4
  a curric:KeyLearningPoint ;
  rdfs:label """The energy transferred to melt 1 kg of a solid at its melting point is proportional
  to the solid’s specific latent heat."""@en ;
  dcterms:modified "2026-06-07T15:30:29.353373Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9124-5
  a curric:KeyLearningPoint ;
  rdfs:label """The energy transferred to boil 1 kg of a liquid at its boiling point is proportional
  to its specific latent heat."""@en ;
  dcterms:modified "2026-06-07T15:30:29.353377Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8431-1
  a curric:KeyLearningPoint ;
  rdfs:label "Condensation polymerisation requires monomers with two functional groups."@en ;
  dcterms:modified "2026-06-07T15:30:29.363595Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8431-2
  a curric:KeyLearningPoint ;
  rdfs:label "Condensation polymers can be made of two different monomers."@en ;
  dcterms:modified "2026-06-07T15:30:29.363599Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8431-3
  a curric:KeyLearningPoint ;
  rdfs:label """A polyester is formed by reaction of a monomer with two carboxylic acid groups with
  a monomer with two alcohol groups."""@en ;
  dcterms:modified "2026-06-07T15:30:29.363603Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8431-4
  a curric:KeyLearningPoint ;
  rdfs:label """In condensation polymerisation as well as the polymer a small molecule is formed,
  usually water."""@en ;
  dcterms:modified "2026-06-07T15:30:29.363607Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8431-5
  a curric:KeyLearningPoint ;
  rdfs:label """Amino acids contain two functional groups and can form polypeptides and
  proteins."""@en ;
  dcterms:modified "2026-06-07T15:30:29.363611Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9893-1
  a curric:KeyLearningPoint ;
  rdfs:label "The velocity of an object is equal to the gradient of a displacement-time graph."@en ;
  dcterms:modified "2026-06-07T15:30:29.366837Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9893-2
  a curric:KeyLearningPoint ;
  rdfs:label "A direction in which velocity and displacement are measured needs to be chosen."@en ;
  dcterms:modified "2026-06-07T15:30:29.366841Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9893-3
  a curric:KeyLearningPoint ;
  rdfs:label """A negative gradient on a displacement-time graph (sloping downwards) represents
  velocity in the opposite direction."""@en ;
  dcterms:modified "2026-06-07T15:30:29.366845Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9893-4
  a curric:KeyLearningPoint ;
  rdfs:label """A negative value for displacement represents a position ‘behind’ the starting
  position."""@en ;
  dcterms:modified "2026-06-07T15:30:29.366849Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9627-1
  a curric:KeyLearningPoint ;
  rdfs:label "Dot and cross diagrams as a model for binary ionic substances"@en ;
  dcterms:modified "2026-06-07T15:30:29.367667Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9627-2
  a curric:KeyLearningPoint ;
  rdfs:label """Dot and cross diagrams show the empirical formula/ratio of atoms to show how
  electrons are transferred"""@en ;
  dcterms:modified "2026-06-07T15:30:29.367671Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9627-3
  a curric:KeyLearningPoint ;
  rdfs:label """Ions are shown with full outer shells, square brackets, and a charge in the top
  right corner."""@en ;
  dcterms:modified "2026-06-07T15:30:29.367693Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9627-4
  a curric:KeyLearningPoint ;
  rdfs:label """Ionic compounds are neutral overall, so positive and negative charge must
  balance."""@en ;
  dcterms:modified "2026-06-07T15:30:29.367698Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9627-5
  a curric:KeyLearningPoint ;
  rdfs:label """When positive ions do not have the same magnitude of charge as negative ions,
  multiple of some ions will be required."""@en ;
  dcterms:modified "2026-06-07T15:30:29.367702Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9148-1
  a curric:KeyLearningPoint ;
  rdfs:label "Different surfaces can scatter light or reflect light in a regular way."@en ;
  dcterms:modified "2026-06-07T15:30:29.367706Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9148-2
  a curric:KeyLearningPoint ;
  rdfs:label """The angle of incidence equals the angle of reflection. Angles are measured from the
  normal."""@en ;
  dcterms:modified "2026-06-07T15:30:29.367710Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9148-3
  a curric:KeyLearningPoint ;
  rdfs:label "Light can be thought of as a wave (ripples) in electric and magnetic fields."@en ;
  dcterms:modified "2026-06-07T15:30:29.367714Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9148-4
  a curric:KeyLearningPoint ;
  rdfs:label "Like all waves, light can be represented using rays or wavefronts."@en ;
  dcterms:modified "2026-06-07T15:30:29.367719Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5056-1
  a curric:KeyLearningPoint ;
  rdfs:label """As the p.d. across a filament lamp increases, it gets hotter and current through it
  increases in a non-ohmic way."""@en ;
  dcterms:modified "2026-06-07T15:30:29.367744Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5056-2
  a curric:KeyLearningPoint ;
  rdfs:label "The greater the p.d. across a filament lamp, the greater its resistance."@en ;
  dcterms:modified "2026-06-07T15:30:29.367749Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5056-3
  a curric:KeyLearningPoint ;
  rdfs:label """A metal is made of a lattice of positively charged ions with negatively charged
  electrons between."""@en ;
  dcterms:modified "2026-06-07T15:30:29.367754Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5056-4
  a curric:KeyLearningPoint ;
  rdfs:label """As a current flows through metal, electrons moving through the ion lattice cause it
  to vibrate more vigorously."""@en ;
  dcterms:modified "2026-06-07T15:30:29.367758Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5056-5
  a curric:KeyLearningPoint ;
  rdfs:label """The more vigorously the ions (ion lattice) vibrate, the hotter the metal and the
  higher its resistance."""@en ;
  dcterms:modified "2026-06-07T15:30:29.367762Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5119-1
  a curric:KeyLearningPoint ;
  rdfs:label "Protons have a positive electric charge of +1 and a mass number of 1."@en ;
  dcterms:modified "2026-06-07T15:30:29.367768Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5119-2
  a curric:KeyLearningPoint ;
  rdfs:label "Neutrons have no electric charge and have a mass number of 1."@en ;
  dcterms:modified "2026-06-07T15:30:29.367772Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5119-3
  a curric:KeyLearningPoint ;
  rdfs:label """The atomic number of an element equals the number of protons in the nucleus of each
  atom of that element."""@en ;
  dcterms:modified "2026-06-07T15:30:29.367776Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5119-4
  a curric:KeyLearningPoint ;
  rdfs:label """The atomic number of an element equals the number of electrons in each atom of that
  element."""@en ;
  dcterms:modified "2026-06-07T15:30:29.367780Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5119-5
  a curric:KeyLearningPoint ;
  rdfs:label """Atoms of an element that have different numbers of neutrons in their nuclei are
  isotopes of the element."""@en ;
  dcterms:modified "2026-06-07T15:30:29.367784Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9159-1
  a curric:KeyLearningPoint ;
  rdfs:label "The animal cell model describes the common structures of animal cells."@en ;
  dcterms:modified "2026-06-07T15:30:29.367804Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9159-2
  a curric:KeyLearningPoint ;
  rdfs:label """These structures include the cytoplasm, cell membrane, nucleus and mitochondria.
  Each structure has a specific function."""@en ;
  dcterms:modified "2026-06-07T15:30:29.367808Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9159-3
  a curric:KeyLearningPoint ;
  rdfs:label """Specialised cells in animals have shapes, sizes and structures that are adapted for
  the jobs the cells do."""@en ;
  dcterms:modified "2026-06-07T15:30:29.367812Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9159-4
  a curric:KeyLearningPoint ;
  rdfs:label "Examples of specialised animal cells include blood cells and nerve cells."@en ;
  dcterms:modified "2026-06-07T15:30:29.367816Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9160-1
  a curric:KeyLearningPoint ;
  rdfs:label "The plant cell model describes the common structures of plant cells."@en ;
  dcterms:modified "2026-06-07T15:30:29.367820Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9160-2
  a curric:KeyLearningPoint ;
  rdfs:label """Some of these structures are common with animal cells, such as the cytoplasm, cell
  membrane, nucleus and mitochondria."""@en ;
  dcterms:modified "2026-06-07T15:30:29.367826Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9160-3
  a curric:KeyLearningPoint ;
  rdfs:label """Plant cells have additional structures, i.e. the cell wall, chloroplasts and
  vacuole; each has a specific function."""@en ;
  dcterms:modified "2026-06-07T15:30:29.367832Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9160-4
  a curric:KeyLearningPoint ;
  rdfs:label """Specialised cells in plants have shapes, sizes and structures that are adapted for
  the jobs the cells do."""@en ;
  dcterms:modified "2026-06-07T15:30:29.367836Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9160-5
  a curric:KeyLearningPoint ;
  rdfs:label "Examples of specialised plant cells include root hair cells and palisade cells."@en ;
  dcterms:modified "2026-06-07T15:30:29.367840Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9682-1
  a curric:KeyLearningPoint ;
  rdfs:label "Molecular modelling represents the bonding and structure of substances."@en ;
  dcterms:modified "2026-06-07T15:30:29.367884Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9682-2
  a curric:KeyLearningPoint ;
  rdfs:label """The way giant covalent structures melt/boil is very different to simple
  molecules."""@en ;
  dcterms:modified "2026-06-07T15:30:29.367888Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9682-3
  a curric:KeyLearningPoint ;
  rdfs:label """Diamond is very hard, has a very high melting point and does not conduct
  electricity, every atom is bonded to another."""@en ;
  dcterms:modified "2026-06-07T15:30:29.367891Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9682-4
  a curric:KeyLearningPoint ;
  rdfs:label """In graphite each atom is bonded to three others to form layers of hexagonal rings.
  Each atom contributes a free electron"""@en ;
  dcterms:modified "2026-06-07T15:30:29.367895Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9682-5
  a curric:KeyLearningPoint ;
  rdfs:label """Simple molecules are held together by intermolecular forces, no chemical bonds hold
  them together."""@en ;
  dcterms:modified "2026-06-07T15:30:29.367903Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9130-1
  a curric:KeyLearningPoint ;
  rdfs:label """In forward–bias, a diode has a very small resistance when the p.d. is larger than
  the threshold voltage."""@en ;
  dcterms:modified "2026-06-07T15:30:29.367907Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9130-2
  a curric:KeyLearningPoint ;
  rdfs:label """In reverse–bias, a diode has a very large resistance and very little current can
  flow."""@en ;
  dcterms:modified "2026-06-07T15:30:29.367911Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9130-3
  a curric:KeyLearningPoint ;
  rdfs:label """The greater the p.d. across a component, the larger the push on electric charges in
  the component."""@en ;
  dcterms:modified "2026-06-07T15:30:29.367917Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9130-4
  a curric:KeyLearningPoint ;
  rdfs:label """The resistance of a component is calculated from an I–V graph using pairs of
  readings and the equation R = V ÷ I."""@en ;
  dcterms:modified "2026-06-07T15:30:29.367921Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9130-5
  a curric:KeyLearningPoint ;
  rdfs:label """The greater the current through a component, the larger the heating effect
  on it."""@en ;
  dcterms:modified "2026-06-07T15:30:29.367925Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9201-1
  a curric:KeyLearningPoint ;
  rdfs:label "Keys can be used to identify organisms in their habitat."@en ;
  dcterms:modified "2026-06-07T15:30:29.367941Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9201-2
  a curric:KeyLearningPoint ;
  rdfs:label """It is not possible to count all the organisms in a population, so we use sampling to
  estimate population size."""@en ;
  dcterms:modified "2026-06-07T15:30:29.367945Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9201-3
  a curric:KeyLearningPoint ;
  rdfs:label "Sampling organisms in habitats (e.g. a river using kick sampling and a net)."@en ;
  dcterms:modified "2026-06-07T15:30:29.367949Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9201-4
  a curric:KeyLearningPoint ;
  rdfs:label "Sampling animals using a pooter."@en ;
  dcterms:modified "2026-06-07T15:30:29.367953Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9201-5
  a curric:KeyLearningPoint ;
  rdfs:label "Estimating populations using capture-mark-recapture."@en ;
  dcterms:modified "2026-06-07T15:30:29.367957Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5077-1
  a curric:KeyLearningPoint ;
  rdfs:label "Wire in a motor is insulated so that the current flows around the coil"@en ;
  dcterms:modified "2026-06-07T15:30:29.367961Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5077-2
  a curric:KeyLearningPoint ;
  rdfs:label "Connections in a motor slide over each other to prevent tangled wires"@en ;
  dcterms:modified "2026-06-07T15:30:29.367964Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5077-3
  a curric:KeyLearningPoint ;
  rdfs:label """When the coil in a motor kit is horizontal it is connected and a force acts on the
  sides 90 deg. to the magnetic field"""@en ;
  dcterms:modified "2026-06-07T15:30:29.367968Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5077-4
  a curric:KeyLearningPoint ;
  rdfs:label """Every half–turn, the coil connections in a motor kit swap over and change the
  direction of current through the coil"""@en ;
  dcterms:modified "2026-06-07T15:30:29.367972Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5077-5
  a curric:KeyLearningPoint ;
  rdfs:label """Each side of a coil in a motor kit at 90º to the magnetic field is pushed
  alternatively up then down every half turn"""@en ;
  dcterms:modified "2026-06-07T15:30:29.367978Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20687-1
  a curric:KeyLearningPoint ;
  rdfs:label """There are five different types of substance: monatomic, simple covalent (molecules),
  giant covalent, ionic and metallic."""@en ;
  dcterms:modified "2026-06-07T15:30:29.368710Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20687-2
  a curric:KeyLearningPoint ;
  rdfs:label """The outer shell in most atoms can hold 8 electrons but, in hydrogen and helium, it
  can only hold 2 electrons."""@en ;
  dcterms:modified "2026-06-07T15:30:29.368714Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20687-3
  a curric:KeyLearningPoint ;
  rdfs:label """Most atoms increase their stability by forming bonds with other atoms so that they
  have a full outer shell of electrons."""@en ;
  dcterms:modified "2026-06-07T15:30:29.368718Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20687-4
  a curric:KeyLearningPoint ;
  rdfs:label "Some atoms will share electrons with other atoms to increase their stability."@en ;
  dcterms:modified "2026-06-07T15:30:29.368722Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20687-5
  a curric:KeyLearningPoint ;
  rdfs:label """Some atoms will lose or gain electrons to increase stability forming cations or
  anions, respectfully."""@en ;
  dcterms:modified "2026-06-07T15:30:29.368726Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5606-1
  a curric:KeyLearningPoint ;
  rdfs:label """Plotting and interpretation of a graph showing the effect of sugar concentration on
  the mass of potato tissue."""@en ;
  dcterms:modified "2026-06-07T15:30:29.368768Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5606-2
  a curric:KeyLearningPoint ;
  rdfs:label """Increase in potato mass means water moved in by osmosis (because the sugar solution
  was more dilute outside)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.368774Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5606-3
  a curric:KeyLearningPoint ;
  rdfs:label """Decrease in potato mass means water moved out by osmosis (because the sugar solution
  was more concentrated outside)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.368778Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5606-4
  a curric:KeyLearningPoint ;
  rdfs:label """The concentration of sugar in the potato tissue can be determined from the point at
  which there was no change in mass."""@en ;
  dcterms:modified "2026-06-07T15:30:29.368782Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5606-5
  a curric:KeyLearningPoint ;
  rdfs:label """At this point the sugar concentration was equal inside and out, so there was no net
  movement of water."""@en ;
  dcterms:modified "2026-06-07T15:30:29.368786Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9889-1
  a curric:KeyLearningPoint ;
  rdfs:label "Average speed = distance / time."@en ;
  dcterms:modified "2026-06-07T15:30:29.368888Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9889-2
  a curric:KeyLearningPoint ;
  rdfs:label "The speed of sound in air is about 330 m/s."@en ;
  dcterms:modified "2026-06-07T15:30:29.368892Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9889-3
  a curric:KeyLearningPoint ;
  rdfs:label "Scalar quantities have magnitude only."@en ;
  dcterms:modified "2026-06-07T15:30:29.368896Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9889-4
  a curric:KeyLearningPoint ;
  rdfs:label "Speed and distance are scalar quantities."@en ;
  dcterms:modified "2026-06-07T15:30:29.368900Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9889-5
  a curric:KeyLearningPoint ;
  rdfs:label """Relative speed is the speed an object is moving towards or away from another object,
  which may also be moving."""@en ;
  dcterms:modified "2026-06-07T15:30:29.368903Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4726-1
  a curric:KeyLearningPoint ;
  rdfs:label "Average speed = distance/time"@en ;
  dcterms:modified "2026-06-07T15:30:29.369494Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4726-2
  a curric:KeyLearningPoint ;
  rdfs:label "The speed of sound in air is about 330 m/s."@en ;
  dcterms:modified "2026-06-07T15:30:29.369498Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4726-3
  a curric:KeyLearningPoint ;
  rdfs:label "Scalar quantities have magnitude only."@en ;
  dcterms:modified "2026-06-07T15:30:29.369502Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4726-4
  a curric:KeyLearningPoint ;
  rdfs:label "Speed and distance are scalar quantities."@en ;
  dcterms:modified "2026-06-07T15:30:29.369505Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4726-5
  a curric:KeyLearningPoint ;
  rdfs:label """Relative speed is the speed an object is moving towards or away from another object,
  which may also be moving."""@en ;
  dcterms:modified "2026-06-07T15:30:29.369509Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9903-1
  a curric:KeyLearningPoint ;
  rdfs:label "A velocity-time graph shows how velocity changes with time."@en ;
  dcterms:modified "2026-06-07T15:30:29.369529Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9903-2
  a curric:KeyLearningPoint ;
  rdfs:label "Acceleration is equal to the gradient of a velocity-time graph."@en ;
  dcterms:modified "2026-06-07T15:30:29.369535Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9903-3
  a curric:KeyLearningPoint ;
  rdfs:label """A falling line shows decreasing velocity called deceleration, which is a negative
  acceleration."""@en ;
  dcterms:modified "2026-06-07T15:30:29.369539Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9689-1
  a curric:KeyLearningPoint ;
  rdfs:label """In all chemical reactions, bonds in the reactants need to be broken before the
  reaction can happen"""@en ;
  dcterms:modified "2026-06-07T15:30:29.370212Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9689-2
  a curric:KeyLearningPoint ;
  rdfs:label "Energy must be supplied to break bonds in the reactants"@en ;
  dcterms:modified "2026-06-07T15:30:29.370216Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9689-3
  a curric:KeyLearningPoint ;
  rdfs:label "Energy is released when bonds in the products are formed"@en ;
  dcterms:modified "2026-06-07T15:30:29.370222Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9689-4
  a curric:KeyLearningPoint ;
  rdfs:label """The difference between the energy needed to break bonds and the energy released is
  the overall energy change"""@en ;
  dcterms:modified "2026-06-07T15:30:29.370226Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9680-1
  a curric:KeyLearningPoint ;
  rdfs:label """Carbon atoms will form up to four covalent bonds (as they will fill their outer
  shell with four more electrons)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.370230Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9680-2
  a curric:KeyLearningPoint ;
  rdfs:label """Carbon atoms can combine with other non-metal atoms to make a wide range of
  molecules, some with chains and rings."""@en ;
  dcterms:modified "2026-06-07T15:30:29.370234Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9680-3
  a curric:KeyLearningPoint ;
  rdfs:label "An organic compound contains two or more elements (including carbon)."@en ;
  dcterms:modified "2026-06-07T15:30:29.370238Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9680-4
  a curric:KeyLearningPoint ;
  rdfs:label "A lot of organic compounds also include hydrogen, oxygen and nitrogen."@en ;
  dcterms:modified "2026-06-07T15:30:29.370242Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9680-5
  a curric:KeyLearningPoint ;
  rdfs:label "Organic compounds can be found both in nature, but also produced synthetically."@en ;
  dcterms:modified "2026-06-07T15:30:29.370246Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5044-1
  a curric:KeyLearningPoint ;
  rdfs:label """Displacement at a point of a wave is the distance that the wave medium is from its
  rest position at that point."""@en ;
  dcterms:modified "2026-06-07T15:30:29.370250Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5044-2
  a curric:KeyLearningPoint ;
  rdfs:label "Amplitude is the maximum displacement of a wave (up or down, or side to side)."@en ;
  dcterms:modified "2026-06-07T15:30:29.370254Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5044-3
  a curric:KeyLearningPoint ;
  rdfs:label "A displacement-distance graph of a wave is not a picture of the wave."@en ;
  dcterms:modified "2026-06-07T15:30:29.370261Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5044-4
  a curric:KeyLearningPoint ;
  rdfs:label """The distance between two wave crests on a displacement-distance graph is equal to
  one wavelength."""@en ;
  dcterms:modified "2026-06-07T15:30:29.370266Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5044-5
  a curric:KeyLearningPoint ;
  rdfs:label """A positive (or negative) displacement shows part of the wave above (or below) the
  equilibrium position."""@en ;
  dcterms:modified "2026-06-07T15:30:29.370270Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8153-1
  a curric:KeyLearningPoint ;
  rdfs:label "Density is calculated using the equation: density = mass ÷ volume."@en ;
  dcterms:modified "2026-06-07T15:30:29.370274Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8153-2
  a curric:KeyLearningPoint ;
  rdfs:label "Density is measured in kg/m³ or g/cm³."@en ;
  dcterms:modified "2026-06-07T15:30:29.370278Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8153-3
  a curric:KeyLearningPoint ;
  rdfs:label """The volume of water displaced by a submerged object is equal to the volume of the
  object."""@en ;
  dcterms:modified "2026-06-07T15:30:29.370282Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8153-4
  a curric:KeyLearningPoint ;
  rdfs:label """The dimensions of a regular cuboid can be measured accurately with Vernier
  callipers."""@en ;
  dcterms:modified "2026-06-07T15:30:29.370286Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8153-5
  a curric:KeyLearningPoint ;
  rdfs:label """The volume of a regular cuboid is calculated using the equation: volume = length ×
  width × height."""@en ;
  dcterms:modified "2026-06-07T15:30:29.370289Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5074-1
  a curric:KeyLearningPoint ;
  rdfs:label "The magnetic field lines around a current-carrying wire are concentric circles"@en ;
  dcterms:modified "2026-06-07T15:30:29.370293Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5074-2
  a curric:KeyLearningPoint ;
  rdfs:label "In a uniform magnetic field, a current carrying wire is forced in one direction"@en ;
  dcterms:modified "2026-06-07T15:30:29.370297Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5074-3
  a curric:KeyLearningPoint ;
  rdfs:label """Fleming’s left–hand rule can be used to predict the direction of movement of a
  current–carrying wire in a magnetic field"""@en ;
  dcterms:modified "2026-06-07T15:30:29.370301Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5074-4
  a curric:KeyLearningPoint ;
  rdfs:label """The force on a current–carrying conductor at right angles to a magnetic field, F, is
  found using F = B I l."""@en ;
  dcterms:modified "2026-06-07T15:30:29.370305Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5074-5
  a curric:KeyLearningPoint ;
  rdfs:label """Opposite sides of a conducting coil in a uniform magnetic field are forced to move
  in opposite directions"""@en ;
  dcterms:modified "2026-06-07T15:30:29.370309Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9692-1
  a curric:KeyLearningPoint ;
  rdfs:label "Polymers are very large covalent molecules (not giant structures)"@en ;
  dcterms:modified "2026-06-07T15:30:29.371273Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9692-2
  a curric:KeyLearningPoint ;
  rdfs:label "Polymers can be represented by showing repeated units"@en ;
  dcterms:modified "2026-06-07T15:30:29.371276Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9692-3
  a curric:KeyLearningPoint ;
  rdfs:label "Polymers consist of repeating and identical sections called monomers"@en ;
  dcterms:modified "2026-06-07T15:30:29.371280Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9692-4
  a curric:KeyLearningPoint ;
  rdfs:label """Polymers are solid at room temperature because the intermolecular forces between
  polymer molecules are relatively strong"""@en ;
  dcterms:modified "2026-06-07T15:30:29.371286Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8409-1
  a curric:KeyLearningPoint ;
  rdfs:label """Catalysts, pressure, temperature & concentration of solutions can affect equilibrium
  position of a reversible reaction."""@en ;
  dcterms:modified "2026-06-07T15:30:29.371291Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8409-2
  a curric:KeyLearningPoint ;
  rdfs:label """If the conditions of a reversible reaction are changed, the equilibrium will move to
  counteract that change."""@en ;
  dcterms:modified "2026-06-07T15:30:29.371295Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8409-3
  a curric:KeyLearningPoint ;
  rdfs:label "A catalyst increases the rate at which equilibrium is achieved."@en ;
  dcterms:modified "2026-06-07T15:30:29.371299Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8409-4
  a curric:KeyLearningPoint ;
  rdfs:label """Increasing temperature increases the rate of both reactions; equilibrium shifts in
  favour of the endothermic reaction."""@en ;
  dcterms:modified "2026-06-07T15:30:29.371305Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8409-5
  a curric:KeyLearningPoint ;
  rdfs:label """Increasing the concentration or pressure of a substance increases the rate of
  reaction; equilibrium shifts in response."""@en ;
  dcterms:modified "2026-06-07T15:30:29.371309Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9623-1
  a curric:KeyLearningPoint ;
  rdfs:label "The periodic table is ordered by increasing atomic number (proton number)."@en ;
  dcterms:modified "2026-06-07T15:30:29.371359Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9623-2
  a curric:KeyLearningPoint ;
  rdfs:label "The periodic table is split into periods and groups."@en ;
  dcterms:modified "2026-06-07T15:30:29.371363Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9623-3
  a curric:KeyLearningPoint ;
  rdfs:label """The position of an element in the periodic table is linked to its atomic number and
  the arrangement of its electrons."""@en ;
  dcterms:modified "2026-06-07T15:30:29.371367Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9623-4
  a curric:KeyLearningPoint ;
  rdfs:label """Elements can be classed as metals or non-metals according to their position on the
  periodic table."""@en ;
  dcterms:modified "2026-06-07T15:30:29.371371Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9623-5
  a curric:KeyLearningPoint ;
  rdfs:label "A useful model for atoms arranges electrons in shells around the nucleus."@en ;
  dcterms:modified "2026-06-07T15:30:29.371375Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5047-1
  a curric:KeyLearningPoint ;
  rdfs:label "An oscilloscope is a displacement-time graph of a wave"@en ;
  dcterms:modified "2026-06-07T15:30:29.371420Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5047-2
  a curric:KeyLearningPoint ;
  rdfs:label """Connected to a microphone, an oscilloscope shows a displacement-time graph of a
  sound wave"""@en ;
  dcterms:modified "2026-06-07T15:30:29.371424Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5047-3
  a curric:KeyLearningPoint ;
  rdfs:label """The distance between two wave crests on an oscilloscope’s graph is equal to the
  period of the wave"""@en ;
  dcterms:modified "2026-06-07T15:30:29.371428Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5047-4
  a curric:KeyLearningPoint ;
  rdfs:label """The time period is measured most accurately by measuring the time for, say, 10 waves
  and dividing time by 10"""@en ;
  dcterms:modified "2026-06-07T15:30:29.371432Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5047-5
  a curric:KeyLearningPoint ;
  rdfs:label "The bigger the amplitude of a sound wave, the louder the sound"@en ;
  dcterms:modified "2026-06-07T15:30:29.371436Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9108-1
  a curric:KeyLearningPoint ;
  rdfs:label "A velocity-time graph shows how velocity changes with time."@en ;
  dcterms:modified "2026-06-07T15:30:29.371880Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9108-2
  a curric:KeyLearningPoint ;
  rdfs:label "Acceleration is equal to the gradient of a velocity-time graph."@en ;
  dcterms:modified "2026-06-07T15:30:29.371884Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9108-3
  a curric:KeyLearningPoint ;
  rdfs:label """A falling line shows decreasing velocity called deceleration, which is a negative
  acceleration."""@en ;
  dcterms:modified "2026-06-07T15:30:29.371888Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4731-1
  a curric:KeyLearningPoint ;
  rdfs:label "A dynamics trolley has a steady acceleration down a steep ramp."@en ;
  dcterms:modified "2026-06-07T15:30:29.371892Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4731-2
  a curric:KeyLearningPoint ;
  rdfs:label """Acceleration = change of velocity ÷ time and change in velocity = final velocity –
  initial velocity"""@en ;
  dcterms:modified "2026-06-07T15:30:29.371896Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4731-3
  a curric:KeyLearningPoint ;
  rdfs:label """Light gates can improve accuracy of measurement of instantaneous velocity and
  reduces random errors."""@en ;
  dcterms:modified "2026-06-07T15:30:29.371899Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4731-4
  a curric:KeyLearningPoint ;
  rdfs:label "For a fair test, total mass of the system must be kept constant."@en ;
  dcterms:modified "2026-06-07T15:30:29.371903Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4731-5
  a curric:KeyLearningPoint ;
  rdfs:label "A compensated ramp can counteract the effect of friction."@en ;
  dcterms:modified "2026-06-07T15:30:29.371907Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9153-1
  a curric:KeyLearningPoint ;
  rdfs:label "Electric charge, Q, is measured in coulombs (C)."@en ;
  dcterms:modified "2026-06-07T15:30:29.372100Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9153-2
  a curric:KeyLearningPoint ;
  rdfs:label """Electric current is a measure of the rate of flow of electric charge, calculated
  using: I = Q ÷ t."""@en ;
  dcterms:modified "2026-06-07T15:30:29.372105Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9153-3
  a curric:KeyLearningPoint ;
  rdfs:label """Potential difference is a measure of the energy transferred by each coulomb of
  charge, calculated using: V = E ÷ Q."""@en ;
  dcterms:modified "2026-06-07T15:30:29.372110Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9153-4
  a curric:KeyLearningPoint ;
  rdfs:label """Combining I = Q ÷ t and V = E ÷ Q gives the equation: E ÷ t = I × V. This is
  equivalent to P = I × V."""@en ;
  dcterms:modified "2026-06-07T15:30:29.372114Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9153-5
  a curric:KeyLearningPoint ;
  rdfs:label """Unknown variables in the power equation can often be calculated using: I = V
  ÷ R."""@en ;
  dcterms:modified "2026-06-07T15:30:29.372118Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9112-1
  a curric:KeyLearningPoint ;
  rdfs:label """Current can be calculated using the equation: current = p.d. ÷ resistance (I = V ÷
  R)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.372122Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9112-2
  a curric:KeyLearningPoint ;
  rdfs:label """The rules of current and p.d. for a parallel circuit can be applied to find some
  missing values of current and p.d."""@en ;
  dcterms:modified "2026-06-07T15:30:29.372126Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9112-3
  a curric:KeyLearningPoint ;
  rdfs:label """The equation I = V ÷ R can be rearranged so that either p.d. or R is the subject of
  the equation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.372130Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9112-4
  a curric:KeyLearningPoint ;
  rdfs:label """If any two values in the equation I = V ÷ R are known, the third can be
  calculated."""@en ;
  dcterms:modified "2026-06-07T15:30:29.372136Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9112-5
  a curric:KeyLearningPoint ;
  rdfs:label """If only one value in I = V ÷ R is shown for a component, circuit rules need to be
  applied to the rest of the circuit."""@en ;
  dcterms:modified "2026-06-07T15:30:29.372140Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4908-1
  a curric:KeyLearningPoint ;
  rdfs:label """Doubling the stiffness of a spring doubles the energy it has because it is
  stretched."""@en ;
  dcterms:modified "2026-06-07T15:30:29.372380Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4908-2
  a curric:KeyLearningPoint ;
  rdfs:label "The spring constant is measured in newtons per metre (N/m)."@en ;
  dcterms:modified "2026-06-07T15:30:29.372384Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4908-3
  a curric:KeyLearningPoint ;
  rdfs:label """Doubling the extension of a spring increases the energy it has because, it is
  stretched, by four times."""@en ;
  dcterms:modified "2026-06-07T15:30:29.372388Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4908-4
  a curric:KeyLearningPoint ;
  rdfs:label """The energy a spring has because it is stretched equals 1/2 × spring constant ×
  (extension)²."""@en ;
  dcterms:modified "2026-06-07T15:30:29.372392Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5097-1
  a curric:KeyLearningPoint ;
  rdfs:label """Power is the amount of energy transferred per second and is measured in
  watts (W)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.372396Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5097-2
  a curric:KeyLearningPoint ;
  rdfs:label """Power can be calculated using the equation: power = current × potential difference
  (P = I V)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.372399Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5097-3
  a curric:KeyLearningPoint ;
  rdfs:label """At a constant p.d., a larger electric current transfers energy more quickly than a
  smaller current."""@en ;
  dcterms:modified "2026-06-07T15:30:29.372403Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5097-4
  a curric:KeyLearningPoint ;
  rdfs:label """Domestic appliances plugged into the mains supply in the UK have a p.d. of 230 V
  across them."""@en ;
  dcterms:modified "2026-06-07T15:30:29.372409Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5097-5
  a curric:KeyLearningPoint ;
  rdfs:label """The fuse with the smallest rating for the required current (calculated using the
  equation: P = I² R) should be used."""@en ;
  dcterms:modified "2026-06-07T15:30:29.372414Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5050-1
  a curric:KeyLearningPoint ;
  rdfs:label "The speed of wave can be caluated using wave speed = frequency × wavelength."@en ;
  dcterms:modified "2026-06-07T15:30:29.372955Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5050-2
  a curric:KeyLearningPoint ;
  rdfs:label "The speed of a wave can be caluated using wave speed = distance ÷ time."@en ;
  dcterms:modified "2026-06-07T15:30:29.372962Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5050-3
  a curric:KeyLearningPoint ;
  rdfs:label """The choice of equation to use to caluate wave speed depends on the information
  provided in the question."""@en ;
  dcterms:modified "2026-06-07T15:30:29.372966Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5050-4
  a curric:KeyLearningPoint ;
  rdfs:label "Prefixes can be used with units to show very large or very small values."@en ;
  dcterms:modified "2026-06-07T15:30:29.372970Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5050-5
  a curric:KeyLearningPoint ;
  rdfs:label """The frequency of a wave does not change as it crosses a boundary from one wave
  medium into another."""@en ;
  dcterms:modified "2026-06-07T15:30:29.372974Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5046-1
  a curric:KeyLearningPoint ;
  rdfs:label """In a longitudinal wave, the oscillations / vibrations are in the same direction in
  which the wave travels."""@en ;
  dcterms:modified "2026-06-07T15:30:29.373689Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5046-2
  a curric:KeyLearningPoint ;
  rdfs:label """Displacement is the distance one part of a wave is moved away from its rest
  position."""@en ;
  dcterms:modified "2026-06-07T15:30:29.373694Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5046-3
  a curric:KeyLearningPoint ;
  rdfs:label """In a longitudinal wave, forwards displacement is positive and backwards displacement
  is negative."""@en ;
  dcterms:modified "2026-06-07T15:30:29.373703Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5046-4
  a curric:KeyLearningPoint ;
  rdfs:label """Wavelength of a longitudinal wave is the distance between one compression (or
  rarefaction) and the next."""@en ;
  dcterms:modified "2026-06-07T15:30:29.373708Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5557-1
  a curric:KeyLearningPoint ;
  rdfs:label """Interpretation of graphs showing data from an investigation of the effect of pH on
  the rate of an enzyme reaction."""@en ;
  dcterms:modified "2026-06-07T15:30:29.373880Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5557-2
  a curric:KeyLearningPoint ;
  rdfs:label """Consideration of whether the data increase or decrease confidence in the original
  prediction or hypothesis."""@en ;
  dcterms:modified "2026-06-07T15:30:29.373884Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5557-3
  a curric:KeyLearningPoint ;
  rdfs:label """Enzyme reaction rate is highest at an optimum pH, at which all active sites are
  full."""@en ;
  dcterms:modified "2026-06-07T15:30:29.373888Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5557-4
  a curric:KeyLearningPoint ;
  rdfs:label """Enzyme reaction rate decreases at pH values below and above the optimum as the
  active site becomes denatured."""@en ;
  dcterms:modified "2026-06-07T15:30:29.373892Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9670-1
  a curric:KeyLearningPoint ;
  rdfs:label """Concentration of an aqueous solution is the mass of solute dissolved in 1 dm³ of
  distilled water, in g/dm³."""@en ;
  dcterms:modified "2026-06-07T15:30:29.374364Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9670-2
  a curric:KeyLearningPoint ;
  rdfs:label """The mass of one mole of solute is equal to the relative mass of the solute measured
  in grams."""@en ;
  dcterms:modified "2026-06-07T15:30:29.374368Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9670-3
  a curric:KeyLearningPoint ;
  rdfs:label "Concentration can be expressed in g/dm³ or mol/dm³."@en ;
  dcterms:modified "2026-06-07T15:30:29.374372Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9670-4
  a curric:KeyLearningPoint ;
  rdfs:label """Equal volumes of solutions of the same concentration (in mol/dm³) have equal numbers
  of dissolved solute particles."""@en ;
  dcterms:modified "2026-06-07T15:30:29.374378Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9670-5
  a curric:KeyLearningPoint ;
  rdfs:label "Volume can be measured in various units; 1 dm³ is equivalent to 1000 cm³."@en ;
  dcterms:modified "2026-06-07T15:30:29.374382Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7981-1
  a curric:KeyLearningPoint ;
  rdfs:label """Most characteristics are influenced by multiple genes, but some are determined by
  just one."""@en ;
  dcterms:modified "2026-06-07T15:30:29.374626Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7981-2
  a curric:KeyLearningPoint ;
  rdfs:label """An individual will inherit two alleles for each gene, the alleles for a gene may be
  dominant or recessive."""@en ;
  dcterms:modified "2026-06-07T15:30:29.374630Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7981-3
  a curric:KeyLearningPoint ;
  rdfs:label """A Punnett square models inheritance of alleles showing possible genotypes of
  offspring as homozygous or heterozygous."""@en ;
  dcterms:modified "2026-06-07T15:30:29.374634Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7981-4
  a curric:KeyLearningPoint ;
  rdfs:label """Punnett squares are used to predict proportion of genotypes/phenotypes, or
  probability of occurrence in the offspring."""@en ;
  dcterms:modified "2026-06-07T15:30:29.374640Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7981-5
  a curric:KeyLearningPoint ;
  rdfs:label """Each instance of sexual reproduction is independent, so does not affect the
  probability for subsequent offspring."""@en ;
  dcterms:modified "2026-06-07T15:30:29.374644Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9095-1
  a curric:KeyLearningPoint ;
  rdfs:label """The particles in liquids and gases move very quickly and randomly in every
  direction; they are both fluids."""@en ;
  dcterms:modified "2026-06-07T15:30:29.374648Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9095-2
  a curric:KeyLearningPoint ;
  rdfs:label """Particles in liquids are very close together; the gaps between particles in gases
  are much larger than the particles."""@en ;
  dcterms:modified "2026-06-07T15:30:29.374652Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9095-3
  a curric:KeyLearningPoint ;
  rdfs:label "The pressure at any point in a fluid is the same size in every direction."@en ;
  dcterms:modified "2026-06-07T15:30:29.374656Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9095-4
  a curric:KeyLearningPoint ;
  rdfs:label "The particles in a fluid exert pressure on a surface by colliding with it."@en ;
  dcterms:modified "2026-06-07T15:30:29.374660Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9095-5
  a curric:KeyLearningPoint ;
  rdfs:label "Pressure is calculated using the equation: pressure = force ÷ surface area."@en ;
  dcterms:modified "2026-06-07T15:30:29.374664Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20342-1
  a curric:KeyLearningPoint ;
  rdfs:label "A dynamics trolley has a steady acceleration down a steep ramp."@en ;
  dcterms:modified "2026-06-07T15:30:29.374670Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20342-2
  a curric:KeyLearningPoint ;
  rdfs:label """Acceleration = change of velocity ÷ time and change in velocity = final velocity –
  initial velocity"""@en ;
  dcterms:modified "2026-06-07T15:30:29.374675Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20342-3
  a curric:KeyLearningPoint ;
  rdfs:label """Light gates can improve accuracy of measurement of instantaneous velocity and
  reduces random errors."""@en ;
  dcterms:modified "2026-06-07T15:30:29.374679Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20342-4
  a curric:KeyLearningPoint ;
  rdfs:label "For a fair test, total mass of the system must be kept constant."@en ;
  dcterms:modified "2026-06-07T15:30:29.374683Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20342-5
  a curric:KeyLearningPoint ;
  rdfs:label "A compensated ramp can counteract the effect of friction."@en ;
  dcterms:modified "2026-06-07T15:30:29.374686Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5552-1
  a curric:KeyLearningPoint ;
  rdfs:label """All carbohydrates, proteins and lipids are made of the elements carbon, hydrogen and
  oxygen."""@en ;
  dcterms:modified "2026-06-07T15:30:29.374691Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5552-2
  a curric:KeyLearningPoint ;
  rdfs:label "All proteins and some lipids also contain the element nitrogen."@en ;
  dcterms:modified "2026-06-07T15:30:29.374695Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5552-3
  a curric:KeyLearningPoint ;
  rdfs:label """Producers obtain carbon and oxygen from the air, hydrogen from water, and nitrogen
  from the soil."""@en ;
  dcterms:modified "2026-06-07T15:30:29.374699Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5552-4
  a curric:KeyLearningPoint ;
  rdfs:label """Consumers cannot use carbon from carbon dioxide in air to make biological molecules;
  only producers can do that."""@en ;
  dcterms:modified "2026-06-07T15:30:29.374703Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5552-5
  a curric:KeyLearningPoint ;
  rdfs:label """Consumers absorb oxygen from the air but get all their carbon and nitrogen by eating
  producers."""@en ;
  dcterms:modified "2026-06-07T15:30:29.374706Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5098-1
  a curric:KeyLearningPoint ;
  rdfs:label "Electric charge, Q, is measured in coulombs (C)."@en ;
  dcterms:modified "2026-06-07T15:30:29.374747Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5098-2
  a curric:KeyLearningPoint ;
  rdfs:label """Electric current is a measure of the rate of flow of electric charge, calculated
  using: I = Q ÷ t."""@en ;
  dcterms:modified "2026-06-07T15:30:29.374752Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5098-3
  a curric:KeyLearningPoint ;
  rdfs:label """Potential difference is a measure of the energy transferred by each coulomb of
  charge, calculated using: V = E ÷ Q."""@en ;
  dcterms:modified "2026-06-07T15:30:29.374756Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5098-4
  a curric:KeyLearningPoint ;
  rdfs:label """Combining I = Q ÷ t and V = E ÷ Q gives the equation: E ÷ t = I × V. This is
  equivalent to P = I × V."""@en ;
  dcterms:modified "2026-06-07T15:30:29.374759Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5098-5
  a curric:KeyLearningPoint ;
  rdfs:label """Unknown variables in the power equation can often be calculated using: I = V
  ÷ R."""@en ;
  dcterms:modified "2026-06-07T15:30:29.374763Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9724-1
  a curric:KeyLearningPoint ;
  rdfs:label """The ozone layer protects life from harmful ultraviolet (UV) radiation from
  the Sun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.374892Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9724-2
  a curric:KeyLearningPoint ;
  rdfs:label """Chlorofluorocarbons (CFCs) were once used, and when they entered our atmosphere
  reacted with ozone (O₃)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.374896Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9724-3
  a curric:KeyLearningPoint ;
  rdfs:label """Ozone levels decreased, but scientific communication led to action being taken to
  prevent further loss of ozone."""@en ;
  dcterms:modified "2026-06-07T15:30:29.374899Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9724-4
  a curric:KeyLearningPoint ;
  rdfs:label "The work of analytical scientists suggests the ozone layer is now reforming."@en ;
  dcterms:modified "2026-06-07T15:30:29.374905Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9902-1
  a curric:KeyLearningPoint ;
  rdfs:label "A dynamics trolley has a steady acceleration down a steep ramp."@en ;
  dcterms:modified "2026-06-07T15:30:29.376070Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9902-2
  a curric:KeyLearningPoint ;
  rdfs:label """Acceleration = change of velocity ÷ time and change in velocity = final velocity –
  initial velocity"""@en ;
  dcterms:modified "2026-06-07T15:30:29.376074Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9902-3
  a curric:KeyLearningPoint ;
  rdfs:label """Light gates can improve accuracy of measurement of instantaneous velocity and
  reduces random errors."""@en ;
  dcterms:modified "2026-06-07T15:30:29.376077Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9902-4
  a curric:KeyLearningPoint ;
  rdfs:label "For a fair test, total mass of the system must be kept constant."@en ;
  dcterms:modified "2026-06-07T15:30:29.376081Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9902-5
  a curric:KeyLearningPoint ;
  rdfs:label "A compensated ramp can counteract the effect of friction."@en ;
  dcterms:modified "2026-06-07T15:30:29.376085Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20425-1
  a curric:KeyLearningPoint ;
  rdfs:label "Calorimetry can be used to measure a reaction's energy change indirectly."@en ;
  dcterms:modified "2026-06-07T15:30:29.376971Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20425-2
  a curric:KeyLearningPoint ;
  rdfs:label """Calorimetry data can be used to calculate the mass of alcohol needed to cause a 1°C
  rise in temperature of the water."""@en ;
  dcterms:modified "2026-06-07T15:30:29.376975Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20425-3
  a curric:KeyLearningPoint ;
  rdfs:label """An alcohol that causes a 1°C temperature rise when the least amount is combusted is
  releasing the most energy."""@en ;
  dcterms:modified "2026-06-07T15:30:29.376980Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20425-4
  a curric:KeyLearningPoint ;
  rdfs:label """The energy change of combustion for a variety of alcohols can be compared to the
  molecular formula of each alcohol."""@en ;
  dcterms:modified "2026-06-07T15:30:29.376985Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9106-1
  a curric:KeyLearningPoint ;
  rdfs:label "The velocity of an object is equal to the gradient of a displacement-time graph."@en ;
  dcterms:modified "2026-06-07T15:30:29.377532Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9106-2
  a curric:KeyLearningPoint ;
  rdfs:label "A direction in which velocity and displacement are measured needs to be chosen."@en ;
  dcterms:modified "2026-06-07T15:30:29.377536Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9106-3
  a curric:KeyLearningPoint ;
  rdfs:label """A negative gradient on a displacement-time graph (sloping downwards) represents
  velocity in the opposite direction."""@en ;
  dcterms:modified "2026-06-07T15:30:29.377540Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9106-4
  a curric:KeyLearningPoint ;
  rdfs:label """A negative value for displacement represents a position ‘behind’ the starting
  position."""@en ;
  dcterms:modified "2026-06-07T15:30:29.377544Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9109-1
  a curric:KeyLearningPoint ;
  rdfs:label "A velocity-time graph shows how velocity changes with time."@en ;
  dcterms:modified "2026-06-07T15:30:29.377886Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9109-2
  a curric:KeyLearningPoint ;
  rdfs:label "Acceleration is equal to the gradient of a velocity-time graph."@en ;
  dcterms:modified "2026-06-07T15:30:29.377890Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9109-3
  a curric:KeyLearningPoint ;
  rdfs:label """A falling line shows decreasing velocity called deceleration, which is a negative
  acceleration."""@en ;
  dcterms:modified "2026-06-07T15:30:29.377894Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9109-4
  a curric:KeyLearningPoint ;
  rdfs:label "The gradient of the line gives the instantaneous acceleration."@en ;
  dcterms:modified "2026-06-07T15:30:29.377898Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9109-5
  a curric:KeyLearningPoint ;
  rdfs:label "The distance travelled is equal to the area under a velocity-time graph."@en ;
  dcterms:modified "2026-06-07T15:30:29.377902Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20086-1
  a curric:KeyLearningPoint ;
  rdfs:label "The periodic table is ordered by increasing atomic number (proton number)."@en ;
  dcterms:modified "2026-06-07T15:30:29.377906Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20086-2
  a curric:KeyLearningPoint ;
  rdfs:label "The periodic table is split into periods and groups."@en ;
  dcterms:modified "2026-06-07T15:30:29.377910Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20086-3
  a curric:KeyLearningPoint ;
  rdfs:label """The position of an element in the periodic table is linked to its atomic number and
  the arrangement of its electrons."""@en ;
  dcterms:modified "2026-06-07T15:30:29.377914Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20086-4
  a curric:KeyLearningPoint ;
  rdfs:label """Elements can be classed as metals or non-metals according to their position on the
  periodic table."""@en ;
  dcterms:modified "2026-06-07T15:30:29.377918Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20086-5
  a curric:KeyLearningPoint ;
  rdfs:label "A useful model for atoms arranges electrons in shells around the nucleus."@en ;
  dcterms:modified "2026-06-07T15:30:29.377922Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9897-1
  a curric:KeyLearningPoint ;
  rdfs:label "The velocity of an object is equal to the gradient of a displacement-time graph."@en ;
  dcterms:modified "2026-06-07T15:30:29.379107Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9897-2
  a curric:KeyLearningPoint ;
  rdfs:label "A direction in which velocity and displacement are measured needs to be chosen."@en ;
  dcterms:modified "2026-06-07T15:30:29.379111Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9897-3
  a curric:KeyLearningPoint ;
  rdfs:label """A negative gradient on a displacement-time graph (sloping downwards) represents
  velocity in the opposite direction."""@en ;
  dcterms:modified "2026-06-07T15:30:29.379115Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9897-4
  a curric:KeyLearningPoint ;
  rdfs:label """A negative value for displacement represents a position ‘behind’ the starting
  position."""@en ;
  dcterms:modified "2026-06-07T15:30:29.379119Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4914-1
  a curric:KeyLearningPoint ;
  rdfs:label "A free body diagram shows all of the forces acting on a single object"@en ;
  dcterms:modified "2026-06-07T15:30:29.379197Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4914-2
  a curric:KeyLearningPoint ;
  rdfs:label """The resultant of two forces can be determined by adding individual forces on a
  vector diagram"""@en ;
  dcterms:modified "2026-06-07T15:30:29.379201Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4914-3
  a curric:KeyLearningPoint ;
  rdfs:label """The resultant of two perpendicular forces is in a different direction from either of
  these forces"""@en ;
  dcterms:modified "2026-06-07T15:30:29.379205Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4914-4
  a curric:KeyLearningPoint ;
  rdfs:label """A single force can be resolved into two components acting at right angles to each
  other"""@en ;
  dcterms:modified "2026-06-07T15:30:29.379209Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4914-5
  a curric:KeyLearningPoint ;
  rdfs:label "The two component forces together have the same effect as the single force"@en ;
  dcterms:modified "2026-06-07T15:30:29.379213Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5038-1
  a curric:KeyLearningPoint ;
  rdfs:label """Current can be calculated using the equation: current = p.d. ÷ resistance (I = V ÷
  R)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.379805Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5038-2
  a curric:KeyLearningPoint ;
  rdfs:label """The rules of current and p.d. for a series circuit can be applied to find some
  missing values of current and p.d."""@en ;
  dcterms:modified "2026-06-07T15:30:29.379809Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5038-3
  a curric:KeyLearningPoint ;
  rdfs:label """The equation I = V ÷ R can be rearranged so that either V or R is the subject of the
  equation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.379813Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5038-4
  a curric:KeyLearningPoint ;
  rdfs:label """If any two values in the equation I = V ÷ R are known, the third can be
  calculated."""@en ;
  dcterms:modified "2026-06-07T15:30:29.379817Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5038-5
  a curric:KeyLearningPoint ;
  rdfs:label """If only one value in the equation I = V ÷ R is known, rules for current or p.d. need
  to be applied to find a second."""@en ;
  dcterms:modified "2026-06-07T15:30:29.379821Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5040-1
  a curric:KeyLearningPoint ;
  rdfs:label """Current can be calculated using the equation: current = p.d. ÷ resistance (I = V ÷
  R)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.379825Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5040-2
  a curric:KeyLearningPoint ;
  rdfs:label """The rules of current and p.d. for a parallel circuit can be applied to find some
  missing values of current and p.d."""@en ;
  dcterms:modified "2026-06-07T15:30:29.379829Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5040-3
  a curric:KeyLearningPoint ;
  rdfs:label """The equation I = V ÷ R can be rearranged so that either p.d. or R is the subject of
  the equation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.379833Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5040-4
  a curric:KeyLearningPoint ;
  rdfs:label """If any two values in the equation I = V ÷ R are known, the third can be
  calculated."""@en ;
  dcterms:modified "2026-06-07T15:30:29.379837Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5040-5
  a curric:KeyLearningPoint ;
  rdfs:label """If only one value in I = V ÷ R is shown for a component, circuit rules need to be
  applied to the rest of the circuit."""@en ;
  dcterms:modified "2026-06-07T15:30:29.379841Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8191-1
  a curric:KeyLearningPoint ;
  rdfs:label "DNA is a type of biological molecule called a nucleic acid."@en ;
  dcterms:modified "2026-06-07T15:30:29.379955Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8191-2
  a curric:KeyLearningPoint ;
  rdfs:label "DNA is made of two strands, each a long polymer of nucleotides."@en ;
  dcterms:modified "2026-06-07T15:30:29.379959Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8191-3
  a curric:KeyLearningPoint ;
  rdfs:label "DNA is a polymer of four different nucleotides (A, C, G and T)."@en ;
  dcterms:modified "2026-06-07T15:30:29.379963Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8191-4
  a curric:KeyLearningPoint ;
  rdfs:label "The two strands in DNA are wound together in a double helix shape."@en ;
  dcterms:modified "2026-06-07T15:30:29.379967Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8191-5
  a curric:KeyLearningPoint ;
  rdfs:label "Making a physical, representational model of DNA."@en ;
  dcterms:modified "2026-06-07T15:30:29.379971Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4905-1
  a curric:KeyLearningPoint ;
  rdfs:label """A spring is elastically deformed if it returns to its original shape after the
  applied force is removed"""@en ;
  dcterms:modified "2026-06-07T15:30:29.380625Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4905-2
  a curric:KeyLearningPoint ;
  rdfs:label """A spring is inelastically deformed if it does not return to its original shape after
  the applied force is removed"""@en ;
  dcterms:modified "2026-06-07T15:30:29.380629Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4905-3
  a curric:KeyLearningPoint ;
  rdfs:label """Elastic deformation is proportional to the force applied to stretch or compress a
  spring"""@en ;
  dcterms:modified "2026-06-07T15:30:29.380633Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4905-4
  a curric:KeyLearningPoint ;
  rdfs:label """The spring constant (k) is the force needed to extend or compress an elastic object
  by one metre"""@en ;
  dcterms:modified "2026-06-07T15:30:29.380637Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4905-5
  a curric:KeyLearningPoint ;
  rdfs:label "Force on a spring = spring constant × extension"@en ;
  dcterms:modified "2026-06-07T15:30:29.380641Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27630-1
  a curric:KeyLearningPoint ;
  rdfs:label """Process data to calculate the volume of gas collected in the measuring cylinder, and
  the mean of repeat measurements."""@en ;
  dcterms:modified "2026-06-07T15:30:29.380755Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27630-2
  a curric:KeyLearningPoint ;
  rdfs:label """Calculate the rate of respiration by dividing the volume of gas collected in the
  measuring cylinder by the time."""@en ;
  dcterms:modified "2026-06-07T15:30:29.380758Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27630-3
  a curric:KeyLearningPoint ;
  rdfs:label "Use appropriate units for the rate of cellular respiration."@en ;
  dcterms:modified "2026-06-07T15:30:29.380762Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27630-4
  a curric:KeyLearningPoint ;
  rdfs:label """Compare the rate of respiration in yeast given different substrates, and describe
  trends in the data."""@en ;
  dcterms:modified "2026-06-07T15:30:29.380766Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27630-5
  a curric:KeyLearningPoint ;
  rdfs:label """Use ideas about enzymes and active sites to explain the effect of different
  substrates on the rate of respiration."""@en ;
  dcterms:modified "2026-06-07T15:30:29.380770Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7993-1
  a curric:KeyLearningPoint ;
  rdfs:label """Genetic engineering involves modifying the genome of an organism by adding DNA from
  another organism."""@en ;
  dcterms:modified "2026-06-07T15:30:29.380774Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7993-2
  a curric:KeyLearningPoint ;
  rdfs:label "The aim of genetic engineering is to introduce a desirable characteristic."@en ;
  dcterms:modified "2026-06-07T15:30:29.380778Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7993-3
  a curric:KeyLearningPoint ;
  rdfs:label "Examples of genetically engineering crop plants and bacteria to benefit humans."@en ;
  dcterms:modified "2026-06-07T15:30:29.380782Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7993-4
  a curric:KeyLearningPoint ;
  rdfs:label "Benefits must be weighed against risks and ethical questions."@en ;
  dcterms:modified "2026-06-07T15:30:29.380786Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20050-1
  a curric:KeyLearningPoint ;
  rdfs:label """The rate of a reaction is the amount of change (e.g. substrate broken down or
  product made) per unit of time."""@en ;
  dcterms:modified "2026-06-07T15:30:29.382620Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20050-2
  a curric:KeyLearningPoint ;
  rdfs:label """Enzyme reaction rate increases as substrate concentration increases, until an
  optimum when all active sites are full."""@en ;
  dcterms:modified "2026-06-07T15:30:29.382624Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20050-3
  a curric:KeyLearningPoint ;
  rdfs:label """Enzyme reaction rate increases with temperature due to more collisions, until an
  optimum when all active sites are full."""@en ;
  dcterms:modified "2026-06-07T15:30:29.382630Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20050-4
  a curric:KeyLearningPoint ;
  rdfs:label """Enzyme rate decreases as temperature increases above the optimum as bonds break and
  the active site becomes denatured."""@en ;
  dcterms:modified "2026-06-07T15:30:29.382634Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20050-5
  a curric:KeyLearningPoint ;
  rdfs:label """Interpretation of graphs showing effects of substrate concentration and temperature
  on enzyme reaction rate."""@en ;
  dcterms:modified "2026-06-07T15:30:29.382638Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9941-1
  a curric:KeyLearningPoint ;
  rdfs:label """A spring is elastically deformed if it returns to its original shape after the
  applied force is removed"""@en ;
  dcterms:modified "2026-06-07T15:30:29.383011Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9941-2
  a curric:KeyLearningPoint ;
  rdfs:label """A spring is inelastically deformed if it does not return to its original shape after
  the applied force is removed"""@en ;
  dcterms:modified "2026-06-07T15:30:29.383015Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9941-3
  a curric:KeyLearningPoint ;
  rdfs:label """Elastic deformation is proportional to the force applied to stretch or compress a
  spring"""@en ;
  dcterms:modified "2026-06-07T15:30:29.383019Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9941-4
  a curric:KeyLearningPoint ;
  rdfs:label """The spring constant (k) is the force needed to extend or compress an elastic object
  by one metre"""@en ;
  dcterms:modified "2026-06-07T15:30:29.383023Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9941-5
  a curric:KeyLearningPoint ;
  rdfs:label "Force on a spring = spring constant × extension"@en ;
  dcterms:modified "2026-06-07T15:30:29.383027Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9624-1
  a curric:KeyLearningPoint ;
  rdfs:label """There are five different types of substance: monatomic, simple covalent (molecules),
  giant covalent, ionic and metallic"""@en ;
  dcterms:modified "2026-06-07T15:30:29.383840Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9624-2
  a curric:KeyLearningPoint ;
  rdfs:label """The outer shell in most atoms can hold 8 electrons but, in hydrogen and helium, it
  can only hold 2 electrons."""@en ;
  dcterms:modified "2026-06-07T15:30:29.383846Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9624-3
  a curric:KeyLearningPoint ;
  rdfs:label """Most atoms increase their stability by forming bonds with other atoms so that they
  have a full outer shell of electrons."""@en ;
  dcterms:modified "2026-06-07T15:30:29.383850Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9624-4
  a curric:KeyLearningPoint ;
  rdfs:label "Some atoms will share electrons with other atoms to increase their stability."@en ;
  dcterms:modified "2026-06-07T15:30:29.383856Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9624-5
  a curric:KeyLearningPoint ;
  rdfs:label """Some atoms will lose or gain electrons to increase stability forming cations or
  anions, respectively."""@en ;
  dcterms:modified "2026-06-07T15:30:29.383860Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9118-1
  a curric:KeyLearningPoint ;
  rdfs:label """Doubling the stiffness of a spring doubles the energy it has because it is
  stretched."""@en ;
  dcterms:modified "2026-06-07T15:30:29.385002Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9118-2
  a curric:KeyLearningPoint ;
  rdfs:label "The spring constant is measured in newtons per metre (N/m)."@en ;
  dcterms:modified "2026-06-07T15:30:29.385006Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9118-3
  a curric:KeyLearningPoint ;
  rdfs:label """Doubling the extension of a spring increases the energy it has, because it is
  stretched, by four times."""@en ;
  dcterms:modified "2026-06-07T15:30:29.385009Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9118-4
  a curric:KeyLearningPoint ;
  rdfs:label """The energy a spring has because it is stretched equals 1/2 × spring constant ×
  (extension)²."""@en ;
  dcterms:modified "2026-06-07T15:30:29.385013Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4906-1
  a curric:KeyLearningPoint ;
  rdfs:label """A spring is elastically deformed if it returns to its original shape after the
  applied force is removed"""@en ;
  dcterms:modified "2026-06-07T15:30:29.388433Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4906-2
  a curric:KeyLearningPoint ;
  rdfs:label """A spring is inelastically deformed if it does not return to its original shape after
  the applied force is removed"""@en ;
  dcterms:modified "2026-06-07T15:30:29.388437Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4906-3
  a curric:KeyLearningPoint ;
  rdfs:label """Elastic deformation is proportional to the force applied to stretch or compress a
  spring"""@en ;
  dcterms:modified "2026-06-07T15:30:29.388440Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4906-4
  a curric:KeyLearningPoint ;
  rdfs:label """The spring constant (k) is the force needed to extend or compress an elastic object
  by one metre"""@en ;
  dcterms:modified "2026-06-07T15:30:29.388444Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4906-5
  a curric:KeyLearningPoint ;
  rdfs:label "Force on a spring = spring constant × extension"@en ;
  dcterms:modified "2026-06-07T15:30:29.388448Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9745-1
  a curric:KeyLearningPoint ;
  rdfs:label """Some metal ions form coloured precipitates in a reaction with sodium hydroxide
  solution."""@en ;
  dcterms:modified "2026-06-07T15:30:29.388452Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9745-2
  a curric:KeyLearningPoint ;
  rdfs:label """Ammonium ions can be identified by heating with NaOH and using damp red litmus
  paper, which turns blue if positive."""@en ;
  dcterms:modified "2026-06-07T15:30:29.388458Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9745-3
  a curric:KeyLearningPoint ;
  rdfs:label """A dilute acid is usually added before testing for carbonates, sulfates or halides to
  avoid false positives."""@en ;
  dcterms:modified "2026-06-07T15:30:29.388462Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9745-4
  a curric:KeyLearningPoint ;
  rdfs:label """Halide ions produce different coloured precipitates when silver nitrate is added to
  a solution containing them."""@en ;
  dcterms:modified "2026-06-07T15:30:29.388466Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9745-5
  a curric:KeyLearningPoint ;
  rdfs:label """A white precipitate is formed when barium chloride is added to an acidified solution
  containing sulfate ions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.388470Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9904-1
  a curric:KeyLearningPoint ;
  rdfs:label "A velocity-time graph shows how velocity changes with time."@en ;
  dcterms:modified "2026-06-07T15:30:29.388922Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9904-2
  a curric:KeyLearningPoint ;
  rdfs:label "Acceleration is equal to the gradient of a velocity-time graph."@en ;
  dcterms:modified "2026-06-07T15:30:29.388926Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9904-3
  a curric:KeyLearningPoint ;
  rdfs:label """A falling line shows decreasing velocity called deceleration, which is a negative
  acceleration."""@en ;
  dcterms:modified "2026-06-07T15:30:29.388930Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9904-4
  a curric:KeyLearningPoint ;
  rdfs:label "The gradient of the line gives the instantaneous acceleration."@en ;
  dcterms:modified "2026-06-07T15:30:29.388934Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9904-5
  a curric:KeyLearningPoint ;
  rdfs:label "The distance travelled is equal to the area under a velocity-time graph."@en ;
  dcterms:modified "2026-06-07T15:30:29.388940Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9656-1
  a curric:KeyLearningPoint ;
  rdfs:label """All the atoms in the reactants of a chemical reaction are reorganised to form all
  the products of the reaction."""@en ;
  dcterms:modified "2026-06-07T15:30:29.394344Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9656-2
  a curric:KeyLearningPoint ;
  rdfs:label """There must be an equal number of each type of atom on both the reactant and product
  side of the equation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.394348Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9656-3
  a curric:KeyLearningPoint ;
  rdfs:label """Chemical formulae cannot be altered to balance a reaction equation; only
  coefficients can change."""@en ;
  dcterms:modified "2026-06-07T15:30:29.394352Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9656-4
  a curric:KeyLearningPoint ;
  rdfs:label """Atoms cannot be created or destroyed. During a chemical reaction, atoms are simply
  rearranged into products."""@en ;
  dcterms:modified "2026-06-07T15:30:29.394356Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6585-1
  a curric:KeyLearningPoint ;
  rdfs:label "In a fair test, only the (independent) variable being investigated is changed"@en ;
  dcterms:modified "2026-06-07T15:30:29.394360Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6585-2
  a curric:KeyLearningPoint ;
  rdfs:label """The dependent variable is measured to investigate the effect of changing the
  independent variable"""@en ;
  dcterms:modified "2026-06-07T15:30:29.394363Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6585-3
  a curric:KeyLearningPoint ;
  rdfs:label """Control variables are other factors that could be changed, but are kept the same in
  order not to affect the results"""@en ;
  dcterms:modified "2026-06-07T15:30:29.394367Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6585-4
  a curric:KeyLearningPoint ;
  rdfs:label """The greater the intensity of black ink, the more easily a surface absorbs
  infrared"""@en ;
  dcterms:modified "2026-06-07T15:30:29.394371Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8313-1
  a curric:KeyLearningPoint ;
  rdfs:label "The atomic model has changed over time."@en ;
  dcterms:modified "2026-06-07T15:30:29.395485Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8313-2
  a curric:KeyLearningPoint ;
  rdfs:label """Dalton, Thomson, Rutherford (Geiger and Marsden), Bohr and Chadwick have all
  suggested atomic models."""@en ;
  dcterms:modified "2026-06-07T15:30:29.395488Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8313-3
  a curric:KeyLearningPoint ;
  rdfs:label """The plum pudding model of the atom and the nuclear model are two important models in
  the history of the atom's discovery"""@en ;
  dcterms:modified "2026-06-07T15:30:29.395492Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8313-4
  a curric:KeyLearningPoint ;
  rdfs:label "New evidence from the scattering experiment led to a change in the atomic model."@en ;
  dcterms:modified "2026-06-07T15:30:29.395496Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8378-1
  a curric:KeyLearningPoint ;
  rdfs:label """The changing rate of a chemical reaction can be represented by a graph of volume of
  gas produced against time."""@en ;
  dcterms:modified "2026-06-07T15:30:29.396867Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8378-2
  a curric:KeyLearningPoint ;
  rdfs:label """When reacting excess acid, the same volume of gas is produced for equal amounts of
  magnesium."""@en ;
  dcterms:modified "2026-06-07T15:30:29.396871Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8378-3
  a curric:KeyLearningPoint ;
  rdfs:label "Doubling the concentration doubles the rate of reaction."@en ;
  dcterms:modified "2026-06-07T15:30:29.396875Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8378-4
  a curric:KeyLearningPoint ;
  rdfs:label """The gradient of a rate of reaction graph can be calculated from a tangent drawn at a
  point on the curve."""@en ;
  dcterms:modified "2026-06-07T15:30:29.396879Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8370-1
  a curric:KeyLearningPoint ;
  rdfs:label """Electric cells contain a store of chemicals that react to produce a voltage across
  two electrical contacts."""@en ;
  dcterms:modified "2026-06-07T15:30:29.396925Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8370-2
  a curric:KeyLearningPoint ;
  rdfs:label """An electric cell made of two different metals in contact with an electrolyte,
  produces a voltage across the metals."""@en ;
  dcterms:modified "2026-06-07T15:30:29.396929Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8370-3
  a curric:KeyLearningPoint ;
  rdfs:label """The size of voltage across an electric cell depends on the materials it is made
  from."""@en ;
  dcterms:modified "2026-06-07T15:30:29.396933Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8370-4
  a curric:KeyLearningPoint ;
  rdfs:label """A battery is made of one or more electric cells, which can be connected in series to
  produce a larger voltage."""@en ;
  dcterms:modified "2026-06-07T15:30:29.396937Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8370-5
  a curric:KeyLearningPoint ;
  rdfs:label """The chemical reaction in a rechargeable battery is reversed when an external voltage
  is connected across it."""@en ;
  dcterms:modified "2026-06-07T15:30:29.396941Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8169-1
  a curric:KeyLearningPoint ;
  rdfs:label "A free body diagram shows all of the forces acting on a single object."@en ;
  dcterms:modified "2026-06-07T15:30:29.398131Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8169-2
  a curric:KeyLearningPoint ;
  rdfs:label """The resultant of two forces can be determined by adding individual forces on a
  vector diagram."""@en ;
  dcterms:modified "2026-06-07T15:30:29.398135Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8169-3
  a curric:KeyLearningPoint ;
  rdfs:label """The resultant of two perpendicular forces is in a different direction from either of
  these forces."""@en ;
  dcterms:modified "2026-06-07T15:30:29.398139Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7984-1
  a curric:KeyLearningPoint ;
  rdfs:label "Growth is part of the life cycle of all living organisms."@en ;
  dcterms:modified "2026-06-07T15:30:29.398206Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7984-2
  a curric:KeyLearningPoint ;
  rdfs:label "Multicellular organisms grow by making new cells."@en ;
  dcterms:modified "2026-06-07T15:30:29.398210Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7984-3
  a curric:KeyLearningPoint ;
  rdfs:label "Multicellular organisms need to repair tissue through cell division."@en ;
  dcterms:modified "2026-06-07T15:30:29.398213Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7984-4
  a curric:KeyLearningPoint ;
  rdfs:label """All new cells are made when existing cells copy their genetic material and then
  divide in two."""@en ;
  dcterms:modified "2026-06-07T15:30:29.398217Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6609-1
  a curric:KeyLearningPoint ;
  rdfs:label "All magnets have a north–seeking pole and a south–seeking pole."@en ;
  dcterms:modified "2026-06-07T15:30:29.404199Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6609-2
  a curric:KeyLearningPoint ;
  rdfs:label """Unlike magnetic poles attract each other, and like magnetic poles repel each
  other."""@en ;
  dcterms:modified "2026-06-07T15:30:29.404205Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6609-3
  a curric:KeyLearningPoint ;
  rdfs:label """Just three metal elements (iron, cobalt and nickel) are magnetic; other metals and
  non–metals are not magnetic."""@en ;
  dcterms:modified "2026-06-07T15:30:29.404209Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6609-4
  a curric:KeyLearningPoint ;
  rdfs:label "The needle of a plotting compass lines up with the magnetic field of a magnet."@en ;
  dcterms:modified "2026-06-07T15:30:29.404213Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6609-5
  a curric:KeyLearningPoint ;
  rdfs:label """Arrows on magnetic field lines show the direction in which the north–seeking pole of
  another magnet would be forced."""@en ;
  dcterms:modified "2026-06-07T15:30:29.404218Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4732-1
  a curric:KeyLearningPoint ;
  rdfs:label "Acceleration is equal to the gradient of a velocity-time graph."@en ;
  dcterms:modified "2026-06-07T15:30:29.404267Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4732-2
  a curric:KeyLearningPoint ;
  rdfs:label """A falling line shows decreasing velocity called deceleration, which is a negative
  acceleration."""@en ;
  dcterms:modified "2026-06-07T15:30:29.404272Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4732-3
  a curric:KeyLearningPoint ;
  rdfs:label """Instantaneous speed at a point on a displacement-time graph equals the gradient of a
  tangent at that point ."""@en ;
  dcterms:modified "2026-06-07T15:30:29.404278Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4732-4
  a curric:KeyLearningPoint ;
  rdfs:label "The distance travelled is equal to the area under a velocity-time graph."@en ;
  dcterms:modified "2026-06-07T15:30:29.404284Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4732-5
  a curric:KeyLearningPoint ;
  rdfs:label "Displacement is equal to the net positive area under a velocity-time graph."@en ;
  dcterms:modified "2026-06-07T15:30:29.404289Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8334-1
  a curric:KeyLearningPoint ;
  rdfs:label """In a chemical reaction, the atoms in reactants are rearranged and are the same atoms
  that are in the products."""@en ;
  dcterms:modified "2026-06-07T15:30:29.407240Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8334-2
  a curric:KeyLearningPoint ;
  rdfs:label """Chemical equations are most correctly interpreted in terms of molar ratios (i.e. 1
  mole of A reacts with 2 moles of B)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.407244Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8334-3
  a curric:KeyLearningPoint ;
  rdfs:label """The molar ratios of the substances in a chemical reaction is known as stoichiometry,
  which means ‘measuring elements’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.407248Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8334-4
  a curric:KeyLearningPoint ;
  rdfs:label """The stoichiometry of a reaction is shown by coefficients in a balanced equation.
  These molar relationships don't change."""@en ;
  dcterms:modified "2026-06-07T15:30:29.407252Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8334-5
  a curric:KeyLearningPoint ;
  rdfs:label """The moles of substance in a reaction can be determined using: mass(g) = Mr × moles
  (& the stoichiometry of reaction)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.407256Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9685-1
  a curric:KeyLearningPoint ;
  rdfs:label """Hydrocarbons are simple covalent compounds made of hydrogen and carbon atoms
  only."""@en ;
  dcterms:modified "2026-06-07T15:30:29.407260Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9685-2
  a curric:KeyLearningPoint ;
  rdfs:label "Hydrocarbons are found in crude oil, and are used as fuels and feedstock."@en ;
  dcterms:modified "2026-06-07T15:30:29.407264Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9685-3
  a curric:KeyLearningPoint ;
  rdfs:label """Alkanes consist of chains, or rings, of carbon atoms that are each also bonded to
  hydrogen atoms."""@en ;
  dcterms:modified "2026-06-07T15:30:29.407268Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9685-4
  a curric:KeyLearningPoint ;
  rdfs:label """Alkanes are a homologous series of hydrocarbons, with the same general formula with
  a trend in properties."""@en ;
  dcterms:modified "2026-06-07T15:30:29.407273Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9685-5
  a curric:KeyLearningPoint ;
  rdfs:label "The general formula for an alkane is CnH2n+2."@en ;
  dcterms:modified "2026-06-07T15:30:29.407277Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8373-1
  a curric:KeyLearningPoint ;
  rdfs:label """Particles of reactants in a chemical reaction can react together if they collide
  with sufficient energy."""@en ;
  dcterms:modified "2026-06-07T15:30:29.407330Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8373-2
  a curric:KeyLearningPoint ;
  rdfs:label """Increasing surface area of a solid lets more reacting particles in a solution
  collide with its particles each second."""@en ;
  dcterms:modified "2026-06-07T15:30:29.407334Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8373-3
  a curric:KeyLearningPoint ;
  rdfs:label """Increasing concentration of a reacting solution introduces more reactant particles,
  so they collide more frequently."""@en ;
  dcterms:modified "2026-06-07T15:30:29.407340Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8373-4
  a curric:KeyLearningPoint ;
  rdfs:label """Increasing temperature of reactants increases the speed of particles, so they
  collide more frequently."""@en ;
  dcterms:modified "2026-06-07T15:30:29.407344Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8373-5
  a curric:KeyLearningPoint ;
  rdfs:label """Increasing pressure of reacting gases pushes reactant particles closer together, so
  they collide more frequently."""@en ;
  dcterms:modified "2026-06-07T15:30:29.407350Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28166-1
  a curric:KeyLearningPoint ;
  rdfs:label """A nuclear equation shows the particles in a nuclear decay, including the electric
  charge and mass number of each one."""@en ;
  dcterms:modified "2026-06-07T15:30:29.407662Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28166-2
  a curric:KeyLearningPoint ;
  rdfs:label """An alpha particle consists of two protons and two neutrons, has a mass of 4 and
  charge of +2."""@en ;
  dcterms:modified "2026-06-07T15:30:29.407666Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28166-3
  a curric:KeyLearningPoint ;
  rdfs:label "The protons and neutrons in an alpha particle are held together very strongly."@en ;
  dcterms:modified "2026-06-07T15:30:29.407673Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28166-4
  a curric:KeyLearningPoint ;
  rdfs:label "After an alpha or beta decay, a nucleus usually emits some gamma radiation."@en ;
  dcterms:modified "2026-06-07T15:30:29.407677Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28166-5
  a curric:KeyLearningPoint ;
  rdfs:label """A beta particle is an electron emitted at a high speed from a nucleus, its mass is
  close to zero and charge of –1."""@en ;
  dcterms:modified "2026-06-07T15:30:29.407681Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20346-1
  a curric:KeyLearningPoint ;
  rdfs:label "All EM waves can transfer energy, from a source to an absorber."@en ;
  dcterms:modified "2026-06-07T15:30:29.407685Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20346-2
  a curric:KeyLearningPoint ;
  rdfs:label """Only UV, X-ray and gamma frequencies of EM wave cause ionisation. The higher the
  frequency, the more ionising."""@en ;
  dcterms:modified "2026-06-07T15:30:29.407689Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20346-3
  a curric:KeyLearningPoint ;
  rdfs:label """Ionising radiation can damage cells, cause genes to mutate and increase the risk of
  cancer."""@en ;
  dcterms:modified "2026-06-07T15:30:29.407693Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20346-4
  a curric:KeyLearningPoint ;
  rdfs:label """UV is used in lighting and to disinfect water. It causes tanning/sunburn. It
  increases the risk of skin cancer."""@en ;
  dcterms:modified "2026-06-07T15:30:29.407697Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20346-5
  a curric:KeyLearningPoint ;
  rdfs:label """X- and gamma rays are used in medical imaging. Gamma rays are used to kill cancer
  cells and to sterilise food/equipment."""@en ;
  dcterms:modified "2026-06-07T15:30:29.407701Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27967-1
  a curric:KeyLearningPoint ;
  rdfs:label """The amount (or activity) of a radioactive isotope repeatedly falls by half in equal
  amounts of time."""@en ;
  dcterms:modified "2026-06-07T15:30:29.407771Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27967-2
  a curric:KeyLearningPoint ;
  rdfs:label """A radioactive half-life graph shows the amount (or activity) of a radioactive
  isotope plotted against time."""@en ;
  dcterms:modified "2026-06-07T15:30:29.407775Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27967-3
  a curric:KeyLearningPoint ;
  rdfs:label """In 2 half-lives the amount (or activity) of a radioactive isotope falls to ½ × ½ = ¼
  as much."""@en ;
  dcterms:modified "2026-06-07T15:30:29.407780Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27967-4
  a curric:KeyLearningPoint ;
  rdfs:label """In 3 half-lives the amount (or activity) of a radioactive isotope falls to ½ × ½ × ½
  = 1/8 as much, and so on."""@en ;
  dcterms:modified "2026-06-07T15:30:29.407784Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27967-5
  a curric:KeyLearningPoint ;
  rdfs:label """Radioactive isotopes with short half-lives decay quickly, emitting most radiation
  over a short period of time."""@en ;
  dcterms:modified "2026-06-07T15:30:29.407788Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9901-1
  a curric:KeyLearningPoint ;
  rdfs:label "A dynamics trolley has a steady acceleration down a steep ramp."@en ;
  dcterms:modified "2026-06-07T15:30:29.407792Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9901-2
  a curric:KeyLearningPoint ;
  rdfs:label """Acceleration = change of velocity / time and change in velocity = final velocity -
  initial velocity"""@en ;
  dcterms:modified "2026-06-07T15:30:29.407796Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9901-3
  a curric:KeyLearningPoint ;
  rdfs:label """Light gates can improve accuracy of measurement of instantaneous velocity and
  reduces random errors."""@en ;
  dcterms:modified "2026-06-07T15:30:29.407800Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9901-4
  a curric:KeyLearningPoint ;
  rdfs:label """Using video recording will allow for accurate measurement of small time
  intervals."""@en ;
  dcterms:modified "2026-06-07T15:30:29.407805Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4730-1
  a curric:KeyLearningPoint ;
  rdfs:label "Acceleration is equal to the amount that velocity changes in one second."@en ;
  dcterms:modified "2026-06-07T15:30:29.409111Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4730-2
  a curric:KeyLearningPoint ;
  rdfs:label "Acceleration is the rate of change of velocity."@en ;
  dcterms:modified "2026-06-07T15:30:29.409115Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4730-3
  a curric:KeyLearningPoint ;
  rdfs:label "Average acceleration = change of velocity / time (a = Δv/t)"@en ;
  dcterms:modified "2026-06-07T15:30:29.409119Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4730-4
  a curric:KeyLearningPoint ;
  rdfs:label "An object that is slowing down is decelerating."@en ;
  dcterms:modified "2026-06-07T15:30:29.409125Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4730-5
  a curric:KeyLearningPoint ;
  rdfs:label "An object that is decelerating has a negative acceleration."@en ;
  dcterms:modified "2026-06-07T15:30:29.409130Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4907-1
  a curric:KeyLearningPoint ;
  rdfs:label """Doubling the stiffness of a spring doubles the energy it has because it is
  stretched."""@en ;
  dcterms:modified "2026-06-07T15:30:29.409330Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4907-2
  a curric:KeyLearningPoint ;
  rdfs:label "The spring constant is measured in newtons per metre (N/m)."@en ;
  dcterms:modified "2026-06-07T15:30:29.409334Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4907-3
  a curric:KeyLearningPoint ;
  rdfs:label """Doubling the extension of a spring increases the energy it has because it is
  stretched by four times."""@en ;
  dcterms:modified "2026-06-07T15:30:29.409338Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4907-4
  a curric:KeyLearningPoint ;
  rdfs:label """The energy a spring has because it is stretched equals 1/2 × spring constant ×
  (extension)²."""@en ;
  dcterms:modified "2026-06-07T15:30:29.409343Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20081-1
  a curric:KeyLearningPoint ;
  rdfs:label """The atomic number of an element states the number of protons in the nucleus of every
  atom of that element."""@en ;
  dcterms:modified "2026-06-07T15:30:29.410003Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20081-2
  a curric:KeyLearningPoint ;
  rdfs:label """The number of electrons in an atom is equal to the number of protons in the nucleus
  of the atom."""@en ;
  dcterms:modified "2026-06-07T15:30:29.410007Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20081-3
  a curric:KeyLearningPoint ;
  rdfs:label """The mass number of an element is about equal to the number of protons and neutrons
  in atoms of that element."""@en ;
  dcterms:modified "2026-06-07T15:30:29.410011Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9664-1
  a curric:KeyLearningPoint ;
  rdfs:label """Whenever a measurement is made, there is always some uncertainty about the result
  obtained."""@en ;
  dcterms:modified "2026-06-07T15:30:29.411523Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9664-2
  a curric:KeyLearningPoint ;
  rdfs:label """The uncertainty of an individual measurement is equal to half the resolution of the
  device used to take the measurement."""@en ;
  dcterms:modified "2026-06-07T15:30:29.411528Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9664-3
  a curric:KeyLearningPoint ;
  rdfs:label """The higher the resolution, the lower the uncertainty of an individual
  measurement."""@en ;
  dcterms:modified "2026-06-07T15:30:29.411532Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9664-4
  a curric:KeyLearningPoint ;
  rdfs:label "Half the range of repeated measurements equals the uncertainty of a mean value."@en ;
  dcterms:modified "2026-06-07T15:30:29.411538Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9664-5
  a curric:KeyLearningPoint ;
  rdfs:label """The uncertainty of a measurement provides a range within which the actual value can
  be found."""@en ;
  dcterms:modified "2026-06-07T15:30:29.411542Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9944-1
  a curric:KeyLearningPoint ;
  rdfs:label "Energy cannot be created or destroyed."@en ;
  dcterms:modified "2026-06-07T15:30:29.411591Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9944-2
  a curric:KeyLearningPoint ;
  rdfs:label "In an ideal situation, no energy is dissipated."@en ;
  dcterms:modified "2026-06-07T15:30:29.411595Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9944-3
  a curric:KeyLearningPoint ;
  rdfs:label """As an object changes height, change in gravitational potential energy = change in
  kinetic energy."""@en ;
  dcterms:modified "2026-06-07T15:30:29.411601Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9151-1
  a curric:KeyLearningPoint ;
  rdfs:label """All bodies (objects) of all temperatures emit and absorb infrared radiation. Hotter
  bodies emit more IR in a set time."""@en ;
  dcterms:modified "2026-06-07T15:30:29.418959Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9151-2
  a curric:KeyLearningPoint ;
  rdfs:label """The range of wavelengths emitted, and their intensities, depend on an object’s
  temperature."""@en ;
  dcterms:modified "2026-06-07T15:30:29.418963Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9151-3
  a curric:KeyLearningPoint ;
  rdfs:label """Good absorbers (e.g. dark and dull surfaces) are also good emitters. Shiny metal
  surfaces are poor absorbers/emitters."""@en ;
  dcterms:modified "2026-06-07T15:30:29.418967Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5036-1
  a curric:KeyLearningPoint ;
  rdfs:label "The current in a series circuit is the same everywhere."@en ;
  dcterms:modified "2026-06-07T15:30:29.426432Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5036-2
  a curric:KeyLearningPoint ;
  rdfs:label """The p.d. across each component in a series electric circuit adds up to the p.d. of
  the battery."""@en ;
  dcterms:modified "2026-06-07T15:30:29.426436Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5036-3
  a curric:KeyLearningPoint ;
  rdfs:label """The greater the resistance in a series circuit, the lower the current (current is
  inversely proportional to resistance)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.426440Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5036-4
  a curric:KeyLearningPoint ;
  rdfs:label """The greater the battery p.d. in series circuit, the larger the current (current is
  directly proportional to p.d.)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.426445Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5036-5
  a curric:KeyLearningPoint ;
  rdfs:label """Current, p.d. or resistance can be calculated with the equation: current =
  p.d./resistance."""@en ;
  dcterms:modified "2026-06-07T15:30:29.426449Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5051-1
  a curric:KeyLearningPoint ;
  rdfs:label "The speed of sound in air is about 340 m/s."@en ;
  dcterms:modified "2026-06-07T15:30:29.426455Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5051-2
  a curric:KeyLearningPoint ;
  rdfs:label """The speed of sound in air can be measured using an echo method and using speed =
  distance/time."""@en ;
  dcterms:modified "2026-06-07T15:30:29.426459Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5051-3
  a curric:KeyLearningPoint ;
  rdfs:label """The speed of sound in a metal rod can be found by measuring the length and the
  frequency produced when struck."""@en ;
  dcterms:modified "2026-06-07T15:30:29.426464Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5051-4
  a curric:KeyLearningPoint ;
  rdfs:label "A result is accurate if it is close to the true value."@en ;
  dcterms:modified "2026-06-07T15:30:29.426468Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5051-5
  a curric:KeyLearningPoint ;
  rdfs:label """A result can be considered accurate if it is repeatable, reproducible and if
  systematic errors have been checked for."""@en ;
  dcterms:modified "2026-06-07T15:30:29.426474Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6610-1
  a curric:KeyLearningPoint ;
  rdfs:label """When there is an electric current in a wire, there is a magnetic field around the
  wire."""@en ;
  dcterms:modified "2026-06-07T15:30:29.426478Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6610-2
  a curric:KeyLearningPoint ;
  rdfs:label """An electromagnet is a magnet that can be turned on with an electric current, and
  turned off."""@en ;
  dcterms:modified "2026-06-07T15:30:29.426483Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6610-3
  a curric:KeyLearningPoint ;
  rdfs:label """The magnetic field of an electromagnet is similar to the field around a bar
  magnet."""@en ;
  dcterms:modified "2026-06-07T15:30:29.426487Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6610-4
  a curric:KeyLearningPoint ;
  rdfs:label """A soft iron core in an electromagnet becomes magnetised and adds to the strength of
  field when the electromagnet is on."""@en ;
  dcterms:modified "2026-06-07T15:30:29.426491Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6610-5
  a curric:KeyLearningPoint ;
  rdfs:label """When there is an electric current in a coil of wire, the magnetic field around each
  loop adds to make a stronger field."""@en ;
  dcterms:modified "2026-06-07T15:30:29.426495Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20084-1
  a curric:KeyLearningPoint ;
  rdfs:label "The atomic model has changed over time."@en ;
  dcterms:modified "2026-06-07T15:30:29.427625Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20084-2
  a curric:KeyLearningPoint ;
  rdfs:label """Dalton, Thomson, Rutherford (Geiger and Marsden), Bohr and Chadwick have all
  suggested atomic models."""@en ;
  dcterms:modified "2026-06-07T15:30:29.427629Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20084-3
  a curric:KeyLearningPoint ;
  rdfs:label """The plum pudding model of the atom & the nuclear model are two important models in
  the history of the atom's discovery."""@en ;
  dcterms:modified "2026-06-07T15:30:29.427633Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20084-4
  a curric:KeyLearningPoint ;
  rdfs:label "New evidence from the scattering experiment led to a change in the atomic model."@en ;
  dcterms:modified "2026-06-07T15:30:29.427638Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27966-1
  a curric:KeyLearningPoint ;
  rdfs:label """The amount (or activity) of a radioactive isotope repeatedly falls by half in equal
  amounts of time."""@en ;
  dcterms:modified "2026-06-07T15:30:29.429501Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27966-2
  a curric:KeyLearningPoint ;
  rdfs:label """A radioactive half-life graph shows the amount (or activity) of a radioactive
  isotope plotted against time."""@en ;
  dcterms:modified "2026-06-07T15:30:29.429505Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27966-3
  a curric:KeyLearningPoint ;
  rdfs:label """In 2 half-lives the amount (or activity) of a radioactive isotope falls to ½ × ½ = ¼
  as much."""@en ;
  dcterms:modified "2026-06-07T15:30:29.429511Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27966-4
  a curric:KeyLearningPoint ;
  rdfs:label """In 3 half-lives the amount (or activity) of a radioactive isotope falls to ½ × ½ × ½
  = 1/8 as much, and so on."""@en ;
  dcterms:modified "2026-06-07T15:30:29.429516Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27966-5
  a curric:KeyLearningPoint ;
  rdfs:label """Radioactive isotopes with short half-lives decay quickly, emitting most radiation
  over a short period of time."""@en ;
  dcterms:modified "2026-06-07T15:30:29.429520Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27388-1
  a curric:KeyLearningPoint ;
  rdfs:label """Transition metals are generally stronger, harder, more dense and have higher melting
  points than Group 1 metals."""@en ;
  dcterms:modified "2026-06-07T15:30:29.429815Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27388-2
  a curric:KeyLearningPoint ;
  rdfs:label "Transition metals react slowly with water or don’t react with it at all."@en ;
  dcterms:modified "2026-06-07T15:30:29.429819Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27388-3
  a curric:KeyLearningPoint ;
  rdfs:label "Transition metals are often catalysts that speed up chemical reactions."@en ;
  dcterms:modified "2026-06-07T15:30:29.429823Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27388-4
  a curric:KeyLearningPoint ;
  rdfs:label """Transition metals can form ions with different charges and their compounds often
  exhibit vibrant colours."""@en ;
  dcterms:modified "2026-06-07T15:30:29.429829Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9693-1
  a curric:KeyLearningPoint ;
  rdfs:label """A more reactive element will replace a less reactive element in a compound
  (displacement)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.429834Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9693-2
  a curric:KeyLearningPoint ;
  rdfs:label "The more easily a metal atom forms a positive ion, the more reactive it is."@en ;
  dcterms:modified "2026-06-07T15:30:29.429838Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9693-3
  a curric:KeyLearningPoint ;
  rdfs:label "Some metals react with acid to produce a metal salt and hydrogen gas."@en ;
  dcterms:modified "2026-06-07T15:30:29.429842Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9693-4
  a curric:KeyLearningPoint ;
  rdfs:label "Some metals react with water to produce a metal hydroxide and hydrogen gas."@en ;
  dcterms:modified "2026-06-07T15:30:29.429846Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9693-5
  a curric:KeyLearningPoint ;
  rdfs:label """Carbon is a non-metal element often included in the reactivity series between
  aluminium and zinc."""@en ;
  dcterms:modified "2026-06-07T15:30:29.429850Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5094-1
  a curric:KeyLearningPoint ;
  rdfs:label """Mains electricity has a p.d. of 230 V between a live wire connection (230 V) and a
  neutral wire connection (0 V)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.431111Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5094-2
  a curric:KeyLearningPoint ;
  rdfs:label "Mains electricity has alternating current at a frequency of 50 Hz."@en ;
  dcterms:modified "2026-06-07T15:30:29.431118Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5094-3
  a curric:KeyLearningPoint ;
  rdfs:label """Electric current passing through a person’s body can damage living tissue and/or
  stop their heart pumping blood."""@en ;
  dcterms:modified "2026-06-07T15:30:29.431122Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5094-4
  a curric:KeyLearningPoint ;
  rdfs:label """The size of current from a shock depends on the p.d. across the person and the
  resistance of their skin (I = V ÷ R)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.431126Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5094-5
  a curric:KeyLearningPoint ;
  rdfs:label """Wet skin has a much lower resistance than dry skin, and a smaller p.d. can cause a
  bigger current from a shock."""@en ;
  dcterms:modified "2026-06-07T15:30:29.431130Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9755-1
  a curric:KeyLearningPoint ;
  rdfs:label """A half–equation describes what happens to one reactant in a reaction, such as the
  process at an individual electrode."""@en ;
  dcterms:modified "2026-06-07T15:30:29.431211Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9755-2
  a curric:KeyLearningPoint ;
  rdfs:label "Half–equations show balanced charges as well as balanced atoms."@en ;
  dcterms:modified "2026-06-07T15:30:29.431216Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9755-3
  a curric:KeyLearningPoint ;
  rdfs:label "A balanced ionic equation shows all reacting ions involved in a reaction."@en ;
  dcterms:modified "2026-06-07T15:30:29.431220Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9755-4
  a curric:KeyLearningPoint ;
  rdfs:label "Ions not involved in a reaction do not appear in a balanced ionic equation."@en ;
  dcterms:modified "2026-06-07T15:30:29.431224Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9694-1
  a curric:KeyLearningPoint ;
  rdfs:label "Oxidation is the loss of electrons and reduction is the gain of electrons."@en ;
  dcterms:modified "2026-06-07T15:30:29.431228Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9694-2
  a curric:KeyLearningPoint ;
  rdfs:label """Half equations can be written to show which species are oxidised and which are
  reduced."""@en ;
  dcterms:modified "2026-06-07T15:30:29.431233Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9694-3
  a curric:KeyLearningPoint ;
  rdfs:label "Ionic equations can be written for displacement reactions."@en ;
  dcterms:modified "2026-06-07T15:30:29.431237Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8331-1
  a curric:KeyLearningPoint ;
  rdfs:label """The relative atomic mass is the mean mass of an atom compared to 1/12 of the mass of
  a carbon-12 atom."""@en ;
  dcterms:modified "2026-06-07T15:30:29.431257Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8331-2
  a curric:KeyLearningPoint ;
  rdfs:label """The relative formula mass (RFM or Mr) is the sum of the relative atomic masses of
  all the atoms in a chemical formula."""@en ;
  dcterms:modified "2026-06-07T15:30:29.431261Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8331-3
  a curric:KeyLearningPoint ;
  rdfs:label """%mass of an element in a compound = (relative mass of element in compound ÷ RFM of
  compound) × 100"""@en ;
  dcterms:modified "2026-06-07T15:30:29.431265Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9659-1
  a curric:KeyLearningPoint ;
  rdfs:label """The stoichiometry of a chemical reaction is the molar ratio of each substance in a
  balanced symbol equation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.431342Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9659-2
  a curric:KeyLearningPoint ;
  rdfs:label "Stoichiometric values can be calculated using masses found by experiment."@en ;
  dcterms:modified "2026-06-07T15:30:29.431347Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9659-3
  a curric:KeyLearningPoint ;
  rdfs:label """Subscript values in chemical formula indicate the ratio of atoms/ions in a
  molecule/formula unit."""@en ;
  dcterms:modified "2026-06-07T15:30:29.431351Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8347-1
  a curric:KeyLearningPoint ;
  rdfs:label """In a covalent bond, two non-metal atoms share a pair of electrons (from their outer
  shells)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.431440Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8347-2
  a curric:KeyLearningPoint ;
  rdfs:label """For every one electron needed to complete the outer shell of an atom, one covalent
  bond will form."""@en ;
  dcterms:modified "2026-06-07T15:30:29.431444Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8347-3
  a curric:KeyLearningPoint ;
  rdfs:label "Atoms can share multiple pairs of electrons."@en ;
  dcterms:modified "2026-06-07T15:30:29.431451Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8347-4
  a curric:KeyLearningPoint ;
  rdfs:label """Displayed formulae of covalent substances are a model, showing lines to represent
  shared pairs of electrons."""@en ;
  dcterms:modified "2026-06-07T15:30:29.431455Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5588-1
  a curric:KeyLearningPoint ;
  rdfs:label "Compare data on rate of water uptake by a plant at a range of light intensities."@en ;
  dcterms:modified "2026-06-07T15:30:29.431475Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5588-2
  a curric:KeyLearningPoint ;
  rdfs:label "Identify a pattern or trend in the data."@en ;
  dcterms:modified "2026-06-07T15:30:29.431481Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5588-3
  a curric:KeyLearningPoint ;
  rdfs:label """Higher light intensity increases transpiration rate as stomata open wider to
  increase gas exchange for photosynthesis."""@en ;
  dcterms:modified "2026-06-07T15:30:29.431486Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5588-4
  a curric:KeyLearningPoint ;
  rdfs:label "Increased temperature and air movement also increase the rate of water uptake."@en ;
  dcterms:modified "2026-06-07T15:30:29.431490Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5588-5
  a curric:KeyLearningPoint ;
  rdfs:label """Higher temperature and air movement increase transpiration due to increased
  diffusion of water out through stomata."""@en ;
  dcterms:modified "2026-06-07T15:30:29.431494Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8402-1
  a curric:KeyLearningPoint ;
  rdfs:label "Carbon dioxide and methane are common greenhouse gases."@en ;
  dcterms:modified "2026-06-07T15:30:29.432127Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8402-2
  a curric:KeyLearningPoint ;
  rdfs:label """Greenhouse gases reduce the amount of lower-energy IR that can escape from Earth’s
  atmosphere."""@en ;
  dcterms:modified "2026-06-07T15:30:29.432132Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8402-3
  a curric:KeyLearningPoint ;
  rdfs:label """Greenhouse gases do not reduce the amount of higher-energy IR radiation entering the
  atmosphere from the Sun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.432136Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8402-4
  a curric:KeyLearningPoint ;
  rdfs:label """If the rate energy is transferred into the atmosphere exceeds the rate it is
  transferred out, average temperatures rise."""@en ;
  dcterms:modified "2026-06-07T15:30:29.432146Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8402-5
  a curric:KeyLearningPoint ;
  rdfs:label """An increasing average temperature of Earth’s atmosphere is called global
  warming."""@en ;
  dcterms:modified "2026-06-07T15:30:29.432151Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8156-1
  a curric:KeyLearningPoint ;
  rdfs:label """The pressure of a gas in a container increases if the temperature or the mass of gas
  increases, or the volume decreases."""@en ;
  dcterms:modified "2026-06-07T15:30:29.432314Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8156-2
  a curric:KeyLearningPoint ;
  rdfs:label """Increasing the temperature increases the average speed of the particles in a
  gas."""@en ;
  dcterms:modified "2026-06-07T15:30:29.432320Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8156-3
  a curric:KeyLearningPoint ;
  rdfs:label """Increasing the speed of the particles in a gas at a fixed volume increases its
  pressure."""@en ;
  dcterms:modified "2026-06-07T15:30:29.432325Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9920-1
  a curric:KeyLearningPoint ;
  rdfs:label "Work done is the total amount of energy transferred."@en ;
  dcterms:modified "2026-06-07T15:30:29.433500Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9920-2
  a curric:KeyLearningPoint ;
  rdfs:label "Work done = force x distance (moved in the direction of the force)."@en ;
  dcterms:modified "2026-06-07T15:30:29.433504Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9920-3
  a curric:KeyLearningPoint ;
  rdfs:label "Work done is measured in Joule (J)."@en ;
  dcterms:modified "2026-06-07T15:30:29.433508Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9891-1
  a curric:KeyLearningPoint ;
  rdfs:label """A dynamics trolley speeds up (accelerates) along the whole length of a steep
  ramp."""@en ;
  dcterms:modified "2026-06-07T15:30:29.433512Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9891-2
  a curric:KeyLearningPoint ;
  rdfs:label "Instantaneous speed is the average speed over a very short time period."@en ;
  dcterms:modified "2026-06-07T15:30:29.433516Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9891-3
  a curric:KeyLearningPoint ;
  rdfs:label "Instantaneous speed is the average speed over a very short time period."@en ;
  dcterms:modified "2026-06-07T15:30:29.433523Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9891-4
  a curric:KeyLearningPoint ;
  rdfs:label "Repeated readings by different observers helps to check for systematic errors."@en ;
  dcterms:modified "2026-06-07T15:30:29.433527Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9138-1
  a curric:KeyLearningPoint ;
  rdfs:label """Acceleration can be measured accurately using light gates or roughly measured using
  a stopwatch and ruler."""@en ;
  dcterms:modified "2026-06-07T15:30:29.433531Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9138-2
  a curric:KeyLearningPoint ;
  rdfs:label """The acceleration of an object is proportional to the resultant force acting on the
  object."""@en ;
  dcterms:modified "2026-06-07T15:30:29.433537Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9138-3
  a curric:KeyLearningPoint ;
  rdfs:label """The acceleration of an object is inversely proportional to the mass of the
  object."""@en ;
  dcterms:modified "2026-06-07T15:30:29.433542Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9138-4
  a curric:KeyLearningPoint ;
  rdfs:label "Newton's Second Law states that F = m × a."@en ;
  dcterms:modified "2026-06-07T15:30:29.433546Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9631-1
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists use models to represent parts of the natural world that are too difficult
  to observe or explain directly."""@en ;
  dcterms:modified "2026-06-07T15:30:29.434100Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9631-2
  a curric:KeyLearningPoint ;
  rdfs:label "There are multiple ways (models) of drawing/showing bonding."@en ;
  dcterms:modified "2026-06-07T15:30:29.434104Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9631-3
  a curric:KeyLearningPoint ;
  rdfs:label """There are multiple advantages and limitations of particular representations and
  models."""@en ;
  dcterms:modified "2026-06-07T15:30:29.434108Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20095-1
  a curric:KeyLearningPoint ;
  rdfs:label "Atoms of every element consist of the same three subatomic particles."@en ;
  dcterms:modified "2026-06-07T15:30:29.434133Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20095-2
  a curric:KeyLearningPoint ;
  rdfs:label """All elements consist of their own atoms, with a unique number of protons defining
  the element."""@en ;
  dcterms:modified "2026-06-07T15:30:29.434137Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20095-3
  a curric:KeyLearningPoint ;
  rdfs:label """Everything around us is made of different combinations of atoms, either on their
  own, or in compound form."""@en ;
  dcterms:modified "2026-06-07T15:30:29.434141Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20095-4
  a curric:KeyLearningPoint ;
  rdfs:label """We use element symbols in formulae as a common language to share chemical
  compositions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.434146Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9898-1
  a curric:KeyLearningPoint ;
  rdfs:label "Acceleration is equal to the amount that velocity changes in one second."@en ;
  dcterms:modified "2026-06-07T15:30:29.434183Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9898-2
  a curric:KeyLearningPoint ;
  rdfs:label "Acceleration is the rate of change of velocity."@en ;
  dcterms:modified "2026-06-07T15:30:29.434187Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9898-3
  a curric:KeyLearningPoint ;
  rdfs:label "Average acceleration = change of velocity/time [a = (v-u)/t]"@en ;
  dcterms:modified "2026-06-07T15:30:29.434191Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9898-4
  a curric:KeyLearningPoint ;
  rdfs:label "An object that is slowing down is decelerating."@en ;
  dcterms:modified "2026-06-07T15:30:29.434196Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9898-5
  a curric:KeyLearningPoint ;
  rdfs:label "An object that is decelerating has a negative acceleration."@en ;
  dcterms:modified "2026-06-07T15:30:29.434200Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20341-1
  a curric:KeyLearningPoint ;
  rdfs:label "A dynamics trolley has a steady acceleration down a steep ramp."@en ;
  dcterms:modified "2026-06-07T15:30:29.435401Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20341-2
  a curric:KeyLearningPoint ;
  rdfs:label """Acceleration = change of velocity / time and change in velocity = final velocity -
  initial velocity"""@en ;
  dcterms:modified "2026-06-07T15:30:29.435406Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20341-3
  a curric:KeyLearningPoint ;
  rdfs:label """Light gates can improve accuracy of measurement of instantaneous velocity and
  reduces random errors."""@en ;
  dcterms:modified "2026-06-07T15:30:29.435410Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20341-4
  a curric:KeyLearningPoint ;
  rdfs:label """Using video recording will allow for accurate measurement of small time
  intervals."""@en ;
  dcterms:modified "2026-06-07T15:30:29.435414Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8401-1
  a curric:KeyLearningPoint ;
  rdfs:label "The combustion of fossil fuels adds more carbon dioxide to the atmosphere."@en ;
  dcterms:modified "2026-06-07T15:30:29.438954Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8401-2
  a curric:KeyLearningPoint ;
  rdfs:label """Carbon dioxide added to the atmosphere in one place will, over time, spread
  throughout Earth’s atmosphere."""@en ;
  dcterms:modified "2026-06-07T15:30:29.438958Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8401-3
  a curric:KeyLearningPoint ;
  rdfs:label """Plants act as carbon sinks because, as they grow, they remove carbon dioxide from
  the atmosphere."""@en ;
  dcterms:modified "2026-06-07T15:30:29.438962Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8401-4
  a curric:KeyLearningPoint ;
  rdfs:label """The decomposition or combustion of plants returns the carbon they are storing into
  the atmosphere."""@en ;
  dcterms:modified "2026-06-07T15:30:29.438968Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8401-5
  a curric:KeyLearningPoint ;
  rdfs:label """Human activity is adding carbon dioxide to the atmosphere more quickly than it is
  being removed by natural processes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.438973Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9967-1
  a curric:KeyLearningPoint ;
  rdfs:label """Chromatograms can identify unknown substances by qualitative visual comparison or
  quantitatively by Rf value comparison."""@en ;
  dcterms:modified "2026-06-07T15:30:29.439028Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9967-2
  a curric:KeyLearningPoint ;
  rdfs:label """Appropriate equipment should be employed when using chromatograms to identify
  unknown substances in a mixture."""@en ;
  dcterms:modified "2026-06-07T15:30:29.439033Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9967-3
  a curric:KeyLearningPoint ;
  rdfs:label "An appropriate number of significant figures should be used in calculations."@en ;
  dcterms:modified "2026-06-07T15:30:29.439041Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9942-1
  a curric:KeyLearningPoint ;
  rdfs:label "Energy cannot be created or destroyed."@en ;
  dcterms:modified "2026-06-07T15:30:29.585292Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9942-2
  a curric:KeyLearningPoint ;
  rdfs:label "In an ideal situation, no energy is dissipated."@en ;
  dcterms:modified "2026-06-07T15:30:29.585297Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9942-3
  a curric:KeyLearningPoint ;
  rdfs:label """As an object changes height, change in gravitational potential energy = change in
  kinetic energy."""@en ;
  dcterms:modified "2026-06-07T15:30:29.585302Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9946-1
  a curric:KeyLearningPoint ;
  rdfs:label """Electrons have a relative charge of -1 and roughly a relative mass of 0.0005 (very
  small)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.585469Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9946-2
  a curric:KeyLearningPoint ;
  rdfs:label """Protons are found in the atomic nucleus, have a relative electric charge of +1, and
  a relative mass of 1."""@en ;
  dcterms:modified "2026-06-07T15:30:29.585474Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9946-3
  a curric:KeyLearningPoint ;
  rdfs:label """Neutrons are found in the atomic nucleus, have no electric charge, and a relative
  mass of 1."""@en ;
  dcterms:modified "2026-06-07T15:30:29.585482Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9946-4
  a curric:KeyLearningPoint ;
  rdfs:label """An atom has no electric charge as it contains equal numbers of protons and electrons
  to balance the charge."""@en ;
  dcterms:modified "2026-06-07T15:30:29.585487Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9946-5
  a curric:KeyLearningPoint ;
  rdfs:label """The atom has a nucleus surrounded by electrons, with the nuclear radius much smaller
  than that of the atom."""@en ;
  dcterms:modified "2026-06-07T15:30:29.585492Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28013-1
  a curric:KeyLearningPoint ;
  rdfs:label """Energy transferred to a solid at its melting point allows its particles to move
  further apart."""@en ;
  dcterms:modified "2026-06-07T15:30:29.586607Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28013-2
  a curric:KeyLearningPoint ;
  rdfs:label """Energy transferred to a liquid at its boiling point allows its particles to move
  fast enough to get even further apart."""@en ;
  dcterms:modified "2026-06-07T15:30:29.586612Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28013-3
  a curric:KeyLearningPoint ;
  rdfs:label """The energy transferred to melt a solid at its melting point is proportional to the
  mass of the solid."""@en ;
  dcterms:modified "2026-06-07T15:30:29.586617Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28013-4
  a curric:KeyLearningPoint ;
  rdfs:label """The energy transferred to melt 1 kg of a solid at its melting point is proportional
  to the solid’s specific latent heat."""@en ;
  dcterms:modified "2026-06-07T15:30:29.586621Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28013-5
  a curric:KeyLearningPoint ;
  rdfs:label """The energy transferred to boil 1 kg of a liquid at its boiling point is proportional
  to it’s specific latent heat."""@en ;
  dcterms:modified "2026-06-07T15:30:29.586626Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4926-1
  a curric:KeyLearningPoint ;
  rdfs:label """Energy transferred to a solid at its melting point allows its particles to move
  further apart."""@en ;
  dcterms:modified "2026-06-07T15:30:29.586698Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4926-2
  a curric:KeyLearningPoint ;
  rdfs:label """Energy transferred to a liquid at its boiling point allows its particles to move
  fast enough to get even further apart."""@en ;
  dcterms:modified "2026-06-07T15:30:29.586703Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4926-3
  a curric:KeyLearningPoint ;
  rdfs:label """The energy transferred to melt a solid at its melting point is proportional to the
  mass of the solid."""@en ;
  dcterms:modified "2026-06-07T15:30:29.586708Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4926-4
  a curric:KeyLearningPoint ;
  rdfs:label """The energy transferred to melt 1 kg of a solid at its melting point is proportional
  to the solid’s specific latent heat."""@en ;
  dcterms:modified "2026-06-07T15:30:29.586712Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4926-5
  a curric:KeyLearningPoint ;
  rdfs:label """The energy transferred to boil 1 kg of a liquid at its boiling point is proportional
  to its specific latent heat."""@en ;
  dcterms:modified "2026-06-07T15:30:29.586717Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5096-1
  a curric:KeyLearningPoint ;
  rdfs:label """Power is transferred by electricity from power stations to consumers using the
  National Grid."""@en ;
  dcterms:modified "2026-06-07T15:30:29.587938Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5096-2
  a curric:KeyLearningPoint ;
  rdfs:label """Step-up transformers increase the transmission voltage from a power station to the
  transmission line."""@en ;
  dcterms:modified "2026-06-07T15:30:29.587944Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5096-3
  a curric:KeyLearningPoint ;
  rdfs:label """Step-down transformers decrease the transmission voltage from a transmission line to
  the consumer."""@en ;
  dcterms:modified "2026-06-07T15:30:29.587949Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5096-4
  a curric:KeyLearningPoint ;
  rdfs:label "Transmission lines dissipate some energy by heating (P = I²R)."@en ;
  dcterms:modified "2026-06-07T15:30:29.587954Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5096-5
  a curric:KeyLearningPoint ;
  rdfs:label """A very high transmission voltage reduces transmission current and the heating of
  transmission lines."""@en ;
  dcterms:modified "2026-06-07T15:30:29.587958Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8343-1
  a curric:KeyLearningPoint ;
  rdfs:label "Atoms are more stable when they have a full outer shell."@en ;
  dcterms:modified "2026-06-07T15:30:29.588031Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8343-2
  a curric:KeyLearningPoint ;
  rdfs:label """Metal atoms become more stable when they lose the electron(s) in their outer shell,
  and become positive ions (cations)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588036Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8343-3
  a curric:KeyLearningPoint ;
  rdfs:label """Non–metal atoms become more stable when they gain electrons to fill their outer
  shell and become negative ions (anions)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588040Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8343-4
  a curric:KeyLearningPoint ;
  rdfs:label "Ions form through the loss or gain of electrons."@en ;
  dcterms:modified "2026-06-07T15:30:29.588045Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8343-5
  a curric:KeyLearningPoint ;
  rdfs:label """Standard ion notation uses superscript charge values where the charge follows the
  number (e.g. 2+, not +2)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588050Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20686-1
  a curric:KeyLearningPoint ;
  rdfs:label "Atoms are more stable when they have a full outer shell."@en ;
  dcterms:modified "2026-06-07T15:30:29.588251Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20686-2
  a curric:KeyLearningPoint ;
  rdfs:label """Metal atoms become more stable when they lose the electron(s) in their outer shell,
  and become positive ions (cations)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588255Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20686-3
  a curric:KeyLearningPoint ;
  rdfs:label """Non–metal atoms become more stable when they gain electrons to fill their outer
  shell and become negative ions (anions)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588260Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20686-4
  a curric:KeyLearningPoint ;
  rdfs:label "Ions form through the loss or gain of electrons."@en ;
  dcterms:modified "2026-06-07T15:30:29.588264Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20686-5
  a curric:KeyLearningPoint ;
  rdfs:label """Standard ion notation uses superscript charge values where the charge follows the
  number (e.g. 2+, not +2)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588269Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4919-1
  a curric:KeyLearningPoint ;
  rdfs:label "Momentum = mass × velocity, p = mv"@en ;
  dcterms:modified "2026-06-07T15:30:29.588291Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4919-2
  a curric:KeyLearningPoint ;
  rdfs:label """In a closed system, the total momentum before an event equals the total momentum
  after the event."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588299Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9168-1
  a curric:KeyLearningPoint ;
  rdfs:label "Average velocity = distance travelled ÷ time"@en ;
  dcterms:modified "2026-06-07T15:30:29.588304Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9168-2
  a curric:KeyLearningPoint ;
  rdfs:label "Average acceleration = change in velocity ÷ time"@en ;
  dcterms:modified "2026-06-07T15:30:29.588310Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9168-3
  a curric:KeyLearningPoint ;
  rdfs:label "Average velocity = (initial velocity + final velocity) ÷ 2"@en ;
  dcterms:modified "2026-06-07T15:30:29.588315Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9168-4
  a curric:KeyLearningPoint ;
  rdfs:label """Combining equations for average acceleration and average velocity leads to the
  equation v² – u² = 2 as"""@en ;
  dcterms:modified "2026-06-07T15:30:29.588320Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9168-5
  a curric:KeyLearningPoint ;
  rdfs:label """Different motion equations can be used to analyse motion based on information
  provided."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588324Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9619-1
  a curric:KeyLearningPoint ;
  rdfs:label "Electrons have a relative charge of -1 and roughly a relative mass of 0.0005."@en ;
  dcterms:modified "2026-06-07T15:30:29.588352Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9619-2
  a curric:KeyLearningPoint ;
  rdfs:label """Protons are found in the atomic nucleus, have a relative electric charge of +1, and
  a relative mass of 1."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588356Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9619-3
  a curric:KeyLearningPoint ;
  rdfs:label """Neutrons are found in the atomic nucleus, have no electric charge, and a relative
  mass of 1."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588379Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9619-4
  a curric:KeyLearningPoint ;
  rdfs:label """An atom has no electric charge and contains equal numbers of protons and electrons
  to balance the charge."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588384Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9619-5
  a curric:KeyLearningPoint ;
  rdfs:label """The atom has a nucleus surrounded by electrons, with the nuclear radius much smaller
  than that of the atom."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588388Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8403-1
  a curric:KeyLearningPoint ;
  rdfs:label "Increasing average global temperatures leads to an increase in sea levels."@en ;
  dcterms:modified "2026-06-07T15:30:29.588575Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8403-2
  a curric:KeyLearningPoint ;
  rdfs:label """Increasing average temperatures cause more powerful convection currents, increasing
  the number and severity of storms."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588581Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8403-3
  a curric:KeyLearningPoint ;
  rdfs:label """Increasing average temperatures can affect atmospheric air streams and change
  weather patterns."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588586Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8403-4
  a curric:KeyLearningPoint ;
  rdfs:label "Changes of human behaviour can lead to smaller increases in global temperature."@en ;
  dcterms:modified "2026-06-07T15:30:29.588591Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8403-5
  a curric:KeyLearningPoint ;
  rdfs:label """Climate engineering may enable humans to reduce global temperatures through the
  application of technologies."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588595Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8371-1
  a curric:KeyLearningPoint ;
  rdfs:label "Most chemical reactions start more quickly and slow down as they progress."@en ;
  dcterms:modified "2026-06-07T15:30:29.588599Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8371-2
  a curric:KeyLearningPoint ;
  rdfs:label """The rate of a chemical reaction is equal to the amount of product formed per unit
  time (or reactant used per unit time)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588604Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8371-3
  a curric:KeyLearningPoint ;
  rdfs:label """The mean rate of a chemical reaction is different to the instantaneous rate that
  changes throughout the reaction."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588608Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8371-4
  a curric:KeyLearningPoint ;
  rdfs:label """Graphs of mass, volume, or concentration vs. time can all represent the changing
  rate of a chemical reaction."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588613Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8371-5
  a curric:KeyLearningPoint ;
  rdfs:label """The gradient of a rate of reaction graph can be calculated from a tangent drawn at a
  point on the curve."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588619Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6578-1
  a curric:KeyLearningPoint ;
  rdfs:label "The velocity of an object is its speed in a given direction."@en ;
  dcterms:modified "2026-06-07T15:30:29.588624Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6578-2
  a curric:KeyLearningPoint ;
  rdfs:label """The displacement of an object is the distance it travels in a particular
  direction."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588628Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6578-3
  a curric:KeyLearningPoint ;
  rdfs:label "Displacement and velocity are both vector quantities."@en ;
  dcterms:modified "2026-06-07T15:30:29.588633Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6578-4
  a curric:KeyLearningPoint ;
  rdfs:label """Velocity has a positive value in one direction and negative value in the opposite
  direction."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588640Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8369-1
  a curric:KeyLearningPoint ;
  rdfs:label """Fractions of crude oil have different properties and uses, affecting the demand for
  these molecules."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588645Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8369-2
  a curric:KeyLearningPoint ;
  rdfs:label """Larger hydrocarbons can be broken down (cracked) to produce smaller, more useful
  molecules."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588649Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8369-3
  a curric:KeyLearningPoint ;
  rdfs:label """Cracking can be done by various methods including catalytic cracking and steam
  cracking."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588686Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8369-4
  a curric:KeyLearningPoint ;
  rdfs:label """The products of cracking include alkanes and alkenes, which have a double bond
  between two carbon atoms."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588692Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8369-5
  a curric:KeyLearningPoint ;
  rdfs:label """Bromine water changes from orange/brown to colourless in the presence of an
  alkene."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588697Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9634-1
  a curric:KeyLearningPoint ;
  rdfs:label """A simple particle model explains melting, boiling, freezing, and condensing
  processes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588704Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9634-2
  a curric:KeyLearningPoint ;
  rdfs:label """Boiling is when a liquid becomes a gas throughout, forming bubbles. Condensation is
  when gas turns into liquid."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588709Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9634-3
  a curric:KeyLearningPoint ;
  rdfs:label """Melting is when a solid turns into a liquid with added energy. Freezing is the
  reverse: liquid to solid, losing energy."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588716Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9634-4
  a curric:KeyLearningPoint ;
  rdfs:label """The particles remain the same size and shape as they do not have bulk properties
  like melting and boiling points."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588720Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9754-1
  a curric:KeyLearningPoint ;
  rdfs:label "Purification of copper involves using copper electrodes in an electrolyte."@en ;
  dcterms:modified "2026-06-07T15:30:29.588725Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9754-2
  a curric:KeyLearningPoint ;
  rdfs:label """The electrolyte must contain the same ions, in solution, as the metal being purified
  by electrolysis."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588729Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9754-3
  a curric:KeyLearningPoint ;
  rdfs:label """Measuring the mass change in the copper electrodes demonstrates the transfer of
  copper."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588734Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9754-4
  a curric:KeyLearningPoint ;
  rdfs:label """Impurities in the anode do not transfer to the cathode, leading to pure copper
  deposition."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588738Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9754-5
  a curric:KeyLearningPoint ;
  rdfs:label """Other uses for this technique include electroplating, where you would use multiple
  metals e.g. gold."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588742Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9640-1
  a curric:KeyLearningPoint ;
  rdfs:label "A solution is a type of mixture made of a solvent and a solute."@en ;
  dcterms:modified "2026-06-07T15:30:29.588747Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9640-2
  a curric:KeyLearningPoint ;
  rdfs:label "Solutions form due to a solute dissolving in the solvent."@en ;
  dcterms:modified "2026-06-07T15:30:29.588751Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9640-3
  a curric:KeyLearningPoint ;
  rdfs:label "Solubility is a measure of how well a chemical dissolves (soluble/insoluble)."@en ;
  dcterms:modified "2026-06-07T15:30:29.588755Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9640-4
  a curric:KeyLearningPoint ;
  rdfs:label "Many substances can act as a solvent; however, water is the most common."@en ;
  dcterms:modified "2026-06-07T15:30:29.588760Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9640-5
  a curric:KeyLearningPoint ;
  rdfs:label """State symbols are used to identify the three states of matter and aqueous solutions
  in chemical equations."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588764Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9679-1
  a curric:KeyLearningPoint ;
  rdfs:label """Data collected during a titration allows chemists to determine a solution’s unknown
  concentration."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588769Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9679-2
  a curric:KeyLearningPoint ;
  rdfs:label """Concordant titres should be used when calculating a mean volume used to neutralise a
  solution."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588773Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9679-3
  a curric:KeyLearningPoint ;
  rdfs:label """The coefficients in a balanced equation indicates the stoichiometry (i.e. molar
  ratio) between substances in a reaction."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588778Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9679-4
  a curric:KeyLearningPoint ;
  rdfs:label """The concentration of an unknown solution is found using the relationship:
  concentration = moles ÷ volume (in dm³)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588782Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9715-1
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists discovered and isolated fullerenes accidentally, which led to exciting
  new possibilities in chemistry."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588788Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9715-2
  a curric:KeyLearningPoint ;
  rdfs:label """Research into the allotropes of carbon is an important part of chemistry's history,
  earning multiple Nobel Prizes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588793Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9715-3
  a curric:KeyLearningPoint ;
  rdfs:label """Graphene is so thin that it's nearly transparent, allowing most light to pass
  through."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588798Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9715-4
  a curric:KeyLearningPoint ;
  rdfs:label """Fullerenes, nanotubes, and graphene have a wide range of real-world uses in fields
  like electronics and medicine."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588802Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9715-5
  a curric:KeyLearningPoint ;
  rdfs:label """Scientific discoveries have the power to change the world, even if their
  significance takes time to be fully understood."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588807Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5541-1
  a curric:KeyLearningPoint ;
  rdfs:label "Neurones are specialised cells that transmit nerve impulses"@en ;
  dcterms:modified "2026-06-07T15:30:29.588811Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5541-2
  a curric:KeyLearningPoint ;
  rdfs:label "The common structures of neurones, including cell body and axon"@en ;
  dcterms:modified "2026-06-07T15:30:29.588816Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5541-3
  a curric:KeyLearningPoint ;
  rdfs:label "A myelin sheath on some neurones increases the speed of the nerve impulse"@en ;
  dcterms:modified "2026-06-07T15:30:29.588820Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5541-4
  a curric:KeyLearningPoint ;
  rdfs:label "Nerve impulses pass from one neurone to another across a gap called a synapse"@en ;
  dcterms:modified "2026-06-07T15:30:29.588825Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5541-5
  a curric:KeyLearningPoint ;
  rdfs:label """An impulse arriving at a synapse releases neurotransmitters that diffuse across the
  gap to receptors on the next neurone"""@en ;
  dcterms:modified "2026-06-07T15:30:29.588829Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7954-1
  a curric:KeyLearningPoint ;
  rdfs:label "The hormone insulin helps to control blood sugar level in the human body."@en ;
  dcterms:modified "2026-06-07T15:30:29.588834Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7954-2
  a curric:KeyLearningPoint ;
  rdfs:label "Insulin is secreted by cells in a gland called the pancreas."@en ;
  dcterms:modified "2026-06-07T15:30:29.588838Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7954-3
  a curric:KeyLearningPoint ;
  rdfs:label """People living with diabetes have problems with controlling their blood sugar
  level."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588843Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7954-4
  a curric:KeyLearningPoint ;
  rdfs:label "The cause and treatments for type 1 diabetes."@en ;
  dcterms:modified "2026-06-07T15:30:29.588847Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7954-5
  a curric:KeyLearningPoint ;
  rdfs:label "The cause and treatments for type 2 diabetes."@en ;
  dcterms:modified "2026-06-07T15:30:29.588851Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8103-1
  a curric:KeyLearningPoint ;
  rdfs:label """Reproduction is part of the life cycle of all organisms; sexual reproduction
  requires specialised cells called gametes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588856Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8103-2
  a curric:KeyLearningPoint ;
  rdfs:label "Gametes are made from body cells by a type of cell division called meiosis."@en ;
  dcterms:modified "2026-06-07T15:30:29.588863Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8103-3
  a curric:KeyLearningPoint ;
  rdfs:label """During interphase the chromosomes are copied; meiosis follows this and includes two
  rounds of cell division."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588867Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8103-4
  a curric:KeyLearningPoint ;
  rdfs:label """The gametes made by meiosis have half the usual number of chromosomes (one from each
  pair in the original body cell)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588874Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8103-5
  a curric:KeyLearningPoint ;
  rdfs:label """Mitosis produces 2 genetically identical diploid cells, whereas meiosis produces 4
  genetically different haploid cells."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588879Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5586-1
  a curric:KeyLearningPoint ;
  rdfs:label """Water and mineral ions are transported from the roots, up the stem, to the leaves,
  in vessels made of xylem."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588883Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5586-2
  a curric:KeyLearningPoint ;
  rdfs:label """Xylem is made of dead, empty cells with no cytoplasm, that form a tube with a tough
  wall made of lignin."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588888Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5586-3
  a curric:KeyLearningPoint ;
  rdfs:label """Water is continually lost from the surface of a plant when water molecules diffuse
  into the air through open stomata."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588892Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5586-4
  a curric:KeyLearningPoint ;
  rdfs:label """Water is pulled up through xylem tubes to replace the water lost through open
  stomata; this process is transpiration."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588896Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5586-5
  a curric:KeyLearningPoint ;
  rdfs:label """The water that is pulled through xylem tubes has mineral ions dissolved in it,
  including nitrate ions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588901Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9185-1
  a curric:KeyLearningPoint ;
  rdfs:label """Some, but not all, fungi are pathogens that can cause communicable diseases in
  humans."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588954Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9185-2
  a curric:KeyLearningPoint ;
  rdfs:label """Athlete’s foot as an example of a fungal disease, how it is spread, and how the
  spread can be reduced."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588961Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9185-3
  a curric:KeyLearningPoint ;
  rdfs:label "Protists are eukaryotic microorganisms."@en ;
  dcterms:modified "2026-06-07T15:30:29.588966Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9185-4
  a curric:KeyLearningPoint ;
  rdfs:label """Malaria as an example of a disease caused by a protist, spread by an insect vector,
  and how the spread can be reduced."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588970Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9185-5
  a curric:KeyLearningPoint ;
  rdfs:label """The interaction of sickle-cell trait and malaria as an example of interaction
  between different types of disease."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588974Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7166-1
  a curric:KeyLearningPoint ;
  rdfs:label """After exposure to a pathogen, memory cells remain in the body to provide
  immunity."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588979Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7166-2
  a curric:KeyLearningPoint ;
  rdfs:label """Vaccination creates immunity by injecting a small amount of a dead or inactivated
  pathogen in a vaccine into the body."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588983Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7166-3
  a curric:KeyLearningPoint ;
  rdfs:label """White blood cells mount an immune response by producing antibodies against the
  pathogen in the vaccine."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588988Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7166-4
  a curric:KeyLearningPoint ;
  rdfs:label """Some of the white blood cells stay in the body as memory cells to provide immunity
  to the pathogen in the vaccine."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588992Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7166-5
  a curric:KeyLearningPoint ;
  rdfs:label """Upon reinfection by the pathogen, memory cells respond by rapidly making antibodies
  against the pathogen."""@en ;
  dcterms:modified "2026-06-07T15:30:29.588997Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7160-1
  a curric:KeyLearningPoint ;
  rdfs:label "Cancer is a non-communicable disease."@en ;
  dcterms:modified "2026-06-07T15:30:29.589001Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7160-2
  a curric:KeyLearningPoint ;
  rdfs:label "Cancer is when cells divide uncontrollably and form a tumour."@en ;
  dcterms:modified "2026-06-07T15:30:29.589005Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7160-3
  a curric:KeyLearningPoint ;
  rdfs:label "Tumours can be benign or malignant."@en ;
  dcterms:modified "2026-06-07T15:30:29.589010Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7160-4
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists have identified risk factors for certain cancers, including lifestyle and
  genetic factors."""@en ;
  dcterms:modified "2026-06-07T15:30:29.589017Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7160-5
  a curric:KeyLearningPoint ;
  rdfs:label """Infection with the sexually transmitted infection HPV can increase the risk of
  cervical cancer."""@en ;
  dcterms:modified "2026-06-07T15:30:29.589022Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6392-1
  a curric:KeyLearningPoint ;
  rdfs:label """The fossil record is made up of millions of fossils aged from 10,000 to billions of
  years old."""@en ;
  dcterms:modified "2026-06-07T15:30:29.589026Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6392-2
  a curric:KeyLearningPoint ;
  rdfs:label "Fossils show that some species have gone extinct."@en ;
  dcterms:modified "2026-06-07T15:30:29.589031Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6392-3
  a curric:KeyLearningPoint ;
  rdfs:label "Fossils show that the features of some species have changed (evolved) over time."@en ;
  dcterms:modified "2026-06-07T15:30:29.589035Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6392-4
  a curric:KeyLearningPoint ;
  rdfs:label """An example of a series of fossils showing changes from evolutionary ancestors to
  modern species (e.g. whales)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.589040Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9182-1
  a curric:KeyLearningPoint ;
  rdfs:label """Some but not all bacteria are pathogens that can cause communicable diseases in
  humans."""@en ;
  dcterms:modified "2026-06-07T15:30:29.589046Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9182-2
  a curric:KeyLearningPoint ;
  rdfs:label """Pathogenic bacteria can produce toxins that damage living tissue and cause
  disease."""@en ;
  dcterms:modified "2026-06-07T15:30:29.589051Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9182-3
  a curric:KeyLearningPoint ;
  rdfs:label """Salmonella food poisoning as an example of a bacterial disease, how it is spread,
  and how the spread can be reduced."""@en ;
  dcterms:modified "2026-06-07T15:30:29.589055Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9182-4
  a curric:KeyLearningPoint ;
  rdfs:label "Viruses invade cells to reproduce where they cause damage to cells."@en ;
  dcterms:modified "2026-06-07T15:30:29.589060Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9182-5
  a curric:KeyLearningPoint ;
  rdfs:label """Measles as an example of a viral disease, how it is spread, and how the spread can
  be reduced."""@en ;
  dcterms:modified "2026-06-07T15:30:29.589064Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9111-1
  a curric:KeyLearningPoint ;
  rdfs:label """Current can be calculated using the equation: current = p.d. ÷ resistance (I = V ÷
  R)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.589069Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9111-2
  a curric:KeyLearningPoint ;
  rdfs:label """The rules of current and p.d. for a series circuit can be applied to find some
  missing values of current and p.d."""@en ;
  dcterms:modified "2026-06-07T15:30:29.589073Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9111-3
  a curric:KeyLearningPoint ;
  rdfs:label """The equation I = V ÷ R can be rearranged so that either V or R is the subject of the
  equation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.589080Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9111-4
  a curric:KeyLearningPoint ;
  rdfs:label """If any two values in the equation I = V ÷ R are known, the third can be
  calculated."""@en ;
  dcterms:modified "2026-06-07T15:30:29.589085Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9111-5
  a curric:KeyLearningPoint ;
  rdfs:label """If only one value in the equation I = V ÷ R is known, rules for current or p.d. need
  to be applied to find a second."""@en ;
  dcterms:modified "2026-06-07T15:30:29.589089Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5048-1
  a curric:KeyLearningPoint ;
  rdfs:label """To find standing wave frequencies, increase the frequency of the oscillator until a
  standing wave pattern is seen."""@en ;
  dcterms:modified "2026-06-07T15:30:29.589093Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5048-2
  a curric:KeyLearningPoint ;
  rdfs:label """The wavelength of the waves can be found from the length of the oscillating string
  and the standing wave pattern"""@en ;
  dcterms:modified "2026-06-07T15:30:29.589098Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5048-3
  a curric:KeyLearningPoint ;
  rdfs:label """The speed of waves on a string only depends on the properties of the wave medium
  (the string)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.589102Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5048-4
  a curric:KeyLearningPoint ;
  rdfs:label "For waves on a string, frequency and wavelength are inversely proportional"@en ;
  dcterms:modified "2026-06-07T15:30:29.589106Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5048-5
  a curric:KeyLearningPoint ;
  rdfs:label """Control variables are the quantities that must be kept the same during experiments
  so they don’t affect results."""@en ;
  dcterms:modified "2026-06-07T15:30:29.589111Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7986-1
  a curric:KeyLearningPoint ;
  rdfs:label """DNA is made of two strands, each a long polymer of nucleotides, wound together in a
  double helix shape."""@en ;
  dcterms:modified "2026-06-07T15:30:29.589452Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7986-2
  a curric:KeyLearningPoint ;
  rdfs:label "DNA is a polymer of four different nucleotides (A, C, G and T)."@en ;
  dcterms:modified "2026-06-07T15:30:29.589456Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7986-3
  a curric:KeyLearningPoint ;
  rdfs:label """Nucleotides in each strand of DNA pair up in a complementary way; A pairs with T,
  and C pairs with G."""@en ;
  dcterms:modified "2026-06-07T15:30:29.589462Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7986-4
  a curric:KeyLearningPoint ;
  rdfs:label """The DNA in chromosomes is unwound & copied during interphase, then the copies
  separate and the cell divides by mitosis."""@en ;
  dcterms:modified "2026-06-07T15:30:29.589467Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7986-5
  a curric:KeyLearningPoint ;
  rdfs:label """Complementary base pairing allows an exact copy of each ‘unzipped’ DNA strand to be
  made from free nucleotides."""@en ;
  dcterms:modified "2026-06-07T15:30:29.589471Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8005-1
  a curric:KeyLearningPoint ;
  rdfs:label "FSH causes follicle maturation and secretion of oestrogen by the ovaries."@en ;
  dcterms:modified "2026-06-07T15:30:29.589475Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8005-2
  a curric:KeyLearningPoint ;
  rdfs:label """Oestrogen causes thickening of uterus wall, secretion of LH by the pituitary gland
  and inhibits the release of FSH."""@en ;
  dcterms:modified "2026-06-07T15:30:29.589480Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8005-3
  a curric:KeyLearningPoint ;
  rdfs:label """LH causes ovulation; FSH and LH cause the mature follicle to break down and secrete
  progesterone."""@en ;
  dcterms:modified "2026-06-07T15:30:29.589484Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8005-4
  a curric:KeyLearningPoint ;
  rdfs:label """Progesterone prepares uterus lining for implantation of fertilised egg; stops
  secretion of LH & FSH by pituitary gland."""@en ;
  dcterms:modified "2026-06-07T15:30:29.589488Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8005-5
  a curric:KeyLearningPoint ;
  rdfs:label "Fall in progesterone causes menstruation."@en ;
  dcterms:modified "2026-06-07T15:30:29.589493Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20362-1
  a curric:KeyLearningPoint ;
  rdfs:label """In a chemical reaction, the atoms in reactants are rearranged and are the same atoms
  that are in the products."""@en ;
  dcterms:modified "2026-06-07T15:30:29.589497Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20362-2
  a curric:KeyLearningPoint ;
  rdfs:label """The mass of products in a chemical reaction is equal to the mass of the
  reactants."""@en ;
  dcterms:modified "2026-06-07T15:30:29.589501Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20362-3
  a curric:KeyLearningPoint ;
  rdfs:label """The sum of the RFM of the reactants equals the sum of the RFM of the products,
  taking account of balancing coefficients."""@en ;
  dcterms:modified "2026-06-07T15:30:29.589506Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8351-1
  a curric:KeyLearningPoint ;
  rdfs:label "A salt is formed when an acid neutralises a base."@en ;
  dcterms:modified "2026-06-07T15:30:29.589510Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8351-2
  a curric:KeyLearningPoint ;
  rdfs:label """Salts are giant, 3D ionic structures that form crystals with regular arrangements of
  ions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.589516Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8351-3
  a curric:KeyLearningPoint ;
  rdfs:label """The empirical chemical formula of a salt provides the ratio of metal to non-metal
  ions it contains."""@en ;
  dcterms:modified "2026-06-07T15:30:29.589523Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8351-4
  a curric:KeyLearningPoint ;
  rdfs:label """Acids contain aqueous hydrogen ions, H⁺(aq) and alkalis contain aqueous hydroxide
  ions, OH⁻(aq)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.589528Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8351-5
  a curric:KeyLearningPoint ;
  rdfs:label "During a neutralisation reaction: H⁺(aq) + OH⁻(aq) → H₂O(l)."@en ;
  dcterms:modified "2026-06-07T15:30:29.589532Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8348-1
  a curric:KeyLearningPoint ;
  rdfs:label "Typical atomic radii, and bond length, are in the order of 10⁻¹⁰m."@en ;
  dcterms:modified "2026-06-07T15:30:29.589539Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8348-2
  a curric:KeyLearningPoint ;
  rdfs:label "Non-metal elements and non-metal compounds form covalent structures."@en ;
  dcterms:modified "2026-06-07T15:30:29.589543Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8348-3
  a curric:KeyLearningPoint ;
  rdfs:label """Simple covalent substances have no free moving charge carriers so cannot conduct
  electricity (some giant covalent can)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.589548Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8348-4
  a curric:KeyLearningPoint ;
  rdfs:label """Small molecules are usually gases or liquids with relatively low melting and boiling
  points."""@en ;
  dcterms:modified "2026-06-07T15:30:29.589552Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8348-5
  a curric:KeyLearningPoint ;
  rdfs:label """Giant covalent structures have high melting/boiling points because strong covalent
  bonds need to be broken."""@en ;
  dcterms:modified "2026-06-07T15:30:29.589556Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9722-1
  a curric:KeyLearningPoint ;
  rdfs:label """There is a correlation between increasing amounts of atmospheric carbon dioxide and
  a rising average global temperature."""@en ;
  dcterms:modified "2026-06-07T15:30:29.589560Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9722-2
  a curric:KeyLearningPoint ;
  rdfs:label "Increases in atmospheric carbon dioxide have been caused by human activity."@en ;
  dcterms:modified "2026-06-07T15:30:29.589565Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9722-3
  a curric:KeyLearningPoint ;
  rdfs:label """Overwhelming evidence shows human activity is responsible for the rapid global
  warming of the last 200 years."""@en ;
  dcterms:modified "2026-06-07T15:30:29.589569Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9722-4
  a curric:KeyLearningPoint ;
  rdfs:label """Global warming measurements and conclusions are reliable despite some unavoidable
  uncertainty in measured values."""@en ;
  dcterms:modified "2026-06-07T15:30:29.589573Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9722-5
  a curric:KeyLearningPoint ;
  rdfs:label """Carbon footprints measure the annual greenhouse gas emissions of individuals,
  industry and nations."""@en ;
  dcterms:modified "2026-06-07T15:30:29.589577Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27390-1
  a curric:KeyLearningPoint ;
  rdfs:label "Corrosion is a general process of degradation of metals through various causes."@en ;
  dcterms:modified "2026-06-07T15:30:29.589582Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27390-2
  a curric:KeyLearningPoint ;
  rdfs:label """Rusting is a specific type of corrosion, affecting iron in the presence of air and
  moisture."""@en ;
  dcterms:modified "2026-06-07T15:30:29.589586Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27390-3
  a curric:KeyLearningPoint ;
  rdfs:label """A metal oxide layer can protect the underlying metal if the oxide forms a physical
  barrier."""@en ;
  dcterms:modified "2026-06-07T15:30:29.589590Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27390-4
  a curric:KeyLearningPoint ;
  rdfs:label """Some coatings are reactive and contain a more reactive metal to provide sacrificial
  protection, e.g. zinc to galvanise."""@en ;
  dcterms:modified "2026-06-07T15:30:29.589595Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27390-5
  a curric:KeyLearningPoint ;
  rdfs:label """Electroplating can be used to improve the appearance and/or the resistance to
  corrosion of metal objects."""@en ;
  dcterms:modified "2026-06-07T15:30:29.589599Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9675-1
  a curric:KeyLearningPoint ;
  rdfs:label """A chemical equation is used to represent the chemical reaction that occurs during
  the formation of a compound."""@en ;
  dcterms:modified "2026-06-07T15:30:29.589605Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9675-2
  a curric:KeyLearningPoint ;
  rdfs:label """Ionic equations can be used to show only the chemical species that are changing
  within a reaction."""@en ;
  dcterms:modified "2026-06-07T15:30:29.589612Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9675-3
  a curric:KeyLearningPoint ;
  rdfs:label """State symbols (s), (l), (g) and (aq), are used in ionic equations to show which
  substances change."""@en ;
  dcterms:modified "2026-06-07T15:30:29.589617Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9675-4
  a curric:KeyLearningPoint ;
  rdfs:label """The ionic equation for water formation (neutralisation) is H⁺(aq) + OH⁻(aq) →
  H2O(l)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.589621Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5589-1
  a curric:KeyLearningPoint ;
  rdfs:label """Cells in all parts of a multicellular plant need water and nutrients, such as
  mineral ions, to stay alive."""@en ;
  dcterms:modified "2026-06-07T15:30:29.589625Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5589-2
  a curric:KeyLearningPoint ;
  rdfs:label """Xylem and phloem transport substances around the plant and minimise the distance
  they have to diffuse to reach cells."""@en ;
  dcterms:modified "2026-06-07T15:30:29.589630Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5589-3
  a curric:KeyLearningPoint ;
  rdfs:label "Root hair cells are an example of an exchange surface in plants."@en ;
  dcterms:modified "2026-06-07T15:30:29.589634Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5589-4
  a curric:KeyLearningPoint ;
  rdfs:label """The root hair cell membrane is adapted to maximise the surface area for osmosis of
  water and active transport of ions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.589639Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9183-1
  a curric:KeyLearningPoint ;
  rdfs:label """Some, but not all, bacteria are pathogens that can cause communicable diseases in
  humans."""@en ;
  dcterms:modified "2026-06-07T15:30:29.589643Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9183-2
  a curric:KeyLearningPoint ;
  rdfs:label "Pathogenic bacteria produce toxins that damage living tissue and cause disease."@en ;
  dcterms:modified "2026-06-07T15:30:29.589647Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9183-3
  a curric:KeyLearningPoint ;
  rdfs:label """Cholera, TB and Helicobacter stomach ulcers as example; how they are spread, and how
  the spread can be reduced."""@en ;
  dcterms:modified "2026-06-07T15:30:29.589652Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9183-4
  a curric:KeyLearningPoint ;
  rdfs:label "Viruses invade cells to reproduce where they cause damage to cells."@en ;
  dcterms:modified "2026-06-07T15:30:29.589656Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9183-5
  a curric:KeyLearningPoint ;
  rdfs:label """Ebola as an example of a viral disease; how it is spread, and how the spread can be
  reduced."""@en ;
  dcterms:modified "2026-06-07T15:30:29.589660Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6288-1
  a curric:KeyLearningPoint ;
  rdfs:label "Most cells are too small to be seen without a microscope."@en ;
  dcterms:modified "2026-06-07T15:30:29.589667Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6288-2
  a curric:KeyLearningPoint ;
  rdfs:label """Comparison of the sizes of cells and cell structures in µm, nm, and in mm in
  standard form."""@en ;
  dcterms:modified "2026-06-07T15:30:29.589672Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6288-3
  a curric:KeyLearningPoint ;
  rdfs:label "Light microscopes have limited magnification and resolution."@en ;
  dcterms:modified "2026-06-07T15:30:29.589676Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6288-4
  a curric:KeyLearningPoint ;
  rdfs:label """Electron microscopes have greater magnification and resolution, allowing much
  smaller structures to be seen clearly."""@en ;
  dcterms:modified "2026-06-07T15:30:29.589680Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6288-5
  a curric:KeyLearningPoint ;
  rdfs:label "Electron microscopy has increased our understanding of sub-cellular structures."@en ;
  dcterms:modified "2026-06-07T15:30:29.589685Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6397-1
  a curric:KeyLearningPoint ;
  rdfs:label """The theory of evolution by natural selection suggests that all modern species
  evolved from earlier species."""@en ;
  dcterms:modified "2026-06-07T15:30:29.589691Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6397-2
  a curric:KeyLearningPoint ;
  rdfs:label """Natural selection causes each generation of a species to become better adapted to
  its environment."""@en ;
  dcterms:modified "2026-06-07T15:30:29.589695Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6397-3
  a curric:KeyLearningPoint ;
  rdfs:label """Natural selection can cause common features of a population to change so much that
  we classify them as a new species."""@en ;
  dcterms:modified "2026-06-07T15:30:29.589700Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6397-4
  a curric:KeyLearningPoint ;
  rdfs:label """Populations of the same species living in different conditions can evolve to become
  separate species."""@en ;
  dcterms:modified "2026-06-07T15:30:29.589706Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6397-5
  a curric:KeyLearningPoint ;
  rdfs:label """An example of speciation of populations living in different conditions (e.g.
  Galápagos tortoises)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.589711Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8366-1
  a curric:KeyLearningPoint ;
  rdfs:label "Crude oil is a non-renewable mixture of different hydrocarbons and impurities."@en ;
  dcterms:modified "2026-06-07T15:30:29.589716Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8366-2
  a curric:KeyLearningPoint ;
  rdfs:label """Crude oil can be separated into groups of hydrocarbon molecules of similar size,
  called fractions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.589720Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8366-3
  a curric:KeyLearningPoint ;
  rdfs:label "Most of the hydrocarbon molecules in crude oil are alkanes."@en ;
  dcterms:modified "2026-06-07T15:30:29.589724Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8366-4
  a curric:KeyLearningPoint ;
  rdfs:label """Smaller hydrocarbon molecules have lower boiling points, are more flammable, and are
  less viscous."""@en ;
  dcterms:modified "2026-06-07T15:30:29.589728Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8366-5
  a curric:KeyLearningPoint ;
  rdfs:label """Fractions of crude oil include petroleum gases, petrol, kerosene, diesel oil, heavy
  fuel oil, and bitumen."""@en ;
  dcterms:modified "2026-06-07T15:30:29.589733Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9114-1
  a curric:KeyLearningPoint ;
  rdfs:label "Power is equal to the rate at which work is done."@en ;
  dcterms:modified "2026-06-07T15:30:29.590152Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9114-2
  a curric:KeyLearningPoint ;
  rdfs:label "Power is equal to the rate at which energy is transferred."@en ;
  dcterms:modified "2026-06-07T15:30:29.590156Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9114-3
  a curric:KeyLearningPoint ;
  rdfs:label "Power = work done ÷ time."@en ;
  dcterms:modified "2026-06-07T15:30:29.590160Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9114-4
  a curric:KeyLearningPoint ;
  rdfs:label "Power is measured in watts (W)."@en ;
  dcterms:modified "2026-06-07T15:30:29.590167Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28016-1
  a curric:KeyLearningPoint ;
  rdfs:label "A non–renewable energy resource cannot be replenished as it is used."@en ;
  dcterms:modified "2026-06-07T15:30:29.590171Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28016-2
  a curric:KeyLearningPoint ;
  rdfs:label """Non-renewable energy resources include fossil fuels (coal, oil and gas) and nuclear
  fuels."""@en ;
  dcterms:modified "2026-06-07T15:30:29.590176Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28016-3
  a curric:KeyLearningPoint ;
  rdfs:label "A renewable energy resource can be replenished as it is used."@en ;
  dcterms:modified "2026-06-07T15:30:29.590180Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28016-4
  a curric:KeyLearningPoint ;
  rdfs:label """Renewable energy resources include biofuels, wind, hydroelectricity, geothermal,
  tidal, solar and water waves."""@en ;
  dcterms:modified "2026-06-07T15:30:29.590187Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28016-5
  a curric:KeyLearningPoint ;
  rdfs:label """Science can identify environmental issues, but political, social, ethical and
  economic considerations determine action."""@en ;
  dcterms:modified "2026-06-07T15:30:29.590191Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8424-1
  a curric:KeyLearningPoint ;
  rdfs:label """Industrial equilibria involve a trade-off between production rate and equilibrium
  position."""@en ;
  dcterms:modified "2026-06-07T15:30:29.590220Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8424-2
  a curric:KeyLearningPoint ;
  rdfs:label """Temperature, pressure, surface area, concentration, and catalysts impact rates and
  equilibrium, often in opposing ways."""@en ;
  dcterms:modified "2026-06-07T15:30:29.590224Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8424-3
  a curric:KeyLearningPoint ;
  rdfs:label """High pressures and temperatures boost reaction rates but must balance safety and
  cost."""@en ;
  dcterms:modified "2026-06-07T15:30:29.590229Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8424-4
  a curric:KeyLearningPoint ;
  rdfs:label "High pressures are costly and increase equipment failure risk."@en ;
  dcterms:modified "2026-06-07T15:30:29.590233Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8424-5
  a curric:KeyLearningPoint ;
  rdfs:label """Low temperatures slow reactions but can favour desired product in exothermic
  reactions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.590237Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20350-1
  a curric:KeyLearningPoint ;
  rdfs:label """Radio waves, microwaves, IR and visible light are non–ionising EM radiation. They
  can harm cells by heating."""@en ;
  dcterms:modified "2026-06-07T15:30:29.590241Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20350-2
  a curric:KeyLearningPoint ;
  rdfs:label """Radio waves are produced by oscillations of current. When absorbed, they may produce
  oscillations of current."""@en ;
  dcterms:modified "2026-06-07T15:30:29.590245Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20350-3
  a curric:KeyLearningPoint ;
  rdfs:label """Radio waves and microwaves are used for long distance communication, broadcasting
  and data transmission."""@en ;
  dcterms:modified "2026-06-07T15:30:29.590252Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20350-4
  a curric:KeyLearningPoint ;
  rdfs:label """Microwaves are absorbed by water, so can be used to cook food from within. IR
  radiation cooks the surface of food."""@en ;
  dcterms:modified "2026-06-07T15:30:29.590257Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20350-5
  a curric:KeyLearningPoint ;
  rdfs:label """IR is used for heating and thermal imaging. Visible light and IR are used for data
  transmission in optical fibres."""@en ;
  dcterms:modified "2026-06-07T15:30:29.590261Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5095-1
  a curric:KeyLearningPoint ;
  rdfs:label """A short circuit happens when a wire becomes loose and touches the wrong part of a
  circuit, or makes a new circuit."""@en ;
  dcterms:modified "2026-06-07T15:30:29.590265Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5095-2
  a curric:KeyLearningPoint ;
  rdfs:label """If a live wire touches the inside of a metal case, the metal case may become
  live."""@en ;
  dcterms:modified "2026-06-07T15:30:29.590272Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5095-3
  a curric:KeyLearningPoint ;
  rdfs:label """If there is too much current in an appliance, a fuse on the live wire in its plug
  melts and turns it off."""@en ;
  dcterms:modified "2026-06-07T15:30:29.590276Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5095-4
  a curric:KeyLearningPoint ;
  rdfs:label """From a live metal case, current flows along an earth and live wire, melts a fuse and
  turns the electricity off."""@en ;
  dcterms:modified "2026-06-07T15:30:29.590281Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5095-5
  a curric:KeyLearningPoint ;
  rdfs:label """Domestic circuits with excessive current are turned off by circuit breakers in a
  consumer box to prevent fire."""@en ;
  dcterms:modified "2026-06-07T15:30:29.590285Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27964-1
  a curric:KeyLearningPoint ;
  rdfs:label """Background radiation is caused by unstable nuclei that are around us all of the
  time."""@en ;
  dcterms:modified "2026-06-07T15:30:29.590289Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27964-2
  a curric:KeyLearningPoint ;
  rdfs:label "Atoms are very small with a radius of about 1 × 10⁻¹⁰ m."@en ;
  dcterms:modified "2026-06-07T15:30:29.590293Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27964-3
  a curric:KeyLearningPoint ;
  rdfs:label """The alpha particle scattering experiment (Rutherford, 1909) provides evidence for
  the size and nature of atomic nuclei."""@en ;
  dcterms:modified "2026-06-07T15:30:29.590298Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27964-4
  a curric:KeyLearningPoint ;
  rdfs:label "An atomic nucleus has a radius about 10 000 times smaller than that of an atom."@en ;
  dcterms:modified "2026-06-07T15:30:29.590302Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27964-5
  a curric:KeyLearningPoint ;
  rdfs:label "Most of the mass of an atom is in its nucleus."@en ;
  dcterms:modified "2026-06-07T15:30:29.590306Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4913-1
  a curric:KeyLearningPoint ;
  rdfs:label """A single resultant force has the same effect as several forces acting on an
  object"""@en ;
  dcterms:modified "2026-06-07T15:30:29.590374Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4913-2
  a curric:KeyLearningPoint ;
  rdfs:label """If there is no resultant force on an object, it remains still or continues to move
  at a steady speed in a straight line"""@en ;
  dcterms:modified "2026-06-07T15:30:29.590378Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4913-3
  a curric:KeyLearningPoint ;
  rdfs:label """If there is a resultant force on an object, it will accelerate in the direction of
  the force"""@en ;
  dcterms:modified "2026-06-07T15:30:29.590382Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4913-4
  a curric:KeyLearningPoint ;
  rdfs:label """A resultant force acting in the opposite direction to movement will decelerate (slow
  down) an object"""@en ;
  dcterms:modified "2026-06-07T15:30:29.590387Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9633-1
  a curric:KeyLearningPoint ;
  rdfs:label "There are three states of matter: solid state, liquid state, and gas state."@en ;
  dcterms:modified "2026-06-07T15:30:29.590633Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9633-2
  a curric:KeyLearningPoint ;
  rdfs:label """A substance in the gas state can be compressed because there is empty space between
  the particles."""@en ;
  dcterms:modified "2026-06-07T15:30:29.590637Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9633-3
  a curric:KeyLearningPoint ;
  rdfs:label """A substance in the liquid or solid state cannot be compressed because the particles
  are already touching."""@en ;
  dcterms:modified "2026-06-07T15:30:29.590641Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9633-4
  a curric:KeyLearningPoint ;
  rdfs:label """A substance in the gas or liquid state has no fixed shape as the particles can move
  past each other."""@en ;
  dcterms:modified "2026-06-07T15:30:29.590647Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9633-5
  a curric:KeyLearningPoint ;
  rdfs:label """A substance in the solid state will not flow because the particles vibrate in a
  fixed position."""@en ;
  dcterms:modified "2026-06-07T15:30:29.590652Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9648-1
  a curric:KeyLearningPoint ;
  rdfs:label """Fractional distillation is an extension of simple distillation, and is mostly used
  to separate mixtures of liquids."""@en ;
  dcterms:modified "2026-06-07T15:30:29.590656Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9648-2
  a curric:KeyLearningPoint ;
  rdfs:label """A main distinction between fractional and simple distillation is that the former
  uses a fractionating column."""@en ;
  dcterms:modified "2026-06-07T15:30:29.590660Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9648-3
  a curric:KeyLearningPoint ;
  rdfs:label """Fractional distillation has multiple real-world examples, including the fractional
  distillation of air."""@en ;
  dcterms:modified "2026-06-07T15:30:29.590664Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9648-4
  a curric:KeyLearningPoint ;
  rdfs:label """Fractional distillation produces fractions; these can be pure or mixtures of
  chemicals with very similar boiling points."""@en ;
  dcterms:modified "2026-06-07T15:30:29.590668Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9190-1
  a curric:KeyLearningPoint ;
  rdfs:label "Tobacco mosaic virus is an example of a disease in plants caused by a virus."@en ;
  dcterms:modified "2026-06-07T15:30:29.590672Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9190-2
  a curric:KeyLearningPoint ;
  rdfs:label "Crown gall disease is an example of a disease in plants caused by a bacterium."@en ;
  dcterms:modified "2026-06-07T15:30:29.590677Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9190-3
  a curric:KeyLearningPoint ;
  rdfs:label "Chalara ash dieback is an example of a disease in plants caused by a fungus."@en ;
  dcterms:modified "2026-06-07T15:30:29.590681Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9190-4
  a curric:KeyLearningPoint ;
  rdfs:label """Ways in which plant diseases can be spread, and ways in which the spread can be
  reduced."""@en ;
  dcterms:modified "2026-06-07T15:30:29.590687Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9190-5
  a curric:KeyLearningPoint ;
  rdfs:label "Impacts of plant diseases, including on biodiversity and human food security."@en ;
  dcterms:modified "2026-06-07T15:30:29.590692Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8439-1
  a curric:KeyLearningPoint ;
  rdfs:label "A solid ionic compound cannot conduct electricity."@en ;
  dcterms:modified "2026-06-07T15:30:29.590696Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8439-2
  a curric:KeyLearningPoint ;
  rdfs:label """Salts are ionic compounds which can be electrolysed when they are in the molten
  state."""@en ;
  dcterms:modified "2026-06-07T15:30:29.590700Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8439-3
  a curric:KeyLearningPoint ;
  rdfs:label "Gases may be formed at the electrodes."@en ;
  dcterms:modified "2026-06-07T15:30:29.590704Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8439-4
  a curric:KeyLearningPoint ;
  rdfs:label "Freely moving ions can reach the electrodes and undergo oxidation or reduction."@en ;
  dcterms:modified "2026-06-07T15:30:29.590709Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8439-5
  a curric:KeyLearningPoint ;
  rdfs:label """A non-metal always forms at the positive electrode, and a metal forms at the
  negative electrode."""@en ;
  dcterms:modified "2026-06-07T15:30:29.590712Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8393-1
  a curric:KeyLearningPoint ;
  rdfs:label """In phytoextraction, metal is extracted from a crop of plants that absorb metal ions
  through their roots."""@en ;
  dcterms:modified "2026-06-07T15:30:29.590716Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8393-2
  a curric:KeyLearningPoint ;
  rdfs:label "In bioleaching, metal is extracted from bacteria that extract metal from an ore."@en ;
  dcterms:modified "2026-06-07T15:30:29.590721Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8393-3
  a curric:KeyLearningPoint ;
  rdfs:label "Electrolysis is a process used to separate metals from their compounds."@en ;
  dcterms:modified "2026-06-07T15:30:29.590727Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8393-4
  a curric:KeyLearningPoint ;
  rdfs:label """There are advantages and disadvantages associated with each method of extracting
  metals."""@en ;
  dcterms:modified "2026-06-07T15:30:29.590734Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8193-1
  a curric:KeyLearningPoint ;
  rdfs:label "Most cells are too small to be seen without a microscope."@en ;
  dcterms:modified "2026-06-07T15:30:29.590738Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8193-2
  a curric:KeyLearningPoint ;
  rdfs:label "Comparison of the sizes of cells and cell structures."@en ;
  dcterms:modified "2026-06-07T15:30:29.590742Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8193-3
  a curric:KeyLearningPoint ;
  rdfs:label "Light microscopes have limited magnification and resolution."@en ;
  dcterms:modified "2026-06-07T15:30:29.590746Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8193-4
  a curric:KeyLearningPoint ;
  rdfs:label """Electron microscopes have greater magnification and resolution, allowing much
  smaller structures to be seen clearly."""@en ;
  dcterms:modified "2026-06-07T15:30:29.590753Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8193-5
  a curric:KeyLearningPoint ;
  rdfs:label "Electron microscopy has increased our understanding of sub-cellular structures."@en ;
  dcterms:modified "2026-06-07T15:30:29.590757Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22197-1
  a curric:KeyLearningPoint ;
  rdfs:label """The Contact Process involves the production of sulfur trioxide (SO₃) from sulfur
  dioxide (SO₂) using a catalyst."""@en ;
  dcterms:modified "2026-06-07T15:30:29.590761Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22197-2
  a curric:KeyLearningPoint ;
  rdfs:label """The process has three main stages: burning sulfur to produce SO₂, converting SO₂ to
  SO₃, then converting SO₃ to H₂SO₄."""@en ;
  dcterms:modified "2026-06-07T15:30:29.590765Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22197-3
  a curric:KeyLearningPoint ;
  rdfs:label """The conversion of SO₂ to SO₃ is a reversible reaction performed at 1-2 atmospheres
  and 450°C, using a V₂O₅ catalyst."""@en ;
  dcterms:modified "2026-06-07T15:30:29.590770Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22197-4
  a curric:KeyLearningPoint ;
  rdfs:label """Sulfuric acid production is energy-intensive and releases large amounts of CO₂,
  contributing to global emissions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.590774Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22197-5
  a curric:KeyLearningPoint ;
  rdfs:label """Sulfuric acid is vital for various industries, such as: fertilisers, chemical
  manufacturing, and petroleum refining."""@en ;
  dcterms:modified "2026-06-07T15:30:29.590778Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9649-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Potable' and 'pure' water are not the same substance."@en ;
  dcterms:modified "2026-06-07T15:30:29.590782Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9649-2
  a curric:KeyLearningPoint ;
  rdfs:label "Water used in analysis must not contain any dissolved ions."@en ;
  dcterms:modified "2026-06-07T15:30:29.590786Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9649-3
  a curric:KeyLearningPoint ;
  rdfs:label "The method used to obtain potable water depends on the water source."@en ;
  dcterms:modified "2026-06-07T15:30:29.590790Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9649-4
  a curric:KeyLearningPoint ;
  rdfs:label """Sedimentation, filtration and chlorination are used to obtain potable water from
  groundwater and fresh water sources."""@en ;
  dcterms:modified "2026-06-07T15:30:29.590794Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9649-5
  a curric:KeyLearningPoint ;
  rdfs:label """Desalination of seawater creates potable water by distillation or reverse
  osmosis."""@en ;
  dcterms:modified "2026-06-07T15:30:29.590799Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9710-1
  a curric:KeyLearningPoint ;
  rdfs:label "Reduction is the gain of electrons, and oxidation is the loss of electrons."@en ;
  dcterms:modified "2026-06-07T15:30:29.590803Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9710-2
  a curric:KeyLearningPoint ;
  rdfs:label "Displacement reactions are often examples of redox reactions."@en ;
  dcterms:modified "2026-06-07T15:30:29.590812Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9710-3
  a curric:KeyLearningPoint ;
  rdfs:label "Half equations show which elements are oxidised, and which are reduced."@en ;
  dcterms:modified "2026-06-07T15:30:29.590817Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8432-1
  a curric:KeyLearningPoint ;
  rdfs:label "DNA is made from monomers called nucleotides."@en ;
  dcterms:modified "2026-06-07T15:30:29.590821Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8432-2
  a curric:KeyLearningPoint ;
  rdfs:label "Natural polymers are important for life."@en ;
  dcterms:modified "2026-06-07T15:30:29.590826Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8432-3
  a curric:KeyLearningPoint ;
  rdfs:label "The carbohydrates starch and cellulose are made from the monomer glucose."@en ;
  dcterms:modified "2026-06-07T15:30:29.590832Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8432-4
  a curric:KeyLearningPoint ;
  rdfs:label """Amino acids contain two functional groups and can form polypeptides and
  proteins."""@en ;
  dcterms:modified "2026-06-07T15:30:29.590837Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8342-1
  a curric:KeyLearningPoint ;
  rdfs:label "Salts form ionic structures because they contain metal and non-metal ions."@en ;
  dcterms:modified "2026-06-07T15:30:29.590841Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8342-2
  a curric:KeyLearningPoint ;
  rdfs:label """In an ionic structure each positive ion attracts the negative ions and
  vice-versa."""@en ;
  dcterms:modified "2026-06-07T15:30:29.590845Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8342-3
  a curric:KeyLearningPoint ;
  rdfs:label """Metal ions attract all non-metal ions and vice-versa, they bond to the opposite
  charged ions that are closest."""@en ;
  dcterms:modified "2026-06-07T15:30:29.590850Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8342-4
  a curric:KeyLearningPoint ;
  rdfs:label """An ionic bond is the electrostatic force of attraction between oppositely-charged
  ions acting in all directions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.590854Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8342-5
  a curric:KeyLearningPoint ;
  rdfs:label """Ionic substances are 3D lattices with regular arrangements of ions ( in a repeating
  pattern of +ve and -ve charge)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.590858Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9157-1
  a curric:KeyLearningPoint ;
  rdfs:label """All organisms (including animals, plants, fungi and micro-organisms) are made up of
  one or more living cells."""@en ;
  dcterms:modified "2026-06-07T15:30:29.590862Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9157-2
  a curric:KeyLearningPoint ;
  rdfs:label """All cells have some structures in common (cell membrane and cytoplasm) and have a
  three-dimensional shape."""@en ;
  dcterms:modified "2026-06-07T15:30:29.590866Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9157-3
  a curric:KeyLearningPoint ;
  rdfs:label """Chemical reactions essential to life occur in cytoplasm; the cell membrane regulates
  the cell’s internal environment."""@en ;
  dcterms:modified "2026-06-07T15:30:29.590870Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9157-4
  a curric:KeyLearningPoint ;
  rdfs:label """Many animals and plants are multicellular; they are made up of many cells organised
  to form tissues and organs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.590875Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9157-5
  a curric:KeyLearningPoint ;
  rdfs:label """Micro-organisms such as bacteria are unicellular – they are made of just one
  cell."""@en ;
  dcterms:modified "2026-06-07T15:30:29.590881Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7165-1
  a curric:KeyLearningPoint ;
  rdfs:label """The human body has defences against infection that work against all pathogens (are
  not targeted at specific pathogens)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.590886Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7165-2
  a curric:KeyLearningPoint ;
  rdfs:label "Physical defences include the skin, hairs and cilia."@en ;
  dcterms:modified "2026-06-07T15:30:29.590890Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7165-3
  a curric:KeyLearningPoint ;
  rdfs:label "Chemical defences include tears, saliva and stomach acid."@en ;
  dcterms:modified "2026-06-07T15:30:29.590897Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7165-4
  a curric:KeyLearningPoint ;
  rdfs:label """Microbial defences are provided by microorganisms on, and in, our bodies that
  compete against pathogens."""@en ;
  dcterms:modified "2026-06-07T15:30:29.590902Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7165-5
  a curric:KeyLearningPoint ;
  rdfs:label """White blood cells called phagocytes are part of the immune system and engulf and
  destroy pathogens by phagocytosis."""@en ;
  dcterms:modified "2026-06-07T15:30:29.590906Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7992-1
  a curric:KeyLearningPoint ;
  rdfs:label """Some alleles are associated with conditions that affect people’s health (e.g. cystic
  fibrosis)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.590910Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7992-2
  a curric:KeyLearningPoint ;
  rdfs:label """Prospective parents can be tested for these alleles, as can embryos (embryo
  screening)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.590915Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7992-3
  a curric:KeyLearningPoint ;
  rdfs:label """A fetus can be tested for these alleles (e.g. by chorionic villus sampling or
  amniocentesis)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.590921Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7992-4
  a curric:KeyLearningPoint ;
  rdfs:label """Tests can have false negative or false positive results, and risks of miscarriage or
  infection."""@en ;
  dcterms:modified "2026-06-07T15:30:29.590925Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7992-5
  a curric:KeyLearningPoint ;
  rdfs:label """Parents must be supported to interpret test results, consider ethical questions and
  make difficult personal decisions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.590930Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7978-1
  a curric:KeyLearningPoint ;
  rdfs:label "An individual inherits two copies  of each gene in a pair of chromosomes."@en ;
  dcterms:modified "2026-06-07T15:30:29.590934Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7978-2
  a curric:KeyLearningPoint ;
  rdfs:label """Versions of genes are called alleles, they can be recessive or dominant, indicated
  with a capital or lowercase letter."""@en ;
  dcterms:modified "2026-06-07T15:30:29.590938Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7978-3
  a curric:KeyLearningPoint ;
  rdfs:label "The combination of alleles that an organism has is called its genotype."@en ;
  dcterms:modified "2026-06-07T15:30:29.590942Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7978-4
  a curric:KeyLearningPoint ;
  rdfs:label """Different alleles of a gene are associated with different versions of the same
  characteristic called the phenotype."""@en ;
  dcterms:modified "2026-06-07T15:30:29.590946Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7978-5
  a curric:KeyLearningPoint ;
  rdfs:label """Some phenotypes are determined only by genotype, others are also affected by the
  environment."""@en ;
  dcterms:modified "2026-06-07T15:30:29.590951Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9194-1
  a curric:KeyLearningPoint ;
  rdfs:label "The parts of a light microscope and their functions."@en ;
  dcterms:modified "2026-06-07T15:30:29.590955Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9194-2
  a curric:KeyLearningPoint ;
  rdfs:label """The sequence of steps for setting up a microscope to observe specimens, including
  changing the magnification and focus."""@en ;
  dcterms:modified "2026-06-07T15:30:29.590959Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9194-3
  a curric:KeyLearningPoint ;
  rdfs:label """The steps of applying nail varnish and clear sticky tape to a leaf surface, then
  observing imprints of stomata."""@en ;
  dcterms:modified "2026-06-07T15:30:29.590963Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9194-4
  a curric:KeyLearningPoint ;
  rdfs:label """Light microscopy can be used to observe and compare the density and distribution of
  stomata on different leaf surfaces."""@en ;
  dcterms:modified "2026-06-07T15:30:29.590967Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9194-5
  a curric:KeyLearningPoint ;
  rdfs:label """Explaining observations of stomatal density using ideas about transpiration and
  water loss."""@en ;
  dcterms:modified "2026-06-07T15:30:29.590971Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8399-1
  a curric:KeyLearningPoint ;
  rdfs:label "Carbon monoxide gas is toxic."@en ;
  dcterms:modified "2026-06-07T15:30:29.590995Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8399-2
  a curric:KeyLearningPoint ;
  rdfs:label "Carbon particulates contribute to health issues and global dimming."@en ;
  dcterms:modified "2026-06-07T15:30:29.590999Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8399-3
  a curric:KeyLearningPoint ;
  rdfs:label """Sulfur dioxide and nitrogen oxides are formed through burning fuels, and form acids
  in water."""@en ;
  dcterms:modified "2026-06-07T15:30:29.591003Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8399-4
  a curric:KeyLearningPoint ;
  rdfs:label """Catalytic converters help complete combustion reactions and the removal of nitrogen
  monoxide from exhaust gases."""@en ;
  dcterms:modified "2026-06-07T15:30:29.591008Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8399-5
  a curric:KeyLearningPoint ;
  rdfs:label """Hydrogen can be used as a fuel in cars and this has advantages and
  disadvantages."""@en ;
  dcterms:modified "2026-06-07T15:30:29.591012Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9206-1
  a curric:KeyLearningPoint ;
  rdfs:label "How to measure pulse rate."@en ;
  dcterms:modified "2026-06-07T15:30:29.591079Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9206-2
  a curric:KeyLearningPoint ;
  rdfs:label """How to control the type and duration of exercise to be undertaken by a test
  subject."""@en ;
  dcterms:modified "2026-06-07T15:30:29.591084Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9206-3
  a curric:KeyLearningPoint ;
  rdfs:label """Record resting pulse rate before exercise and take repeated measurements of pulse
  rate after exercise."""@en ;
  dcterms:modified "2026-06-07T15:30:29.591088Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9206-4
  a curric:KeyLearningPoint ;
  rdfs:label """The recovery time is the time it takes for the pulse rate to return to the resting
  rate after exercise."""@en ;
  dcterms:modified "2026-06-07T15:30:29.591092Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9669-1
  a curric:KeyLearningPoint ;
  rdfs:label """Concentration of a solution is the mass of solute dissolved in 1 dm³ of distilled
  water, in g/dm³."""@en ;
  dcterms:modified "2026-06-07T15:30:29.591096Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9669-2
  a curric:KeyLearningPoint ;
  rdfs:label "The more solute that is dissolved, the more concentrated the solution."@en ;
  dcterms:modified "2026-06-07T15:30:29.591100Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9669-3
  a curric:KeyLearningPoint ;
  rdfs:label """Solutions can be diluted (i.e. made less concentrated) by increasing the volume of
  distilled water."""@en ;
  dcterms:modified "2026-06-07T15:30:29.591104Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9669-4
  a curric:KeyLearningPoint ;
  rdfs:label """Diluting solutions with distilled water ensures no other substances are present in
  the solution."""@en ;
  dcterms:modified "2026-06-07T15:30:29.591108Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9669-5
  a curric:KeyLearningPoint ;
  rdfs:label "Volume can be measured in various units; 1 dm³ is equivalent to 1000 cm³."@en ;
  dcterms:modified "2026-06-07T15:30:29.591112Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9922-1
  a curric:KeyLearningPoint ;
  rdfs:label "Power is equal to the rate at which work is done."@en ;
  dcterms:modified "2026-06-07T15:30:29.591119Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9922-2
  a curric:KeyLearningPoint ;
  rdfs:label "Power is equal to the rate at which energy is transferred."@en ;
  dcterms:modified "2026-06-07T15:30:29.591123Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9922-3
  a curric:KeyLearningPoint ;
  rdfs:label "Power = work done ÷ time."@en ;
  dcterms:modified "2026-06-07T15:30:29.591127Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9922-4
  a curric:KeyLearningPoint ;
  rdfs:label "Power is measured in watts (W)."@en ;
  dcterms:modified "2026-06-07T15:30:29.591132Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9167-1
  a curric:KeyLearningPoint ;
  rdfs:label "Most animals and plants are made up of millions or billions of cells."@en ;
  dcterms:modified "2026-06-07T15:30:29.591156Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9167-2
  a curric:KeyLearningPoint ;
  rdfs:label "Cell numbers can be expressed in standard form."@en ;
  dcterms:modified "2026-06-07T15:30:29.591160Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9167-3
  a curric:KeyLearningPoint ;
  rdfs:label "Cells are usually too small to see with the unaided eye."@en ;
  dcterms:modified "2026-06-07T15:30:29.591164Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9167-4
  a curric:KeyLearningPoint ;
  rdfs:label """Comparison of sizes of eukaryotic and prokaryotic cells, and cell structures, in µm,
  nm, and in metres in standard form."""@en ;
  dcterms:modified "2026-06-07T15:30:29.591171Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8107-1
  a curric:KeyLearningPoint ;
  rdfs:label "Infertility is the inability to become pregnant (conceive)."@en ;
  dcterms:modified "2026-06-07T15:30:29.591175Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8107-2
  a curric:KeyLearningPoint ;
  rdfs:label """In adult human females, some types of infertility are caused by problems with
  hormones that control the menstrual cycle."""@en ;
  dcterms:modified "2026-06-07T15:30:29.591180Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8107-3
  a curric:KeyLearningPoint ;
  rdfs:label "Hormones can be used as a treatment for these types of infertility."@en ;
  dcterms:modified "2026-06-07T15:30:29.591184Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8107-4
  a curric:KeyLearningPoint ;
  rdfs:label "The use of hormones in IVF treatment."@en ;
  dcterms:modified "2026-06-07T15:30:29.591188Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20445-1
  a curric:KeyLearningPoint ;
  rdfs:label """Most cells in multicellular organisms go through different phases that are part of a
  cell cycle."""@en ;
  dcterms:modified "2026-06-07T15:30:29.591192Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20445-2
  a curric:KeyLearningPoint ;
  rdfs:label "The main phases of the cell cycle are interphase and mitosis."@en ;
  dcterms:modified "2026-06-07T15:30:29.591196Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20445-3
  a curric:KeyLearningPoint ;
  rdfs:label """During cell interphase, each chromosome is copied, sub-cellular structures are
  copied."""@en ;
  dcterms:modified "2026-06-07T15:30:29.591200Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20445-4
  a curric:KeyLearningPoint ;
  rdfs:label """The stages of mitosis are prophase, metaphase, anaphase, telophase and
  cytokinesis."""@en ;
  dcterms:modified "2026-06-07T15:30:29.591204Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9139-1
  a curric:KeyLearningPoint ;
  rdfs:label "Resultant force = mass × acceleration, F = m × a."@en ;
  dcterms:modified "2026-06-07T15:30:29.591209Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9139-2
  a curric:KeyLearningPoint ;
  rdfs:label """An object that is thrown in the air experiences a constant gravitational force
  towards the centre of the Earth."""@en ;
  dcterms:modified "2026-06-07T15:30:29.591213Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9139-3
  a curric:KeyLearningPoint ;
  rdfs:label """An object that is thrown in the air is constantly accelerating towards the centre of
  the Earth."""@en ;
  dcterms:modified "2026-06-07T15:30:29.591217Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9139-4
  a curric:KeyLearningPoint ;
  rdfs:label """Inertial mass is a measure of how hard it is to change the velocity of an
  object."""@en ;
  dcterms:modified "2026-06-07T15:30:29.591223Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9139-5
  a curric:KeyLearningPoint ;
  rdfs:label "Inertial mass = force ÷ acceleration, m = F ÷ a."@en ;
  dcterms:modified "2026-06-07T15:30:29.591228Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8392-1
  a curric:KeyLearningPoint ;
  rdfs:label "Unreactive metals are often found in the earth as pure metal."@en ;
  dcterms:modified "2026-06-07T15:30:29.591232Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8392-2
  a curric:KeyLearningPoint ;
  rdfs:label """Metals that are less reactive than carbon can be extracted by heating their oxides
  with carbon."""@en ;
  dcterms:modified "2026-06-07T15:30:29.591237Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8392-3
  a curric:KeyLearningPoint ;
  rdfs:label """A metal oxide is said to be reduced by carbon because the metal oxide loses
  oxygen."""@en ;
  dcterms:modified "2026-06-07T15:30:29.591241Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8392-4
  a curric:KeyLearningPoint ;
  rdfs:label """Carbon is oxidised when it reacts with a metal oxide because it gains oxygen to form
  carbon dioxide."""@en ;
  dcterms:modified "2026-06-07T15:30:29.591245Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5573-1
  a curric:KeyLearningPoint ;
  rdfs:label """The hormone adrenaline is secreted by the adrenal gland during stress; it causes the
  body to prepare for rapid action."""@en ;
  dcterms:modified "2026-06-07T15:30:29.591249Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5573-2
  a curric:KeyLearningPoint ;
  rdfs:label """The hormone thyroxine is secreted by the thyroid gland; it controls growth and the
  rates of chemical reactions in cells."""@en ;
  dcterms:modified "2026-06-07T15:30:29.591253Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5573-3
  a curric:KeyLearningPoint ;
  rdfs:label "The pituitary gland secretes hormones that can control other glands."@en ;
  dcterms:modified "2026-06-07T15:30:29.591257Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5573-4
  a curric:KeyLearningPoint ;
  rdfs:label """The pituitary gland secretes TSH, which causes the thyroid gland to secrete
  thyroxine."""@en ;
  dcterms:modified "2026-06-07T15:30:29.591262Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5573-5
  a curric:KeyLearningPoint ;
  rdfs:label """Thyroxine causes the pituitary gland to stop secreting TSH; this is an example of
  negative feedback."""@en ;
  dcterms:modified "2026-06-07T15:30:29.591266Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5577-1
  a curric:KeyLearningPoint ;
  rdfs:label """Word and balanced symbol equations to summarise the chemical reactants and products
  of photosynthesis."""@en ;
  dcterms:modified "2026-06-07T15:30:29.591270Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5577-2
  a curric:KeyLearningPoint ;
  rdfs:label """Photosynthesis is an endothermic chemical process that requires energy from a light
  source such as the Sun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.591275Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5577-3
  a curric:KeyLearningPoint ;
  rdfs:label """Light is not a chemical reactant, but transfers energy to chlorophyll to enable
  photosynthesis to take place."""@en ;
  dcterms:modified "2026-06-07T15:30:29.591279Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5577-4
  a curric:KeyLearningPoint ;
  rdfs:label """Photosynthesis occurs in chloroplasts in cells in green parts of plants, which
  contain chlorophyll to absorb light."""@en ;
  dcterms:modified "2026-06-07T15:30:29.591283Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5577-5
  a curric:KeyLearningPoint ;
  rdfs:label """Chloroplasts and stomata are adaptations of leaves for photosynthesis and gas
  exchange."""@en ;
  dcterms:modified "2026-06-07T15:30:29.591287Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28176-1
  a curric:KeyLearningPoint ;
  rdfs:label "Radioactive contamination is the presence of unwanted radioactive atoms."@en ;
  dcterms:modified "2026-06-07T15:30:29.591749Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28176-2
  a curric:KeyLearningPoint ;
  rdfs:label """A material being exposed to iodising radiation is being irradiated and does not
  become radioactive."""@en ;
  dcterms:modified "2026-06-07T15:30:29.591754Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28176-3
  a curric:KeyLearningPoint ;
  rdfs:label """Radioactive isotopes with short half-lives decay quickly, emitting most radiation
  over a short period of time."""@en ;
  dcterms:modified "2026-06-07T15:30:29.591758Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8380-1
  a curric:KeyLearningPoint ;
  rdfs:label """Measuring volume of gas produced throughout a reaction allows the changing rate of
  reaction to be calculated."""@en ;
  dcterms:modified "2026-06-07T15:30:29.591825Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8380-2
  a curric:KeyLearningPoint ;
  rdfs:label """Errors in measuring volumes of gas over time include timing, reading volumes in real
  time and gas displaced by the bung."""@en ;
  dcterms:modified "2026-06-07T15:30:29.591830Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8380-3
  a curric:KeyLearningPoint ;
  rdfs:label """Measuring an end-point in a reaction allows direct and simple comparison of reaction
  rates."""@en ;
  dcterms:modified "2026-06-07T15:30:29.591834Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8380-4
  a curric:KeyLearningPoint ;
  rdfs:label """Errors in measuring end-points include subjectivity of observations, measuring times
  and volumes, and contamination."""@en ;
  dcterms:modified "2026-06-07T15:30:29.591838Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8316-1
  a curric:KeyLearningPoint ;
  rdfs:label "Dalton (1803) arranged known elements in order of atomic weights."@en ;
  dcterms:modified "2026-06-07T15:30:29.591842Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8316-2
  a curric:KeyLearningPoint ;
  rdfs:label """Newlands (1865) noticed that every eighth element, in order of atomic mass, repeated
  similar properties."""@en ;
  dcterms:modified "2026-06-07T15:30:29.591846Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8316-3
  a curric:KeyLearningPoint ;
  rdfs:label """Mendeleev swapped the order of atomic weights in order to fit elements better into
  groups of similar properties."""@en ;
  dcterms:modified "2026-06-07T15:30:29.591851Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8316-4
  a curric:KeyLearningPoint ;
  rdfs:label """Mendeleev’s periodic table had gaps and he predicted missing elements that were
  later found."""@en ;
  dcterms:modified "2026-06-07T15:30:29.591855Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8316-5
  a curric:KeyLearningPoint ;
  rdfs:label """Mendeleev was not aware of isotopes, so was unable to explain why the ordering by
  atomic weight was not always correct."""@en ;
  dcterms:modified "2026-06-07T15:30:29.591859Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9686-1
  a curric:KeyLearningPoint ;
  rdfs:label """The prefixes milli-, micro-, nano-, and pico-, in this order, subdivide a metre into
  smaller and smaller divisions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.591886Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9686-2
  a curric:KeyLearningPoint ;
  rdfs:label "Nanoparticles are 1-100 nm in size, and are larger than atoms and molecules."@en ;
  dcterms:modified "2026-06-07T15:30:29.591891Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9686-3
  a curric:KeyLearningPoint ;
  rdfs:label "The smaller a particle, the bigger its surface area to volume ratio."@en ;
  dcterms:modified "2026-06-07T15:30:29.591895Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9686-4
  a curric:KeyLearningPoint ;
  rdfs:label """Nanotubes are very small and extremely strong fibres that are thermal and electrical
  conductors."""@en ;
  dcterms:modified "2026-06-07T15:30:29.591899Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9686-5
  a curric:KeyLearningPoint ;
  rdfs:label """Nanoparticles have many applications; new applications for nanoparticulate materials
  are an important area of research."""@en ;
  dcterms:modified "2026-06-07T15:30:29.591905Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9681-1
  a curric:KeyLearningPoint ;
  rdfs:label """In diamond each carbon atom is bonded to four others with strong covalent bonds to
  form a giant covalent structure."""@en ;
  dcterms:modified "2026-06-07T15:30:29.591910Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9681-2
  a curric:KeyLearningPoint ;
  rdfs:label """Diamond is very hard, has a very high melting point and does not conduct electricity
  (makes it good for cutting tools)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.591914Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9681-3
  a curric:KeyLearningPoint ;
  rdfs:label """In graphite, each carbon atom is covalently bonded to three others to form layers of
  hexagonal rings."""@en ;
  dcterms:modified "2026-06-07T15:30:29.591927Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9681-4
  a curric:KeyLearningPoint ;
  rdfs:label """There are only weak forces between the layers in graphite which can easily be rubbed
  apart (makes it a good lubricant)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.591931Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9681-5
  a curric:KeyLearningPoint ;
  rdfs:label """Graphite conducts electricity because it has delocalised electrons which can move
  and carry charge/current."""@en ;
  dcterms:modified "2026-06-07T15:30:29.591936Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5579-1
  a curric:KeyLearningPoint ;
  rdfs:label """Models are used in science to explain things that can be difficult to see or
  understand."""@en ;
  dcterms:modified "2026-06-07T15:30:29.591940Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5579-2
  a curric:KeyLearningPoint ;
  rdfs:label """The word summary and symbol equation for photosynthesis are simple models of the
  process."""@en ;
  dcterms:modified "2026-06-07T15:30:29.591944Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5579-3
  a curric:KeyLearningPoint ;
  rdfs:label "Photosynthesis can also be summarised using a model of the two main stages."@en ;
  dcterms:modified "2026-06-07T15:30:29.591951Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5579-4
  a curric:KeyLearningPoint ;
  rdfs:label """In the first stage, energy from light is required to split water molecules into
  hydrogen and waste oxygen."""@en ;
  dcterms:modified "2026-06-07T15:30:29.591955Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5579-5
  a curric:KeyLearningPoint ;
  rdfs:label """In the second stage, the hydrogen is combined with carbon dioxide to make
  glucose."""@en ;
  dcterms:modified "2026-06-07T15:30:29.591959Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6394-1
  a curric:KeyLearningPoint ;
  rdfs:label """Some plants and animals have features that are useful to us (e.g. they can provide
  food and materials, or do work)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.591963Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6394-2
  a curric:KeyLearningPoint ;
  rdfs:label """Selective breeding by humans causes particular features to become more (or less)
  common in the species."""@en ;
  dcterms:modified "2026-06-07T15:30:29.591967Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6394-3
  a curric:KeyLearningPoint ;
  rdfs:label """After many generations, the resulting domesticated species can be quite different to
  their wild ancestors."""@en ;
  dcterms:modified "2026-06-07T15:30:29.591971Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6394-4
  a curric:KeyLearningPoint ;
  rdfs:label """Examples of the selective breeding of a farm animal and a crop from their wild
  ancestors."""@en ;
  dcterms:modified "2026-06-07T15:30:29.591975Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6394-5
  a curric:KeyLearningPoint ;
  rdfs:label "The dependence of humans on domesticated animals and crops for food security."@en ;
  dcterms:modified "2026-06-07T15:30:29.591979Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8100-1
  a curric:KeyLearningPoint ;
  rdfs:label """During sexual reproduction, an individual’s biological sex is determined by the
  chromosomes they inherit."""@en ;
  dcterms:modified "2026-06-07T15:30:29.591984Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8100-2
  a curric:KeyLearningPoint ;
  rdfs:label """In humans, the 23rd pair of chromosomes are sex chromosomes; XX in females and XY in
  males."""@en ;
  dcterms:modified "2026-06-07T15:30:29.591988Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8100-3
  a curric:KeyLearningPoint ;
  rdfs:label """A gene on the Y chromosome triggers the development of testes, which make male sex
  hormones (androgens)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.591994Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8100-4
  a curric:KeyLearningPoint ;
  rdfs:label """Interpreting, completing and constructing Punnett squares showing the inheritance of
  human sex chromosomes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.591999Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5545-1
  a curric:KeyLearningPoint ;
  rdfs:label """Reflex responses are fast and involuntary, and are essential to the survival of many
  organisms."""@en ;
  dcterms:modified "2026-06-07T15:30:29.592003Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5545-2
  a curric:KeyLearningPoint ;
  rdfs:label "Reflex responses do not involve a processing centre (e.g. the brain) in the CNS."@en ;
  dcterms:modified "2026-06-07T15:30:29.592008Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5545-3
  a curric:KeyLearningPoint ;
  rdfs:label """In a reflex arc, the nerve impulse travels across a synapse from the sensory neurone
  to a relay neurone in the CNS."""@en ;
  dcterms:modified "2026-06-07T15:30:29.592012Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5545-4
  a curric:KeyLearningPoint ;
  rdfs:label """The nerve impulse travels across a synapse from the relay neurone to a motor neurone
  in the PNS."""@en ;
  dcterms:modified "2026-06-07T15:30:29.592016Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5545-5
  a curric:KeyLearningPoint ;
  rdfs:label """Sometimes the brain can modify (e.g. stop) a reflex response via a neurone to the
  motor neurone of the reflex arc."""@en ;
  dcterms:modified "2026-06-07T15:30:29.592020Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8101-1
  a curric:KeyLearningPoint ;
  rdfs:label """Cancer is caused by uncontrolled cell growth and division which can lead to the
  formation of tumours."""@en ;
  dcterms:modified "2026-06-07T15:30:29.592045Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8101-2
  a curric:KeyLearningPoint ;
  rdfs:label "Not all tumours are cancerous; they can be benign or malignant."@en ;
  dcterms:modified "2026-06-07T15:30:29.592049Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8101-3
  a curric:KeyLearningPoint ;
  rdfs:label """Benign tumours are usually contained within one area and do not invade surrounding
  tissues."""@en ;
  dcterms:modified "2026-06-07T15:30:29.592053Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8101-4
  a curric:KeyLearningPoint ;
  rdfs:label """Malignant tumours are cancerous, they invade surrounding tissues and can cause
  secondary tumours."""@en ;
  dcterms:modified "2026-06-07T15:30:29.592057Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8101-5
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists have identified lifestyle and genetic factors that can increase the risk
  of developing cancer."""@en ;
  dcterms:modified "2026-06-07T15:30:29.592062Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9191-1
  a curric:KeyLearningPoint ;
  rdfs:label """Use a light microscope to observe effects of osmosis in plant cells (including:
  shrinking/crenation, swelling/bursting)"""@en ;
  dcterms:modified "2026-06-07T15:30:29.592613Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9191-2
  a curric:KeyLearningPoint ;
  rdfs:label "The parts of a light microscope and their functions."@en ;
  dcterms:modified "2026-06-07T15:30:29.592620Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9191-3
  a curric:KeyLearningPoint ;
  rdfs:label """The sequence of steps for setting up a light microscope to observe cells, including
  changing magnification and focus."""@en ;
  dcterms:modified "2026-06-07T15:30:29.592624Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9191-4
  a curric:KeyLearningPoint ;
  rdfs:label """Explaining observations from microscopy using ideas about osmosis and net movement
  of water into/out of cells."""@en ;
  dcterms:modified "2026-06-07T15:30:29.592628Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5555-1
  a curric:KeyLearningPoint ;
  rdfs:label """Planning an investigation into the effect of pH on the rate at which amylase enzyme
  breaks down starch into maltose"""@en ;
  dcterms:modified "2026-06-07T15:30:29.592633Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5555-2
  a curric:KeyLearningPoint ;
  rdfs:label "Writing an aim for the investigation, and a testable prediction"@en ;
  dcterms:modified "2026-06-07T15:30:29.592637Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5555-3
  a curric:KeyLearningPoint ;
  rdfs:label "Identifying independent and dependent variables, and which factors to control"@en ;
  dcterms:modified "2026-06-07T15:30:29.592641Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5555-4
  a curric:KeyLearningPoint ;
  rdfs:label """Planning a method, to include use of iodine in continuous sampling to indicate when
  all starch has been broken down"""@en ;
  dcterms:modified "2026-06-07T15:30:29.592645Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5555-5
  a curric:KeyLearningPoint ;
  rdfs:label "Identifying hazards and risks, and how to limit them"@en ;
  dcterms:modified "2026-06-07T15:30:29.592649Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8189-1
  a curric:KeyLearningPoint ;
  rdfs:label "If conditions in the body change too much this can be dangerous to our health."@en ;
  dcterms:modified "2026-06-07T15:30:29.592674Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8189-2
  a curric:KeyLearningPoint ;
  rdfs:label """Changes in body temperature affect the rate of chemical reactions and can impact
  enzyme activity."""@en ;
  dcterms:modified "2026-06-07T15:30:29.592678Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8189-3
  a curric:KeyLearningPoint ;
  rdfs:label "Changes in body temperature can lead to hypo- or hyperthermia and death."@en ;
  dcterms:modified "2026-06-07T15:30:29.592682Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8189-4
  a curric:KeyLearningPoint ;
  rdfs:label "Changes in water balance in the body can lead to dehydration and death."@en ;
  dcterms:modified "2026-06-07T15:30:29.592686Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8189-5
  a curric:KeyLearningPoint ;
  rdfs:label "Use of antagonistic effects to maintain a constant environment."@en ;
  dcterms:modified "2026-06-07T15:30:29.592690Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6393-1
  a curric:KeyLearningPoint ;
  rdfs:label """The fossil record includes species that appear to be the common ancestor of numerous
  later species."""@en ;
  dcterms:modified "2026-06-07T15:30:29.592695Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6393-2
  a curric:KeyLearningPoint ;
  rdfs:label """Evolutionary trees can be used to help visualise the relationships between groups of
  organisms."""@en ;
  dcterms:modified "2026-06-07T15:30:29.592699Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6393-3
  a curric:KeyLearningPoint ;
  rdfs:label """The fossil record includes transitional species with features of both evolutionary
  ancestors and modern species."""@en ;
  dcterms:modified "2026-06-07T15:30:29.592703Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6393-4
  a curric:KeyLearningPoint ;
  rdfs:label """A case study of an example of a transitional species (e.g. Archaeopteryx, which
  links dinosaurs and modern birds)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.592741Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6393-5
  a curric:KeyLearningPoint ;
  rdfs:label """There are gaps in the fossil record, e.g. ‘missing links’ between evolutionary
  ancestors and modern species."""@en ;
  dcterms:modified "2026-06-07T15:30:29.592746Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6292-1
  a curric:KeyLearningPoint ;
  rdfs:label "Ecosystems contain biotic and abiotic components."@en ;
  dcterms:modified "2026-06-07T15:30:29.592751Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6292-2
  a curric:KeyLearningPoint ;
  rdfs:label """Changes in biotic and abiotic factors will affect communities within an
  ecosystem."""@en ;
  dcterms:modified "2026-06-07T15:30:29.592755Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6292-3
  a curric:KeyLearningPoint ;
  rdfs:label "Predators are consumers that eat prey."@en ;
  dcterms:modified "2026-06-07T15:30:29.592759Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6292-4
  a curric:KeyLearningPoint ;
  rdfs:label """The population sizes of predators and prey increase and decrease in predator-prey
  cycles."""@en ;
  dcterms:modified "2026-06-07T15:30:29.592763Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6299-1
  a curric:KeyLearningPoint ;
  rdfs:label "The water cycle shows how water is recycled on planet Earth."@en ;
  dcterms:modified "2026-06-07T15:30:29.592767Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6299-2
  a curric:KeyLearningPoint ;
  rdfs:label "Water is continuously being evaporated and precipitated."@en ;
  dcterms:modified "2026-06-07T15:30:29.592774Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6299-3
  a curric:KeyLearningPoint ;
  rdfs:label "Plants lose water through transpiration."@en ;
  dcterms:modified "2026-06-07T15:30:29.592781Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6299-4
  a curric:KeyLearningPoint ;
  rdfs:label "Water availability impacts upon a species' ability to survive in a habitat."@en ;
  dcterms:modified "2026-06-07T15:30:29.592785Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5616-1
  a curric:KeyLearningPoint ;
  rdfs:label """The rate of photosynthesis depends on factors including light, chlorophyll, water,
  temperature and carbon dioxide."""@en ;
  dcterms:modified "2026-06-07T15:30:29.592810Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5616-2
  a curric:KeyLearningPoint ;
  rdfs:label """A factor that when in short supply slows down or limits the rate of photosynthesis
  is called a limiting factor."""@en ;
  dcterms:modified "2026-06-07T15:30:29.592814Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5616-3
  a curric:KeyLearningPoint ;
  rdfs:label """Increased temperature increases photosynthesis rate up to the optimum (due to
  increased enzyme-substrate collisions)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.592819Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5616-4
  a curric:KeyLearningPoint ;
  rdfs:label """Above the optimum temperature, enzymes are denatured and rate of photosynthesis
  decreases."""@en ;
  dcterms:modified "2026-06-07T15:30:29.592823Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5616-5
  a curric:KeyLearningPoint ;
  rdfs:label """Increased CO2 concentration increases rate of photosynthesis up to the optimum, when
  all enzyme active sites are full."""@en ;
  dcterms:modified "2026-06-07T15:30:29.592827Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9644-1
  a curric:KeyLearningPoint ;
  rdfs:label """Paper, thin layer (TLC), and gas chromatography (GC) can all distinguish between
  pure and impure substances."""@en ;
  dcterms:modified "2026-06-07T15:30:29.592831Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9644-2
  a curric:KeyLearningPoint ;
  rdfs:label """Chromatographic processes use a mobile and stationary phase. TLC and GC both use
  silica/alumina as a stationary phase."""@en ;
  dcterms:modified "2026-06-07T15:30:29.592837Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9644-3
  a curric:KeyLearningPoint ;
  rdfs:label """Thin layer chromatography (TLC) uses locating agents to develop chromatograms and
  aid analysis of them."""@en ;
  dcterms:modified "2026-06-07T15:30:29.592842Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9644-4
  a curric:KeyLearningPoint ;
  rdfs:label """Chromatograms from gas chromatography (GC) also provide details about the amount of
  each component in a sample."""@en ;
  dcterms:modified "2026-06-07T15:30:29.592846Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9644-5
  a curric:KeyLearningPoint ;
  rdfs:label """Retention factors (Rf) and retention times both provide quantitative information
  about a sample's components."""@en ;
  dcterms:modified "2026-06-07T15:30:29.592850Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20083-1
  a curric:KeyLearningPoint ;
  rdfs:label """Atoms of many elements vary in the exact number of neutrons in their nucleus, and
  each version is called an isotope."""@en ;
  dcterms:modified "2026-06-07T15:30:29.592880Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20083-2
  a curric:KeyLearningPoint ;
  rdfs:label """Existence of isotopes results in relative atomic masses of some elements not being
  whole numbers."""@en ;
  dcterms:modified "2026-06-07T15:30:29.592884Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20083-3
  a curric:KeyLearningPoint ;
  rdfs:label """Standard nuclear notation shows the chemical symbol, the mass number and the atomic
  number of the isotope."""@en ;
  dcterms:modified "2026-06-07T15:30:29.592888Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20083-4
  a curric:KeyLearningPoint ;
  rdfs:label """The relative atomic mass is an average value that takes account of the abundance of
  the isotopes of the element."""@en ;
  dcterms:modified "2026-06-07T15:30:29.592892Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9704-1
  a curric:KeyLearningPoint ;
  rdfs:label """The number of particles (atoms, ions, molecules etc.) in one mole of a substance is
  always the same."""@en ;
  dcterms:modified "2026-06-07T15:30:29.592896Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9704-2
  a curric:KeyLearningPoint ;
  rdfs:label """The mass of one mole of a substance is equal to the relative mass of the substance
  measured in grams."""@en ;
  dcterms:modified "2026-06-07T15:30:29.592900Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9704-3
  a curric:KeyLearningPoint ;
  rdfs:label """Mathematical relationships are manipulated to process practical results, calculating
  the number of moles in a substance."""@en ;
  dcterms:modified "2026-06-07T15:30:29.592905Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8374-1
  a curric:KeyLearningPoint ;
  rdfs:label "A catalyst affects the reaction rate without being used up."@en ;
  dcterms:modified "2026-06-07T15:30:29.592909Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8374-2
  a curric:KeyLearningPoint ;
  rdfs:label "A catalyst reduces the activation energy needed for a reaction."@en ;
  dcterms:modified "2026-06-07T15:30:29.592913Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8374-3
  a curric:KeyLearningPoint ;
  rdfs:label """With a catalyst present, more collisions between reactants result in the formation
  of product(s)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.592917Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8374-4
  a curric:KeyLearningPoint ;
  rdfs:label "Enzymes are biological catalysts."@en ;
  dcterms:modified "2026-06-07T15:30:29.592921Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8374-5
  a curric:KeyLearningPoint ;
  rdfs:label "Catalysts vary in efficiency; qualitative data helps evaluate effectiveness."@en ;
  dcterms:modified "2026-06-07T15:30:29.592925Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9702-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Potable' and 'pure' water are not the same material."@en ;
  dcterms:modified "2026-06-07T15:30:29.592930Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9702-2
  a curric:KeyLearningPoint ;
  rdfs:label "Water used in analysis must not contain any dissolved ions."@en ;
  dcterms:modified "2026-06-07T15:30:29.592934Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9702-3
  a curric:KeyLearningPoint ;
  rdfs:label "The method used to obtain potable water depends on the water source."@en ;
  dcterms:modified "2026-06-07T15:30:29.592941Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9702-4
  a curric:KeyLearningPoint ;
  rdfs:label """Filtration and sterilisation are used to obtain potable water from groundwater and
  fresh water sources."""@en ;
  dcterms:modified "2026-06-07T15:30:29.592946Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9702-5
  a curric:KeyLearningPoint ;
  rdfs:label """Desalination of sea water creates potable water by distillation or reverse
  osmosis."""@en ;
  dcterms:modified "2026-06-07T15:30:29.592950Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9683-1
  a curric:KeyLearningPoint ;
  rdfs:label "Graphene is a single layer of graphite, is very strong and conducts electricity."@en ;
  dcterms:modified "2026-06-07T15:30:29.593007Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9683-2
  a curric:KeyLearningPoint ;
  rdfs:label "Fullerenes are molecules of carbon with hollow shapes."@en ;
  dcterms:modified "2026-06-07T15:30:29.593011Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9683-3
  a curric:KeyLearningPoint ;
  rdfs:label """The structure of fullerenes is based on hexagonal rings of carbon atoms, or on
  carbon rings of five or seven atoms."""@en ;
  dcterms:modified "2026-06-07T15:30:29.593016Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9683-4
  a curric:KeyLearningPoint ;
  rdfs:label "A Buckminsterfullerene is a spherical fullerene of sixty carbon atoms (C₆₀)."@en ;
  dcterms:modified "2026-06-07T15:30:29.593022Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9683-5
  a curric:KeyLearningPoint ;
  rdfs:label """A carbon nanotube is a tube of graphene that is very long compared to its diameter
  and has a high tensile strength."""@en ;
  dcterms:modified "2026-06-07T15:30:29.593027Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8440-1
  a curric:KeyLearningPoint ;
  rdfs:label """Aluminium is above carbon in the reactivity series and can therefore not be
  extracted with carbon."""@en ;
  dcterms:modified "2026-06-07T15:30:29.593031Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8440-2
  a curric:KeyLearningPoint ;
  rdfs:label "Impurities are removed from the bauxite ore at the start."@en ;
  dcterms:modified "2026-06-07T15:30:29.593036Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8440-3
  a curric:KeyLearningPoint ;
  rdfs:label """Cryolite acts as a solvent and allows the electrolysis to take place at a lower
  temperature."""@en ;
  dcterms:modified "2026-06-07T15:30:29.593040Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8440-4
  a curric:KeyLearningPoint ;
  rdfs:label """Carbon electrodes need to be continuously replaced as they react with oxygen as it
  is produced, forming carbon dioxide."""@en ;
  dcterms:modified "2026-06-07T15:30:29.593044Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8440-5
  a curric:KeyLearningPoint ;
  rdfs:label "Electrolysis is an expensive process as it requires large amounts of energy."@en ;
  dcterms:modified "2026-06-07T15:30:29.593048Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9655-1
  a curric:KeyLearningPoint ;
  rdfs:label """There are changes in arrangement, movement and energy of particles during state
  changes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.593052Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9655-2
  a curric:KeyLearningPoint ;
  rdfs:label """There are two types of change; physical and chemical, and the physical state of a
  substance can be predicted."""@en ;
  dcterms:modified "2026-06-07T15:30:29.593057Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9655-3
  a curric:KeyLearningPoint ;
  rdfs:label """The attraction between particles has a role in determining the amount of energy
  needed for state changes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.593061Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9655-4
  a curric:KeyLearningPoint ;
  rdfs:label """The particle model has limitations, for example by showing particles as same sized,
  inelastic spheres."""@en ;
  dcterms:modified "2026-06-07T15:30:29.593065Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9655-5
  a curric:KeyLearningPoint ;
  rdfs:label """The model does not show the attraction between the particles which affects the
  amount of energy needed to change state."""@en ;
  dcterms:modified "2026-06-07T15:30:29.593069Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5570-1
  a curric:KeyLearningPoint ;
  rdfs:label """The human body has an endocrine system that uses hormones to control changes in the
  body."""@en ;
  dcterms:modified "2026-06-07T15:30:29.593073Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5570-2
  a curric:KeyLearningPoint ;
  rdfs:label """Hormones are chemicals secreted by glands, transported in blood plasma and detected
  by receptors on cells and tissues."""@en ;
  dcterms:modified "2026-06-07T15:30:29.593077Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5570-3
  a curric:KeyLearningPoint ;
  rdfs:label """Changes in the body can be triggered by an increase in hormones (e.g. puberty) and a
  decrease in them (e.g. menopause)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.593084Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5570-4
  a curric:KeyLearningPoint ;
  rdfs:label """Changes in the body are detected by receptors; the nervous system sends nerve
  impulses to glands to secrete hormones."""@en ;
  dcterms:modified "2026-06-07T15:30:29.593088Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9186-1
  a curric:KeyLearningPoint ;
  rdfs:label """Some pathogens are spread by direct contact, or transfer of body fluids, during
  sexual activity."""@en ;
  dcterms:modified "2026-06-07T15:30:29.593093Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9186-2
  a curric:KeyLearningPoint ;
  rdfs:label """Gonorrhoea and chlamydia as examples of common sexually transmitted infections
  caused by bacteria."""@en ;
  dcterms:modified "2026-06-07T15:30:29.593097Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9186-3
  a curric:KeyLearningPoint ;
  rdfs:label """Ways to prevent the spread of gonorrhoea and chlamydia, and issues in treating them
  (including resistance)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.593103Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9186-4
  a curric:KeyLearningPoint ;
  rdfs:label """HIV as an example of a common sexually transmitted infection caused by a virus, and
  ways to prevent the spread."""@en ;
  dcterms:modified "2026-06-07T15:30:29.593108Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9186-5
  a curric:KeyLearningPoint ;
  rdfs:label """Effects of AIDS on the body, increased risk of other diseases (inc. TB), and
  management of progression in HIV+ people ."""@en ;
  dcterms:modified "2026-06-07T15:30:29.593112Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7936-1
  a curric:KeyLearningPoint ;
  rdfs:label """Rate of photosynthesis increases as CO₂ concentration, temperature and light
  intensity increase from low levels."""@en ;
  dcterms:modified "2026-06-07T15:30:29.593116Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7936-2
  a curric:KeyLearningPoint ;
  rdfs:label """The rate of photosynthesis can be limited by one of these factors even if the others
  continue to increase."""@en ;
  dcterms:modified "2026-06-07T15:30:29.593120Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7936-3
  a curric:KeyLearningPoint ;
  rdfs:label """The rate of photosynthesis increases until one of more factors becomes limiting,
  then does not increase further."""@en ;
  dcterms:modified "2026-06-07T15:30:29.593126Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7936-4
  a curric:KeyLearningPoint ;
  rdfs:label """Interpretation and explanation of graphs depicting effect of interacting limiting
  factors on the rate of photosynthesis."""@en ;
  dcterms:modified "2026-06-07T15:30:29.593131Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7994-1
  a curric:KeyLearningPoint ;
  rdfs:label """Genetic engineering involves modifying the genome of an organism by adding DNA from
  another organism."""@en ;
  dcterms:modified "2026-06-07T15:30:29.593154Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7994-2
  a curric:KeyLearningPoint ;
  rdfs:label "The aim of genetic engineering is to introduce a desirable characteristic."@en ;
  dcterms:modified "2026-06-07T15:30:29.593158Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7994-3
  a curric:KeyLearningPoint ;
  rdfs:label "Examples of genetically engineering crop plants and bacteria to benefit humans."@en ;
  dcterms:modified "2026-06-07T15:30:29.593162Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7994-4
  a curric:KeyLearningPoint ;
  rdfs:label "Benefits must be weighed against risks and ethical issues."@en ;
  dcterms:modified "2026-06-07T15:30:29.593166Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7994-5
  a curric:KeyLearningPoint ;
  rdfs:label "The main steps in the process of genetic engineering."@en ;
  dcterms:modified "2026-06-07T15:30:29.593171Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9909-1
  a curric:KeyLearningPoint ;
  rdfs:label "Average velocity = distance travelled ÷ time"@en ;
  dcterms:modified "2026-06-07T15:30:29.593382Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9909-2
  a curric:KeyLearningPoint ;
  rdfs:label "Average acceleration = change in velocity ÷ time"@en ;
  dcterms:modified "2026-06-07T15:30:29.593386Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9909-3
  a curric:KeyLearningPoint ;
  rdfs:label "Average velocity = (initial velocity + final velocity) ÷ 2"@en ;
  dcterms:modified "2026-06-07T15:30:29.593390Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9909-4
  a curric:KeyLearningPoint ;
  rdfs:label """Combining equations for average acceleration and average velocity leads to the
  equation v² – u² = 2ax"""@en ;
  dcterms:modified "2026-06-07T15:30:29.593395Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9909-5
  a curric:KeyLearningPoint ;
  rdfs:label """Different motion equations can be used to analyse motion based on information
  provided."""@en ;
  dcterms:modified "2026-06-07T15:30:29.593399Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4915-1
  a curric:KeyLearningPoint ;
  rdfs:label "Resultant force = mass × acceleration, F = m × a"@en ;
  dcterms:modified "2026-06-07T15:30:29.593500Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4915-2
  a curric:KeyLearningPoint ;
  rdfs:label """An object that is thrown in the air experiences a constant gravitational force
  towards the centre of Earth."""@en ;
  dcterms:modified "2026-06-07T15:30:29.593506Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4915-3
  a curric:KeyLearningPoint ;
  rdfs:label """An object that is thrown in the air is constantly accelerating towards the centre of
  Earth."""@en ;
  dcterms:modified "2026-06-07T15:30:29.593511Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5049-1
  a curric:KeyLearningPoint ;
  rdfs:label "The speed of a wave depends on the medium it is travelling through"@en ;
  dcterms:modified "2026-06-07T15:30:29.593541Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5049-2
  a curric:KeyLearningPoint ;
  rdfs:label "The speed of a wave does not depend on its frequency"@en ;
  dcterms:modified "2026-06-07T15:30:29.593545Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5049-3
  a curric:KeyLearningPoint ;
  rdfs:label "For a given wave speed, the higher the frequency, the shorter the wavelength"@en ;
  dcterms:modified "2026-06-07T15:30:29.593551Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5049-4
  a curric:KeyLearningPoint ;
  rdfs:label "For a given wave speed, the longer the wavelength, the lower the frequency"@en ;
  dcterms:modified "2026-06-07T15:30:29.593558Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5049-5
  a curric:KeyLearningPoint ;
  rdfs:label "Wave speed = frequency x wavelength"@en ;
  dcterms:modified "2026-06-07T15:30:29.593562Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8323-1
  a curric:KeyLearningPoint ;
  rdfs:label """Chromatography has two phases, stationary and mobile, and separation depends on the
  distribution between these phases."""@en ;
  dcterms:modified "2026-06-07T15:30:29.593684Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8323-2
  a curric:KeyLearningPoint ;
  rdfs:label "Both aqueous and non-aqueous solvents can be used in chromatography."@en ;
  dcterms:modified "2026-06-07T15:30:29.593688Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8323-3
  a curric:KeyLearningPoint ;
  rdfs:label "Chromatograms can be used to identify pure and impure substances."@en ;
  dcterms:modified "2026-06-07T15:30:29.593692Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8003-1
  a curric:KeyLearningPoint ;
  rdfs:label """Hormones are chemicals that are made and secreted by groups of specialised cells
  called glands."""@en ;
  dcterms:modified "2026-06-07T15:30:29.593698Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8003-2
  a curric:KeyLearningPoint ;
  rdfs:label """Hormones are transported around the body in the blood plasma, and detected by
  receptors on cells and tissues."""@en ;
  dcterms:modified "2026-06-07T15:30:29.593703Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8003-3
  a curric:KeyLearningPoint ;
  rdfs:label """During puberty, hormones cause maturation of the sex organs and development of
  secondary sexual characteristics."""@en ;
  dcterms:modified "2026-06-07T15:30:29.593707Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8003-4
  a curric:KeyLearningPoint ;
  rdfs:label """Hormones control the menstrual cycle in adult human females, by causing ovulation
  and menstruation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.593711Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8003-5
  a curric:KeyLearningPoint ;
  rdfs:label """Decreases in hormone levels in older human females cause the menopause, after which
  the menstrual cycle stops."""@en ;
  dcterms:modified "2026-06-07T15:30:29.593715Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8352-1
  a curric:KeyLearningPoint ;
  rdfs:label """metal + acid ⭢ salt + hydrogen; metal carbonate + acid → salt + water + carbon
  dioxide"""@en ;
  dcterms:modified "2026-06-07T15:30:29.593740Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8352-2
  a curric:KeyLearningPoint ;
  rdfs:label """The test for hydrogen gas is to introduce a lighted splint, which will make a
  squeaky pop in hydrogen."""@en ;
  dcterms:modified "2026-06-07T15:30:29.593745Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8352-3
  a curric:KeyLearningPoint ;
  rdfs:label "The name of a salt formed is dependent on the acid used."@en ;
  dcterms:modified "2026-06-07T15:30:29.593751Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8352-4
  a curric:KeyLearningPoint ;
  rdfs:label """(s), (l), (g), (aq) in chemical equations identify the state of substances as solid,
  liquid, gas or in aqueous solution."""@en ;
  dcterms:modified "2026-06-07T15:30:29.593756Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8352-5
  a curric:KeyLearningPoint ;
  rdfs:label """Carbon dioxide can be bubbled through limewater, which turns cloudy (test
  for CO₂)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.593760Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7990-1
  a curric:KeyLearningPoint ;
  rdfs:label """Plants have unspecialised cells called meristem cells, which are located in the stem
  and the tips of roots and shoots."""@en ;
  dcterms:modified "2026-06-07T15:30:29.593765Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7990-2
  a curric:KeyLearningPoint ;
  rdfs:label """Meristem cells in roots and shoots divide and differentiate to enable roots and
  shoots to grow longer and wider."""@en ;
  dcterms:modified "2026-06-07T15:30:29.593769Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7990-3
  a curric:KeyLearningPoint ;
  rdfs:label """Meristem cells in the shoots also divide and differentiate to make leaves and
  flowers."""@en ;
  dcterms:modified "2026-06-07T15:30:29.593775Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7990-4
  a curric:KeyLearningPoint ;
  rdfs:label """Meristem cells in the stem and roots also divide and differentiate to make tissues
  such as xylem and phloem."""@en ;
  dcterms:modified "2026-06-07T15:30:29.593780Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7990-5
  a curric:KeyLearningPoint ;
  rdfs:label """Meristem tissue can be used to produce clones for crops or to protect endangered
  species."""@en ;
  dcterms:modified "2026-06-07T15:30:29.593784Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7157-1
  a curric:KeyLearningPoint ;
  rdfs:label """The good health of humans, other animals and plants can be compromised by
  diseases."""@en ;
  dcterms:modified "2026-06-07T15:30:29.593926Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7157-2
  a curric:KeyLearningPoint ;
  rdfs:label """Communicable diseases are spread by pathogens, including some bacteria, viruses,
  fungi and protists."""@en ;
  dcterms:modified "2026-06-07T15:30:29.593930Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7157-3
  a curric:KeyLearningPoint ;
  rdfs:label """Non-communicable diseases cannot be spread between organisms; they are caused by
  lifestyle and environmental factors."""@en ;
  dcterms:modified "2026-06-07T15:30:29.593934Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7157-4
  a curric:KeyLearningPoint ;
  rdfs:label """Lifestyle factors (e.g. hygiene, diet) affect the chances of developing communicable
  and non-communicable diseases."""@en ;
  dcterms:modified "2026-06-07T15:30:29.593938Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9184-1
  a curric:KeyLearningPoint ;
  rdfs:label """Some, but not all, bacteria are pathogens that can cause communicable diseases in
  humans."""@en ;
  dcterms:modified "2026-06-07T15:30:29.593943Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9184-2
  a curric:KeyLearningPoint ;
  rdfs:label "Pathogenic bacteria produce toxins that damage living tissue and cause disease."@en ;
  dcterms:modified "2026-06-07T15:30:29.593949Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9184-3
  a curric:KeyLearningPoint ;
  rdfs:label """Salmonella food poisoning as an example of a bacterial disease, how it is spread,
  and how the spread can be reduced."""@en ;
  dcterms:modified "2026-06-07T15:30:29.593955Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9184-4
  a curric:KeyLearningPoint ;
  rdfs:label "Viruses invade cells to reproduce where they cause damage to cells."@en ;
  dcterms:modified "2026-06-07T15:30:29.593959Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9184-5
  a curric:KeyLearningPoint ;
  rdfs:label """Influenza as an example of a viral disease, how it is spread, and how the spread can
  be reduced."""@en ;
  dcterms:modified "2026-06-07T15:30:29.593963Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7167-1
  a curric:KeyLearningPoint ;
  rdfs:label """Vaccines have had a positive effect on public health (e.g. the eradication of
  smallpox)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.593975Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7167-2
  a curric:KeyLearningPoint ;
  rdfs:label """Vaccination is not risk free as it can have side effects, but the benefits outweigh
  the risks."""@en ;
  dcterms:modified "2026-06-07T15:30:29.593979Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7167-3
  a curric:KeyLearningPoint ;
  rdfs:label """New vaccines are trialled, and are only approved for use when the benefits of the
  vaccination outweigh the risks."""@en ;
  dcterms:modified "2026-06-07T15:30:29.593984Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7167-4
  a curric:KeyLearningPoint ;
  rdfs:label """It is necessary to vaccinate a high proportion of a population against a pathogen to
  provide herd immunity."""@en ;
  dcterms:modified "2026-06-07T15:30:29.593988Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7167-5
  a curric:KeyLearningPoint ;
  rdfs:label "Herd immunity helps protect those who can’t or won’t have the vaccination."@en ;
  dcterms:modified "2026-06-07T15:30:29.593992Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7158-1
  a curric:KeyLearningPoint ;
  rdfs:label """Cardiovascular disease (including coronary heart disease) is a common
  non-communicable disease."""@en ;
  dcterms:modified "2026-06-07T15:30:29.593996Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7158-2
  a curric:KeyLearningPoint ;
  rdfs:label """The coronary arteries supply blood to the heart muscle, and can become blocked by
  fatty deposits."""@en ;
  dcterms:modified "2026-06-07T15:30:29.594000Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7158-3
  a curric:KeyLearningPoint ;
  rdfs:label """This restricts blood flow and causes a lack of oxygen to the heart muscle, which can
  cause a heart attack."""@en ;
  dcterms:modified "2026-06-07T15:30:29.594004Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7158-4
  a curric:KeyLearningPoint ;
  rdfs:label """Heart valves stop the backflow of blood in the heart and they can become
  damaged."""@en ;
  dcterms:modified "2026-06-07T15:30:29.594008Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7158-5
  a curric:KeyLearningPoint ;
  rdfs:label """Heart disease can be prevented with lifestyle changes, or treated with stents,
  medicines, transplants and surgery."""@en ;
  dcterms:modified "2026-06-07T15:30:29.594015Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28971-1
  a curric:KeyLearningPoint ;
  rdfs:label """Human health is affected by nutrition, fresh water availability, pathogens, and
  environmental conditions"""@en ;
  dcterms:modified "2026-06-07T15:30:29.594019Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28971-2
  a curric:KeyLearningPoint ;
  rdfs:label "Climate change affects fresh water availability and the growth of crops"@en ;
  dcterms:modified "2026-06-07T15:30:29.594023Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28971-3
  a curric:KeyLearningPoint ;
  rdfs:label """Heat-related ill health, malnutrition and communicable diseases are becoming more
  common as a result of climate change"""@en ;
  dcterms:modified "2026-06-07T15:30:29.594029Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28971-4
  a curric:KeyLearningPoint ;
  rdfs:label "The spread and prevalence of diseases are influenced by climate"@en ;
  dcterms:modified "2026-06-07T15:30:29.594034Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28971-5
  a curric:KeyLearningPoint ;
  rdfs:label """Communicable diseases (e.g. malaria) may spread more easily and into new
  geographical areas due to climate change"""@en ;
  dcterms:modified "2026-06-07T15:30:29.594040Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8102-1
  a curric:KeyLearningPoint ;
  rdfs:label """Cancer is caused by uncontrolled cell growth and division which can lead to the
  formation of tumours."""@en ;
  dcterms:modified "2026-06-07T15:30:29.594065Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8102-2
  a curric:KeyLearningPoint ;
  rdfs:label """Benign tumours are usually contained within one area and do not invade surrounding
  tissues."""@en ;
  dcterms:modified "2026-06-07T15:30:29.594069Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8102-3
  a curric:KeyLearningPoint ;
  rdfs:label """Malignant tumours are cancerous, they invade surrounding tissues and can cause
  secondary tumours."""@en ;
  dcterms:modified "2026-06-07T15:30:29.594073Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8102-4
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists have identified lifestyle and genetic factors that can increase the risk
  of developing cancer."""@en ;
  dcterms:modified "2026-06-07T15:30:29.594077Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8102-5
  a curric:KeyLearningPoint ;
  rdfs:label """Mutations can cause changes in DNA; this alters the nucleotide sequence and genetic
  code"""@en ;
  dcterms:modified "2026-06-07T15:30:29.594081Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7955-1
  a curric:KeyLearningPoint ;
  rdfs:label """If conditions in the body change too much this can be dangerous to our health (e.g.
  enzymes)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.594086Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7955-2
  a curric:KeyLearningPoint ;
  rdfs:label """Homeostasis is the regulation of internal conditions for optimum enzyme
  activity."""@en ;
  dcterms:modified "2026-06-07T15:30:29.594090Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7955-3
  a curric:KeyLearningPoint ;
  rdfs:label """Glucose travels in the blood plasma and is delivered to cells for aerobic
  respiration."""@en ;
  dcterms:modified "2026-06-07T15:30:29.594094Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7955-4
  a curric:KeyLearningPoint ;
  rdfs:label "The hormone insulin helps to keep human blood sugar level constant."@en ;
  dcterms:modified "2026-06-07T15:30:29.594098Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7955-5
  a curric:KeyLearningPoint ;
  rdfs:label """The pancreas secretes insulin when blood sugar level is too high; it causes liver
  cells to convert glucose to glycogen."""@en ;
  dcterms:modified "2026-06-07T15:30:29.594102Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7969-1
  a curric:KeyLearningPoint ;
  rdfs:label """Genetic material is stored in the nucleus of plant and animal cells, and in the
  cytoplasm of bacterial cells."""@en ;
  dcterms:modified "2026-06-07T15:30:29.594109Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7969-2
  a curric:KeyLearningPoint ;
  rdfs:label """Genetic material of organisms is made of a chemical substance called DNA, which is
  made up of smaller chemical units."""@en ;
  dcterms:modified "2026-06-07T15:30:29.594113Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7969-3
  a curric:KeyLearningPoint ;
  rdfs:label """The DNA in every cell is wound up into tightly-packed structures called
  chromosomes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.594117Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7969-4
  a curric:KeyLearningPoint ;
  rdfs:label """Sections of chromosomes are called genes; short sections of DNA which carry
  instructions for features and processes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.594123Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7969-5
  a curric:KeyLearningPoint ;
  rdfs:label """All the DNA in a cell is called the genome, the similarity of a genome indicates how
  similar individuals or species are."""@en ;
  dcterms:modified "2026-06-07T15:30:29.594128Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7991-1
  a curric:KeyLearningPoint ;
  rdfs:label """Some alleles affect health (e.g. increase the risk of non-communicable diseases or
  adverse reactions to treatments)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.594132Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7991-2
  a curric:KeyLearningPoint ;
  rdfs:label """Genetic testing and genome sequencing can identify the presence of these alleles in
  a person’s genome."""@en ;
  dcterms:modified "2026-06-07T15:30:29.594136Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7991-3
  a curric:KeyLearningPoint ;
  rdfs:label """Healthcare can be personalised and lifestyle changes can be implemented to decrease
  risk and improve health."""@en ;
  dcterms:modified "2026-06-07T15:30:29.594140Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7991-4
  a curric:KeyLearningPoint ;
  rdfs:label "Genetic test data could be misused, and its use must be regulated."@en ;
  dcterms:modified "2026-06-07T15:30:29.594144Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6295-1
  a curric:KeyLearningPoint ;
  rdfs:label """Organisms compete for resources such as food, water, space, shelter, light, mates,
  pollinators and seed dispersers."""@en ;
  dcterms:modified "2026-06-07T15:30:29.594149Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6295-2
  a curric:KeyLearningPoint ;
  rdfs:label """The populations of species within a community are interdependent (they rely upon and
  affect one another)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.594153Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6295-3
  a curric:KeyLearningPoint ;
  rdfs:label """Organisms have adaptations that help them survive and compete in their
  environment."""@en ;
  dcterms:modified "2026-06-07T15:30:29.594159Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6295-4
  a curric:KeyLearningPoint ;
  rdfs:label "Adaptations can be physiological, structural or behavioural."@en ;
  dcterms:modified "2026-06-07T15:30:29.594163Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6295-5
  a curric:KeyLearningPoint ;
  rdfs:label """Extremophiles are adapted to live in extreme environments, e.g. high salt
  concentration or very high or low temperature."""@en ;
  dcterms:modified "2026-06-07T15:30:29.594168Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6406-1
  a curric:KeyLearningPoint ;
  rdfs:label """Some mutations cause genetic variants that cause advantageous adaptations in
  phenotype."""@en ;
  dcterms:modified "2026-06-07T15:30:29.594172Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6406-2
  a curric:KeyLearningPoint ;
  rdfs:label """Individuals with these genetic variants are better adapted to compete, survive,
  reproduce and pass them on to offspring."""@en ;
  dcterms:modified "2026-06-07T15:30:29.594176Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6406-3
  a curric:KeyLearningPoint ;
  rdfs:label """Natural selection causes advantageous genetic variants to become more common in the
  population over generations."""@en ;
  dcterms:modified "2026-06-07T15:30:29.594180Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6406-4
  a curric:KeyLearningPoint ;
  rdfs:label """This causes advantageous adaptations in phenotype to become more common in the
  population over generations."""@en ;
  dcterms:modified "2026-06-07T15:30:29.594184Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6406-5
  a curric:KeyLearningPoint ;
  rdfs:label """Examples explained at the genetic level using ideas about mutation, genetic variants
  and natural selection."""@en ;
  dcterms:modified "2026-06-07T15:30:29.594190Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8394-1
  a curric:KeyLearningPoint ;
  rdfs:label "To make a product, raw materials need to be obtained and processed."@en ;
  dcterms:modified "2026-06-07T15:30:29.594216Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8394-2
  a curric:KeyLearningPoint ;
  rdfs:label """A life cycle assessment can reveal the people who benefit from each stage of a
  product’s life."""@en ;
  dcterms:modified "2026-06-07T15:30:29.594220Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8394-3
  a curric:KeyLearningPoint ;
  rdfs:label """A life cycle assessment can reveal the costs to individuals or the environment at
  each stage of a product’s life."""@en ;
  dcterms:modified "2026-06-07T15:30:29.594224Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8394-4
  a curric:KeyLearningPoint ;
  rdfs:label """At the end of its useful life a product can be repaired, recycled, incinerated or
  thrown away."""@en ;
  dcterms:modified "2026-06-07T15:30:29.594228Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8394-5
  a curric:KeyLearningPoint ;
  rdfs:label """LCAs are often subjective, so it is important to consider the vested interests of
  those reporting on their findings."""@en ;
  dcterms:modified "2026-06-07T15:30:29.594233Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27392-1
  a curric:KeyLearningPoint ;
  rdfs:label """Fertilisers contain nitrogen, phosphorus and potassium compounds to promote plant
  growth."""@en ;
  dcterms:modified "2026-06-07T15:30:29.594237Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27392-2
  a curric:KeyLearningPoint ;
  rdfs:label """Ammonia is a feedstock for manufacture of fertilisers, explosives, plastics, dyes
  and cleaning products."""@en ;
  dcterms:modified "2026-06-07T15:30:29.594241Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27392-3
  a curric:KeyLearningPoint ;
  rdfs:label "Ammonia can be used to manufacture ammonium salts and nitric acid."@en ;
  dcterms:modified "2026-06-07T15:30:29.594245Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27392-4
  a curric:KeyLearningPoint ;
  rdfs:label """The laboratory preparation of ammonium salts is not the same as the industrial
  preparation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.594249Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9932-1
  a curric:KeyLearningPoint ;
  rdfs:label "When an object moves upwards, work is done against the gravitational force."@en ;
  dcterms:modified "2026-06-07T15:30:29.594295Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9932-2
  a curric:KeyLearningPoint ;
  rdfs:label """The gravitational force acting on an object does work to speed it up when it is
  falling."""@en ;
  dcterms:modified "2026-06-07T15:30:29.594301Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9932-3
  a curric:KeyLearningPoint ;
  rdfs:label "Weight = mass x gravitational field strength, W = mg"@en ;
  dcterms:modified "2026-06-07T15:30:29.594305Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9932-4
  a curric:KeyLearningPoint ;
  rdfs:label """Change in gravitational potential energy of an object = mass × gravitational field
  strength × change in height"""@en ;
  dcterms:modified "2026-06-07T15:30:29.594310Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5092-1
  a curric:KeyLearningPoint ;
  rdfs:label """Electromagnetic waves/radiation are transverse oscillations (ripples) in electric
  and magnetic fields."""@en ;
  dcterms:modified "2026-06-07T15:30:29.594314Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5092-2
  a curric:KeyLearningPoint ;
  rdfs:label """The visible spectrum shows the range of different frequencies (colours) of visible
  light waves (visible EM radiation)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.594318Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5092-3
  a curric:KeyLearningPoint ;
  rdfs:label """In the visible spectrum, violet light has the highest frequency and refracts more
  than red as it slows more in glass."""@en ;
  dcterms:modified "2026-06-07T15:30:29.594322Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5092-4
  a curric:KeyLearningPoint ;
  rdfs:label """The EM spectrum shows the range of frequencies that EM waves can have (radio,
  microwave, IR, visible, UV, X-ray, gamma)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.594326Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5092-5
  a curric:KeyLearningPoint ;
  rdfs:label """EM waves in different frequency ranges have the same speed in air, but interact
  differently with different materials."""@en ;
  dcterms:modified "2026-06-07T15:30:29.594330Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20360-1
  a curric:KeyLearningPoint ;
  rdfs:label "Heating sodium hydrogencarbonate in a crucible leads to its decomposition."@en ;
  dcterms:modified "2026-06-07T15:30:29.594337Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20360-2
  a curric:KeyLearningPoint ;
  rdfs:label "The risk involved with heating sodium hydrogencarbonate is low."@en ;
  dcterms:modified "2026-06-07T15:30:29.594341Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20360-3
  a curric:KeyLearningPoint ;
  rdfs:label "The stoichiometry for a reaction can be calculated given experimental data."@en ;
  dcterms:modified "2026-06-07T15:30:29.594345Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20360-4
  a curric:KeyLearningPoint ;
  rdfs:label """Because a gas is not a reactant in this reaction, the crucible lid remains closed
  throughout the heating process."""@en ;
  dcterms:modified "2026-06-07T15:30:29.594351Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5122-1
  a curric:KeyLearningPoint ;
  rdfs:label """Radioactive particles can emit radiation in the form of particles or gamma
  radiation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.594523Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5122-2
  a curric:KeyLearningPoint ;
  rdfs:label """Ionising radiation forces electrons from atoms, leaving an atom with a positive
  charge called an ion."""@en ;
  dcterms:modified "2026-06-07T15:30:29.594527Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5122-3
  a curric:KeyLearningPoint ;
  rdfs:label """Alpha particles are more ionising than beta or gamma because they have a bigger
  charge and stronger electric field."""@en ;
  dcterms:modified "2026-06-07T15:30:29.594531Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20348-1
  a curric:KeyLearningPoint ;
  rdfs:label """Radio waves, microwaves, IR and visible light are non–ionising EM radiation. They
  can harm cells by heating."""@en ;
  dcterms:modified "2026-06-07T15:30:29.594713Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20348-2
  a curric:KeyLearningPoint ;
  rdfs:label """Radio waves and microwaves are used for long distance communication, broadcasting
  and data transmission."""@en ;
  dcterms:modified "2026-06-07T15:30:29.594717Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20348-3
  a curric:KeyLearningPoint ;
  rdfs:label """Microwaves are absorbed by water, so can be used to cook food from within. IR
  radiation cooks the surface of food."""@en ;
  dcterms:modified "2026-06-07T15:30:29.594723Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20348-4
  a curric:KeyLearningPoint ;
  rdfs:label """IR is used for heating and thermal imaging. Visible light and IR are used for data
  transmission in optical fibres."""@en ;
  dcterms:modified "2026-06-07T15:30:29.594729Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9158-1
  a curric:KeyLearningPoint ;
  rdfs:label "A light microscope can be used to observe animal and plant cells."@en ;
  dcterms:modified "2026-06-07T15:30:29.595223Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9158-2
  a curric:KeyLearningPoint ;
  rdfs:label "The parts of a light microscope and their functions."@en ;
  dcterms:modified "2026-06-07T15:30:29.595227Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9158-3
  a curric:KeyLearningPoint ;
  rdfs:label """The sequence of steps setting up a light microscope to observe cells, including
  changing the magnification and focus."""@en ;
  dcterms:modified "2026-06-07T15:30:29.595231Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9158-4
  a curric:KeyLearningPoint ;
  rdfs:label """Observations from a light microscope can be recorded in a labelled scientific line
  drawing with an indication of scale."""@en ;
  dcterms:modified "2026-06-07T15:30:29.595235Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9158-5
  a curric:KeyLearningPoint ;
  rdfs:label """The magnification and real size of structures observed with a microscope can be
  calculated."""@en ;
  dcterms:modified "2026-06-07T15:30:29.595240Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9750-1
  a curric:KeyLearningPoint ;
  rdfs:label "There are four ions present in a solution of brine: H⁺, OH⁻, Na⁺ and Cl⁻."@en ;
  dcterms:modified "2026-06-07T15:30:29.595256Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9750-2
  a curric:KeyLearningPoint ;
  rdfs:label "The product at the negative electrode is hydrogen gas."@en ;
  dcterms:modified "2026-06-07T15:30:29.595261Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9750-3
  a curric:KeyLearningPoint ;
  rdfs:label "The product at the positive electrode is chlorine gas."@en ;
  dcterms:modified "2026-06-07T15:30:29.595265Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9750-4
  a curric:KeyLearningPoint ;
  rdfs:label "Sodium hydroxide solution forms in the electrolyte solution, making it alkaline."@en ;
  dcterms:modified "2026-06-07T15:30:29.595269Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9750-5
  a curric:KeyLearningPoint ;
  rdfs:label "Two types of ions are in competition at each electrode."@en ;
  dcterms:modified "2026-06-07T15:30:29.595275Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8387-1
  a curric:KeyLearningPoint ;
  rdfs:label "Humans use Earth’s natural resources for most of our material needs."@en ;
  dcterms:modified "2026-06-07T15:30:29.595279Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8387-2
  a curric:KeyLearningPoint ;
  rdfs:label """Finite resources exist in limited quantities and will run out because we use them
  quicker than they can be regenerated."""@en ;
  dcterms:modified "2026-06-07T15:30:29.595283Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8387-3
  a curric:KeyLearningPoint ;
  rdfs:label """Synthetic products such as plastic and glass are made by humans using natural
  resources."""@en ;
  dcterms:modified "2026-06-07T15:30:29.595287Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8387-4
  a curric:KeyLearningPoint ;
  rdfs:label """Sustainable development meets our needs without compromising the ability of future
  generations to meet their own needs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.595291Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8387-5
  a curric:KeyLearningPoint ;
  rdfs:label """Use of renewable resources, and the reuse and recycling of products, are sustainable
  development strategies."""@en ;
  dcterms:modified "2026-06-07T15:30:29.595295Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8344-1
  a curric:KeyLearningPoint ;
  rdfs:label """In a giant ionic structure there are strong electrostatic forces in all directions
  between oppositely charged particles."""@en ;
  dcterms:modified "2026-06-07T15:30:29.595301Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8344-2
  a curric:KeyLearningPoint ;
  rdfs:label """Ionic compounds have high melting points and high boiling points because strong
  ionic bonds need to be broken."""@en ;
  dcterms:modified "2026-06-07T15:30:29.595306Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8344-3
  a curric:KeyLearningPoint ;
  rdfs:label "Most ionic substances can dissolve in water."@en ;
  dcterms:modified "2026-06-07T15:30:29.595310Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8344-4
  a curric:KeyLearningPoint ;
  rdfs:label """The ions of ionic compounds dissolved in water are free to move around and the
  solution can conduct electricity."""@en ;
  dcterms:modified "2026-06-07T15:30:29.595314Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8344-5
  a curric:KeyLearningPoint ;
  rdfs:label """The ions of ionic compounds that are in the liquid state are free to move around and
  the liquid can conduct electricity."""@en ;
  dcterms:modified "2026-06-07T15:30:29.595318Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20078-1
  a curric:KeyLearningPoint ;
  rdfs:label "The atmosphere comprises ~80% nitrogen and ~20% oxygen."@en ;
  dcterms:modified "2026-06-07T15:30:29.595327Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20078-2
  a curric:KeyLearningPoint ;
  rdfs:label """The atmosphere contains small proportions of various other gases, including CO₂,
  water vapour and noble gases."""@en ;
  dcterms:modified "2026-06-07T15:30:29.595333Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20078-3
  a curric:KeyLearningPoint ;
  rdfs:label """The atmosphere thins out with height which makes it harder for humans to breathe
  sufficient oxygen at high altitude."""@en ;
  dcterms:modified "2026-06-07T15:30:29.595337Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20078-4
  a curric:KeyLearningPoint ;
  rdfs:label """The atmosphere contains water, mainly in its gas state but in its liquid (or solid)
  state in clouds and precipitation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.595342Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20078-5
  a curric:KeyLearningPoint ;
  rdfs:label "The atmosphere also contains a wide range of solid particulates."@en ;
  dcterms:modified "2026-06-07T15:30:29.595346Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8364-1
  a curric:KeyLearningPoint ;
  rdfs:label """Combustion is the chemical combination of a substance with oxygen, involving the
  production of heat and light."""@en ;
  dcterms:modified "2026-06-07T15:30:29.595350Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8364-2
  a curric:KeyLearningPoint ;
  rdfs:label """Complete combustion of fuels (like hydrocarbons) involve the production of carbon
  dioxide and water."""@en ;
  dcterms:modified "2026-06-07T15:30:29.595356Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8364-3
  a curric:KeyLearningPoint ;
  rdfs:label """The chemical test for oxygen is a combustion reaction, involving relighting a
  glowing splint."""@en ;
  dcterms:modified "2026-06-07T15:30:29.595361Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8364-4
  a curric:KeyLearningPoint ;
  rdfs:label """Incomplete combustion produces carbon particulates (soot) and carbon monoxide due to
  reduced oxygen levels."""@en ;
  dcterms:modified "2026-06-07T15:30:29.595365Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5553-1
  a curric:KeyLearningPoint ;
  rdfs:label "Enzymes are proteins that act as catalysts, speeding up chemical reactions."@en ;
  dcterms:modified "2026-06-07T15:30:29.595369Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5553-2
  a curric:KeyLearningPoint ;
  rdfs:label "Without enzymes, many reactions would happen too slowly to support life."@en ;
  dcterms:modified "2026-06-07T15:30:29.595373Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5553-3
  a curric:KeyLearningPoint ;
  rdfs:label """Enzymes catalyse reactions essential to life, including digestion and reactions in
  photosynthesis and respiration."""@en ;
  dcterms:modified "2026-06-07T15:30:29.595377Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5553-4
  a curric:KeyLearningPoint ;
  rdfs:label """Each enzyme has a 3D shape with an active site that a specific substrate
  fits into."""@en ;
  dcterms:modified "2026-06-07T15:30:29.595381Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5553-5
  a curric:KeyLearningPoint ;
  rdfs:label "The lock and key model to explain enzyme-substrate interactions."@en ;
  dcterms:modified "2026-06-07T15:30:29.595386Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7989-1
  a curric:KeyLearningPoint ;
  rdfs:label """An early animal embryo is made of unspecialised cells; these are embryonic stem
  cells."""@en ;
  dcterms:modified "2026-06-07T15:30:29.595438Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7989-2
  a curric:KeyLearningPoint ;
  rdfs:label """Embryonic stem cells can differentiate to become all types of cells in the animal’s
  body."""@en ;
  dcterms:modified "2026-06-07T15:30:29.595443Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7989-3
  a curric:KeyLearningPoint ;
  rdfs:label """As an animal develops into an adult, some cells remain unspecialised; these are
  adult stem cells."""@en ;
  dcterms:modified "2026-06-07T15:30:29.595449Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7989-4
  a curric:KeyLearningPoint ;
  rdfs:label """Adult stem cells can differentiate to become most but not all types of cells in the
  animal’s body."""@en ;
  dcterms:modified "2026-06-07T15:30:29.595454Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7989-5
  a curric:KeyLearningPoint ;
  rdfs:label """An example of adult stem cells in humans (e.g. in bone marrow; these can divide and
  differentiate to make blood cells)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.595458Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20353-1
  a curric:KeyLearningPoint ;
  rdfs:label "Dalton (1803) arranged known elements in order of atomic weights."@en ;
  dcterms:modified "2026-06-07T15:30:29.595494Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20353-2
  a curric:KeyLearningPoint ;
  rdfs:label """Newlands (1865) noticed that every eighth element, in order of atomic mass, repeated
  similar properties."""@en ;
  dcterms:modified "2026-06-07T15:30:29.595499Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20353-3
  a curric:KeyLearningPoint ;
  rdfs:label """Mendeleev swapped the order of atomic weights in order to fit elements better into
  groups of similar properties."""@en ;
  dcterms:modified "2026-06-07T15:30:29.595503Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20353-4
  a curric:KeyLearningPoint ;
  rdfs:label """Mendeleev’s periodic table had gaps and he predicted missing elements that were
  later found."""@en ;
  dcterms:modified "2026-06-07T15:30:29.595507Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20353-5
  a curric:KeyLearningPoint ;
  rdfs:label """Mendeleev was not aware of isotopes, so was unable to explain why the ordering by
  atomic weight was not always correct."""@en ;
  dcterms:modified "2026-06-07T15:30:29.595513Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8362-1
  a curric:KeyLearningPoint ;
  rdfs:label """A reaction profile compares the amount of energy the products of a reaction have
  compared to the reactants."""@en ;
  dcterms:modified "2026-06-07T15:30:29.595537Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8362-2
  a curric:KeyLearningPoint ;
  rdfs:label """Exothermic chemical reactions transfer energy from reactants to the surroundings
  causing an increase in temperature."""@en ;
  dcterms:modified "2026-06-07T15:30:29.595541Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8362-3
  a curric:KeyLearningPoint ;
  rdfs:label """Endothermic chemical reactions transfer energy from the surroundings to the products
  causing a decrease in temperature."""@en ;
  dcterms:modified "2026-06-07T15:30:29.595545Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8362-4
  a curric:KeyLearningPoint ;
  rdfs:label """Activation energy is the minimum amount of energy transferred to reactants that
  allows a chemical reaction to start."""@en ;
  dcterms:modified "2026-06-07T15:30:29.595549Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9638-1
  a curric:KeyLearningPoint ;
  rdfs:label """An experiment can be planned to measure the temperature change through continuous
  heating of a substance"""@en ;
  dcterms:modified "2026-06-07T15:30:29.595553Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9638-2
  a curric:KeyLearningPoint ;
  rdfs:label """Energy is needed to overcome forces of attraction between particles so temperature
  does not change when changing state"""@en ;
  dcterms:modified "2026-06-07T15:30:29.595557Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9638-3
  a curric:KeyLearningPoint ;
  rdfs:label """The change in state of pure substances can be seen on a heating/cooling curve as a
  horizontal line"""@en ;
  dcterms:modified "2026-06-07T15:30:29.595562Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9638-4
  a curric:KeyLearningPoint ;
  rdfs:label """There is a change of energy, arrangement, and organisation of particles of a pure
  substance at each stage"""@en ;
  dcterms:modified "2026-06-07T15:30:29.595566Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8397-1
  a curric:KeyLearningPoint ;
  rdfs:label """The atmosphere comprises 78% nitrogen, 21% oxygen, 1% argon and trace gases
  including 0.04% carbon dioxide."""@en ;
  dcterms:modified "2026-06-07T15:30:29.595570Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8397-2
  a curric:KeyLearningPoint ;
  rdfs:label """The atmosphere thins out with height which makes it harder for humans to breathe
  sufficient oxygen at high altitude."""@en ;
  dcterms:modified "2026-06-07T15:30:29.595574Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8397-3
  a curric:KeyLearningPoint ;
  rdfs:label """The atmosphere contains water, mainly in its gas state but in its liquid (or solid)
  state in clouds and precipitation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.595578Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8397-4
  a curric:KeyLearningPoint ;
  rdfs:label "The atmosphere also contains a wide range of solid particulates."@en ;
  dcterms:modified "2026-06-07T15:30:29.595582Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8357-1
  a curric:KeyLearningPoint ;
  rdfs:label "Gently heating the acid speeds up the reaction, ensuring all acid reacts."@en ;
  dcterms:modified "2026-06-07T15:30:29.595588Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8357-2
  a curric:KeyLearningPoint ;
  rdfs:label """The salt should be dried using an appropriate method (using filter paper, or in the
  oven)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.595593Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8357-3
  a curric:KeyLearningPoint ;
  rdfs:label """A pure sample should be prepared with equipment washed with distilled water to avoid
  contamination."""@en ;
  dcterms:modified "2026-06-07T15:30:29.595599Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8357-4
  a curric:KeyLearningPoint ;
  rdfs:label "Reacting a metal hydroxide with an acid also produces a salt and water."@en ;
  dcterms:modified "2026-06-07T15:30:29.595604Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8357-5
  a curric:KeyLearningPoint ;
  rdfs:label """Reacting a metal carbonate with an acid can produce a desired salt with water, as
  well as carbon dioxide gas."""@en ;
  dcterms:modified "2026-06-07T15:30:29.595608Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7973-1
  a curric:KeyLearningPoint ;
  rdfs:label """The genome stores instructions that are used by cells to make structural and
  functional proteins (including enzymes)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.595947Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7973-2
  a curric:KeyLearningPoint ;
  rdfs:label """The proteins that are made are used to build other structures and control chemical
  reactions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.595951Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7973-3
  a curric:KeyLearningPoint ;
  rdfs:label "The characteristics of an organism are called the phenotype."@en ;
  dcterms:modified "2026-06-07T15:30:29.595955Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7973-4
  a curric:KeyLearningPoint ;
  rdfs:label """Some characteristics in an organism’s phenotype are determined only by its genome
  (e.g. eye colour)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.595959Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7973-5
  a curric:KeyLearningPoint ;
  rdfs:label """Most characteristics in the phenotype are influenced by the organism's genome and
  interaction with its environment."""@en ;
  dcterms:modified "2026-06-07T15:30:29.595963Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9117-1
  a curric:KeyLearningPoint ;
  rdfs:label """A spring is elastically deformed if it returns to its original shape after the
  applied force is removed"""@en ;
  dcterms:modified "2026-06-07T15:30:29.596023Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9117-2
  a curric:KeyLearningPoint ;
  rdfs:label """A spring is inelastically deformed if it does not return to its original shape after
  the applied force is removed"""@en ;
  dcterms:modified "2026-06-07T15:30:29.596027Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9117-3
  a curric:KeyLearningPoint ;
  rdfs:label """Elastic deformation is proportional to the force applied to stretch or compress a
  spring"""@en ;
  dcterms:modified "2026-06-07T15:30:29.596031Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9117-4
  a curric:KeyLearningPoint ;
  rdfs:label """The spring constant (k) is the force needed to extend or compress an elastic object
  by one metre"""@en ;
  dcterms:modified "2026-06-07T15:30:29.596038Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9117-5
  a curric:KeyLearningPoint ;
  rdfs:label "Force on a spring = spring constant × extension"@en ;
  dcterms:modified "2026-06-07T15:30:29.596042Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26663-1
  a curric:KeyLearningPoint ;
  rdfs:label """All cells, including our body cells and pathogens, have molecules called antigens on
  their surface."""@en ;
  dcterms:modified "2026-06-07T15:30:29.596131Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26663-2
  a curric:KeyLearningPoint ;
  rdfs:label "White blood cells only respond to non-self antigens on pathogens."@en ;
  dcterms:modified "2026-06-07T15:30:29.596135Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26663-3
  a curric:KeyLearningPoint ;
  rdfs:label """Lymphocytes are an important part of the human immune system and respond to antigens
  on specific pathogens."""@en ;
  dcterms:modified "2026-06-07T15:30:29.596140Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26663-4
  a curric:KeyLearningPoint ;
  rdfs:label "Lymphocytes produce antibodies against specific pathogens."@en ;
  dcterms:modified "2026-06-07T15:30:29.596144Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26663-5
  a curric:KeyLearningPoint ;
  rdfs:label "Lymphocytes produce antitoxins to neutralise toxins produced by bacteria."@en ;
  dcterms:modified "2026-06-07T15:30:29.596148Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6404-1
  a curric:KeyLearningPoint ;
  rdfs:label """Some variation in phenotype is caused only by the environment and is not
  heritable."""@en ;
  dcterms:modified "2026-06-07T15:30:29.596194Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6404-2
  a curric:KeyLearningPoint ;
  rdfs:label """Some variation is caused by genetic material; this can be passed on to offspring via
  gametes or asexual reproduction."""@en ;
  dcterms:modified "2026-06-07T15:30:29.596201Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6404-3
  a curric:KeyLearningPoint ;
  rdfs:label """A change in the sequence of bases in an organism's DNA is called a mutation and
  creates a genetic variant."""@en ;
  dcterms:modified "2026-06-07T15:30:29.596206Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6404-4
  a curric:KeyLearningPoint ;
  rdfs:label """Mutations happen at random (caused by carcinogens, or by ionising radiation, or by
  errors when DNA is copied)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.596210Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6404-5
  a curric:KeyLearningPoint ;
  rdfs:label """Most mutations have no effect on phenotype, some influence phenotype, and a few
  determine phenotype."""@en ;
  dcterms:modified "2026-06-07T15:30:29.596214Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5585-1
  a curric:KeyLearningPoint ;
  rdfs:label """Sugars, amino acids and other organic substances (nutrients) are transported in
  phloem."""@en ;
  dcterms:modified "2026-06-07T15:30:29.596241Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5585-2
  a curric:KeyLearningPoint ;
  rdfs:label "Translocation starts at a source, such as a leaf where sugars are made."@en ;
  dcterms:modified "2026-06-07T15:30:29.596246Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5585-3
  a curric:KeyLearningPoint ;
  rdfs:label """Sugars are transported into phloem by active transport across the membranes of the
  living phloem cells."""@en ;
  dcterms:modified "2026-06-07T15:30:29.596250Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5585-4
  a curric:KeyLearningPoint ;
  rdfs:label """Water moves into the phloem cells by osmosis, which increases the pressure and
  pushes the sugars along the phloem tube."""@en ;
  dcterms:modified "2026-06-07T15:30:29.596254Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5585-5
  a curric:KeyLearningPoint ;
  rdfs:label """Sugars are transported out of the phloem by active transport at a sink, such as a
  developing root, stem or flower."""@en ;
  dcterms:modified "2026-06-07T15:30:29.596258Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9730-1
  a curric:KeyLearningPoint ;
  rdfs:label """In a reversible reaction the desired product needs to be continuously removed from
  the reaction."""@en ;
  dcterms:modified "2026-06-07T15:30:29.596339Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9730-2
  a curric:KeyLearningPoint ;
  rdfs:label "Natural gas is a feedstock for industrial production of ammonia."@en ;
  dcterms:modified "2026-06-07T15:30:29.596343Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9730-3
  a curric:KeyLearningPoint ;
  rdfs:label """Hydrogen, one of the raw materials in ammonia production, is produced from natural
  gas and steam."""@en ;
  dcterms:modified "2026-06-07T15:30:29.596347Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9730-4
  a curric:KeyLearningPoint ;
  rdfs:label """In industry, the Haber process is typically performed at 150-300 atmospheres,
  400-450°C, with an iron catalyst."""@en ;
  dcterms:modified "2026-06-07T15:30:29.596351Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9730-5
  a curric:KeyLearningPoint ;
  rdfs:label """Ammonia production is energy-intensive and releases large amounts of carbon dioxide,
  contributing to global emissions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.596355Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9646-1
  a curric:KeyLearningPoint ;
  rdfs:label """Distillation separates a soluble substance from its solvent based on differences in
  boiling points."""@en ;
  dcterms:modified "2026-06-07T15:30:29.596382Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9646-2
  a curric:KeyLearningPoint ;
  rdfs:label """Distillation requires multiple pieces of apparatus which work in conjunction with
  each other."""@en ;
  dcterms:modified "2026-06-07T15:30:29.596386Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9646-3
  a curric:KeyLearningPoint ;
  rdfs:label """The processes of boiling and condensing are involved in the process of
  distillation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.596391Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9646-4
  a curric:KeyLearningPoint ;
  rdfs:label """Simple distillation is used primarily to separate mixtures of only two
  components."""@en ;
  dcterms:modified "2026-06-07T15:30:29.596395Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8340-1
  a curric:KeyLearningPoint ;
  rdfs:label "Metals are good electrical conductors and good thermal conductors."@en ;
  dcterms:modified "2026-06-07T15:30:29.596399Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8340-2
  a curric:KeyLearningPoint ;
  rdfs:label "Metals can be stretched into wires, or bent/hammered into different shapes."@en ;
  dcterms:modified "2026-06-07T15:30:29.596403Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8340-3
  a curric:KeyLearningPoint ;
  rdfs:label """Individual atoms do not have the physical properties of the substances that contain
  them."""@en ;
  dcterms:modified "2026-06-07T15:30:29.596409Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8340-4
  a curric:KeyLearningPoint ;
  rdfs:label """Metallic structures consist of positive ions and free–moving outer shell
  electrons."""@en ;
  dcterms:modified "2026-06-07T15:30:29.596414Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8340-5
  a curric:KeyLearningPoint ;
  rdfs:label """Electrostatic forces of attraction between ions and free electrons bind them all
  together in a giant metallic structure."""@en ;
  dcterms:modified "2026-06-07T15:30:29.596418Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4912-1
  a curric:KeyLearningPoint ;
  rdfs:label "Some forces require contact between objects, while others do not."@en ;
  dcterms:modified "2026-06-07T15:30:29.596422Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4912-2
  a curric:KeyLearningPoint ;
  rdfs:label "Forces are vectors and can be drawn as arrows on diagrams."@en ;
  dcterms:modified "2026-06-07T15:30:29.596427Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4912-3
  a curric:KeyLearningPoint ;
  rdfs:label "A free body diagram shows all of the forces acting on a single object."@en ;
  dcterms:modified "2026-06-07T15:30:29.596431Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4912-4
  a curric:KeyLearningPoint ;
  rdfs:label "For every force there is an equal sized force acting in the opposite direction."@en ;
  dcterms:modified "2026-06-07T15:30:29.596435Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4912-5
  a curric:KeyLearningPoint ;
  rdfs:label """Force pairs have the same magnitude and type, and act in opposite directions between
  two objects."""@en ;
  dcterms:modified "2026-06-07T15:30:29.596439Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9189-1
  a curric:KeyLearningPoint ;
  rdfs:label "Tobacco mosaic virus is an example of a disease in plants caused by a virus."@en ;
  dcterms:modified "2026-06-07T15:30:29.596838Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9189-2
  a curric:KeyLearningPoint ;
  rdfs:label "Crown gall disease is an example of a disease in plants caused by a bacterium."@en ;
  dcterms:modified "2026-06-07T15:30:29.596842Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9189-3
  a curric:KeyLearningPoint ;
  rdfs:label "Barley powdery mildew is an example of a disease in plants caused by a fungus."@en ;
  dcterms:modified "2026-06-07T15:30:29.596846Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9189-4
  a curric:KeyLearningPoint ;
  rdfs:label """Ways in which plant diseases can be spread, and ways in which the spread can be
  reduced."""@en ;
  dcterms:modified "2026-06-07T15:30:29.596852Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9189-5
  a curric:KeyLearningPoint ;
  rdfs:label "Impacts of plant diseases, including on biodiversity and human food security."@en ;
  dcterms:modified "2026-06-07T15:30:29.596857Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6294-1
  a curric:KeyLearningPoint ;
  rdfs:label """Abiotic factors such as light levels, temperature, soil moisture and pH can be
  measured."""@en ;
  dcterms:modified "2026-06-07T15:30:29.596863Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6294-2
  a curric:KeyLearningPoint ;
  rdfs:label """Transects can be used to investigate the effects of a changing factor on the
  distribution and abundance of organisms."""@en ;
  dcterms:modified "2026-06-07T15:30:29.596868Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6294-3
  a curric:KeyLearningPoint ;
  rdfs:label """A transect can be placed along a gradient of a factor (e.g. from shade to full
  sunlight)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.596872Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6294-4
  a curric:KeyLearningPoint ;
  rdfs:label """A belt transect uses quadrats placed along the straight line to measure distribution
  and abundance."""@en ;
  dcterms:modified "2026-06-07T15:30:29.596876Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5576-1
  a curric:KeyLearningPoint ;
  rdfs:label """Producers use photosynthesis to make their own food in the form of glucose (a simple
  carbohydrate)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.596880Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5576-2
  a curric:KeyLearningPoint ;
  rdfs:label """Consumers can only get food by eating producers or other consumers; producers are
  the source of food for food chains."""@en ;
  dcterms:modified "2026-06-07T15:30:29.596885Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5576-3
  a curric:KeyLearningPoint ;
  rdfs:label """Consumers cannot use carbon and nitrogen from the environment to make biomass; they
  get them by eating producers."""@en ;
  dcterms:modified "2026-06-07T15:30:29.596889Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5576-4
  a curric:KeyLearningPoint ;
  rdfs:label """Producers and consumers use the carbohydrate from photosynthesis to make biomass for
  growth and as fuel for respiration."""@en ;
  dcterms:modified "2026-06-07T15:30:29.596893Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5576-5
  a curric:KeyLearningPoint ;
  rdfs:label """Consumers also depend upon producers to add oxygen to the atmosphere, which they use
  for aerobic cellular respiration."""@en ;
  dcterms:modified "2026-06-07T15:30:29.596897Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20457-1
  a curric:KeyLearningPoint ;
  rdfs:label """The volume of one mole of any gas at room temperature and pressure (20℃ and 1
  atmosphere pressure) is 24 dm³."""@en ;
  dcterms:modified "2026-06-07T15:30:29.596901Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20457-2
  a curric:KeyLearningPoint ;
  rdfs:label """Reacting mass calculations can use a combination of mass to volume calculations and
  vice versa."""@en ;
  dcterms:modified "2026-06-07T15:30:29.596905Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20457-3
  a curric:KeyLearningPoint ;
  rdfs:label "Amount of substance (moles) can be calculated using multiple equations."@en ;
  dcterms:modified "2026-06-07T15:30:29.596910Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20457-4
  a curric:KeyLearningPoint ;
  rdfs:label """The choice of equation for calculating moles depends on the context of the problem
  or calculation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.596914Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8426-1
  a curric:KeyLearningPoint ;
  rdfs:label """In an ideal chemical reaction, all atoms in the reactants would end up in useful
  products, with no waste."""@en ;
  dcterms:modified "2026-06-07T15:30:29.596918Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8426-2
  a curric:KeyLearningPoint ;
  rdfs:label """The theoretical yield of a chemical reaction can be calculated from the reaction
  equation alone."""@en ;
  dcterms:modified "2026-06-07T15:30:29.596922Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8426-3
  a curric:KeyLearningPoint ;
  rdfs:label "The percentage yield shows how actual yield compares with theoretical yield."@en ;
  dcterms:modified "2026-06-07T15:30:29.596926Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8426-4
  a curric:KeyLearningPoint ;
  rdfs:label """Atom economy is a measure of the efficiency with which a reaction uses its
  reactants."""@en ;
  dcterms:modified "2026-06-07T15:30:29.596932Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8426-5
  a curric:KeyLearningPoint ;
  rdfs:label "Many factors will be considered when choosing a reaction pathway."@en ;
  dcterms:modified "2026-06-07T15:30:29.596937Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20082-1
  a curric:KeyLearningPoint ;
  rdfs:label """Atoms of many elements vary in the exact number of neutrons in their nucleus, and
  each version is called an isotope."""@en ;
  dcterms:modified "2026-06-07T15:30:29.596943Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20082-2
  a curric:KeyLearningPoint ;
  rdfs:label """Existence of isotopes results in relative atomic masses of some elements not being
  whole numbers."""@en ;
  dcterms:modified "2026-06-07T15:30:29.596947Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20082-3
  a curric:KeyLearningPoint ;
  rdfs:label """Standard nuclear notation shows the chemical symbol, the mass number and the atomic
  number of the isotope."""@en ;
  dcterms:modified "2026-06-07T15:30:29.596952Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28012-1
  a curric:KeyLearningPoint ;
  rdfs:label """A base is a substance that neutralises an acid to make salt and water only (this is
  a neutralisation reaction)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.596968Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28012-2
  a curric:KeyLearningPoint ;
  rdfs:label "Hydroxides are generally soluble bases (they contain OH⁻ ions)."@en ;
  dcterms:modified "2026-06-07T15:30:29.596972Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28012-3
  a curric:KeyLearningPoint ;
  rdfs:label "Metal oxides are bases that are generally insoluble."@en ;
  dcterms:modified "2026-06-07T15:30:29.596976Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28012-4
  a curric:KeyLearningPoint ;
  rdfs:label "Non-metal oxides are soluble and form acidic solutions."@en ;
  dcterms:modified "2026-06-07T15:30:29.596980Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6580-1
  a curric:KeyLearningPoint ;
  rdfs:label "Some forces require contact between objects, while others do not."@en ;
  dcterms:modified "2026-06-07T15:30:29.596984Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6580-2
  a curric:KeyLearningPoint ;
  rdfs:label "Forces are vectors and can be drawn as arrows on diagrams."@en ;
  dcterms:modified "2026-06-07T15:30:29.596988Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6580-3
  a curric:KeyLearningPoint ;
  rdfs:label """A free body diagram shows all of the individual forces acting on a single
  object."""@en ;
  dcterms:modified "2026-06-07T15:30:29.596993Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6580-4
  a curric:KeyLearningPoint ;
  rdfs:label "For every force there is an equal sized force acting in the opposite direction."@en ;
  dcterms:modified "2026-06-07T15:30:29.596997Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6580-5
  a curric:KeyLearningPoint ;
  rdfs:label """Force pairs have the same magnitude and type and act in opposite directions between
  two objects."""@en ;
  dcterms:modified "2026-06-07T15:30:29.597001Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6286-1
  a curric:KeyLearningPoint ;
  rdfs:label "The common features of animal and plant cells."@en ;
  dcterms:modified "2026-06-07T15:30:29.597005Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6286-2
  a curric:KeyLearningPoint ;
  rdfs:label """Animals, plants, fungi and protists are made up of cells with a nucleus in which
  their genome is stored."""@en ;
  dcterms:modified "2026-06-07T15:30:29.597011Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6286-3
  a curric:KeyLearningPoint ;
  rdfs:label "Organisms made of cells with a nucleus are classified as eukaryotic organisms."@en ;
  dcterms:modified "2026-06-07T15:30:29.597016Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6286-4
  a curric:KeyLearningPoint ;
  rdfs:label """Common features of bacteria cells, including cell membrane, cell wall, plasmids and
  storing the genome in the cytoplasm."""@en ;
  dcterms:modified "2026-06-07T15:30:29.597020Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6286-5
  a curric:KeyLearningPoint ;
  rdfs:label """Organisms made of cells without a nucleus are classified as prokaryotic
  organisms."""@en ;
  dcterms:modified "2026-06-07T15:30:29.597024Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7980-1
  a curric:KeyLearningPoint ;
  rdfs:label """Offspring inherit two alleles, one from each parent, the combination of these
  alleles is the genotype."""@en ;
  dcterms:modified "2026-06-07T15:30:29.597098Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7980-2
  a curric:KeyLearningPoint ;
  rdfs:label """The phenotypes of members of a family can be shown in a diagram such as a family
  tree (pedigree)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.597102Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7980-3
  a curric:KeyLearningPoint ;
  rdfs:label """A family tree diagram is a model of inheritance, showing whether a characteristic
  was passed from parents to offspring."""@en ;
  dcterms:modified "2026-06-07T15:30:29.597107Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7980-4
  a curric:KeyLearningPoint ;
  rdfs:label """A family tree can be used to work out an individual’s genotype if their phenotype
  and relatives’ genotypes are known."""@en ;
  dcterms:modified "2026-06-07T15:30:29.597114Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7980-5
  a curric:KeyLearningPoint ;
  rdfs:label """A family tree can be used to determine the history and probability of genetic
  disorders: cystic fibrosis and polydactyly"""@en ;
  dcterms:modified "2026-06-07T15:30:29.597120Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8141-1
  a curric:KeyLearningPoint ;
  rdfs:label """Human hearing involves the transmission of sound waves through different parts of
  the ear."""@en ;
  dcterms:modified "2026-06-07T15:30:29.597639Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8141-2
  a curric:KeyLearningPoint ;
  rdfs:label """Wave transmission to a new medium can be limited by the wave amplitude or the wave
  frequency."""@en ;
  dcterms:modified "2026-06-07T15:30:29.597643Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8141-3
  a curric:KeyLearningPoint ;
  rdfs:label """The range of human hearing is 20 Hz to 20 000 Hz. Frequencies above and below this
  are called ultrasound and infrasound."""@en ;
  dcterms:modified "2026-06-07T15:30:29.597647Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8141-4
  a curric:KeyLearningPoint ;
  rdfs:label """The highest frequency you can hear reduces with age as cells of the cochlea and
  auditory nerve become damaged over time."""@en ;
  dcterms:modified "2026-06-07T15:30:29.597651Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28973-1
  a curric:KeyLearningPoint ;
  rdfs:label """Forests act as a global carbon sink, absorbing one-quarter of the annual global CO₂
  emissions from the atmosphere."""@en ;
  dcterms:modified "2026-06-07T15:30:29.597692Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28973-2
  a curric:KeyLearningPoint ;
  rdfs:label """Deforestation contributes to climate change and is a major cause of habitat and
  biodiversity loss."""@en ;
  dcterms:modified "2026-06-07T15:30:29.597696Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28973-3
  a curric:KeyLearningPoint ;
  rdfs:label """Mitigation strategies include forest protection, reducing deforestation for farming,
  and replanting trees."""@en ;
  dcterms:modified "2026-06-07T15:30:29.597700Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28973-4
  a curric:KeyLearningPoint ;
  rdfs:label """Oceans act as a global carbon sink, absorbing one-quarter of annual global CO₂
  emissions from the atmosphere."""@en ;
  dcterms:modified "2026-06-07T15:30:29.597706Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28973-5
  a curric:KeyLearningPoint ;
  rdfs:label """High CO₂ levels harm marine biodiversity through ocean acidification and reduced
  shell formation, alongside overfishing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.597713Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7983-1
  a curric:KeyLearningPoint ;
  rdfs:label """Most cells in multicellular organisms go through different phases that are part of a
  cell cycle."""@en ;
  dcterms:modified "2026-06-07T15:30:29.597717Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7983-2
  a curric:KeyLearningPoint ;
  rdfs:label "The main phases of the cell cycle are interphase and mitosis."@en ;
  dcterms:modified "2026-06-07T15:30:29.597721Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7983-3
  a curric:KeyLearningPoint ;
  rdfs:label """During cell interphase, each chromosome is copied, sub-cellular structures are
  copied."""@en ;
  dcterms:modified "2026-06-07T15:30:29.597726Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7983-4
  a curric:KeyLearningPoint ;
  rdfs:label """During mitosis, chromosome copies line up along the middle of the cell and the
  nucleus divides."""@en ;
  dcterms:modified "2026-06-07T15:30:29.597730Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7983-5
  a curric:KeyLearningPoint ;
  rdfs:label "After division, the two new cells both have a copy of the same chromosomes."@en ;
  dcterms:modified "2026-06-07T15:30:29.597734Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5540-1
  a curric:KeyLearningPoint ;
  rdfs:label """The human body has a nervous system that enables us to sense and respond quickly to
  changes outside and inside the body."""@en ;
  dcterms:modified "2026-06-07T15:30:29.597738Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5540-2
  a curric:KeyLearningPoint ;
  rdfs:label """Examples of stimulus (e.g. increase in temperature) and response (e.g.
  sweating)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.597742Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5540-3
  a curric:KeyLearningPoint ;
  rdfs:label """The structures that make up the central nervous system (CNS) and peripheral nervous
  system (PNS)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.597746Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5540-4
  a curric:KeyLearningPoint ;
  rdfs:label """Receptors detect stimuli; they can be single cells (e.g. in the skin) or groups of
  cells in sense organs (e.g. the eye)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.597751Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5540-5
  a curric:KeyLearningPoint ;
  rdfs:label """Sensory neurones join receptors to the CNS; motor neurones join the CNS to effectors
  that carry out the response."""@en ;
  dcterms:modified "2026-06-07T15:30:29.597755Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20446-1
  a curric:KeyLearningPoint ;
  rdfs:label """A light microscope can be used to observe plant cells in different stages of mitosis
  (e.g. from onion root tip)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.597759Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20446-2
  a curric:KeyLearningPoint ;
  rdfs:label "The parts of a light microscope and their functions."@en ;
  dcterms:modified "2026-06-07T15:30:29.597763Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20446-3
  a curric:KeyLearningPoint ;
  rdfs:label """The sequence of steps to set up a light microscope to observe cells, including
  changing the magnification and focus."""@en ;
  dcterms:modified "2026-06-07T15:30:29.597767Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20446-4
  a curric:KeyLearningPoint ;
  rdfs:label """Explaining observations from microscopy using ideas about what happens during the
  cell cycle (including PMAT)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.597772Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9625-1
  a curric:KeyLearningPoint ;
  rdfs:label "Iron is alloyed with other metals to produce steel alloys."@en ;
  dcterms:modified "2026-06-07T15:30:29.597776Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9625-2
  a curric:KeyLearningPoint ;
  rdfs:label "Copper is alloyed with other metals to make multiple useful alloys."@en ;
  dcterms:modified "2026-06-07T15:30:29.597780Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9625-3
  a curric:KeyLearningPoint ;
  rdfs:label "Gold, aluminium, and magnesium all form useful alloys with other metals."@en ;
  dcterms:modified "2026-06-07T15:30:29.597784Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8422-1
  a curric:KeyLearningPoint ;
  rdfs:label """Fertilisers contain nitrogen, phosphorus and potassium compounds to promote plant
  growth."""@en ;
  dcterms:modified "2026-06-07T15:30:29.597790Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8422-2
  a curric:KeyLearningPoint ;
  rdfs:label """Ammonia is a feedstock for manufacture of fertilisers, explosives, plastics, dyes
  and cleaning products."""@en ;
  dcterms:modified "2026-06-07T15:30:29.597795Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8422-3
  a curric:KeyLearningPoint ;
  rdfs:label "Ammonia can be used to manufacture ammonium salts and nitric acid."@en ;
  dcterms:modified "2026-06-07T15:30:29.597799Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8422-4
  a curric:KeyLearningPoint ;
  rdfs:label "Phosphate rock is used in the production of fertilisers."@en ;
  dcterms:modified "2026-06-07T15:30:29.597803Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8422-5
  a curric:KeyLearningPoint ;
  rdfs:label """The laboratory preparation of ammonium salts is not the same as the industrial
  preparation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.597807Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9116-1
  a curric:KeyLearningPoint ;
  rdfs:label "When an object moves upwards, work is done against the gravitational force."@en ;
  dcterms:modified "2026-06-07T15:30:29.597811Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9116-2
  a curric:KeyLearningPoint ;
  rdfs:label """The gravitational force acting on an object does work to speed it up when it is
  falling."""@en ;
  dcterms:modified "2026-06-07T15:30:29.597815Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9116-3
  a curric:KeyLearningPoint ;
  rdfs:label "Weight = mass x gravitational field strength, W = mg"@en ;
  dcterms:modified "2026-06-07T15:30:29.597819Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9116-4
  a curric:KeyLearningPoint ;
  rdfs:label """Gravitational potential energy of an object = mass × gravitational field strength ×
  height"""@en ;
  dcterms:modified "2026-06-07T15:30:29.597826Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9635-1
  a curric:KeyLearningPoint ;
  rdfs:label """There are changes in arrangement, movement and energy of particles during state
  changes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.597830Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9635-2
  a curric:KeyLearningPoint ;
  rdfs:label """There are two types of change, physical and chemical, and these can be explained in
  terms of the particle model."""@en ;
  dcterms:modified "2026-06-07T15:30:29.597834Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9635-3
  a curric:KeyLearningPoint ;
  rdfs:label "The physical state of a substance can be predicted at specified temperatures."@en ;
  dcterms:modified "2026-06-07T15:30:29.597839Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9635-4
  a curric:KeyLearningPoint ;
  rdfs:label """Forces of attraction between particles have a role in determining the amount of
  energy needed for state changes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.597843Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6296-1
  a curric:KeyLearningPoint ;
  rdfs:label """Microorganisms and detritivores (detritus feeders) are responsible for the
  decomposition of plant and animal material."""@en ;
  dcterms:modified "2026-06-07T15:30:29.597849Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6296-2
  a curric:KeyLearningPoint ;
  rdfs:label "Decay is needed to keep nutrients cycling around an ecosystem."@en ;
  dcterms:modified "2026-06-07T15:30:29.597854Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6296-3
  a curric:KeyLearningPoint ;
  rdfs:label "Compost is made out of decomposed plant and animal material."@en ;
  dcterms:modified "2026-06-07T15:30:29.597858Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6296-4
  a curric:KeyLearningPoint ;
  rdfs:label "Biogas is produced when waste material is anaerobically digested."@en ;
  dcterms:modified "2026-06-07T15:30:29.597862Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6296-5
  a curric:KeyLearningPoint ;
  rdfs:label "Biogas contains methane which can be harvested and used as a fuel."@en ;
  dcterms:modified "2026-06-07T15:30:29.597867Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9666-1
  a curric:KeyLearningPoint ;
  rdfs:label """A base is a substance that neutralises an acid to make salt and water only (this is
  a neutralisation reaction)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.597873Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9666-2
  a curric:KeyLearningPoint ;
  rdfs:label "Hydroxides are generally soluble bases (they contain OH⁻ ions)."@en ;
  dcterms:modified "2026-06-07T15:30:29.597877Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9666-3
  a curric:KeyLearningPoint ;
  rdfs:label "Metal oxides are bases that are generally insoluble."@en ;
  dcterms:modified "2026-06-07T15:30:29.597881Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9666-4
  a curric:KeyLearningPoint ;
  rdfs:label "Non-metal oxides are soluble and form acidic solutions."@en ;
  dcterms:modified "2026-06-07T15:30:29.597886Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4902-1
  a curric:KeyLearningPoint ;
  rdfs:label "Work done is the total amount of energy transferred."@en ;
  dcterms:modified "2026-06-07T15:30:29.598831Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4902-2
  a curric:KeyLearningPoint ;
  rdfs:label "Work done = force x distance (moved in the direction of the force)."@en ;
  dcterms:modified "2026-06-07T15:30:29.598835Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4902-3
  a curric:KeyLearningPoint ;
  rdfs:label "Work done is measured in Joule (J)."@en ;
  dcterms:modified "2026-06-07T15:30:29.598839Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9896-1
  a curric:KeyLearningPoint ;
  rdfs:label "The velocity of an object is equal to the gradient of a displacement-time graph."@en ;
  dcterms:modified "2026-06-07T15:30:29.598843Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9896-2
  a curric:KeyLearningPoint ;
  rdfs:label "A direction in which velocity and displacement are measured needs to be chosen."@en ;
  dcterms:modified "2026-06-07T15:30:29.598847Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9896-3
  a curric:KeyLearningPoint ;
  rdfs:label """A negative gradient on a displacement-time graph (sloping downwards) represents
  velocity in the opposite direction."""@en ;
  dcterms:modified "2026-06-07T15:30:29.598851Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9896-4
  a curric:KeyLearningPoint ;
  rdfs:label """A negative value for displacement represents a position ‘behind’ the starting
  position."""@en ;
  dcterms:modified "2026-06-07T15:30:29.598855Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7985-1
  a curric:KeyLearningPoint ;
  rdfs:label """A light microscope can be used to observe plant cells in different stages of mitosis
  (e.g. from onion root tip)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.598859Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7985-2
  a curric:KeyLearningPoint ;
  rdfs:label "The parts of a light microscope and their functions."@en ;
  dcterms:modified "2026-06-07T15:30:29.598863Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7985-3
  a curric:KeyLearningPoint ;
  rdfs:label """The sequence of steps for setting up a light microscope to observe cells, including
  changing the magnification & focus."""@en ;
  dcterms:modified "2026-06-07T15:30:29.598868Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7985-4
  a curric:KeyLearningPoint ;
  rdfs:label """Explaining observations from microscopy using ideas about what happens during stages
  of the cell cycle."""@en ;
  dcterms:modified "2026-06-07T15:30:29.598874Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8006-1
  a curric:KeyLearningPoint ;
  rdfs:label """Hormones can be used as a contraceptive to prevent pregnancy by disrupting the
  menstrual cycle."""@en ;
  dcterms:modified "2026-06-07T15:30:29.598943Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8006-2
  a curric:KeyLearningPoint ;
  rdfs:label """Some oral hormone contraceptive pills prevent ovulation. If no egg is released,
  fertilisation cannot take place."""@en ;
  dcterms:modified "2026-06-07T15:30:29.598947Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8006-3
  a curric:KeyLearningPoint ;
  rdfs:label """Reasons why hormone pills may not be 100% effective (e.g. missing/late dose, taking
  after ovulation)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.598951Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8006-4
  a curric:KeyLearningPoint ;
  rdfs:label """Non-hormonal contraceptives act as a barrier to prevent sperm from reaching the egg,
  so fertilisation cannot occur."""@en ;
  dcterms:modified "2026-06-07T15:30:29.598956Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8006-5
  a curric:KeyLearningPoint ;
  rdfs:label """Evaluating benefits and risks of hormonal and non-hormonal (barrier) methods of
  contraception (including STIs)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.598960Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7988-1
  a curric:KeyLearningPoint ;
  rdfs:label """Most cells in multicellular organisms are specialised – they have structures that
  are adapted for the jobs the cells."""@en ;
  dcterms:modified "2026-06-07T15:30:29.598964Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7988-2
  a curric:KeyLearningPoint ;
  rdfs:label """Multicellular organisms grow (make new cells by mitosis) and develop (make
  specialised cells to form tissues/organs)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.598968Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7988-3
  a curric:KeyLearningPoint ;
  rdfs:label "Unspecialised cells become specialised through a process called differentiation."@en ;
  dcterms:modified "2026-06-07T15:30:29.598972Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7988-4
  a curric:KeyLearningPoint ;
  rdfs:label """During differentiation, particular genes in the cell’s genome are switched off or
  on."""@en ;
  dcterms:modified "2026-06-07T15:30:29.598977Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7988-5
  a curric:KeyLearningPoint ;
  rdfs:label """Specialised cells only use particular genes, so only make the proteins needed for
  the job they are adapted to do."""@en ;
  dcterms:modified "2026-06-07T15:30:29.598997Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20369-1
  a curric:KeyLearningPoint ;
  rdfs:label """Group 1 elements are very reactive and their reactivity increases down the
  group."""@en ;
  dcterms:modified "2026-06-07T15:30:29.599148Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20369-2
  a curric:KeyLearningPoint ;
  rdfs:label "Moving down Group 1 elements, atomic mass, density and melting points increase."@en ;
  dcterms:modified "2026-06-07T15:30:29.599153Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20369-3
  a curric:KeyLearningPoint ;
  rdfs:label """In chemical reactions, atoms of Group 1 elements lose one outer electron leaving
  full electron shells."""@en ;
  dcterms:modified "2026-06-07T15:30:29.599157Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20369-4
  a curric:KeyLearningPoint ;
  rdfs:label """Going down Group 1, the outer electron of each element is attracted to the atomic
  nucleus with less force."""@en ;
  dcterms:modified "2026-06-07T15:30:29.599161Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20369-5
  a curric:KeyLearningPoint ;
  rdfs:label "Group 1 metals react with water to produce alkaline solutions."@en ;
  dcterms:modified "2026-06-07T15:30:29.599167Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9658-1
  a curric:KeyLearningPoint ;
  rdfs:label """In a chemical reaction, the atoms in reactants are rearranged and are the same atoms
  that are in the products."""@en ;
  dcterms:modified "2026-06-07T15:30:29.599184Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9658-2
  a curric:KeyLearningPoint ;
  rdfs:label """A theoretical yield is calculated using the stoichiometry of a balanced equation &
  relevant mathematical relationships."""@en ;
  dcterms:modified "2026-06-07T15:30:29.599190Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9658-3
  a curric:KeyLearningPoint ;
  rdfs:label """The number of moles of limiting reactant available is used to calculate the
  theoretical yield of a reaction."""@en ;
  dcterms:modified "2026-06-07T15:30:29.599194Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9658-4
  a curric:KeyLearningPoint ;
  rdfs:label """If a reactant is added in excess, not all of it will react and some will be found in
  the final product mixture."""@en ;
  dcterms:modified "2026-06-07T15:30:29.599199Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9658-5
  a curric:KeyLearningPoint ;
  rdfs:label """A limiting reactant is one that restricts the amount of product that can form from
  the available particles."""@en ;
  dcterms:modified "2026-06-07T15:30:29.599203Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8398-1
  a curric:KeyLearningPoint ;
  rdfs:label """Early volcanic activity is thought to have made an atmosphere of carbon dioxide and
  nitrogen billions of years ago."""@en ;
  dcterms:modified "2026-06-07T15:30:29.599669Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8398-2
  a curric:KeyLearningPoint ;
  rdfs:label """Carbon dioxide can dissolve in oceans and form carbonates that, over millions of
  years, can form sedimentary rock."""@en ;
  dcterms:modified "2026-06-07T15:30:29.599673Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8398-3
  a curric:KeyLearningPoint ;
  rdfs:label """The amount of carbon dioxide was reduced by the formation of sedimentary rocks and
  photosynthesis by algae and plants."""@en ;
  dcterms:modified "2026-06-07T15:30:29.599677Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8398-4
  a curric:KeyLearningPoint ;
  rdfs:label """Algae and plants produced the oxygen that is now in the atmosphere by
  photosynthesis."""@en ;
  dcterms:modified "2026-06-07T15:30:29.599681Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8398-5
  a curric:KeyLearningPoint ;
  rdfs:label """Phytoplankton in the oceans are responsible for roughly half of all oxygen
  production that takes place today."""@en ;
  dcterms:modified "2026-06-07T15:30:29.599686Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8341-1
  a curric:KeyLearningPoint ;
  rdfs:label """In pure metals, ions are arranged in a regular structure with delocalised electrons
  between them"""@en ;
  dcterms:modified "2026-06-07T15:30:29.599690Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8341-2
  a curric:KeyLearningPoint ;
  rdfs:label """If a metal is stretched or forced out of shape, its ions are able to move position
  without the metallic bonds breaking"""@en ;
  dcterms:modified "2026-06-07T15:30:29.599694Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8341-3
  a curric:KeyLearningPoint ;
  rdfs:label """An alloy is a mixture of different metal elements or of metals with non metal
  elements (i.e. carbon)"""@en ;
  dcterms:modified "2026-06-07T15:30:29.599698Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8341-4
  a curric:KeyLearningPoint ;
  rdfs:label """Ions of different metal elements may be different sizes and have different
  electrical charges"""@en ;
  dcterms:modified "2026-06-07T15:30:29.599702Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8341-5
  a curric:KeyLearningPoint ;
  rdfs:label """The structure of an alloy is not as regular as a pure metal and this affects its
  properties"""@en ;
  dcterms:modified "2026-06-07T15:30:29.599708Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28152-1
  a curric:KeyLearningPoint ;
  rdfs:label """Data collected during a titration allows chemists to determine a solution’s unknown
  concentration."""@en ;
  dcterms:modified "2026-06-07T15:30:29.599713Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28152-2
  a curric:KeyLearningPoint ;
  rdfs:label """Concordant titres should be used when calculating a mean volume used to neutralise a
  solution."""@en ;
  dcterms:modified "2026-06-07T15:30:29.599717Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28152-3
  a curric:KeyLearningPoint ;
  rdfs:label """The coefficients in a balanced equation indicate the stoichiometry (i.e. molar
  ratio) between substances in a reaction."""@en ;
  dcterms:modified "2026-06-07T15:30:29.599721Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28152-4
  a curric:KeyLearningPoint ;
  rdfs:label """The concentration of an unknown solution if found using the relationship:
  concentration = moles ÷ volume (in dm³)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.599725Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9933-1
  a curric:KeyLearningPoint ;
  rdfs:label "When an object moves upwards, work is done against the gravitational force."@en ;
  dcterms:modified "2026-06-07T15:30:29.600364Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9933-2
  a curric:KeyLearningPoint ;
  rdfs:label """The gravitational force acting on an object does work to speed it up when it is
  falling."""@en ;
  dcterms:modified "2026-06-07T15:30:29.600368Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9933-3
  a curric:KeyLearningPoint ;
  rdfs:label "Weight = mass x gravitational field strength, W = mg"@en ;
  dcterms:modified "2026-06-07T15:30:29.600372Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9933-4
  a curric:KeyLearningPoint ;
  rdfs:label """Gravitational potential energy of an object = mass × gravitational field strength ×
  height"""@en ;
  dcterms:modified "2026-06-07T15:30:29.600376Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6289-1
  a curric:KeyLearningPoint ;
  rdfs:label "Organisms can now be classified using evidence from sequencing their genes"@en ;
  dcterms:modified "2026-06-07T15:30:29.600420Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6289-2
  a curric:KeyLearningPoint ;
  rdfs:label "Comparing gene sequences provides evidence of evolutionary relationships"@en ;
  dcterms:modified "2026-06-07T15:30:29.600424Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6289-3
  a curric:KeyLearningPoint ;
  rdfs:label """Sometimes organisms are reclassified into a different group if new evidence is
  discovered"""@en ;
  dcterms:modified "2026-06-07T15:30:29.600428Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6287-1
  a curric:KeyLearningPoint ;
  rdfs:label """Organisms are classified into groups within larger groups, from species up to
  kingdoms and domains"""@en ;
  dcterms:modified "2026-06-07T15:30:29.600432Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6287-2
  a curric:KeyLearningPoint ;
  rdfs:label """There are domains of eukaryotes (animals, plants, fungi and protists), bacteria and
  archaea (both prokaryotic)"""@en ;
  dcterms:modified "2026-06-07T15:30:29.600436Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6287-3
  a curric:KeyLearningPoint ;
  rdfs:label """Organisms can be classified using evidence of their macroscopic features
  (phenotype)"""@en ;
  dcterms:modified "2026-06-07T15:30:29.600440Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6287-4
  a curric:KeyLearningPoint ;
  rdfs:label """Organisms can be classified using evidence of their and microscopic cell
  structures"""@en ;
  dcterms:modified "2026-06-07T15:30:29.600444Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6408-1
  a curric:KeyLearningPoint ;
  rdfs:label """An example of a mutation in bacteria that could be helpful to humans (e.g. ability
  to digest man-made waste)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.600448Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6408-2
  a curric:KeyLearningPoint ;
  rdfs:label """An example of a mutation in bacteria that is dangerous to humans (e.g. antibiotic
  resistance)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.600455Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6408-3
  a curric:KeyLearningPoint ;
  rdfs:label """Explanations of examples at the genetic level using ideas about mutation, natural
  selection and asexual reproduction."""@en ;
  dcterms:modified "2026-06-07T15:30:29.600459Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6408-4
  a curric:KeyLearningPoint ;
  rdfs:label """Explanations to include why advantageous genetic variants become more common in the
  bacteria over generations."""@en ;
  dcterms:modified "2026-06-07T15:30:29.600465Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5550-1
  a curric:KeyLearningPoint ;
  rdfs:label """Organisms are made of carbohydrates, proteins and lipids (including fats), plus
  water and minerals."""@en ;
  dcterms:modified "2026-06-07T15:30:29.600470Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5550-2
  a curric:KeyLearningPoint ;
  rdfs:label """Carbohydrates, proteins and lipids are used to build cell structures including
  membranes and organelles."""@en ;
  dcterms:modified "2026-06-07T15:30:29.600474Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5550-3
  a curric:KeyLearningPoint ;
  rdfs:label "Carbohydrates are polymers made of sugars."@en ;
  dcterms:modified "2026-06-07T15:30:29.600478Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5550-4
  a curric:KeyLearningPoint ;
  rdfs:label "Proteins are polymers made of amino acids."@en ;
  dcterms:modified "2026-06-07T15:30:29.600482Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5550-5
  a curric:KeyLearningPoint ;
  rdfs:label "Lipids are molecules made of fatty acids and glycerol."@en ;
  dcterms:modified "2026-06-07T15:30:29.600486Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9711-1
  a curric:KeyLearningPoint ;
  rdfs:label "Hazard symbols provide vital safety information about chemical substances."@en ;
  dcterms:modified "2026-06-07T15:30:29.600513Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9711-2
  a curric:KeyLearningPoint ;
  rdfs:label "Correct identification of hazard symbols is crucial for laboratory safety."@en ;
  dcterms:modified "2026-06-07T15:30:29.600517Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9711-3
  a curric:KeyLearningPoint ;
  rdfs:label """Correctly choosing and using appropriate lab equipment is essential for conducting
  experiments safely and accurately."""@en ;
  dcterms:modified "2026-06-07T15:30:29.600521Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9711-4
  a curric:KeyLearningPoint ;
  rdfs:label """Risk assessments identify potential hazards & outline how to minimise risk; these
  can be general & specific precautions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.600525Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9711-5
  a curric:KeyLearningPoint ;
  rdfs:label """Safety protocols, like wearing eye protection and ensuring good ventilation, are
  essential when working with hazards."""@en ;
  dcterms:modified "2026-06-07T15:30:29.600529Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4904-1
  a curric:KeyLearningPoint ;
  rdfs:label "Energy is measured in joules (J)."@en ;
  dcterms:modified "2026-06-07T15:30:29.600550Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4904-2
  a curric:KeyLearningPoint ;
  rdfs:label """Doubling the mass of a moving object doubles the energy it has in its
  kinetic store."""@en ;
  dcterms:modified "2026-06-07T15:30:29.600554Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4904-3
  a curric:KeyLearningPoint ;
  rdfs:label """Doubling the speed of an object increases the energy it has in its kinetic store by
  four times."""@en ;
  dcterms:modified "2026-06-07T15:30:29.600558Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4904-4
  a curric:KeyLearningPoint ;
  rdfs:label """The energy an object has in its kinetic store of energy is found using the equation
  Ek = ½ mv²."""@en ;
  dcterms:modified "2026-06-07T15:30:29.600562Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5093-1
  a curric:KeyLearningPoint ;
  rdfs:label """Electromagnetic waves/radiation are transverse oscillations (ripples) in electric
  and magnetic fields."""@en ;
  dcterms:modified "2026-06-07T15:30:29.600566Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5093-2
  a curric:KeyLearningPoint ;
  rdfs:label """The visible spectrum shows the range of different frequencies (colours) of visible
  light waves (visible EM radiation)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.600570Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5093-3
  a curric:KeyLearningPoint ;
  rdfs:label """In the visible spectrum, violet light has the highest frequency and refracts more
  than red."""@en ;
  dcterms:modified "2026-06-07T15:30:29.600576Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5093-4
  a curric:KeyLearningPoint ;
  rdfs:label """The EM spectrum shows the range of frequencies that EM waves can have (radio,
  microwave, IR, visible, UV, X-ray, gamma)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.600580Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5093-5
  a curric:KeyLearningPoint ;
  rdfs:label """EM waves in different frequency ranges have the same speed in air, but interact
  differently with different materials."""@en ;
  dcterms:modified "2026-06-07T15:30:29.600584Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9900-1
  a curric:KeyLearningPoint ;
  rdfs:label "Acceleration is equal to the amount that velocity changes in one second."@en ;
  dcterms:modified "2026-06-07T15:30:29.600588Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9900-2
  a curric:KeyLearningPoint ;
  rdfs:label "Acceleration is the rate of change of velocity."@en ;
  dcterms:modified "2026-06-07T15:30:29.600592Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9900-3
  a curric:KeyLearningPoint ;
  rdfs:label "Average acceleration = change of velocity/time [a = (v-u)/t]"@en ;
  dcterms:modified "2026-06-07T15:30:29.600597Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9900-4
  a curric:KeyLearningPoint ;
  rdfs:label "An object that is slowing down is decelerating."@en ;
  dcterms:modified "2026-06-07T15:30:29.600600Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9900-5
  a curric:KeyLearningPoint ;
  rdfs:label "An object that is decelerating has a negative acceleration."@en ;
  dcterms:modified "2026-06-07T15:30:29.600604Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5598-1
  a curric:KeyLearningPoint ;
  rdfs:label """Cellular respiration happens continuously in all living organisms to transfer the
  energy needed for life processes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.601056Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5598-2
  a curric:KeyLearningPoint ;
  rdfs:label """Cellular respiration is an exothermic chemical process that uses glucose as
  a fuel."""@en ;
  dcterms:modified "2026-06-07T15:30:29.601062Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5598-3
  a curric:KeyLearningPoint ;
  rdfs:label """Word equation and balanced symbol equation summarises the reactants and products of
  aerobic cellular respiration."""@en ;
  dcterms:modified "2026-06-07T15:30:29.601067Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5598-4
  a curric:KeyLearningPoint ;
  rdfs:label """Aerobic cellular respiration takes place in the mitochondria of eukaryotic
  cells."""@en ;
  dcterms:modified "2026-06-07T15:30:29.601071Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5598-5
  a curric:KeyLearningPoint ;
  rdfs:label """Aerobic cellular respiration takes place in the cytoplasm of prokaryotic cells,
  which do not have mitochondria."""@en ;
  dcterms:modified "2026-06-07T15:30:29.601075Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8417-1
  a curric:KeyLearningPoint ;
  rdfs:label "Corrosion is a general process of degradation of metals through various causes."@en ;
  dcterms:modified "2026-06-07T15:30:29.601102Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8417-2
  a curric:KeyLearningPoint ;
  rdfs:label """Rusting is a specific type of corrosion, affecting iron in the presence of air and
  moisture."""@en ;
  dcterms:modified "2026-06-07T15:30:29.601106Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8417-3
  a curric:KeyLearningPoint ;
  rdfs:label """A metal oxide layer can protect the underlying metal if the oxide forms a physical
  barrier."""@en ;
  dcterms:modified "2026-06-07T15:30:29.601110Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8417-4
  a curric:KeyLearningPoint ;
  rdfs:label """Some coatings are reactive and contain a more reactive metal to provide sacrificial
  protection, e.g. zinc to galvanise."""@en ;
  dcterms:modified "2026-06-07T15:30:29.601115Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8417-5
  a curric:KeyLearningPoint ;
  rdfs:label """Electroplating can be used to improve the appearance and/or the resistance to
  corrosion of metal objects."""@en ;
  dcterms:modified "2026-06-07T15:30:29.601119Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9642-1
  a curric:KeyLearningPoint ;
  rdfs:label """Crystallisation is a technique that is used to separate a soluble solute from a
  solution."""@en ;
  dcterms:modified "2026-06-07T15:30:29.601123Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9642-2
  a curric:KeyLearningPoint ;
  rdfs:label """Crystallisation involves the formation of a saturated solution and temperature
  differences."""@en ;
  dcterms:modified "2026-06-07T15:30:29.601127Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9642-3
  a curric:KeyLearningPoint ;
  rdfs:label "Crystallisation results in the loss of the solvent to the surroundings."@en ;
  dcterms:modified "2026-06-07T15:30:29.601131Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9665-1
  a curric:KeyLearningPoint ;
  rdfs:label """Equal amounts in moles of gases occupy the same volume under the same conditions of
  temperature and pressure."""@en ;
  dcterms:modified "2026-06-07T15:30:29.601135Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9665-2
  a curric:KeyLearningPoint ;
  rdfs:label """The volume of one mole of any gas at room temperature and pressure (20℃ and 1
  atmosphere pressure) is 24 dm³."""@en ;
  dcterms:modified "2026-06-07T15:30:29.601142Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9665-3
  a curric:KeyLearningPoint ;
  rdfs:label """The volumes of gaseous reactants and products can be calculated from the balanced
  equation for the reaction."""@en ;
  dcterms:modified "2026-06-07T15:30:29.601146Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9665-4
  a curric:KeyLearningPoint ;
  rdfs:label """If moles of gas are known, its density can be calculated using molar gas volume and
  the relationship mass = RFM x moles."""@en ;
  dcterms:modified "2026-06-07T15:30:29.601150Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8886-1
  a curric:KeyLearningPoint ;
  rdfs:label """One type of fuel cell contains hydrogen that reacts with oxygen from the air to
  produce a voltage."""@en ;
  dcterms:modified "2026-06-07T15:30:29.601154Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8886-2
  a curric:KeyLearningPoint ;
  rdfs:label """Hydrogen used in fuel cells can be extracted from fossil fuels or produced by
  electrolysis powered by the National Grid."""@en ;
  dcterms:modified "2026-06-07T15:30:29.601159Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8886-3
  a curric:KeyLearningPoint ;
  rdfs:label "Other fuel cells exist, but have other products than just water."@en ;
  dcterms:modified "2026-06-07T15:30:29.601163Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8886-4
  a curric:KeyLearningPoint ;
  rdfs:label """There are many strengths and weaknesses of fuel cells, and these should be compared
  against other energy sources."""@en ;
  dcterms:modified "2026-06-07T15:30:29.601166Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9162-1
  a curric:KeyLearningPoint ;
  rdfs:label """Eukaryotic cells store their genetic material in a nucleus and have membrane bound
  sub-cellular structures."""@en ;
  dcterms:modified "2026-06-07T15:30:29.601170Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9162-2
  a curric:KeyLearningPoint ;
  rdfs:label "Eukaryotic organisms can be unicellular or multicellular."@en ;
  dcterms:modified "2026-06-07T15:30:29.601174Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9162-3
  a curric:KeyLearningPoint ;
  rdfs:label "Examples of eukaryotic and prokaryotic organisms."@en ;
  dcterms:modified "2026-06-07T15:30:29.601179Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9162-4
  a curric:KeyLearningPoint ;
  rdfs:label """Prokaryotic cells do not have membrane bound sub-cellular structures including a
  nucleus; DNA is floating in cytoplasm."""@en ;
  dcterms:modified "2026-06-07T15:30:29.601183Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9162-5
  a curric:KeyLearningPoint ;
  rdfs:label "Prokaryotic organisms are unicellular."@en ;
  dcterms:modified "2026-06-07T15:30:29.601187Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5599-1
  a curric:KeyLearningPoint ;
  rdfs:label """Word and balanced symbol equations for anaerobic cellular respiration in humans, and
  conditions in which it occurs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.601454Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5599-2
  a curric:KeyLearningPoint ;
  rdfs:label """Word and symbol equations for anaerobic respiration in plants and micro-organisms,
  and conditions in which it occurs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.601458Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5599-3
  a curric:KeyLearningPoint ;
  rdfs:label """Anaerobic cellular respiration takes place only in the cell cytoplasm and does not
  involve mitochondria."""@en ;
  dcterms:modified "2026-06-07T15:30:29.601465Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5599-4
  a curric:KeyLearningPoint ;
  rdfs:label """Anaerobic cellular respiration transfers less energy than aerobic cellular
  respiration, but more quickly."""@en ;
  dcterms:modified "2026-06-07T15:30:29.601469Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5599-5
  a curric:KeyLearningPoint ;
  rdfs:label "Uses of anaerobic cellular respiration (fermentation) in yeast."@en ;
  dcterms:modified "2026-06-07T15:30:29.601473Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5572-1
  a curric:KeyLearningPoint ;
  rdfs:label "If conditions in the body change too much, this can be dangerous to our health."@en ;
  dcterms:modified "2026-06-07T15:30:29.601521Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5572-2
  a curric:KeyLearningPoint ;
  rdfs:label "Glucose travels in the blood and is delivered to cells for respiration."@en ;
  dcterms:modified "2026-06-07T15:30:29.601525Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5572-3
  a curric:KeyLearningPoint ;
  rdfs:label "The hormones insulin and glucagon help to keep human blood sugar level constant."@en ;
  dcterms:modified "2026-06-07T15:30:29.601542Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5572-4
  a curric:KeyLearningPoint ;
  rdfs:label """The pancreas secretes insulin when blood sugar level is too high; the liver absorbs
  glucose and coverts it to glycogen."""@en ;
  dcterms:modified "2026-06-07T15:30:29.601547Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5572-5
  a curric:KeyLearningPoint ;
  rdfs:label """The pancreas secretes glucagon when blood sugar level is too low; the liver converts
  glycogen into glucose in the blood."""@en ;
  dcterms:modified "2026-06-07T15:30:29.601551Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9187-1
  a curric:KeyLearningPoint ;
  rdfs:label "Plant health can be affected by mineral deficiencies and pathogens."@en ;
  dcterms:modified "2026-06-07T15:30:29.601556Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9187-2
  a curric:KeyLearningPoint ;
  rdfs:label "Tobacco mosaic virus is an example of a disease in plants caused by a virus."@en ;
  dcterms:modified "2026-06-07T15:30:29.601562Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9187-3
  a curric:KeyLearningPoint ;
  rdfs:label "Rose black spot is an example of a disease in plants caused by a fungus."@en ;
  dcterms:modified "2026-06-07T15:30:29.601567Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9187-4
  a curric:KeyLearningPoint ;
  rdfs:label """Ways in which plant diseases can be spread, and ways in which the spread can be
  reduced."""@en ;
  dcterms:modified "2026-06-07T15:30:29.601571Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9187-5
  a curric:KeyLearningPoint ;
  rdfs:label "Impacts of plant diseases, including on biodiversity and human food security."@en ;
  dcterms:modified "2026-06-07T15:30:29.601575Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8319-1
  a curric:KeyLearningPoint ;
  rdfs:label """Group 1 elements are very reactive and their reactivity increases down the
  group."""@en ;
  dcterms:modified "2026-06-07T15:30:29.601640Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8319-2
  a curric:KeyLearningPoint ;
  rdfs:label "Moving down Group 1 elements, atomic mass, density and melting points increase."@en ;
  dcterms:modified "2026-06-07T15:30:29.601647Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8319-3
  a curric:KeyLearningPoint ;
  rdfs:label """In chemical reactions, atoms of Group 1 elements lose one outer electron leaving
  full electron shells."""@en ;
  dcterms:modified "2026-06-07T15:30:29.601651Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8319-4
  a curric:KeyLearningPoint ;
  rdfs:label """Going down Group 1, the outer electron of each element is attracted to the atomic
  nucleus with less force."""@en ;
  dcterms:modified "2026-06-07T15:30:29.601656Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8319-5
  a curric:KeyLearningPoint ;
  rdfs:label "Group 1 metals react with water to produce alkaline solutions."@en ;
  dcterms:modified "2026-06-07T15:30:29.601660Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9931-1
  a curric:KeyLearningPoint ;
  rdfs:label "Energy is measured in joules (J)."@en ;
  dcterms:modified "2026-06-07T15:30:29.601687Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9931-2
  a curric:KeyLearningPoint ;
  rdfs:label """Doubling the mass of a moving object doubles the energy it has in its
  kinetic store."""@en ;
  dcterms:modified "2026-06-07T15:30:29.601692Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9931-3
  a curric:KeyLearningPoint ;
  rdfs:label """Doubling the speed of an object increases the energy it has in its kinetic store by
  four times."""@en ;
  dcterms:modified "2026-06-07T15:30:29.601696Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9931-4
  a curric:KeyLearningPoint ;
  rdfs:label """The energy an object has in its kinetic store of energy is found using the equation
  E = ½ mv²."""@en ;
  dcterms:modified "2026-06-07T15:30:29.601700Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20138-1
  a curric:KeyLearningPoint ;
  rdfs:label "Chemical amounts are measured in moles (mol)."@en ;
  dcterms:modified "2026-06-07T15:30:29.602192Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20138-2
  a curric:KeyLearningPoint ;
  rdfs:label """One mole of particles of a substance is defined as the Avogadro constant number of
  particles."""@en ;
  dcterms:modified "2026-06-07T15:30:29.602196Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20138-3
  a curric:KeyLearningPoint ;
  rdfs:label """The number of particles (atoms, ions, molecules etc.) in one mole of a substance is
  always the same."""@en ;
  dcterms:modified "2026-06-07T15:30:29.602200Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20138-4
  a curric:KeyLearningPoint ;
  rdfs:label """Use of Avogadro's number to calculate the number of particles of substance when
  number of moles is known and vice versa."""@en ;
  dcterms:modified "2026-06-07T15:30:29.602204Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20138-5
  a curric:KeyLearningPoint ;
  rdfs:label """The mass of one mole of a monatomic element is equal to the relative atomic mass of
  that element measured in grams."""@en ;
  dcterms:modified "2026-06-07T15:30:29.602209Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6387-1
  a curric:KeyLearningPoint ;
  rdfs:label "Benefits of high biodiversity, including ecosystem services and food security."@en ;
  dcterms:modified "2026-06-07T15:30:29.602233Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6387-2
  a curric:KeyLearningPoint ;
  rdfs:label """Humans can interact positively with ecosystems to prevent and reduce biodiversity
  loss."""@en ;
  dcterms:modified "2026-06-07T15:30:29.602237Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6387-3
  a curric:KeyLearningPoint ;
  rdfs:label """Resources can be used sustainably (e.g. at a rate at which they can be
  replaced)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.602241Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6387-4
  a curric:KeyLearningPoint ;
  rdfs:label """A range of conservation measures can be taken to protect biodiversity at the
  species, ecosystem and genetic levels."""@en ;
  dcterms:modified "2026-06-07T15:30:29.602248Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6387-5
  a curric:KeyLearningPoint ;
  rdfs:label "Conservation efforts range from very local actions to international ones."@en ;
  dcterms:modified "2026-06-07T15:30:29.602252Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9164-1
  a curric:KeyLearningPoint ;
  rdfs:label "Most animals and plants are made up of millions or billions of cells."@en ;
  dcterms:modified "2026-06-07T15:30:29.602627Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9164-2
  a curric:KeyLearningPoint ;
  rdfs:label "Cells are usually too small to see with the unaided eye."@en ;
  dcterms:modified "2026-06-07T15:30:29.602631Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9164-3
  a curric:KeyLearningPoint ;
  rdfs:label """Comparison of the sizes of eukaryotic and prokaryotic cells, and cell structures, in
  micrometres."""@en ;
  dcterms:modified "2026-06-07T15:30:29.602635Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20079-1
  a curric:KeyLearningPoint ;
  rdfs:label "The velocity of an object is its speed in a given direction."@en ;
  dcterms:modified "2026-06-07T15:30:29.602640Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20079-2
  a curric:KeyLearningPoint ;
  rdfs:label """The displacement of an object is the distance it travels in a particular
  direction."""@en ;
  dcterms:modified "2026-06-07T15:30:29.602644Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20079-3
  a curric:KeyLearningPoint ;
  rdfs:label "Displacement and velocity are both vector quantities."@en ;
  dcterms:modified "2026-06-07T15:30:29.602648Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20079-4
  a curric:KeyLearningPoint ;
  rdfs:label """Velocity has a positive value in one direction and negative value in the opposite
  direction."""@en ;
  dcterms:modified "2026-06-07T15:30:29.602654Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27970-1
  a curric:KeyLearningPoint ;
  rdfs:label """Word and balanced symbol equations for anaerobic cellular respiration in humans, and
  conditions in which it occurs"""@en ;
  dcterms:modified "2026-06-07T15:30:29.603034Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27970-2
  a curric:KeyLearningPoint ;
  rdfs:label """Word and symbol equations for anaerobic respiration in plants and micro-organisms,
  and conditions in which it occurs"""@en ;
  dcterms:modified "2026-06-07T15:30:29.603038Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27970-3
  a curric:KeyLearningPoint ;
  rdfs:label """Anaerobic cellular respiration takes place only in the cell cytoplasm and does not
  involve mitochondria"""@en ;
  dcterms:modified "2026-06-07T15:30:29.603042Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27970-4
  a curric:KeyLearningPoint ;
  rdfs:label """Anaerobic cellular respiration provides less ATP (so less energy) than aerobic
  cellular respiration, but more quickly"""@en ;
  dcterms:modified "2026-06-07T15:30:29.603047Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27970-5
  a curric:KeyLearningPoint ;
  rdfs:label "Uses of anaerobic cellular respiration (fermentation) in yeast"@en ;
  dcterms:modified "2026-06-07T15:30:29.603051Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27585-1
  a curric:KeyLearningPoint ;
  rdfs:label """Growing food helps feed the increasing human population, but can have negative
  impacts on ecosystems and biodiversity."""@en ;
  dcterms:modified "2026-06-07T15:30:29.603055Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27585-2
  a curric:KeyLearningPoint ;
  rdfs:label "The use of peat and destruction of peat bogs as an example of a negative impact."@en ;
  dcterms:modified "2026-06-07T15:30:29.603062Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27585-3
  a curric:KeyLearningPoint ;
  rdfs:label "Eutrophication as an example of a negative impact."@en ;
  dcterms:modified "2026-06-07T15:30:29.603066Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27585-4
  a curric:KeyLearningPoint ;
  rdfs:label "The introduction of non-indigenous species as an example of a negative impact."@en ;
  dcterms:modified "2026-06-07T15:30:29.603070Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27585-5
  a curric:KeyLearningPoint ;
  rdfs:label "Ways of mitigating some of these negative impacts."@en ;
  dcterms:modified "2026-06-07T15:30:29.603074Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28975-1
  a curric:KeyLearningPoint ;
  rdfs:label """Predictions about effects of factors such as temperature and availability of water
  and CO2 on rate of photosynthesis."""@en ;
  dcterms:modified "2026-06-07T15:30:29.603079Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28975-2
  a curric:KeyLearningPoint ;
  rdfs:label """Photosynthesis in producers creates the biomass for food chains, which all consumers
  (including humans) depend on."""@en ;
  dcterms:modified "2026-06-07T15:30:29.603083Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28975-3
  a curric:KeyLearningPoint ;
  rdfs:label """Climate change and global warming affect the temperature and the availability of
  water."""@en ;
  dcterms:modified "2026-06-07T15:30:29.603087Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28975-4
  a curric:KeyLearningPoint ;
  rdfs:label """Rising temperatures, droughts and floods will reduce the yields of crop plants that
  feed farm animals and humans."""@en ;
  dcterms:modified "2026-06-07T15:30:29.603091Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28975-5
  a curric:KeyLearningPoint ;
  rdfs:label """Different regions of the world and the people living there will be affected in
  different ways."""@en ;
  dcterms:modified "2026-06-07T15:30:29.603095Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9690-1
  a curric:KeyLearningPoint ;
  rdfs:label """The energy needed to break bonds and the energy released when bonds are formed can
  be calculated from bond energies."""@en ;
  dcterms:modified "2026-06-07T15:30:29.603457Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9690-2
  a curric:KeyLearningPoint ;
  rdfs:label """The difference between the energy needed to break bonds and the energy released is
  the overall energy change."""@en ;
  dcterms:modified "2026-06-07T15:30:29.603461Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20356-1
  a curric:KeyLearningPoint ;
  rdfs:label """In a chemical reaction, the atoms in reactants are rearranged and are the same atoms
  that are in the products."""@en ;
  dcterms:modified "2026-06-07T15:30:29.603465Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20356-2
  a curric:KeyLearningPoint ;
  rdfs:label """A theoretical yield is calculated using the stoichiometry of a balanced equation &
  relevant mathematical relationships."""@en ;
  dcterms:modified "2026-06-07T15:30:29.603469Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20356-3
  a curric:KeyLearningPoint ;
  rdfs:label """The number of moles of limiting reactant available is used to calculate the
  theoretical yield of a reaction."""@en ;
  dcterms:modified "2026-06-07T15:30:29.603476Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20356-4
  a curric:KeyLearningPoint ;
  rdfs:label """If a reactant is added excess, not all of it will react and some will be found in
  the final product mixture."""@en ;
  dcterms:modified "2026-06-07T15:30:29.603480Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20356-5
  a curric:KeyLearningPoint ;
  rdfs:label """A limiting reactant is one that restricts the amount of product that can form from
  the available particles."""@en ;
  dcterms:modified "2026-06-07T15:30:29.603484Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20008-1
  a curric:KeyLearningPoint ;
  rdfs:label """Energy is dissipated due to friction which causes particles to vibrate more quickly
  and heats up the surroundings."""@en ;
  dcterms:modified "2026-06-07T15:30:29.603956Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20008-2
  a curric:KeyLearningPoint ;
  rdfs:label """Energy is dissipated due to drag which causes particles in the surroundings to move
  more quickly."""@en ;
  dcterms:modified "2026-06-07T15:30:29.603960Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20008-3
  a curric:KeyLearningPoint ;
  rdfs:label "Efficiency = useful output energy transfer / total input energy transfer"@en ;
  dcterms:modified "2026-06-07T15:30:29.603964Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20008-4
  a curric:KeyLearningPoint ;
  rdfs:label "Efficiency = useful power output / total power input"@en ;
  dcterms:modified "2026-06-07T15:30:29.603969Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20008-5
  a curric:KeyLearningPoint ;
  rdfs:label "Efficiency can be increased by lubrication, bearings or wheels."@en ;
  dcterms:modified "2026-06-07T15:30:29.603973Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8320-1
  a curric:KeyLearningPoint ;
  rdfs:label """Group 7 elements are very reactive and their reactivity decreases down the
  group."""@en ;
  dcterms:modified "2026-06-07T15:30:29.604000Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8320-2
  a curric:KeyLearningPoint ;
  rdfs:label """Moving down Group 7 elements, atomic mass, density, and melting and boiling points
  increase."""@en ;
  dcterms:modified "2026-06-07T15:30:29.604004Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8320-3
  a curric:KeyLearningPoint ;
  rdfs:label """In chemical reactions, atoms of Group 7 elements gain one outer electron making just
  full electron shells."""@en ;
  dcterms:modified "2026-06-07T15:30:29.604008Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8320-4
  a curric:KeyLearningPoint ;
  rdfs:label """Going down Group 7, the force attracting an extra electron reduces with the distance
  of each shell from the nucleus."""@en ;
  dcterms:modified "2026-06-07T15:30:29.604015Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8320-5
  a curric:KeyLearningPoint ;
  rdfs:label "Halogens are elements, halides are salts."@en ;
  dcterms:modified "2026-06-07T15:30:29.604019Z"^^xsd:dateTime .

