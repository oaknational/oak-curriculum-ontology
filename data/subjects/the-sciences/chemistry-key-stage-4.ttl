  dcterms:modified "2026-06-09T00:46:04.306023Z"^^xsd:dateTime .

oakcurric:keyword-chemical-equation
  a curric:Keyword ;
  schema:name "chemical equation"@en ;
  schema:description """A chemical equation describes a reaction, indicating the reactants and
  products."""@en ;
  dcterms:modified "2026-06-09T00:46:04.306042Z"^^xsd:dateTime .

oakcurric:keyword-false-positive
  a curric:Keyword ;
