  schema:description "a compound consisting of two aluminum atoms and three oxygen atoms"@en ;
  dcterms:modified "2026-06-07T15:30:02.417042Z"^^xsd:dateTime .

oakcurric:keyword-bauxite
  a curric:Keyword ;
  schema:name "bauxite"@en ;
