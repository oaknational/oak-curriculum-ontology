  a curric:Keyword ;
  schema:name "parallax error"@en ;
  schema:description "A parallax error occurs when a measurement is not taken at eye-level."@en ;
  dcterms:modified "2026-06-09T00:46:04.339113Z"^^xsd:dateTime .

oakcurric:keyword-isotope
  a curric:Keyword ;
  schema:name "isotope"@en ;
  schema:description """An atom of an element with the same number of protons, but different mass
  numbers due to different numbers of neutrons."""@en ;
  dcterms:modified "2026-06-09T00:46:04.339120Z"^^xsd:dateTime .

oakcurric:keyword-atomic-weight
  a curric:Keyword ;
  schema:name "atomic weight"@en ;
  schema:description """The historical name for atomic mass, i.e. the ratio of the mass of an atom
  compared to a standard."""@en ;
  dcterms:modified "2026-06-09T00:46:04.339128Z"^^xsd:dateTime .

oakcurric:keyword-dmitri-mendeleev
  a curric:Keyword ;
  schema:name "Dmitri Mendeleev"@en ;
  schema:description "A scientist who devised the periodic table of elements."@en ;
  dcterms:modified "2026-06-09T00:46:04.339137Z"^^xsd:dateTime .

oakcurric:keyword-nanometre
  a curric:Keyword ;
  schema:name "nanometre"@en ;
  schema:description """A unit used to measure very small distances, equal to 10⁻⁹ metres or one
  billionth of a metre."""@en ;
  dcterms:modified "2026-06-09T00:46:04.339143Z"^^xsd:dateTime .

oakcurric:keyword-nanoparticle
  a curric:Keyword ;
  schema:name "nanoparticle"@en ;
  schema:description """A very small particle, typically ranging from 1 to 100 nanometres in
  size."""@en ;
  dcterms:modified "2026-06-09T00:46:04.339148Z"^^xsd:dateTime .

oakcurric:keyword-nanoparticulate
  a curric:Keyword ;
  schema:name "nanoparticulate"@en ;
  schema:description "A material composed of nanoparticles."@en ;
  dcterms:modified "2026-06-09T00:46:04.339154Z"^^xsd:dateTime .

oakcurric:keyword-allotrope
  a curric:Keyword ;
  schema:name "allotrope"@en ;
  schema:description """A different structural form of an element, e.g. graphite and diamond are
  allotropes of carbon."""@en ;
  dcterms:modified "2026-06-09T00:46:04.339160Z"^^xsd:dateTime .

oakcurric:keyword-delocalised
  a curric:Keyword ;
  schema:name "delocalised"@en ;
  schema:description """Particles are said to be delocalised when they are free to move through a
  structure (delocalised electrons can carry an electrical current)."""@en ;
  dcterms:modified "2026-06-09T00:46:04.339165Z"^^xsd:dateTime .

oakcurric:keyword-stationary-phase
  a curric:Keyword ;
  schema:name "stationary phase"@en ;
  schema:description """A surface along which the solvent (and any dissolved components) travels. It
  does not move during chromatography."""@en ;
  dcterms:modified "2026-06-09T00:46:04.339420Z"^^xsd:dateTime .

oakcurric:keyword-mobile-phase
  a curric:Keyword ;
  schema:name "mobile phase"@en ;
  schema:description """The movement of a solvent and any dissolved components of a sample along the
  stationary phase in chromatography."""@en ;
  dcterms:modified "2026-06-09T00:46:04.339428Z"^^xsd:dateTime .

oakcurric:keyword-thin-layer-chromatography
  a curric:Keyword ;
  schema:name "thin layer chromatography"@en ;
  schema:description """A type of chromatography that uses a thin layer of an inert substance spread
  over an unreactive flat surface as the stationary phase and a liquid state substance for
  the mobile phase."""@en ;
  dcterms:modified "2026-06-09T00:46:04.339434Z"^^xsd:dateTime .

oakcurric:keyword-gas-chromatography
  a curric:Keyword ;
  schema:name "gas chromatography"@en ;
  schema:description """A type of chromatography that uses an inert substance packed into a coiled
  tube as the stationary phase and an unreactive/inert gas as the mobile phase."""@en ;
  dcterms:modified "2026-06-09T00:46:04.339439Z"^^xsd:dateTime .

oakcurric:keyword-relative-atomic-mass-element
  a curric:Keyword ;
  schema:name "relative atomic mass (element)"@en ;
  schema:description """The relative atomic mass of an element is an average value that takes
  account of the abundance of the isotopes of the element."""@en ;
  dcterms:modified "2026-06-09T00:46:04.339450Z"^^xsd:dateTime .

oakcurric:keyword-reaction-profiles
  a curric:Keyword ;
  schema:name "reaction profiles"@en ;
  schema:description """Reaction profiles are diagrams that show the energy of the reactants and
  products in a chemical reaction."""@en ;
  dcterms:modified "2026-06-09T00:46:04.339459Z"^^xsd:dateTime .

oakcurric:keyword-buckminsterfullerene
  a curric:Keyword ;
  schema:name "Buckminsterfullerene"@en ;
  schema:description """A spherical fullerene composed of 60 carbon atoms (held together by covalent
  bonds). It is a very stable structure."""@en ;
  dcterms:modified "2026-06-09T00:46:04.339470Z"^^xsd:dateTime .

oakcurric:keyword-aluminium-oxide
  a curric:Keyword ;
  schema:name "aluminium oxide"@en ;
  schema:description "a compound consisting of two aluminum atoms and three oxygen atoms"@en ;
  dcterms:modified "2026-06-09T00:46:04.339478Z"^^xsd:dateTime .

oakcurric:keyword-bauxite
  a curric:Keyword ;
  schema:name "bauxite"@en ;
  schema:description "a sedimentary rock with a high aluminium content"@en ;
  dcterms:modified "2026-06-09T00:46:04.339484Z"^^xsd:dateTime .

oakcurric:keyword-cryolite
  a curric:Keyword ;
  schema:name "cryolite"@en ;
  schema:description "a compound used in the smelting of aluminium to lower the melting point"@en ;
  dcterms:modified "2026-06-09T00:46:04.339489Z"^^xsd:dateTime .

oakcurric:keyword-physical-change
  a curric:Keyword ;
  schema:name "physical change"@en ;
  schema:description """A change in which no new substances are formed, such as a change in state,
  e.g. melting."""@en ;
  dcterms:modified "2026-06-09T00:46:04.339495Z"^^xsd:dateTime .

oakcurric:keyword-chemical-change
  a curric:Keyword ;
  schema:name "chemical change"@en ;
  schema:description """Occurs when a reaction takes place and atoms or ions in the reactants are
  rearranged to make new products/substances."""@en ;
  dcterms:modified "2026-06-09T00:46:04.339500Z"^^xsd:dateTime .

oakcurric:keyword-limitation-of-a-model
  a curric:Keyword ;
  schema:name "limitation of a model"@en ;
  schema:description """A point at which we cannot use the model to help us explain a scientific
  phenomena."""@en ;
  dcterms:modified "2026-06-09T00:46:04.339506Z"^^xsd:dateTime .

oakcurric:keyword-balanced-equation
  a curric:Keyword ;
  schema:name "balanced equation"@en ;
  schema:description """This describes a reaction using a symbol equation with coefficients which
  ensure there are equal numbers of atoms of each element on both sides of the symbol
  equation."""@en ;
  dcterms:modified "2026-06-09T00:46:04.339711Z"^^xsd:dateTime .

oakcurric:keyword-life-cycle-assessment
  a curric:Keyword ;
  schema:name "life cycle assessment"@en ;
  schema:description """A life cycle assessment (LCA) measures the environmental impact of a product
  throughout its manufacture, use and disposal."""@en ;
  dcterms:modified "2026-06-09T00:46:04.339802Z"^^xsd:dateTime .

oakcurric:keyword-batch-process
  a curric:Keyword ;
  schema:name "batch process"@en ;
  schema:description """a manufacturing method made up of discrete stages, rather than a product
  being constantly produced"""@en ;
  dcterms:modified "2026-06-09T00:46:04.339811Z"^^xsd:dateTime .

oakcurric:keyword-continuous-process
  a curric:Keyword ;
  schema:name "continuous process"@en ;
  schema:description "a manufacturing method where a product is constantly produced"@en ;
  dcterms:modified "2026-06-09T00:46:04.339816Z"^^xsd:dateTime .

oakcurric:keyword-brine
  a curric:Keyword ;
  schema:name "brine"@en ;
  schema:description """A concentrated aqueous solution containing between 3.5% and 26% sodium
  chloride."""@en ;
  dcterms:modified "2026-06-09T00:46:04.340117Z"^^xsd:dateTime .

oakcurric:keyword-finite-resources
  a curric:Keyword ;
  schema:name "finite resources"@en ;
  schema:description """Finite resources exist in limited quantities on Earth and will run out if we
  keep using them because they cannot be regenerated or replaced within our lifetime."""@en ;
  dcterms:modified "2026-06-09T00:46:04.340122Z"^^xsd:dateTime .

oakcurric:keyword-synthetic-products
  a curric:Keyword ;
  schema:name "synthetic products"@en ;
  schema:description """Synthetic products such as plastic and glass are made by humans using
  natural resources."""@en ;
  dcterms:modified "2026-06-09T00:46:04.340128Z"^^xsd:dateTime .

oakcurric:keyword-sustainable-development
  a curric:Keyword ;
  schema:name "sustainable development"@en ;
  schema:description """Sustainable development helps us to meet the needs of current generations
  without compromising the ability of future generations to meet their needs."""@en ;
  dcterms:modified "2026-06-09T00:46:04.340133Z"^^xsd:dateTime .

oakcurric:keyword-complete-combustion
  a curric:Keyword ;
  schema:name "complete combustion"@en ;
  schema:description """The complete combustion of fuels, such as hydrocarbons, occurs when enough
  oxygen is present to convert all the fuel into carbon dioxide and water."""@en ;
  dcterms:modified "2026-06-09T00:46:04.340141Z"^^xsd:dateTime .

oakcurric:keyword-incomplete-combustion
  a curric:Keyword ;
  schema:name "incomplete combustion"@en ;
  schema:description """Incomplete combustion is when a substance reacts only partially with oxygen,
  such as when carbon burns in air, producing carbon dioxide, carbon monoxide and soot
  (unburnt carbon)."""@en ;
  dcterms:modified "2026-06-09T00:46:04.340147Z"^^xsd:dateTime .

oakcurric:keyword-reaction-profile
  a curric:Keyword ;
  schema:name "reaction profile"@en ;
  schema:description """A reaction profile is a diagram showing the energy changes during exothermic
  and endothermic reactions."""@en ;
  dcterms:modified "2026-06-09T00:46:04.340173Z"^^xsd:dateTime .

oakcurric:keyword-heating-curve
  a curric:Keyword ;
  schema:name "heating curve"@en ;
  schema:description "shows temperature changes of a substance over time as it is heated."@en ;
  dcterms:modified "2026-06-09T00:46:04.340179Z"^^xsd:dateTime .

oakcurric:keyword-natural-gas
  a curric:Keyword ;
  schema:name "natural gas"@en ;
  schema:description """A mixture of gases which are rich in hydrocarbons, consisting largely of
  methane."""@en ;
  dcterms:modified "2026-06-09T00:46:04.340368Z"^^xsd:dateTime .

oakcurric:keyword-molar-gas-volume
  a curric:Keyword ;
  schema:name "molar gas volume"@en ;
  schema:description """Molar gas volume is the volume occupied by one mole of any gas. It is equal
  to 24 dm³ or 24 000 cm³ at room temperature and pressure."""@en ;
  dcterms:modified "2026-06-09T00:46:04.340606Z"^^xsd:dateTime .

oakcurric:keyword-theoretical-yield
  a curric:Keyword ;
  schema:name "theoretical yield"@en ;
  schema:description """is the maximum calculated mass of product expected to form from a given mass
  of reactants"""@en ;
  dcterms:modified "2026-06-09T00:46:04.340611Z"^^xsd:dateTime .

oakcurric:keyword-actual-yield
  a curric:Keyword ;
  schema:name "actual yield"@en ;
  schema:description "is the actual amount of product obtained from a chemical reaction"@en ;
  dcterms:modified "2026-06-09T00:46:04.340616Z"^^xsd:dateTime .

oakcurric:keyword-percentage-yield
  a curric:Keyword ;
  schema:name "percentage yield"@en ;
  schema:description """is the actual yield (mass of product obtained) divided by the theoretical
  yield (maximum mass of product possible), as a percentage"""@en ;
  dcterms:modified "2026-06-09T00:46:04.340625Z"^^xsd:dateTime .

oakcurric:keyword-atom-economy
  a curric:Keyword ;
  schema:name "atom economy"@en ;
  schema:description """is the percentage, by relative mass, of reactants that are converted into
  useful products"""@en ;
  dcterms:modified "2026-06-09T00:46:04.340630Z"^^xsd:dateTime .

oakcurric:keyword-useful-product
  a curric:Keyword ;
  schema:name "useful product"@en ;
  schema:description "is a chemical product that is desired or valuable"@en ;
  dcterms:modified "2026-06-09T00:46:04.340636Z"^^xsd:dateTime .

oakcurric:keyword-hydroxide
  a curric:Keyword ;
  schema:name "hydroxide"@en ;
  schema:description """A basic compound which contains an ion comprising of an oxygen and a
  hydrogen atom (OH⁻)."""@en ;
  dcterms:modified "2026-06-09T00:46:04.340642Z"^^xsd:dateTime .

oakcurric:keyword-steel
  a curric:Keyword ;
  schema:name "steel"@en ;
  schema:description """An alloy of iron that contains specific amounts of carbon and may contain
  other metals."""@en ;
  dcterms:modified "2026-06-09T00:46:04.340907Z"^^xsd:dateTime .

oakcurric:keyword-carat
  a curric:Keyword ;
  schema:name "carat"@en ;
  schema:description "A unit for measuring the purity of gold."@en ;
  dcterms:modified "2026-06-09T00:46:04.340915Z"^^xsd:dateTime .

oakcurric:keyword-alkali-metals
  a curric:Keyword ;
  schema:name "alkali metals"@en ;
  schema:description """Alkali metals are the elements in Group 1 of the periodic table which react
  with water to form strongly alkaline hydroxides."""@en ;
  dcterms:modified "2026-06-09T00:46:04.341147Z"^^xsd:dateTime .

oakcurric:keyword-alkali-metal-hydroxides
  a curric:Keyword ;
  schema:name "alkali metal hydroxides"@en ;
  schema:description """Alkali metal hydroxides are soluble compounds formed when the alkali metals
  react with water. They form colourless solutions."""@en ;
  dcterms:modified "2026-06-09T00:46:04.341152Z"^^xsd:dateTime .

oakcurric:keyword-algae
  a curric:Keyword ;
  schema:name "algae"@en ;
  schema:description """A diverse range of unicellular or multicellular organisms that can
  photosynthesise."""@en ;
  dcterms:modified "2026-06-09T00:46:04.341275Z"^^xsd:dateTime .

oakcurric:keyword-phytoplankton
  a curric:Keyword ;
  schema:name "phytoplankton"@en ;
  schema:description """A group of microscopic algae, usually found floating in the upper part of
  the ocean."""@en ;
  dcterms:modified "2026-06-09T00:46:04.341281Z"^^xsd:dateTime .

oakcurric:keyword-delocalised-electron
  a curric:Keyword ;
  schema:name "delocalised electron"@en ;
  schema:description """Electrons are said to be delocalised when they are free to move through the
  structure of a metal and can carry an electrical current."""@en ;
  dcterms:modified "2026-06-09T00:46:04.341287Z"^^xsd:dateTime .

oakcurric:keyword-precaution
  a curric:Keyword ;
  schema:name "precaution"@en ;
  schema:description "An action taken to prevent or reduce the risk of danger or harm."@en ;
  dcterms:modified "2026-06-09T00:46:04.341548Z"^^xsd:dateTime .

oakcurric:keyword-moles
  a curric:Keyword ;
  schema:name "moles"@en ;
  schema:description """of something is 6.02 × 10²³ of it. The mass of a mole of a substance is its
  relative mass expressed in grams."""@en ;
  dcterms:modified "2026-06-09T00:46:04.341754Z"^^xsd:dateTime .

oakcurric:keyword-fuel-cell
  a curric:Keyword ;
  schema:name "fuel cell"@en ;
  schema:description "a device that produces a voltage when supplied with a fuel and oxygen"@en ;
  dcterms:modified "2026-06-09T00:46:04.341759Z"^^xsd:dateTime .

oakcurric:keyword-bond-energy
  a curric:Keyword ;
  schema:name "bond energy"@en ;
  schema:description """The energy required to break a covalent bond, or released when making a
  covalent bond. is known as the bond energy."""@en ;
  dcterms:modified "2026-06-09T00:46:04.342473Z"^^xsd:dateTime .

oakcurric:keyword-salts
  a curric:Keyword ;
  schema:name "salts"@en ;
  schema:description """are ionic compounds formed from positive and negative ions electrostatically
  attracted to each other."""@en ;
  dcterms:modified "2026-06-09T00:46:04.342682Z"^^xsd:dateTime .

oakcurric:keyword-halogens
  a curric:Keyword ;
  schema:name "halogens"@en ;
  schema:description """are reactive non-metallic elements in Group 7 of the periodic table which
  react with metals to form salts."""@en ;
  dcterms:modified "2026-06-09T00:46:04.342688Z"^^xsd:dateTime .

oakcurric:keyword-hydrogen-ion
  a curric:Keyword ;
  schema:name "hydrogen ion"@en ;
  schema:description """A positively charged ion formed when a hydrogen atom loses an
  electron (H⁺)."""@en ;
  dcterms:modified "2026-06-09T00:46:04.343127Z"^^xsd:dateTime .

oakcurric:keyword-weak-acid
  a curric:Keyword ;
  schema:name "weak acid"@en ;
  schema:description "An acid which partially dissociates to form H⁺ ions in aqueous solution."@en ;
  dcterms:modified "2026-06-09T00:46:04.343133Z"^^xsd:dateTime .

oakcurric:keyword-reinforcement
  a curric:Keyword ;
  schema:name "reinforcement"@en ;
  schema:description """In a composite material, it is the substance that is bound together by the
  matrix material."""@en ;
  dcterms:modified "2026-06-09T00:46:04.343311Z"^^xsd:dateTime .

oakcurric:keyword-energy-change
  a curric:Keyword ;
  schema:name "energy change"@en ;
  schema:description """The energy change is the difference between the energy of the reactants and
  the energy of the products."""@en ;
  dcterms:modified "2026-06-09T00:46:04.343840Z"^^xsd:dateTime .

oakcurric:keyword-phytomining
  a curric:Keyword ;
  schema:name "phytomining"@en ;
  schema:description """Phytomining is a method of extracting metals by growing plants in soil
  containing low-grade ore."""@en ;
  dcterms:modified "2026-06-09T00:46:04.346079Z"^^xsd:dateTime .

oakcurric:keyword-chemical-species
  a curric:Keyword ;
  schema:name "chemical species"@en ;
  schema:description """Any chemical entity, such as atoms, ions, or molecules involved in a
  chemical process."""@en ;
  dcterms:modified "2026-06-09T00:46:04.346892Z"^^xsd:dateTime .

oakcurric:keyword-molecular-mass
  a curric:Keyword ;
  schema:name "molecular mass"@en ;
  schema:description "The sum of the atomic masses of all the atoms in a molecule."@en ;
  dcterms:modified "2026-06-09T00:46:04.348515Z"^^xsd:dateTime .

oakcurric:keyword-molecular-ion
  a curric:Keyword ;
  schema:name "molecular ion"@en ;
  schema:description """The ion produced when the molecule is ionised by loss of an electron from
  the molecule."""@en ;
  dcterms:modified "2026-06-09T00:46:04.348521Z"^^xsd:dateTime .

oakcurric:keyword-spectrometer
  a curric:Keyword ;
  schema:name "spectrometer"@en ;
  schema:description """An apparatus used for recording and measuring spectra, especially as a
  method of analysis."""@en ;
  dcterms:modified "2026-06-09T00:46:04.348526Z"^^xsd:dateTime .

# ----------------------------------------------------------------------
# Misconceptions
# ----------------------------------------------------------------------

oakcurric:misconception-thinking-precise-accurate-same-thing
  a curric:Misconception ;
  curric:statement "Thinking that precise and accurate are the same thing."@en ;
  curric:correction """It may help to draw a bullseye target board. Precise results will all be
  close to each other but may not be near the bullseye. Accurate results will be near the
  bullseye but may be more scattered if they are not precise."""@en ;
  dcterms:modified "2026-06-09T00:46:22.057886Z"^^xsd:dateTime .

oakcurric:misconception-using-ionic-charges-determine-empirical
  a curric:Misconception ;
  curric:statement """Using ionic charges to determine the empirical formulae, especially with
  polyatomic ions. Standard notation is difficult and confusing, e.g. when to use
  superscripts, subscripts or brackets."""@en ;
  curric:correction """At this stage, pupils will need to just learn the the formulae of the
  polyatomic ions and accept that a full explanation will come later in their chemistry
  learning. Provide pupils with plenty of practice of writing and using ionic formulae."""@en ;
  dcterms:modified "2026-06-09T00:46:22.058004Z"^^xsd:dateTime .

oakcurric:misconception-students-think-elemental-diatomic-molecule
  a curric:Misconception ;
  curric:statement """Students often think that an elemental diatomic molecule, e.g. hydrogen, is a
  compound because they see two atoms chemically joined together."""@en ;
  curric:correction """The teacher needs to emphasise the definition for compounds. Molecules are
  not the same as compounds, some molecules are compounds, not all."""@en ;
  dcterms:modified "2026-06-09T00:46:22.058026Z"^^xsd:dateTime .

oakcurric:misconception-pupils-mistake-common-everyday-usage
  a curric:Misconception ;
  curric:statement """Pupils mistake common (everyday) usage of pure (i.e. pure orange juice) as
  being a pure substance when it is, in fact, a mixture."""@en ;
  curric:correction """'Everyday' usage refers to one source whereas scientific usage refers to
  particle composition."""@en ;
  dcterms:modified "2026-06-09T00:46:22.058032Z"^^xsd:dateTime .

oakcurric:misconception-students-struggle-idea-small-atom
  a curric:Misconception ;
  curric:statement """Students often struggle with the idea of how small an atom actually is. In
  contrast, how small the nucleus is, relative to the size of the atom."""@en ;
  curric:correction """The use of units and numbers to show the difference in size, e.g. the atom is
  approximately 10, 000 times larger than the nucleus. The radius of the atom is 0.1nm and
  the nucleus very small compared to that of the atom."""@en ;
  dcterms:modified "2026-06-09T00:46:22.059005Z"^^xsd:dateTime .

oakcurric:misconception-funnel-same-filter
  a curric:Misconception ;
  curric:statement "A funnel is the same as a filter."@en ;
  curric:correction """A funnel streamlines movement, while a filter separates materials. Use
  everyday examples to highlight the difference, e.g. an oil funnel vs. an oil filter, or a
  coffee funnel vs. a coffee filter."""@en ;
  dcterms:modified "2026-06-09T00:46:22.059879Z"^^xsd:dateTime .

oakcurric:misconception-recognising-particles-present-aqueous-solution
  a curric:Misconception ;
  curric:statement """Recognising the particles present in an aqueous solution is problematic.
  Understanding how an electric current flows through an electrolyte is confusing as ions,
  not electrons, are the charge carrier."""@en ;
  curric:correction """Ensure that pupils have a good understanding of key terms such as atom, ion,
  electron, solutions and reactivity before moving on to the electrolysis of aqueous
  solutions."""@en ;
  dcterms:modified "2026-06-09T00:46:22.059894Z"^^xsd:dateTime .

oakcurric:misconception-pupils-confuse-key-terminology-many
  a curric:Misconception ;
  curric:statement """Pupils often confuse key terminology, as many words are similar, and confuse
  electrolysis with physical methods of separation."""@en ;
  curric:correction """Emphasise the keywords and provide plenty of opportunity for them to be used
  in the correct context. Compare electrolysis to physical methods of separation, such as
  filtration, and explain that chemical reactions occur at the electrodes."""@en ;
  dcterms:modified "2026-06-09T00:46:22.059983Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-wastewater-same-sewage
  a curric:Misconception ;
  curric:statement """Some pupils think that 'wastewater' is the same as 'sewage' and/or that
  anything found in a sewer is 'sewage'."""@en ;
  curric:correction """Stress that wastewater is any used water that has been affected by domestic,
  industrial and agricultural processes; sewage is a part of waste water, but specifically
  that which is contaminated by with faeces and urine."""@en ;
  dcterms:modified "2026-06-09T00:46:22.061008Z"^^xsd:dateTime .

oakcurric:misconception-pupils-use-atomic-number-rather
  a curric:Misconception ;
  curric:statement """Pupils may use the atomic number rather than mass when calculating the
  relative formula mass. Also, the number of atoms can be missed for the percentage of an
  element in a compound."""@en ;
  curric:correction """Emphasise that atomic mass is the larger number for each element on the
  periodic table and encourage pupils to use the key present to help them identify the mass."""@en ;
  dcterms:modified "2026-06-09T00:46:22.061363Z"^^xsd:dateTime .

oakcurric:misconception-pupils-easily-confuse-empirical-molecular
  a curric:Misconception ;
  curric:statement "Pupils easily confuse empirical and molecular formula."@en ;
  curric:correction """Provide multiple examples of formula and challenge pupils to distinguish them
  as molecular or empirical formula; if the former, push pupils to suggest the molecule's
  empirical formula."""@en ;
  dcterms:modified "2026-06-09T00:46:22.062105Z"^^xsd:dateTime .

oakcurric:misconception-spelling-noble-re-nobel-concept
  a curric:Misconception ;
  curric:statement """Spelling of noble re- Nobel and the concept of why they were given this name,
  i.e. due to having a full outer shell of electrons which means they do not need to bond
  with other elements."""@en ;
  curric:correction """Explain that the name noble was due to the fact that they are so unreactive
  and did not need to bond with other elements due to already having a full outer shell of
  electrons making them so stable."""@en ;
  dcterms:modified "2026-06-09T00:46:22.062724Z"^^xsd:dateTime .

oakcurric:misconception-pupils-mix-atomic-number-atomic
  a curric:Misconception ;
  curric:statement """Pupils often mix up the atomic number and atomic mass number and get confused
  over which subatomic particles these represent."""@en ;
  curric:correction """It helps to describe the atomic number as the proton number to help the
  pupils remember. Also, the provided periodic tables often have a key to help and this
  should be highlight to pupils."""@en ;
  dcterms:modified "2026-06-09T00:46:22.064025Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-temperature-increasing-e
  a curric:Misconception ;
  curric:statement """Pupils can often think that when the temperature is not increasing, i.e. at a
  change of state, that the experiment is 'not working'."""@en ;
  curric:correction """Question students whilst circulating the class about what they would expect
  to see and try to get them to imagine what is happening to the particles. Use the heating
  curve to explain why the temperature did not increase during state changes."""@en ;
  dcterms:modified "2026-06-09T00:46:22.071811Z"^^xsd:dateTime .

oakcurric:misconception-confusing-electrodes-electrical-cables-carbon
  a curric:Misconception ;
  curric:statement """confusing the electrodes, electrical cables or carbon electrodes having a
  break in them"""@en ;
  curric:correction """Use the PANIC acronym; positive anode negative is cathode. Check all
  components of the electric circuit."""@en ;
  dcterms:modified "2026-06-09T00:46:22.071817Z"^^xsd:dateTime .

oakcurric:misconception-added-calcium-hydroxide-dissolves-completely
  a curric:Misconception ;
  curric:statement """All added calcium hydroxide dissolves completely, and the pH readings are
  accurate without consistent mixing."""@en ;
  curric:correction """Calcium hydroxide has low solubility in water, so not all of it dissolves
  readily. Consistent mixing ensures uniform pH readings. Without proper mixing, pH readings
  can be inaccurate, leading to incorrect conclusions about the neutralisation point."""@en ;
  dcterms:modified "2026-06-09T00:46:22.071830Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-identify-surroundings-exothermic
  a curric:Misconception ;
  curric:statement """Pupils struggle to identify the surroundings in exothermic and endothermic
  reactions and why the temperature decreases in endothermic reactions when energy is
  transferred into the reaction."""@en ;
  curric:correction """Explain that the surroundings are where you are making the temperature
  measurements and that the energy is transferred from the thermal energy store of the
  surroundings to the chemical energy store of the reaction."""@en ;
  dcterms:modified "2026-06-09T00:46:22.071836Z"^^xsd:dateTime .

oakcurric:misconception-increasing-temperature-increases-rate-product
  a curric:Misconception ;
  curric:statement """Increasing the temperature increases the rate product is formed, and therefore
  think a faster reaction produces more product."""@en ;
  curric:correction """Increasing the temperature will make the reaction proceed faster but will not
  change the amount of product formed. The reactants are the limiting factor, not the
  temperature."""@en ;
  dcterms:modified "2026-06-09T00:46:22.071879Z"^^xsd:dateTime .

oakcurric:misconception-pupils-confuse-mean-rate-reaction
  a curric:Misconception ;
  curric:statement """Pupils often confuse the mean rate of reaction with the instantaneous rate of
  reaction, thinking they are the same or not understanding the distinction between the two."""@en ;
  curric:correction """The tasks give pupils s the opportunity to distinguish between mean and
  instantaneous rate of reaction by calculating both from the same set of data."""@en ;
  dcterms:modified "2026-06-09T00:46:22.071942Z"^^xsd:dateTime .

oakcurric:misconception-pupils-understand-observing-excess-metal
  a curric:Misconception ;
  curric:statement """Pupils often do not understand that observing excess metal oxide in the
  reaction mixture means that the acid has fully reacted."""@en ;
  curric:correction """Emphasise how to observe the end of the reaction and what these observations
  mean, i.e. excess metal oxide in the reaction mixture or using pH paper to indicate the
  solution is neutral. Both are evidence of the acid having fully reacted."""@en ;
  dcterms:modified "2026-06-09T00:46:22.073108Z"^^xsd:dateTime .

oakcurric:misconception-pupils-mistake-same-mass-different
  a curric:Misconception ;
  curric:statement """Pupils mistake that the same mass of different substances = the same number of
  particles."""@en ;
  curric:correction """This activity reinforces the mathematical relationship between relative
  formula mass of a substance, the number of particles present and the mass measured in the
  lab."""@en ;
  dcterms:modified "2026-06-09T00:46:22.073183Z"^^xsd:dateTime .

oakcurric:misconception-equilibrium-occur-open-system-reactions
  a curric:Misconception ;
  curric:statement """Equilibrium can occur in an open system; no reactions occur at equilibrium;
  amounts of reactants and products are equal at equilibrium."""@en ;
  curric:correction """Equilibrium requires a closed system; in an open system, matter exchange
  disrupts balance. At equilibrium, reactions still occur but at equal rates, leading to
  constant amounts, not necessarily equal amounts of reactants and products."""@en ;
  dcterms:modified "2026-06-09T00:46:22.073221Z"^^xsd:dateTime .

oakcurric:misconception-indicators-provide-precise-ph-values
  a curric:Misconception ;
  curric:statement """All indicators provide precise pH values and give the same information as pH
  meters."""@en ;
  curric:correction """Indicators do not provide exact pH values; they only indicate whether a
  solution is acidic, neutral, or alkaline by changing colour. A pH meter, on the other
  hand, measures the exact pH value of a solution and is more accurate."""@en ;
  dcterms:modified "2026-06-09T00:46:22.073666Z"^^xsd:dateTime .

oakcurric:misconception-water-samples-neutral-e-ph
  a curric:Misconception ;
  curric:statement "All water samples are neutral (i.e. pH of 7)."@en ;
  curric:correction """The acidity / alkalinity of water samples is affected by the dissolved
  substances in each sample."""@en ;
  dcterms:modified "2026-06-09T00:46:22.073742Z"^^xsd:dateTime .

oakcurric:misconception-reaction-stops-x-longer-visible
  a curric:Misconception ;
  curric:statement "The reaction stops when the 'X' is no longer visible."@en ;
  curric:correction """The disappearance of the cross only indicates that the sulfur precipitate has
  formed sufficiently to obscure the cross. The reaction itself continues beyond this point
  until all reactants are consumed."""@en ;
  dcterms:modified "2026-06-09T00:46:22.073864Z"^^xsd:dateTime .

oakcurric:misconception-pupils-assume-decrease-temperature-occurring
  a curric:Misconception ;
  curric:statement """Pupils can assume that any decrease in temperature occurring when excess
  reactant is added to an exothermic reaction is because the reaction has become
  endothermic."""@en ;
  curric:correction """Explain that once the limiting reactant has been used up the exothermic
  reaction is complete. The addition of excess reactant will only act to cool down the
  reaction mixture."""@en ;
  dcterms:modified "2026-06-09T00:46:22.073902Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-substances-need-their
  a curric:Misconception ;
  curric:statement """Pupils think that substances need to be at their boiling point temperature to
  evaporate."""@en ;
  curric:correction """Use plenty of real life examples of liquids evaporating in situations where
  pupils know that the liquid is not above its boiling point but still evaporates."""@en ;
  dcterms:modified "2026-06-09T00:46:22.074663Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-interpret-information-contains
  a curric:Misconception ;
  curric:statement """Pupils can struggle to interpret information that contains several samples on
  one chromatogram."""@en ;
  curric:correction """Stress a systematic approach to interpreting chromatograms - use rulers. Live
  model this - using a visualiser helps enormously."""@en ;
  dcterms:modified "2026-06-09T00:46:22.075345Z"^^xsd:dateTime .

oakcurric:misconception-pupils-believe-small-colour-change
  a curric:Misconception ;
  curric:statement """Pupils often believe that any small colour change signals the end point,
  leading to inaccurate titrations."""@en ;
  curric:correction """Emphasise the importance of adding the titrant drop by drop near the end
  point and ensure pupils understand that the end point is reached only when the colour
  change is persistent."""@en ;
  dcterms:modified "2026-06-09T00:46:22.077518Z"^^xsd:dateTime .

oakcurric:misconception-heating-mixture-strongly-cause-distillation
  a curric:Misconception ;
  curric:statement "Heating a mixture strongly will cause distillation to occur more quickly."@en ;
  curric:correction """Heating a mixture strongly could cause multiple components to enter a
  condenser (or delivery tube), resulting in a contaminated distillate. Careful, gentle
  heating of the mixture to ensure no bubbles near the condenser will reduce contamination."""@en ;
  dcterms:modified "2026-06-09T00:46:22.077740Z"^^xsd:dateTime .

oakcurric:misconception-larger-surface-area-produces-larger
  a curric:Misconception ;
  curric:statement "That a larger surface area produces a larger volume/mass of product."@en ;
  curric:correction """The experiment should help pupils realise they produce the same mass of
  carbon dioxide when using the same mass of calcium carbonate chips and powder."""@en ;
  dcterms:modified "2026-06-09T00:46:22.077770Z"^^xsd:dateTime .

oakcurric:misconception-flame-colours-unique-even-mixtures
  a curric:Misconception ;
  curric:statement "Flame colours are unique, even in mixtures."@en ;
  curric:correction """Explain that strong colours, like sodium's yellow, can mask others. Use
  spectrometry to identify masked elements."""@en ;
  dcterms:modified "2026-06-09T00:46:22.078169Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-ammonia-safe-handle
  a curric:Misconception ;
  curric:statement """Pupils may think ammonia is safe to handle without precautions because it's a
  common household chemical."""@en ;
  curric:correction """Emphasise ammonia's toxicity and the importance of using PPE and proper
  ventilation."""@en ;
  dcterms:modified "2026-06-09T00:46:22.078176Z"^^xsd:dateTime .

oakcurric:misconception-thinking-concentration-solution-excess-changes
  a curric:Misconception ;
  curric:statement """Thinking that as the concentration of a solution in excess changes, so does
  the volume of gas produced."""@en ;
  curric:correction """The slide deck uses graphical data to show that the same volume of gas is
  produced when different concentrations are used, so long as the reacting solution is in
  excess."""@en ;
  dcterms:modified "2026-06-09T00:46:22.078635Z"^^xsd:dateTime .

oakcurric:misconception-salts-either-completely-soluble-completely
  a curric:Misconception ;
  curric:statement "All salts are either completely soluble or completely insoluble in water."@en ;
  curric:correction """Not all salts follow a strict 'soluble' or 'insoluble' rule. Some salts have
  limited solubility, meaning they dissolve only to a certain extent. Solubility rules help
  us predict the solubility of common salts, but there are always exceptions."""@en ;
  dcterms:modified "2026-06-09T00:46:22.078705Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-reversible-reaction-go
  a curric:Misconception ;
  curric:statement """Pupils often think that a reversible reaction will always go to completion in
  one direction before reversing."""@en ;
  curric:correction """Explain that in a reversible reaction, if the conditions allow it, both the
  forward and backward reaction can occur at the same time."""@en ;
  dcterms:modified "2026-06-09T00:46:22.079341Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-decide-scales-needed
  a curric:Misconception ;
  curric:statement "Pupils can struggle to decide on the scales needed for an axis on a graph."@en ;
  curric:correction """Suggest a suitable scale that will fit on the graph paper they will use or
  use a computer to draw graphs."""@en ;
  dcterms:modified "2026-06-09T00:46:22.080782Z"^^xsd:dateTime .

oakcurric:misconception-white-precipitates-chemical-tests-indicate
  a curric:Misconception ;
  curric:statement """All white precipitates in chemical tests indicate the presence of the same ion
  without the need for further testing."""@en ;
  curric:correction """Explain that white precipitates can indicate different ions depending on the
  test. For instance, barium sulfate indicates sulfate ions, silver chloride indicates
  chloride ions, and sodium hydroxide tests distinguish between cations."""@en ;
  dcterms:modified "2026-06-09T00:46:22.086821Z"^^xsd:dateTime .

oakcurric:misconception-acid-rain-immediately-harmful-human
  a curric:Misconception ;
  curric:statement """Acid rain is immediately harmful to human skin. Acid rain's effects are quick
  and devastating."""@en ;
  curric:correction """Educate that acid rain is less acidic than household acids. Discuss the
  long-term ecological and structural impacts of acid rain."""@en ;
  dcterms:modified "2026-06-09T00:46:22.087453Z"^^xsd:dateTime .

oakcurric:misconception-pupils-measure-final-temperature-reaction
  a curric:Misconception ;
  curric:statement """Pupils often measure the final temperature of the reaction mixture rather than
  the highest temperature."""@en ;
  curric:correction """Encourage pupils to keep monitoring the temperature until it starts to
  decrease; that way they will know they have seen the highest temperature."""@en ;
  dcterms:modified "2026-06-09T00:46:22.087486Z"^^xsd:dateTime .

oakcurric:misconception-halogen-solutions-coloured-difficult-determine
  a curric:Misconception ;
  curric:statement """Halogen solutions are coloured and sometimes it can be difficult to determine
  colour changes during displacement reactions."""@en ;
  curric:correction """Displacement of iodine gives the darkest colour change (turns brown), while
  bromine will provide one which is lighter (turns orange)."""@en ;
  dcterms:modified "2026-06-09T00:46:22.087492Z"^^xsd:dateTime .

oakcurric:misconception-water-same
  a curric:Misconception ;
  curric:statement "All water is the same."@en ;
  curric:correction """The dissolved solid content of water samples is affected by the environment
  from which it was obtained."""@en ;
  dcterms:modified "2026-06-09T00:46:22.088316Z"^^xsd:dateTime .

oakcurric:misconception-tests-ions-interchangeable-used-order
  a curric:Misconception ;
  curric:statement """All tests for ions are interchangeable and can be used in any order without
  affecting the outcome."""@en ;
  curric:correction """Clarify that each test is specific and must be conducted in a particular
  order to avoid interference. For example, testing for sulfates before halides can prevent
  false positives caused by overlapping precipitates, ensuring accurate identification."""@en ;
  dcterms:modified "2026-06-09T00:46:22.090428Z"^^xsd:dateTime .

oakcurric:misconception-ionic-substances-binary-compounds-bonding
  a curric:Misconception ;
  curric:statement """Ionic substances are binary compounds. Bonding and structure are the same
  thing. Only bonding influences properties."""@en ;
  curric:correction """As well as multiple ions in ionic substances, there can be polyatomic ions
  too. Bonding informs structure, and bonding and structure together influences properties."""@en ;
  dcterms:modified "2026-06-09T00:46:22.090621Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-mass-crucible-contents
  a curric:Misconception ;
  curric:statement """Pupils may think that the mass of the crucible and contents will not change
  during the reaction because the lid is closed, believing that all gases produced remain
  inside."""@en ;
  curric:correction """Explain that even with the crucible lid on, gases like carbon dioxide & water
  vapour formed during decomposition can escape around the edges. This leads to a decrease
  in mass, which is crucial for calculating the stoichiometry based on the mass loss."""@en ;
  dcterms:modified "2026-06-09T00:46:22.090878Z"^^xsd:dateTime .

oakcurric:misconception-pupils-overshoot-end-point-especially
  a curric:Misconception ;
  curric:statement """Pupils often overshoot the end point, especially on their first attempt at a
  titration."""@en ;
  curric:correction """Pupils will need to work on their dexterity, often with a partner, to ensure
  the flow of titrant is slow enough from the burette, and that their swirling technique
  allows ample mixing of the solutions."""@en ;
  dcterms:modified "2026-06-09T00:46:22.093620Z"^^xsd:dateTime .

oakcurric:misconception-students-think-metals-react-vigorously
  a curric:Misconception ;
  curric:statement """Students may think all metals react vigorously with water, and may believe all
  transition metals form only one type of ion, and might think that all metals are equally
  good catalysts."""@en ;
  curric:correction """Unlike Group 1 metals, transition metals react slowly with water or not at
  all. Transition metals can form ions with different charges, leading to compounds with
  varying properties and colours. Each reaction will be catalysed best by one catalyst."""@en ;
  dcterms:modified "2026-06-09T00:46:22.095297Z"^^xsd:dateTime .

oakcurric:misconception-number-one-mole-represents-difficult
  a curric:Misconception ;
  curric:statement """The number one mole represents can be difficult for pupils to grasp and
  appreciate."""@en ;
  curric:correction """Show many real world examples of 6.02 × 10²³ examples of something - that
  many basketballs would form a planet the size of the Earth."""@en ;
  dcterms:modified "2026-06-09T00:46:22.095387Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-understand-heating-constant
  a curric:Misconception ;
  curric:statement """Pupils sometimes struggle to understand that 'heating to constant mass' takes
  time and multiple measurements."""@en ;
  curric:correction """Link the idea that atoms rearrange during a reaction and that for all atoms
  of a substance to be oxidised, enough oxygen must be present. If the product measurements
  show a 'constant mass' we can be confident that complete oxidation has occurred."""@en ;
  dcterms:modified "2026-06-09T00:46:22.095429Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-link-chemical-formulae
  a curric:Misconception ;
  curric:statement """Pupils can struggle to link chemical formulae to what is happening on the
  atomic level and to what they observe during a chemical reaction."""@en ;
  curric:correction """Reinforce via demonstrations, modelling and diagrams via Johnstone's
  triangle. One simple demo (e.g. magnesium + oxygen) = one model, one diagram and one
  chemical reaction equation. Use progressively more complicated demos and build up from
  there."""@en ;
  dcterms:modified "2026-06-09T00:46:22.097235Z"^^xsd:dateTime .

oakcurric:misconception-pupils-use-terms-evaporation-boiling
  a curric:Misconception ;
  curric:statement """Pupils sometimes use the terms evaporation and boiling interchangeably, but
  they are not the same."""@en ;
  curric:correction """Boiling: a liquid substance is heated & gas bubbles form. Evaporation: same,
  BUT only on the surface of the liquid & the gas mixes with air."""@en ;
  dcterms:modified "2026-06-09T00:46:22.097390Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-heating-substance-strongly
  a curric:Misconception ;
  curric:statement """Pupils think that heating a substance strongly and for extended periods will
  improve distillation."""@en ;
  curric:correction """Stress that distillation is a skill which requires careful control of heating
  so only one substance is in the condenser at a time."""@en ;
  dcterms:modified "2026-06-09T00:46:22.101933Z"^^xsd:dateTime .

oakcurric:misconception-pupils-easily-confuse-different-types
  a curric:Misconception ;
  curric:statement "Pupils *very* easily confuse different types of reactions."@en ;
  curric:correction """Spend time developing ways to help pupils remember the differences and
  regularly challenge them to explain why one reaction is the type it is."""@en ;
  dcterms:modified "2026-06-09T00:46:22.102884Z"^^xsd:dateTime .

oakcurric:misconception-thinking-polymer-identification-codes-mean
  a curric:Misconception ;
  curric:statement """Thinking that the polymer identification codes mean that all these polymers
  can be recycled as the symbols look similar to the recycling symbol."""@en ;
  curric:correction "Only some polymers can be recycled. These normally have the code 1 or 2."@en ;
  dcterms:modified "2026-06-09T00:46:22.108327Z"^^xsd:dateTime .

oakcurric:misconception-describing-colour-change-bromine-water
  a curric:Misconception ;
  curric:statement """Describing the colour change of bromine water with an alkene from orange to
  clear."""@en ;
  curric:correction """Coloured solutions can be clear if you can see through them. Colourless means
  it has no colour. Bromine water in the presence of an alkene changes from orange to
  colourless."""@en ;
  dcterms:modified "2026-06-09T00:46:22.108340Z"^^xsd:dateTime .

oakcurric:misconception-incorrectly-writing-molecular-formula-alcohols
  a curric:Misconception ;
  curric:statement "Incorrectly writing the molecular formula of alcohols."@en ;
  curric:correction """Help pupils understand the difference between structural formula, e.g C₂H₅OH,
  and molecular formula, e.g C₂H₆O."""@en ;
  dcterms:modified "2026-06-09T00:46:22.108520Z"^^xsd:dateTime .

oakcurric:misconception-shortest-alkene-one-containing-one
  a curric:Misconception ;
  curric:statement "The shortest alkene is one containing only one carbon atom."@en ;
  curric:correction """Teach that alkenes contain the C=C bond and therefore the shortest alkene is
  ethene."""@en ;
  dcterms:modified "2026-06-09T00:46:22.109605Z"^^xsd:dateTime .

oakcurric:misconception-confusing-concentration-strength-acids
  a curric:Misconception ;
  curric:statement "Confusing the concentration and strength of acids."@en ;
  curric:correction "Clearly define a strong and weak acid."@en ;
  dcterms:modified "2026-06-09T00:46:22.110902Z"^^xsd:dateTime .

oakcurric:misconception-including-bonds-end-repeating-unit
  a curric:Misconception ;
  curric:statement "Not including the bonds at the end of a repeating unit."@en ;
  curric:correction """The slide deck states the need for open bonds to show how repeating units are
  bonded to each other."""@en ;
  dcterms:modified "2026-06-09T00:46:22.110908Z"^^xsd:dateTime .

oakcurric:misconception-thinking-polymers-made-one-monomer
  a curric:Misconception ;
  curric:statement """Thinking that all polymers are only made up of one monomer. Also, confusing
  condensation reactions to think that it means to condense and take up less space."""@en ;
  curric:correction """Examples are shown where more than one monomer is used to make condensation
  polymers. Discuss what condensation is, and how condensation polymerisation produces water
  or other small molecules depending on the monomers used."""@en ;
  dcterms:modified "2026-06-09T00:46:22.116158Z"^^xsd:dateTime .

oakcurric:misconception-ionic-bond-transfer-electrons-electrostatic
  a curric:Misconception ;
  curric:statement """The ionic bond is the transfer of electrons and not the electrostatic forces
  of attraction between the ions. Dot and cross diagrams show the empirical formula of the
  lattice and not an ionic molecule."""@en ;
  curric:correction """Ensure students have a good understanding of how ions are formed, the
  arrangement of ions in a giant lattice structure and empricial formula before moving on to
  disucss using dot and cross diagrams to model ionic bonding."""@en ;
  dcterms:modified "2026-06-09T00:46:22.118065Z"^^xsd:dateTime .

oakcurric:misconception-covalent-bonds-break-simple-molecules
  a curric:Misconception ;
  curric:statement """Covalent bonds break in simple molecules for substances to melt/boil, because
  this happens in giant covalent structures."""@en ;
  curric:correction """Highlight that bonds require large amounts of energy to break, hence the very
  high melting points of diamond and graphite. As all atoms are bonded these must be broken
  to melt/boil."""@en ;
  dcterms:modified "2026-06-09T00:46:22.118245Z"^^xsd:dateTime .

oakcurric:misconception-atoms-react-because-want-gain
  a curric:Misconception ;
  curric:statement """Atoms react because they 'want' to gain a fuller outer shell of electrons –
  atoms don't have feelings! Monatomic means one atom and may be confused with the term
  element, which means one type of atom."""@en ;
  curric:correction """Take care with language and avoid personifying the atoms. Make sure that
  definitions and terms are used correctly."""@en ;
  dcterms:modified "2026-06-09T00:46:22.118595Z"^^xsd:dateTime .

oakcurric:misconception-pupils-confuse-ideas-bonds-require
  a curric:Misconception ;
  curric:statement """Pupils often confuse the ideas that bonds require energy to break i.e.
  endothermic process and that energy is released forming bonds i.e. exothermic process."""@en ;
  curric:correction """Bonds will not break unless energy is absorbed to do so. The formation of a
  bond releases energy to the surroundings."""@en ;
  dcterms:modified "2026-06-09T00:46:22.119431Z"^^xsd:dateTime .

oakcurric:misconception-atoms-anthropomorphised-described-wanting-full
  a curric:Misconception ;
  curric:statement """Atoms are often anthropomorphised, described as 'wanting' full shells. This
  implies intent and oversimplifies chemical bonding."""@en ;
  curric:correction """Focus on the tendency of atoms to fill their outer shell to 8 electrons to
  become stable. Emphasise carbon atoms do this by sharing electrons in covalent bonds."""@en ;
  dcterms:modified "2026-06-09T00:46:22.119438Z"^^xsd:dateTime .

oakcurric:misconception-including-bonds-either-side-repeating
  a curric:Misconception ;
  curric:statement "Not including the bonds either side of the repeating unit."@en ;
  curric:correction """The slide deck states the need for open bonds to show how repeating units are
  bonded to each other."""@en ;
  dcterms:modified "2026-06-09T00:46:22.119685Z"^^xsd:dateTime .

oakcurric:misconception-dynamic-equilibrium-reactions-stop-increasing
  a curric:Misconception ;
  curric:statement """At dynamic equilibrium the reactions stop; increasing pressure always shifts
  equilibrium to one side; increasing temperature always favours product formation;
  catalysts shift the equilibrium position."""@en ;
  curric:correction """At dynamic equilibrium, reactions continue at equal rates. Pressure shifts
  equilibrium only if gas molecule numbers differ. Temperature favours the endothermic
  direction when increased. Catalysts speed up reaching equilibrium but don't shift it."""@en ;
  dcterms:modified "2026-06-09T00:46:22.119692Z"^^xsd:dateTime .

oakcurric:misconception-pupils-confuse-atomic-number-mass
  a curric:Misconception ;
  curric:statement """Pupils often confuse the atomic number and mass number with regard to the
  number of electrons in an atom. They also can confuse the number of electrons which can be
  held by each shell."""@en ;
  curric:correction """Emphasise that the lower number (atomic number/proton number) represents the
  number of electrons (reference to the mass being larger can help). Practise as many
  electron arrangements as possible."""@en ;
  dcterms:modified "2026-06-09T00:46:22.119723Z"^^xsd:dateTime .

oakcurric:misconception-pupils-confuse-chemical-definitions-concentration
  a curric:Misconception ;
  curric:statement """Pupils often confuse the chemical definitions for 'concentration' and
  'strength'."""@en ;
  curric:correction """Stress that concentration is a measure of particles interspersed throughout a
  specific volume of liquid."""@en ;
  dcterms:modified "2026-06-09T00:46:22.121172Z"^^xsd:dateTime .

oakcurric:misconception-ozone-layer-climate-change-linked
  a curric:Misconception ;
  curric:statement "Ozone layer and climate change are linked/the same thing."@en ;
  curric:correction """Ozone layer depletion was caused by human activity, but not through use of
  burning fossil fuels/greenhouse gas emissions. Both are atmospheric issues, but not the
  same issue."""@en ;
  dcterms:modified "2026-06-09T00:46:22.121338Z"^^xsd:dateTime .

oakcurric:misconception-forgetting-measure-initial-mass-burner
  a curric:Misconception ;
  curric:statement """Forgetting to measure the initial mass of the burner and initial temperature
  of the water."""@en ;
  curric:correction """Emphasise the importance in remembering to measure this data when writing a
  method for this practical."""@en ;
  dcterms:modified "2026-06-09T00:46:22.122119Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-chemical-formulae-changed
  a curric:Misconception ;
  curric:statement """Pupils sometimes think that chemical formulae can be changed to
  balance atoms."""@en ;
  curric:correction """Put boxes around each formula in the equation / pretend there is a bucket of
  pre-made molecules which they can use to balance the number of atoms on each side. Stress
  that it takes perseverance and practice before equations are balanced."""@en ;
  dcterms:modified "2026-06-09T00:46:22.128383Z"^^xsd:dateTime .

oakcurric:misconception-confusion-models-order-conceived-pupils
  a curric:Misconception ;
  curric:statement """Confusion between the models and the order in which they were conceived. Also,
  pupils often mix up which subatomic particles are present in each model."""@en ;
  curric:correction """Practise is required listing the key features of each model and the subatomic
  particles present. A timeline with the key features present helps pupils to understand the
  process of discovery and how long this can take."""@en ;
  dcterms:modified "2026-06-09T00:46:22.128814Z"^^xsd:dateTime .

oakcurric:misconception-understanding-way-electrons-flow-electric
  a curric:Misconception ;
  curric:statement """Understanding which way the electrons flow in the electric cell and explaining
  why the voltage is sometimes recorded as negative."""@en ;
  curric:correction """The more reactive metal is always oxidised, i.e. looses electrons which flow
  towards the less reactive metal. Demonstrate that a negative voltage is seen when the
  electrical leads connected to the voltmeter are swapped around."""@en ;
  dcterms:modified "2026-06-09T00:46:22.129492Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-recall-order-steps
  a curric:Misconception ;
  curric:statement """Pupils struggle to recall the order of steps required to mathematically
  process the available information in order to answer the question."""@en ;
  curric:correction """Colour-coding the steps can help pupils remember how many steps are involved.
  Much practice and perseverance is needed to create and maintain the memory pathway of the
  mathematical processing."""@en ;
  dcterms:modified "2026-06-09T00:46:22.133039Z"^^xsd:dateTime .

oakcurric:misconception-students-think-prefix-hydro-term
  a curric:Misconception ;
  curric:statement """Students often think that the prefix hydro- in the term hydrocarbons means
  they contain water; also that hydrocarbons and crude oil are synonymous."""@en ;
  curric:correction """Use diagrams to show hydrocarbon composition and compare crude oil to pure
  hydrocarbons, highlighting the difference visually."""@en ;
  dcterms:modified "2026-06-09T00:46:22.133045Z"^^xsd:dateTime .

oakcurric:misconception-collision-reactant-particles-results-chemical
  a curric:Misconception ;
  curric:statement """That every collision between reactant particles results in a chemical
  reaction."""@en ;
  curric:correction """The slide deck addresses that not every collision between reactant particles
  results in a chemical reaction. The particles must collide with the activation energy in
  order for the collision to be successful and a new product be formed."""@en ;
  dcterms:modified "2026-06-09T00:46:22.133059Z"^^xsd:dateTime .

oakcurric:misconception-pupils-rarely-consider-choice-equipment
  a curric:Misconception ;
  curric:statement """Pupils rarely consider the choice of equipment and its link to the accuracy of
  the data they collect in a practical."""@en ;
  curric:correction """Highlight that equipment with smaller resolution provides more precise
  measurements, which can decrease the uncertainty of a calculated mean."""@en ;
  dcterms:modified "2026-06-09T00:46:22.134925Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-metals-react-vigorously
  a curric:Misconception ;
  curric:statement """Pupils may think all metals react vigorously with water, and may believe all
  transition metals form only one type of ion, and might think that all metals are equally
  good catalysts."""@en ;
  curric:correction """Unlike Group 1 metals, transition metals react slowly with water or not at
  all. Transition metals can form ions with different charges, leading to compounds with
  varying properties and colours. Each reaction will be catalysed best by one catalyst."""@en ;
  dcterms:modified "2026-06-09T00:46:22.142315Z"^^xsd:dateTime .

oakcurric:misconception-thinking-metal-acid-react-together
  a curric:Misconception ;
  curric:statement "Thinking that a metal and acid react together to produce salt and water."@en ;
  curric:correction """Use symbol equations to show how hydrogen is produced, rather than water, due
  to the absence of oxygen atoms."""@en ;
  dcterms:modified "2026-06-09T00:46:22.142322Z"^^xsd:dateTime .

oakcurric:misconception-getting-electrons-confused-many-side
  a curric:Misconception ;
  curric:statement """Getting the electrons confused; how many and which side of the half equations
  to write them on."""@en ;
  curric:correction """When writing a half equation, electrons should be added and not taken away
  and so should go on the side of the equation where they are added. All charges must cancel
  each other out and the atoms on each side of the equation balance."""@en ;
  dcterms:modified "2026-06-09T00:46:22.142789Z"^^xsd:dateTime .

oakcurric:misconception-show-spectator-ions-ionic-equation
  a curric:Misconception ;
  curric:statement "To show the spectator ions in an ionic equation."@en ;
  curric:correction """Spectator ions are ions that remain the same throughout a reaction. They are
  not included in the ionic equation."""@en ;
  dcterms:modified "2026-06-09T00:46:22.142798Z"^^xsd:dateTime .

oakcurric:misconception-pupils-incorrectly-interpret-subscript-stoichiometric
  a curric:Misconception ;
  curric:statement """Some pupils incorrectly interpret subscript and stoichiometric values in a
  balanced symbol equation."""@en ;
  curric:correction """Both subscript and stoichiometric values represent ratios. Subscripts
  indicate ratios *within* substances; stoichiometry. Molar ratios *between* substances in a
  reaction. Much practice distinguishing between/ interpreting these is time well spent."""@en ;
  dcterms:modified "2026-06-09T00:46:22.142822Z"^^xsd:dateTime .

oakcurric:misconception-covalent-bond-shared-pair-electrons
  a curric:Misconception ;
  curric:statement """The covalent bond is the shared pair of electrons; both electrons must come
  from different atoms. The central atom is responsible for the formation of covalent bonds
  as they want a full outer shell."""@en ;
  curric:correction """All chemical bonds are an electrostatic force of attraction between positive
  and negative charges. The sharing of electrons is the process by which covalent bonds are
  formed. Avoid using anthropomorphic analogies to explain how covalent bonds form."""@en ;
  dcterms:modified "2026-06-09T00:46:22.142858Z"^^xsd:dateTime .

oakcurric:misconception-greenhouse-gases-artificial-harmful-increasing
  a curric:Misconception ;
  curric:statement """All greenhouse gases are artificial and harmful. Increasing any greenhouse gas
  is bad."""@en ;
  curric:correction """Emphasise and explain the natural occurrence and necessity of greenhouse
  gases. Discuss the effect of human activity increasing amounts of greenhouse gases at a
  very fast rate."""@en ;
  dcterms:modified "2026-06-09T00:46:22.143101Z"^^xsd:dateTime .

oakcurric:misconception-understanding-models-used-represent-chemical
  a curric:Misconception ;
  curric:statement """Understanding that the models used to represent chemical story do not tell the
  complete story. Different models can be used to explain different aspects of bonding, but
  they all have limitations."""@en ;
  curric:correction """Avoid telling your class that the model is wrong; rather stress its
  limitations. Stress the idea that as we learn more about bonding, we will be able to use
  more sophisticated models to show and explain more key ideas."""@en ;
  dcterms:modified "2026-06-09T00:46:22.143742Z"^^xsd:dateTime .

oakcurric:misconception-plants-absorb-carbon-dioxide-human
  a curric:Misconception ;
  curric:statement """Plants can absorb all of the carbon dioxide that human activity adds to the
  atmosphere."""@en ;
  curric:correction """Talk to the pupils about what happens to the carbon dioxide absorbed by
  plants so that they understand how the size and number of plants determine the maximum
  amount of carbon dioxide they can store."""@en ;
  dcterms:modified "2026-06-09T00:46:22.145120Z"^^xsd:dateTime .

oakcurric:misconception-ions-formed-because-atoms-want
  a curric:Misconception ;
  curric:statement """Ions are not formed because atoms 'want' or 'need' a full outer electron
  shell. Pupils often find standard notation difficult and get confused about when to use
  superscript and subscript."""@en ;
  curric:correction """It is important that pupils understand that atoms do not have 'wants' or
  'needs'. Emphasise that the driving force for the formation of atoms is an increase in
  stability when the outer electron shell is full."""@en ;
  dcterms:modified "2026-06-09T00:46:22.146303Z"^^xsd:dateTime .

oakcurric:misconception-climate-change-leads-hotter-weather
  a curric:Misconception ;
  curric:statement """Climate change only leads to hotter weather. Human activity has a negligible
  impact on climate change."""@en ;
  curric:correction """Explain the diverse effects of climate change, including extreme weather.
  Highlight the significant role of human activity in accelerating climate change."""@en ;
  dcterms:modified "2026-06-09T00:46:22.146492Z"^^xsd:dateTime .

oakcurric:misconception-calculate-instantaneous-rate-reaction-reading
  a curric:Misconception ;
  curric:statement """To calculate the instantaneous rate of reaction by reading values from the
  graph at a specific time."""@en ;
  curric:correction """Students need to draw a tangent in order to calculate the gradient of the
  graph at a specific time to work out the instantaneous rate of reaction."""@en ;
  dcterms:modified "2026-06-09T00:46:22.146498Z"^^xsd:dateTime .

oakcurric:misconception-cracking-same-fractional-distillation
  a curric:Misconception ;
  curric:statement "Cracking is the same as fractional distillation."@en ;
  curric:correction """Fractional distillation separates hydrocarbons based on their boiling points.
  Cracking alters the molecular formula of compounds."""@en ;
  dcterms:modified "2026-06-09T00:46:22.146504Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-particles-within-liquid
  a curric:Misconception ;
  curric:statement """Pupils often think that the particles within the liquid will have melted or
  boiled rather than remain the same size and shape, i.e. atoms do not have bulk properties
  like melting and boiling points."""@en ;
  curric:correction """Ensure that you specifically say that the particles themselves will not melt
  or boil."""@en ;
  dcterms:modified "2026-06-09T00:46:22.146509Z"^^xsd:dateTime .

oakcurric:misconception-pupils-appreciate-difference-using-inert
  a curric:Misconception ;
  curric:statement """Pupils do not always appreciate the difference between using inert carbon
  electrodes and metal electrodes, which will take part in the reaction."""@en ;
  curric:correction """Provide pupils with the opportunity to investigate the electrolysis of copper
  sulfate with both inert electrodes and with copper electrodes and then compare the
  results."""@en ;
  dcterms:modified "2026-06-09T00:46:22.146515Z"^^xsd:dateTime .

oakcurric:misconception-think-because-solute-longer-seen
  a curric:Misconception ;
  curric:statement """Some think that because a solute can no longer be seen, or that a solvent
  becomes coloured when a solute dissolves, that the creation of a solution is a chemical
  change."""@en ;
  curric:correction """Create a salt solution, then evaporate the water (leaving salt crystals) to
  demonstrate that the salt and water have not chemically combined and therefore dissolving
  (to create a solution) is a physical change."""@en ;
  dcterms:modified "2026-06-09T00:46:22.146524Z"^^xsd:dateTime .

oakcurric:misconception-pupils-use-their-titration-results
  a curric:Misconception ;
  curric:statement """Pupils use all of their titration results to calculate an average volume used
  during titration. Pupils also tend to miss steps in this multi-step process."""@en ;
  curric:correction """Stress the need to use concordant results when calculating an average volume
  for neutralising a solution via titration. Use a calculation grid to help keep each
  calculation step clearly organised."""@en ;
  dcterms:modified "2026-06-09T00:46:22.146530Z"^^xsd:dateTime .

oakcurric:misconception-students-think-carbon-allotrope-discoveries
  a curric:Misconception ;
  curric:statement """Students may think that all carbon allotrope discoveries were recent and that
  these materials are primarily used in cutting-edge, futuristic applications."""@en ;
  curric:correction """Emphasise the timeline of discoveries (graphite > fullerenes > nanotubes >
  graphene), highlighting theoretical predictions preceding isolation. Discuss current uses
  (e.g. nanotubes in sporting equipment) alongside potential future breakthroughs."""@en ;
  dcterms:modified "2026-06-09T00:46:22.146538Z"^^xsd:dateTime .

oakcurric:misconception-pupils-regularly-think-neutralisation-produces
  a curric:Misconception ;
  curric:statement """Pupils regularly think that neutralisation produces a neutral (i.e. pH 7)
  solution."""@en ;
  curric:correction """Stress that neutralisation occurs from a complete reaction between an acid
  and base, which usually occurs between strong acids and strong bases. If a weak acid or
  weak base is used, the salt solution produced may be alkaline or acidic respectively."""@en ;
  dcterms:modified "2026-06-09T00:46:22.146719Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-covalent-bonds-broken
  a curric:Misconception ;
  curric:statement """Pupils often think that covalent bonds are broken when any covalent structure
  undergoes a change of state; not just those in giant covalent structures."""@en ;
  curric:correction """Use physical models to show the difference between a simple covalent
  structure and a giant covalent structure. Explain that it is the weak intermolecular
  forces that are overcome when a simple covalent molecule changes state."""@en ;
  dcterms:modified "2026-06-09T00:46:22.146725Z"^^xsd:dateTime .

oakcurric:misconception-individuals-helpless-combatting-climate-change
  a curric:Misconception ;
  curric:statement """As individuals we are helpless in combatting climate change. Technology alone
  can solve climate issues."""@en ;
  curric:correction """Emphasise the impact of collective individual actions, especially in
  supporting national and international actions (including legislation) that cause
  appropriate change."""@en ;
  dcterms:modified "2026-06-09T00:46:22.146731Z"^^xsd:dateTime .

oakcurric:misconception-students-believe-rusting-refers-oxidation
  a curric:Misconception ;
  curric:statement """Students often believe rusting refers to the oxidation of any metal, and that
  corrosion is linked to the hazard 'corrosive'."""@en ;
  curric:correction """Highlight the conditions required for rusting, and the general description of
  corrosion."""@en ;
  dcterms:modified "2026-06-09T00:46:22.146739Z"^^xsd:dateTime .

oakcurric:misconception-ionic-equations-include-ions-involved
  a curric:Misconception ;
  curric:statement """Ionic equations only include ions involved in the reaction, not all ions in
  the reaction mixture."""@en ;
  curric:correction "Stress the difference between reacting ions and spectator ions."@en ;
  dcterms:modified "2026-06-09T00:46:22.146745Z"^^xsd:dateTime .

oakcurric:misconception-students-think-fractional-distillation-produces
  a curric:Misconception ;
  curric:statement """Some students may think that fractional distillation produces new substances
  from crude oil."""@en ;
  curric:correction """It is important to emphasise that crude oil is a mixture, and the process of
  fractional distillation is to separate out the different hydrocarbons based on their
  boiling points."""@en ;
  dcterms:modified "2026-06-09T00:46:22.146781Z"^^xsd:dateTime .

oakcurric:misconception-higher-temperature-pressure-increases-yield
  a curric:Misconception ;
  curric:statement """Higher temperature/pressure always increases the yield of products in
  equilibrium reactions."""@en ;
  curric:correction """High temperature can decrease yield in exothermic reactions by shifting
  equilibrium toward reactants; high pressures can decrease yield where there are fewer
  gaseous moles of reactants than products."""@en ;
  dcterms:modified "2026-06-09T00:46:22.146956Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-particles-embedded-substance
  a curric:Misconception ;
  curric:statement """Pupils often think that the particles are embedded in the substance rather
  than being the substance. Most pupils think that substances in the liquid state will
  compress a little."""@en ;
  curric:correction """Reinforce that most substances can exist in all three states of matter and
  when they are in the gas state there is nothing between the particles but empty space."""@en ;
  dcterms:modified "2026-06-09T00:46:22.147070Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-electrolysis-charge-carriers
  a curric:Misconception ;
  curric:statement """Pupils often think that, during electrolysis, the charge carriers are
  electrons and not ions."""@en ;
  curric:correction """Revisit the structure of ionic compounds in the solid and liquid states.
  Point out that there are no delocalised electrons. The electrons are associated with ions
  and so are unable to move through the electrolyte. Ions can move in the liquid state."""@en ;
  dcterms:modified "2026-06-09T00:46:22.147076Z"^^xsd:dateTime .

oakcurric:misconception-students-struggle-distinguish-phytoextraction-bioleaching
  a curric:Misconception ;
  curric:statement "Students struggle to distinguish between phytoextraction and bioleaching."@en ;
  curric:correction "Reinforce that the term 'phyto' is a combining form meaning 'plant'."@en ;
  dcterms:modified "2026-06-09T00:46:22.147082Z"^^xsd:dateTime .

oakcurric:misconception-students-assume-production-sulfuric-acid
  a curric:Misconception ;
  curric:statement """Students often assume that the production of sulfuric acid in the Contact
  Process is a one-step process (similar to the Haber process)."""@en ;
  curric:correction """Clarify that the Contact Process involves multiple stages, each requiring
  specific conditions. Emphasise the importance of these conditions in maximising yield and
  minimising energy consumption."""@en ;
  dcterms:modified "2026-06-09T00:46:22.147088Z"^^xsd:dateTime .

oakcurric:misconception-pupils-tend-think-water-same
  a curric:Misconception ;
  curric:statement """Pupils tend to think that all water is the same. Pupils tend to forget that
  non-visible substances are also found in water."""@en ;
  curric:correction """Stress that pure water only contains H₂O molecules. Other types of water may
  include varying amounts of dissolved salts, other solids or micro-organisms. Stress that
  microbes must be killed for water to be potable, but are too difficult to remove."""@en ;
  dcterms:modified "2026-06-09T00:46:22.147094Z"^^xsd:dateTime .

oakcurric:misconception-pupils-confuse-oxidation-reduction-involving
  a curric:Misconception ;
  curric:statement """Pupils can confuse oxidation and reduction when involving electrons. They
  often mistake a positive charge on an ion as meaning electrons have been added and vice
  versa for negative ions."""@en ;
  curric:correction """It is very important to teach from first principles what causes the charges
  and then work up to half equations where the pupils can see the electrons in the
  equations, finally combining these to form ionic equations."""@en ;
  dcterms:modified "2026-06-09T00:46:22.147100Z"^^xsd:dateTime .

oakcurric:misconception-thinking-dna-made-single-polymer
  a curric:Misconception ;
  curric:statement "Thinking that DNA is made of a single polymer chain."@en ;
  curric:correction """Use the slides and a model to reinforce that DNA contains two polymer chains
  in a double helix structure."""@en ;
  dcterms:modified "2026-06-09T00:46:22.147106Z"^^xsd:dateTime .

oakcurric:misconception-industrial-activities-contribute-atmospheric-pollution
  a curric:Misconception ;
  curric:statement """Only industrial activities contribute to atmospheric pollution. Atmospheric
  pollutants are always visible."""@en ;
  curric:correction """Discuss natural sources of pollutants, like volcanoes. Explain that many
  harmful pollutants are invisible."""@en ;
  dcterms:modified "2026-06-09T00:46:22.147156Z"^^xsd:dateTime .

oakcurric:misconception-thinking-oxidation-reduction-loss-gain
  a curric:Misconception ;
  curric:statement """Thinking that oxidation and reduction are only to do with the loss and gain of
  oxygen."""@en ;
  curric:correction """Oxidation is the loss of electrons or the gain of oxygen. Reduction is the
  gain of electrons or loss of oxygen."""@en ;
  dcterms:modified "2026-06-09T00:46:22.147235Z"^^xsd:dateTime .

oakcurric:misconception-adding-bung-top-conical-flask
  a curric:Misconception ;
  curric:statement """Adding a bung to the top of a conical flask does not affect volume
  measurements."""@en ;
  curric:correction """The bung can displace a small volume of gas, which can affect the accuracy of
  the measurements. It is essential to account for the volume displaced by the bung in
  calculations."""@en ;
  dcterms:modified "2026-06-09T00:46:22.147477Z"^^xsd:dateTime .

oakcurric:misconception-pupils-believe-periodic-table-devised
  a curric:Misconception ;
  curric:statement """Pupils often believe that the when the periodic table was devised, scientists
  knew about the subatomic particles."""@en ;
  curric:correction """Emphasise when the subatomic particles were discovered in comparison to when
  Mendeleev devised his periodic table."""@en ;
  dcterms:modified "2026-06-09T00:46:22.147485Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-nanoparticles-hazardous-without
  a curric:Misconception ;
  curric:statement """Pupils might think all nanoparticles are hazardous without considering their
  varied applications and benefits."""@en ;
  curric:correction """Clarify that while nanoparticles may pose risks, they also offer significant
  benefits in medicine, technology, and environmental protection, with risks varying by type
  and usage."""@en ;
  dcterms:modified "2026-06-09T00:46:22.147491Z"^^xsd:dateTime .

oakcurric:misconception-students-think-carbon-forms-alike
  a curric:Misconception ;
  curric:statement """Students may think all carbon forms are alike, ignoring structure's impact on
  properties."""@en ;
  curric:correction """Emphasise structure-property relationships. Use models to show how diamond's
  and graphite's differing bonds affect their characteristics."""@en ;
  dcterms:modified "2026-06-09T00:46:22.147500Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-understand-using-different
  a curric:Misconception ;
  curric:statement """Pupils sometimes struggle to understand how using different mobile and/or
  stationary phases affects the resulting chromatograms."""@en ;
  curric:correction """Perform chromatography of the same mixture using different mobile
  phases/stationary phases and discuss the pros/cons of each combination."""@en ;
  dcterms:modified "2026-06-09T00:46:22.147769Z"^^xsd:dateTime .

oakcurric:misconception-students-confuse-subatomic-particle-responsible
  a curric:Misconception ;
  curric:statement """Students often confuse the subatomic particle responsible for making an atom
  an isotope, and how isotopes are responsible for the relative atomic masses to 1 d.p."""@en ;
  curric:correction "Practice determining the number of neutrons in multiple isotopes."@en ;
  dcterms:modified "2026-06-09T00:46:22.147782Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-link-mole-number
  a curric:Misconception ;
  curric:statement "Pupils struggle to link a mole to number of particles."@en ;
  curric:correction """Use real world examples of converting volumes / masses into number of
  particles so pupils become more comfortable converting between moles, number of particles
  particles and masses."""@en ;
  dcterms:modified "2026-06-09T00:46:22.147790Z"^^xsd:dateTime .

oakcurric:misconception-catalysts-increase-amount-product-formed
  a curric:Misconception ;
  curric:statement "Catalysts increase the amount of product formed."@en ;
  curric:correction """Catalysts do not affect the quantity of products formed. They increase the
  rate at which the products are formed."""@en ;
  dcterms:modified "2026-06-09T00:46:22.147797Z"^^xsd:dateTime .

oakcurric:misconception-students-think-carbon-allotropes-giant
  a curric:Misconception ;
  curric:statement """Students may think all carbon allotropes have giant covalent structures due to
  strong covalent bonds."""@en ;
  curric:correction """Emphasise that fullerenes and nanotubes, unlike graphene and diamond, have
  discrete molecular structures."""@en ;
  dcterms:modified "2026-06-09T00:46:22.147825Z"^^xsd:dateTime .

oakcurric:misconception-understanding-why-carbon-dioxide-produced
  a curric:Misconception ;
  curric:statement """Understanding why carbon dioxide is produced at the anode, when there is no
  carbon in aluminium oxide."""@en ;
  curric:correction """Remind students of previous knowledge about combustion reactions. Help them
  to apply this knowledge to this new situation in the electrolysis cell."""@en ;
  dcterms:modified "2026-06-09T00:46:22.147831Z"^^xsd:dateTime .

oakcurric:misconception-pupils-confuse-physical-chemical-changes
  a curric:Misconception ;
  curric:statement """Pupils often confuse physical and chemical changes and think that all
  particles look and act like those shown in the particle model."""@en ;
  curric:correction """Give the pupils an array of different examples of physical and chemical
  reactions and get the pupils to consider if new substances have been produced. Show the
  pupils, using molymods, how different molecules can be."""@en ;
  dcterms:modified "2026-06-09T00:46:22.147837Z"^^xsd:dateTime .

oakcurric:misconception-pupils-forget-gases-produced-metals
  a curric:Misconception ;
  curric:statement """Pupils often forget that gases are produced when metals and metal carbonates
  react with acids."""@en ;
  curric:correction """Emphasise the tests for the gases as a way to remember that they are
  produced. Writing balanced symbol equations also helps as the pupils can see what elements
  would be present in the products formed."""@en ;
  dcterms:modified "2026-06-09T00:46:22.148037Z"^^xsd:dateTime .

oakcurric:misconception-lcas-measure-carbon-footprint-product
  a curric:Misconception ;
  curric:statement "LCAs only measure the carbon footprint of a product."@en ;
  curric:correction """The slide deck addresses what is included in a LCA such as energy use, water
  use and pollutants released."""@en ;
  dcterms:modified "2026-06-09T00:46:22.148166Z"^^xsd:dateTime .

oakcurric:misconception-ammonia-ammonium-same-thing
  a curric:Misconception ;
  curric:statement "Ammonia and ammonium are the same thing."@en ;
  curric:correction """Carefully compare the different chemical formulae, structures, and distinct
  uses in fertilisers vs. industrial applications. Use visual aids to reinforce these
  differences."""@en ;
  dcterms:modified "2026-06-09T00:46:22.148173Z"^^xsd:dateTime .

oakcurric:misconception-pupils-find-hard-remember-formed
  a curric:Misconception ;
  curric:statement "Pupils find it hard to remember what is formed at each electrode."@en ;
  curric:correction """Remind pupils about the electrolysis rules and provide opportunities for them
  to apply the rules to different electrolytes. Use animations to show the ions present in
  brine and how they move in the electrolysis cell."""@en ;
  dcterms:modified "2026-06-09T00:46:22.148508Z"^^xsd:dateTime .

oakcurric:misconception-students-believing-sustainability-someone-elses
  a curric:Misconception ;
  curric:statement "Students believing that sustainability is someone else's responsibility."@en ;
  curric:correction """Everyone needs to reduce, reuse and recycle to ensure sustainable
  development. The slide deck gives examples of products that can be recycled and the
  benefits of reducing, reusing and recycling."""@en ;
  dcterms:modified "2026-06-09T00:46:22.148514Z"^^xsd:dateTime .

oakcurric:misconception-several-misconceptions-associated-properties-such
  a curric:Misconception ;
  curric:statement """There are several misconceptions associated with properties such as when
  something dissolves it disappears, electrical conductivity is a flow of electrons rather
  than charge."""@en ;
  curric:correction """When discussing electrical conductivity, emphasise the idea of electrical
  conductivity being a flow charge with ions behaving as charge carriers. The electron
  transfer that occurs during ion formation is nothing to do with conductivity."""@en ;
  dcterms:modified "2026-06-09T00:46:22.148522Z"^^xsd:dateTime .

oakcurric:misconception-atmosphere-mostly-oxygen-same-atmospheric
  a curric:Misconception ;
  curric:statement """The atmosphere is mostly oxygen. The same atmospheric conditions exist at all
  heights."""@en ;
  curric:correction """Explain that the atmosphere is ~80% nitrogen and ~20% oxygen. Discuss how
  atmospheric conditions vary with altitude, affecting oxygen availability."""@en ;
  dcterms:modified "2026-06-09T00:46:22.148537Z"^^xsd:dateTime .

oakcurric:misconception-combustion-complete-producing-co-water
  a curric:Misconception ;
  curric:statement "All combustion is complete, producing only CO₂ and water."@en ;
  curric:correction "Highlight the differences between complete and incomplete combustion."@en ;
  dcterms:modified "2026-06-09T00:46:22.148545Z"^^xsd:dateTime .

oakcurric:misconception-pupils-confuse-energy-temperature-therefore
  a curric:Misconception ;
  curric:statement """Pupils often confuse energy with temperature and therefore expect the products
  to be higher than the reactants for exothermic reactions i.e. due to temperature increase,
  and lower for endothermic."""@en ;
  curric:correction """It is useful to discuss the energy transfers occurring during the reaction
  e.g. exothermic reactions involve the reactant's chemical energy store converting to a
  smaller chemical energy store in the products and a thermal energy store."""@en ;
  dcterms:modified "2026-06-09T00:46:22.148608Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-understand-taking-place
  a curric:Misconception ;
  curric:statement """Pupils struggle to understand what is taking place at the horizontal parts of
  the graph."""@en ;
  curric:correction """Be concise with your language and ask pupils to use the same language. 'have
  enough energy to overcome the forces of attraction between particles', 'to slide past each
  other', 'to move past each other'."""@en ;
  dcterms:modified "2026-06-09T00:46:22.148614Z"^^xsd:dateTime .

oakcurric:misconception-pupils-mistake-excess-base-salt
  a curric:Misconception ;
  curric:statement """Pupils can sometimes mistake the excess base for the salt formed as it is a
  solid."""@en ;
  curric:correction """Emphasise at the beginning of the experiment what soluble means and that the
  salt will be initially obtained dissolved in water."""@en ;
  dcterms:modified "2026-06-09T00:46:22.148620Z"^^xsd:dateTime .

oakcurric:misconception-students-find-difficult-understand-why
  a curric:Misconception ;
  curric:statement """Students find it difficult to understand why continuous removal of ammonia is
  required to increase yield."""@en ;
  curric:correction """Highlight that the Haber Process is a dynamic equilibrium. If ammonia is not
  continuously removed, the equilibrium will shift back towards the reactants, reducing the
  yield."""@en ;
  dcterms:modified "2026-06-09T00:46:22.148806Z"^^xsd:dateTime .

oakcurric:misconception-pupils-understand-gas-state-thinking
  a curric:Misconception ;
  curric:statement """Pupils to understand gas state; thinking solids, liquids and gases as 'types'
  of matter."""@en ;
  curric:correction """Refer to/use particle models to help clarify different states of matter and
  use these to describe why separation techniques work."""@en ;
  dcterms:modified "2026-06-09T00:46:22.148818Z"^^xsd:dateTime .

oakcurric:misconception-metal-individual-atom-property-metal
  a curric:Misconception ;
  curric:statement """A metal is an individual atom. The property of a metal atom is the same as the
  bulk material. Pupils get confused between the attractive forces in the metal atoms and
  the metallic bond."""@en ;
  curric:correction """Reinforce the idea that atoms are tiny and not visible to the naked eye. The
  material we know as metal is many millions of atoms joined together. Revisit the structure
  of the atoms before introducing the idea of metallic bonding and giant structure."""@en ;
  dcterms:modified "2026-06-09T00:46:22.148824Z"^^xsd:dateTime .

oakcurric:misconception-pupils-use-incorrect-mathematical-relationship
  a curric:Misconception ;
  curric:statement """Pupils use an incorrect mathematical relationship to calculate the number of
  moles in a sample."""@en ;
  curric:correction """Depending on the type of substance (solid, solution or gas) a specific
  mathematical relationship for moles must be used. Challenge pupils to classify substances
  as (s), (aq), or (g) and apply correct mathematical relationship."""@en ;
  dcterms:modified "2026-06-09T00:46:22.148938Z"^^xsd:dateTime .

oakcurric:misconception-pupils-confuse-percentage-yield-atom
  a curric:Misconception ;
  curric:statement """Pupils often confuse percentage yield with atom economy, thinking both measure
  the same efficiency aspect."""@en ;
  curric:correction """Clarify that percentage yield measures actual vs. theoretical product amount,
  while atom economy measures reactants' mass converted to desired product."""@en ;
  dcterms:modified "2026-06-09T00:46:22.148943Z"^^xsd:dateTime .

oakcurric:misconception-pupils-believe-acids-eat-substances
  a curric:Misconception ;
  curric:statement """Pupils often believe that acids 'eat' away at substances, e.g. acid rain and
  limestone, rather than understanding that this is a chemical reaction."""@en ;
  curric:correction """Using familiar reactions between acids and bases, e.g. hydrochloric acid and
  sodium hydroxide or calcium carbonate, will provide evidence that a reaction has taken
  place (i.e. a change in temperature or producing a gas)."""@en ;
  dcterms:modified "2026-06-09T00:46:22.148960Z"^^xsd:dateTime .

oakcurric:misconception-pupils-find-difficult-apply-learnt
  a curric:Misconception ;
  curric:statement """Pupils often find it difficult to apply what they have learnt about alloys
  when asked about an unfamiliar one, or when provided with a table of data."""@en ;
  curric:correction """Provide pupils with a range of different examples of alloys. Give them plenty
  of practice of comparing the properties of the alloy with those of the pure metal."""@en ;
  dcterms:modified "2026-06-09T00:46:22.149258Z"^^xsd:dateTime .

oakcurric:misconception-pupils-confuse-trend-reactivity-group
  a curric:Misconception ;
  curric:statement "Pupils can confuse the trend in reactivity down the group."@en ;
  curric:correction """The practical reacting the metals with water helps to memorably demonstrate
  the trend, however it is important to ensure that pupils can explain why this happens."""@en ;
  dcterms:modified "2026-06-09T00:46:22.149464Z"^^xsd:dateTime .

oakcurric:misconception-pupils-fail-understand-excess-reactant
  a curric:Misconception ;
  curric:statement """Pupils sometimes fail to understand that excess reactant particles remain in
  the reaction mixture after the reaction."""@en ;
  curric:correction """Provide a balanced equation and challenge pupils to draw diagrams of a final
  mixture, stressing that excess particles would also be present. Challenge pupils to
  consider how the product could be extracted from the excess particles."""@en ;
  dcterms:modified "2026-06-09T00:46:22.149478Z"^^xsd:dateTime .

oakcurric:misconception-earths-atmosphere-contained-oxygen-atmospheres
  a curric:Misconception ;
  curric:statement """Earth's atmosphere has always contained oxygen. The atmosphere's composition
  is static and unchanging."""@en ;
  curric:correction """Clarify the development of oxygen through photosynthesis. Describe how
  atmospheric composition has evolved over time due to geological and biological processes."""@en ;
  dcterms:modified "2026-06-09T00:46:22.149601Z"^^xsd:dateTime .

oakcurric:misconception-metallic-structure-model-replication-reality
  a curric:Misconception ;
  curric:statement """The metallic structure model is a replication of reality. Therefore, metals
  contain seawater. The concept of electric current is challenging. Some may think that
  electrons jump from atom to atom."""@en ;
  curric:correction """Discuss why scientists use models with the pupils, explaining that a model is
  only as good as what it can explain, so it develops over time. Remind pupils how an
  electric circuit works before discussing why metals are good conductors."""@en ;
  dcterms:modified "2026-06-09T00:46:22.149607Z"^^xsd:dateTime .

oakcurric:misconception-pupils-appreciate-safety-laboratory-shared
  a curric:Misconception ;
  curric:statement """Pupils do not always appreciate that safety in the laboratory is a shared
  responsibility."""@en ;
  curric:correction """Ensure pupils understand the hazards related to both common chemicals and
  regularly used equipment."""@en ;
  dcterms:modified "2026-06-09T00:46:22.149855Z"^^xsd:dateTime .

oakcurric:misconception-pupils-rush-calculations-forget-take
  a curric:Misconception ;
  curric:statement """Pupils sometimes rush these calculations and forget to take note of
  the units."""@en ;
  curric:correction """Remind pupils that units provide the comparison standard for values. Much
  practice ensuring the correct molar gas volume value is used in calculations is necessary."""@en ;
  dcterms:modified "2026-06-09T00:46:22.150032Z"^^xsd:dateTime .

oakcurric:misconception-confusing-electrode-reactions-occur-electrolysis
  a curric:Misconception ;
  curric:statement """Confusing electrode reactions with those that occur in electrolysis. For
  example in a hydrogen fuel cell, hydrogen is oxidised at the anode but in electrolysis,
  hydrogen is produced at the cathode."""@en ;
  curric:correction """Discuss the electrode reactions in terms of electron loss or gain; rather
  that just relying on memory. This will provide pupils with the tools to work out the
  electrode reactions."""@en ;
  dcterms:modified "2026-06-09T00:46:22.150038Z"^^xsd:dateTime .

oakcurric:misconception-pupils-make-mistakes-identifying-different
  a curric:Misconception ;
  curric:statement """Pupils often make mistakes when identifying the different types of bonds and
  the number of each in a molecule. They may also reverse the calculation of the overall
  energy change, as make - break."""@en ;
  curric:correction """Molecules can be complex and should be drawn to show all the bonds. Emphasis
  that double and triple covalent bonds are different to single bonds. Pupils should be
  instructed to consider whether a reaction is exothermic or endothermic."""@en ;
  dcterms:modified "2026-06-09T00:46:22.150871Z"^^xsd:dateTime .

oakcurric:misconception-pupils-forget-halogens-diatomic-molecules
  a curric:Misconception ;
  curric:statement "Pupils often forget that the halogens are diatomic molecules."@en ;
  curric:correction """Explanation of the bonding to form molecules helps to explain why they exist
  as diatomic molecules."""@en ;
  dcterms:modified "2026-06-09T00:46:22.151044Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-simply-ensuring-fair
  a curric:Misconception ;
  curric:statement """Pupils think that simply ensuring a fair test will improve data collecting in
  a practical."""@en ;
  curric:correction """Evaluating a practical is an often overlooked skill. Challenge pupils to
  focus on the equipment chosen and/or the method followed to consider how better data might
  be collected."""@en ;
  dcterms:modified "2026-06-09T00:46:22.151362Z"^^xsd:dateTime .

oakcurric:misconception-pupils-confuse-chemistry-meaning-strong
  a curric:Misconception ;
  curric:statement """Pupils often confuse the chemistry meaning of strong/weak and
  concentrated/dilute due to the use of these words in everyday conversation."""@en ;
  curric:correction """Clear definitions of the words are required with practice opportunities to
  recognise/describe whether the substances are strong or weak acids and if concentrated or
  dilute."""@en ;
  dcterms:modified "2026-06-09T00:46:22.151579Z"^^xsd:dateTime .

oakcurric:misconception-students-think-glass-types-same
  a curric:Misconception ;
  curric:statement """Students often think: all glass types have the same properties and uses;
  polyethene types are identical in structure and use; and composites are simple mixtures
  (not engineered materials)."""@en ;
  curric:correction """Clarify that soda-lime and borosilicate glass differ in production and use.
  Explain the distinct processes and uses of LDPE and HDPE. Describe how composites are
  engineered to achieve specific properties."""@en ;
  dcterms:modified "2026-06-09T00:46:22.151917Z"^^xsd:dateTime .

oakcurric:misconception-water-samples-boil-100-c
  a curric:Misconception ;
  curric:statement "All water samples boil at 100°C."@en ;
  curric:correction """If a water sample is impure, the boiling point of water increases. The
  greater the amount of impurities in a water sample, the larger the temperature range over
  which it boils."""@en ;
  dcterms:modified "2026-06-09T00:46:22.152239Z"^^xsd:dateTime .

oakcurric:misconception-students-confuse-percentage-yield-atom
  a curric:Misconception ;
  curric:statement """Students often confuse percentage yield with atom economy, thinking both
  measure the same efficiency aspect."""@en ;
  curric:correction """Clarify that percentage yield measures actual vs. theoretical product amount,
  while atom economy measures reactants' mass converted to desired product."""@en ;
  dcterms:modified "2026-06-09T00:46:22.153471Z"^^xsd:dateTime .

oakcurric:misconception-students-struggle-distinguish-phytomining-bioleaching
  a curric:Misconception ;
  curric:statement "Students struggle to distinguish between phytomining and bioleaching."@en ;
  curric:correction "Reinforce that the term 'phyto' is a combining form meaning 'plant'."@en ;
  dcterms:modified "2026-06-09T00:46:22.154707Z"^^xsd:dateTime .

oakcurric:misconception-ionic-compounds-dissociate-completely-aqueous
  a curric:Misconception ;
  curric:statement "All ionic compounds dissociate completely in aqueous solutions."@en ;
  curric:correction """Not all ionic compounds dissociate completely in water; some may not dissolve
  at all. It's important to know the solubility rules to correctly predict the behaviour of
  compounds in solution."""@en ;
  dcterms:modified "2026-06-09T00:46:22.155374Z"^^xsd:dateTime .

oakcurric:misconception-peaks-mass-spectrum-represent-intact
  a curric:Misconception ;
  curric:statement """All peaks in a mass spectrum represent intact (and neutral) molecules or
  atoms."""@en ;
  curric:correction """Clarify that in mass spectrometry, all detected peaks represent ionised
  species, not neutral molecules or atoms. The peaks can correspond to either the molecular
  ion (M⁺) or smaller ionised fragments, as well as different isotopes of an element."""@en ;
  dcterms:modified "2026-06-09T00:46:22.159357Z"^^xsd:dateTime .
