  schema:description """A salt that does not contain any water molecules in the crystal structure,
  e.g. anhydrous copper(II) sulfate (CuSO₄)."""@en ;
  dcterms:modified "2026-06-07T15:30:02.371680Z"^^xsd:dateTime .

oakcurric:keyword-double-headed-arrow
  a curric:Keyword ;
  schema:name "double-headed arrow (⇌)"@en ;
