  dcterms:modified "2026-06-07T15:30:02.417346Z"^^xsd:dateTime .

oakcurric:keyword-personalised-medicine
  a curric:Keyword ;
  schema:name "personalised medicine"@en ;
  schema:description "healthcare tailored to a person’s individual risk of ill health"@en ;
  dcterms:modified "2026-06-07T15:30:02.417356Z"^^xsd:dateTime .

oakcurric:keyword-physiological
  a curric:Keyword ;
  schema:name "physiological"@en ;
  schema:description """Physiological adaptations are body processes that help an organism to
  survive and reproduce."""@en ;
  dcterms:modified "2026-06-07T15:30:02.417362Z"^^xsd:dateTime .

oakcurric:keyword-extremophile
  a curric:Keyword ;
  schema:name "extremophile"@en ;
  schema:description """Extremophiles are organisms that are able to successfully survive and
  reproduce in extreme environments (e.g. very hot/very cold)."""@en ;
  dcterms:modified "2026-06-07T15:30:02.417367Z"^^xsd:dateTime .

oakcurric:keyword-life-cycle-assessment
  a curric:Keyword ;
