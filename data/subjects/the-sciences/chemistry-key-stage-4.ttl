oakcurric:keylearningpoint-lesson-8326-5
  a curric:KeyLearningPoint ;
  rdfs:label """A spectrometer can measure more than one metal ion in a single solution and the
  concentration of each."""@en ;
  dcterms:modified "2026-06-09T00:46:37.510411Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9677-1
  a curric:KeyLearningPoint ;
  rdfs:label """Titration is a method used to completely neutralise an acid with a soluble base
  (alkali)."""@en ;
  dcterms:modified "2026-06-09T00:46:37.510677Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9677-2
  a curric:KeyLearningPoint ;
  rdfs:label """Titrations are performed using strong acids and strong alkalis to accurately
  determine reacting volumes."""@en ;
  dcterms:modified "2026-06-09T00:46:37.510682Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9677-3
  a curric:KeyLearningPoint ;
  rdfs:label "Strong acids and alkalis are completely ionised in an aqueous solution."@en ;
  dcterms:modified "2026-06-09T00:46:37.510687Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9677-4
  a curric:KeyLearningPoint ;
  rdfs:label "Each piece of apparatus in a titration has a specific and essential function."@en ;
  dcterms:modified "2026-06-09T00:46:37.510692Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9677-5
  a curric:KeyLearningPoint ;
  rdfs:label """A suitable indicator (not universal indicator) is used to identify the end point of
  the titration."""@en ;
  dcterms:modified "2026-06-09T00:46:37.510697Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9725-1
  a curric:KeyLearningPoint ;
  rdfs:label """Transition metals are generally stronger, harder, more dense and have higher melting
  points than Group 1 metals."""@en ;
  dcterms:modified "2026-06-09T00:46:37.515192Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9725-2
  a curric:KeyLearningPoint ;
