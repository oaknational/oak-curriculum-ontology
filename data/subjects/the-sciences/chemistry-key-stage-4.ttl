  dcterms:modified "2026-06-09T00:46:04.310727Z"^^xsd:dateTime .

oakcurric:keyword-raw-materials
  a curric:Keyword ;
  schema:name "raw materials"@en ;
  schema:description """The starting materials used to make products are known as the raw materials.
  Wood, metal and crude oil are examples of raw materials."""@en ;
  dcterms:modified "2026-06-09T00:46:04.312346Z"^^xsd:dateTime .

oakcurric:keyword-homologous-series
  a curric:Keyword ;
  schema:name "homologous series"@en ;
  schema:description """A homologous series of organic compounds have the same general formula, and
  show similar chemical properties and physical property trends."""@en ;
  dcterms:modified "2026-06-09T00:46:04.312352Z"^^xsd:dateTime .

oakcurric:keyword-functional-group
  a curric:Keyword ;
  schema:name "functional group"@en ;
  schema:description """The functional group is the atom or group of atoms responsible for the way a
  compound reacts."""@en ;
  dcterms:modified "2026-06-09T00:46:04.312357Z"^^xsd:dateTime .

oakcurric:keyword-carbon-sink
  a curric:Keyword ;
  schema:name "carbon sink"@en ;
  schema:description """a natural or artificial system that absorbs more carbon dioxide than it
  releases"""@en ;
  dcterms:modified "2026-06-09T00:46:04.312417Z"^^xsd:dateTime .

oakcurric:keyword-compress
  a curric:Keyword ;
  schema:name "compress"@en ;
  schema:description """To make something smaller using forces, e.g. a spring gets shorter when it
  is compressed."""@en ;
  dcterms:modified "2026-06-09T00:46:04.313227Z"^^xsd:dateTime .

oakcurric:keyword-alloy
  a curric:Keyword ;
  schema:name "alloy"@en ;
  schema:description "A mixture of two or more elements where at least one element is a metal."@en ;
  dcterms:modified "2026-06-09T00:46:04.313242Z"^^xsd:dateTime .

oakcurric:keyword-composite
  a curric:Keyword ;
  schema:name "composite"@en ;
  schema:description """A material made from two or more different types of materials. When combined
  they create a new material with improved properties."""@en ;
  dcterms:modified "2026-06-09T00:46:04.313250Z"^^xsd:dateTime .

oakcurric:keyword-unsaturated
  a curric:Keyword ;
  schema:name "unsaturated"@en ;
  schema:description """Unsaturated compounds contain at least one carbon-carbon double covalent
  bond."""@en ;
  dcterms:modified "2026-06-09T00:46:04.313255Z"^^xsd:dateTime .

oakcurric:keyword-saturated
  a curric:Keyword ;
  schema:name "saturated"@en ;
  schema:description """Alkanes are saturated hydrocarbons as they contain only single bonds between
  carbon and hydrogen atoms."""@en ;
  dcterms:modified "2026-06-09T00:46:04.313260Z"^^xsd:dateTime .

oakcurric:keyword-isomers
  a curric:Keyword ;
  schema:name "isomers"@en ;
  schema:description """Isomers are structures with the same molecular formula, but different
  arrangement of atoms in space."""@en ;
  dcterms:modified "2026-06-09T00:46:04.313265Z"^^xsd:dateTime .

oakcurric:keyword-alkenes
  a curric:Keyword ;
  schema:name "alkenes"@en ;
  schema:description """Alkenes are unsaturated hydrocarbons that contain the C=C functional
  group."""@en ;
  dcterms:modified "2026-06-09T00:46:04.313270Z"^^xsd:dateTime .

oakcurric:keyword-eutrophication
  a curric:Keyword ;
  schema:name "eutrophication"@en ;
  schema:description """Eutrophication is the process in which a body of water is overly enriched
  with plant nutrients. This leads to excessive growth of simple plants such as algae."""@en ;
  dcterms:modified "2026-06-09T00:46:04.313530Z"^^xsd:dateTime .

oakcurric:keyword-carboxylic-acids
  a curric:Keyword ;
  schema:name "carboxylic acids"@en ;
  schema:description """Carboxylic acids are a homologous series of compounds that contain the -COOH
  functional group."""@en ;
  dcterms:modified "2026-06-09T00:46:04.314194Z"^^xsd:dateTime .

oakcurric:keyword-weak-acids
  a curric:Keyword ;
  schema:name "weak acids"@en ;
  schema:description "Weak acids partially dissociate to form Hᐩ ions in solution."@en ;
  dcterms:modified "2026-06-09T00:46:04.314199Z"^^xsd:dateTime .

oakcurric:keyword-carbonate
  a curric:Keyword ;
  schema:name "carbonate"@en ;
  schema:description """A carbonate is a compound containing the CO₃²ᐨ ion. An example is calcium
  carbonate CaCO₃."""@en ;
  dcterms:modified "2026-06-09T00:46:04.314204Z"^^xsd:dateTime .

oakcurric:keyword-esters
  a curric:Keyword ;
  schema:name "esters"@en ;
  schema:description """Esters are a homologous series of compounds that contain the -COO-
  functional group."""@en ;
  dcterms:modified "2026-06-09T00:46:04.314209Z"^^xsd:dateTime .

oakcurric:keyword-ethyl-ethanoate
  a curric:Keyword ;
  schema:name "ethyl ethanoate"@en ;
  schema:description """Ethyl ethanoate is an ester produced from the alcohol ethanol and the
  carboxylic acid ethanoic acid."""@en ;
  dcterms:modified "2026-06-09T00:46:04.314217Z"^^xsd:dateTime .

oakcurric:keyword-monomers
  a curric:Keyword ;
  schema:name "monomers"@en ;
  schema:description "Monomers are small molecules that can join together to form a polymer."@en ;
  dcterms:modified "2026-06-09T00:46:04.314225Z"^^xsd:dateTime .

oakcurric:keyword-relative-molecular-mass
  a curric:Keyword ;
  schema:name "relative molecular mass"@en ;
  schema:description """The relative molecular mass of a substance is the sum of the relative atomic
  masses of all the atoms in a molecule."""@en ;
  dcterms:modified "2026-06-09T00:46:04.314231Z"^^xsd:dateTime .

oakcurric:keyword-addition-polymerisation
  a curric:Keyword ;
  schema:name "addition polymerisation"@en ;
  schema:description """Addition polymerisation is a type of polymerisation where monomers join
  together to form only one product; a polymer."""@en ;
  dcterms:modified "2026-06-09T00:46:04.314236Z"^^xsd:dateTime .

oakcurric:keyword-repeating-unit
  a curric:Keyword ;
  schema:name "repeating unit"@en ;
  schema:description "The section of a polymer that repeats is known as the repeating unit."@en ;
  dcterms:modified "2026-06-09T00:46:04.314241Z"^^xsd:dateTime .

oakcurric:keyword-impurity
  a curric:Keyword ;
  schema:name "impurity"@en ;
  schema:description """An impurity is a chemical that is found in a material in very small amounts,
  but can change the material's properties"""@en ;
  dcterms:modified "2026-06-09T00:46:04.315802Z"^^xsd:dateTime .

oakcurric:keyword-hydrocarbons
  a curric:Keyword ;
  schema:name "hydrocarbons"@en ;
  schema:description "Hydrocarbons are molecules made up of hydrogen and carbon atoms only."@en ;
  dcterms:modified "2026-06-09T00:46:04.316190Z"^^xsd:dateTime .

oakcurric:keyword-condensation-polymerisation
  a curric:Keyword ;
  schema:name "condensation polymerisation"@en ;
  schema:description """Condensation polymerisation is a type of polymerisation where monomers join
  together to form a polymer and a small molecule such as water."""@en ;
  dcterms:modified "2026-06-09T00:46:04.316868Z"^^xsd:dateTime .

oakcurric:keyword-polyesters
  a curric:Keyword ;
  schema:name "polyesters"@en ;
  schema:description """Polyesters are condensation polymers formed from monomers containing
  carboxylic acid and alcohol groups. They contain ester bonds."""@en ;
  dcterms:modified "2026-06-09T00:46:04.316873Z"^^xsd:dateTime .

oakcurric:keyword-polyamides
  a curric:Keyword ;
  schema:name "polyamides"@en ;
  schema:description """Polyamides are condensation polymers formed from monomers containing
  carboxylic acid and amine groups. They contain amide bonds."""@en ;
  dcterms:modified "2026-06-09T00:46:04.316878Z"^^xsd:dateTime .

oakcurric:keyword-polypeptides
  a curric:Keyword ;
  schema:name "polypeptides"@en ;
  schema:description """Polypeptides are condensation polymers formed from amino acids. They contain
  peptide bonds."""@en ;
  dcterms:modified "2026-06-09T00:46:04.316884Z"^^xsd:dateTime .

oakcurric:keyword-binary-ionic-substance
  a curric:Keyword ;
  schema:name "binary ionic substance"@en ;
  schema:description """is made up of two different elements, one of which is a metal and the other
  a non-metal element."""@en ;
  dcterms:modified "2026-06-09T00:46:04.318119Z"^^xsd:dateTime .

oakcurric:keyword-dot-and-cross-diagram
  a curric:Keyword ;
  schema:name "dot-and-cross diagram"@en ;
  schema:description """is used to show how chemical bonds are formed between atoms. The electrons
  from one atom are shown as dots and the electrons from the other atom are shown as
  crosses."""@en ;
  dcterms:modified "2026-06-09T00:46:04.318125Z"^^xsd:dateTime .

oakcurric:keyword-simple-molecular
  a curric:Keyword ;
  schema:name "simple molecular"@en ;
  schema:description """Simple molecular substances are made up of two or more atoms covalently
  bonded together to form a distinct unit."""@en ;
  dcterms:modified "2026-06-09T00:46:04.318191Z"^^xsd:dateTime .

oakcurric:keyword-intermolecular-force
  a curric:Keyword ;
  schema:name "intermolecular force"@en ;
  schema:description """Intermolecular forces are weak forces of attraction between molecules and
  molecular substances."""@en ;
  dcterms:modified "2026-06-09T00:46:04.318196Z"^^xsd:dateTime .

oakcurric:keyword-giant-covalent
  a curric:Keyword ;
  schema:name "giant covalent"@en ;
  schema:description """A giant covalent substance has a large regular arrangement of atoms all
  joined together by covalent bonds."""@en ;
  dcterms:modified "2026-06-09T00:46:04.318201Z"^^xsd:dateTime .

oakcurric:keyword-noble-gas-configuration
  a curric:Keyword ;
  schema:name "noble gas configuration"@en ;
  schema:description """When an atom has a full outer shell of electrons, it has a noble gas
  electron configuration."""@en ;
