  dcterms:modified "2026-06-07T15:30:02.416679Z"^^xsd:dateTime .

oakcurric:keyword-parallax-error
  a curric:Keyword ;
  schema:name "parallax error"@en ;
  schema:description "A parallax error occurs when a measurement is not taken at eye-level."@en ;
  dcterms:modified "2026-06-07T15:30:02.416698Z"^^xsd:dateTime .

oakcurric:keyword-isotope
  a curric:Keyword ;
