  rdfs:label "Efficiency can be increased by lubrication, bearings or wheels"@en ;
  dcterms:modified "2026-06-07T15:30:29.604555Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9927-1
  a curric:KeyLearningPoint ;
  rdfs:label "Energy is measured in joules (J)."@en ;
  dcterms:modified "2026-06-07T15:30:29.604834Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9927-2
  a curric:KeyLearningPoint ;
  rdfs:label """Doubling the mass of a moving object doubles the energy it has in its
  kinetic store."""@en ;
  dcterms:modified "2026-06-07T15:30:29.604838Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9927-3
  a curric:KeyLearningPoint ;
  rdfs:label """Doubling the speed of an object increases the energy it has in its kinetic store by
  four times."""@en ;
  dcterms:modified "2026-06-07T15:30:29.604842Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9927-4
  a curric:KeyLearningPoint ;
  rdfs:label """The energy an object has in its kinetic store of energy is found using the equation
  KE = ½ mv²."""@en ;
  dcterms:modified "2026-06-07T15:30:29.604846Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20357-1
  a curric:KeyLearningPoint ;
  rdfs:label """Small masses of a substance, including magnesium, can be easily heated in a
  crucible."""@en ;
  dcterms:modified "2026-06-07T15:30:29.604851Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20357-2
  a curric:KeyLearningPoint ;
  rdfs:label """The crucible needs to be opened periodically to allow air (i.e. oxygen) to enter the
  apparatus."""@en ;
  dcterms:modified "2026-06-07T15:30:29.604855Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20357-3
  a curric:KeyLearningPoint ;
  rdfs:label """Lifting a crucible lid too often or for too long may lead to loss of product (i.e.
  lower final mass recorded)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.604859Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20357-4
  a curric:KeyLearningPoint ;
  rdfs:label """Using practical data and conservation of mass, chemists can calculate unknown
  reactant masses."""@en ;
  dcterms:modified "2026-06-07T15:30:29.604863Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20357-5
  a curric:KeyLearningPoint ;
  rdfs:label """Reactant masses can determine the empirical formula of a substance, including the
  ionic molar ratio of a metal & oxygen."""@en ;
  dcterms:modified "2026-06-07T15:30:29.604870Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9621-1
  a curric:KeyLearningPoint ;
  rdfs:label """Atoms of many elements vary in the exact number of neutrons in their nucleus, and
  each version is called an isotope."""@en ;
  dcterms:modified "2026-06-07T15:30:29.604883Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9621-2
  a curric:KeyLearningPoint ;
  rdfs:label """Existence of isotopes results in relative atomic masses of some elements not being
  whole numbers."""@en ;
  dcterms:modified "2026-06-07T15:30:29.604887Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9621-3
  a curric:KeyLearningPoint ;
  rdfs:label """Standard nuclear notation shows the chemical symbol, the mass number and the atomic
  number of the isotope."""@en ;
  dcterms:modified "2026-06-07T15:30:29.604891Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9923-1
  a curric:KeyLearningPoint ;
  rdfs:label "Power is equal to the rate at which work is done."@en ;
  dcterms:modified "2026-06-07T15:30:29.604896Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9923-2
  a curric:KeyLearningPoint ;
  rdfs:label "Power is equal to the rate at which energy is transferred."@en ;
  dcterms:modified "2026-06-07T15:30:29.604900Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9923-3
  a curric:KeyLearningPoint ;
  rdfs:label "Power = work done ÷ time."@en ;
  dcterms:modified "2026-06-07T15:30:29.604904Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9923-4
  a curric:KeyLearningPoint ;
  rdfs:label "Power is measured in watts (W)."@en ;
  dcterms:modified "2026-06-07T15:30:29.604910Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20153-1
  a curric:KeyLearningPoint ;
  rdfs:label """The number of particles (atoms, ions, molecules etc.) in one mole of a substance is
  always the same."""@en ;
  dcterms:modified "2026-06-07T15:30:29.604915Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20153-2
  a curric:KeyLearningPoint ;
  rdfs:label """The mass of one mole of a substance is equal to the relative mass of the substance
  measured in grams."""@en ;
  dcterms:modified "2026-06-07T15:30:29.604919Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20153-3
  a curric:KeyLearningPoint ;
  rdfs:label """Mathematical relationships are manipulated to process practical results, calculating
  the number of moles in a substance."""@en ;
  dcterms:modified "2026-06-07T15:30:29.604923Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27969-1
  a curric:KeyLearningPoint ;
  rdfs:label """Cellular respiration happens continuously in all living organisms to transfer the
  energy needed for life processes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.605564Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27969-2
  a curric:KeyLearningPoint ;
  rdfs:label """Cellular respiration is an exothermic chemical process that uses glucose as a fuel,
  and makes ATP."""@en ;
  dcterms:modified "2026-06-07T15:30:29.605569Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27969-3
  a curric:KeyLearningPoint ;
  rdfs:label """Word equation and balanced symbol equation summarises the reactants and products of
  aerobic cellular respiration."""@en ;
  dcterms:modified "2026-06-07T15:30:29.605573Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27969-4
  a curric:KeyLearningPoint ;
  rdfs:label """Aerobic cellular respiration takes place in the mitochondria of eukaryotic
  cells."""@en ;
  dcterms:modified "2026-06-07T15:30:29.605577Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27969-5
  a curric:KeyLearningPoint ;
  rdfs:label """Aerobic cellular respiration takes place in the cytoplasm of prokaryotic cells,
  which do not have mitochondria."""@en ;
  dcterms:modified "2026-06-07T15:30:29.605604Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9663-1
  a curric:KeyLearningPoint ;
  rdfs:label """Small masses of a substance, including magnesium, can be easily heated in a
  crucible."""@en ;
  dcterms:modified "2026-06-07T15:30:29.605609Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9663-2
  a curric:KeyLearningPoint ;
  rdfs:label """The crucible needs to be opened periodically to allow air (i.e. oxygen) to enter the
  apparatus."""@en ;
  dcterms:modified "2026-06-07T15:30:29.605632Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9663-3
  a curric:KeyLearningPoint ;
  rdfs:label """Lifting a crucible lid too often or for too long may lead to loss of product (i.e.
  lower final mass recorded)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.605637Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9663-4
  a curric:KeyLearningPoint ;
  rdfs:label """Using practical data and conservation of mass, chemists can calculate unknown
  reactant masses."""@en ;
  dcterms:modified "2026-06-07T15:30:29.605641Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9663-5
  a curric:KeyLearningPoint ;
  rdfs:label """Reactant masses can determine the empirical formula of a substance, including the
  ionic ratio of a metal and oxygen."""@en ;
  dcterms:modified "2026-06-07T15:30:29.605645Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9676-1
  a curric:KeyLearningPoint ;
  rdfs:label """pH is a logarithmic scale (as hydrogen ion concentration increases by a factor of
  10, the pH decreases by 1)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.605649Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9676-2
  a curric:KeyLearningPoint ;
  rdfs:label "For a given concentration, a stronger acid contains more H⁺ ions."@en ;
  dcterms:modified "2026-06-07T15:30:29.605684Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9676-3
  a curric:KeyLearningPoint ;
  rdfs:label """Titration curves can be used to show the change in pH to allow chemists to pinpoint
  a more accurate end point."""@en ;
  dcterms:modified "2026-06-07T15:30:29.605706Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9676-4
  a curric:KeyLearningPoint ;
  rdfs:label """A strong acid is completely ionised in aqueous solution, a weak acid only partially
  ionises."""@en ;
  dcterms:modified "2026-06-07T15:30:29.605711Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9676-5
  a curric:KeyLearningPoint ;
  rdfs:label "Titration curves show how the pH changes throughout a neutralisation reaction."@en ;
  dcterms:modified "2026-06-07T15:30:29.605715Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28118-1
  a curric:KeyLearningPoint ;
  rdfs:label """Concentration of an aqueous solution is the mass of solute dissolved in 1 dm³ of
  distilled water, in g/dm³."""@en ;
  dcterms:modified "2026-06-07T15:30:29.605719Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28118-2
  a curric:KeyLearningPoint ;
  rdfs:label """The mass of one mole of solute is equal to the relative mass of the solute measured
  in grams."""@en ;
  dcterms:modified "2026-06-07T15:30:29.605724Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28118-3
  a curric:KeyLearningPoint ;
  rdfs:label "Concentration can be expressed in g/dm³ or mol/dm³."@en ;
  dcterms:modified "2026-06-07T15:30:29.605728Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28118-4
  a curric:KeyLearningPoint ;
  rdfs:label """Equal volumes of solutions of the same concentration (in mol/dm³) have equal numbers
  of dissolved solute particles."""@en ;
  dcterms:modified "2026-06-07T15:30:29.605732Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28118-5
  a curric:KeyLearningPoint ;
  rdfs:label "Volume can be measured in various units; 1 dm³ is equivalent to 1000 cm³."@en ;
  dcterms:modified "2026-06-07T15:30:29.605752Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9929-1
  a curric:KeyLearningPoint ;
  rdfs:label "Energy is measured in joules (J)."@en ;
  dcterms:modified "2026-06-07T15:30:29.605831Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9929-2
  a curric:KeyLearningPoint ;
  rdfs:label """Doubling the mass of a moving object doubles the energy it has in its
  kinetic store."""@en ;
  dcterms:modified "2026-06-07T15:30:29.605835Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9929-3
  a curric:KeyLearningPoint ;
  rdfs:label """Doubling the speed of an object increases the energy it has in its kinetic store by
  four times."""@en ;
  dcterms:modified "2026-06-07T15:30:29.605840Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9929-4
  a curric:KeyLearningPoint ;
  rdfs:label """The energy an object has in its kinetic store of energy is found using the equation
  Ek = ½ mv²."""@en ;
  dcterms:modified "2026-06-07T15:30:29.605844Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8418-1
  a curric:KeyLearningPoint ;
  rdfs:label """Production processes for industrial materials are under continuous development, with
  new materials discovered."""@en ;
  dcterms:modified "2026-06-07T15:30:29.606514Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8418-2
  a curric:KeyLearningPoint ;
  rdfs:label """Several factors direct a choice of materials: performance, production processes,
  cost, aesthetics, and others."""@en ;
  dcterms:modified "2026-06-07T15:30:29.606519Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8418-3
  a curric:KeyLearningPoint ;
  rdfs:label "Composites are mixtures of materials made up of a matrix and a reinforcement."@en ;
  dcterms:modified "2026-06-07T15:30:29.606523Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8418-4
  a curric:KeyLearningPoint ;
  rdfs:label """Qualitative data describes properties, while quantitative data measures properties
  numerically."""@en ;
  dcterms:modified "2026-06-07T15:30:29.606527Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9192-1
  a curric:KeyLearningPoint ;
  rdfs:label "A light microscope can be used to observe plant root hair cells."@en ;
  dcterms:modified "2026-06-07T15:30:29.606917Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9192-2
  a curric:KeyLearningPoint ;
  rdfs:label "The parts of a light microscope and their functions."@en ;
  dcterms:modified "2026-06-07T15:30:29.606921Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9192-3
  a curric:KeyLearningPoint ;
  rdfs:label """The sequence of steps for setting up a light microscope to observe cells including
  changing the magnification and focus."""@en ;
  dcterms:modified "2026-06-07T15:30:29.606925Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9192-4
  a curric:KeyLearningPoint ;
  rdfs:label """Observations from a light microscope can be recorded in a labelled scientific line
  drawing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.606929Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9192-5
  a curric:KeyLearningPoint ;
  rdfs:label """Total magnification = magnification of the eyepiece lens × magnification of the
  objective lens"""@en ;
  dcterms:modified "2026-06-07T15:30:29.606934Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9652-1
  a curric:KeyLearningPoint ;
  rdfs:label "Distillation can be used to purify water samples."@en ;
  dcterms:modified "2026-06-07T15:30:29.607533Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9652-2
  a curric:KeyLearningPoint ;
  rdfs:label "Boiling point data can be analysed to assess the purity of water samples."@en ;
  dcterms:modified "2026-06-07T15:30:29.607538Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9652-3
  a curric:KeyLearningPoint ;
  rdfs:label """The more impurities present in a sample, the larger the temperature range over which
  the water will boil."""@en ;
  dcterms:modified "2026-06-07T15:30:29.607542Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9652-4
  a curric:KeyLearningPoint ;
  rdfs:label "Pure water boils at 100°C."@en ;
  dcterms:modified "2026-06-07T15:30:29.607546Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27389-1
  a curric:KeyLearningPoint ;
  rdfs:label """Transition metals are generally stronger, harder, more dense and have higher melting
  points than Group 1 metals."""@en ;
  dcterms:modified "2026-06-07T15:30:29.607841Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27389-2
  a curric:KeyLearningPoint ;
  rdfs:label "Transition metals react slowly with water or don’t react with it at all."@en ;
  dcterms:modified "2026-06-07T15:30:29.607847Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27389-3
  a curric:KeyLearningPoint ;
  rdfs:label "Transition metals are often catalysts that speed up chemical reactions."@en ;
  dcterms:modified "2026-06-07T15:30:29.607853Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27389-4
  a curric:KeyLearningPoint ;
  rdfs:label """Transition metals can form ions with different charges and their compounds often
  exhibit vibrant colours."""@en ;
  dcterms:modified "2026-06-07T15:30:29.607857Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9746-1
  a curric:KeyLearningPoint ;
  rdfs:label "Balanced symbol equations can be written for the combustion of alcohols."@en ;
  dcterms:modified "2026-06-07T15:30:29.608194Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9746-2
  a curric:KeyLearningPoint ;
  rdfs:label "It is difficult to measure directly the energy change of a reaction."@en ;
  dcterms:modified "2026-06-07T15:30:29.608199Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9746-3
  a curric:KeyLearningPoint ;
  rdfs:label "Calorimetry can be used to measure a reaction's energy change indirectly."@en ;
  dcterms:modified "2026-06-07T15:30:29.608205Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9934-1
  a curric:KeyLearningPoint ;
  rdfs:label "When an object moves upwards, work is done against the gravitational force."@en ;
  dcterms:modified "2026-06-07T15:30:29.608623Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9934-2
  a curric:KeyLearningPoint ;
  rdfs:label """The gravitational force acting on an object does work to speed it up when it is
  falling."""@en ;
  dcterms:modified "2026-06-07T15:30:29.608629Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9934-3
  a curric:KeyLearningPoint ;
  rdfs:label "Weight = mass x gravitational field strength, W = mg"@en ;
  dcterms:modified "2026-06-07T15:30:29.608633Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9934-4
  a curric:KeyLearningPoint ;
  rdfs:label """Gravitational potential energy of an object = mass × gravitational field strength ×
  height"""@en ;
  dcterms:modified "2026-06-07T15:30:29.608638Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9935-1
  a curric:KeyLearningPoint ;
  rdfs:label "When an object moves upwards, work is done against the gravitational force."@en ;
  dcterms:modified "2026-06-07T15:30:29.608642Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9935-2
  a curric:KeyLearningPoint ;
  rdfs:label """The gravitational force acting on an object does work to speed it up when it is
  falling."""@en ;
  dcterms:modified "2026-06-07T15:30:29.608646Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9935-3
  a curric:KeyLearningPoint ;
  rdfs:label "Weight = mass x gravitational field strength, W = mg"@en ;
  dcterms:modified "2026-06-07T15:30:29.608650Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9935-4
  a curric:KeyLearningPoint ;
  rdfs:label """Change in gravitational potential energy of an object = mass × gravitational field
  strength × change in height"""@en ;
  dcterms:modified "2026-06-07T15:30:29.608657Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9930-1
  a curric:KeyLearningPoint ;
  rdfs:label "Energy is measured in joules (J)."@en ;
  dcterms:modified "2026-06-07T15:30:29.609193Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9930-2
  a curric:KeyLearningPoint ;
  rdfs:label """Doubling the mass of a moving object doubles the energy it has in its
  kinetic store."""@en ;
  dcterms:modified "2026-06-07T15:30:29.609197Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9930-3
  a curric:KeyLearningPoint ;
  rdfs:label """Doubling the speed of an object increases the energy it has in its kinetic store by
  four times."""@en ;
  dcterms:modified "2026-06-07T15:30:29.609202Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9930-4
  a curric:KeyLearningPoint ;
  rdfs:label """The energy an object has in its kinetic store of energy is found using the equation
  KE = ½ mv²."""@en ;
  dcterms:modified "2026-06-07T15:30:29.609206Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9928-1
  a curric:KeyLearningPoint ;
  rdfs:label "Energy is measured in joules (J)."@en ;
  dcterms:modified "2026-06-07T15:30:29.609326Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9928-2
  a curric:KeyLearningPoint ;
  rdfs:label """Doubling the mass of a moving object doubles the energy it has in its
  kinetic store."""@en ;
  dcterms:modified "2026-06-07T15:30:29.609331Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9928-3
  a curric:KeyLearningPoint ;
  rdfs:label """Doubling the speed of an object increases the energy it has in its kinetic store by
  four times."""@en ;
  dcterms:modified "2026-06-07T15:30:29.609335Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9928-4
  a curric:KeyLearningPoint ;
  rdfs:label """The energy an object has in its kinetic store of energy is found using the equation
  E = ½ mv²."""@en ;
  dcterms:modified "2026-06-07T15:30:29.609339Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27881-1
  a curric:KeyLearningPoint ;
  rdfs:label """The hormone adrenaline is secreted by the adrenal gland during stress; it causes the
  body to prepare for rapid action."""@en ;
  dcterms:modified "2026-06-07T15:30:29.609371Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27881-2
  a curric:KeyLearningPoint ;
  rdfs:label """The hormone thyroxine is secreted by the thyroid gland; it controls growth and the
  rates of chemical reactions in cells."""@en ;
  dcterms:modified "2026-06-07T15:30:29.609375Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27881-3
  a curric:KeyLearningPoint ;
  rdfs:label "The pituitary gland secretes hormones that control other glands."@en ;
  dcterms:modified "2026-06-07T15:30:29.609379Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27881-4
  a curric:KeyLearningPoint ;
  rdfs:label """Hypothalamus secretes TRH; this causes pituitary gland to secrete TSH; this causes
  thyroid gland to secrete thyroxine."""@en ;
  dcterms:modified "2026-06-07T15:30:29.609385Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27881-5
  a curric:KeyLearningPoint ;
  rdfs:label """Thyroxine causes the pituitary gland to stop secreting TSH; this is an example of
  negative feedback."""@en ;
  dcterms:modified "2026-06-07T15:30:29.609390Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20676-1
  a curric:KeyLearningPoint ;
  rdfs:label """Group 7 elements are very reactive and their reactivity decreases down the
  group."""@en ;
  dcterms:modified "2026-06-07T15:30:29.609628Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20676-2
  a curric:KeyLearningPoint ;
  rdfs:label """Moving down Group 7 elements, atomic mass, density, and melting and boiling points
  increase."""@en ;
  dcterms:modified "2026-06-07T15:30:29.609632Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20676-3
  a curric:KeyLearningPoint ;
  rdfs:label """In chemical reactions, atoms of Group 7 elements gain one outer electron making just
  full electron shells."""@en ;
  dcterms:modified "2026-06-07T15:30:29.609637Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20676-4
  a curric:KeyLearningPoint ;
  rdfs:label """Going down Group 7, the force attracting an extra electron reduces with the distance
  of each shell from the nucleus."""@en ;
  dcterms:modified "2026-06-07T15:30:29.609641Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20676-5
  a curric:KeyLearningPoint ;
  rdfs:label "Halogens are elements, halides are salts."@en ;
  dcterms:modified "2026-06-07T15:30:29.609645Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20361-1
  a curric:KeyLearningPoint ;
  rdfs:label """Equal amounts in moles of gases occupy the same volume under the same conditions of
  temperature and pressure."""@en ;
  dcterms:modified "2026-06-07T15:30:29.610456Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20361-2
  a curric:KeyLearningPoint ;
  rdfs:label """The volume of one mole of any gas at room temperature and pressure (20℃ and 1
  atmosphere pressure) is 24 dm³."""@en ;
  dcterms:modified "2026-06-07T15:30:29.610460Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20361-3
  a curric:KeyLearningPoint ;
  rdfs:label """The volumes of gaseous reactants and products can be calculated from the balanced
  equation for the reaction."""@en ;
  dcterms:modified "2026-06-07T15:30:29.610464Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20361-4
  a curric:KeyLearningPoint ;
  rdfs:label """If moles of gas are known, its density can be calculated using molar gas volume and
  the relationship mass = RFM x moles."""@en ;
  dcterms:modified "2026-06-07T15:30:29.610468Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9911-1
  a curric:KeyLearningPoint ;
  rdfs:label "Average velocity = distance travelled ÷ time"@en ;
  dcterms:modified "2026-06-07T15:30:29.610882Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9911-2
  a curric:KeyLearningPoint ;
  rdfs:label "Average acceleration = change in velocity ÷ time"@en ;
  dcterms:modified "2026-06-07T15:30:29.610886Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9911-3
  a curric:KeyLearningPoint ;
  rdfs:label "Average velocity = (initial velocity + final velocity) ÷ 2"@en ;
  dcterms:modified "2026-06-07T15:30:29.610891Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9911-4
  a curric:KeyLearningPoint ;
  rdfs:label """Combining equations for average acceleration and average velocity leads to the
  equation v² – u² = 2as"""@en ;
  dcterms:modified "2026-06-07T15:30:29.610895Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9911-5
  a curric:KeyLearningPoint ;
  rdfs:label """Different motion equations can be used to analyse motion based on information
  provided."""@en ;
  dcterms:modified "2026-06-07T15:30:29.610899Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20458-1
  a curric:KeyLearningPoint ;
  rdfs:label """The volume of one mole of any gas at room temperature and pressure (20℃ and 1
  atmosphere pressure) is 24 dm³."""@en ;
  dcterms:modified "2026-06-07T15:30:29.611124Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20458-2
  a curric:KeyLearningPoint ;
  rdfs:label """Reacting mass calculations can use a combination of mass to volume calculations and
  vice versa."""@en ;
  dcterms:modified "2026-06-07T15:30:29.611128Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20458-3
  a curric:KeyLearningPoint ;
  rdfs:label "Amount of substance (moles) can be calculated using multiple equations."@en ;
  dcterms:modified "2026-06-07T15:30:29.611132Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20458-4
  a curric:KeyLearningPoint ;
  rdfs:label """The choice of equation for calculating moles depends on the context of the problem
  or calculation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.611139Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27391-1
  a curric:KeyLearningPoint ;
  rdfs:label """In an ideal chemical reaction, all atoms in the reactants would end up in useful
  products, with no waste."""@en ;
  dcterms:modified "2026-06-07T15:30:29.611144Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27391-2
  a curric:KeyLearningPoint ;
  rdfs:label """The theoretical yield of a chemical reaction can be calculated from the reaction
  equation alone."""@en ;
  dcterms:modified "2026-06-07T15:30:29.611150Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27391-3
  a curric:KeyLearningPoint ;
  rdfs:label "The percentage yield shows how actual yield compares with theoretical yield."@en ;
  dcterms:modified "2026-06-07T15:30:29.611155Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27391-4
  a curric:KeyLearningPoint ;
  rdfs:label """Atom economy is a measure of the efficiency with which a reaction uses its
  reactants."""@en ;
  dcterms:modified "2026-06-07T15:30:29.611159Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27391-5
  a curric:KeyLearningPoint ;
  rdfs:label "Many factors will be considered when choosing a reaction pathway."@en ;
  dcterms:modified "2026-06-07T15:30:29.611163Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20354-1
  a curric:KeyLearningPoint ;
  rdfs:label """Manipulating apparatus correctly ensures both accurate results and safety in the
  lab."""@en ;
  dcterms:modified "2026-06-07T15:30:29.613798Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20354-2
  a curric:KeyLearningPoint ;
  rdfs:label """Interconversion between units like grams, moles, volume, density & particles is
  fundamental in chemical calculations."""@en ;
  dcterms:modified "2026-06-07T15:30:29.613802Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20354-3
  a curric:KeyLearningPoint ;
  rdfs:label "Successful interconversion is only possible if the units match."@en ;
  dcterms:modified "2026-06-07T15:30:29.613806Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20354-4
  a curric:KeyLearningPoint ;
  rdfs:label """Using the appropriate apparatus for a required measurement can help to reduce
  uncertainty."""@en ;
  dcterms:modified "2026-06-07T15:30:29.613810Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9936-1
  a curric:KeyLearningPoint ;
  rdfs:label "When an object moves upwards, work is done against the gravitational force."@en ;
  dcterms:modified "2026-06-07T15:30:29.614038Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9936-2
  a curric:KeyLearningPoint ;
  rdfs:label """The gravitational force acting on an object does work to speed it up when it is
  falling."""@en ;
  dcterms:modified "2026-06-07T15:30:29.614042Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9936-3
  a curric:KeyLearningPoint ;
  rdfs:label "Weight = mass x gravitational field strength, W = mg"@en ;
  dcterms:modified "2026-06-07T15:30:29.614046Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9936-4
  a curric:KeyLearningPoint ;
  rdfs:label """Gravitational potential energy of an object = mass × gravitational field strength ×
  height"""@en ;
  dcterms:modified "2026-06-07T15:30:29.614050Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9921-1
  a curric:KeyLearningPoint ;
  rdfs:label "Power is equal to the rate at which work is done."@en ;
  dcterms:modified "2026-06-07T15:30:29.614310Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9921-2
  a curric:KeyLearningPoint ;
  rdfs:label "Power is equal to the rate at which energy is transferred."@en ;
  dcterms:modified "2026-06-07T15:30:29.614315Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9921-3
  a curric:KeyLearningPoint ;
  rdfs:label "Power = work done ÷ time."@en ;
  dcterms:modified "2026-06-07T15:30:29.614319Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9921-4
  a curric:KeyLearningPoint ;
  rdfs:label "Power is measured in watts (W)."@en ;
  dcterms:modified "2026-06-07T15:30:29.614323Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21042-1
  a curric:KeyLearningPoint ;
  rdfs:label """In phytomining, metal is extracted from a crop of plants that absorb metal ions
  through their roots."""@en ;
  dcterms:modified "2026-06-07T15:30:29.615503Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21042-2
  a curric:KeyLearningPoint ;
  rdfs:label "In bioleaching, metal is extracted from bacteria that extract metal from an ore."@en ;
  dcterms:modified "2026-06-07T15:30:29.615507Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21042-3
  a curric:KeyLearningPoint ;
  rdfs:label "Electrolysis is a process used to separate metals from their compounds."@en ;
  dcterms:modified "2026-06-07T15:30:29.615511Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-21042-4
  a curric:KeyLearningPoint ;
  rdfs:label """There are advantages and disadvantages associated with each method of extracting
  metals."""@en ;
  dcterms:modified "2026-06-07T15:30:29.615515Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9918-1
  a curric:KeyLearningPoint ;
  rdfs:label "Work done is the total amount of energy transferred."@en ;
  dcterms:modified "2026-06-07T15:30:29.617542Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9918-2
  a curric:KeyLearningPoint ;
  rdfs:label "Work done = force × distance (moved in the direction of the force)."@en ;
  dcterms:modified "2026-06-07T15:30:29.617547Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9918-3
  a curric:KeyLearningPoint ;
  rdfs:label "Work done is measured in joules (J)."@en ;
  dcterms:modified "2026-06-07T15:30:29.617551Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27913-1
  a curric:KeyLearningPoint ;
  rdfs:label "An ionic equation represents the reaction between positive and negative ions."@en ;
  dcterms:modified "2026-06-07T15:30:29.617732Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27913-2
  a curric:KeyLearningPoint ;
  rdfs:label "The electric charge on each side of an ionic equation adds up to zero."@en ;
  dcterms:modified "2026-06-07T15:30:29.617737Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27913-3
  a curric:KeyLearningPoint ;
  rdfs:label """(s), (l), (g) and (aq) in ionic equations identify the state of each substance as
  solid, liquid, gas or in solution"""@en ;
  dcterms:modified "2026-06-07T15:30:29.617741Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9661-1
  a curric:KeyLearningPoint ;
  rdfs:label """Empirical formula is the simplest whole number ratio of atoms of each element in a
  compound."""@en ;
  dcterms:modified "2026-06-07T15:30:29.618716Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9661-2
  a curric:KeyLearningPoint ;
  rdfs:label """Using the masses of elements reacted together, or their percentage compositions,
  calculate the empirical formula."""@en ;
  dcterms:modified "2026-06-07T15:30:29.618720Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9661-3
  a curric:KeyLearningPoint ;
  rdfs:label """Knowing the relative formula mass of a substance, and its empirical formula,
  calculate the molecular formula."""@en ;
  dcterms:modified "2026-06-07T15:30:29.618725Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9105-1
  a curric:KeyLearningPoint ;
  rdfs:label "A light gate measures the time for a card of a fixed length to pass through it."@en ;
  dcterms:modified "2026-06-07T15:30:29.618784Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9105-2
  a curric:KeyLearningPoint ;
  rdfs:label """A radar gun measures changes in the frequency of reflected waves to measure
  speed."""@en ;
  dcterms:modified "2026-06-07T15:30:29.618790Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9105-3
  a curric:KeyLearningPoint ;
  rdfs:label """A motion sensor can use reflected ultrasonic wave timings to measure changes in
  distance to determine speed."""@en ;
  dcterms:modified "2026-06-07T15:30:29.618794Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28164-1
  a curric:KeyLearningPoint ;
  rdfs:label """A nuclear equation shows the particles in a nuclear decay, including the electric
  charge and mass number of each one."""@en ;
  dcterms:modified "2026-06-07T15:30:29.618798Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28164-2
  a curric:KeyLearningPoint ;
  rdfs:label """An alpha particle consists of two protons and two neutrons, has a mass of 4 and
  charge of +2."""@en ;
  dcterms:modified "2026-06-07T15:30:29.618802Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28164-3
  a curric:KeyLearningPoint ;
  rdfs:label "The protons and neutrons in an alpha particle are held together very strongly."@en ;
  dcterms:modified "2026-06-07T15:30:29.618806Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28164-4
  a curric:KeyLearningPoint ;
  rdfs:label "After an alpha or beta decay, a nucleus usually emits some gamma radiation."@en ;
  dcterms:modified "2026-06-07T15:30:29.618810Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28164-5
  a curric:KeyLearningPoint ;
  rdfs:label """A beta particle is an electron emitted at a high speed from a nucleus, its mass is
  close to zero and charge of –1."""@en ;
  dcterms:modified "2026-06-07T15:30:29.618815Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9938-1
  a curric:KeyLearningPoint ;
  rdfs:label "Energy cannot be created or destroyed."@en ;
  dcterms:modified "2026-06-07T15:30:29.618846Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9938-2
  a curric:KeyLearningPoint ;
  rdfs:label "In an ideal situation, no energy is dissipated."@en ;
  dcterms:modified "2026-06-07T15:30:29.618851Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9938-3
  a curric:KeyLearningPoint ;
  rdfs:label """As an object changes height, change in gravitational potential energy = change in
  kinetic energy."""@en ;
  dcterms:modified "2026-06-07T15:30:29.618855Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9899-1
  a curric:KeyLearningPoint ;
  rdfs:label "Acceleration is equal to the amount that velocity changes in one second."@en ;
  dcterms:modified "2026-06-07T15:30:29.620387Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9899-2
  a curric:KeyLearningPoint ;
  rdfs:label "Acceleration is the rate of change of velocity."@en ;
  dcterms:modified "2026-06-07T15:30:29.620391Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9899-3
  a curric:KeyLearningPoint ;
  rdfs:label "Average acceleration = change of velocity/time (a = Δv/t)"@en ;
  dcterms:modified "2026-06-07T15:30:29.620395Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9899-4
  a curric:KeyLearningPoint ;
  rdfs:label "An object that is slowing down is decelerating."@en ;
  dcterms:modified "2026-06-07T15:30:29.620400Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9899-5
  a curric:KeyLearningPoint ;
  rdfs:label "An object that is decelerating has a negative acceleration."@en ;
  dcterms:modified "2026-06-07T15:30:29.620404Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20137-1
  a curric:KeyLearningPoint ;
  rdfs:label """Group 0 elements are called noble gases (or inert gases) and are very unreactive
  with other elements."""@en ;
  dcterms:modified "2026-06-07T15:30:29.620959Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20137-2
  a curric:KeyLearningPoint ;
  rdfs:label """Group 0 elements can be described as having either full or empty outer electron
  shells."""@en ;
  dcterms:modified "2026-06-07T15:30:29.620963Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20137-3
  a curric:KeyLearningPoint ;
  rdfs:label """Noble gases emit coloured light when a high voltage is applied across them, and they
  do not decompose."""@en ;
  dcterms:modified "2026-06-07T15:30:29.620967Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4734-1
  a curric:KeyLearningPoint ;
  rdfs:label "A dynamics trolley has a constant acceleration down a steep ramp."@en ;
  dcterms:modified "2026-06-07T15:30:29.622345Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4734-2
  a curric:KeyLearningPoint ;
  rdfs:label """Acceleration = change of velocity ÷ time and change in velocity = final velocity –
  initial velocity"""@en ;
  dcterms:modified "2026-06-07T15:30:29.622349Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4734-3
  a curric:KeyLearningPoint ;
  rdfs:label """Light gates can improve accuracy of measurement of instantaneous velocity and
  reduces random errors."""@en ;
  dcterms:modified "2026-06-07T15:30:29.622353Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4734-4
  a curric:KeyLearningPoint ;
  rdfs:label "Using video recording allows for accurate measurement of small time intervals."@en ;
  dcterms:modified "2026-06-07T15:30:29.622357Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9937-1
  a curric:KeyLearningPoint ;
  rdfs:label "Energy cannot be created or destroyed."@en ;
  dcterms:modified "2026-06-07T15:30:29.622419Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9937-2
  a curric:KeyLearningPoint ;
  rdfs:label "In an ideal situation, no energy is dissipated."@en ;
  dcterms:modified "2026-06-07T15:30:29.622423Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9937-3
  a curric:KeyLearningPoint ;
  rdfs:label """As an object changes height, change in gravitational potential energy = change in
  kinetic energy."""@en ;
  dcterms:modified "2026-06-07T15:30:29.622427Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4733-1
  a curric:KeyLearningPoint ;
  rdfs:label "Average velocity = distance travelled ÷ time"@en ;
  dcterms:modified "2026-06-07T15:30:29.623303Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4733-2
  a curric:KeyLearningPoint ;
  rdfs:label "Average acceleration = change in velocity ÷ time"@en ;
  dcterms:modified "2026-06-07T15:30:29.623307Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4733-3
  a curric:KeyLearningPoint ;
  rdfs:label "Average velocity = (initial velocity + final velocity) ÷ 2"@en ;
  dcterms:modified "2026-06-07T15:30:29.623311Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4733-4
  a curric:KeyLearningPoint ;
  rdfs:label """Combining equations for average acceleration and average velocity leads to the
  equation v² – u² = 2as"""@en ;
  dcterms:modified "2026-06-07T15:30:29.623316Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4733-5
  a curric:KeyLearningPoint ;
  rdfs:label """Different motion equations can be used to analyse motion based on information
  provided."""@en ;
  dcterms:modified "2026-06-07T15:30:29.623320Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20358-1
  a curric:KeyLearningPoint ;
  rdfs:label """The stoichiometry of a chemical reaction is the molar ratio of each substance in a
  balanced symbol equation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.623343Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20358-2
  a curric:KeyLearningPoint ;
  rdfs:label "Stoichiometric values can be calculated using masses found by experiment."@en ;
  dcterms:modified "2026-06-07T15:30:29.623347Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20358-3
  a curric:KeyLearningPoint ;
  rdfs:label """Subscript values in chemical formula indicate the ratio of atoms/ions in a
  molecule/formula unit."""@en ;
  dcterms:modified "2026-06-07T15:30:29.623352Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20355-1
  a curric:KeyLearningPoint ;
  rdfs:label """Stoichiometry means ‘measuring elements’, from the Greek 'stoikhein' – meaning
  element and 'metron' – to measure."""@en ;
  dcterms:modified "2026-06-07T15:30:29.623356Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20355-2
  a curric:KeyLearningPoint ;
  rdfs:label """Chemical equations should be interpreted in terms of moles (i.e. 1 mole of this
  reacts with 2 moles of that)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.623362Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20355-3
  a curric:KeyLearningPoint ;
  rdfs:label """The mass of each reactant that does react can be worked out from the relative
  formula masses in the chemical equation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.623367Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20355-4
  a curric:KeyLearningPoint ;
  rdfs:label """In a chemical reaction, the atoms in reactants are rearranged and are the same atoms
  that are in the products."""@en ;
  dcterms:modified "2026-06-07T15:30:29.623371Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20355-5
  a curric:KeyLearningPoint ;
  rdfs:label """The mass of products in a chemical reaction is equal to the mass of the
  reactants."""@en ;
  dcterms:modified "2026-06-07T15:30:29.623375Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8332-1
  a curric:KeyLearningPoint ;
  rdfs:label """In a chemical reaction, the atoms in reactants are rearranged and are the same atoms
  that are in the products."""@en ;
  dcterms:modified "2026-06-07T15:30:29.623746Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8332-2
  a curric:KeyLearningPoint ;
  rdfs:label """The mass of products in a chemical reaction is equal to the mass of the
  reactants."""@en ;
  dcterms:modified "2026-06-07T15:30:29.623752Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8332-3
  a curric:KeyLearningPoint ;
  rdfs:label """The sum of the RFM of the reactants equals the sum of the RFM of the products,
  taking account of balancing coefficients."""@en ;
  dcterms:modified "2026-06-07T15:30:29.623756Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20007-1
  a curric:KeyLearningPoint ;
  rdfs:label """Energy is dissipated due to friction which causes particles to vibrate more quickly
  and heats up the surroundings."""@en ;
  dcterms:modified "2026-06-07T15:30:29.626138Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20007-2
  a curric:KeyLearningPoint ;
  rdfs:label """Energy is dissipated due to drag which causes particles in the surroundings to move
  more quickly."""@en ;
  dcterms:modified "2026-06-07T15:30:29.626143Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20007-3
  a curric:KeyLearningPoint ;
  rdfs:label "Efficiency = useful output energy transfer / total input energy transfer"@en ;
  dcterms:modified "2026-06-07T15:30:29.626147Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20007-4
  a curric:KeyLearningPoint ;
  rdfs:label "Efficiency = useful power output / total power input"@en ;
  dcterms:modified "2026-06-07T15:30:29.626151Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9912-1
  a curric:KeyLearningPoint ;
  rdfs:label "Average velocity = distance travelled ÷ time"@en ;
  dcterms:modified "2026-06-07T15:30:29.627777Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9912-2
  a curric:KeyLearningPoint ;
  rdfs:label "Average acceleration = change in velocity ÷ time"@en ;
  dcterms:modified "2026-06-07T15:30:29.627782Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9912-3
  a curric:KeyLearningPoint ;
  rdfs:label "Average velocity = (initial velocity + final velocity) ÷ 2"@en ;
  dcterms:modified "2026-06-07T15:30:29.627786Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9912-4
  a curric:KeyLearningPoint ;
  rdfs:label """Combining equations for average acceleration and average velocity leads to the
  equation v² – u² = 2ax"""@en ;
  dcterms:modified "2026-06-07T15:30:29.627887Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9912-5
  a curric:KeyLearningPoint ;
  rdfs:label """Different motion equations can be used to analyse motion based on information
  provided."""@en ;
  dcterms:modified "2026-06-07T15:30:29.627947Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28011-1
  a curric:KeyLearningPoint ;
  rdfs:label "Isotopes are atoms of the same element with different numbers of neutrons."@en ;
  dcterms:modified "2026-06-07T15:30:29.627958Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28011-2
  a curric:KeyLearningPoint ;
  rdfs:label """Relative abundances of isotopes can be used to calculate the relative atomic mass
  (RAM) of an element."""@en ;
  dcterms:modified "2026-06-07T15:30:29.627988Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28011-3
  a curric:KeyLearningPoint ;
  rdfs:label "Mass spectrometry ionises samples to create positive ions for analysis."@en ;
  dcterms:modified "2026-06-07T15:30:29.628005Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28011-4
  a curric:KeyLearningPoint ;
  rdfs:label "The M⁺ peak represents the molecular ion, indicating the molecular mass."@en ;
  dcterms:modified "2026-06-07T15:30:29.628012Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28011-5
  a curric:KeyLearningPoint ;
  rdfs:label """Fragmentation in mass spectrometry helps identify molecular structure by breaking
  molecules into smaller ions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.628052Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9943-1
  a curric:KeyLearningPoint ;
  rdfs:label "Energy cannot be created or destroyed."@en ;
  dcterms:modified "2026-06-07T15:30:29.630241Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9943-2
  a curric:KeyLearningPoint ;
  rdfs:label "In an ideal situation, no energy is dissipated."@en ;
  dcterms:modified "2026-06-07T15:30:29.630245Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9943-3
  a curric:KeyLearningPoint ;
  rdfs:label """As an object changes height, change in gravitational potential energy = change in
  kinetic energy."""@en ;
  dcterms:modified "2026-06-07T15:30:29.630251Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20080-1
  a curric:KeyLearningPoint ;
  rdfs:label """The atomic number of an element states the number of protons in the nucleus of every
  atom of that element."""@en ;
  dcterms:modified "2026-06-07T15:30:29.634618Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20080-2
  a curric:KeyLearningPoint ;
  rdfs:label """The number of electrons in an atom is equal to the number of protons in the nucleus
  of the atom."""@en ;
  dcterms:modified "2026-06-07T15:30:29.634622Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20080-3
  a curric:KeyLearningPoint ;
  rdfs:label """The mass number of an element is about equal to the number of protons and neutrons
  in atoms of that element."""@en ;
  dcterms:modified "2026-06-07T15:30:29.634626Z"^^xsd:dateTime .

