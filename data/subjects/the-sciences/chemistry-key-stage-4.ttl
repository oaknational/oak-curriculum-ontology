  unrestricted flow of blood."""@en ;
  dcterms:modified "2026-06-07T15:30:02.417320Z"^^xsd:dateTime .

oakcurric:keyword-statins
  a curric:Keyword ;
  schema:name "statins"@en ;
  schema:description "Medication to lower blood cholesterol."@en ;
  dcterms:modified "2026-06-07T15:30:02.417325Z"^^xsd:dateTime .

oakcurric:keyword-prevalence
  a curric:Keyword ;
  schema:name "prevalence"@en ;
  schema:description "how widespread something is, especially a disease or pathogen"@en ;
  dcterms:modified "2026-06-07T15:30:02.417330Z"^^xsd:dateTime .

oakcurric:keyword-asexual-reproduction
  a curric:Keyword ;
  schema:name "asexual reproduction"@en ;
  schema:description """Reproduction involving one parent, giving genetically identical
  offspring."""@en ;
  dcterms:modified "2026-06-07T15:30:02.417336Z"^^xsd:dateTime .

oakcurric:keyword-glycogen
  a curric:Keyword ;
