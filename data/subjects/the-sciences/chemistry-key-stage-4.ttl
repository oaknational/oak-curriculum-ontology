  dcterms:modified "2026-06-09T00:45:28.240390Z"^^xsd:dateTime .

oakcurric:priorknowledge-972-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "A chemical that is reduced either loses oxygen or gains electrons."@en ;
  dcterms:modified "2026-06-09T00:45:28.240406Z"^^xsd:dateTime .

oakcurric:priorknowledge-972-3
  a curric:PriorKnowledgeRequirement ;
