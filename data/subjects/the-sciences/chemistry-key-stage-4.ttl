  schema:description """A diagram that shows the evolutionary relationships between different groups
  of organisms."""@en ;
  dcterms:modified "2026-06-07T15:30:02.416973Z"^^xsd:dateTime .

oakcurric:keyword-transitional-species
  a curric:Keyword ;
  schema:name "transitional species"@en ;
  schema:description """A species that shows intermediate characteristics from evolutionary
  ancestors and modern species."""@en ;
  dcterms:modified "2026-06-07T15:30:02.416978Z"^^xsd:dateTime .

oakcurric:keyword-limiting-factor
  a curric:Keyword ;
  schema:name "limiting factor"@en ;
  schema:description """A condition that when in short supply slows down or limits the rate of
  photosynthesis."""@en ;
  dcterms:modified "2026-06-07T15:30:02.416983Z"^^xsd:dateTime .

oakcurric:keyword-stationary-phase
  a curric:Keyword ;
  schema:name "stationary phase"@en ;
  schema:description """A surface along which the solvent (and any dissolved components) travels. It
  does not move during chromatography."""@en ;
  dcterms:modified "2026-06-07T15:30:02.416989Z"^^xsd:dateTime .

oakcurric:keyword-mobile-phase
  a curric:Keyword ;
  schema:name "mobile phase"@en ;
  schema:description """The movement of a solvent and any dissolved components of a sample along the
  stationary phase in chromatography."""@en ;
  dcterms:modified "2026-06-07T15:30:02.416994Z"^^xsd:dateTime .

oakcurric:keyword-thin-layer-chromatography
  a curric:Keyword ;
