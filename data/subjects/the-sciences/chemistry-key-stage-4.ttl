  schema:description """This describes a reaction using a symbol equation with coefficients which
  ensure there are equal numbers of atoms of each element on both sides of the symbol
  equation."""@en ;
  dcterms:modified "2026-06-07T15:30:02.417287Z"^^xsd:dateTime .

oakcurric:keyword-meristem
  a curric:Keyword ;
