  schema:description """A species that several other species evolved from. For example, tigers and
  lions share a common ancestor."""@en ;
  dcterms:modified "2026-06-07T15:30:02.416967Z"^^xsd:dateTime .

oakcurric:keyword-evolutionary-tree
  a curric:Keyword ;
