  dcterms:modified "2026-06-07T15:30:02.417308Z"^^xsd:dateTime .

oakcurric:keyword-cardiovascular-disease
  a curric:Keyword ;
  schema:name "cardiovascular disease"@en ;
  schema:description "General term for conditions affecting the heart or the blood vessels."@en ;
  dcterms:modified "2026-06-07T15:30:02.417314Z"^^xsd:dateTime .

oakcurric:keyword-stent
  a curric:Keyword ;
  schema:name "stent"@en ;
