oakcurric:keylearningpoint-lesson-8400-1
  a curric:KeyLearningPoint ;
  rdfs:label "The pH of rain water is naturally below 7."@en ;
  dcterms:modified "2026-06-09T00:46:37.493693Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8400-2
  a curric:KeyLearningPoint ;
  rdfs:label """Chemical reactions between certain pollutants and water in the atmosphere may cause
  a decrease in the pH of rainwater."""@en ;
  dcterms:modified "2026-06-09T00:46:37.493699Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8400-3
  a curric:KeyLearningPoint ;
  rdfs:label """Acid rain is not as acidic as vinegar or citric acid that is found in lemons and
  oranges."""@en ;
  dcterms:modified "2026-06-09T00:46:37.493703Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8400-4
  a curric:KeyLearningPoint ;
  rdfs:label """Acid rain chemically reacts with carbonates that form many rocks to produce a salt,
  water and carbon dioxide."""@en ;
  dcterms:modified "2026-06-09T00:46:37.493708Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8400-5
  a curric:KeyLearningPoint ;
  rdfs:label "Acid rain can have long term effects on habitats and ecosystems."@en ;
  dcterms:modified "2026-06-09T00:46:37.493713Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9716-1
  a curric:KeyLearningPoint ;
  rdfs:label """Displacement reactions involve a more reactive element replacing another in a
  compound."""@en ;
  dcterms:modified "2026-06-09T00:46:37.493794Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9716-2
  a curric:KeyLearningPoint ;
  rdfs:label "Exothermic reactions release energy to the surroundings, often through heating."@en ;
  dcterms:modified "2026-06-09T00:46:37.493799Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9716-3
  a curric:KeyLearningPoint ;
  rdfs:label """The initial and final temperatures of the reaction mixture need to be recorded to
  calculate energy change."""@en ;
  dcterms:modified "2026-06-09T00:46:37.493804Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9716-4
  a curric:KeyLearningPoint ;
  rdfs:label "Hypotheses guide predictions about the effect of variables in experiments."@en ;
  dcterms:modified "2026-06-09T00:46:37.493811Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9716-5
  a curric:KeyLearningPoint ;
  rdfs:label "Bar charts can visually represent collected results to help analyse data."@en ;
  dcterms:modified "2026-06-09T00:46:37.493816Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9709-1
  a curric:KeyLearningPoint ;
