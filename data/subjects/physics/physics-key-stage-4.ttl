  dcterms:modified "2026-02-12T08:59:15.822656Z"^^xsd:dateTime .

oakcurric:keyword-neutron-star
  a curric:Keyword ;
  schema:name "neutron star"@en ;
  schema:description "an incredibly dense star, formed after a supernova"@en ;
  dcterms:modified "2026-02-12T08:59:15.822660Z"^^xsd:dateTime .

oakcurric:keyword-centripetal-force
