  dcterms:modified "2026-02-12T08:59:15.793590Z"^^xsd:dateTime .

oakcurric:keyword-refraction
  a curric:Keyword ;
  schema:name "refraction"@en ;
  schema:description """Occurs when light travels from one transparent medium to another, causing a change in direction."""@en ;
  dcterms:modified "2026-02-12T08:59:15.793699Z"^^xsd:dateTime .

oakcurric:keyword-nucleus
  a curric:Keyword ;
