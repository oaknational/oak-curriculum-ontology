oakcurric:keyword-satellite
  a curric:Keyword ;
  schema:name "satellite"@en ;
  schema:description "in this context, an object that moves around a planet in space"@en ;
  dcterms:modified "2026-02-12T08:59:15.790909Z"^^xsd:dateTime .

oakcurric:keyword-efficiency
  a curric:Keyword ;
  schema:name "efficiency"@en ;
  schema:description """energy efficiency means using technology that needs less energy to perform the same task"""@en ;
  dcterms:modified "2026-02-12T08:59:15.791330Z"^^xsd:dateTime .

oakcurric:keyword-carbon-emissions
  a curric:Keyword ;
  schema:name "carbon emissions"@en ;
  schema:description """the release of carbon into the atmosphere, contributing to the greenhouse effect and global warming"""@en ;
  dcterms:modified "2026-02-12T08:59:15.791433Z"^^xsd:dateTime .

oakcurric:keyword-power
  a curric:Keyword ;
  schema:name "power"@en ;
  schema:description "having control or authority over something or someone"@en ;
  dcterms:modified "2026-02-12T08:59:15.792948Z"^^xsd:dateTime .

oakcurric:keyword-stopping-forces
  a curric:Keyword ;
  schema:name "stopping forces"@en ;
  schema:description "Forces used to bring moving objects to a stop."@en ;
  dcterms:modified "2026-02-12T08:59:15.793146Z"^^xsd:dateTime .

oakcurric:keyword-stopping-time
  a curric:Keyword ;
  schema:name "stopping time"@en ;
  schema:description "The time taken for a moving object to stop."@en ;
  dcterms:modified "2026-02-12T08:59:15.793151Z"^^xsd:dateTime .

oakcurric:keyword-momentum
  a curric:Keyword ;
  schema:name "momentum"@en ;
  schema:description "The product of the mass and velocity of a moving object, p = m × v."@en ;
  dcterms:modified "2026-02-12T08:59:15.793155Z"^^xsd:dateTime .

oakcurric:keyword-crumple-zones
  a curric:Keyword ;
  schema:name "crumple zones"@en ;
  schema:description """Parts of a car designed to crumple during impacts, increasing the stopping time and reducing the stopping forces."""@en ;
  dcterms:modified "2026-02-12T08:59:15.793159Z"^^xsd:dateTime .

oakcurric:keyword-airbags
  a curric:Keyword ;
  schema:name "airbags"@en ;
  schema:description """These inflate rapidly in collisions and protect passengers from impacts with hard surfaces."""@en ;
  dcterms:modified "2026-02-12T08:59:15.793163Z"^^xsd:dateTime .

oakcurric:keyword-fossil-fuels
  a curric:Keyword ;
  schema:name "fossil fuels"@en ;
