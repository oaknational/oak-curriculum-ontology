  dcterms:modified "2026-02-12T08:59:15.823884Z"^^xsd:dateTime .

oakcurric:keyword-black-body
  a curric:Keyword ;
  schema:name "black body"@en ;
  schema:description """A black body is a theoretical object that absorbs all of the radiation that falls on it."""@en ;
  dcterms:modified "2026-02-12T08:59:15.823890Z"^^xsd:dateTime .

oakcurric:keyword-displacement-can
  a curric:Keyword ;
  schema:name "displacement can"@en ;
  schema:description "A can with a spout used to measure the volume of a submerged object."@en ;
  dcterms:modified "2026-02-12T08:59:15.824136Z"^^xsd:dateTime .

oakcurric:keyword-delta-v-v
  a curric:Keyword ;
  schema:name "delta v (Δv)"@en ;
  schema:description "The change in velocity is represented by 𝚫v."@en ;
  dcterms:modified "2026-02-12T08:59:15.824328Z"^^xsd:dateTime .

oakcurric:keyword-kilogram-metres-per-second
  a curric:Keyword ;
  schema:name "kilogram metres per second"@en ;
  schema:description "is the unit of momentum (kg m/s)"@en ;
  dcterms:modified "2026-02-12T08:59:15.825187Z"^^xsd:dateTime .

oakcurric:keyword-conservation-of-momentum
  a curric:Keyword ;
  schema:name "conservation of momentum"@en ;
  schema:description """is the principle that states, for a closed system, momentum is always conserved in any interaction"""@en ;
  dcterms:modified "2026-02-12T08:59:15.825191Z"^^xsd:dateTime .

oakcurric:keyword-collisions
  a curric:Keyword ;
  schema:name "collisions"@en ;
  schema:description "happen when two objects move together and hit each other"@en ;
  dcterms:modified "2026-02-12T08:59:15.825196Z"^^xsd:dateTime .

oakcurric:keyword-explosions
  a curric:Keyword ;
  schema:name "explosions"@en ;
  schema:description """happen when a single object splits, or combined objects separate, into pieces that move apart"""@en ;
  dcterms:modified "2026-02-12T08:59:15.825200Z"^^xsd:dateTime .

oakcurric:keyword-positron
  a curric:Keyword ;
