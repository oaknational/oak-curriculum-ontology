  dcterms:modified "2026-02-12T08:59:15.823535Z"^^xsd:dateTime .

oakcurric:keyword-cmbr
  a curric:Keyword ;
  schema:name "CMBR"@en ;
  schema:description """cosmic microwave background radiation is electromagnetic radiation produced in the hot early universe which has since been ‘stretched’ to the microwave part of the spectrum."""@en ;
  dcterms:modified "2026-02-12T08:59:15.823540Z"^^xsd:dateTime .

oakcurric:keyword-initial-velocity
  a curric:Keyword ;
  schema:name "initial velocity"@en ;
  schema:description """The initial velocity of an object is the velocity it starts with during a phase of motion."""@en ;
  dcterms:modified "2026-02-12T08:59:15.823775Z"^^xsd:dateTime .

oakcurric:keyword-average-velocity
  a curric:Keyword ;
  schema:name "average velocity"@en ;
  schema:description """The average velocity of an object travelling in a straight line is the change in distance divided by the time taken."""@en ;
  dcterms:modified "2026-02-12T08:59:15.823780Z"^^xsd:dateTime .

oakcurric:keyword-average-acceleration
  a curric:Keyword ;
  schema:name "average acceleration"@en ;
  schema:description """The average acceleration of an object is the change in velocity divided by the time taken."""@en ;
  dcterms:modified "2026-02-12T08:59:15.823784Z"^^xsd:dateTime .

oakcurric:keyword-random
  a curric:Keyword ;
  schema:name "random"@en ;
  schema:description "to happen entirely by chance"@en ;
  dcterms:modified "2026-02-12T08:59:15.823788Z"^^xsd:dateTime .

oakcurric:keyword-radioactive-decay
  a curric:Keyword ;
  schema:name "radioactive decay"@en ;
  schema:description "a random process by which unstable nuclei emit radiation"@en ;
  dcterms:modified "2026-02-12T08:59:15.823793Z"^^xsd:dateTime .

oakcurric:keyword-decay-curve
  a curric:Keyword ;
  schema:name "decay curve"@en ;
