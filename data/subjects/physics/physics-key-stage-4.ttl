oakcurric:keylearningpoint-lesson-28164-1
  a curric:KeyLearningPoint ;
  rdfs:label """A nuclear equation shows the particles in a nuclear decay, including the electric charge and mass number of each one."""@en ;
  dcterms:modified "2026-02-12T08:59:21.735370Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28164-2
  a curric:KeyLearningPoint ;
  rdfs:label """An alpha particle consists of two protons and two neutrons, has a mass of 4 and charge of +2."""@en ;
  dcterms:modified "2026-02-12T08:59:21.735374Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28164-3
  a curric:KeyLearningPoint ;
  rdfs:label "The protons and neutrons in an alpha particle are held together very strongly."@en ;
  dcterms:modified "2026-02-12T08:59:21.735378Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28164-4
  a curric:KeyLearningPoint ;
  rdfs:label "After an alpha or beta decay, a nucleus usually emits some gamma radiation."@en ;
  dcterms:modified "2026-02-12T08:59:21.735382Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28164-5
  a curric:KeyLearningPoint ;
  rdfs:label """A beta particle is an electron emitted at a high speed from a nucleus, its mass is close to zero and charge of –1."""@en ;
  dcterms:modified "2026-02-12T08:59:21.735385Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9105-1
  a curric:KeyLearningPoint ;
  rdfs:label "A light gate measures the time for a card of a fixed length to pass through it."@en ;
