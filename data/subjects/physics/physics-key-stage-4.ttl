# ----------------------------------------------------------------------
# Key Learning Points
# ----------------------------------------------------------------------

oakcurric:keylearningpoint-lesson-4921-1
  a curric:KeyLearningPoint ;
  rdfs:label "Increasing a stopping force decreases the time it takes a moving object to stop."@en ;
  dcterms:modified "2026-02-12T08:59:21.485624Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4921-2
  a curric:KeyLearningPoint ;
  rdfs:label "Extending the time it takes to stop reduces the size of the stopping force."@en ;
  dcterms:modified "2026-02-12T08:59:21.485628Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4921-3
  a curric:KeyLearningPoint ;
  rdfs:label """Many safety devices crumple on impact to increase the time that forces act before stopping a moving object."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485632Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5056-1
  a curric:KeyLearningPoint ;
  rdfs:label """As the p.d. across a filament lamp increases, it gets hotter and current through it increases in a non-ohmic way."""@en ;
  dcterms:modified "2026-02-12T08:59:21.654015Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5056-2
  a curric:KeyLearningPoint ;
  rdfs:label "The greater the p.d. across a filament lamp, the greater its resistance."@en ;
  dcterms:modified "2026-02-12T08:59:21.654020Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5056-3
  a curric:KeyLearningPoint ;
  rdfs:label """A metal is made of a lattice of positively charged ions with negatively charged electrons between."""@en ;
  dcterms:modified "2026-02-12T08:59:21.654027Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5056-4
  a curric:KeyLearningPoint ;
  rdfs:label """As a current flows through metal,  electrons moving through the ion lattice cause it to vibrate more vigorously."""@en ;
  dcterms:modified "2026-02-12T08:59:21.654031Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5056-5
  a curric:KeyLearningPoint ;
  rdfs:label """The more vigorously the ions (ion lattice) vibrate, the hotter the metal and the higher its resistance."""@en ;
  dcterms:modified "2026-02-12T08:59:21.654036Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5058-1
  a curric:KeyLearningPoint ;
  rdfs:label """The p.d. across a component in an electric circuit measures the size of push that is moving current through it."""@en ;
  dcterms:modified "2026-02-12T08:59:21.654040Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5058-2
  a curric:KeyLearningPoint ;
  rdfs:label """The p.d. across each component in a series circuit adds up to the p.d. across the battery."""@en ;
  dcterms:modified "2026-02-12T08:59:21.654045Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5058-3
  a curric:KeyLearningPoint ;
  rdfs:label "The current is the same through every component in a series circuit."@en ;
  dcterms:modified "2026-02-12T08:59:21.654049Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5058-4
  a curric:KeyLearningPoint ;
  rdfs:label """The larger the total resistance of a series circuit, the smaller the current through it."""@en ;
  dcterms:modified "2026-02-12T08:59:21.654054Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5058-5
  a curric:KeyLearningPoint ;
  rdfs:label """In a series circuit, the share of p.d. across each component is proportional to its resistance."""@en ;
  dcterms:modified "2026-02-12T08:59:21.654058Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4727-1
  a curric:KeyLearningPoint ;
  rdfs:label """A dynamics trolley speeds up (accelerates) along the whole length of a steep ramp."""@en ;
  dcterms:modified "2026-02-12T08:59:21.654063Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4727-2
  a curric:KeyLearningPoint ;
  rdfs:label "Instantaneous speed is the average speed over a very short time period."@en ;
  dcterms:modified "2026-02-12T08:59:21.654067Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4727-3
  a curric:KeyLearningPoint ;
  rdfs:label """Instantaneous speed can be estimated by measuring movement in a small time period."""@en ;
  dcterms:modified "2026-02-12T08:59:21.654074Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4727-4
  a curric:KeyLearningPoint ;
  rdfs:label """Anomalous readings should be repeated and replaced or removed from sets of repeat readings."""@en ;
  dcterms:modified "2026-02-12T08:59:21.654079Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9107-1
  a curric:KeyLearningPoint ;
  rdfs:label "The velocity of an object is equal to the gradient of a displacement-time graph."@en ;
  dcterms:modified "2026-02-12T08:59:21.654083Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9107-2
  a curric:KeyLearningPoint ;
  rdfs:label "A direction in which velocity and displacement are measured needs to be chosen."@en ;
  dcterms:modified "2026-02-12T08:59:21.654088Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9107-3
  a curric:KeyLearningPoint ;
  rdfs:label """A negative gradient on a displacement-time graph (sloping downwards) represents velocity in the opposite direction."""@en ;
  dcterms:modified "2026-02-12T08:59:21.654092Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9107-4
  a curric:KeyLearningPoint ;
  rdfs:label """A negative value for displacement represents a position ‘behind’ the starting position."""@en ;
  dcterms:modified "2026-02-12T08:59:21.654097Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9107-5
  a curric:KeyLearningPoint ;
  rdfs:label """Instantaneous velocity of an object is equal to the gradient of a tangent to a displacement-time curve."""@en ;
  dcterms:modified "2026-02-12T08:59:21.654101Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5081-1
  a curric:KeyLearningPoint ;
  rdfs:label """A sound can be represented by an electronic signal changing in time to match the sound wave."""@en ;
  dcterms:modified "2026-02-12T08:59:21.654106Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5081-2
  a curric:KeyLearningPoint ;
  rdfs:label """Loudspeakers use the motor effect to convert electrical signals into sound waves."""@en ;
  dcterms:modified "2026-02-12T08:59:21.654110Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5081-3
  a curric:KeyLearningPoint ;
  rdfs:label """A moving–coil loudspeaker is made from a cone connected to a coil of wire that moves in relation to a fixed magnet."""@en ;
  dcterms:modified "2026-02-12T08:59:21.654115Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5081-4
  a curric:KeyLearningPoint ;
  rdfs:label """Microphones use the generator effect to convert sound waves into electrical signals."""@en ;
  dcterms:modified "2026-02-12T08:59:21.654119Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5081-5
  a curric:KeyLearningPoint ;
  rdfs:label """A moving–coil microphone is made from a diaphragm connected to a coil of wire that moves in relation to a fixed magnet."""@en ;
  dcterms:modified "2026-02-12T08:59:21.654124Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4916-1
  a curric:KeyLearningPoint ;
  rdfs:label """An object that is dropped experiences a constant gravitational force towards the centre of Earth."""@en ;
  dcterms:modified "2026-02-12T08:59:21.654129Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4916-2
  a curric:KeyLearningPoint ;
  rdfs:label """For a falling object, drag acts in the opposite direction to the gravitational force."""@en ;
  dcterms:modified "2026-02-12T08:59:21.654133Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4916-3
  a curric:KeyLearningPoint ;
  rdfs:label "As a falling object speeds up, the air resistance pushing up on it increases."@en ;
  dcterms:modified "2026-02-12T08:59:21.654138Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4916-4
  a curric:KeyLearningPoint ;
  rdfs:label """When the resultant force on a falling object becomes zero, the object reaches terminal velocity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.654142Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5039-1
  a curric:KeyLearningPoint ;
  rdfs:label """The p.d. across each branch of a parallel circuit is the same as the p.d. across the battery."""@en ;
  dcterms:modified "2026-02-12T08:59:21.654773Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5039-2
  a curric:KeyLearningPoint ;
  rdfs:label """The current through each branch of a parallel circuit adds up to the current through the battery."""@en ;
  dcterms:modified "2026-02-12T08:59:21.654777Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5039-3
  a curric:KeyLearningPoint ;
  rdfs:label """Adding a component in a new branch of a parallel circuit reduces the resistance of the circuit."""@en ;
  dcterms:modified "2026-02-12T08:59:21.654782Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5039-4
  a curric:KeyLearningPoint ;
  rdfs:label """Adding a component to an existing branch of a parallel circuit increases the resistance of the circuit."""@en ;
  dcterms:modified "2026-02-12T08:59:21.654786Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5039-5
  a curric:KeyLearningPoint ;
  rdfs:label """The p.d. across the terminals of a battery does not change when components are added to a circuit."""@en ;
  dcterms:modified "2026-02-12T08:59:21.654791Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4726-1
  a curric:KeyLearningPoint ;
  rdfs:label "Average speed = distance/time"@en ;
  dcterms:modified "2026-02-12T08:59:21.654795Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4726-2
  a curric:KeyLearningPoint ;
  rdfs:label "The speed of sound in air is about 330 m/s."@en ;
  dcterms:modified "2026-02-12T08:59:21.654800Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4726-3
  a curric:KeyLearningPoint ;
  rdfs:label "Scalar quantities have magnitude only."@en ;
  dcterms:modified "2026-02-12T08:59:21.654804Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4726-4
  a curric:KeyLearningPoint ;
  rdfs:label "Speed and distance are scalar quantities."@en ;
  dcterms:modified "2026-02-12T08:59:21.654811Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4726-5
  a curric:KeyLearningPoint ;
  rdfs:label """Relative speed is the speed an object is moving towards or away from another object, which may also be moving."""@en ;
  dcterms:modified "2026-02-12T08:59:21.654816Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5059-1
  a curric:KeyLearningPoint ;
  rdfs:label """An LDR is made of a semiconductor, and the brighter the light shining on it, the lower its resistance."""@en ;
  dcterms:modified "2026-02-12T08:59:21.654820Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5059-2
  a curric:KeyLearningPoint ;
  rdfs:label """Light transfers energy that enables electrons in a semiconductor to move as they do in a metal conductor."""@en ;
  dcterms:modified "2026-02-12T08:59:21.654825Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5059-3
  a curric:KeyLearningPoint ;
  rdfs:label """A thermistor is made of a semiconductor, and the hotter it is, the lower its resistance."""@en ;
  dcterms:modified "2026-02-12T08:59:21.654829Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5059-4
  a curric:KeyLearningPoint ;
  rdfs:label """Heating transfers energy that enables electrons in a semiconductor to move as they do in a metal conductor."""@en ;
  dcterms:modified "2026-02-12T08:59:21.654836Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5059-5
  a curric:KeyLearningPoint ;
  rdfs:label """A potential divider circuit can be set up with an LDR/thermistor to trigger a switch if it becomes too dark or too cold."""@en ;
  dcterms:modified "2026-02-12T08:59:21.654841Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9889-1
  a curric:KeyLearningPoint ;
  rdfs:label "Average speed = distance / time."@en ;
  dcterms:modified "2026-02-12T08:59:21.654864Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9889-2
  a curric:KeyLearningPoint ;
  rdfs:label "The speed of sound in air is about 330 m/s."@en ;
  dcterms:modified "2026-02-12T08:59:21.654868Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9889-3
  a curric:KeyLearningPoint ;
  rdfs:label "Scalar quantities have magnitude only."@en ;
  dcterms:modified "2026-02-12T08:59:21.654873Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9889-4
  a curric:KeyLearningPoint ;
  rdfs:label "Speed and distance are scalar quantities."@en ;
  dcterms:modified "2026-02-12T08:59:21.654877Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9889-5
  a curric:KeyLearningPoint ;
  rdfs:label """Relative speed is the speed an object is moving towards or away from another object, which may also be moving."""@en ;
  dcterms:modified "2026-02-12T08:59:21.654882Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9130-1
  a curric:KeyLearningPoint ;
  rdfs:label """In forward–bias, a diode has a very small resistance when the p.d. is larger than the threshold voltage."""@en ;
  dcterms:modified "2026-02-12T08:59:21.654886Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9130-2
  a curric:KeyLearningPoint ;
  rdfs:label """In reverse–bias, a diode has a very large resistance and very little current can flow."""@en ;
  dcterms:modified "2026-02-12T08:59:21.654891Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9130-3
  a curric:KeyLearningPoint ;
  rdfs:label """The greater the p.d. across a component, the larger the push on electric charges in the component."""@en ;
  dcterms:modified "2026-02-12T08:59:21.654898Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9130-4
  a curric:KeyLearningPoint ;
  rdfs:label """The resistance of a component is calculated from an I–V graph using pairs of readings and the equation R = V ÷ I."""@en ;
  dcterms:modified "2026-02-12T08:59:21.654903Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9130-5
  a curric:KeyLearningPoint ;
  rdfs:label """The greater the current through a component, the larger the heating effect on it."""@en ;
  dcterms:modified "2026-02-12T08:59:21.654908Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9903-1
  a curric:KeyLearningPoint ;
  rdfs:label "A velocity-time graph shows how velocity changes with time."@en ;
  dcterms:modified "2026-02-12T08:59:21.654912Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9903-2
  a curric:KeyLearningPoint ;
  rdfs:label "Acceleration is equal to the gradient of a velocity-time graph."@en ;
  dcterms:modified "2026-02-12T08:59:21.654917Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9903-3
  a curric:KeyLearningPoint ;
  rdfs:label """A falling line shows decreasing velocity called deceleration, which is a negative acceleration."""@en ;
  dcterms:modified "2026-02-12T08:59:21.654921Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9108-1
  a curric:KeyLearningPoint ;
  rdfs:label "A velocity-time graph shows how velocity changes with time."@en ;
  dcterms:modified "2026-02-12T08:59:21.656323Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9108-2
  a curric:KeyLearningPoint ;
  rdfs:label "Acceleration is equal to the gradient of a velocity-time graph."@en ;
  dcterms:modified "2026-02-12T08:59:21.656327Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9108-3
  a curric:KeyLearningPoint ;
  rdfs:label """A falling line shows decreasing velocity called deceleration, which is a negative acceleration."""@en ;
  dcterms:modified "2026-02-12T08:59:21.656332Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4731-1
  a curric:KeyLearningPoint ;
  rdfs:label "A dynamics trolley has a steady acceleration down a steep ramp."@en ;
  dcterms:modified "2026-02-12T08:59:21.656337Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4731-2
  a curric:KeyLearningPoint ;
  rdfs:label """Acceleration = change of velocity ÷ time and change in velocity = final velocity – initial velocity"""@en ;
  dcterms:modified "2026-02-12T08:59:21.656341Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4731-3
  a curric:KeyLearningPoint ;
  rdfs:label """Light gates can improve accuracy of measurement of instantaneous velocity and reduces random errors."""@en ;
  dcterms:modified "2026-02-12T08:59:21.656348Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4731-4
  a curric:KeyLearningPoint ;
  rdfs:label "For a fair test, total mass of the system must be kept constant."@en ;
  dcterms:modified "2026-02-12T08:59:21.656353Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4731-5
  a curric:KeyLearningPoint ;
  rdfs:label "A compensated ramp can counteract the effect of friction."@en ;
  dcterms:modified "2026-02-12T08:59:21.656358Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5077-1
  a curric:KeyLearningPoint ;
  rdfs:label "Wire in a motor is insulated so that the current flows around the coil"@en ;
  dcterms:modified "2026-02-12T08:59:21.656363Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5077-2
  a curric:KeyLearningPoint ;
  rdfs:label "Connections in a motor slide over each other to prevent tangled wires"@en ;
  dcterms:modified "2026-02-12T08:59:21.656367Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5077-3
  a curric:KeyLearningPoint ;
  rdfs:label """When the coil in a motor kit is horizontal it is connected and a force acts on the sides 90 deg. to the magnetic field"""@en ;
  dcterms:modified "2026-02-12T08:59:21.656372Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5077-4
  a curric:KeyLearningPoint ;
  rdfs:label """Every half–turn, the coil connections in a motor kit swap over and change the direction of current through the coil"""@en ;
  dcterms:modified "2026-02-12T08:59:21.656376Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5077-5
  a curric:KeyLearningPoint ;
  rdfs:label """Each side of a coil in a motor kit at 90º to the magnetic field is pushed alternatively up then down every half turn"""@en ;
  dcterms:modified "2026-02-12T08:59:21.656381Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6605-1
  a curric:KeyLearningPoint ;
  rdfs:label """An appropriate range of p.d. values includes 0 V and the maximum p.d. of the lamp and at least four other readings."""@en ;
  dcterms:modified "2026-02-12T08:59:21.656385Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6605-2
  a curric:KeyLearningPoint ;
  rdfs:label """For electricity investigations, it is good practice to take many more than the minimum number of measurements."""@en ;
  dcterms:modified "2026-02-12T08:59:21.656390Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6605-3
  a curric:KeyLearningPoint ;
  rdfs:label """After plotting a graph, extra readings could be taken to fill gaps or to check possible errors."""@en ;
  dcterms:modified "2026-02-12T08:59:21.656394Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6605-4
  a curric:KeyLearningPoint ;
  rdfs:label """Plots that lie off the best fit line are possible errors that need to be checked."""@en ;
  dcterms:modified "2026-02-12T08:59:21.656399Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6605-5
  a curric:KeyLearningPoint ;
  rdfs:label """The resistance of a filament lamp is calculated from an I–V graph using pairs of readings and the equation R = V ÷ I."""@en ;
  dcterms:modified "2026-02-12T08:59:21.656403Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5044-1
  a curric:KeyLearningPoint ;
  rdfs:label """Displacement at a point of a wave is the distance that the wave medium is from its rest position at that point."""@en ;
  dcterms:modified "2026-02-12T08:59:21.656408Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5044-2
  a curric:KeyLearningPoint ;
  rdfs:label "Amplitude is the maximum displacement of a wave (up or down, or side to side)."@en ;
  dcterms:modified "2026-02-12T08:59:21.656412Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5044-3
  a curric:KeyLearningPoint ;
  rdfs:label "A displacement-distance graph of a wave is not a picture of the wave."@en ;
  dcterms:modified "2026-02-12T08:59:21.656417Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5044-4
  a curric:KeyLearningPoint ;
  rdfs:label """The distance between two wave crests on a displacement-distance graph is equal to one wavelength."""@en ;
  dcterms:modified "2026-02-12T08:59:21.656421Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5044-5
  a curric:KeyLearningPoint ;
  rdfs:label """A positive (or negative) displacement shows part of the wave above (or below) the equilibrium position."""@en ;
  dcterms:modified "2026-02-12T08:59:21.656429Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6606-1
  a curric:KeyLearningPoint ;
  rdfs:label """The properties of a diode are different, depending on the direction of p.d. across it."""@en ;
  dcterms:modified "2026-02-12T08:59:21.656436Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6606-2
  a curric:KeyLearningPoint ;
  rdfs:label """An appropriate range of p.d. includes 0 V and the maximum voltage of the diode and at least four other readings."""@en ;
  dcterms:modified "2026-02-12T08:59:21.656441Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6606-3
  a curric:KeyLearningPoint ;
  rdfs:label """An appropriate range for a diode includes the maximum p.d. in both directions, with positive and negative values."""@en ;
  dcterms:modified "2026-02-12T08:59:21.656445Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6606-4
  a curric:KeyLearningPoint ;
  rdfs:label """For electricity investigations, it is good practice to take many more than the minimum number of measurements."""@en ;
  dcterms:modified "2026-02-12T08:59:21.656450Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9153-1
  a curric:KeyLearningPoint ;
  rdfs:label "Electric charge, Q, is measured in coulombs (C)."@en ;
  dcterms:modified "2026-02-12T08:59:21.656477Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9153-2
  a curric:KeyLearningPoint ;
  rdfs:label """Electric current is a measure of the rate of flow of electric charge, calculated using: I = Q ÷ t."""@en ;
  dcterms:modified "2026-02-12T08:59:21.656482Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9153-3
  a curric:KeyLearningPoint ;
  rdfs:label """Potential difference is a measure of the energy transferred by each coulomb of charge, calculated using: V = E ÷ Q."""@en ;
  dcterms:modified "2026-02-12T08:59:21.656486Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9153-4
  a curric:KeyLearningPoint ;
  rdfs:label """Combining I = Q ÷ t and V = E ÷ Q gives the equation: E ÷ t = I × V. This is equivalent to P = I × V."""@en ;
  dcterms:modified "2026-02-12T08:59:21.656491Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9153-5
  a curric:KeyLearningPoint ;
  rdfs:label """Unknown variables in the power equation can often be calculated using: I = V ÷ R."""@en ;
  dcterms:modified "2026-02-12T08:59:21.656495Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9112-1
  a curric:KeyLearningPoint ;
  rdfs:label """Current can be calculated using the equation: current = p.d. ÷ resistance (I = V ÷ R)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.656500Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9112-2
  a curric:KeyLearningPoint ;
  rdfs:label """The rules of current and p.d. for a parallel circuit can be applied to find some missing values of current and p.d."""@en ;
  dcterms:modified "2026-02-12T08:59:21.656504Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9112-3
  a curric:KeyLearningPoint ;
  rdfs:label """The equation I = V ÷ R can be rearranged so that either p.d. or R is the subject of the equation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.656509Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9112-4
  a curric:KeyLearningPoint ;
  rdfs:label """If any two values in the equation I = V ÷ R are known, the third can be calculated."""@en ;
  dcterms:modified "2026-02-12T08:59:21.656513Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9112-5
  a curric:KeyLearningPoint ;
  rdfs:label """If only one value in I = V ÷ R is shown for a component, circuit rules need to be applied to the rest of the circuit."""@en ;
  dcterms:modified "2026-02-12T08:59:21.656528Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5119-1
  a curric:KeyLearningPoint ;
  rdfs:label "Protons have a positive electric charge of +1 and a mass number of 1."@en ;
  dcterms:modified "2026-02-12T08:59:21.657124Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5119-2
  a curric:KeyLearningPoint ;
  rdfs:label "Neutrons have no electric charge and have a mass number of 1."@en ;
  dcterms:modified "2026-02-12T08:59:21.657129Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5119-3
  a curric:KeyLearningPoint ;
  rdfs:label """The atomic number of an element equals the number of protons in the nucleus of each atom of that element."""@en ;
  dcterms:modified "2026-02-12T08:59:21.657133Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5119-4
  a curric:KeyLearningPoint ;
  rdfs:label """The atomic number of an element equals the number of electrons in each atom of that element."""@en ;
  dcterms:modified "2026-02-12T08:59:21.657138Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5119-5
  a curric:KeyLearningPoint ;
  rdfs:label """Atoms of an element that have different numbers of neutrons in their nuclei are isotopes of the element."""@en ;
  dcterms:modified "2026-02-12T08:59:21.657142Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5050-1
  a curric:KeyLearningPoint ;
  rdfs:label "The speed of wave can be caluated using wave speed = frequency × wavelength."@en ;
  dcterms:modified "2026-02-12T08:59:21.657146Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5050-2
  a curric:KeyLearningPoint ;
  rdfs:label "The speed of a wave can be caluated using wave speed = distance ÷ time."@en ;
  dcterms:modified "2026-02-12T08:59:21.657151Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5050-3
  a curric:KeyLearningPoint ;
  rdfs:label """The choice of equation to use to caluate wave speed depends on the information provided in the question."""@en ;
  dcterms:modified "2026-02-12T08:59:21.657155Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5050-4
  a curric:KeyLearningPoint ;
  rdfs:label "Prefixes can be used with units to show very large or very small values."@en ;
  dcterms:modified "2026-02-12T08:59:21.657160Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5050-5
  a curric:KeyLearningPoint ;
  rdfs:label """The frequency of a wave does not change as it crosses a boundary from one wave medium into another."""@en ;
  dcterms:modified "2026-02-12T08:59:21.657164Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5035-1
  a curric:KeyLearningPoint ;
  rdfs:label "Two unlike electric charges attract each other."@en ;
  dcterms:modified "2026-02-12T08:59:21.657171Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5035-2
  a curric:KeyLearningPoint ;
  rdfs:label "Two like electric charges repel each other."@en ;
  dcterms:modified "2026-02-12T08:59:21.657178Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5035-3
  a curric:KeyLearningPoint ;
  rdfs:label """In an electric circuit, electrons are forced towards the positive terminal of a battery."""@en ;
  dcterms:modified "2026-02-12T08:59:21.657183Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5035-4
  a curric:KeyLearningPoint ;
  rdfs:label """Electric current is the amount of charge that passes a point in a circuit in each second."""@en ;
  dcterms:modified "2026-02-12T08:59:21.657190Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5035-5
  a curric:KeyLearningPoint ;
  rdfs:label "Current can be found using the equation: current = charge ÷ time."@en ;
  dcterms:modified "2026-02-12T08:59:21.657195Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4918-1
  a curric:KeyLearningPoint ;
  rdfs:label """Stopping distance is the distance travelled both as a drive reacts and then for the brakes to bring a vehicle to a stop"""@en ;
  dcterms:modified "2026-02-12T08:59:21.657199Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4918-2
  a curric:KeyLearningPoint ;
  rdfs:label """Reaction time of a drive can be affected by tiredness, drugs, alcohol or distractions"""@en ;
  dcterms:modified "2026-02-12T08:59:21.657204Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4918-3
  a curric:KeyLearningPoint ;
  rdfs:label """Braking distance can be affected by adverse road and weather conditions and the condition of the vehicle"""@en ;
  dcterms:modified "2026-02-12T08:59:21.657208Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4918-4
  a curric:KeyLearningPoint ;
  rdfs:label "When braking, work is done on the brakes that heats them up"@en ;
  dcterms:modified "2026-02-12T08:59:21.657213Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4918-5
  a curric:KeyLearningPoint ;
  rdfs:label """If brakes overheat they can stop working effectively and lead to a loss of control"""@en ;
  dcterms:modified "2026-02-12T08:59:21.657217Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9127-1
  a curric:KeyLearningPoint ;
  rdfs:label "A wire heats up when a current flows and its temperature will vary over time."@en ;
  dcterms:modified "2026-02-12T08:59:21.658436Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9127-2
  a curric:KeyLearningPoint ;
  rdfs:label "A water bath helps to keep the temperature of a wire constant."@en ;
  dcterms:modified "2026-02-12T08:59:21.658442Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9127-3
  a curric:KeyLearningPoint ;
  rdfs:label "Turning a circuit on for a very short time reduces the heating effect in a wire."@en ;
  dcterms:modified "2026-02-12T08:59:21.658448Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9127-4
  a curric:KeyLearningPoint ;
  rdfs:label """In electricity investigations, it is often easy to take lots of readings rather than a few, repeated readings."""@en ;
  dcterms:modified "2026-02-12T08:59:21.658452Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9127-5
  a curric:KeyLearningPoint ;
  rdfs:label """The resistance of a wire is directly proportional to its length, at a constant temperature."""@en ;
  dcterms:modified "2026-02-12T08:59:21.658457Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5087-1
  a curric:KeyLearningPoint ;
  rdfs:label """The different colours of light are electromagnetic waves with different frequencies and wavelengths."""@en ;
  dcterms:modified "2026-02-12T08:59:21.658461Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5087-2
  a curric:KeyLearningPoint ;
  rdfs:label """A triangular prism can produce a colour spectrum from white light, showing it is a mixture of all visible wavelengths."""@en ;
  dcterms:modified "2026-02-12T08:59:21.658469Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5087-3
  a curric:KeyLearningPoint ;
  rdfs:label """From red to violet in the spectrum, frequency increases and wavelength decreases. Higher frequencies refract further."""@en ;
  dcterms:modified "2026-02-12T08:59:21.658475Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5087-4
  a curric:KeyLearningPoint ;
  rdfs:label """Opaque objects transmit no incident light. Their colour depends on which wavelengths of incident light are reflected."""@en ;
  dcterms:modified "2026-02-12T08:59:21.658480Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5087-5
  a curric:KeyLearningPoint ;
  rdfs:label """Colour filters only transmit some wavelengths. The filter colour depends on the transmitted wavelengths."""@en ;
  dcterms:modified "2026-02-12T08:59:21.658485Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6584-1
  a curric:KeyLearningPoint ;
  rdfs:label """When rays of light are brought to a focus a real image forms. A real image can be projected onto a screen."""@en ;
  dcterms:modified "2026-02-12T08:59:21.658703Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6584-2
  a curric:KeyLearningPoint ;
  rdfs:label """Virtual images occur at points where rays appear to (but do not actually) originate from. They cannot form on a screen."""@en ;
  dcterms:modified "2026-02-12T08:59:21.658710Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6584-3
  a curric:KeyLearningPoint ;
  rdfs:label """The size and position of a virtual image is found by drawing virtual rays to find where rays appear to originate from."""@en ;
  dcterms:modified "2026-02-12T08:59:21.658715Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6584-4
  a curric:KeyLearningPoint ;
  rdfs:label """Upright virtual images are produced by concave lenses, and objects within a focal length of a convex lens."""@en ;
  dcterms:modified "2026-02-12T08:59:21.658720Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6584-5
  a curric:KeyLearningPoint ;
  rdfs:label """Convex lenses fix long sight by shortening the focus. Concave lenses fix short sight by lengthening the focus."""@en ;
  dcterms:modified "2026-02-12T08:59:21.658724Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5098-1
  a curric:KeyLearningPoint ;
  rdfs:label "Electric charge, Q, is measured in coulombs (C)."@en ;
  dcterms:modified "2026-02-12T08:59:21.658729Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5098-2
  a curric:KeyLearningPoint ;
  rdfs:label """Electric current is a measure of the rate of flow of electric charge, calculated using: I = Q ÷ t."""@en ;
  dcterms:modified "2026-02-12T08:59:21.658733Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5098-3
  a curric:KeyLearningPoint ;
  rdfs:label """Potential difference is a measure of the energy transferred by each coulomb of charge, calculated using: V = E ÷ Q."""@en ;
  dcterms:modified "2026-02-12T08:59:21.658738Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5098-4
  a curric:KeyLearningPoint ;
  rdfs:label """Combining I = Q ÷ t and V = E ÷ Q gives the equation: E ÷ t = I × V. This is equivalent to P = I × V."""@en ;
  dcterms:modified "2026-02-12T08:59:21.658742Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5098-5
  a curric:KeyLearningPoint ;
  rdfs:label """Unknown variables in the power equation can often be calculated using: I = V ÷ R."""@en ;
  dcterms:modified "2026-02-12T08:59:21.658747Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9140-1
  a curric:KeyLearningPoint ;
  rdfs:label """An object that is dropped experiences a constant gravitational force towards the centre of the Earth"""@en ;
  dcterms:modified "2026-02-12T08:59:21.658751Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9140-2
  a curric:KeyLearningPoint ;
  rdfs:label """For a falling object, air resistance acts in the opposite direction to the gravitational force"""@en ;
  dcterms:modified "2026-02-12T08:59:21.658756Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9140-3
  a curric:KeyLearningPoint ;
  rdfs:label "As a falling object speeds up, the air resistance pushing up on it increases"@en ;
  dcterms:modified "2026-02-12T08:59:21.658761Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9140-4
  a curric:KeyLearningPoint ;
  rdfs:label """When the resultant force on a falling object becomes zero, the object reaches terminal velocity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.658766Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5088-1
  a curric:KeyLearningPoint ;
  rdfs:label "Convex lenses can produce an inverted image on a screen by refracting light."@en ;
  dcterms:modified "2026-02-12T08:59:21.659377Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5088-2
  a curric:KeyLearningPoint ;
  rdfs:label """Rays parallel to the principal axis are refracted to the principal focus, located at the focal length of a convex lens."""@en ;
  dcterms:modified "2026-02-12T08:59:21.659382Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5088-3
  a curric:KeyLearningPoint ;
  rdfs:label """The image distance and size (magnification) depend on the power of the lens and the object distance."""@en ;
  dcterms:modified "2026-02-12T08:59:21.659386Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5088-4
  a curric:KeyLearningPoint ;
  rdfs:label """As the object distance decreases, the image distance and size both increase, until the object reaches the focal length."""@en ;
  dcterms:modified "2026-02-12T08:59:21.659391Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5088-5
  a curric:KeyLearningPoint ;
  rdfs:label """If the object is too close to the lens, the rays leaving the lens are parallel/diverging, images can't form on a screen."""@en ;
  dcterms:modified "2026-02-12T08:59:21.659396Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5046-1
  a curric:KeyLearningPoint ;
  rdfs:label """In a longitudinal wave, the oscillations / vibrations are in the same direction in which the wave travels."""@en ;
  dcterms:modified "2026-02-12T08:59:21.659400Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5046-2
  a curric:KeyLearningPoint ;
  rdfs:label """Displacement is the distance one part of a wave is moved away from its rest position."""@en ;
  dcterms:modified "2026-02-12T08:59:21.659405Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5046-3
  a curric:KeyLearningPoint ;
  rdfs:label """In a longitudinal wave, forwards displacement is positive and backwards displacement is negative."""@en ;
  dcterms:modified "2026-02-12T08:59:21.659409Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5046-4
  a curric:KeyLearningPoint ;
  rdfs:label """Wavelength of a longitudinal wave is the distance between one compression (or rarefaction) and the next."""@en ;
  dcterms:modified "2026-02-12T08:59:21.659414Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9123-1
  a curric:KeyLearningPoint ;
  rdfs:label """In a fair test, only the independent variable is changed so that no other changes could affect the results."""@en ;
  dcterms:modified "2026-02-12T08:59:21.659419Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9123-2
  a curric:KeyLearningPoint ;
  rdfs:label "The variables that are deliberately kept the same are called control variables."@en ;
  dcterms:modified "2026-02-12T08:59:21.659423Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9123-3
  a curric:KeyLearningPoint ;
  rdfs:label "A lid on a beaker prevents transfer of energy by convection currents."@en ;
  dcterms:modified "2026-02-12T08:59:21.659428Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9123-4
  a curric:KeyLearningPoint ;
  rdfs:label "Gas is a very poor thermal conductor."@en ;
  dcterms:modified "2026-02-12T08:59:21.659433Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6583-1
  a curric:KeyLearningPoint ;
  rdfs:label """In cameras and the human eye, the required image distance < the object distance so the image is diminished and inverted."""@en ;
  dcterms:modified "2026-02-12T08:59:21.660471Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6583-2
  a curric:KeyLearningPoint ;
  rdfs:label """In projectors, the required image distance > the object distance so the image is magnified and inverted."""@en ;
  dcterms:modified "2026-02-12T08:59:21.660476Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6583-3
  a curric:KeyLearningPoint ;
  rdfs:label """A ray incident on a convex lens parallel to the principal axis is refracted to pass through principal focus."""@en ;
  dcterms:modified "2026-02-12T08:59:21.660480Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6583-4
  a curric:KeyLearningPoint ;
  rdfs:label "A ray incident on the centre of a convex lens is not refracted."@en ;
  dcterms:modified "2026-02-12T08:59:21.660485Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6583-5
  a curric:KeyLearningPoint ;
  rdfs:label """A ray incident on a convex lens from the principal focus is refracted so it becomes parallel to the principal axis."""@en ;
  dcterms:modified "2026-02-12T08:59:21.660490Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9095-1
  a curric:KeyLearningPoint ;
  rdfs:label """The particles in liquids and gases move very quickly and randomly in every direction; they are both fluids."""@en ;
  dcterms:modified "2026-02-12T08:59:21.660494Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9095-2
  a curric:KeyLearningPoint ;
  rdfs:label """Particles in liquids are very close together; the gaps between particles in gases are much larger than the particles."""@en ;
  dcterms:modified "2026-02-12T08:59:21.660499Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9095-3
  a curric:KeyLearningPoint ;
  rdfs:label "The pressure at any point in a fluid is the same size in every direction."@en ;
  dcterms:modified "2026-02-12T08:59:21.660503Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9095-4
  a curric:KeyLearningPoint ;
  rdfs:label "The particles in a fluid exert pressure on a surface by colliding with it."@en ;
  dcterms:modified "2026-02-12T08:59:21.660508Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9095-5
  a curric:KeyLearningPoint ;
  rdfs:label "Pressure is calculated using the equation: pressure = force ÷ surface area."@en ;
  dcterms:modified "2026-02-12T08:59:21.660512Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6612-1
  a curric:KeyLearningPoint ;
  rdfs:label """A soft iron core increases the strength of an electromagnet because it becomes magnetised when it is turned on."""@en ;
  dcterms:modified "2026-02-12T08:59:21.661194Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6612-2
  a curric:KeyLearningPoint ;
  rdfs:label """The more tightly wound the coil of wire is in an electromagnet, the stronger its magnetic field."""@en ;
  dcterms:modified "2026-02-12T08:59:21.661199Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6612-3
  a curric:KeyLearningPoint ;
  rdfs:label """The greater the current through the coil of an electromagnet, the stronger its magnetic field."""@en ;
  dcterms:modified "2026-02-12T08:59:21.661203Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6612-4
  a curric:KeyLearningPoint ;
  rdfs:label """The strength of an electromagnet is directly proportional to the current through it."""@en ;
  dcterms:modified "2026-02-12T08:59:21.661208Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9106-1
  a curric:KeyLearningPoint ;
  rdfs:label "The velocity of an object is equal to the gradient of a displacement-time graph."@en ;
  dcterms:modified "2026-02-12T08:59:21.661213Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9106-2
  a curric:KeyLearningPoint ;
  rdfs:label "A direction in which velocity and displacement are measured needs to be chosen."@en ;
  dcterms:modified "2026-02-12T08:59:21.661217Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9106-3
  a curric:KeyLearningPoint ;
  rdfs:label """A negative gradient on a displacement-time graph (sloping downwards) represents velocity in the opposite direction."""@en ;
  dcterms:modified "2026-02-12T08:59:21.661222Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9106-4
  a curric:KeyLearningPoint ;
  rdfs:label """A negative value for displacement represents a position ‘behind’ the starting position."""@en ;
  dcterms:modified "2026-02-12T08:59:21.661226Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9147-1
  a curric:KeyLearningPoint ;
  rdfs:label "Specular reflection is reflection from a smooth surface in a single direction."@en ;
  dcterms:modified "2026-02-12T08:59:21.661822Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9147-2
  a curric:KeyLearningPoint ;
  rdfs:label "Diffuse reflection is reflection from a rough surface in multiple directions."@en ;
  dcterms:modified "2026-02-12T08:59:21.661827Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9147-3
  a curric:KeyLearningPoint ;
  rdfs:label """The angle of incidence equals the angle of reflection. Angles are measured from the normal."""@en ;
  dcterms:modified "2026-02-12T08:59:21.661831Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9147-4
  a curric:KeyLearningPoint ;
  rdfs:label "Light can be thought of as a wave (ripples) in electric and magnetic fields."@en ;
  dcterms:modified "2026-02-12T08:59:21.661838Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9147-5
  a curric:KeyLearningPoint ;
  rdfs:label "Like all waves, light can be represented using rays or wavefronts."@en ;
  dcterms:modified "2026-02-12T08:59:21.661843Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8153-1
  a curric:KeyLearningPoint ;
  rdfs:label "Density is calculated using the equation: density = mass ÷ volume."@en ;
  dcterms:modified "2026-02-12T08:59:21.662393Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8153-2
  a curric:KeyLearningPoint ;
  rdfs:label "Density is measured in kg/m³ or g/cm³."@en ;
  dcterms:modified "2026-02-12T08:59:21.662400Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8153-3
  a curric:KeyLearningPoint ;
  rdfs:label """The volume of water displaced by a submerged object is equal to the volume of the object."""@en ;
  dcterms:modified "2026-02-12T08:59:21.662405Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8153-4
  a curric:KeyLearningPoint ;
  rdfs:label """The dimensions of a regular cuboid can be measured accurately with Vernier callipers."""@en ;
  dcterms:modified "2026-02-12T08:59:21.662410Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8153-5
  a curric:KeyLearningPoint ;
  rdfs:label """The volume of a regular cuboid is calculated using the equation: volume = length × width × height."""@en ;
  dcterms:modified "2026-02-12T08:59:21.662414Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5034-1
  a curric:KeyLearningPoint ;
  rdfs:label "Two unlike electric charges attract each other."@en ;
  dcterms:modified "2026-02-12T08:59:21.662419Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5034-2
  a curric:KeyLearningPoint ;
  rdfs:label "Two like electric charges repel each other."@en ;
  dcterms:modified "2026-02-12T08:59:21.662423Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5034-3
  a curric:KeyLearningPoint ;
  rdfs:label "There is an electric field radiating out from an electric charge."@en ;
  dcterms:modified "2026-02-12T08:59:21.662428Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5034-4
  a curric:KeyLearningPoint ;
  rdfs:label "Electric field lines show the direction of force on a positive electric charge."@en ;
  dcterms:modified "2026-02-12T08:59:21.662432Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5034-5
  a curric:KeyLearningPoint ;
  rdfs:label """The closer electric field lines are to each other, the stronger the electric field."""@en ;
  dcterms:modified "2026-02-12T08:59:21.662437Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5074-1
  a curric:KeyLearningPoint ;
  rdfs:label "The magnetic field lines around a current-carrying wire are concentric circles"@en ;
  dcterms:modified "2026-02-12T08:59:21.662442Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5074-2
  a curric:KeyLearningPoint ;
  rdfs:label "In a uniform magnetic field, a current carrying wire is forced in one direction"@en ;
  dcterms:modified "2026-02-12T08:59:21.662446Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5074-3
  a curric:KeyLearningPoint ;
  rdfs:label """Fleming’s left–hand rule can be used to predict the direction of movement of a current–carrying wire in a magnetic field"""@en ;
  dcterms:modified "2026-02-12T08:59:21.662451Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5074-4
  a curric:KeyLearningPoint ;
  rdfs:label """The force on a current–carrying conductor at right angles to a magnetic field, F, is found using F = B I l."""@en ;
  dcterms:modified "2026-02-12T08:59:21.662455Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5074-5
  a curric:KeyLearningPoint ;
  rdfs:label """Opposite sides of a conducting coil in a uniform magnetic field are forced to move in opposite directions"""@en ;
  dcterms:modified "2026-02-12T08:59:21.662460Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9897-1
  a curric:KeyLearningPoint ;
  rdfs:label "The velocity of an object is equal to the gradient of a displacement-time graph."@en ;
  dcterms:modified "2026-02-12T08:59:21.662464Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9897-2
  a curric:KeyLearningPoint ;
  rdfs:label "A direction in which velocity and displacement are measured needs to be chosen."@en ;
  dcterms:modified "2026-02-12T08:59:21.662471Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9897-3
  a curric:KeyLearningPoint ;
  rdfs:label """A negative gradient on a displacement-time graph (sloping downwards) represents velocity in the opposite direction."""@en ;
  dcterms:modified "2026-02-12T08:59:21.662476Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9897-4
  a curric:KeyLearningPoint ;
  rdfs:label """A negative value for displacement represents a position ‘behind’ the starting position."""@en ;
  dcterms:modified "2026-02-12T08:59:21.662481Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5038-1
  a curric:KeyLearningPoint ;
  rdfs:label """Current can be calculated using the equation: current = p.d. ÷ resistance (I = V ÷ R)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.663013Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5038-2
  a curric:KeyLearningPoint ;
  rdfs:label """The rules of current and p.d. for a series circuit can be applied to find some missing values of current and p.d."""@en ;
  dcterms:modified "2026-02-12T08:59:21.663020Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5038-3
  a curric:KeyLearningPoint ;
  rdfs:label """The equation I = V ÷ R can be rearranged so that either V or R is the subject of the equation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.663027Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5038-4
  a curric:KeyLearningPoint ;
  rdfs:label """If any two values in the equation I = V ÷ R are known, the third can be calculated."""@en ;
  dcterms:modified "2026-02-12T08:59:21.663031Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5038-5
  a curric:KeyLearningPoint ;
  rdfs:label """If only one value in the equation I = V ÷ R is known, rules for current or p.d. need to be applied to find a second."""@en ;
  dcterms:modified "2026-02-12T08:59:21.663038Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5040-1
  a curric:KeyLearningPoint ;
  rdfs:label """Current can be calculated using the equation: current = p.d. ÷ resistance (I = V ÷ R)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.663043Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5040-2
  a curric:KeyLearningPoint ;
  rdfs:label """The rules of current and p.d. for a parallel circuit can be applied to find some missing values of current and p.d."""@en ;
  dcterms:modified "2026-02-12T08:59:21.663048Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5040-3
  a curric:KeyLearningPoint ;
  rdfs:label """The equation I = V ÷ R can be rearranged so that either p.d. or R is the subject of the equation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.663053Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5040-4
  a curric:KeyLearningPoint ;
  rdfs:label """If any two values in the equation I = V ÷ R are known, the third can be calculated."""@en ;
  dcterms:modified "2026-02-12T08:59:21.663060Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5040-5
  a curric:KeyLearningPoint ;
  rdfs:label """If only one value in  I = V ÷ R is shown for a component, circuit rules need to be applied to the rest of the circuit."""@en ;
  dcterms:modified "2026-02-12T08:59:21.663064Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4905-1
  a curric:KeyLearningPoint ;
  rdfs:label """A spring is elastically deformed if it returns to its original shape after the applied force is removed"""@en ;
  dcterms:modified "2026-02-12T08:59:21.663590Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4905-2
  a curric:KeyLearningPoint ;
  rdfs:label """A spring is inelastically deformed if it does not return to its original shape after the applied force is removed"""@en ;
  dcterms:modified "2026-02-12T08:59:21.663595Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4905-3
  a curric:KeyLearningPoint ;
  rdfs:label """Elastic deformation is proportional to the force applied to stretch or compress a spring"""@en ;
  dcterms:modified "2026-02-12T08:59:21.663599Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4905-4
  a curric:KeyLearningPoint ;
  rdfs:label """The spring constant (k) is the force needed to extend or compress an elastic object by one metre"""@en ;
  dcterms:modified "2026-02-12T08:59:21.663604Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4905-5
  a curric:KeyLearningPoint ;
  rdfs:label "Force on a spring = spring constant × extension"@en ;
  dcterms:modified "2026-02-12T08:59:21.663608Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9890-1
  a curric:KeyLearningPoint ;
  rdfs:label """A dynamics trolley speeds up (accelerates) along the whole length of a steep ramp."""@en ;
  dcterms:modified "2026-02-12T08:59:21.664165Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9890-2
  a curric:KeyLearningPoint ;
  rdfs:label "Instantaneous speed is the average speed over a very short time period."@en ;
  dcterms:modified "2026-02-12T08:59:21.664170Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9890-3
  a curric:KeyLearningPoint ;
  rdfs:label """Instantaneous speed can be estimated by measuring movement in a small time period."""@en ;
  dcterms:modified "2026-02-12T08:59:21.664174Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9890-4
  a curric:KeyLearningPoint ;
  rdfs:label """Anomalous readings should be repeated and replaced or removed from sets of repeat readings."""@en ;
  dcterms:modified "2026-02-12T08:59:21.664179Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4914-1
  a curric:KeyLearningPoint ;
  rdfs:label "A free body diagram shows all of the forces acting on a single object"@en ;
  dcterms:modified "2026-02-12T08:59:21.664183Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4914-2
  a curric:KeyLearningPoint ;
  rdfs:label """The resultant of two forces can be determined by adding individual forces on a vector diagram"""@en ;
  dcterms:modified "2026-02-12T08:59:21.664190Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4914-3
  a curric:KeyLearningPoint ;
  rdfs:label """The resultant of two perpendicular forces is in a different direction from either of these forces"""@en ;
  dcterms:modified "2026-02-12T08:59:21.664195Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4914-4
  a curric:KeyLearningPoint ;
  rdfs:label """A single force can be resolved into two components acting at right angles to each other"""@en ;
  dcterms:modified "2026-02-12T08:59:21.664199Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4914-5
  a curric:KeyLearningPoint ;
  rdfs:label "The two component forces together have the same effect as the single force"@en ;
  dcterms:modified "2026-02-12T08:59:21.664204Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5084-1
  a curric:KeyLearningPoint ;
  rdfs:label """Refraction is when waves travel from one transparent medium to another, causing a change in direction."""@en ;
  dcterms:modified "2026-02-12T08:59:21.664209Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5084-2
  a curric:KeyLearningPoint ;
  rdfs:label """When waves slow down, they turn towards the normal line (angle of incidence > angle of refraction)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.664213Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5084-3
  a curric:KeyLearningPoint ;
  rdfs:label """When waves speed up, they turn away from the normal line (angle of incidence < angle of refraction)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.664217Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5084-4
  a curric:KeyLearningPoint ;
  rdfs:label """Refraction can be investigated using a clear rectangular block, ray box and narrow slit, pencil, paper and a protractor."""@en ;
  dcterms:modified "2026-02-12T08:59:21.664225Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5084-5
  a curric:KeyLearningPoint ;
  rdfs:label """Refraction occurs when one side of a wavefront enters the new medium before the other, causing a change in wave speed."""@en ;
  dcterms:modified "2026-02-12T08:59:21.664230Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5047-1
  a curric:KeyLearningPoint ;
  rdfs:label "An oscilloscope is a displacement-time graph of a wave"@en ;
  dcterms:modified "2026-02-12T08:59:21.664880Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5047-2
  a curric:KeyLearningPoint ;
  rdfs:label """Connected to a microphone, an oscilloscope shows a displacement-time graph of a sound wave"""@en ;
  dcterms:modified "2026-02-12T08:59:21.664884Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5047-3
  a curric:KeyLearningPoint ;
  rdfs:label """The distance between two wave crests on an oscilloscope’s graph is equal to the period of the wave"""@en ;
  dcterms:modified "2026-02-12T08:59:21.664889Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5047-4
  a curric:KeyLearningPoint ;
  rdfs:label """The time period is measured most accurately by measuring the time for, say, 10 waves and dividing time by 10"""@en ;
  dcterms:modified "2026-02-12T08:59:21.664893Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5047-5
  a curric:KeyLearningPoint ;
  rdfs:label "The bigger the amplitude of a sound wave, the louder the sound"@en ;
  dcterms:modified "2026-02-12T08:59:21.664898Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5097-1
  a curric:KeyLearningPoint ;
  rdfs:label """Power is the amount of energy transferred per second and is measured in watts (W)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.667044Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5097-2
  a curric:KeyLearningPoint ;
  rdfs:label """Power can be calculated using the equation: power = current × potential difference (P = I V)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.667049Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5097-3
  a curric:KeyLearningPoint ;
  rdfs:label """At a constant p.d., a larger electric current transfers energy more quickly than a smaller current."""@en ;
  dcterms:modified "2026-02-12T08:59:21.667056Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5097-4
  a curric:KeyLearningPoint ;
  rdfs:label """Domestic appliances plugged into the mains supply in the UK have a p.d. of 230 V across them."""@en ;
  dcterms:modified "2026-02-12T08:59:21.667063Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5097-5
  a curric:KeyLearningPoint ;
  rdfs:label """The fuse with the smallest rating for the required current (calculated using the equation: P = I² R) should be used."""@en ;
  dcterms:modified "2026-02-12T08:59:21.667068Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9902-1
  a curric:KeyLearningPoint ;
  rdfs:label "A dynamics trolley has a steady acceleration down a steep ramp."@en ;
  dcterms:modified "2026-02-12T08:59:21.668001Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9902-2
  a curric:KeyLearningPoint ;
  rdfs:label """Acceleration = change of velocity ÷ time and change in velocity = final velocity – initial velocity"""@en ;
  dcterms:modified "2026-02-12T08:59:21.668006Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9902-3
  a curric:KeyLearningPoint ;
  rdfs:label """Light gates can improve accuracy of measurement of instantaneous velocity and reduces random errors."""@en ;
  dcterms:modified "2026-02-12T08:59:21.668010Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9902-4
  a curric:KeyLearningPoint ;
  rdfs:label "For a fair test, total mass of the system must be kept constant."@en ;
  dcterms:modified "2026-02-12T08:59:21.668015Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9902-5
  a curric:KeyLearningPoint ;
  rdfs:label "A compensated ramp can counteract the effect of friction."@en ;
  dcterms:modified "2026-02-12T08:59:21.668019Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6616-1
  a curric:KeyLearningPoint ;
  rdfs:label """In cameras and the human eye, the required image distance < the object distance. The image is diminished and inverted."""@en ;
  dcterms:modified "2026-02-12T08:59:21.668488Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6616-2
  a curric:KeyLearningPoint ;
  rdfs:label """In projectors, the required image distance > the object distance. The image is magnified and inverted."""@en ;
  dcterms:modified "2026-02-12T08:59:21.668492Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6616-3
  a curric:KeyLearningPoint ;
  rdfs:label """A ray incident on a convex lens parallel to the principal axis is refracted to pass through principal focus."""@en ;
  dcterms:modified "2026-02-12T08:59:21.668497Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6616-4
  a curric:KeyLearningPoint ;
  rdfs:label "A ray incident on the centre of a convex lens is not refracted."@en ;
  dcterms:modified "2026-02-12T08:59:21.668502Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6616-5
  a curric:KeyLearningPoint ;
  rdfs:label """A ray incident on a convex lens from the principal focus is refracted so it becomes parallel to the principal axis."""@en ;
  dcterms:modified "2026-02-12T08:59:21.668509Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5091-1
  a curric:KeyLearningPoint ;
  rdfs:label """When rays of light are brought to a focus a real image forms. A real image can be projected onto a screen."""@en ;
  dcterms:modified "2026-02-12T08:59:21.668852Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5091-2
  a curric:KeyLearningPoint ;
  rdfs:label """Virtual images occur at points where rays appear to (but do not actually) originate from. They cannot form on a screen."""@en ;
  dcterms:modified "2026-02-12T08:59:21.668884Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5091-3
  a curric:KeyLearningPoint ;
  rdfs:label """The size and position of a virtual image is found by drawing virtual rays to find where rays appear to originate from."""@en ;
  dcterms:modified "2026-02-12T08:59:21.668892Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5091-4
  a curric:KeyLearningPoint ;
  rdfs:label """Upright virtual images are produced by diverging lenses, and objects within a focal length of a converging lens."""@en ;
  dcterms:modified "2026-02-12T08:59:21.668897Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5091-5
  a curric:KeyLearningPoint ;
  rdfs:label """Converging lenses fix long sight by shortening the focus. Diverging lenses fix short sight by lengthening the focus."""@en ;
  dcterms:modified "2026-02-12T08:59:21.668904Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4906-1
  a curric:KeyLearningPoint ;
  rdfs:label """A spring is elastically deformed if it returns to its original shape after the applied force is removed"""@en ;
  dcterms:modified "2026-02-12T08:59:21.668909Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4906-2
  a curric:KeyLearningPoint ;
  rdfs:label """A spring is inelastically deformed if it does not return to its original shape after the applied force is removed"""@en ;
  dcterms:modified "2026-02-12T08:59:21.668916Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4906-3
  a curric:KeyLearningPoint ;
  rdfs:label """Elastic deformation is proportional to the force applied to stretch or compress a spring"""@en ;
  dcterms:modified "2026-02-12T08:59:21.668921Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4906-4
  a curric:KeyLearningPoint ;
  rdfs:label """The spring constant (k) is the force needed to extend or compress an elastic object by one metre"""@en ;
  dcterms:modified "2026-02-12T08:59:21.668925Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4906-5
  a curric:KeyLearningPoint ;
  rdfs:label "Force on a spring = spring constant × extension"@en ;
  dcterms:modified "2026-02-12T08:59:21.668930Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9149-1
  a curric:KeyLearningPoint ;
  rdfs:label "Converging lenses can produce an inverted image on a screen by refracting light."@en ;
  dcterms:modified "2026-02-12T08:59:21.671605Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9149-2
  a curric:KeyLearningPoint ;
  rdfs:label """Rays parallel to the principal axis are refracted to the principal focus of a converging lens (at the focal length)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.671613Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9149-3
  a curric:KeyLearningPoint ;
  rdfs:label """The image distance and size (magnification) depend on the power of the lens and the object distance."""@en ;
  dcterms:modified "2026-02-12T08:59:21.671617Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9149-4
  a curric:KeyLearningPoint ;
  rdfs:label """As the object distance decreases, the image distance and size both increase, until the object reaches the focal length."""@en ;
  dcterms:modified "2026-02-12T08:59:21.671622Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9149-5
  a curric:KeyLearningPoint ;
  rdfs:label """If the object is too close to the lens, the rays leaving the lens are parallel/diverging, images can't form on a screen."""@en ;
  dcterms:modified "2026-02-12T08:59:21.671626Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5080-1
  a curric:KeyLearningPoint ;
  rdfs:label """Rotating a conducting loop in a uniform magnetic field induces a potential across the ends of the loop."""@en ;
  dcterms:modified "2026-02-12T08:59:21.672771Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5080-2
  a curric:KeyLearningPoint ;
  rdfs:label "An electrical generator can be made in the same way as an electric motor."@en ;
  dcterms:modified "2026-02-12T08:59:21.672776Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5080-3
  a curric:KeyLearningPoint ;
  rdfs:label "A DC generator (dynamo) generates a varying DC current."@en ;
  dcterms:modified "2026-02-12T08:59:21.672781Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5080-4
  a curric:KeyLearningPoint ;
  rdfs:label """The connections in an AC generator (an alternator) are different to those of a dynamo."""@en ;
  dcterms:modified "2026-02-12T08:59:21.672788Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5080-5
  a curric:KeyLearningPoint ;
  rdfs:label """An alternator makes an alternating current that repeatedly reverses direction as the coil spins round."""@en ;
  dcterms:modified "2026-02-12T08:59:21.672793Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9109-1
  a curric:KeyLearningPoint ;
  rdfs:label "A velocity-time graph shows how velocity changes with time."@en ;
  dcterms:modified "2026-02-12T08:59:21.673423Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9109-2
  a curric:KeyLearningPoint ;
  rdfs:label "Acceleration is equal to the gradient of a velocity-time graph."@en ;
  dcterms:modified "2026-02-12T08:59:21.673428Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9109-3
  a curric:KeyLearningPoint ;
  rdfs:label """A falling line shows decreasing velocity called deceleration, which is a negative acceleration."""@en ;
  dcterms:modified "2026-02-12T08:59:21.673433Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9109-4
  a curric:KeyLearningPoint ;
  rdfs:label "The gradient of the line gives the instantaneous acceleration."@en ;
  dcterms:modified "2026-02-12T08:59:21.673437Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9109-5
  a curric:KeyLearningPoint ;
  rdfs:label "The distance travelled is equal to the area under a velocity-time graph."@en ;
  dcterms:modified "2026-02-12T08:59:21.673442Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28181-1
  a curric:KeyLearningPoint ;
  rdfs:label """Telescopes extended what was visible after their invention in the seventeenth century."""@en ;
  dcterms:modified "2026-02-12T08:59:21.673954Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28181-2
  a curric:KeyLearningPoint ;
  rdfs:label """Images detected by telescopes in space are not distorted by effects of the Earth’s atmosphere."""@en ;
  dcterms:modified "2026-02-12T08:59:21.673958Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28181-3
  a curric:KeyLearningPoint ;
  rdfs:label """A galaxy is a group of hundreds of billions of stars, and there are many galaxies spread across the universe."""@en ;
  dcterms:modified "2026-02-12T08:59:21.673966Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28181-4
  a curric:KeyLearningPoint ;
  rdfs:label """A visible spectrum of light emitted from stars or galaxies shows dark lines of frequencies of light."""@en ;
  dcterms:modified "2026-02-12T08:59:21.673971Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28181-5
  a curric:KeyLearningPoint ;
  rdfs:label """Red shift is the movement of hydrogen lines towards the red end of the visible spectrum."""@en ;
  dcterms:modified "2026-02-12T08:59:21.673977Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9118-1
  a curric:KeyLearningPoint ;
  rdfs:label """Doubling the stiffness of a spring doubles the energy it has because it is stretched."""@en ;
  dcterms:modified "2026-02-12T08:59:21.676678Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9118-2
  a curric:KeyLearningPoint ;
  rdfs:label "The spring constant is measured in newtons per metre (N/m)."@en ;
  dcterms:modified "2026-02-12T08:59:21.676683Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9118-3
  a curric:KeyLearningPoint ;
  rdfs:label """Doubling the extension of a spring increases the energy it has, because it is stretched, by four times."""@en ;
  dcterms:modified "2026-02-12T08:59:21.676688Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9118-4
  a curric:KeyLearningPoint ;
  rdfs:label """The energy a spring has because it is stretched equals 1/2 × spring constant × (extension)²."""@en ;
  dcterms:modified "2026-02-12T08:59:21.676692Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4922-1
  a curric:KeyLearningPoint ;
  rdfs:label """The faster the particles of a substance are vibrating or moving, the higher the substance's temperature."""@en ;
  dcterms:modified "2026-02-12T08:59:21.677189Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4922-2
  a curric:KeyLearningPoint ;
  rdfs:label """In solids, energy is transferred by vibrating particles colliding with nearby particles, causing them to vibrate more."""@en ;
  dcterms:modified "2026-02-12T08:59:21.677194Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4922-3
  a curric:KeyLearningPoint ;
  rdfs:label """Metals are good conductors as their free electrons move through them more quickly when heated and transfer energy."""@en ;
  dcterms:modified "2026-02-12T08:59:21.677198Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4922-4
  a curric:KeyLearningPoint ;
  rdfs:label """Thermal conductors can feel cold because they transfer energy quickly away from their surface."""@en ;
  dcterms:modified "2026-02-12T08:59:21.677205Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4922-5
  a curric:KeyLearningPoint ;
  rdfs:label """Thermal insulators can feel warm because they do not transfer energy quickly from their surface."""@en ;
  dcterms:modified "2026-02-12T08:59:21.677210Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9136-1
  a curric:KeyLearningPoint ;
  rdfs:label "Moment = force × distance (M = Fd)"@en ;
  dcterms:modified "2026-02-12T08:59:21.677217Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9136-2
  a curric:KeyLearningPoint ;
  rdfs:label """If an object is balanced, the total clockwise moment about a pivot equals the total anticlockwise moment."""@en ;
  dcterms:modified "2026-02-12T08:59:21.677223Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9136-3
  a curric:KeyLearningPoint ;
  rdfs:label """An object is in equilibrium if it is balanced and there are no resultant forces acting."""@en ;
  dcterms:modified "2026-02-12T08:59:21.677227Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5045-1
  a curric:KeyLearningPoint ;
  rdfs:label "A displacement-time graph of a wave is a representation of a wave."@en ;
  dcterms:modified "2026-02-12T08:59:21.677326Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5045-2
  a curric:KeyLearningPoint ;
  rdfs:label """A displacement-time graph of a wave shows how the displacement at one point varies as the wave passes"""@en ;
  dcterms:modified "2026-02-12T08:59:21.677333Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5045-3
  a curric:KeyLearningPoint ;
  rdfs:label """The distance between two wave crests on a displacement-time graph is equal to the period of the wave"""@en ;
  dcterms:modified "2026-02-12T08:59:21.677340Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5045-4
  a curric:KeyLearningPoint ;
  rdfs:label "The period of a wave, T, is equal to the time of one complete oscillation"@en ;
  dcterms:modified "2026-02-12T08:59:21.677345Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5045-5
  a curric:KeyLearningPoint ;
  rdfs:label "Frequency is equal to 1 / period"@en ;
  dcterms:modified "2026-02-12T08:59:21.677352Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9098-1
  a curric:KeyLearningPoint ;
  rdfs:label """The pressure of a gas in a container increases if the temperature or amount of gas increases, or volume decreases."""@en ;
  dcterms:modified "2026-02-12T08:59:21.677597Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9098-2
  a curric:KeyLearningPoint ;
  rdfs:label "Increasing temperature increases the speed of particles in a gas."@en ;
  dcterms:modified "2026-02-12T08:59:21.677601Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9098-3
  a curric:KeyLearningPoint ;
  rdfs:label "Pressure × volume = constant (pV = constant)."@en ;
  dcterms:modified "2026-02-12T08:59:21.677606Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9098-4
  a curric:KeyLearningPoint ;
  rdfs:label "When a gas expands, its particles do work on the surrounding air."@en ;
  dcterms:modified "2026-02-12T08:59:21.677610Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9098-5
  a curric:KeyLearningPoint ;
  rdfs:label "Doing work on a gas can increase its temperature."@en ;
  dcterms:modified "2026-02-12T08:59:21.677617Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5048-1
  a curric:KeyLearningPoint ;
  rdfs:label """To find standing wave frequencies, increase the frequency of the oscillator until a standing wave pattern is seen."""@en ;
  dcterms:modified "2026-02-12T08:59:21.677703Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5048-2
  a curric:KeyLearningPoint ;
  rdfs:label """The wavelength of the waves can be found from the length of the oscillating string and the standing wave pattern"""@en ;
  dcterms:modified "2026-02-12T08:59:21.677707Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5048-3
  a curric:KeyLearningPoint ;
  rdfs:label """The speed of waves on a string only depends on the properties of the wave medium (the string)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.677712Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5048-4
  a curric:KeyLearningPoint ;
  rdfs:label "For waves on a string, frequency and wavelength are inversely proportional"@en ;
  dcterms:modified "2026-02-12T08:59:21.677717Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5048-5
  a curric:KeyLearningPoint ;
  rdfs:label """Control variables are the quantities that must be kept the same during experiments so they don’t affect results."""@en ;
  dcterms:modified "2026-02-12T08:59:21.677724Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9935-1
  a curric:KeyLearningPoint ;
  rdfs:label "When an object moves upwards, work is done against the gravitational force."@en ;
  dcterms:modified "2026-02-12T08:59:21.678032Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9935-2
  a curric:KeyLearningPoint ;
  rdfs:label """The gravitational force acting on an object does work to speed it up when it is falling."""@en ;
  dcterms:modified "2026-02-12T08:59:21.678036Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9935-3
  a curric:KeyLearningPoint ;
  rdfs:label "Weight = mass x gravitational field strength, W = mg"@en ;
  dcterms:modified "2026-02-12T08:59:21.678041Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9935-4
  a curric:KeyLearningPoint ;
  rdfs:label """Change in gravitational potential energy of an object = mass × gravitational field strength × change in height"""@en ;
  dcterms:modified "2026-02-12T08:59:21.678045Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4903-1
  a curric:KeyLearningPoint ;
  rdfs:label """Energy is dissipated due to friction which causes particles to vibrate more quickly and heats up the surroundings."""@en ;
  dcterms:modified "2026-02-12T08:59:21.678050Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4903-2
  a curric:KeyLearningPoint ;
  rdfs:label """Energy is dissipated due to drag which causes particles in the surroundings to move more quickly."""@en ;
  dcterms:modified "2026-02-12T08:59:21.678054Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4903-3
  a curric:KeyLearningPoint ;
  rdfs:label """Efficiency = (useful energy transferred by the device)/(total energy supplied to the device)"""@en ;
  dcterms:modified "2026-02-12T08:59:21.678059Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27964-1
  a curric:KeyLearningPoint ;
  rdfs:label """Background radiation is caused by unstable nuclei that are around us all of the time."""@en ;
  dcterms:modified "2026-02-12T08:59:21.679626Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27964-2
  a curric:KeyLearningPoint ;
  rdfs:label "Atoms are very small with a radius of about 1 × 10⁻¹⁰ m."@en ;
  dcterms:modified "2026-02-12T08:59:21.679633Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27964-3
  a curric:KeyLearningPoint ;
  rdfs:label """The alpha particle scattering experiment (Rutherford, 1909) provides evidence for the size and nature of atomic nuclei."""@en ;
  dcterms:modified "2026-02-12T08:59:21.679638Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27964-4
  a curric:KeyLearningPoint ;
  rdfs:label "An atomic nucleus has a radius about 10 000 times smaller than that of an atom."@en ;
  dcterms:modified "2026-02-12T08:59:21.679644Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27964-5
  a curric:KeyLearningPoint ;
  rdfs:label "Most of the mass of an atom is in its nucleus."@en ;
  dcterms:modified "2026-02-12T08:59:21.679649Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5095-1
  a curric:KeyLearningPoint ;
  rdfs:label """A short circuit happens when a wire becomes loose and touches the wrong part of a circuit, or makes a new circuit."""@en ;
  dcterms:modified "2026-02-12T08:59:21.679654Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5095-2
  a curric:KeyLearningPoint ;
  rdfs:label """If a live wire touches the inside of a metal case, the metal case may become live."""@en ;
  dcterms:modified "2026-02-12T08:59:21.679658Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5095-3
  a curric:KeyLearningPoint ;
  rdfs:label """If there is too much current in an appliance, a fuse on the live wire in its plug melts and turns it off."""@en ;
  dcterms:modified "2026-02-12T08:59:21.679663Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5095-4
  a curric:KeyLearningPoint ;
  rdfs:label """From a live metal case, current flows along an earth and live wire, melts a fuse and turns the electricity off."""@en ;
  dcterms:modified "2026-02-12T08:59:21.679667Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5095-5
  a curric:KeyLearningPoint ;
  rdfs:label """Domestic circuits with excessive current are turned off by circuit breakers in a consumer box to prevent fire."""@en ;
  dcterms:modified "2026-02-12T08:59:21.679672Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6617-1
  a curric:KeyLearningPoint ;
  rdfs:label """When rays of light are brought to a focus a real image forms. A real image can be projected onto a screen."""@en ;
  dcterms:modified "2026-02-12T08:59:21.680949Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6617-2
  a curric:KeyLearningPoint ;
  rdfs:label """Virtual images occur at points where rays appear to (but do not actually) originate from. They cannot form on a screen."""@en ;
  dcterms:modified "2026-02-12T08:59:21.680954Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6617-3
  a curric:KeyLearningPoint ;
  rdfs:label """The size and position of a virtual image is found by drawing virtual rays to find where rays appear to originate from."""@en ;
  dcterms:modified "2026-02-12T08:59:21.680958Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6617-4
  a curric:KeyLearningPoint ;
  rdfs:label """Upright virtual images are produced by concave lenses, and objects within a focal length of a convex lens."""@en ;
  dcterms:modified "2026-02-12T08:59:21.680963Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6617-5
  a curric:KeyLearningPoint ;
  rdfs:label """Convex lenses fix long sight by shortening the focus. Concave lenses fix short sight by lengthening the focus."""@en ;
  dcterms:modified "2026-02-12T08:59:21.680967Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9135-1
  a curric:KeyLearningPoint ;
  rdfs:label "A force can produce a turning effect known as a moment."@en ;
  dcterms:modified "2026-02-12T08:59:21.681818Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9135-2
  a curric:KeyLearningPoint ;
  rdfs:label "If an object is in equilibrium, there is no resultant force or moment on it."@en ;
  dcterms:modified "2026-02-12T08:59:21.681823Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9135-3
  a curric:KeyLearningPoint ;
  rdfs:label "moment = force × distance (M = Fd)"@en ;
  dcterms:modified "2026-02-12T08:59:21.681827Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9135-4
  a curric:KeyLearningPoint ;
  rdfs:label "Levers can act as force or distance multipliers."@en ;
  dcterms:modified "2026-02-12T08:59:21.681832Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9135-5
  a curric:KeyLearningPoint ;
  rdfs:label "Gears can be used to transfer moments."@en ;
  dcterms:modified "2026-02-12T08:59:21.681839Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9921-1
  a curric:KeyLearningPoint ;
  rdfs:label "Power is equal to the rate at which work is done."@en ;
  dcterms:modified "2026-02-12T08:59:21.681909Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9921-2
  a curric:KeyLearningPoint ;
  rdfs:label "Power is equal to the rate at which energy is transferred."@en ;
  dcterms:modified "2026-02-12T08:59:21.681914Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9921-3
  a curric:KeyLearningPoint ;
  rdfs:label "Power = work done ÷ time."@en ;
  dcterms:modified "2026-02-12T08:59:21.681918Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9921-4
  a curric:KeyLearningPoint ;
  rdfs:label "Power is measured in watts (W)."@en ;
  dcterms:modified "2026-02-12T08:59:21.681923Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6609-1
  a curric:KeyLearningPoint ;
  rdfs:label "All magnets have a north–seeking pole and a south–seeking pole."@en ;
  dcterms:modified "2026-02-12T08:59:21.682157Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6609-2
  a curric:KeyLearningPoint ;
  rdfs:label """Unlike magnetic poles attract each other, and like magnetic poles repel each other."""@en ;
  dcterms:modified "2026-02-12T08:59:21.682162Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6609-3
  a curric:KeyLearningPoint ;
  rdfs:label """Just three metal elements (iron, cobalt and nickel) are magnetic; other metals and non–metals are not magnetic."""@en ;
  dcterms:modified "2026-02-12T08:59:21.682166Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6609-4
  a curric:KeyLearningPoint ;
  rdfs:label "The needle of a plotting compass lines up with the magnetic field of a magnet."@en ;
  dcterms:modified "2026-02-12T08:59:21.682173Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6609-5
  a curric:KeyLearningPoint ;
  rdfs:label """Arrows on magnetic field lines show the direction in which the north–seeking pole of another magnet would be forced."""@en ;
  dcterms:modified "2026-02-12T08:59:21.682178Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4729-1
  a curric:KeyLearningPoint ;
  rdfs:label "The velocity of an object is equal to the gradient of a displacement-time graph."@en ;
  dcterms:modified "2026-02-12T08:59:21.682199Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4729-2
  a curric:KeyLearningPoint ;
  rdfs:label "A direction in which velocity and displacement are measured needs to be chosen."@en ;
  dcterms:modified "2026-02-12T08:59:21.682203Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4729-3
  a curric:KeyLearningPoint ;
  rdfs:label """A negative gradient on a displacement-time graph (sloping downwards) represents velocity in the opposite direction."""@en ;
  dcterms:modified "2026-02-12T08:59:21.682210Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4729-4
  a curric:KeyLearningPoint ;
  rdfs:label """A negative value for displacement represents a position ‘behind’ the starting position."""@en ;
  dcterms:modified "2026-02-12T08:59:21.682218Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9919-1
  a curric:KeyLearningPoint ;
  rdfs:label "Work done is the total amount of energy transferred."@en ;
  dcterms:modified "2026-02-12T08:59:21.682223Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9919-2
  a curric:KeyLearningPoint ;
  rdfs:label "Work done = force × distance (moved in the direction of the force)."@en ;
  dcterms:modified "2026-02-12T08:59:21.682227Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9919-3
  a curric:KeyLearningPoint ;
  rdfs:label "Work done is measured in joules (J)."@en ;
  dcterms:modified "2026-02-12T08:59:21.682232Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8142-1
  a curric:KeyLearningPoint ;
  rdfs:label "Earthquakes usually occur near to the edges of tectonic plates"@en ;
  dcterms:modified "2026-02-12T08:59:21.682236Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8142-2
  a curric:KeyLearningPoint ;
  rdfs:label """P waves and S waves are produced deep underground where tectonic plates slip and cause vibrations in rock"""@en ;
  dcterms:modified "2026-02-12T08:59:21.682241Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8142-3
  a curric:KeyLearningPoint ;
  rdfs:label "P waves are longitudinal waves and travel through liquid"@en ;
  dcterms:modified "2026-02-12T08:59:21.682245Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8142-4
  a curric:KeyLearningPoint ;
  rdfs:label """S waves are transverse waves and cannot travel through liquid layers inside Earth"""@en ;
  dcterms:modified "2026-02-12T08:59:21.682250Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8142-5
  a curric:KeyLearningPoint ;
  rdfs:label "P waves and S waves provide evidence for the internal structure of Earth"@en ;
  dcterms:modified "2026-02-12T08:59:21.682254Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8141-1
  a curric:KeyLearningPoint ;
  rdfs:label """Human hearing involves the transmission of sound waves through different parts of the ear."""@en ;
  dcterms:modified "2026-02-12T08:59:21.682259Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8141-2
  a curric:KeyLearningPoint ;
  rdfs:label """Wave transmission to a new medium can be limited by the wave amplitude or the wave frequency."""@en ;
  dcterms:modified "2026-02-12T08:59:21.682264Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8141-3
  a curric:KeyLearningPoint ;
  rdfs:label """The range of human hearing is 20 Hz to 20 000 Hz. Frequencies above and below this are called ultrasound and infrasound."""@en ;
  dcterms:modified "2026-02-12T08:59:21.682268Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8141-4
  a curric:KeyLearningPoint ;
  rdfs:label """The highest frequency you can hear reduces with age as cells of the cochlea and auditory nerve become damaged over time."""@en ;
  dcterms:modified "2026-02-12T08:59:21.682272Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4732-1
  a curric:KeyLearningPoint ;
  rdfs:label "Acceleration is equal to the gradient of a velocity-time graph."@en ;
  dcterms:modified "2026-02-12T08:59:21.682350Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4732-2
  a curric:KeyLearningPoint ;
  rdfs:label """A falling line shows decreasing velocity called deceleration, which is a negative acceleration."""@en ;
  dcterms:modified "2026-02-12T08:59:21.682355Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4732-3
  a curric:KeyLearningPoint ;
  rdfs:label """Instantaneous speed at a point on a displacement-time graph equals the gradient of a tangent at that point ."""@en ;
  dcterms:modified "2026-02-12T08:59:21.682360Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4732-4
  a curric:KeyLearningPoint ;
  rdfs:label "The distance travelled is equal to the area under a velocity-time graph."@en ;
  dcterms:modified "2026-02-12T08:59:21.682364Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4732-5
  a curric:KeyLearningPoint ;
  rdfs:label "Displacement is equal to the net positive area under a velocity-time graph."@en ;
  dcterms:modified "2026-02-12T08:59:21.682371Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4908-1
  a curric:KeyLearningPoint ;
  rdfs:label """Doubling the stiffness of a spring doubles the energy it has because it is stretched."""@en ;
  dcterms:modified "2026-02-12T08:59:21.682934Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4908-2
  a curric:KeyLearningPoint ;
  rdfs:label "The spring constant is measured in newtons per metre (N/m)."@en ;
  dcterms:modified "2026-02-12T08:59:21.682939Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4908-3
  a curric:KeyLearningPoint ;
  rdfs:label """Doubling the extension of a spring increases the energy it has because, it is stretched, by four times."""@en ;
  dcterms:modified "2026-02-12T08:59:21.682943Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4908-4
  a curric:KeyLearningPoint ;
  rdfs:label """The energy a spring has because it is stretched equals 1/2 × spring constant × (extension)²."""@en ;
  dcterms:modified "2026-02-12T08:59:21.682950Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5089-1
  a curric:KeyLearningPoint ;
  rdfs:label "Convex lenses can produce an inverted image on a screen by refracting light."@en ;
  dcterms:modified "2026-02-12T08:59:21.682955Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5089-2
  a curric:KeyLearningPoint ;
  rdfs:label """Rays parallel to the principal axis are refracted to the principal focus, located at the focal length of a convex lens."""@en ;
  dcterms:modified "2026-02-12T08:59:21.682960Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5089-3
  a curric:KeyLearningPoint ;
  rdfs:label """The image distance and size (magnification) depend on the power of the lens and the object distance."""@en ;
  dcterms:modified "2026-02-12T08:59:21.682965Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5089-4
  a curric:KeyLearningPoint ;
  rdfs:label """As the object distance decreases, the image distance and size both increase, until the object reaches the focal length."""@en ;
  dcterms:modified "2026-02-12T08:59:21.682969Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5089-5
  a curric:KeyLearningPoint ;
  rdfs:label """If the object is too close to the lens, the rays leaving the lens are parallel/diverging, images can't form on a screen."""@en ;
  dcterms:modified "2026-02-12T08:59:21.682974Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9936-1
  a curric:KeyLearningPoint ;
  rdfs:label "When an object moves upwards, work is done against the gravitational force."@en ;
  dcterms:modified "2026-02-12T08:59:21.684926Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9936-2
  a curric:KeyLearningPoint ;
  rdfs:label """The gravitational force acting on an object does work to speed it up when it is falling."""@en ;
  dcterms:modified "2026-02-12T08:59:21.684933Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9936-3
  a curric:KeyLearningPoint ;
  rdfs:label "Weight = mass x gravitational field strength, W = mg"@en ;
  dcterms:modified "2026-02-12T08:59:21.684940Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9936-4
  a curric:KeyLearningPoint ;
  rdfs:label """Gravitational potential energy of an object = mass × gravitational field strength × height"""@en ;
  dcterms:modified "2026-02-12T08:59:21.684945Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8154-1
  a curric:KeyLearningPoint ;
  rdfs:label """Particles in a gas move very quickly in random directions and have empty space between them."""@en ;
  dcterms:modified "2026-02-12T08:59:21.684972Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8154-2
  a curric:KeyLearningPoint ;
  rdfs:label """Heating a fluid increases the speed of particles and they push each other further apart."""@en ;
  dcterms:modified "2026-02-12T08:59:21.684979Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8154-3
  a curric:KeyLearningPoint ;
  rdfs:label "As a fluid is heated, it becomes less dense."@en ;
  dcterms:modified "2026-02-12T08:59:21.684984Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8154-4
  a curric:KeyLearningPoint ;
  rdfs:label "Hotter fluid rises through cooler fluid because it is less dense."@en ;
  dcterms:modified "2026-02-12T08:59:21.684988Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9894-1
  a curric:KeyLearningPoint ;
  rdfs:label "Velocity of an object is equal to the gradient of a displacement-time graph."@en ;
  dcterms:modified "2026-02-12T08:59:21.685466Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9894-2
  a curric:KeyLearningPoint ;
  rdfs:label "A direction in which velocity and displacement are measured needs to be chosen."@en ;
  dcterms:modified "2026-02-12T08:59:21.685471Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9894-3
  a curric:KeyLearningPoint ;
  rdfs:label """A negative gradient on a displacement-time graph (sloping downwards) represents velocity in the opposite direction."""@en ;
  dcterms:modified "2026-02-12T08:59:21.685476Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9894-4
  a curric:KeyLearningPoint ;
  rdfs:label """A negative value for displacement represents a position ‘behind’ the starting position."""@en ;
  dcterms:modified "2026-02-12T08:59:21.685480Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4926-1
  a curric:KeyLearningPoint ;
  rdfs:label """Energy transferred to a solid at its melting point allows its particles to move further apart."""@en ;
  dcterms:modified "2026-02-12T08:59:21.685540Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4926-2
  a curric:KeyLearningPoint ;
  rdfs:label """Energy transferred to a liquid at its boiling point allows its particles to move fast enough to get even further apart."""@en ;
  dcterms:modified "2026-02-12T08:59:21.685544Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4926-3
  a curric:KeyLearningPoint ;
  rdfs:label """The energy transferred to melt a solid at its melting point is proportional to the mass of the solid."""@en ;
  dcterms:modified "2026-02-12T08:59:21.685549Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4926-4
  a curric:KeyLearningPoint ;
  rdfs:label """The energy transferred to melt 1 kg of a solid at its melting point is proportional to the solid’s specific latent heat."""@en ;
  dcterms:modified "2026-02-12T08:59:21.685553Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4926-5
  a curric:KeyLearningPoint ;
  rdfs:label """The energy transferred to boil 1 kg of a liquid at its boiling point is proportional to its specific latent heat."""@en ;
  dcterms:modified "2026-02-12T08:59:21.685557Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8169-1
  a curric:KeyLearningPoint ;
  rdfs:label "A free body diagram shows all of the forces acting on a single object."@en ;
  dcterms:modified "2026-02-12T08:59:21.686165Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8169-2
  a curric:KeyLearningPoint ;
  rdfs:label """The resultant of two forces can be determined by adding individual forces on a vector diagram."""@en ;
  dcterms:modified "2026-02-12T08:59:21.686170Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8169-3
  a curric:KeyLearningPoint ;
  rdfs:label """The resultant of two perpendicular forces is in a different direction from either of these forces."""@en ;
  dcterms:modified "2026-02-12T08:59:21.686174Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27963-1
  a curric:KeyLearningPoint ;
  rdfs:label """The fission of uranium-235 produces two daughter nuclei, two or more neutrons and gamma radiation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.686922Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27963-2
  a curric:KeyLearningPoint ;
  rdfs:label """In a nuclear power station, control rods absorb neutrons to control the rate at which U-235 fissions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.686926Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27963-3
  a curric:KeyLearningPoint ;
  rdfs:label """In a nuclear power station, a moderator absorbs the energy from gamma radiation and heats up."""@en ;
  dcterms:modified "2026-02-12T08:59:21.686931Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27963-4
  a curric:KeyLearningPoint ;
  rdfs:label "Heating by the moderator, via a coolant, boils pure water turning it to steam."@en ;
  dcterms:modified "2026-02-12T08:59:21.686936Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27963-5
  a curric:KeyLearningPoint ;
  rdfs:label """The expansion of pure water turning to steam creates a driving force that spins a turbine."""@en ;
  dcterms:modified "2026-02-12T08:59:21.686940Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28166-1
  a curric:KeyLearningPoint ;
  rdfs:label """A nuclear equation shows the particles in a nuclear decay, including the electric charge and mass number of each one."""@en ;
  dcterms:modified "2026-02-12T08:59:21.686944Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28166-2
  a curric:KeyLearningPoint ;
  rdfs:label """An alpha particle consists of two protons and two neutrons, has a mass of 4 and charge of +2."""@en ;
  dcterms:modified "2026-02-12T08:59:21.686949Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28166-3
  a curric:KeyLearningPoint ;
  rdfs:label "The protons and neutrons in an alpha particle are held together very strongly."@en ;
  dcterms:modified "2026-02-12T08:59:21.686953Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28166-4
  a curric:KeyLearningPoint ;
  rdfs:label "After an alpha or beta decay, a nucleus usually emits some gamma radiation."@en ;
  dcterms:modified "2026-02-12T08:59:21.686960Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28166-5
  a curric:KeyLearningPoint ;
  rdfs:label """A beta particle is an electron emitted at a high speed from a nucleus, its mass is close to zero and charge of –1."""@en ;
  dcterms:modified "2026-02-12T08:59:21.686967Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20346-1
  a curric:KeyLearningPoint ;
  rdfs:label "All EM waves can transfer energy, from a source to an absorber."@en ;
  dcterms:modified "2026-02-12T08:59:21.686972Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20346-2
  a curric:KeyLearningPoint ;
  rdfs:label """Only UV, X-ray and gamma frequencies of EM wave cause ionisation. The higher the frequency, the more ionising."""@en ;
  dcterms:modified "2026-02-12T08:59:21.686976Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20346-3
  a curric:KeyLearningPoint ;
  rdfs:label """Ionising radiation can damage cells, cause genes to mutate and increase the risk of cancer."""@en ;
  dcterms:modified "2026-02-12T08:59:21.686983Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20346-4
  a curric:KeyLearningPoint ;
  rdfs:label """UV is used in lighting and to disinfect water. It causes tanning/sunburn. It increases the risk of skin cancer."""@en ;
  dcterms:modified "2026-02-12T08:59:21.686988Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20346-5
  a curric:KeyLearningPoint ;
  rdfs:label """X- and gamma rays are used in medical imaging. Gamma rays are used to kill cancer cells and to sterilise food/equipment."""@en ;
  dcterms:modified "2026-02-12T08:59:21.686992Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27967-1
  a curric:KeyLearningPoint ;
  rdfs:label """The amount (or activity) of a radioactive isotope repeatedly falls by half in equal amounts of time."""@en ;
  dcterms:modified "2026-02-12T08:59:21.687085Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27967-2
  a curric:KeyLearningPoint ;
  rdfs:label """A radioactive half-life graph shows the amount (or activity) of a radioactive isotope plotted against time."""@en ;
  dcterms:modified "2026-02-12T08:59:21.687090Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27967-3
  a curric:KeyLearningPoint ;
  rdfs:label """In 2 half-lives the amount (or activity) of a radioactive isotope falls to ½ × ½ = ¼ as much."""@en ;
  dcterms:modified "2026-02-12T08:59:21.687094Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27967-4
  a curric:KeyLearningPoint ;
  rdfs:label """In 3 half-lives the amount (or activity) of a radioactive isotope falls to ½ × ½ × ½ = 1/8 as much, and so on."""@en ;
  dcterms:modified "2026-02-12T08:59:21.687099Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27967-5
  a curric:KeyLearningPoint ;
  rdfs:label """Radioactive isotopes with short half-lives decay quickly, emitting most radiation over a short period of time."""@en ;
  dcterms:modified "2026-02-12T08:59:21.687103Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8166-1
  a curric:KeyLearningPoint ;
  rdfs:label """The pressure of a gas in a container increases if the temperature or amount of gas increases, or volume decreases."""@en ;
  dcterms:modified "2026-02-12T08:59:21.687158Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8166-2
  a curric:KeyLearningPoint ;
  rdfs:label "Increasing temperature increases the speed of particles in a gas."@en ;
  dcterms:modified "2026-02-12T08:59:21.687163Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8166-3
  a curric:KeyLearningPoint ;
  rdfs:label "Pressure × volume = constant (pV = constant)."@en ;
  dcterms:modified "2026-02-12T08:59:21.687169Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8166-4
  a curric:KeyLearningPoint ;
  rdfs:label "When a gas expands, its particles do work on the surrounding air."@en ;
  dcterms:modified "2026-02-12T08:59:21.687174Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4913-1
  a curric:KeyLearningPoint ;
  rdfs:label """A single resultant force has the same effect as several forces acting on an object"""@en ;
  dcterms:modified "2026-02-12T08:59:21.687179Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4913-2
  a curric:KeyLearningPoint ;
  rdfs:label """If there is no resultant force on an object, it remains still or continues to move at a steady speed in a straight line"""@en ;
  dcterms:modified "2026-02-12T08:59:21.687183Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4913-3
  a curric:KeyLearningPoint ;
  rdfs:label """If there is a resultant force on an object, it will accelerate in the direction of the force"""@en ;
  dcterms:modified "2026-02-12T08:59:21.687188Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4913-4
  a curric:KeyLearningPoint ;
  rdfs:label """A resultant force acting in the opposite direction to movement will decelerate (slow down) an object"""@en ;
  dcterms:modified "2026-02-12T08:59:21.687193Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20350-1
  a curric:KeyLearningPoint ;
  rdfs:label """Radio waves, microwaves, IR and visible light are non–ionising EM radiation. They can harm cells by heating."""@en ;
  dcterms:modified "2026-02-12T08:59:21.687197Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20350-2
  a curric:KeyLearningPoint ;
  rdfs:label """Radio waves are produced by oscillations of current. When absorbed, they may produce oscillations of current."""@en ;
  dcterms:modified "2026-02-12T08:59:21.687202Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20350-3
  a curric:KeyLearningPoint ;
  rdfs:label """Radio waves and microwaves are used for long distance communication, broadcasting and data transmission."""@en ;
  dcterms:modified "2026-02-12T08:59:21.687207Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20350-4
  a curric:KeyLearningPoint ;
  rdfs:label """Microwaves are absorbed by water, so can be used to cook food from within. IR radiation cooks the surface of food."""@en ;
  dcterms:modified "2026-02-12T08:59:21.687211Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20350-5
  a curric:KeyLearningPoint ;
  rdfs:label """IR is used for heating and thermal imaging. Visible light and IR are used for data transmission in optical fibres."""@en ;
  dcterms:modified "2026-02-12T08:59:21.687216Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9901-1
  a curric:KeyLearningPoint ;
  rdfs:label "A dynamics trolley has a steady acceleration down a steep ramp."@en ;
  dcterms:modified "2026-02-12T08:59:21.687220Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9901-2
  a curric:KeyLearningPoint ;
  rdfs:label """Acceleration = change of velocity / time and change in velocity = final velocity - initial velocity"""@en ;
  dcterms:modified "2026-02-12T08:59:21.687227Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9901-3
  a curric:KeyLearningPoint ;
  rdfs:label """Light gates can improve accuracy of measurement of instantaneous velocity and reduces random errors."""@en ;
  dcterms:modified "2026-02-12T08:59:21.687234Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9901-4
  a curric:KeyLearningPoint ;
  rdfs:label """Using video recording will allow for accurate measurement of small time intervals."""@en ;
  dcterms:modified "2026-02-12T08:59:21.687239Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6598-1
  a curric:KeyLearningPoint ;
  rdfs:label """A dynamics trolley speeds up (accelerates) along the whole length of a steep ramp."""@en ;
  dcterms:modified "2026-02-12T08:59:21.687244Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6598-2
  a curric:KeyLearningPoint ;
  rdfs:label "Instantaneous speed is the average speed over a very short time period."@en ;
  dcterms:modified "2026-02-12T08:59:21.687248Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6598-3
  a curric:KeyLearningPoint ;
  rdfs:label "Taking measurements by reading the timing lines at eye level improves accuracy."@en ;
  dcterms:modified "2026-02-12T08:59:21.687253Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6598-4
  a curric:KeyLearningPoint ;
  rdfs:label "Repeated readings by different observers helps to check for systematic errors."@en ;
  dcterms:modified "2026-02-12T08:59:21.687257Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5052-1
  a curric:KeyLearningPoint ;
  rdfs:label """The speed of water waves can be measured using measurements of distance travelled and time taken."""@en ;
  dcterms:modified "2026-02-12T08:59:21.687395Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5052-2
  a curric:KeyLearningPoint ;
  rdfs:label "Random errors are made when the method limits how accurate a measurement can be."@en ;
  dcterms:modified "2026-02-12T08:59:21.687401Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5052-3
  a curric:KeyLearningPoint ;
  rdfs:label """The effect of random errors can be reduced by repeating readings and calculating a mean."""@en ;
  dcterms:modified "2026-02-12T08:59:21.687406Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5052-4
  a curric:KeyLearningPoint ;
  rdfs:label """The uncertainty in a mean result is calculated from half the range of the repeat measurements."""@en ;
  dcterms:modified "2026-02-12T08:59:21.687411Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9941-1
  a curric:KeyLearningPoint ;
  rdfs:label """A spring is elastically deformed if it returns to its original shape after the applied force is removed"""@en ;
  dcterms:modified "2026-02-12T08:59:21.687938Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9941-2
  a curric:KeyLearningPoint ;
  rdfs:label """A spring is inelastically deformed if it does not return to its original shape after the applied force is removed"""@en ;
  dcterms:modified "2026-02-12T08:59:21.687943Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9941-3
  a curric:KeyLearningPoint ;
  rdfs:label """Elastic deformation is proportional to the force applied to stretch or compress a spring"""@en ;
  dcterms:modified "2026-02-12T08:59:21.687947Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9941-4
  a curric:KeyLearningPoint ;
  rdfs:label """The spring constant (k) is the force needed to extend or compress an elastic object by one metre"""@en ;
  dcterms:modified "2026-02-12T08:59:21.687952Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9941-5
  a curric:KeyLearningPoint ;
  rdfs:label "Force on a spring = spring constant × extension"@en ;
  dcterms:modified "2026-02-12T08:59:21.687959Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20342-1
  a curric:KeyLearningPoint ;
  rdfs:label "A dynamics trolley has a steady acceleration down a steep ramp."@en ;
  dcterms:modified "2026-02-12T08:59:21.688346Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20342-2
  a curric:KeyLearningPoint ;
  rdfs:label """Acceleration = change of velocity ÷ time and change in velocity = final velocity – initial velocity"""@en ;
  dcterms:modified "2026-02-12T08:59:21.688351Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20342-3
  a curric:KeyLearningPoint ;
  rdfs:label """Light gates can improve accuracy of measurement of instantaneous velocity and reduces random errors."""@en ;
  dcterms:modified "2026-02-12T08:59:21.688355Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20342-4
  a curric:KeyLearningPoint ;
  rdfs:label "For a fair test, total mass of the system must be kept constant."@en ;
  dcterms:modified "2026-02-12T08:59:21.688360Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20342-5
  a curric:KeyLearningPoint ;
  rdfs:label "A compensated ramp can counteract the effect of friction."@en ;
  dcterms:modified "2026-02-12T08:59:21.688364Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4907-1
  a curric:KeyLearningPoint ;
  rdfs:label """Doubling the stiffness of a spring doubles the energy it has because it is stretched."""@en ;
  dcterms:modified "2026-02-12T08:59:21.689037Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4907-2
  a curric:KeyLearningPoint ;
  rdfs:label "The spring constant is measured in newtons per metre (N/m)."@en ;
  dcterms:modified "2026-02-12T08:59:21.689044Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4907-3
  a curric:KeyLearningPoint ;
  rdfs:label """Doubling the extension of a spring increases the energy it has because it is stretched by four times."""@en ;
  dcterms:modified "2026-02-12T08:59:21.689049Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4907-4
  a curric:KeyLearningPoint ;
  rdfs:label """The energy a spring has because it is stretched equals 1/2 × spring constant × (extension)²."""@en ;
  dcterms:modified "2026-02-12T08:59:21.689055Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6580-1
  a curric:KeyLearningPoint ;
  rdfs:label "Some forces require contact between objects, while others do not."@en ;
  dcterms:modified "2026-02-12T08:59:21.690066Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6580-2
  a curric:KeyLearningPoint ;
  rdfs:label "Forces are vectors and can be drawn as arrows on diagrams."@en ;
  dcterms:modified "2026-02-12T08:59:21.690073Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6580-3
  a curric:KeyLearningPoint ;
  rdfs:label """A free body diagram shows all of the individual forces acting on a single object."""@en ;
  dcterms:modified "2026-02-12T08:59:21.690079Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6580-4
  a curric:KeyLearningPoint ;
  rdfs:label "For every force there is an equal sized force acting in the opposite direction."@en ;
  dcterms:modified "2026-02-12T08:59:21.690083Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6580-5
  a curric:KeyLearningPoint ;
  rdfs:label """Force pairs have the same magnitude and type and act in opposite directions between two objects."""@en ;
  dcterms:modified "2026-02-12T08:59:21.690088Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9905-1
  a curric:KeyLearningPoint ;
  rdfs:label "A displacement–time graph shows how displacement changes with time."@en ;
  dcterms:modified "2026-02-12T08:59:21.690092Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9905-2
  a curric:KeyLearningPoint ;
  rdfs:label "A velocity–time graph shows how velocity changes with time."@en ;
  dcterms:modified "2026-02-12T08:59:21.690097Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9905-3
  a curric:KeyLearningPoint ;
  rdfs:label """Displacement–time and velocity–time graphs of the same motion have different shapes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.690102Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9905-4
  a curric:KeyLearningPoint ;
  rdfs:label "Acceleration is equal to the gradient of a velocity–time graph."@en ;
  dcterms:modified "2026-02-12T08:59:21.690106Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9905-5
  a curric:KeyLearningPoint ;
  rdfs:label """A falling line shows deceleration (decreasing velocity) which is a negative acceleration."""@en ;
  dcterms:modified "2026-02-12T08:59:21.690111Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20371-1
  a curric:KeyLearningPoint ;
  rdfs:label """Electromagnetic waves/radiation are transverse oscillations (ripples) in electric and magnetic fields."""@en ;
  dcterms:modified "2026-02-12T08:59:21.690115Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20371-2
  a curric:KeyLearningPoint ;
  rdfs:label """The visible spectrum shows the range of different frequencies (colours) of visible light waves (visible EM radiation)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.690120Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20371-3
  a curric:KeyLearningPoint ;
  rdfs:label """In the visible spectrum, violet light has the highest frequency and refracts more than red."""@en ;
  dcterms:modified "2026-02-12T08:59:21.690125Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20371-4
  a curric:KeyLearningPoint ;
  rdfs:label """The EM spectrum shows the range of frequencies that EM waves can have (radio, microwave, IR, visible, UV, X-ray, gamma)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.690129Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20371-5
  a curric:KeyLearningPoint ;
  rdfs:label """EM waves in different frequency ranges have the same speed in air, but interact differently with different materials."""@en ;
  dcterms:modified "2026-02-12T08:59:21.690134Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6613-1
  a curric:KeyLearningPoint ;
  rdfs:label """An electromagnetic door lock uses an electromagnet to pull a magnetic bolt to unlock a door."""@en ;
  dcterms:modified "2026-02-12T08:59:21.690180Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6613-2
  a curric:KeyLearningPoint ;
  rdfs:label """An electric bell often contains an electromagnet that attracts and moves the striker, making it hit the bell."""@en ;
  dcterms:modified "2026-02-12T08:59:21.690185Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6613-3
  a curric:KeyLearningPoint ;
  rdfs:label """As an electromagnet moves the striker in an electric bell, it breaks its own circuit to let the striker spring back."""@en ;
  dcterms:modified "2026-02-12T08:59:21.690189Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6613-4
  a curric:KeyLearningPoint ;
  rdfs:label "A motor contains a spinning coil of wire that is an electromagnet."@en ;
  dcterms:modified "2026-02-12T08:59:21.690194Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6613-5
  a curric:KeyLearningPoint ;
  rdfs:label """When there is a current in the spinning coil of wire in a motor, other magnets around it will push it round."""@en ;
  dcterms:modified "2026-02-12T08:59:21.690198Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6603-1
  a curric:KeyLearningPoint ;
  rdfs:label """A random error is a chance difference between an observed value and the true value."""@en ;
  dcterms:modified "2026-02-12T08:59:21.690241Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6603-2
  a curric:KeyLearningPoint ;
  rdfs:label """Random errors can be caused by mistakes in taking readings, or by taking a reading at the wrong time."""@en ;
  dcterms:modified "2026-02-12T08:59:21.690246Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6603-3
  a curric:KeyLearningPoint ;
  rdfs:label "The temperature of a melting solid does not change as it heated."@en ;
  dcterms:modified "2026-02-12T08:59:21.690251Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6603-4
  a curric:KeyLearningPoint ;
  rdfs:label "The temperature of a boiling liquid does not change as it is heated."@en ;
  dcterms:modified "2026-02-12T08:59:21.690255Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28176-1
  a curric:KeyLearningPoint ;
  rdfs:label "Radioactive contamination is the presence of unwanted radioactive atoms."@en ;
  dcterms:modified "2026-02-12T08:59:21.690398Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28176-2
  a curric:KeyLearningPoint ;
  rdfs:label """A material being exposed to iodising radiation is being irradiated and does not become radioactive."""@en ;
  dcterms:modified "2026-02-12T08:59:21.690405Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28176-3
  a curric:KeyLearningPoint ;
  rdfs:label """Radioactive isotopes with short half-lives decay quickly, emitting most radiation over a short period of time."""@en ;
  dcterms:modified "2026-02-12T08:59:21.690410Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9165-1
  a curric:KeyLearningPoint ;
  rdfs:label """The solar system includes the Sun, eight planets, dwarf planets and bands of smaller rocks."""@en ;
  dcterms:modified "2026-02-12T08:59:21.690613Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9165-2
  a curric:KeyLearningPoint ;
  rdfs:label """The planets, dwarf planets and bands of smaller rocks all move the same way around the Sun as they orbit it."""@en ;
  dcterms:modified "2026-02-12T08:59:21.690620Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9165-3
  a curric:KeyLearningPoint ;
  rdfs:label "Most planets in the solar system are orbited by one or more moons."@en ;
  dcterms:modified "2026-02-12T08:59:21.690625Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9165-4
  a curric:KeyLearningPoint ;
  rdfs:label """Each moon orbits a planet because of the gravitational attraction between it and the planet."""@en ;
  dcterms:modified "2026-02-12T08:59:21.690629Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9165-5
  a curric:KeyLearningPoint ;
  rdfs:label """Each planet in the solar system orbits the Sun because of the gravitational attraction between it and the Sun."""@en ;
  dcterms:modified "2026-02-12T08:59:21.690634Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9895-1
  a curric:KeyLearningPoint ;
  rdfs:label "The velocity of an object is equal to the gradient of a displacement-time graph."@en ;
  dcterms:modified "2026-02-12T08:59:21.690705Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9895-2
  a curric:KeyLearningPoint ;
  rdfs:label "A direction in which velocity and displacement are measured needs to be chosen."@en ;
  dcterms:modified "2026-02-12T08:59:21.690710Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9895-3
  a curric:KeyLearningPoint ;
  rdfs:label """A negative gradient on a displacement-time graph (sloping downwards) represents velocity in the opposite direction."""@en ;
  dcterms:modified "2026-02-12T08:59:21.690715Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9895-4
  a curric:KeyLearningPoint ;
  rdfs:label """A negative value for displacement represents a position ‘behind’ the starting position."""@en ;
  dcterms:modified "2026-02-12T08:59:21.690719Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20079-1
  a curric:KeyLearningPoint ;
  rdfs:label "The velocity of an object is its speed in a given direction."@en ;
  dcterms:modified "2026-02-12T08:59:21.690825Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20079-2
  a curric:KeyLearningPoint ;
  rdfs:label """The displacement of an object is the distance it travels in a particular direction."""@en ;
  dcterms:modified "2026-02-12T08:59:21.690830Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20079-3
  a curric:KeyLearningPoint ;
  rdfs:label "Displacement and velocity are both vector quantities."@en ;
  dcterms:modified "2026-02-12T08:59:21.690834Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20079-4
  a curric:KeyLearningPoint ;
  rdfs:label """Velocity has a positive value in one direction and negative value in the opposite direction."""@en ;
  dcterms:modified "2026-02-12T08:59:21.690841Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4915-1
  a curric:KeyLearningPoint ;
  rdfs:label "Resultant force = mass × acceleration, F = m × a"@en ;
  dcterms:modified "2026-02-12T08:59:21.690846Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4915-2
  a curric:KeyLearningPoint ;
  rdfs:label """An object that is thrown in the air experiences a constant gravitational force towards the centre of Earth."""@en ;
  dcterms:modified "2026-02-12T08:59:21.690850Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4915-3
  a curric:KeyLearningPoint ;
  rdfs:label """An object that is thrown in the air is constantly accelerating towards the centre of Earth."""@en ;
  dcterms:modified "2026-02-12T08:59:21.690855Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9904-1
  a curric:KeyLearningPoint ;
  rdfs:label "A velocity-time graph shows how velocity changes with time."@en ;
  dcterms:modified "2026-02-12T08:59:21.693084Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9904-2
  a curric:KeyLearningPoint ;
  rdfs:label "Acceleration is equal to the gradient of a velocity-time graph."@en ;
  dcterms:modified "2026-02-12T08:59:21.693088Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9904-3
  a curric:KeyLearningPoint ;
  rdfs:label """A falling line shows decreasing velocity called deceleration, which is a negative acceleration."""@en ;
  dcterms:modified "2026-02-12T08:59:21.693093Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9904-4
  a curric:KeyLearningPoint ;
  rdfs:label "The gradient of the line gives the instantaneous acceleration."@en ;
  dcterms:modified "2026-02-12T08:59:21.693097Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9904-5
  a curric:KeyLearningPoint ;
  rdfs:label "The distance travelled is equal to the area under a velocity-time graph."@en ;
  dcterms:modified "2026-02-12T08:59:21.693102Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9939-1
  a curric:KeyLearningPoint ;
  rdfs:label "Stretching or compressing an object requires more than one force."@en ;
  dcterms:modified "2026-02-12T08:59:21.694191Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9939-2
  a curric:KeyLearningPoint ;
  rdfs:label """Below the limit of proportionality, a stretched spring is not stretched permanently out of shape."""@en ;
  dcterms:modified "2026-02-12T08:59:21.694196Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9939-3
  a curric:KeyLearningPoint ;
  rdfs:label """Above the limit of proportionality, a stretched spring is stretched permanently out of shape."""@en ;
  dcterms:modified "2026-02-12T08:59:21.694200Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4935-1
  a curric:KeyLearningPoint ;
  rdfs:label """Artificial satellites orbit Earth because of the gravitational attraction between them."""@en ;
  dcterms:modified "2026-02-12T08:59:21.694205Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4935-2
  a curric:KeyLearningPoint ;
  rdfs:label "The speed of a satellite along its orbit around Earth is constant."@en ;
  dcterms:modified "2026-02-12T08:59:21.694211Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4935-3
  a curric:KeyLearningPoint ;
  rdfs:label """The velocity of a satellite along its orbit around Earth constantly changes as it changes direction."""@en ;
  dcterms:modified "2026-02-12T08:59:21.694216Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4935-4
  a curric:KeyLearningPoint ;
  rdfs:label """The centripetal force on a satellite makes it accelerate and change direction, but not speed."""@en ;
  dcterms:modified "2026-02-12T08:59:21.694221Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4935-5
  a curric:KeyLearningPoint ;
  rdfs:label """To orbit in a stable orbit, the orbital radius of a satellite must change if its speed changes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.694225Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5049-1
  a curric:KeyLearningPoint ;
  rdfs:label "The speed of a wave depends on the medium it is travelling through"@en ;
  dcterms:modified "2026-02-12T08:59:21.694230Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5049-2
  a curric:KeyLearningPoint ;
  rdfs:label "The speed of a wave does not depend on its frequency"@en ;
  dcterms:modified "2026-02-12T08:59:21.694236Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5049-3
  a curric:KeyLearningPoint ;
  rdfs:label "For a given wave speed, the higher the frequency, the shorter the wavelength"@en ;
  dcterms:modified "2026-02-12T08:59:21.694241Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5049-4
  a curric:KeyLearningPoint ;
  rdfs:label "For a given wave speed, the longer the wavelength, the lower the frequency"@en ;
  dcterms:modified "2026-02-12T08:59:21.694245Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5049-5
  a curric:KeyLearningPoint ;
  rdfs:label "Wave speed = frequency x wavelength"@en ;
  dcterms:modified "2026-02-12T08:59:21.694250Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27968-1
  a curric:KeyLearningPoint ;
  rdfs:label """Nuclear fission is the splitting of a large and unstable nucleus such as uranium or plutonium."""@en ;
  dcterms:modified "2026-02-12T08:59:21.697306Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27968-2
  a curric:KeyLearningPoint ;
  rdfs:label """A neutron fired at a uranium nucleus can cause nuclear fission that splits the nucleus and emits 2 or 3 more neutrons."""@en ;
  dcterms:modified "2026-02-12T08:59:21.697311Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27968-3
  a curric:KeyLearningPoint ;
  rdfs:label """The motion of all the particles shot out from a nuclear fission can cause heating by making other particles move faster."""@en ;
  dcterms:modified "2026-02-12T08:59:21.697315Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27968-4
  a curric:KeyLearningPoint ;
  rdfs:label """Neutrons shot out from a nuclear fission can split more uranium nuclei in a chain reaction."""@en ;
  dcterms:modified "2026-02-12T08:59:21.697320Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27968-5
  a curric:KeyLearningPoint ;
  rdfs:label """Nuclear fusion is the joining of two light nuclei to form a heavier nucleus with the creation of gamma radiation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.697324Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4941-1
  a curric:KeyLearningPoint ;
  rdfs:label """Artificial satellites orbit Earth because of the gravitational attraction between them."""@en ;
  dcterms:modified "2026-02-12T08:59:21.697329Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4941-2
  a curric:KeyLearningPoint ;
  rdfs:label "The speed of a satellite along its orbit around Earth is constant."@en ;
  dcterms:modified "2026-02-12T08:59:21.697333Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4941-3
  a curric:KeyLearningPoint ;
  rdfs:label """The velocity of a satellite along its orbit around Earth constantly changes as it changes direction."""@en ;
  dcterms:modified "2026-02-12T08:59:21.697337Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4941-4
  a curric:KeyLearningPoint ;
  rdfs:label """The gravitational force on a satellite makes it accelerate and change direction, but not speed."""@en ;
  dcterms:modified "2026-02-12T08:59:21.697342Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6578-1
  a curric:KeyLearningPoint ;
  rdfs:label "The velocity of an object is its speed in a given direction."@en ;
  dcterms:modified "2026-02-12T08:59:21.697391Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6578-2
  a curric:KeyLearningPoint ;
  rdfs:label """The displacement of an object is the distance it travels in a particular direction."""@en ;
  dcterms:modified "2026-02-12T08:59:21.697395Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6578-3
  a curric:KeyLearningPoint ;
  rdfs:label "Displacement and velocity are both vector quantities."@en ;
  dcterms:modified "2026-02-12T08:59:21.697400Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6578-4
  a curric:KeyLearningPoint ;
  rdfs:label """Velocity has a positive value in one direction and negative value in the opposite direction."""@en ;
  dcterms:modified "2026-02-12T08:59:21.697404Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9139-1
  a curric:KeyLearningPoint ;
  rdfs:label "Resultant force = mass × acceleration, F = m × a."@en ;
  dcterms:modified "2026-02-12T08:59:21.697409Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9139-2
  a curric:KeyLearningPoint ;
  rdfs:label """An object that is thrown in the air experiences a constant gravitational force towards the centre of the Earth."""@en ;
  dcterms:modified "2026-02-12T08:59:21.697414Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9139-3
  a curric:KeyLearningPoint ;
  rdfs:label """An object that is thrown in the air is constantly accelerating towards the centre of the Earth."""@en ;
  dcterms:modified "2026-02-12T08:59:21.697418Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9139-4
  a curric:KeyLearningPoint ;
  rdfs:label """Inertial mass is a measure of how hard it is to change the velocity of an object."""@en ;
  dcterms:modified "2026-02-12T08:59:21.697423Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9139-5
  a curric:KeyLearningPoint ;
  rdfs:label "Inertial mass = force ÷ acceleration, m = F ÷ a."@en ;
  dcterms:modified "2026-02-12T08:59:21.697427Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9931-1
  a curric:KeyLearningPoint ;
  rdfs:label "Energy is measured in joules (J)."@en ;
  dcterms:modified "2026-02-12T08:59:21.697762Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9931-2
  a curric:KeyLearningPoint ;
  rdfs:label """Doubling the mass of a moving object doubles the energy it has in its kinetic store."""@en ;
  dcterms:modified "2026-02-12T08:59:21.697767Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9931-3
  a curric:KeyLearningPoint ;
  rdfs:label """Doubling the speed of an object increases the energy it has in its kinetic store by four times."""@en ;
  dcterms:modified "2026-02-12T08:59:21.697771Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9931-4
  a curric:KeyLearningPoint ;
  rdfs:label """The energy an object has in its kinetic store of energy is found using the equation E = ½ mv²."""@en ;
  dcterms:modified "2026-02-12T08:59:21.697776Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28016-1
  a curric:KeyLearningPoint ;
  rdfs:label "A non–renewable energy resource cannot be replenished as it is used."@en ;
  dcterms:modified "2026-02-12T08:59:21.697805Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28016-2
  a curric:KeyLearningPoint ;
  rdfs:label """Non-renewable energy resources include fossil fuels (coal, oil and gas) and nuclear fuels."""@en ;
  dcterms:modified "2026-02-12T08:59:21.697810Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28016-3
  a curric:KeyLearningPoint ;
  rdfs:label "A renewable energy resource can be replenished as it is used."@en ;
  dcterms:modified "2026-02-12T08:59:21.697814Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28016-4
  a curric:KeyLearningPoint ;
  rdfs:label """Renewable energy resources include biofuels, wind, hydroelectricity, geothermal, tidal, solar and water waves."""@en ;
  dcterms:modified "2026-02-12T08:59:21.697821Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28016-5
  a curric:KeyLearningPoint ;
  rdfs:label """Science can identify environmental issues, but political, social, ethical and economic considerations determine action."""@en ;
  dcterms:modified "2026-02-12T08:59:21.697825Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9114-1
  a curric:KeyLearningPoint ;
  rdfs:label "Power is equal to the rate at which work is done."@en ;
  dcterms:modified "2026-02-12T08:59:21.697830Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9114-2
  a curric:KeyLearningPoint ;
  rdfs:label "Power is equal to the rate at which energy is transferred."@en ;
  dcterms:modified "2026-02-12T08:59:21.697835Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9114-3
  a curric:KeyLearningPoint ;
  rdfs:label "Power = work done ÷ time."@en ;
  dcterms:modified "2026-02-12T08:59:21.697839Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9114-4
  a curric:KeyLearningPoint ;
  rdfs:label "Power is measured in watts (W)."@en ;
  dcterms:modified "2026-02-12T08:59:21.697844Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4923-1
  a curric:KeyLearningPoint ;
  rdfs:label """Different hot metals, of the same mass and starting temperature, heat a fixed amount of water by different amounts."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700196Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4923-2
  a curric:KeyLearningPoint ;
  rdfs:label """The energy a material has because its particles are moving with forces between them can be labelled internal energy."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700200Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4923-3
  a curric:KeyLearningPoint ;
  rdfs:label """The larger the specific heat capacity of a material, the more energy transferred to increase its temperature by 1ºC."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700205Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4923-4
  a curric:KeyLearningPoint ;
  rdfs:label """The larger the specific heat capacity of a material, the more heating it does as its temperature falls by 1ºC."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700209Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8158-1
  a curric:KeyLearningPoint ;
  rdfs:label """The pressure in a fluid increases with depth because the weight of fluid above pushes particles closer together."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700214Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8158-2
  a curric:KeyLearningPoint ;
  rdfs:label """The pressure on an object in a fluid pushes with more force on the lower part of it and causes upthrust."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700218Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8158-3
  a curric:KeyLearningPoint ;
  rdfs:label "An object floats in water if its density is less than that of water."@en ;
  dcterms:modified "2026-02-12T08:59:21.700223Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8158-4
  a curric:KeyLearningPoint ;
  rdfs:label """The density of a material increases with the mass of each particle and the closeness of its particles."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700228Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8158-5
  a curric:KeyLearningPoint ;
  rdfs:label """Ice is less dense than water as its crystal structure fixes the particles further apart than they are in water."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700232Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20365-1
  a curric:KeyLearningPoint ;
  rdfs:label "Frequency of a wave can be measured indirectly from its speed and wavelength."@en ;
  dcterms:modified "2026-02-12T08:59:21.700237Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20365-2
  a curric:KeyLearningPoint ;
  rdfs:label """Wavelength of a wave can be measured by using a freeze frame of a wave moving along the length of a ruler."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700241Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20365-3
  a curric:KeyLearningPoint ;
  rdfs:label """It is more accurate to measure the length of, e.g. ten waves and dividing by ten, than measuring one wavelength."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700245Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20365-4
  a curric:KeyLearningPoint ;
  rdfs:label """Speed of a wave can be measured by recording the wave moving along a ruler with a timer in the frame."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700250Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20365-5
  a curric:KeyLearningPoint ;
  rdfs:label """Accurate distance and time are measured by freezing the film, played back in slow motion, to track one wave crest."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700257Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9934-1
  a curric:KeyLearningPoint ;
  rdfs:label "When an object moves upwards, work is done against the gravitational force."@en ;
  dcterms:modified "2026-02-12T08:59:21.700262Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9934-2
  a curric:KeyLearningPoint ;
  rdfs:label """The gravitational force acting on an object does work to speed it up when it is falling."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700266Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9934-3
  a curric:KeyLearningPoint ;
  rdfs:label "Weight = mass x gravitational field strength, W = mg"@en ;
  dcterms:modified "2026-02-12T08:59:21.700273Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9934-4
  a curric:KeyLearningPoint ;
  rdfs:label """Gravitational potential energy of an object = mass × gravitational field strength × height"""@en ;
  dcterms:modified "2026-02-12T08:59:21.700278Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5078-1
  a curric:KeyLearningPoint ;
  rdfs:label """A magnet moving relative to a wire connected in a complete circuit can cause a current to flow in the wire."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700398Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5078-2
  a curric:KeyLearningPoint ;
  rdfs:label """A magnet moving in the opposite direction relative to a wire induces a current in the opposite direction."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700403Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5078-3
  a curric:KeyLearningPoint ;
  rdfs:label """A magnet moving relative to a wire can cause a potential difference across the wire called the induced potential."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700409Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5078-4
  a curric:KeyLearningPoint ;
  rdfs:label """Induced potential is proportional to mag. field strength and the relative speed of movement between a wire and a magnet."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700416Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5078-5
  a curric:KeyLearningPoint ;
  rdfs:label """For a magnet moving relative to a coil, the induced potential is proportional to the number of turns of wire in a coil."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700421Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6615-1
  a curric:KeyLearningPoint ;
  rdfs:label """Refraction is when waves travel from one transparent medium to another, causing a change in direction."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700426Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6615-2
  a curric:KeyLearningPoint ;
  rdfs:label """When waves slow down, they turn towards the normal line (angle of incidence > angle of refraction)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700430Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6615-3
  a curric:KeyLearningPoint ;
  rdfs:label """When waves speed up, they turn away from the normal line (angle of incidence < angle of refraction)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700435Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6615-4
  a curric:KeyLearningPoint ;
  rdfs:label """Refraction can be investigated using a clear rectangular block, ray box and narrow slit, pencil, paper and a protractor."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700439Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6615-5
  a curric:KeyLearningPoint ;
  rdfs:label "The greater the angle of incidence, the greater the angle of refraction."@en ;
  dcterms:modified "2026-02-12T08:59:21.700446Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20370-1
  a curric:KeyLearningPoint ;
  rdfs:label """Electromagnetic waves/radiation are transverse oscillations (ripples) in electric and magnetic fields."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700476Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20370-2
  a curric:KeyLearningPoint ;
  rdfs:label """The visible spectrum shows the range of different frequencies (colours) of visible light waves (visible EM radiation)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700480Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20370-3
  a curric:KeyLearningPoint ;
  rdfs:label """In the visible spectrum, violet light has the highest frequency and refracts more than red as it slows more in glass."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700485Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20370-4
  a curric:KeyLearningPoint ;
  rdfs:label """The EM spectrum shows the range of frequencies that EM waves can have (radio, microwave, IR, visible, UV, X-ray, gamma)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700489Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20370-5
  a curric:KeyLearningPoint ;
  rdfs:label """EM waves in different frequency ranges have the same speed in air, but interact differently with different materials."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700494Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9922-1
  a curric:KeyLearningPoint ;
  rdfs:label "Power is equal to the rate at which work is done."@en ;
  dcterms:modified "2026-02-12T08:59:21.700499Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9922-2
  a curric:KeyLearningPoint ;
  rdfs:label "Power is equal to the rate at which energy is transferred."@en ;
  dcterms:modified "2026-02-12T08:59:21.700503Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9922-3
  a curric:KeyLearningPoint ;
  rdfs:label "Power = work done ÷ time."@en ;
  dcterms:modified "2026-02-12T08:59:21.700508Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9922-4
  a curric:KeyLearningPoint ;
  rdfs:label "Power is measured in watts (W)."@en ;
  dcterms:modified "2026-02-12T08:59:21.700512Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9094-1
  a curric:KeyLearningPoint ;
  rdfs:label """The pressure in a fluid increases with depth because the weight of fluid above pushes particles closer together."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700517Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9094-2
  a curric:KeyLearningPoint ;
  rdfs:label """The pressure on an object in a fluid pushes with more force on the lower part of it and causes upthrust."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700521Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9094-3
  a curric:KeyLearningPoint ;
  rdfs:label "An object floats in water if its density is less than that of water."@en ;
  dcterms:modified "2026-02-12T08:59:21.700526Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9094-4
  a curric:KeyLearningPoint ;
  rdfs:label """The density of a material increases with the mass of each particle and the closeness of its particles."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700533Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9094-5
  a curric:KeyLearningPoint ;
  rdfs:label """Ice is less dense than water as its crystal structure fixes the particles further apart than they are in water."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700537Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9137-1
  a curric:KeyLearningPoint ;
  rdfs:label """Acceleration can be measured accurately using light gates or roughly measured using a stopwatch and ruler."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700542Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9137-2
  a curric:KeyLearningPoint ;
  rdfs:label """The acceleration of an object is proportional to the resultant force acting on the object."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700546Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9137-3
  a curric:KeyLearningPoint ;
  rdfs:label """The acceleration of an object is inversely proportional to the mass of the object."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700551Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9137-4
  a curric:KeyLearningPoint ;
  rdfs:label "Newton's Second Law states that F = m × a."@en ;
  dcterms:modified "2026-02-12T08:59:21.700555Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20008-1
  a curric:KeyLearningPoint ;
  rdfs:label """Energy is dissipated due to friction which causes particles to vibrate more quickly and heats up the surroundings."""@en ;
  dcterms:modified "2026-02-12T08:59:21.702128Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20008-2
  a curric:KeyLearningPoint ;
  rdfs:label """Energy is dissipated due to drag which causes particles in the surroundings to move more quickly."""@en ;
  dcterms:modified "2026-02-12T08:59:21.702132Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20008-3
  a curric:KeyLearningPoint ;
  rdfs:label "Efficiency = useful output energy transfer / total input energy transfer"@en ;
  dcterms:modified "2026-02-12T08:59:21.702137Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20008-4
  a curric:KeyLearningPoint ;
  rdfs:label "Efficiency = useful power output / total power input"@en ;
  dcterms:modified "2026-02-12T08:59:21.702141Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20008-5
  a curric:KeyLearningPoint ;
  rdfs:label "Efficiency can be increased by lubrication, bearings or wheels."@en ;
  dcterms:modified "2026-02-12T08:59:21.702146Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4909-1
  a curric:KeyLearningPoint ;
  rdfs:label """Doubling the stiffness of a spring doubles the energy it has because it is stretched."""@en ;
  dcterms:modified "2026-02-12T08:59:21.702151Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4909-2
  a curric:KeyLearningPoint ;
  rdfs:label "The spring constant is measured in newtons per metre (N/m)."@en ;
  dcterms:modified "2026-02-12T08:59:21.702155Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4909-3
  a curric:KeyLearningPoint ;
  rdfs:label """Doubling the extension of a spring increases the energy it has, because it is stretched, by four times."""@en ;
  dcterms:modified "2026-02-12T08:59:21.702160Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4909-4
  a curric:KeyLearningPoint ;
  rdfs:label """The energy a spring has because it is stretched equals 1/2 × spring constant × (extension)²."""@en ;
  dcterms:modified "2026-02-12T08:59:21.702164Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9111-1
  a curric:KeyLearningPoint ;
  rdfs:label """Current can be calculated using the equation: current = p.d. ÷ resistance (I = V ÷ R)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.702169Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9111-2
  a curric:KeyLearningPoint ;
  rdfs:label """The rules of current and p.d. for a series circuit can be applied to find some missing values of current and p.d."""@en ;
  dcterms:modified "2026-02-12T08:59:21.702176Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9111-3
  a curric:KeyLearningPoint ;
  rdfs:label """The equation I = V ÷ R can be rearranged so that either V or R is the subject of the equation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.702181Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9111-4
  a curric:KeyLearningPoint ;
  rdfs:label """If any two values in the equation I = V ÷ R are known, the third can be calculated."""@en ;
  dcterms:modified "2026-02-12T08:59:21.702185Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9111-5
  a curric:KeyLearningPoint ;
  rdfs:label """If only one value in the equation I = V ÷ R is known, rules for current or p.d. need to be applied to find a second."""@en ;
  dcterms:modified "2026-02-12T08:59:21.702190Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9924-1
  a curric:KeyLearningPoint ;
  rdfs:label """Energy is dissipated due to friction which causes particles to vibrate more quickly and heats up the surroundings."""@en ;
  dcterms:modified "2026-02-12T08:59:21.702310Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9924-2
  a curric:KeyLearningPoint ;
  rdfs:label """Energy is dissipated due to drag which causes particles in the surroundings to move more quickly."""@en ;
  dcterms:modified "2026-02-12T08:59:21.702315Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9924-3
  a curric:KeyLearningPoint ;
  rdfs:label "Efficiency = useful output energy transfer / total input energy transfer"@en ;
  dcterms:modified "2026-02-12T08:59:21.702319Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9927-1
  a curric:KeyLearningPoint ;
  rdfs:label "Energy is measured in joules (J)."@en ;
  dcterms:modified "2026-02-12T08:59:21.702471Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9927-2
  a curric:KeyLearningPoint ;
  rdfs:label """Doubling the mass of a moving object doubles the energy it has in its kinetic store."""@en ;
  dcterms:modified "2026-02-12T08:59:21.702476Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9927-3
  a curric:KeyLearningPoint ;
  rdfs:label """Doubling the speed of an object increases the energy it has in its kinetic store by four times."""@en ;
  dcterms:modified "2026-02-12T08:59:21.702481Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9927-4
  a curric:KeyLearningPoint ;
  rdfs:label """The energy an object has in its kinetic store of energy is found using the equation KE = ½ mv²."""@en ;
  dcterms:modified "2026-02-12T08:59:21.702485Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9117-1
  a curric:KeyLearningPoint ;
  rdfs:label """A spring is elastically deformed if it returns to its original shape after the applied force is removed"""@en ;
  dcterms:modified "2026-02-12T08:59:21.702490Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9117-2
  a curric:KeyLearningPoint ;
  rdfs:label """A spring is inelastically deformed if it does not return to its original shape after the applied force is removed"""@en ;
  dcterms:modified "2026-02-12T08:59:21.702494Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9117-3
  a curric:KeyLearningPoint ;
  rdfs:label """Elastic deformation is proportional to the force applied to stretch or compress a spring"""@en ;
  dcterms:modified "2026-02-12T08:59:21.702499Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9117-4
  a curric:KeyLearningPoint ;
  rdfs:label """The spring constant (k) is the force needed to extend or compress an elastic object by one metre"""@en ;
  dcterms:modified "2026-02-12T08:59:21.702503Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9117-5
  a curric:KeyLearningPoint ;
  rdfs:label "Force on a spring = spring constant × extension"@en ;
  dcterms:modified "2026-02-12T08:59:21.702508Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20348-1
  a curric:KeyLearningPoint ;
  rdfs:label """Radio waves, microwaves, IR and visible light are non–ionising EM radiation. They can harm cells by heating."""@en ;
  dcterms:modified "2026-02-12T08:59:21.703425Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20348-2
  a curric:KeyLearningPoint ;
  rdfs:label """Radio waves and microwaves are used for long distance communication, broadcasting and data transmission."""@en ;
  dcterms:modified "2026-02-12T08:59:21.703430Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20348-3
  a curric:KeyLearningPoint ;
  rdfs:label """Microwaves are absorbed by water, so can be used to cook food from within. IR radiation cooks the surface of food."""@en ;
  dcterms:modified "2026-02-12T08:59:21.703434Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20348-4
  a curric:KeyLearningPoint ;
  rdfs:label """IR is used for heating and thermal imaging. Visible light and IR are used for data transmission in optical fibres."""@en ;
  dcterms:modified "2026-02-12T08:59:21.703439Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4902-1
  a curric:KeyLearningPoint ;
  rdfs:label "Work done is the total amount of energy transferred."@en ;
  dcterms:modified "2026-02-12T08:59:21.703443Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4902-2
  a curric:KeyLearningPoint ;
  rdfs:label "Work done = force x distance (moved in the direction of the force)."@en ;
  dcterms:modified "2026-02-12T08:59:21.703448Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4902-3
  a curric:KeyLearningPoint ;
  rdfs:label "Work done is measured in Joule (J)."@en ;
  dcterms:modified "2026-02-12T08:59:21.703453Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4912-1
  a curric:KeyLearningPoint ;
  rdfs:label "Some forces require contact between objects, while others do not."@en ;
  dcterms:modified "2026-02-12T08:59:21.703483Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4912-2
  a curric:KeyLearningPoint ;
  rdfs:label "Forces are vectors and can be drawn as arrows on diagrams."@en ;
  dcterms:modified "2026-02-12T08:59:21.703488Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4912-3
  a curric:KeyLearningPoint ;
  rdfs:label "A free body diagram shows all of the forces acting on a single object."@en ;
  dcterms:modified "2026-02-12T08:59:21.703492Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4912-4
  a curric:KeyLearningPoint ;
  rdfs:label "For every force there is an equal sized force acting in the opposite direction."@en ;
  dcterms:modified "2026-02-12T08:59:21.703497Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4912-5
  a curric:KeyLearningPoint ;
  rdfs:label """Force pairs have the same magnitude and type, and act in opposite directions between two objects."""@en ;
  dcterms:modified "2026-02-12T08:59:21.703502Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5085-1
  a curric:KeyLearningPoint ;
  rdfs:label """At a boundary to a medium where the wave speed increases, waves are refracted away from the normal."""@en ;
  dcterms:modified "2026-02-12T08:59:21.703667Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5085-2
  a curric:KeyLearningPoint ;
  rdfs:label """If the angle of incidence is too big the waves will undergo total internal reflection."""@en ;
  dcterms:modified "2026-02-12T08:59:21.703672Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5085-3
  a curric:KeyLearningPoint ;
  rdfs:label """For a glass–air boundary, the total internal reflection occurs when the angle of incidence is 42° or greater."""@en ;
  dcterms:modified "2026-02-12T08:59:21.703677Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28013-1
  a curric:KeyLearningPoint ;
  rdfs:label """Energy transferred to a solid at its melting point allows its particles to move further apart."""@en ;
  dcterms:modified "2026-02-12T08:59:21.703727Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28013-2
  a curric:KeyLearningPoint ;
  rdfs:label """Energy transferred to a liquid at its boiling point allows its particles to move fast enough to get even further apart."""@en ;
  dcterms:modified "2026-02-12T08:59:21.703732Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28013-3
  a curric:KeyLearningPoint ;
  rdfs:label """The energy transferred to melt a solid at its melting point is proportional to the mass of the solid."""@en ;
  dcterms:modified "2026-02-12T08:59:21.703739Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28013-4
  a curric:KeyLearningPoint ;
  rdfs:label """The energy transferred to melt 1 kg of a solid at its melting point is proportional to the solid’s specific latent heat."""@en ;
  dcterms:modified "2026-02-12T08:59:21.703744Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28013-5
  a curric:KeyLearningPoint ;
  rdfs:label """The energy transferred to boil 1 kg of a liquid at its boiling point is proportional to it’s specific latent heat."""@en ;
  dcterms:modified "2026-02-12T08:59:21.703748Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9925-1
  a curric:KeyLearningPoint ;
  rdfs:label """Energy is dissipated due to friction which causes particles to vibrate more quickly and heats up the surroundings."""@en ;
  dcterms:modified "2026-02-12T08:59:21.703789Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9925-2
  a curric:KeyLearningPoint ;
  rdfs:label """Energy is dissipated due to drag which causes particles in the surroundings to move more quickly."""@en ;
  dcterms:modified "2026-02-12T08:59:21.703794Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9925-3
  a curric:KeyLearningPoint ;
  rdfs:label "Efficiency = useful output energy transfer / total input energy transfer"@en ;
  dcterms:modified "2026-02-12T08:59:21.703798Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9925-4
  a curric:KeyLearningPoint ;
  rdfs:label "Efficiency can be increased by lubrication, bearings or wheels"@en ;
  dcterms:modified "2026-02-12T08:59:21.703803Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4920-1
  a curric:KeyLearningPoint ;
  rdfs:label """The momentum of an object is changed by a resultant force acting over a period of time."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704753Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4920-2
  a curric:KeyLearningPoint ;
  rdfs:label "Force = rate of change of momentum, F = Δp ÷ t = (mv – mu) ÷ t"@en ;
  dcterms:modified "2026-02-12T08:59:21.704757Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4920-3
  a curric:KeyLearningPoint ;
  rdfs:label """The size of an impact force can be changed when the duration of the impact changes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704762Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5036-1
  a curric:KeyLearningPoint ;
  rdfs:label "The current in a series circuit is the same everywhere."@en ;
  dcterms:modified "2026-02-12T08:59:21.706652Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5036-2
  a curric:KeyLearningPoint ;
  rdfs:label """The p.d. across each component in a series electric circuit adds up to the p.d. of the battery."""@en ;
  dcterms:modified "2026-02-12T08:59:21.706656Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5036-3
  a curric:KeyLearningPoint ;
  rdfs:label """The greater the resistance in a series circuit, the lower the current (current is inversely proportional to resistance)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.706661Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5036-4
  a curric:KeyLearningPoint ;
  rdfs:label """The greater the battery p.d. in series circuit, the larger the current (current is directly proportional to p.d.)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.706665Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5036-5
  a curric:KeyLearningPoint ;
  rdfs:label """Current, p.d. or resistance can be calculated with the equation: current = p.d./resistance."""@en ;
  dcterms:modified "2026-02-12T08:59:21.706670Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5051-1
  a curric:KeyLearningPoint ;
  rdfs:label "The speed of sound in air is about 340 m/s."@en ;
  dcterms:modified "2026-02-12T08:59:21.706674Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5051-2
  a curric:KeyLearningPoint ;
  rdfs:label """The speed of sound in air can be measured using an echo method and using speed = distance/time."""@en ;
  dcterms:modified "2026-02-12T08:59:21.706682Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5051-3
  a curric:KeyLearningPoint ;
  rdfs:label """The speed of sound in a metal rod can be found by measuring the length and the frequency produced when struck."""@en ;
  dcterms:modified "2026-02-12T08:59:21.706687Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5051-4
  a curric:KeyLearningPoint ;
  rdfs:label "A result is accurate if it is close to the true value."@en ;
  dcterms:modified "2026-02-12T08:59:21.706691Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5051-5
  a curric:KeyLearningPoint ;
  rdfs:label """A result can be considered accurate if it is repeatable, reproducible and if systematic errors have been checked for."""@en ;
  dcterms:modified "2026-02-12T08:59:21.706695Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6610-1
  a curric:KeyLearningPoint ;
  rdfs:label """When there is an electric current in a wire, there is a magnetic field around the wire."""@en ;
  dcterms:modified "2026-02-12T08:59:21.706700Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6610-2
  a curric:KeyLearningPoint ;
  rdfs:label """An electromagnet is a magnet that can be turned on with an electric current, and turned off."""@en ;
  dcterms:modified "2026-02-12T08:59:21.706705Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6610-3
  a curric:KeyLearningPoint ;
  rdfs:label """The magnetic field of an electromagnet is similar to the field around a bar magnet."""@en ;
  dcterms:modified "2026-02-12T08:59:21.706712Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6610-4
  a curric:KeyLearningPoint ;
  rdfs:label """A soft iron core in an electromagnet becomes magnetised and adds to the strength of field when the electromagnet is on."""@en ;
  dcterms:modified "2026-02-12T08:59:21.706717Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6610-5
  a curric:KeyLearningPoint ;
  rdfs:label """When there is an electric current in a coil of wire, the magnetic field around each loop adds to make a stronger field."""@en ;
  dcterms:modified "2026-02-12T08:59:21.706721Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6604-1
  a curric:KeyLearningPoint ;
  rdfs:label """Energy transferred to increase the temperature of a substance by heating by a fixed amount is proportional to mass."""@en ;
  dcterms:modified "2026-02-12T08:59:21.706769Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6604-2
  a curric:KeyLearningPoint ;
  rdfs:label """Energy transferred to a substance by heating a fixed amount is proportional to the increase in temperature."""@en ;
  dcterms:modified "2026-02-12T08:59:21.706773Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6604-3
  a curric:KeyLearningPoint ;
  rdfs:label """Energy transferred to increase the temperature of a substance by heating is proportional to its specific heat capacity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.706778Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6604-4
  a curric:KeyLearningPoint ;
  rdfs:label """Specific heat capacity equals the energy transferred to/by 1 kg of a material when its temperature changes by 1ºC."""@en ;
  dcterms:modified "2026-02-12T08:59:21.706811Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6604-5
  a curric:KeyLearningPoint ;
  rdfs:label """Specific heat capacity, c, is measured in joules per kilogram per degree Celsius (J/kg ºC)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.706816Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6579-1
  a curric:KeyLearningPoint ;
  rdfs:label "A displacement–time graph shows how displacement changes with time."@en ;
  dcterms:modified "2026-02-12T08:59:21.707141Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6579-2
  a curric:KeyLearningPoint ;
  rdfs:label "A velocity–time graph shows how velocity changes with time."@en ;
  dcterms:modified "2026-02-12T08:59:21.707146Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6579-3
  a curric:KeyLearningPoint ;
  rdfs:label """Displacement–time and velocity–time graphs of the same motion have different shapes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707150Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6579-4
  a curric:KeyLearningPoint ;
  rdfs:label "Acceleration is equal to the gradient of a velocity–time graph."@en ;
  dcterms:modified "2026-02-12T08:59:21.707155Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6579-5
  a curric:KeyLearningPoint ;
  rdfs:label """A falling line shows deceleration (decreasing velocity) which is a negative acceleration."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707159Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5086-1
  a curric:KeyLearningPoint ;
  rdfs:label """At a boundary to a medium where the wave speed increases, waves are refracted away from the normal."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707198Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5086-2
  a curric:KeyLearningPoint ;
  rdfs:label """If the angle of incidence is too big (bigger than the critical angle) the waves will undergo total internal reflection."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707203Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5086-3
  a curric:KeyLearningPoint ;
  rdfs:label """The critical angle is the greatest angle of incidence before total internal reflection occurs."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707208Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5086-4
  a curric:KeyLearningPoint ;
  rdfs:label "For a glass–air boundary, the critical angle (c) is about 42°."@en ;
  dcterms:modified "2026-02-12T08:59:21.707216Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9896-1
  a curric:KeyLearningPoint ;
  rdfs:label "The velocity of an object is equal to the gradient of a displacement-time graph."@en ;
  dcterms:modified "2026-02-12T08:59:21.707737Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9896-2
  a curric:KeyLearningPoint ;
  rdfs:label "A direction in which velocity and displacement are measured needs to be chosen."@en ;
  dcterms:modified "2026-02-12T08:59:21.707741Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9896-3
  a curric:KeyLearningPoint ;
  rdfs:label """A negative gradient on a displacement-time graph (sloping downwards) represents velocity in the opposite direction."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707746Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9896-4
  a curric:KeyLearningPoint ;
  rdfs:label """A negative value for displacement represents a position ‘behind’ the starting position."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707750Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4728-1
  a curric:KeyLearningPoint ;
  rdfs:label "Velocity of an object is its speed in a given direction."@en ;
  dcterms:modified "2026-02-12T08:59:21.707876Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4728-2
  a curric:KeyLearningPoint ;
  rdfs:label "Displacement is distance in a particular direction."@en ;
  dcterms:modified "2026-02-12T08:59:21.707880Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4728-3
  a curric:KeyLearningPoint ;
  rdfs:label "Displacement and velocity are vectors."@en ;
  dcterms:modified "2026-02-12T08:59:21.707885Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4728-4
  a curric:KeyLearningPoint ;
  rdfs:label "Velocity is positive in one direction and negative in the opposite direction."@en ;
  dcterms:modified "2026-02-12T08:59:21.707890Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4728-5
  a curric:KeyLearningPoint ;
  rdfs:label "Movement around a circle at a steady speed involves a changing velocity."@en ;
  dcterms:modified "2026-02-12T08:59:21.707894Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27966-1
  a curric:KeyLearningPoint ;
  rdfs:label """The amount (or activity) of a radioactive isotope repeatedly falls by half in equal amounts of time."""@en ;
  dcterms:modified "2026-02-12T08:59:21.708416Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27966-2
  a curric:KeyLearningPoint ;
  rdfs:label """A radioactive half-life graph shows the amount (or activity) of a radioactive isotope plotted against time."""@en ;
  dcterms:modified "2026-02-12T08:59:21.708421Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27966-3
  a curric:KeyLearningPoint ;
  rdfs:label """In 2 half-lives the amount (or activity) of a radioactive isotope falls to ½ × ½ = ¼ as much."""@en ;
  dcterms:modified "2026-02-12T08:59:21.708425Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27966-4
  a curric:KeyLearningPoint ;
  rdfs:label """In 3 half-lives the amount (or activity) of a radioactive isotope falls to ½ × ½ × ½ = 1/8 as much, and so on."""@en ;
  dcterms:modified "2026-02-12T08:59:21.708430Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27966-5
  a curric:KeyLearningPoint ;
  rdfs:label """Radioactive isotopes with short half-lives decay quickly, emitting most radiation over a short period of time."""@en ;
  dcterms:modified "2026-02-12T08:59:21.708435Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4925-1
  a curric:KeyLearningPoint ;
  rdfs:label """A joulemeter measures a total amount of energy transferred to an electric circuit."""@en ;
  dcterms:modified "2026-02-12T08:59:21.708439Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4925-2
  a curric:KeyLearningPoint ;
  rdfs:label """At equilibrium, a metal block is at the same temperature as the water bath it is in."""@en ;
  dcterms:modified "2026-02-12T08:59:21.708444Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4925-3
  a curric:KeyLearningPoint ;
  rdfs:label """Specific heat capacity, c, is measured in joules per kilogram per degree Celsius."""@en ;
  dcterms:modified "2026-02-12T08:59:21.708448Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6585-1
  a curric:KeyLearningPoint ;
  rdfs:label "In a fair test, only the (independent) variable being investigated is changed"@en ;
  dcterms:modified "2026-02-12T08:59:21.708456Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6585-2
  a curric:KeyLearningPoint ;
  rdfs:label """The dependent variable is measured to investigate the effect of changing the independent variable"""@en ;
  dcterms:modified "2026-02-12T08:59:21.708461Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6585-3
  a curric:KeyLearningPoint ;
  rdfs:label """Control variables are other factors that could be changed, but are kept the same in order not to affect the results"""@en ;
  dcterms:modified "2026-02-12T08:59:21.708465Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6585-4
  a curric:KeyLearningPoint ;
  rdfs:label """The greater the intensity of black ink, the more easily a surface absorbs infrared"""@en ;
  dcterms:modified "2026-02-12T08:59:21.708470Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4936-1
  a curric:KeyLearningPoint ;
  rdfs:label """The Sun is a medium sized star that emits radiation as a result of nuclear fusion reactions in its core."""@en ;
  dcterms:modified "2026-02-12T08:59:21.708474Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4936-2
  a curric:KeyLearningPoint ;
  rdfs:label """A star is formed from a cloud (nebula) of dust and gas pulled together by gravitational attraction."""@en ;
  dcterms:modified "2026-02-12T08:59:21.708479Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4936-3
  a curric:KeyLearningPoint ;
  rdfs:label """Dust in a nebula is any sort of fine particle, such as specks of rock, and most of the gas in space is hydrogen."""@en ;
  dcterms:modified "2026-02-12T08:59:21.708483Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4936-4
  a curric:KeyLearningPoint ;
  rdfs:label """As a star forms, dust and gas accelerate towards its centre over a very long time, creating very high temperatures."""@en ;
  dcterms:modified "2026-02-12T08:59:21.708488Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4936-5
  a curric:KeyLearningPoint ;
  rdfs:label """A star forms when hydrogen nuclei in a protostar fuse together converting mass into gamma radiation that causes heating."""@en ;
  dcterms:modified "2026-02-12T08:59:21.708492Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9933-1
  a curric:KeyLearningPoint ;
  rdfs:label "When an object moves upwards, work is done against the gravitational force."@en ;
  dcterms:modified "2026-02-12T08:59:21.708566Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9933-2
  a curric:KeyLearningPoint ;
  rdfs:label """The gravitational force acting on an object does work to speed it up when it is falling."""@en ;
  dcterms:modified "2026-02-12T08:59:21.708570Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9933-3
  a curric:KeyLearningPoint ;
  rdfs:label "Weight = mass x gravitational field strength, W = mg"@en ;
  dcterms:modified "2026-02-12T08:59:21.708575Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9933-4
  a curric:KeyLearningPoint ;
  rdfs:label """Gravitational potential energy of an object = mass × gravitational field strength × height"""@en ;
  dcterms:modified "2026-02-12T08:59:21.708580Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28014-1
  a curric:KeyLearningPoint ;
  rdfs:label """A potential difference that causes a current to flow in the primary coil magnetises the iron core."""@en ;
  dcterms:modified "2026-02-12T08:59:21.709625Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28014-2
  a curric:KeyLearningPoint ;
  rdfs:label """When the iron core is magnetised, it induces a potential difference across the secondary coil."""@en ;
  dcterms:modified "2026-02-12T08:59:21.709629Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28014-3
  a curric:KeyLearningPoint ;
  rdfs:label """An AC gives the changing magnetic field needed to induce a potential difference across the secondary coil."""@en ;
  dcterms:modified "2026-02-12T08:59:21.709636Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28014-4
  a curric:KeyLearningPoint ;
  rdfs:label """Transformers are almost 100% efficient so the power output is equal to the power input."""@en ;
  dcterms:modified "2026-02-12T08:59:21.709641Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28014-5
  a curric:KeyLearningPoint ;
  rdfs:label """The ratio of the number of turns on the coils is equal to the ratio of the potential differences across them."""@en ;
  dcterms:modified "2026-02-12T08:59:21.709648Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27962-1
  a curric:KeyLearningPoint ;
  rdfs:label "The products and by–products of nuclear fission are often radioactive."@en ;
  dcterms:modified "2026-02-12T08:59:21.709652Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27962-2
  a curric:KeyLearningPoint ;
  rdfs:label """The products and by–products of nuclear fission need to be safely stored for very long periods of time."""@en ;
  dcterms:modified "2026-02-12T08:59:21.709657Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27962-3
  a curric:KeyLearningPoint ;
  rdfs:label """Nuclear reactors do not emit carbon dioxide and risks of catastrophic failure are very small."""@en ;
  dcterms:modified "2026-02-12T08:59:21.709662Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27962-4
  a curric:KeyLearningPoint ;
  rdfs:label """Nuclear fusion requires extremely high temperatures such as those found in the centre of stars."""@en ;
  dcterms:modified "2026-02-12T08:59:21.709666Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27962-5
  a curric:KeyLearningPoint ;
  rdfs:label """Nuclear fusion power stations would create very little radioactive waste, but have not yet been developed."""@en ;
  dcterms:modified "2026-02-12T08:59:21.709671Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9926-1
  a curric:KeyLearningPoint ;
  rdfs:label """Energy is dissipated due to friction which causes particles to vibrate more quickly and heats up the surroundings."""@en ;
  dcterms:modified "2026-02-12T08:59:21.709839Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9926-2
  a curric:KeyLearningPoint ;
  rdfs:label """Energy is dissipated due to drag which causes particles in the surroundings to move more quickly."""@en ;
  dcterms:modified "2026-02-12T08:59:21.709843Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9926-3
  a curric:KeyLearningPoint ;
  rdfs:label """Efficiency = (useful energy transferred by the device)/(total energy supplied to the device)"""@en ;
  dcterms:modified "2026-02-12T08:59:21.709848Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9926-4
  a curric:KeyLearningPoint ;
  rdfs:label "Efficiency can be increased by lubrication, bearings or wheels."@en ;
  dcterms:modified "2026-02-12T08:59:21.709852Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5094-1
  a curric:KeyLearningPoint ;
  rdfs:label """Mains electricity has a p.d. of 230 V between a live wire connection (230 V) and a neutral wire connection (0 V)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.709857Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5094-2
  a curric:KeyLearningPoint ;
  rdfs:label "Mains electricity has alternating current at a frequency of 50 Hz."@en ;
  dcterms:modified "2026-02-12T08:59:21.709862Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5094-3
  a curric:KeyLearningPoint ;
  rdfs:label """Electric current passing through a person’s body can damage living tissue and/or stop their heart pumping blood."""@en ;
  dcterms:modified "2026-02-12T08:59:21.709866Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5094-4
  a curric:KeyLearningPoint ;
  rdfs:label """The size of current from a shock depends on the p.d. across the person and the resistance of their skin (I = V ÷ R)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.709871Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5094-5
  a curric:KeyLearningPoint ;
  rdfs:label """Wet skin has a much lower resistance than dry skin, and a smaller p.d. can cause a bigger current from a shock."""@en ;
  dcterms:modified "2026-02-12T08:59:21.709875Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9906-1
  a curric:KeyLearningPoint ;
  rdfs:label "A displacement–time graph shows how displacement changes with time."@en ;
  dcterms:modified "2026-02-12T08:59:21.709968Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9906-2
  a curric:KeyLearningPoint ;
  rdfs:label "A velocity–time graph shows how velocity changes with time."@en ;
  dcterms:modified "2026-02-12T08:59:21.709972Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9906-3
  a curric:KeyLearningPoint ;
  rdfs:label """Displacement–time and velocity–time graphs of the same motion have different shapes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.709977Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9923-1
  a curric:KeyLearningPoint ;
  rdfs:label "Power is equal to the rate at which work is done."@en ;
  dcterms:modified "2026-02-12T08:59:21.710104Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9923-2
  a curric:KeyLearningPoint ;
  rdfs:label "Power is equal to the rate at which energy is transferred."@en ;
  dcterms:modified "2026-02-12T08:59:21.710109Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9923-3
  a curric:KeyLearningPoint ;
  rdfs:label "Power = work done ÷ time."@en ;
  dcterms:modified "2026-02-12T08:59:21.710113Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9923-4
  a curric:KeyLearningPoint ;
  rdfs:label "Power is measured in watts (W)."@en ;
  dcterms:modified "2026-02-12T08:59:21.710121Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4904-1
  a curric:KeyLearningPoint ;
  rdfs:label "Energy is measured in joules (J)."@en ;
  dcterms:modified "2026-02-12T08:59:21.711690Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4904-2
  a curric:KeyLearningPoint ;
  rdfs:label """Doubling the mass of a moving object doubles the energy it has in its kinetic store."""@en ;
  dcterms:modified "2026-02-12T08:59:21.711694Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4904-3
  a curric:KeyLearningPoint ;
  rdfs:label """Doubling the speed of an object increases the energy it has in its kinetic store by four times."""@en ;
  dcterms:modified "2026-02-12T08:59:21.711698Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4904-4
  a curric:KeyLearningPoint ;
  rdfs:label """The energy an object has in its kinetic store of energy is found using the equation Ek = ½ mv²."""@en ;
  dcterms:modified "2026-02-12T08:59:21.711703Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9932-1
  a curric:KeyLearningPoint ;
  rdfs:label "When an object moves upwards, work is done against the gravitational force."@en ;
  dcterms:modified "2026-02-12T08:59:21.711708Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9932-2
  a curric:KeyLearningPoint ;
  rdfs:label """The gravitational force acting on an object does work to speed it up when it is falling."""@en ;
  dcterms:modified "2026-02-12T08:59:21.711712Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9932-3
  a curric:KeyLearningPoint ;
  rdfs:label "Weight = mass x gravitational field strength, W = mg"@en ;
  dcterms:modified "2026-02-12T08:59:21.711717Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9932-4
  a curric:KeyLearningPoint ;
  rdfs:label """Change in gravitational potential energy of an object = mass × gravitational field strength × change in height"""@en ;
  dcterms:modified "2026-02-12T08:59:21.711724Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9920-1
  a curric:KeyLearningPoint ;
  rdfs:label "Work done is the total amount of energy transferred."@en ;
  dcterms:modified "2026-02-12T08:59:21.713024Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9920-2
  a curric:KeyLearningPoint ;
  rdfs:label "Work done = force x distance (moved in the direction of the force)."@en ;
  dcterms:modified "2026-02-12T08:59:21.713028Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9920-3
  a curric:KeyLearningPoint ;
  rdfs:label "Work done is measured in Joule (J)."@en ;
  dcterms:modified "2026-02-12T08:59:21.713035Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4924-1
  a curric:KeyLearningPoint ;
  rdfs:label """Energy transferred to increase the temperature of a substance by heating by a fixed amount is proportional to mass."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713040Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4924-2
  a curric:KeyLearningPoint ;
  rdfs:label """Energy transferred to a substance by heating a fixed amount is proportional to the increase in temperature."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713045Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4924-3
  a curric:KeyLearningPoint ;
  rdfs:label """Energy transferred to increase the temperature of a substance by heating is proportional to its specific heat capacity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713051Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4924-4
  a curric:KeyLearningPoint ;
  rdfs:label """Specific heat capacity equals the energy transferred to or by 1 kg of a material when its temperature changes by 1ºC."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713056Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4924-5
  a curric:KeyLearningPoint ;
  rdfs:label """Specific heat capacity, c, is measured in joules per kilogram per degree Celsius (J/kg ºC)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713061Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9891-1
  a curric:KeyLearningPoint ;
  rdfs:label """A dynamics trolley speeds up (accelerates) along the whole length of a steep ramp."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713065Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9891-2
  a curric:KeyLearningPoint ;
  rdfs:label "Instantaneous speed is the average speed over a very short time period."@en ;
  dcterms:modified "2026-02-12T08:59:21.713070Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9891-3
  a curric:KeyLearningPoint ;
  rdfs:label "Instantaneous speed is the average speed over a very short time period."@en ;
  dcterms:modified "2026-02-12T08:59:21.713074Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9891-4
  a curric:KeyLearningPoint ;
  rdfs:label "Repeated readings by different observers helps to check for systematic errors."@en ;
  dcterms:modified "2026-02-12T08:59:21.713079Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9138-1
  a curric:KeyLearningPoint ;
  rdfs:label """Acceleration can be measured accurately using light gates or roughly measured using a stopwatch and ruler."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713084Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9138-2
  a curric:KeyLearningPoint ;
  rdfs:label """The acceleration of an object is proportional to the resultant force acting on the object."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713088Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9138-3
  a curric:KeyLearningPoint ;
  rdfs:label """The acceleration of an object is inversely proportional to the mass of the object."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713093Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9138-4
  a curric:KeyLearningPoint ;
  rdfs:label "Newton's Second Law states that F = m × a."@en ;
  dcterms:modified "2026-02-12T08:59:21.713098Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4937-1
  a curric:KeyLearningPoint ;
  rdfs:label "Radiation pressure from nuclear fusion pushes out from the centre of a star."@en ;
  dcterms:modified "2026-02-12T08:59:21.714189Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4937-2
  a curric:KeyLearningPoint ;
  rdfs:label "Gravitational force pulls in towards the centre of a star."@en ;
  dcterms:modified "2026-02-12T08:59:21.714193Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4937-3
  a curric:KeyLearningPoint ;
  rdfs:label """When a star is in balance, forces from radiation pressure are equal in size to gravitational forces."""@en ;
  dcterms:modified "2026-02-12T08:59:21.714198Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4937-4
  a curric:KeyLearningPoint ;
  rdfs:label """A main sequence star is a star in balance for millions of years, until it no can longer fuse hydrogen nuclei."""@en ;
  dcterms:modified "2026-02-12T08:59:21.714203Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4937-5
  a curric:KeyLearningPoint ;
  rdfs:label """After all available hydrogen has been fused, gravity contracts a star raising temperature until other nuclei can fuse."""@en ;
  dcterms:modified "2026-02-12T08:59:21.714207Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20341-1
  a curric:KeyLearningPoint ;
  rdfs:label "A dynamics trolley has a steady acceleration down a steep ramp."@en ;
  dcterms:modified "2026-02-12T08:59:21.714258Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20341-2
  a curric:KeyLearningPoint ;
  rdfs:label """Acceleration = change of velocity / time and change in velocity = final velocity - initial velocity"""@en ;
  dcterms:modified "2026-02-12T08:59:21.714263Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20341-3
  a curric:KeyLearningPoint ;
  rdfs:label """Light gates can improve accuracy of measurement of instantaneous velocity and reduces random errors."""@en ;
  dcterms:modified "2026-02-12T08:59:21.714268Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20341-4
  a curric:KeyLearningPoint ;
  rdfs:label """Using video recording will allow for accurate measurement of small time intervals."""@en ;
  dcterms:modified "2026-02-12T08:59:21.714273Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9116-1
  a curric:KeyLearningPoint ;
  rdfs:label "When an object moves upwards, work is done against the gravitational force."@en ;
  dcterms:modified "2026-02-12T08:59:21.715996Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9116-2
  a curric:KeyLearningPoint ;
  rdfs:label """The gravitational force acting on an object does work to speed it up when it is falling."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716003Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9116-3
  a curric:KeyLearningPoint ;
  rdfs:label "Weight = mass x gravitational field strength, W = mg"@en ;
  dcterms:modified "2026-02-12T08:59:21.716010Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9116-4
  a curric:KeyLearningPoint ;
  rdfs:label """Gravitational potential energy of an object = mass × gravitational field strength × height"""@en ;
  dcterms:modified "2026-02-12T08:59:21.716015Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5090-1
  a curric:KeyLearningPoint ;
  rdfs:label """In cameras and the human eye, the required image distance < the object distance. The image is diminished and inverted."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716165Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5090-2
  a curric:KeyLearningPoint ;
  rdfs:label """In projectors, the required image distance > the object distance. The image is magnified and inverted."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716170Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5090-3
  a curric:KeyLearningPoint ;
  rdfs:label """A ray incident on a converging lens parallel to the principal axis is refracted to pass through principal focus."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716174Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5090-4
  a curric:KeyLearningPoint ;
  rdfs:label "A ray incident on the centre of a converging lens is not refracted."@en ;
  dcterms:modified "2026-02-12T08:59:21.716179Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5090-5
  a curric:KeyLearningPoint ;
  rdfs:label """A ray incident on a converging lens from the principal focus is refracted so it becomes parallel to the principal axis."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716186Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9928-1
  a curric:KeyLearningPoint ;
  rdfs:label "Energy is measured in joules (J)."@en ;
  dcterms:modified "2026-02-12T08:59:21.716372Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9928-2
  a curric:KeyLearningPoint ;
  rdfs:label """Doubling the mass of a moving object doubles the energy it has in its kinetic store."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716377Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9928-3
  a curric:KeyLearningPoint ;
  rdfs:label """Doubling the speed of an object increases the energy it has in its kinetic store by four times."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716381Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9928-4
  a curric:KeyLearningPoint ;
  rdfs:label """The energy an object has in its kinetic store of energy is found using the equation E = ½ mv²."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716386Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9908-1
  a curric:KeyLearningPoint ;
  rdfs:label "Acceleration is equal to the gradient of a velocity-time graph."@en ;
  dcterms:modified "2026-02-12T08:59:21.716529Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9908-2
  a curric:KeyLearningPoint ;
  rdfs:label """A falling line shows decreasing velocity called deceleration, which is a negative acceleration."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716534Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9908-3
  a curric:KeyLearningPoint ;
  rdfs:label """Instantaneous speed at a point on a displacement-time graph equals the gradient of a tangent at that point."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716538Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9908-4
  a curric:KeyLearningPoint ;
  rdfs:label "The distance travelled is equal to the area under a velocity-time graph."@en ;
  dcterms:modified "2026-02-12T08:59:21.716543Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9908-5
  a curric:KeyLearningPoint ;
  rdfs:label "Displacement is equal to the net positive area under a velocity-time graph."@en ;
  dcterms:modified "2026-02-12T08:59:21.716547Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9892-1
  a curric:KeyLearningPoint ;
  rdfs:label "The velocity of an object is its speed in a given direction."@en ;
  dcterms:modified "2026-02-12T08:59:21.716593Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9892-2
  a curric:KeyLearningPoint ;
  rdfs:label """The displacement of an object is the distance it travels in a particular direction."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716597Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9892-3
  a curric:KeyLearningPoint ;
  rdfs:label "Displacement and velocity are both vector quantities."@en ;
  dcterms:modified "2026-02-12T08:59:21.716602Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9892-4
  a curric:KeyLearningPoint ;
  rdfs:label """Velocity has a positive value in one direction and negative value in the opposite direction."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716606Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9892-5
  a curric:KeyLearningPoint ;
  rdfs:label """Motion in a circle involves a centripetal force which constantly changes the velocity of an object."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716613Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9893-1
  a curric:KeyLearningPoint ;
  rdfs:label "The velocity of an object is equal to the gradient of a displacement-time graph."@en ;
  dcterms:modified "2026-02-12T08:59:21.716705Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9893-2
  a curric:KeyLearningPoint ;
  rdfs:label "A direction in which velocity and displacement are measured needs to be chosen."@en ;
  dcterms:modified "2026-02-12T08:59:21.716709Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9893-3
  a curric:KeyLearningPoint ;
  rdfs:label """A negative gradient on a displacement-time graph (sloping downwards) represents velocity in the opposite direction."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716714Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9893-4
  a curric:KeyLearningPoint ;
  rdfs:label """A negative value for displacement represents a position ‘behind’ the starting position."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716718Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9907-1
  a curric:KeyLearningPoint ;
  rdfs:label "Acceleration is equal to the gradient of a velocity-time graph."@en ;
  dcterms:modified "2026-02-12T08:59:21.716725Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9907-2
  a curric:KeyLearningPoint ;
  rdfs:label """A falling line shows decreasing velocity called deceleration, which is a negative acceleration."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716730Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9907-3
  a curric:KeyLearningPoint ;
  rdfs:label """Instantaneous speed at a point on a displacement-time graph equals the gradient of a tangent at that point."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716734Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9907-4
  a curric:KeyLearningPoint ;
  rdfs:label "The distance travelled is equal to the area under a velocity-time graph."@en ;
  dcterms:modified "2026-02-12T08:59:21.716739Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9907-5
  a curric:KeyLearningPoint ;
  rdfs:label "Displacement is equal to the net positive area under a velocity-time graph."@en ;
  dcterms:modified "2026-02-12T08:59:21.716743Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5096-1
  a curric:KeyLearningPoint ;
  rdfs:label """Power is transferred by electricity from power stations to consumers using the National Grid."""@en ;
  dcterms:modified "2026-02-12T08:59:21.717552Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5096-2
  a curric:KeyLearningPoint ;
  rdfs:label """Step-up transformers increase the transmission voltage from a power station to the transmission line."""@en ;
  dcterms:modified "2026-02-12T08:59:21.717556Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5096-3
  a curric:KeyLearningPoint ;
  rdfs:label """Step-down transformers decrease the transmission voltage from a transmission line to the consumer."""@en ;
  dcterms:modified "2026-02-12T08:59:21.717560Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5096-4
  a curric:KeyLearningPoint ;
  rdfs:label "Transmission lines dissipate some energy by heating (P = I²R)."@en ;
  dcterms:modified "2026-02-12T08:59:21.717567Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5096-5
  a curric:KeyLearningPoint ;
  rdfs:label """A very high transmission voltage reduces transmission current and the heating of transmission lines."""@en ;
  dcterms:modified "2026-02-12T08:59:21.717572Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28182-1
  a curric:KeyLearningPoint ;
  rdfs:label """Light from nearly all galaxies is redshifted, showing they're moving away, with distant galaxies receding faster."""@en ;
  dcterms:modified "2026-02-12T08:59:21.717594Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28182-2
  a curric:KeyLearningPoint ;
  rdfs:label """Evidence shows that galaxies were all in the same place about 14 billion years ago, showing their movement apart since."""@en ;
  dcterms:modified "2026-02-12T08:59:21.717598Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28182-3
  a curric:KeyLearningPoint ;
  rdfs:label """The Big Bang Theory suggests that the universe began from a very small region that was extremely hot and dense."""@en ;
  dcterms:modified "2026-02-12T08:59:21.717603Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28182-4
  a curric:KeyLearningPoint ;
  rdfs:label """A scientific theory is our best understanding based on all evidence and is subject to rigorous testing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.717607Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28182-5
  a curric:KeyLearningPoint ;
  rdfs:label "We do not fully understand dark matter or dark energy."@en ;
  dcterms:modified "2026-02-12T08:59:21.717612Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9909-1
  a curric:KeyLearningPoint ;
  rdfs:label "Average velocity = distance travelled ÷ time"@en ;
  dcterms:modified "2026-02-12T08:59:21.719214Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9909-2
  a curric:KeyLearningPoint ;
  rdfs:label "Average acceleration = change in velocity ÷ time"@en ;
  dcterms:modified "2026-02-12T08:59:21.719218Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9909-3
  a curric:KeyLearningPoint ;
  rdfs:label "Average velocity = (initial velocity + final velocity) ÷ 2"@en ;
  dcterms:modified "2026-02-12T08:59:21.719225Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9909-4
  a curric:KeyLearningPoint ;
  rdfs:label """Combining equations for average acceleration and average velocity leads to the equation v² – u² = 2ax"""@en ;
  dcterms:modified "2026-02-12T08:59:21.719230Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9909-5
  a curric:KeyLearningPoint ;
  rdfs:label """Different motion equations can be used to analyse motion based on information provided."""@en ;
  dcterms:modified "2026-02-12T08:59:21.719235Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27965-1
  a curric:KeyLearningPoint ;
  rdfs:label "Radioactive decay is a random process."@en ;
  dcterms:modified "2026-02-12T08:59:21.719239Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27965-2
  a curric:KeyLearningPoint ;
  rdfs:label """It is impossible to predict the moment that a particular unstable nucleus will decay."""@en ;
  dcterms:modified "2026-02-12T08:59:21.719243Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27965-3
  a curric:KeyLearningPoint ;
  rdfs:label """It is possible to predict how long it will take for half of a sample of a radioactive isotope to decay."""@en ;
  dcterms:modified "2026-02-12T08:59:21.719248Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27965-4
  a curric:KeyLearningPoint ;
  rdfs:label """Radioactive half-life is the time taken for half of a radioactive isotope to decay (or for its activity to halve)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.719252Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27965-5
  a curric:KeyLearningPoint ;
  rdfs:label "Each radioactive isotope has its own half-life that is always the same."@en ;
  dcterms:modified "2026-02-12T08:59:21.719256Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5122-1
  a curric:KeyLearningPoint ;
  rdfs:label """Radioactive particles can emit radiation in the form of particles or gamma radiation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.719360Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5122-2
  a curric:KeyLearningPoint ;
  rdfs:label """Ionising radiation forces electrons from atoms, leaving an atom with a positive charge called an ion."""@en ;
  dcterms:modified "2026-02-12T08:59:21.719364Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5122-3
  a curric:KeyLearningPoint ;
  rdfs:label """Alpha particles are more ionising than beta or gamma because they have a bigger charge and stronger electric field."""@en ;
  dcterms:modified "2026-02-12T08:59:21.719369Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20344-1
  a curric:KeyLearningPoint ;
  rdfs:label """All bodies (objects) of all temperatures emit and absorb infrared radiation. Hotter bodies emit more IR in a set time."""@en ;
  dcterms:modified "2026-02-12T08:59:21.719658Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20344-2
  a curric:KeyLearningPoint ;
  rdfs:label """The range of wavelengths emitted, and their intensities, depend on an object’s temperature."""@en ;
  dcterms:modified "2026-02-12T08:59:21.719663Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20344-3
  a curric:KeyLearningPoint ;
  rdfs:label """Good absorbers (e.g. dark and dull surfaces) are also good emitters. Shiny metal surfaces are poor absorbers/emitters."""@en ;
  dcterms:modified "2026-02-12T08:59:21.719667Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20344-4
  a curric:KeyLearningPoint ;
  rdfs:label """A black body is a theoretical object that absorbs all of the radiation that falls on it."""@en ;
  dcterms:modified "2026-02-12T08:59:21.719672Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20344-5
  a curric:KeyLearningPoint ;
  rdfs:label """The temperature of a body depends on the rates at which radiation is absorbed and emitted."""@en ;
  dcterms:modified "2026-02-12T08:59:21.719676Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9900-1
  a curric:KeyLearningPoint ;
  rdfs:label "Acceleration is equal to the amount that velocity changes in one second."@en ;
  dcterms:modified "2026-02-12T08:59:21.720653Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9900-2
  a curric:KeyLearningPoint ;
  rdfs:label "Acceleration is the rate of change of velocity."@en ;
  dcterms:modified "2026-02-12T08:59:21.720658Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9900-3
  a curric:KeyLearningPoint ;
  rdfs:label "Average acceleration = change of velocity/time [a = (v-u)/t]"@en ;
  dcterms:modified "2026-02-12T08:59:21.720662Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9900-4
  a curric:KeyLearningPoint ;
  rdfs:label "An object that is slowing down is decelerating."@en ;
  dcterms:modified "2026-02-12T08:59:21.720666Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9900-5
  a curric:KeyLearningPoint ;
  rdfs:label "An object that is decelerating has a negative acceleration."@en ;
  dcterms:modified "2026-02-12T08:59:21.720673Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8155-1
  a curric:KeyLearningPoint ;
  rdfs:label "Density is calculated using the equation: density = mass ÷ volume."@en ;
  dcterms:modified "2026-02-12T08:59:21.720880Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8155-2
  a curric:KeyLearningPoint ;
  rdfs:label """The volume of water displaced by a submerged object is equal to the volume of the object."""@en ;
  dcterms:modified "2026-02-12T08:59:21.720887Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8155-3
  a curric:KeyLearningPoint ;
  rdfs:label """The dimensions of a regular cuboid can be measured accurately with Vernier callipers."""@en ;
  dcterms:modified "2026-02-12T08:59:21.720891Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8155-4
  a curric:KeyLearningPoint ;
  rdfs:label """The volume of a regular cuboid is calculated using the equation: volume = length × width × height."""@en ;
  dcterms:modified "2026-02-12T08:59:21.720896Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4730-1
  a curric:KeyLearningPoint ;
  rdfs:label "Acceleration is equal to the amount that velocity changes in one second."@en ;
  dcterms:modified "2026-02-12T08:59:21.722139Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4730-2
  a curric:KeyLearningPoint ;
  rdfs:label "Acceleration is the rate of change of velocity."@en ;
  dcterms:modified "2026-02-12T08:59:21.722144Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4730-3
  a curric:KeyLearningPoint ;
  rdfs:label "Average acceleration = change of velocity / time (a = Δv/t)"@en ;
  dcterms:modified "2026-02-12T08:59:21.722148Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4730-4
  a curric:KeyLearningPoint ;
  rdfs:label "An object that is slowing down is decelerating."@en ;
  dcterms:modified "2026-02-12T08:59:21.722153Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4730-5
  a curric:KeyLearningPoint ;
  rdfs:label "An object that is decelerating has a negative acceleration."@en ;
  dcterms:modified "2026-02-12T08:59:21.722157Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9124-1
  a curric:KeyLearningPoint ;
  rdfs:label """Energy transferred to a solid at its melting point allows its particles to move further apart."""@en ;
  dcterms:modified "2026-02-12T08:59:21.722162Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9124-2
  a curric:KeyLearningPoint ;
  rdfs:label """Energy transferred to a liquid at its boiling point allows its particles to move fast enough to get even further apart."""@en ;
  dcterms:modified "2026-02-12T08:59:21.722166Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9124-3
  a curric:KeyLearningPoint ;
  rdfs:label """The energy transferred to melt a solid at its melting point is proportional to the mass of the solid."""@en ;
  dcterms:modified "2026-02-12T08:59:21.722170Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9124-4
  a curric:KeyLearningPoint ;
  rdfs:label """The energy transferred to melt 1 kg of a solid at its melting point is proportional to the solid’s specific latent heat."""@en ;
  dcterms:modified "2026-02-12T08:59:21.722175Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9124-5
  a curric:KeyLearningPoint ;
  rdfs:label """The energy transferred to boil 1 kg of a liquid at its boiling point is proportional to its specific latent heat."""@en ;
  dcterms:modified "2026-02-12T08:59:21.722179Z"^^xsd:dateTime .

