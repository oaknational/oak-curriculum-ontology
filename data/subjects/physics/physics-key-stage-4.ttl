  dcterms:modified "2026-02-12T08:59:15.823296Z"^^xsd:dateTime .

oakcurric:keyword-transmission-line
  a curric:Keyword ;
  schema:name "transmission line"@en ;
  schema:description "a high voltage cable often seen between electricity pylons"@en ;
  dcterms:modified "2026-02-12T08:59:15.823514Z"^^xsd:dateTime .

oakcurric:keyword-step-up-transformer
  a curric:Keyword ;
  schema:name "step-up transformer"@en ;
  schema:description "a device that can change lower alternating voltages to higher ones"@en ;
  dcterms:modified "2026-02-12T08:59:15.823518Z"^^xsd:dateTime .

oakcurric:keyword-step-down-transformer
  a curric:Keyword ;
  schema:name "step-down transformer"@en ;
  schema:description "a device that can change higher alternating voltages to lower ones"@en ;
  dcterms:modified "2026-02-12T08:59:15.823522Z"^^xsd:dateTime .

oakcurric:keyword-dissipation
  a curric:Keyword ;
  schema:name "dissipation"@en ;
  schema:description "the transfer of energy into the surroundings by heating"@en ;
  dcterms:modified "2026-02-12T08:59:15.823526Z"^^xsd:dateTime .

oakcurric:keyword-big-bang-theory
  a curric:Keyword ;
