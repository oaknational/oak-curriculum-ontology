  dcterms:modified "2026-02-12T08:59:15.821475Z"^^xsd:dateTime .

oakcurric:keyword-protostar
  a curric:Keyword ;
  schema:name "protostar"@en ;
  schema:description "a dense, hot, ball of gas formed by a collapsed nebula"@en ;
  dcterms:modified "2026-02-12T08:59:15.821482Z"^^xsd:dateTime .

oakcurric:keyword-main-sequence-star
  a curric:Keyword ;
  schema:name "main sequence star"@en ;
  schema:description "the stable period of a star when it is fusing hydrogen in its core"@en ;
  dcterms:modified "2026-02-12T08:59:15.821486Z"^^xsd:dateTime .

oakcurric:keyword-primary-coil
  a curric:Keyword ;
  schema:name "primary coil"@en ;
  schema:description """a coil of insulated wire in a transformer, across which potential difference is applied"""@en ;
  dcterms:modified "2026-02-12T08:59:15.821702Z"^^xsd:dateTime .

oakcurric:keyword-secondary-coil
  a curric:Keyword ;
  schema:name "secondary coil"@en ;
  schema:description """a coil of insulated wire in a transformer, across which potential difference is induced"""@en ;
  dcterms:modified "2026-02-12T08:59:15.821706Z"^^xsd:dateTime .

oakcurric:keyword-soft-iron-core
  a curric:Keyword ;
