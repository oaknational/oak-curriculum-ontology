  dcterms:modified "2026-02-12T08:59:15.810583Z"^^xsd:dateTime .

oakcurric:keyword-range
  a curric:Keyword ;
  schema:name "Range"@en ;
  schema:description """The range is a measure of spread. It is found by finding the difference between the highest and lowest values."""@en ;
  dcterms:modified "2026-02-12T08:59:15.810625Z"^^xsd:dateTime .

oakcurric:keyword-control-variable
  a curric:Keyword ;
  schema:name "control variable"@en ;
  schema:description "a factor that is kept the same during an experiment"@en ;
  dcterms:modified "2026-02-12T08:59:15.810854Z"^^xsd:dateTime .

oakcurric:keyword-filament-lamp
  a curric:Keyword ;
  schema:name "filament lamp"@en ;
