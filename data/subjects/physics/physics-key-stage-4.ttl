  dcterms:modified "2026-02-12T08:59:15.823823Z"^^xsd:dateTime .

oakcurric:keyword-emit
  a curric:Keyword ;
  schema:name "emit"@en ;
  schema:description "To emit infrared radiation is to give out infrared radiation."@en ;
  dcterms:modified "2026-02-12T08:59:15.823880Z"^^xsd:dateTime .

oakcurric:keyword-leslie-cube
