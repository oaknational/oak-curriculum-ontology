  dcterms:modified "2026-02-12T08:59:15.810959Z"^^xsd:dateTime .

oakcurric:keyword-ohmic-conductor
  a curric:Keyword ;
  schema:name "ohmic conductor"@en ;
  schema:description "a conductor for which the current is directly proportional to the p.d."@en ;
  dcterms:modified "2026-02-12T08:59:15.810964Z"^^xsd:dateTime .

oakcurric:keyword-directly-proportional
  a curric:Keyword ;
  schema:name "directly proportional"@en ;
  schema:description "a relationship between variables in which one is a multiple of the other"@en ;
  dcterms:modified "2026-02-12T08:59:15.810968Z"^^xsd:dateTime .

oakcurric:keyword-metal-ion
  a curric:Keyword ;
  schema:name "metal ion"@en ;
  schema:description """a metal atom that has lost one or more outer electrons and has become positively charged"""@en ;
  dcterms:modified "2026-02-12T08:59:15.810973Z"^^xsd:dateTime .

oakcurric:keyword-free-electron
  a curric:Keyword ;
  schema:name "free electron"@en ;
  schema:description """an electron from the outer shell of an atom that is free to move from ion to ion through a metal"""@en ;
  dcterms:modified "2026-02-12T08:59:15.810977Z"^^xsd:dateTime .

oakcurric:keyword-series-circuit
  a curric:Keyword ;
  schema:name "series circuit"@en ;
  schema:description "an electrical circuit with a single loop"@en ;
  dcterms:modified "2026-02-12T08:59:15.810983Z"^^xsd:dateTime .

oakcurric:keyword-potential-difference-pd
  a curric:Keyword ;
  schema:name "potential difference (p.d.)"@en ;
  schema:description "a measure of the push an electric field gives to charges"@en ;
  dcterms:modified "2026-02-12T08:59:15.810988Z"^^xsd:dateTime .

oakcurric:keyword-potential-divider
  a curric:Keyword ;
  schema:name "potential divider"@en ;
  schema:description """a series circuit that divides the p.d. across a power supply into two or more smaller voltages"""@en ;
  dcterms:modified "2026-02-12T08:59:15.810992Z"^^xsd:dateTime .

oakcurric:keyword-dynamics-trolley
  a curric:Keyword ;
  schema:name "dynamics trolley"@en ;
  schema:description """A dynamics trolley is a wheeled device used in experiments to study motion, designed to move smoothly over flat surfaces."""@en ;
  dcterms:modified "2026-02-12T08:59:15.810996Z"^^xsd:dateTime .

oakcurric:keyword-average-speed
  a curric:Keyword ;
  schema:name "average speed"@en ;
  schema:description """The average speed of an object is the total distance travelled divided by the total time taken for a journey."""@en ;
  dcterms:modified "2026-02-12T08:59:15.811003Z"^^xsd:dateTime .

oakcurric:keyword-instantaneous-speed
  a curric:Keyword ;
  schema:name "instantaneous speed"@en ;
  schema:description "The instantaneous speed of an object is its speed at a specific moment in time."@en ;
  dcterms:modified "2026-02-12T08:59:15.811007Z"^^xsd:dateTime .

oakcurric:keyword-anomalous-reading
  a curric:Keyword ;
  schema:name "anomalous reading"@en ;
  schema:description """An anomalous reading is a result that is significantly outside the expected pattern in a set of results."""@en ;
  dcterms:modified "2026-02-12T08:59:15.811011Z"^^xsd:dateTime .

oakcurric:keyword-displacement-time-graph
  a curric:Keyword ;
  schema:name "displacement-time graph"@en ;
  schema:description """A displacement-time graph shows the change in displacement over a time period. The displacement along a straight line can be positive or negative."""@en ;
  dcterms:modified "2026-02-12T08:59:15.811016Z"^^xsd:dateTime .

oakcurric:keyword-gradient
  a curric:Keyword ;
  schema:name "gradient"@en ;
  schema:description "The gradient on a displacement-time graph gives the instantaneous velocity."@en ;
  dcterms:modified "2026-02-12T08:59:15.811020Z"^^xsd:dateTime .

oakcurric:keyword-tangent
  a curric:Keyword ;
  schema:name "tangent"@en ;
  schema:description """A tangent drawn to the gradient on a curving displacement-time graph will give the instantaneous velocity."""@en ;
  dcterms:modified "2026-02-12T08:59:15.811024Z"^^xsd:dateTime .

oakcurric:keyword-instantaneous-velocity
  a curric:Keyword ;
  schema:name "instantaneous velocity"@en ;
  schema:description """The instantaneous velocity is the velocity of an object at a particular moment in time."""@en ;
  dcterms:modified "2026-02-12T08:59:15.811030Z"^^xsd:dateTime .

oakcurric:keyword-oscilloscope
  a curric:Keyword ;
  schema:name "oscilloscope"@en ;
  schema:description "A piece of equipment that can display a representation of a sound wave."@en ;
  dcterms:modified "2026-02-12T08:59:15.811035Z"^^xsd:dateTime .

oakcurric:keyword-motor-effect
  a curric:Keyword ;
  schema:name "motor effect"@en ;
  schema:description "The effect of causing movement between a magnet and an electromagnet."@en ;
  dcterms:modified "2026-02-12T08:59:15.811039Z"^^xsd:dateTime .

oakcurric:keyword-moving-coil-loudspeaker
  a curric:Keyword ;
  schema:name "moving-coil loudspeaker"@en ;
  schema:description "A loudspeaker that produces sound using the motor effect."@en ;
  dcterms:modified "2026-02-12T08:59:15.811043Z"^^xsd:dateTime .

oakcurric:keyword-generator-effect
  a curric:Keyword ;
  schema:name "generator effect"@en ;
  schema:description """The effect of inducing a current by the relative movement of a circuit and a magnetic field."""@en ;
  dcterms:modified "2026-02-12T08:59:15.811048Z"^^xsd:dateTime .

oakcurric:keyword-moving-coil-microphone
  a curric:Keyword ;
  schema:name "moving-coil microphone"@en ;
  schema:description """A microphone that produces an electric signal from sound using the generator effect."""@en ;
  dcterms:modified "2026-02-12T08:59:15.811052Z"^^xsd:dateTime .

oakcurric:keyword-gravitational-force
  a curric:Keyword ;
  schema:name "gravitational force"@en ;
  schema:description "is a non–contact force that attracts objects with mass towards each other"@en ;
  dcterms:modified "2026-02-12T08:59:15.811056Z"^^xsd:dateTime .

oakcurric:keyword-drag
  a curric:Keyword ;
  schema:name "drag"@en ;
  schema:description """is a force of a fluid on an object moving through it, in the opposite direction to the object’s motion"""@en ;
  dcterms:modified "2026-02-12T08:59:15.811061Z"^^xsd:dateTime .

oakcurric:keyword-resultant-force
  a curric:Keyword ;
  schema:name "resultant force"@en ;
  schema:description "is the overall effect of the forces acting on an object"@en ;
  dcterms:modified "2026-02-12T08:59:15.811065Z"^^xsd:dateTime .

oakcurric:keyword-terminal-velocity
  a curric:Keyword ;
  schema:name "terminal velocity"@en ;
  schema:description """is the velocity of an object falling through a fluid, when there is zero resultant force"""@en ;
  dcterms:modified "2026-02-12T08:59:15.811069Z"^^xsd:dateTime .

oakcurric:keyword-independent-variable
  a curric:Keyword ;
  schema:name "independent variable"@en ;
  schema:description "The factor that we change in an experiment."@en ;
  dcterms:modified "2026-02-12T08:59:15.811096Z"^^xsd:dateTime .

oakcurric:keyword-dependent-variable
  a curric:Keyword ;
  schema:name "dependent variable"@en ;
  schema:description "The factor that we measure in an experiment."@en ;
  dcterms:modified "2026-02-12T08:59:15.811100Z"^^xsd:dateTime .

oakcurric:keyword-electric-charge
  a curric:Keyword ;
  schema:name "electric charge"@en ;
  schema:description "an electrical property; it can either be positive or negative"@en ;
  dcterms:modified "2026-02-12T08:59:15.811279Z"^^xsd:dateTime .

oakcurric:keyword-parallel-circuit
  a curric:Keyword ;
  schema:name "parallel circuit"@en ;
  schema:description "a circuit with separate branches connected to the battery"@en ;
  dcterms:modified "2026-02-12T08:59:15.811283Z"^^xsd:dateTime .

oakcurric:keyword-electric-field
  a curric:Keyword ;
  schema:name "electric field"@en ;
  schema:description """the invisible field around a charged object that causes other charges to experience a force"""@en ;
  dcterms:modified "2026-02-12T08:59:15.811287Z"^^xsd:dateTime .

oakcurric:keyword-electric-current
  a curric:Keyword ;
  schema:name "electric current"@en ;
  schema:description "a measure of the amount of charge passing a given point in one second"@en ;
  dcterms:modified "2026-02-12T08:59:15.811291Z"^^xsd:dateTime .

oakcurric:keyword-scalar-quantity
  a curric:Keyword ;
  schema:name "scalar quantity"@en ;
  schema:description """Some quantities only have magnitude (size), and not direction. This includes distance and speed."""@en ;
  dcterms:modified "2026-02-12T08:59:15.811296Z"^^xsd:dateTime .

oakcurric:keyword-relative-speed
  a curric:Keyword ;
  schema:name "relative speed"@en ;
  schema:description """The relative speed of objects is the difference in their speeds taking into account direction of movement."""@en ;
  dcterms:modified "2026-02-12T08:59:15.811300Z"^^xsd:dateTime .

oakcurric:keyword-light-dependent-resistor
  a curric:Keyword ;
  schema:name "light-dependent resistor"@en ;
  schema:description """a semiconducting component with a resistance that gets lower in increasingly bright light"""@en ;
  dcterms:modified "2026-02-12T08:59:15.811304Z"^^xsd:dateTime .

oakcurric:keyword-semiconductor
  a curric:Keyword ;
  schema:name "semiconductor"@en ;
  schema:description "a material that has both metallic and non-metallic properties"@en ;
  dcterms:modified "2026-02-12T08:59:15.811308Z"^^xsd:dateTime .

oakcurric:keyword-thermistor
  a curric:Keyword ;
  schema:name "thermistor"@en ;
  schema:description """a semiconducting component with a resistance that gets lower in increasingly high temperatures"""@en ;
  dcterms:modified "2026-02-12T08:59:15.811312Z"^^xsd:dateTime .

oakcurric:keyword-reversebias
  a curric:Keyword ;
  schema:name "reverse–bias"@en ;
  schema:description "When a diode is reverse–biased, it prevents current from flowing."@en ;
  dcterms:modified "2026-02-12T08:59:15.811325Z"^^xsd:dateTime .

oakcurric:keyword-forwardbias
  a curric:Keyword ;
  schema:name "forward–bias"@en ;
  schema:description "When a diode is forward–biased, it allows current to flow."@en ;
  dcterms:modified "2026-02-12T08:59:15.811333Z"^^xsd:dateTime .

oakcurric:keyword-threshold-pd
  a curric:Keyword ;
  schema:name "threshold p.d."@en ;
  schema:description """The threshold p.d. is the potential difference at which a diode allows current to flow."""@en ;
  dcterms:modified "2026-02-12T08:59:15.811338Z"^^xsd:dateTime .

oakcurric:keyword-fuse
  a curric:Keyword ;
  schema:name "fuse"@en ;
  schema:description "A fuse is a component that has a wire that melts if the current is too high."@en ;
  dcterms:modified "2026-02-12T08:59:15.811342Z"^^xsd:dateTime .

oakcurric:keyword-ion-lattice
  a curric:Keyword ;
  schema:name "ion lattice"@en ;
  schema:description """In a solid metal, the regular and repeating pattern that metal ions are arranged in is known as an ion lattice."""@en ;
  dcterms:modified "2026-02-12T08:59:15.811346Z"^^xsd:dateTime .

oakcurric:keyword-velocity-time-graph
  a curric:Keyword ;
  schema:name "velocity-time graph"@en ;
  schema:description "A velocity-time graph shows the velocity of an object over a period of time."@en ;
  dcterms:modified "2026-02-12T08:59:15.811350Z"^^xsd:dateTime .

oakcurric:keyword-acceleration
  a curric:Keyword ;
  schema:name "acceleration"@en ;
  schema:description """The acceleration of an object is the rate of change of velocity. This is how much the velocity changes per second."""@en ;
  dcterms:modified "2026-02-12T08:59:15.811355Z"^^xsd:dateTime .

oakcurric:keyword-deceleration
  a curric:Keyword ;
  schema:name "deceleration"@en ;
  schema:description """Deceleration is used to describe a change in velocity where the object slows down."""@en ;
  dcterms:modified "2026-02-12T08:59:15.811359Z"^^xsd:dateTime .

oakcurric:keyword-ray
  a curric:Keyword ;
  schema:name "Ray"@en ;
  schema:description """A ray is a part of a line with a fixed starting point that extends forever in one direction."""@en ;
  dcterms:modified "2026-02-12T08:59:15.811419Z"^^xsd:dateTime .

oakcurric:keyword-random-error
  a curric:Keyword ;
  schema:name "random error"@en ;
  schema:description """causes results to differ by different amounts due to a factor other than the independent variable (the factor we changed)"""@en ;
  dcterms:modified "2026-02-12T08:59:15.811593Z"^^xsd:dateTime .

oakcurric:keyword-compensated-ramp
  a curric:Keyword ;
  schema:name "compensated ramp"@en ;
  schema:description "A ramp with a slope to counteract the effect of friction."@en ;
  dcterms:modified "2026-02-12T08:59:15.811744Z"^^xsd:dateTime .

oakcurric:keyword-final-velocity
  a curric:Keyword ;
  schema:name "final velocity"@en ;
  schema:description """The final velocity of an object is the velocity it finishes with after a phase of motion."""@en ;
  dcterms:modified "2026-02-12T08:59:15.811748Z"^^xsd:dateTime .

oakcurric:keyword-light-gate
  a curric:Keyword ;
  schema:name "light gate"@en ;
  schema:description """A light gate can be used to measure velocity. It uses an infrared beam to turn a timer on and off as an object passes through."""@en ;
  dcterms:modified "2026-02-12T08:59:15.811752Z"^^xsd:dateTime .

oakcurric:keyword-repeatable
  a curric:Keyword ;
  schema:name "repeatable"@en ;
  schema:description """Measurements are repeatable if they are very similar when the same procedure is carried out by the same person or team."""@en ;
  dcterms:modified "2026-02-12T08:59:15.811759Z"^^xsd:dateTime .

oakcurric:keyword-uniform-acceleration
  a curric:Keyword ;
  schema:name "uniform acceleration"@en ;
  schema:description "When the acceleration is constant, it is described as uniform acceleration."@en ;
  dcterms:modified "2026-02-12T08:59:15.811763Z"^^xsd:dateTime .

oakcurric:keyword-electrical-insulator
  a curric:Keyword ;
  schema:name "electrical insulator"@en ;
  schema:description "is a material that does not conduct electric current"@en ;
  dcterms:modified "2026-02-12T08:59:15.811768Z"^^xsd:dateTime .

oakcurric:keyword-motor-coil
  a curric:Keyword ;
  schema:name "motor coil"@en ;
  schema:description """a coil of insulated wire that spins inside an electric motor when a current flows through it"""@en ;
  dcterms:modified "2026-02-12T08:59:15.811774Z"^^xsd:dateTime .

oakcurric:keyword-axle
  a curric:Keyword ;
  schema:name "axle"@en ;
  schema:description "a rod at the centre of wheels and gears around which they turn"@en ;
  dcterms:modified "2026-02-12T08:59:15.811778Z"^^xsd:dateTime .

oakcurric:keyword-yoke
  a curric:Keyword ;
  schema:name "yoke"@en ;
  schema:description """in a motor kit, a U–shaped piece of iron that holds two magnets in place to create a uniform magnetic field"""@en ;
  dcterms:modified "2026-02-12T08:59:15.811783Z"^^xsd:dateTime .

oakcurric:keyword-variable-resistor
  a curric:Keyword ;
  schema:name "variable resistor"@en ;
  schema:description "a resistor that can be easily changed to any value in its range"@en ;
  dcterms:modified "2026-02-12T08:59:15.811787Z"^^xsd:dateTime .

oakcurric:keyword-repeat-reading
  a curric:Keyword ;
  schema:name "repeat reading"@en ;
  schema:description "when a measurement is taken again to improve the experiment"@en ;
  dcterms:modified "2026-02-12T08:59:15.811791Z"^^xsd:dateTime .

oakcurric:keyword-best-fit-line
  a curric:Keyword ;
  schema:name "best fit line"@en ;
  schema:description """a line that shows the underlying trend of a set of results on a graph, it can be straight or curved"""@en ;
  dcterms:modified "2026-02-12T08:59:15.811795Z"^^xsd:dateTime .

oakcurric:keyword-crest
  a curric:Keyword ;
  schema:name "crest"@en ;
  schema:description "the crest of a wave is the top or peak of the wave."@en ;
  dcterms:modified "2026-02-12T08:59:15.811799Z"^^xsd:dateTime .

oakcurric:keyword-trough
  a curric:Keyword ;
  schema:name "trough"@en ;
  schema:description "the trough of a wave is the lowest point of the wave."@en ;
  dcterms:modified "2026-02-12T08:59:15.811804Z"^^xsd:dateTime .

oakcurric:keyword-wavelength
  a curric:Keyword ;
  schema:name "wavelength"@en ;
  schema:description """wavelength of a transverse wave is the distance between one wave crest (or trough) and the next."""@en ;
  dcterms:modified "2026-02-12T08:59:15.811808Z"^^xsd:dateTime .

oakcurric:keyword-amplitude
  a curric:Keyword ;
  schema:name "amplitude"@en ;
  schema:description """the amplitude of a wave is the maximum distance that each part of the wave moves from its normal position as a wave passes."""@en ;
  dcterms:modified "2026-02-12T08:59:15.811812Z"^^xsd:dateTime .

oakcurric:keyword-diode
  a curric:Keyword ;
  schema:name "diode"@en ;
  schema:description "an electrical component that is used to prevent current flow in one direction"@en ;
  dcterms:modified "2026-02-12T08:59:15.811817Z"^^xsd:dateTime .

oakcurric:keyword-reversebiased
  a curric:Keyword ;
  schema:name "reverse–biased"@en ;
  schema:description "when a diode is reverse–biased, it prevents current from flowing"@en ;
  dcterms:modified "2026-02-12T08:59:15.811821Z"^^xsd:dateTime .

oakcurric:keyword-forwardbiased
  a curric:Keyword ;
  schema:name "forward–biased"@en ;
  schema:description "when a diode is forward–biased, it allows current to flow"@en ;
  dcterms:modified "2026-02-12T08:59:15.811825Z"^^xsd:dateTime .

oakcurric:keyword-coulombs-c
  a curric:Keyword ;
  schema:name "coulombs (C)"@en ;
  schema:description "the unit of electric charge"@en ;
  dcterms:modified "2026-02-12T08:59:15.811842Z"^^xsd:dateTime .

oakcurric:keyword-current
  a curric:Keyword ;
  schema:name "current"@en ;
  schema:description "the rate of flow of charge in a circuit"@en ;
  dcterms:modified "2026-02-12T08:59:15.811846Z"^^xsd:dateTime .

oakcurric:keyword-branch
  a curric:Keyword ;
  schema:name "branch"@en ;
  schema:description "a separate series loop in a parallel circuit"@en ;
  dcterms:modified "2026-02-12T08:59:15.811851Z"^^xsd:dateTime .

oakcurric:keyword-frequency
  a curric:Keyword ;
  schema:name "Frequency"@en ;
  schema:description """The frequency is the number of times an event occurs; or the number of individuals (people, animals etc.) with some specific property."""@en ;
  dcterms:modified "2026-02-12T08:59:15.811977Z"^^xsd:dateTime .

oakcurric:keyword-nucleon
  a curric:Keyword ;
  schema:name "nucleon"@en ;
  schema:description "the term for particles in a nucleus (protons and neutrons)"@en ;
  dcterms:modified "2026-02-12T08:59:15.812032Z"^^xsd:dateTime .

oakcurric:keyword-atomic-proton-number
  a curric:Keyword ;
  schema:name "atomic (proton) number"@en ;
  schema:description "the number of protons within a particular nucleus"@en ;
  dcterms:modified "2026-02-12T08:59:15.812036Z"^^xsd:dateTime .

oakcurric:keyword-mass-nucleon-number
  a curric:Keyword ;
  schema:name "mass (nucleon) number"@en ;
  schema:description "the total number of nucleons within a particular nucleus (protons + neutrons)"@en ;
  dcterms:modified "2026-02-12T08:59:15.812040Z"^^xsd:dateTime .

oakcurric:keyword-isotopes
  a curric:Keyword ;
  schema:name "isotopes"@en ;
  schema:description "atoms of the same element with differing numbers of neutrons"@en ;
  dcterms:modified "2026-02-12T08:59:15.812045Z"^^xsd:dateTime .

oakcurric:keyword-wave-equation
  a curric:Keyword ;
  schema:name "wave equation"@en ;
  schema:description "wave speed = frequency × wavelength (v = f × λ)"@en ;
  dcterms:modified "2026-02-12T08:59:15.812049Z"^^xsd:dateTime .

oakcurric:keyword-wave-speed
  a curric:Keyword ;
  schema:name "wave speed"@en ;
  schema:description """The speed of a wave through a medium. Given by the wave equation: wave speed = frequency × wavelength (v = f × λ)"""@en ;
  dcterms:modified "2026-02-12T08:59:15.812053Z"^^xsd:dateTime .

oakcurric:keyword-van-de-graaff-generator
  a curric:Keyword ;
  schema:name "Van de Graaff generator"@en ;
  schema:description "A device that produces electric charge and is used in electrostatic experiments."@en ;
  dcterms:modified "2026-02-12T08:59:15.812058Z"^^xsd:dateTime .

oakcurric:keyword-charge
  a curric:Keyword ;
  schema:name "charge"@en ;
  schema:description "An electrical property; it can either be positive or negative."@en ;
  dcterms:modified "2026-02-12T08:59:15.812062Z"^^xsd:dateTime .

oakcurric:keyword-coulomb
  a curric:Keyword ;
  schema:name "coulomb"@en ;
  schema:description "The unit of electric charge."@en ;
  dcterms:modified "2026-02-12T08:59:15.812066Z"^^xsd:dateTime .

oakcurric:keyword-ampere
  a curric:Keyword ;
  schema:name "ampere"@en ;
  schema:description "The unit of electric current."@en ;
  dcterms:modified "2026-02-12T08:59:15.812070Z"^^xsd:dateTime .

oakcurric:keyword-thinking-distance
  a curric:Keyword ;
  schema:name "thinking distance"@en ;
  schema:description """is the distance a vehicle travels while a driver reacts; the vehicle does not slow during this time"""@en ;
  dcterms:modified "2026-02-12T08:59:15.812075Z"^^xsd:dateTime .

oakcurric:keyword-braking-distance
  a curric:Keyword ;
  schema:name "braking distance"@en ;
  schema:description """is the distance a vehicle travels between the brakes being applied and the vehicle coming to a stop"""@en ;
  dcterms:modified "2026-02-12T08:59:15.812079Z"^^xsd:dateTime .

oakcurric:keyword-stopping-distance
  a curric:Keyword ;
  schema:name "stopping distance"@en ;
  schema:description "is the sum of the thinking and braking distances"@en ;
  dcterms:modified "2026-02-12T08:59:15.812083Z"^^xsd:dateTime .

oakcurric:keyword-electromagnetic-wave
  a curric:Keyword ;
  schema:name "electromagnetic wave"@en ;
  schema:description """Electromagnetic waves are ripples/oscillations in the invisible electric and magnetic fields that are all around us."""@en ;
  dcterms:modified "2026-02-12T08:59:15.812377Z"^^xsd:dateTime .

oakcurric:keyword-refract
  a curric:Keyword ;
  schema:name "refract"@en ;
  schema:description "Waves are said to refract when they change direction upon entering a new medium."@en ;
  dcterms:modified "2026-02-12T08:59:15.812382Z"^^xsd:dateTime .

oakcurric:keyword-opaque
  a curric:Keyword ;
  schema:name "opaque"@en ;
  schema:description "An object is opaque if no light is transmitted through it."@en ;
  dcterms:modified "2026-02-12T08:59:15.812386Z"^^xsd:dateTime .

oakcurric:keyword-systematic-error
  a curric:Keyword ;
  schema:name "systematic error"@en ;
  schema:description """Causes measurements to differ from the true value by the same amount each time they are taken."""@en ;
  dcterms:modified "2026-02-12T08:59:15.812403Z"^^xsd:dateTime .

oakcurric:keyword-period
  a curric:Keyword ;
  schema:name "period"@en ;
  schema:description """is a horizontal row on the periodic table, it corresponds to the number of shells of an atom in an element that have electrons in them."""@en ;
  dcterms:modified "2026-02-12T08:59:15.812422Z"^^xsd:dateTime .

oakcurric:keyword-principal-axis
  a curric:Keyword ;
  schema:name "principal axis"@en ;
  schema:description """The principal axis is a line through the centre of a lens, 90° to the optical axis of the lens."""@en ;
  dcterms:modified "2026-02-12T08:59:15.812465Z"^^xsd:dateTime .

oakcurric:keyword-principal-focus
  a curric:Keyword ;
  schema:name "principal focus"@en ;
  schema:description """The principal focus for a convex lens is the point to which rays parallel to the principal axis are focused. For a concave lens it is the point from which such rays appear to be diverged."""@en ;
  dcterms:modified "2026-02-12T08:59:15.812469Z"^^xsd:dateTime .

oakcurric:keyword-real-image
  a curric:Keyword ;
  schema:name "real image"@en ;
  schema:description """When rays of light are brought to a focus a real image forms. A real image can be projected onto a screen."""@en ;
  dcterms:modified "2026-02-12T08:59:15.812475Z"^^xsd:dateTime .

oakcurric:keyword-virtual-image
  a curric:Keyword ;
  schema:name "virtual image"@en ;
  schema:description """Virtual images occur at points where rays appear to (but do not actually) originate from. They cannot form on a screen."""@en ;
  dcterms:modified "2026-02-12T08:59:15.812480Z"^^xsd:dateTime .

oakcurric:keyword-virtual-ray
  a curric:Keyword ;
  schema:name "virtual ray"@en ;
  schema:description """Virtual rays are dashed lines drawn to represent where rays of light appear to have come from."""@en ;
  dcterms:modified "2026-02-12T08:59:15.812484Z"^^xsd:dateTime .

oakcurric:keyword-rate-of-change
  a curric:Keyword ;
  schema:name "Rate of change"@en ;
  schema:description "The rate of change is how quickly one variable changes in relation to another."@en ;
  dcterms:modified "2026-02-12T08:59:15.812598Z"^^xsd:dateTime .

oakcurric:keyword-diminished
  a curric:Keyword ;
  schema:name "diminished"@en ;
  schema:description """Diminished means smaller than an object’s real size. It is the opposite of magnified."""@en ;
  dcterms:modified "2026-02-12T08:59:15.812634Z"^^xsd:dateTime .

oakcurric:keyword-convex
  a curric:Keyword ;
  schema:name "convex"@en ;
  schema:description "A convex shape bulges ‘out’ rather than bulging ‘in’ (concave)."@en ;
  dcterms:modified "2026-02-12T08:59:15.812639Z"^^xsd:dateTime .

oakcurric:keyword-focal-length
  a curric:Keyword ;
  schema:name "focal length"@en ;
  schema:description """The focal length is the distance from the centre of the lens to the principal focus."""@en ;
  dcterms:modified "2026-02-12T08:59:15.812643Z"^^xsd:dateTime .

oakcurric:keyword-lens-power
  a curric:Keyword ;
  schema:name "lens power"@en ;
  schema:description """The greater the power of a lens, the greater the angles through which light is refracted and the shorter the focal length."""@en ;
  dcterms:modified "2026-02-12T08:59:15.812647Z"^^xsd:dateTime .

oakcurric:keyword-longitudinal-wave
  a curric:Keyword ;
  schema:name "longitudinal wave"@en ;
  schema:description """each part of a longitudinal wave oscillates forward and backward in the same direction in which the wave moves."""@en ;
  dcterms:modified "2026-02-12T08:59:15.812652Z"^^xsd:dateTime .

oakcurric:keyword-compression
  a curric:Keyword ;
  schema:name "compression"@en ;
  schema:description """part of a longitudinal wave in which parts of the wave are squashed closer together is called a compression."""@en ;
  dcterms:modified "2026-02-12T08:59:15.812656Z"^^xsd:dateTime .

oakcurric:keyword-rarefaction
  a curric:Keyword ;
  schema:name "rarefaction"@en ;
  schema:description """part of a longitudinal wave in which parts of the wave are spaced further apart is called a rarefaction."""@en ;
  dcterms:modified "2026-02-12T08:59:15.812660Z"^^xsd:dateTime .

oakcurric:keyword-control-experiments
  a curric:Keyword ;
  schema:name "control experiments"@en ;
  schema:description """These are done to find a baseline set of results to which others can be compared."""@en ;
  dcterms:modified "2026-02-12T08:59:15.812665Z"^^xsd:dateTime .

oakcurric:keyword-control-variables
  a curric:Keyword ;
  schema:name "control variables"@en ;
  schema:description """These are factors that need to be kept constant in an experiment for the test to be fair."""@en ;
  dcterms:modified "2026-02-12T08:59:15.812669Z"^^xsd:dateTime .

oakcurric:keyword-object-distance
  a curric:Keyword ;
  schema:name "object distance"@en ;
  schema:description "The object distance is the distance between an object and a lens."@en ;
  dcterms:modified "2026-02-12T08:59:15.812861Z"^^xsd:dateTime .

oakcurric:keyword-image-distance
  a curric:Keyword ;
  schema:name "image distance"@en ;
  schema:description """The image distance is the distance between a lens and an image formed by that lens."""@en ;
  dcterms:modified "2026-02-12T08:59:15.812865Z"^^xsd:dateTime .

oakcurric:keyword-atom
  a curric:Keyword ;
  schema:name "atom"@en ;
  schema:description """the building block of matter; even small pieces of matter have trillions of atoms"""@en ;
  dcterms:modified "2026-02-12T08:59:15.812869Z"^^xsd:dateTime .

oakcurric:keyword-particle
  a curric:Keyword ;
  schema:name "particle"@en ;
  schema:description "a term used to describe atoms or molecules which make up matter"@en ;
  dcterms:modified "2026-02-12T08:59:15.812875Z"^^xsd:dateTime .

oakcurric:keyword-coil-of-an-electromagnet
  a curric:Keyword ;
  schema:name "coil of an electromagnet"@en ;
  schema:description "An insulated wire wound into the shape of a spring."@en ;
  dcterms:modified "2026-02-12T08:59:15.812992Z"^^xsd:dateTime .

oakcurric:keyword-turn-of-wire
  a curric:Keyword ;
  schema:name "turn of wire"@en ;
  schema:description "A single loop of wire in a coil."@en ;
  dcterms:modified "2026-02-12T08:59:15.812996Z"^^xsd:dateTime .

oakcurric:keyword-soft-iron
  a curric:Keyword ;
  schema:name "soft iron"@en ;
  schema:description "Very pure iron that cannot be made into a permanent magnet."@en ;
  dcterms:modified "2026-02-12T08:59:15.813000Z"^^xsd:dateTime .

oakcurric:keyword-directly-proportional-to
  a curric:Keyword ;
  schema:name "directly proportional to"@en ;
  schema:description """Describes the relationship between two variables, in which doubling the value of one variable doubles the value of the other."""@en ;
  dcterms:modified "2026-02-12T08:59:15.813004Z"^^xsd:dateTime .

oakcurric:keyword-error-bars
  a curric:Keyword ;
  schema:name "error bars"@en ;
  schema:description "These show the accuracy of each measurement on a graph."@en ;
  dcterms:modified "2026-02-12T08:59:15.813008Z"^^xsd:dateTime .

oakcurric:keyword-mean
  a curric:Keyword ;
  schema:name "Mean"@en ;
  schema:description """The (arithmetic) mean for a set of numerical data is the sum of the values divided by the number of values."""@en ;
  dcterms:modified "2026-02-12T08:59:15.813064Z"^^xsd:dateTime .

oakcurric:keyword-specular-reflection
  a curric:Keyword ;
  schema:name "specular reflection"@en ;
  schema:description "Specular reflection is reflection from smooth surfaces in one direction."@en ;
  dcterms:modified "2026-02-12T08:59:15.813096Z"^^xsd:dateTime .

oakcurric:keyword-diffuse-reflection
  a curric:Keyword ;
  schema:name "diffuse reflection"@en ;
  schema:description "Diffuse reflection is reflection from rough surfaces in multiple directions."@en ;
  dcterms:modified "2026-02-12T08:59:15.813100Z"^^xsd:dateTime .

oakcurric:keyword-normal
  a curric:Keyword ;
  schema:name "normal"@en ;
  schema:description "The normal is an imaginary line drawn at 90° to a surface."@en ;
  dcterms:modified "2026-02-12T08:59:15.813105Z"^^xsd:dateTime .

oakcurric:keyword-wavefront
  a curric:Keyword ;
  schema:name "wavefront"@en ;
  schema:description "Wavefronts are lines drawn to represent peaks of a wave."@en ;
  dcterms:modified "2026-02-12T08:59:15.813109Z"^^xsd:dateTime .

oakcurric:keyword-density
  a curric:Keyword ;
  schema:name "density"@en ;
  schema:description "the mass per cubic metre (m³) or cubic centimetre (cm³) of a material"@en ;
  dcterms:modified "2026-02-12T08:59:15.813208Z"^^xsd:dateTime .

oakcurric:keyword-kilograms-per-cubic-metre
  a curric:Keyword ;
  schema:name "kilograms per cubic metre"@en ;
  schema:description """the unit for density when mass is measured in kilograms (kg) and volume in cubic metres (m³), written as kg/m³"""@en ;
  dcterms:modified "2026-02-12T08:59:15.813212Z"^^xsd:dateTime .

oakcurric:keyword-grams-per-cubic-centimetre
  a curric:Keyword ;
  schema:name "grams per cubic centimetre"@en ;
  schema:description """the unit for density when mass is measured in grams (g) and volume in cubic centimetres (cm³), written as g/cm³"""@en ;
  dcterms:modified "2026-02-12T08:59:15.813217Z"^^xsd:dateTime .

oakcurric:keyword-vernier-callipers
  a curric:Keyword ;
  schema:name "Vernier callipers"@en ;
  schema:description "a device used to measure length precisely"@en ;
  dcterms:modified "2026-02-12T08:59:15.813221Z"^^xsd:dateTime .

oakcurric:keyword-micrometer
  a curric:Keyword ;
  schema:name "micrometer"@en ;
  schema:description "a device used to measure length to a very high precision"@en ;
  dcterms:modified "2026-02-12T08:59:15.813225Z"^^xsd:dateTime .

oakcurric:keyword-positive-electric-charge
  a curric:Keyword ;
  schema:name "positive electric charge"@en ;
  schema:description "The type of charge produced when electrons are removed."@en ;
  dcterms:modified "2026-02-12T08:59:15.813230Z"^^xsd:dateTime .

oakcurric:keyword-negative-electric-charge
  a curric:Keyword ;
  schema:name "negative electric charge"@en ;
  schema:description "The type of charge produced when electrons are gained."@en ;
  dcterms:modified "2026-02-12T08:59:15.813234Z"^^xsd:dateTime .

oakcurric:keyword-electrostatic-force
  a curric:Keyword ;
  schema:name "electrostatic force"@en ;
  schema:description "The type of force due to electrically charged objects."@en ;
  dcterms:modified "2026-02-12T08:59:15.813238Z"^^xsd:dateTime .

oakcurric:keyword-van-de-graaff
  a curric:Keyword ;
  schema:name "Van de Graaff"@en ;
  schema:description "A device that produces electric charge and is used in electrostatic experiments."@en ;
  dcterms:modified "2026-02-12T08:59:15.813242Z"^^xsd:dateTime .

oakcurric:keyword-uniform-magnetic-field
  a curric:Keyword ;
  schema:name "uniform magnetic field"@en ;
  schema:description """has evenly spaced field lines and the strength of the magnetic field is the same everywhere"""@en ;
  dcterms:modified "2026-02-12T08:59:15.813246Z"^^xsd:dateTime .

oakcurric:keyword-flemings-left-hand-rule
  a curric:Keyword ;
  schema:name "Fleming’s left-hand rule"@en ;
  schema:description """indicates the direction a conducting wire is forced to move in a uniform magnetic field"""@en ;
  dcterms:modified "2026-02-12T08:59:15.813250Z"^^xsd:dateTime .

oakcurric:keyword-magnetic-flux-density-b
  a curric:Keyword ;
  schema:name "magnetic flux density, B"@en ;
  schema:description "is a measure of the strength of a magnetic field"@en ;
  dcterms:modified "2026-02-12T08:59:15.813255Z"^^xsd:dateTime .

oakcurric:keyword-tesla-t
  a curric:Keyword ;
  schema:name "tesla (T)"@en ;
  schema:description "is the unit that magnetic flux density is measured in"@en ;
  dcterms:modified "2026-02-12T08:59:15.813259Z"^^xsd:dateTime .

oakcurric:keyword-electrical-current
  a curric:Keyword ;
  schema:name "electrical current"@en ;
  schema:description "The amount of charge flowing past a given point in one second."@en ;
  dcterms:modified "2026-02-12T08:59:15.813351Z"^^xsd:dateTime .

oakcurric:keyword-ohms
  a curric:Keyword ;
  schema:name "ohms (Ω)"@en ;
  schema:description "The unit of resistance."@en ;
  dcterms:modified "2026-02-12T08:59:15.813356Z"^^xsd:dateTime .

oakcurric:keyword-elastic-deformation
  a curric:Keyword ;
  schema:name "elastic deformation"@en ;
  schema:description """The stretch of a spring that returns to its original shape when the stretching force is removed."""@en ;
  dcterms:modified "2026-02-12T08:59:15.813484Z"^^xsd:dateTime .

oakcurric:keyword-inelastic-deformation
  a curric:Keyword ;
  schema:name "inelastic deformation"@en ;
  schema:description "The stretch of a spring as it is permanently stretched out of shape."@en ;
  dcterms:modified "2026-02-12T08:59:15.813488Z"^^xsd:dateTime .

oakcurric:keyword-spring-constant
  a curric:Keyword ;
  schema:name "spring constant"@en ;
  schema:description "A measure of how stiff a spring is and how hard it is to stretch or compress."@en ;
  dcterms:modified "2026-02-12T08:59:15.813492Z"^^xsd:dateTime .

oakcurric:keyword-hookes-law
  a curric:Keyword ;
  schema:name "Hooke’s Law"@en ;
  schema:description """For elastic deformations, extension (or compression) is directly proportional to the force applied."""@en ;
  dcterms:modified "2026-02-12T08:59:15.813497Z"^^xsd:dateTime .

oakcurric:keyword-equilibrium
  a curric:Keyword ;
  schema:name "equilibrium"@en ;
  schema:description "is the state of an object if there is no resultant force acting on it."@en ;
  dcterms:modified "2026-02-12T08:59:15.813556Z"^^xsd:dateTime .

oakcurric:keyword-vector-diagram
  a curric:Keyword ;
  schema:name "vector diagram"@en ;
  schema:description """is a drawing on which forces are drawn end to end and to scale, which can be used to find a resultant force."""@en ;
  dcterms:modified "2026-02-12T08:59:15.813560Z"^^xsd:dateTime .

oakcurric:keyword-component-of-a-force
  a curric:Keyword ;
  schema:name "component of a force"@en ;
  schema:description "is one of two perpendicular forces that add up to a single force."@en ;
  dcterms:modified "2026-02-12T08:59:15.813564Z"^^xsd:dateTime .

oakcurric:keyword-resolving-forces
  a curric:Keyword ;
  schema:name "resolving forces"@en ;
  schema:description "splits a force into two perpendicular forces that add up to that force."@en ;
  dcterms:modified "2026-02-12T08:59:15.813569Z"^^xsd:dateTime .

oakcurric:keyword-angle-of-incidence
  a curric:Keyword ;
  schema:name "angle of incidence"@en ;
  schema:description "The angle of incidence is the angle between the incident ray and the normal."@en ;
  dcterms:modified "2026-02-12T08:59:15.813573Z"^^xsd:dateTime .

oakcurric:keyword-angle-of-refraction
  a curric:Keyword ;
  schema:name "angle of refraction"@en ;
  schema:description "The angle of refraction is the angle between the refracted ray and the normal."@en ;
  dcterms:modified "2026-02-12T08:59:15.813577Z"^^xsd:dateTime .

oakcurric:keyword-loudness
  a curric:Keyword ;
  schema:name "loudness"@en ;
  schema:description "the loudness of a sound wave is a measure of how loud it is."@en ;
  dcterms:modified "2026-02-12T08:59:15.813724Z"^^xsd:dateTime .

oakcurric:keyword-significant-figures
  a curric:Keyword ;
  schema:name "Significant figures"@en ;
  schema:description """Significant figures are the digits in a number that contribute to the accuracy of the number."""@en ;
  dcterms:modified "2026-02-12T08:59:15.813884Z"^^xsd:dateTime .

oakcurric:keyword-watts-w
  a curric:Keyword ;
  schema:name "watts (W)"@en ;
  schema:description """the unit of power; equal to the number of joules of energy transferred each second"""@en ;
  dcterms:modified "2026-02-12T08:59:15.813983Z"^^xsd:dateTime .

oakcurric:keyword-kilowatts-kw
  a curric:Keyword ;
  schema:name "kilowatts (kW)"@en ;
  schema:description "a unit of power; 1 kilowatt is equal to 1000 watts"@en ;
  dcterms:modified "2026-02-12T08:59:15.813987Z"^^xsd:dateTime .

oakcurric:keyword-converging
  a curric:Keyword ;
  schema:name "converging"@en ;
  schema:description """Light rays are converging if they are coming together to a point where they will meet."""@en ;
  dcterms:modified "2026-02-12T08:59:15.814657Z"^^xsd:dateTime .

oakcurric:keyword-induced-potential
  a curric:Keyword ;
  schema:name "induced potential"@en ;
  schema:description """The potential difference generated in a conductor moving relative to a magnetic field."""@en ;
  dcterms:modified "2026-02-12T08:59:15.814789Z"^^xsd:dateTime .

oakcurric:keyword-direct-current-dc
  a curric:Keyword ;
  schema:name "direct current (DC)"@en ;
  schema:description "An electric current that consistently flows in one direction."@en ;
  dcterms:modified "2026-02-12T08:59:15.814793Z"^^xsd:dateTime .

oakcurric:keyword-dynamo
  a curric:Keyword ;
  schema:name "dynamo"@en ;
  schema:description "A generator of direct current."@en ;
  dcterms:modified "2026-02-12T08:59:15.814798Z"^^xsd:dateTime .

oakcurric:keyword-alternating-current-ac
  a curric:Keyword ;
  schema:name "alternating current (AC)"@en ;
  schema:description "An electric current that repeatedly reverses direction."@en ;
  dcterms:modified "2026-02-12T08:59:15.814802Z"^^xsd:dateTime .

oakcurric:keyword-alternator
  a curric:Keyword ;
  schema:name "alternator"@en ;
  schema:description "A generator of alternating current."@en ;
  dcterms:modified "2026-02-12T08:59:15.814806Z"^^xsd:dateTime .

oakcurric:keyword-space-telescope
  a curric:Keyword ;
  schema:name "space telescope"@en ;
  schema:description """is a telescope positioned in space to avoid atmospheric interference and observe parts of the spectrum which cannot reach the Earth’s surface"""@en ;
  dcterms:modified "2026-02-12T08:59:15.815149Z"^^xsd:dateTime .

oakcurric:keyword-galaxy
  a curric:Keyword ;
  schema:name "galaxy"@en ;
  schema:description """is a collection of many millions or billions of stars held together by gravitational forces"""@en ;
  dcterms:modified "2026-02-12T08:59:15.815153Z"^^xsd:dateTime .

oakcurric:keyword-redshift
  a curric:Keyword ;
  schema:name "redshift"@en ;
  schema:description """is the increase in the wavelength of light (and decrease in its frequency) cause by the movement of a star or galaxy away from us"""@en ;
  dcterms:modified "2026-02-12T08:59:15.815158Z"^^xsd:dateTime .

oakcurric:keyword-melting
  a curric:Keyword ;
  schema:name "melting"@en ;
  schema:description "When a substance changes from a solid state to a liquid state."@en ;
  dcterms:modified "2026-02-12T08:59:15.815532Z"^^xsd:dateTime .

oakcurric:keyword-boiling
  a curric:Keyword ;
  schema:name "boiling"@en ;
  schema:description """When a substance in the liquid state is heated, gas bubbles form and it changes to the gas state."""@en ;
  dcterms:modified "2026-02-12T08:59:15.815547Z"^^xsd:dateTime .

oakcurric:keyword-elastic-store
  a curric:Keyword ;
  schema:name "elastic store"@en ;
  schema:description """If an elastic object is stretched, compressed or bent out of shape, there is energy in the elastic store."""@en ;
  dcterms:modified "2026-02-12T08:59:15.815654Z"^^xsd:dateTime .

oakcurric:keyword-compress
  a curric:Keyword ;
  schema:name "compress"@en ;
  schema:description """To make something smaller using forces, e.g. a spring gets shorter when it is compressed."""@en ;
  dcterms:modified "2026-02-12T08:59:15.815659Z"^^xsd:dateTime .

oakcurric:keyword-extension
  a curric:Keyword ;
  schema:name "extension"@en ;
  schema:description """The increase in length from the original length of a spring when it is stretched."""@en ;
  dcterms:modified "2026-02-12T08:59:15.815663Z"^^xsd:dateTime .

oakcurric:keyword-heating
  a curric:Keyword ;
  schema:name "heating"@en ;
  schema:description "causes the particles of a substance to move or vibrate more rapidly"@en ;
  dcterms:modified "2026-02-12T08:59:15.815723Z"^^xsd:dateTime .

oakcurric:keyword-thermal-conduction
  a curric:Keyword ;
  schema:name "thermal conduction"@en ;
  schema:description """the transfer of energy through a material due to collisions between moving or vibrating particles"""@en ;
  dcterms:modified "2026-02-12T08:59:15.815727Z"^^xsd:dateTime .

oakcurric:keyword-thermal-insulation
  a curric:Keyword ;
  schema:name "thermal insulation"@en ;
  schema:description "reduces the transfer of energy by thermal conduction"@en ;
  dcterms:modified "2026-02-12T08:59:15.815731Z"^^xsd:dateTime .

oakcurric:keyword-thermal-conductors
  a curric:Keyword ;
  schema:name "thermal conductors"@en ;
  schema:description "substances that transfer energy by thermal conduction quickly"@en ;
  dcterms:modified "2026-02-12T08:59:15.815735Z"^^xsd:dateTime .

oakcurric:keyword-thermal-insulators
  a curric:Keyword ;
  schema:name "thermal insulators"@en ;
  schema:description "substances that transfer energy by thermal conduction slowly or not at all"@en ;
  dcterms:modified "2026-02-12T08:59:15.815740Z"^^xsd:dateTime .

oakcurric:keyword-moment
  a curric:Keyword ;
  schema:name "moment"@en ;
  schema:description "The turning effect of a force, measured in newton metres (Nm)."@en ;
  dcterms:modified "2026-02-12T08:59:15.815744Z"^^xsd:dateTime .

oakcurric:keyword-principle-of-moments
  a curric:Keyword ;
  schema:name "principle of moments"@en ;
  schema:description """An object will balance when the clockwise moments are equal to the anticlockwise moments."""@en ;
  dcterms:modified "2026-02-12T08:59:15.815748Z"^^xsd:dateTime .

oakcurric:keyword-wave-medium
  a curric:Keyword ;
  schema:name "wave medium"@en ;
  schema:description "the wave medium is the material that a wave can move through."@en ;
  dcterms:modified "2026-02-12T08:59:15.815769Z"^^xsd:dateTime .

oakcurric:keyword-period-of-a-wave
  a curric:Keyword ;
  schema:name "period (of a wave)"@en ;
  schema:description """period (of a wave), T, is the time for a complete wave to pass any point, which is the same as the time to make one complete wave."""@en ;
  dcterms:modified "2026-02-12T08:59:15.815773Z"^^xsd:dateTime .

oakcurric:keyword-particle-model
  a curric:Keyword ;
  schema:name "particle model"@en ;
  schema:description """a scientific model using the idea of moving particles to explain the behaviour of matter."""@en ;
  dcterms:modified "2026-02-12T08:59:15.815860Z"^^xsd:dateTime .

oakcurric:keyword-standing-wave
  a curric:Keyword ;
  schema:name "standing wave"@en ;
  schema:description """A standing wave is a stable pattern of oscillation that does not appear to travel across a wave medium."""@en ;
  dcterms:modified "2026-02-12T08:59:15.815880Z"^^xsd:dateTime .

oakcurric:keyword-gravitational-store
  a curric:Keyword ;
  schema:name "gravitational store"@en ;
  schema:description """Objects have energy in the gravitational store because of their mass and their height."""@en ;
  dcterms:modified "2026-02-12T08:59:15.815910Z"^^xsd:dateTime .

oakcurric:keyword-work-done
  a curric:Keyword ;
  schema:name "work done"@en ;
  schema:description """Work is done whenever a force makes an object move. The amount of work done is equal to the force multiplied by distance moved in the direction of the force."""@en ;
  dcterms:modified "2026-02-12T08:59:15.815914Z"^^xsd:dateTime .

oakcurric:keyword-weight
  a curric:Keyword ;
  schema:name "weight"@en ;
  schema:description "Weight = mass × gravitational field strength, measured in newtons."@en ;
  dcterms:modified "2026-02-12T08:59:15.815918Z"^^xsd:dateTime .

oakcurric:keyword-gravitational-field-strength
  a curric:Keyword ;
  schema:name "gravitational field strength"@en ;
  schema:description """Gravitational field strength, g, is the force per kilogram caused by a gravitational field."""@en ;
  dcterms:modified "2026-02-12T08:59:15.815925Z"^^xsd:dateTime .

oakcurric:keyword-gravitational-potential-energy
  a curric:Keyword ;
  schema:name "gravitational potential energy"@en ;
  schema:description "The energy stored in an object due to its height above the ground."@en ;
  dcterms:modified "2026-02-12T08:59:15.815929Z"^^xsd:dateTime .

oakcurric:keyword-dissipate
  a curric:Keyword ;
  schema:name "dissipate"@en ;
  schema:description """Friction can cause energy to dissipate (spread out and become unusable) into the surroundings, causing them to heat up."""@en ;
  dcterms:modified "2026-02-12T08:59:15.815934Z"^^xsd:dateTime .

oakcurric:keyword-useful-energy-transferred
  a curric:Keyword ;
  schema:name "useful energy transferred"@en ;
  schema:description """The amount of energy usefully transferred by an object or system is the useful energy transferred by the device."""@en ;
  dcterms:modified "2026-02-12T08:59:15.815938Z"^^xsd:dateTime .

oakcurric:keyword-total-energy-supplied
  a curric:Keyword ;
  schema:name "total energy supplied"@en ;
  schema:description """The total amount of energy transferred to an object or system is the total energy supplied to the device."""@en ;
  dcterms:modified "2026-02-12T08:59:15.815942Z"^^xsd:dateTime .

oakcurric:keyword-background-radiation
  a curric:Keyword ;
  schema:name "background radiation"@en ;
  schema:description "the radiation in the surroundings of a particular place"@en ;
  dcterms:modified "2026-02-12T08:59:15.816235Z"^^xsd:dateTime .

oakcurric:keyword-alpha-particle
  a curric:Keyword ;
  schema:name "alpha particle"@en ;
  schema:description "a small, positively charged particle which was used to discover the nucleus"@en ;
  dcterms:modified "2026-02-12T08:59:15.816240Z"^^xsd:dateTime .

oakcurric:keyword-alpha-scattering-experiment
  a curric:Keyword ;
  schema:name "alpha scattering experiment"@en ;
  schema:description """the experiment used to discover the atomic nucleus from the deflection of alpha particles fired at it"""@en ;
  dcterms:modified "2026-02-12T08:59:15.816245Z"^^xsd:dateTime .

oakcurric:keyword-short-circuit
  a curric:Keyword ;
  schema:name "short circuit"@en ;
  schema:description "a complete circuit with a very small resistance, often caused by a loose wire"@en ;
  dcterms:modified "2026-02-12T08:59:15.816251Z"^^xsd:dateTime .

oakcurric:keyword-double-insulation
  a curric:Keyword ;
  schema:name "double insulation"@en ;
  schema:description "two layers of electrical insulation, including the outer casing of an appliance"@en ;
  dcterms:modified "2026-02-12T08:59:15.816256Z"^^xsd:dateTime .

oakcurric:keyword-earth-wire
  a curric:Keyword ;
  schema:name "earth wire"@en ;
  schema:description "a wire connected between a metal casing and the ground (0 V)"@en ;
  dcterms:modified "2026-02-12T08:59:15.816260Z"^^xsd:dateTime .

oakcurric:keyword-circuit-breaker
  a curric:Keyword ;
  schema:name "circuit breaker"@en ;
  schema:description """a switch that is turned off by an electromagnet when a dangerously large current flows through it"""@en ;
  dcterms:modified "2026-02-12T08:59:15.816264Z"^^xsd:dateTime .

oakcurric:keyword-force-multiplier
  a curric:Keyword ;
  schema:name "force multiplier"@en ;
  schema:description "A type of lever that increases the size of an applied force."@en ;
  dcterms:modified "2026-02-12T08:59:15.816491Z"^^xsd:dateTime .

oakcurric:keyword-distance-multiplier
  a curric:Keyword ;
  schema:name "distance multiplier"@en ;
  schema:description "A type of lever that increases the distance an applied force moves through."@en ;
  dcterms:modified "2026-02-12T08:59:15.816495Z"^^xsd:dateTime .

oakcurric:keyword-gears
  a curric:Keyword ;
  schema:name "gears"@en ;
  schema:description "Toothed wheels that rotate around an axle and are used to transfer moments."@en ;
  dcterms:modified "2026-02-12T08:59:15.816499Z"^^xsd:dateTime .

oakcurric:keyword-work
  a curric:Keyword ;
  schema:name "work"@en ;
  schema:description """Work is done whenever a force makes an object move. The amount of work is force multiplied by distance moved in the direction of the force."""@en ;
  dcterms:modified "2026-02-12T08:59:15.816504Z"^^xsd:dateTime .

oakcurric:keyword-watt-w
  a curric:Keyword ;
  schema:name "watt (W)"@en ;
  schema:description "The unit for measuring power is the watt (W)."@en ;
  dcterms:modified "2026-02-12T08:59:15.816508Z"^^xsd:dateTime .

oakcurric:keyword-kilowatt-kw
  a curric:Keyword ;
  schema:name "kilowatt (kW)"@en ;
  schema:description "A thousand watts is called a kilowatt (kW)."@en ;
  dcterms:modified "2026-02-12T08:59:15.816512Z"^^xsd:dateTime .

oakcurric:keyword-northseeking-pole
  a curric:Keyword ;
  schema:name "north–seeking pole"@en ;
  schema:description """The part of a magnet that is attracted to the south–seeking pole of another magnet, and to Earth's magnetic North Pole."""@en ;
  dcterms:modified "2026-02-12T08:59:15.816541Z"^^xsd:dateTime .

oakcurric:keyword-magnetic-material
  a curric:Keyword ;
  schema:name "magnetic material"@en ;
  schema:description """A material that is attracted to a magnet. The elements iron, cobalt and nickel, and their alloys (such as steel), are magnetic; non–metals and other metals are not magnetic."""@en ;
  dcterms:modified "2026-02-12T08:59:15.816547Z"^^xsd:dateTime .

oakcurric:keyword-compass-needle
  a curric:Keyword ;
  schema:name "compass needle"@en ;
  schema:description """A tiny magnet in a compass that freely turns to line up with the direction of a magnetic field."""@en ;
  dcterms:modified "2026-02-12T08:59:15.816551Z"^^xsd:dateTime .

oakcurric:keyword-magnetic-field-line
  a curric:Keyword ;
  schema:name "magnetic field line"@en ;
  schema:description """A line with an arrow, showing the direction in which a force acts on the north–seeking pole of a magnet in a magnetic field."""@en ;
  dcterms:modified "2026-02-12T08:59:15.816555Z"^^xsd:dateTime .

oakcurric:keyword-motion-sensor
  a curric:Keyword ;
  schema:name "motion sensor"@en ;
  schema:description """A motion sensor measures the distance between itself and an object. We can use the measurements to calculate and plot graphs of displacement, velocity and acceleration."""@en ;
  dcterms:modified "2026-02-12T08:59:15.816560Z"^^xsd:dateTime .

oakcurric:keyword-conservation-of-energy
  a curric:Keyword ;
  schema:name "conservation of energy"@en ;
  schema:description """The law of conservation of energy states that energy cannot be created or destroyed, but it can be transferred."""@en ;
  dcterms:modified "2026-02-12T08:59:15.816564Z"^^xsd:dateTime .

oakcurric:keyword-joule-j
  a curric:Keyword ;
  schema:name "joule (J)"@en ;
  schema:description """The unit for measuring energy is the joule (J) which is the same as the unit for measuring energy."""@en ;
  dcterms:modified "2026-02-12T08:59:15.816568Z"^^xsd:dateTime .

oakcurric:keyword-kilojoule-kj
  a curric:Keyword ;
  schema:name "kilojoule (kJ)"@en ;
  schema:description "A thousand joules is called a kilojoule (kJ)."@en ;
  dcterms:modified "2026-02-12T08:59:15.816575Z"^^xsd:dateTime .

oakcurric:keyword-earthquake
  a curric:Keyword ;
  schema:name "earthquake"@en ;
  schema:description """An earthquake is caused by the sudden sliding movement of tectonic plates against each other."""@en ;
  dcterms:modified "2026-02-12T08:59:15.816579Z"^^xsd:dateTime .

oakcurric:keyword-s-wave
  a curric:Keyword ;
  schema:name "S wave"@en ;
  schema:description "S waves are transverse seismic waves that travel through solids but not liquids."@en ;
  dcterms:modified "2026-02-12T08:59:15.816583Z"^^xsd:dateTime .

oakcurric:keyword-p-wave
  a curric:Keyword ;
  schema:name "P wave"@en ;
  schema:description """P waves are longitudinal seismic waves that travel at different speeds through solids and liquids."""@en ;
  dcterms:modified "2026-02-12T08:59:15.816587Z"^^xsd:dateTime .

oakcurric:keyword-transverse
  a curric:Keyword ;
  schema:name "transverse"@en ;
  schema:description """A transverse wave is where the wave oscillates perpendicular to the direction of travel."""@en ;
  dcterms:modified "2026-02-12T08:59:15.816591Z"^^xsd:dateTime .

oakcurric:keyword-longitudinal
  a curric:Keyword ;
  schema:name "longitudinal"@en ;
  schema:description """A longitudinal wave is where the wave oscillates along the direction of travel with areas of compression and rarefaction."""@en ;
  dcterms:modified "2026-02-12T08:59:15.816596Z"^^xsd:dateTime .

oakcurric:keyword-transmit
  a curric:Keyword ;
  schema:name "transmit"@en ;
  schema:description """Waves are transmitted when they pass across a boundary from one material (medium) into another."""@en ;
  dcterms:modified "2026-02-12T08:59:15.816600Z"^^xsd:dateTime .

oakcurric:keyword-ear-drum
  a curric:Keyword ;
  schema:name "ear drum"@en ;
  schema:description """The eardrum is a membrane within the ear that is caused to vibrate by incoming sound waves."""@en ;
  dcterms:modified "2026-02-12T08:59:15.816606Z"^^xsd:dateTime .

oakcurric:keyword-cochlea
  a curric:Keyword ;
  schema:name "cochlea"@en ;
  schema:description """The cochlea is a spiral-shaped structure within the ear that creates electrical signals when set vibrating."""@en ;
  dcterms:modified "2026-02-12T08:59:15.816611Z"^^xsd:dateTime .

oakcurric:keyword-infrasound
  a curric:Keyword ;
  schema:name "infrasound"@en ;
  schema:description """Sound waves of frequency below 20 Hz usually cannot be heard by humans, so are called infrasound."""@en ;
  dcterms:modified "2026-02-12T08:59:15.816615Z"^^xsd:dateTime .

oakcurric:keyword-ultrasound
  a curric:Keyword ;
  schema:name "ultrasound"@en ;
  schema:description """Sound waves of frequency above 20 000 Hz usually cannot be heard by humans, so are called ultrasound."""@en ;
  dcterms:modified "2026-02-12T08:59:15.816619Z"^^xsd:dateTime .

oakcurric:keyword-velocity
  a curric:Keyword ;
  schema:name "velocity"@en ;
  schema:description """The velocity of an object is the rate of change of displacement. This is how fast it is moving in a particular direction."""@en ;
  dcterms:modified "2026-02-12T08:59:15.816628Z"^^xsd:dateTime .

oakcurric:keyword-random-motion
  a curric:Keyword ;
  schema:name "random motion"@en ;
  schema:description """Describes the movement of particles in a fluid that travels at a range of speeds in all directions."""@en ;
  dcterms:modified "2026-02-12T08:59:15.817006Z"^^xsd:dateTime .

oakcurric:keyword-convection-current
  a curric:Keyword ;
  schema:name "convection current"@en ;
  schema:description """The movement of fluids caused by differences in density within the fluid, which allows energy to be transferred as the hotter fluid rises to cooler areas."""@en ;
  dcterms:modified "2026-02-12T08:59:15.817011Z"^^xsd:dateTime .

oakcurric:keyword-specific-latent-heat
  a curric:Keyword ;
  schema:name "specific latent heat"@en ;
  schema:description "the change in energy when 1 kg of a substance changes state"@en ;
  dcterms:modified "2026-02-12T08:59:15.817058Z"^^xsd:dateTime .

oakcurric:keyword-specific-heat-capacity
  a curric:Keyword ;
  schema:name "specific heat capacity"@en ;
  schema:description """the change in internal energy when the temperature of 1 kg of a substance changes by 1°C"""@en ;
  dcterms:modified "2026-02-12T08:59:15.817062Z"^^xsd:dateTime .

oakcurric:keyword-chain-reaction
  a curric:Keyword ;
  schema:name "chain reaction"@en ;
  schema:description "occurs when neutrons from nuclear fission go on to cause more fission events"@en ;
  dcterms:modified "2026-02-12T08:59:15.817658Z"^^xsd:dateTime .

oakcurric:keyword-control-rod
  a curric:Keyword ;
  schema:name "control rod"@en ;
  schema:description "used to absorb neutrons in a reactor to reduce the rate of reaction"@en ;
  dcterms:modified "2026-02-12T08:59:15.817662Z"^^xsd:dateTime .

oakcurric:keyword-moderator
  a curric:Keyword ;
  schema:name "moderator"@en ;
  schema:description "used to slow neutrons in a reactor so that they can cause more fission"@en ;
  dcterms:modified "2026-02-12T08:59:15.817666Z"^^xsd:dateTime .

oakcurric:keyword-turbine
  a curric:Keyword ;
  schema:name "turbine"@en ;
  schema:description "rotated by high pressure steam in a power station"@en ;
  dcterms:modified "2026-02-12T08:59:15.817671Z"^^xsd:dateTime .

oakcurric:keyword-electrical-generator
  a curric:Keyword ;
  schema:name "electrical generator"@en ;
  schema:description "produces a potential difference when rotated"@en ;
  dcterms:modified "2026-02-12T08:59:15.817675Z"^^xsd:dateTime .

oakcurric:keyword-alpha-decay
  a curric:Keyword ;
  schema:name "alpha decay"@en ;
  schema:description """the emission of a particle containing two protons and two neutrons from a nucleus"""@en ;
  dcterms:modified "2026-02-12T08:59:15.817681Z"^^xsd:dateTime .

oakcurric:keyword-gamma-radiation
  a curric:Keyword ;
  schema:name "gamma radiation"@en ;
  schema:description "the emission of electromagnetic radiation from a nucleus that reduces its energy"@en ;
  dcterms:modified "2026-02-12T08:59:15.817686Z"^^xsd:dateTime .

oakcurric:keyword-betaminus-decay
  a curric:Keyword ;
  schema:name "beta–minus decay"@en ;
  schema:description """the conversion of a neutron to a proton with the emission of a high speed electron from a nucleus"""@en ;
  dcterms:modified "2026-02-12T08:59:15.817690Z"^^xsd:dateTime .

oakcurric:keyword-nuclear-decay-equations
  a curric:Keyword ;
  schema:name "nuclear decay equations"@en ;
  schema:description "show the changes of particles during nuclear decay processes"@en ;
  dcterms:modified "2026-02-12T08:59:15.817694Z"^^xsd:dateTime .

oakcurric:keyword-energy-transfer
  a curric:Keyword ;
  schema:name "energy transfer"@en ;
  schema:description """Electromagnetic waves transfer energy because stores of energy decrease when they are emitted and increase when they are absorbed."""@en ;
  dcterms:modified "2026-02-12T08:59:15.817698Z"^^xsd:dateTime .

oakcurric:keyword-ionisation
  a curric:Keyword ;
  schema:name "ionisation"@en ;
  schema:description """Ionisation is the process of an atom losing or gaining electrons so become charged/becoming an ion."""@en ;
  dcterms:modified "2026-02-12T08:59:15.817703Z"^^xsd:dateTime .

oakcurric:keyword-ultraviolet
  a curric:Keyword ;
  schema:name "ultraviolet"@en ;
  schema:description """Ultraviolet means EM radiation with frequencies greater than visible light but lower than X–rays."""@en ;
  dcterms:modified "2026-02-12T08:59:15.817707Z"^^xsd:dateTime .

oakcurric:keyword-x-rays
  a curric:Keyword ;
  schema:name "X-rays"@en ;
  schema:description """X-rays are EM radiation with frequencies greater than ultraviolet but lower than gamma rays."""@en ;
  dcterms:modified "2026-02-12T08:59:15.817711Z"^^xsd:dateTime .

oakcurric:keyword-gamma-rays
  a curric:Keyword ;
  schema:name "gamma rays"@en ;
  schema:description "Gamma rays are the highest frequency electromagnetic waves."@en ;
  dcterms:modified "2026-02-12T08:59:15.817716Z"^^xsd:dateTime .

oakcurric:keyword-radioactive-isotopes
  a curric:Keyword ;
  schema:name "radioactive isotopes"@en ;
  schema:description "contain unstable nuclei that will decay over time and emit ionising radiation"@en ;
  dcterms:modified "2026-02-12T08:59:15.817724Z"^^xsd:dateTime .

oakcurric:keyword-radioactive-half-life
  a curric:Keyword ;
  schema:name "radioactive half-life"@en ;
  schema:description "the time taken for the activity of a sample of a radioactive isotope to halve"@en ;
  dcterms:modified "2026-02-12T08:59:15.817729Z"^^xsd:dateTime .

oakcurric:keyword-newtons-first-law-of-motion
  a curric:Keyword ;
  schema:name "Newton’s First Law of motion"@en ;
  schema:description """an object will remain at rest, or in motion in a straight line at constant speed, unless there is a resultant force acting on it"""@en ;
  dcterms:modified "2026-02-12T08:59:15.817765Z"^^xsd:dateTime .

oakcurric:keyword-accelerate
  a curric:Keyword ;
  schema:name "accelerate"@en ;
  schema:description "a change in the speed and/or direction of an object"@en ;
  dcterms:modified "2026-02-12T08:59:15.817769Z"^^xsd:dateTime .

oakcurric:keyword-decelerate
  a curric:Keyword ;
  schema:name "decelerate"@en ;
  schema:description "a decrease in the speed of an object"@en ;
  dcterms:modified "2026-02-12T08:59:15.817773Z"^^xsd:dateTime .

oakcurric:keyword-non-ionising
  a curric:Keyword ;
  schema:name "non-ionising"@en ;
  schema:description """Radio waves, microwaves, infrared and visible light are non–ionising electromagnetic waves, as they cannot remove electrons from atoms."""@en ;
  dcterms:modified "2026-02-12T08:59:15.817780Z"^^xsd:dateTime .

oakcurric:keyword-oscillations
  a curric:Keyword ;
  schema:name "oscillations"@en ;
  schema:description "Oscillations are the vibrations of a wave about a rest position."@en ;
  dcterms:modified "2026-02-12T08:59:15.817784Z"^^xsd:dateTime .

oakcurric:keyword-antenna
  a curric:Keyword ;
  schema:name "antenna"@en ;
  schema:description """An antenna is a metal structure designed to emit or absorb electromagnetic waves."""@en ;
  dcterms:modified "2026-02-12T08:59:15.817789Z"^^xsd:dateTime .

oakcurric:keyword-reproducible
  a curric:Keyword ;
  schema:name "reproducible"@en ;
  schema:description """A measurement is reproducible if the same (or similar) results are obtained when the same person repeats it using a different method, or a different person repeats it using the same method."""@en ;
  dcterms:modified "2026-02-12T08:59:15.817793Z"^^xsd:dateTime .

oakcurric:keyword-anomalous-result
  a curric:Keyword ;
  schema:name "anomalous result"@en ;
  schema:description """An anomalous result is a measurement that is significantly different from the others. It should be crossed out and not used in calculating the mean."""@en ;
  dcterms:modified "2026-02-12T08:59:15.817802Z"^^xsd:dateTime .

oakcurric:keyword-non-contact-force
  a curric:Keyword ;
  schema:name "non-contact force"@en ;
  schema:description "A force that exists between objects, even if they are not touching."@en ;
  dcterms:modified "2026-02-12T08:59:15.818181Z"^^xsd:dateTime .

oakcurric:keyword-contact-force
  a curric:Keyword ;
  schema:name "contact force"@en ;
  schema:description "A force that exists between objects when they are touching."@en ;
  dcterms:modified "2026-02-12T08:59:15.818186Z"^^xsd:dateTime .

oakcurric:keyword-free-body-diagram
  a curric:Keyword ;
  schema:name "free body diagram"@en ;
  schema:description "A diagram showing all of the forces acting on a single object."@en ;
  dcterms:modified "2026-02-12T08:59:15.818190Z"^^xsd:dateTime .

oakcurric:keyword-newtons-third-law
  a curric:Keyword ;
  schema:name "Newton’s Third Law"@en ;
  schema:description """Forces come in equal and opposite pairs, which act on pairs of different objects."""@en ;
  dcterms:modified "2026-02-12T08:59:15.818194Z"^^xsd:dateTime .

oakcurric:keyword-displacementtime-graph
  a curric:Keyword ;
  schema:name "displacement–time graph"@en ;
  schema:description """A displacement–time graph shows the displacement of an object over a period of time."""@en ;
  dcterms:modified "2026-02-12T08:59:15.818199Z"^^xsd:dateTime .

oakcurric:keyword-velocitytime-graph
  a curric:Keyword ;
  schema:name "velocity–time graph"@en ;
  schema:description "A velocity–time graph shows the velocity of an object over a period of time."@en ;
  dcterms:modified "2026-02-12T08:59:15.818203Z"^^xsd:dateTime .

oakcurric:keyword-spectrum
  a curric:Keyword ;
  schema:name "spectrum"@en ;
  schema:description "A spectrum is a continuous range or scale."@en ;
  dcterms:modified "2026-02-12T08:59:15.818207Z"^^xsd:dateTime .

oakcurric:keyword-electromagnet
  a curric:Keyword ;
  schema:name "electromagnet"@en ;
  schema:description "A magnet made by running current through a coil of wire round an iron core."@en ;
  dcterms:modified "2026-02-12T08:59:15.818211Z"^^xsd:dateTime .

oakcurric:keyword-temporary-magnet
  a curric:Keyword ;
  schema:name "temporary magnet"@en ;
  schema:description "An electromagnet that loses its magnetism when current stops flowing through it."@en ;
  dcterms:modified "2026-02-12T08:59:15.818216Z"^^xsd:dateTime .

oakcurric:keyword-electric-lock
  a curric:Keyword ;
  schema:name "electric lock"@en ;
  schema:description "A lock that can be opened with an electromagnet when a switch is closed."@en ;
  dcterms:modified "2026-02-12T08:59:15.818221Z"^^xsd:dateTime .

oakcurric:keyword-electric-bell
  a curric:Keyword ;
  schema:name "electric bell"@en ;
  schema:description """A bell that uses an electromagnet to strike a clapper on the bell and which resets itself to keep ringing."""@en ;
  dcterms:modified "2026-02-12T08:59:15.818226Z"^^xsd:dateTime .

oakcurric:keyword-electric-motor
  a curric:Keyword ;
  schema:name "electric motor"@en ;
  schema:description "A motor that uses a magnetic field to produce a force."@en ;
  dcterms:modified "2026-02-12T08:59:15.818230Z"^^xsd:dateTime .

oakcurric:keyword-change-of-state
  a curric:Keyword ;
  schema:name "change of state"@en ;
  schema:description "changing from a solid to a liquid or liquid to gas (or the reverse)"@en ;
  dcterms:modified "2026-02-12T08:59:15.818239Z"^^xsd:dateTime .

oakcurric:keyword-irradiation
  a curric:Keyword ;
  schema:name "irradiation"@en ;
  schema:description "the effect of exposing an object to radiation"@en ;
  dcterms:modified "2026-02-12T08:59:15.818275Z"^^xsd:dateTime .

oakcurric:keyword-radioactive-contamination
  a curric:Keyword ;
  schema:name "radioactive contamination"@en ;
  schema:description "the transfer of radioactive particles to an object or place"@en ;
  dcterms:modified "2026-02-12T08:59:15.818280Z"^^xsd:dateTime .

oakcurric:keyword-radiation-dose
  a curric:Keyword ;
  schema:name "radiation dose"@en ;
  schema:description "a measure of risk of harm from a person’s exposure to radiation"@en ;
  dcterms:modified "2026-02-12T08:59:15.818284Z"^^xsd:dateTime .

oakcurric:keyword-sievert-sv
  a curric:Keyword ;
  schema:name "sievert (Sv)"@en ;
  schema:description "the unit of radiation dose"@en ;
  dcterms:modified "2026-02-12T08:59:15.818288Z"^^xsd:dateTime .

oakcurric:keyword-radiotherapy
  a curric:Keyword ;
  schema:name "radiotherapy"@en ;
  schema:description "a method for killing cancer cells using radiation"@en ;
  dcterms:modified "2026-02-12T08:59:15.818292Z"^^xsd:dateTime .

oakcurric:keyword-solar-system
  a curric:Keyword ;
  schema:name "solar system"@en ;
  schema:description "the Sun and the collection of objects in orbit around it"@en ;
  dcterms:modified "2026-02-12T08:59:15.818327Z"^^xsd:dateTime .

oakcurric:keyword-planet
  a curric:Keyword ;
  schema:name "planet"@en ;
  schema:description """a very large, spherical object in orbit around a star that has cleared the path of its orbit of other objects"""@en ;
  dcterms:modified "2026-02-12T08:59:15.818331Z"^^xsd:dateTime .

oakcurric:keyword-dwarf-planet
  a curric:Keyword ;
  schema:name "dwarf planet"@en ;
  schema:description """a large object in orbit around a star that has not cleared the path of its orbit of other objects"""@en ;
  dcterms:modified "2026-02-12T08:59:15.818336Z"^^xsd:dateTime .

oakcurric:keyword-moon
  a curric:Keyword ;
  schema:name "moon"@en ;
  schema:description "a natural object in orbit around a planet"@en ;
  dcterms:modified "2026-02-12T08:59:15.818341Z"^^xsd:dateTime .

oakcurric:keyword-limit-of-proportionality
  a curric:Keyword ;
  schema:name "limit of proportionality"@en ;
  schema:description "The largest extension of a spring before it is stretched out of shape."@en ;
  dcterms:modified "2026-02-12T08:59:15.818741Z"^^xsd:dateTime .

oakcurric:keyword-polar-orbit
  a curric:Keyword ;
  schema:name "polar orbit"@en ;
  schema:description "an orbit in which the satellite passes over the poles of a planet"@en ;
  dcterms:modified "2026-02-12T08:59:15.818746Z"^^xsd:dateTime .

oakcurric:keyword-geostationary-orbit
  a curric:Keyword ;
  schema:name "geostationary orbit"@en ;
  schema:description """an orbit in which the satellite is stationary in the sky as it orbits in the same time as the planet, directly above its equator"""@en ;
  dcterms:modified "2026-02-12T08:59:15.818750Z"^^xsd:dateTime .

oakcurric:keyword-orbital-path
  a curric:Keyword ;
  schema:name "orbital path"@en ;
  schema:description "the path a satellite takes around the planet it orbits"@en ;
  dcterms:modified "2026-02-12T08:59:15.818756Z"^^xsd:dateTime .

oakcurric:keyword-orbital-radius
  a curric:Keyword ;
  schema:name "orbital radius"@en ;
  schema:description "the radius of an orbit, measured from the centre of a planet"@en ;
  dcterms:modified "2026-02-12T08:59:15.818761Z"^^xsd:dateTime .

oakcurric:keyword-lambda
  a curric:Keyword ;
  schema:name "lambda"@en ;
  schema:description "(λ) the symbol used for the wavelength of a wave"@en ;
  dcterms:modified "2026-02-12T08:59:15.818765Z"^^xsd:dateTime .

oakcurric:keyword-nuclear-fission
  a curric:Keyword ;
  schema:name "nuclear fission"@en ;
  schema:description """the splitting of large nuclei to form pairs of smaller nuclei and some free neutrons, with the release of energy"""@en ;
  dcterms:modified "2026-02-12T08:59:15.819210Z"^^xsd:dateTime .

oakcurric:keyword-daughter-nuclei
  a curric:Keyword ;
  schema:name "daughter nuclei"@en ;
  schema:description "the smaller nuclei produced during nuclear fission"@en ;
  dcterms:modified "2026-02-12T08:59:15.819214Z"^^xsd:dateTime .

oakcurric:keyword-nuclear-fusion
  a curric:Keyword ;
  schema:name "nuclear fusion"@en ;
  schema:description """the combining of small nuclei at very high temperatures with the release of energy"""@en ;
  dcterms:modified "2026-02-12T08:59:15.819218Z"^^xsd:dateTime .

oakcurric:keyword-inertial-mass
  a curric:Keyword ;
  schema:name "inertial mass"@en ;
  schema:description "The mass determined by Newton’s Second Law of Motion; m = F ÷ a."@en ;
  dcterms:modified "2026-02-12T08:59:15.819227Z"^^xsd:dateTime .

oakcurric:keyword-kinetic-store
  a curric:Keyword ;
  schema:name "kinetic store"@en ;
  schema:description """If an object is moving and has a mass, then there is energy in its kinetic store."""@en ;
  dcterms:modified "2026-02-12T08:59:15.819293Z"^^xsd:dateTime .

oakcurric:keyword-kinetic-energy
  a curric:Keyword ;
  schema:name "kinetic energy"@en ;
  schema:description """The energy an object has in its kinetic store is referred to as the object’s kinetic energy."""@en ;
  dcterms:modified "2026-02-12T08:59:15.819298Z"^^xsd:dateTime .

oakcurric:keyword-renewable-energy-resource
  a curric:Keyword ;
  schema:name "renewable energy resource"@en ;
  schema:description """an energy resource that can be replenished as quickly as it is used or will not run out"""@en ;
  dcterms:modified "2026-02-12T08:59:15.819306Z"^^xsd:dateTime .

oakcurric:keyword-non-renewable-energy-resource
  a curric:Keyword ;
  schema:name "non-renewable energy resource"@en ;
  schema:description """an energy resource that cannot be replenished as quickly as it is used and will eventually run out"""@en ;
  dcterms:modified "2026-02-12T08:59:15.819311Z"^^xsd:dateTime .

oakcurric:keyword-sustainable-energy
  a curric:Keyword ;
  schema:name "sustainable energy"@en ;
  schema:description """using energy resources so that, in the future, there will be enough for people's needs"""@en ;
  dcterms:modified "2026-02-12T08:59:15.819315Z"^^xsd:dateTime .

oakcurric:keyword-internal-energy
  a curric:Keyword ;
  schema:name "internal energy"@en ;
  schema:description """the sum of the kinetic energy and potential energy of the particles something is made of"""@en ;
  dcterms:modified "2026-02-12T08:59:15.819646Z"^^xsd:dateTime .

oakcurric:keyword-potential-energy
  a curric:Keyword ;
  schema:name "potential energy"@en ;
  schema:description "the energy an object has because of its position and the forces acting on it"@en ;
  dcterms:modified "2026-02-12T08:59:15.819650Z"^^xsd:dateTime .

oakcurric:keyword-particles
  a curric:Keyword ;
  schema:name "particles"@en ;
  schema:description "Atoms or molecules that make up matter."@en ;
  dcterms:modified "2026-02-12T08:59:15.819654Z"^^xsd:dateTime .

oakcurric:keyword-upthrust
  a curric:Keyword ;
  schema:name "upthrust"@en ;
  schema:description """A force acting upwards on an object in a liquid due to pressure differences between the top and bottom surface."""@en ;
  dcterms:modified "2026-02-12T08:59:15.819658Z"^^xsd:dateTime .

oakcurric:keyword-ripple-tank
  a curric:Keyword ;
  schema:name "ripple tank"@en ;
  schema:description """A vibrating beam in a ripple tank creates water waves in a clear bottomed container that makes the waves easier to observe."""@en ;
  dcterms:modified "2026-02-12T08:59:15.819663Z"^^xsd:dateTime .

oakcurric:keyword-slow-motion
  a curric:Keyword ;
  schema:name "slow motion"@en ;
  schema:description """A film played back in slow motion shows everything happening slowly, including the speed of a timer shown in the film."""@en ;
  dcterms:modified "2026-02-12T08:59:15.819667Z"^^xsd:dateTime .

oakcurric:keyword-induced-current
  a curric:Keyword ;
  schema:name "induced current"@en ;
  schema:description "The current generated in a circuit moving relative to a magnetic field."@en ;
  dcterms:modified "2026-02-12T08:59:15.819755Z"^^xsd:dateTime .

oakcurric:keyword-milliammeter
  a curric:Keyword ;
  schema:name "milliammeter"@en ;
  schema:description "A sensitive ammeter able to measure thousandths of an amp."@en ;
  dcterms:modified "2026-02-12T08:59:15.819759Z"^^xsd:dateTime .

oakcurric:keyword-air-track
  a curric:Keyword ;
  schema:name "air track"@en ;
  schema:description "A track which uses a cushion of air to reduce frictional forces in experiments."@en ;
  dcterms:modified "2026-02-12T08:59:15.819763Z"^^xsd:dateTime .

oakcurric:keyword-newtons-second-law-of-motion
  a curric:Keyword ;
  schema:name "Newton's Second Law of Motion"@en ;
  schema:description """Newton's Second Law of motion states that the acceleration of an object is directly proportional to the resultant force acting on it and inversely proportional to its mass."""@en ;
  dcterms:modified "2026-02-12T08:59:15.819770Z"^^xsd:dateTime .

oakcurric:keyword-national-grid
  a curric:Keyword ;
  schema:name "National Grid"@en ;
  schema:description """the network that connects all the power stations in the country to make sure that everywhere has access to electricity"""@en ;
  dcterms:modified "2026-02-12T08:59:15.819849Z"^^xsd:dateTime .

oakcurric:keyword-useful-output-energy-transfer
  a curric:Keyword ;
  schema:name "useful output energy transfer"@en ;
  schema:description """The amount of energy usefully transferred by an object or system is the useful output energy transfer."""@en ;
  dcterms:modified "2026-02-12T08:59:15.820110Z"^^xsd:dateTime .

oakcurric:keyword-total-input-energy-transfer
  a curric:Keyword ;
  schema:name "total input energy transfer"@en ;
  schema:description """The total amount of energy transferred to an object or system is the total input energy transfer."""@en ;
  dcterms:modified "2026-02-12T08:59:15.820114Z"^^xsd:dateTime .

oakcurric:keyword-normal-contact-force
  a curric:Keyword ;
  schema:name "normal contact force"@en ;
  schema:description """The overall effect of a set of forces acting on an object is represented by a single resultant force."""@en ;
  dcterms:modified "2026-02-12T08:59:15.820377Z"^^xsd:dateTime .

oakcurric:keyword-medium
  a curric:Keyword ;
  schema:name "medium"@en ;
  schema:description "A medium is the material through which a wave is travelling."@en ;
  dcterms:modified "2026-02-12T08:59:15.820423Z"^^xsd:dateTime .

oakcurric:keyword-total-internal-reflection
  a curric:Keyword ;
  schema:name "total internal reflection"@en ;
  schema:description """Total internal reflection is when waves fully reflect from a boundary to a medium when greater wave speed, rather than being transmitted through."""@en ;
  dcterms:modified "2026-02-12T08:59:15.820427Z"^^xsd:dateTime .

oakcurric:keyword-initial-velocity-u
  a curric:Keyword ;
  schema:name "initial velocity, u"@en ;
  schema:description "is the velocity of an object at the start of a phase of motion, represented by u"@en ;
  dcterms:modified "2026-02-12T08:59:15.820640Z"^^xsd:dateTime .

oakcurric:keyword-final-velocity-v
  a curric:Keyword ;
  schema:name "final velocity, v"@en ;
  schema:description "is the velocity of an object at the end of a phase of motion, represented by v"@en ;
  dcterms:modified "2026-02-12T08:59:15.820644Z"^^xsd:dateTime .

oakcurric:keyword-rate-of-change-of-momentum
  a curric:Keyword ;
  schema:name "rate of change of momentum"@en ;
  schema:description """is the change in momentum per second, this is equal to the resultant force acting on an object"""@en ;
  dcterms:modified "2026-02-12T08:59:15.820649Z"^^xsd:dateTime .

oakcurric:keyword-synchronisation
  a curric:Keyword ;
  schema:name "synchronisation"@en ;
  schema:description """Synchronisation is the process of ensuring two (or more) things happen at the same time."""@en ;
  dcterms:modified "2026-02-12T08:59:15.821048Z"^^xsd:dateTime .

oakcurric:keyword-joules-kilogram-degrees-c
  a curric:Keyword ;
  schema:name "joules / kilogram degrees C"@en ;
  schema:description "The unit for the specific heat capacity of a material (J/kg ºC)."@en ;
  dcterms:modified "2026-02-12T08:59:15.821056Z"^^xsd:dateTime .

oakcurric:keyword-critical-angle
  a curric:Keyword ;
  schema:name "critical angle"@en ;
  schema:description """The critical angle is the greatest angle of incidence before total internal reflection occurs for a boundary to a medium with greater wave speed."""@en ;
  dcterms:modified "2026-02-12T08:59:15.821182Z"^^xsd:dateTime .

oakcurric:keyword-immersion-heater
  a curric:Keyword ;
  schema:name "immersion heater"@en ;
  schema:description "An electrical heating element which can be submerged in liquid to heat it."@en ;
  dcterms:modified "2026-02-12T08:59:15.821454Z"^^xsd:dateTime .

oakcurric:keyword-joulemeter
  a curric:Keyword ;
  schema:name "joulemeter"@en ;
  schema:description "A meter which measures the energy transferred by an electric current."@en ;
  dcterms:modified "2026-02-12T08:59:15.821458Z"^^xsd:dateTime .

oakcurric:keyword-absorption
  a curric:Keyword ;
  schema:name "absorption"@en ;
  schema:description """Absorption is when an electromagnetic wave is incident on a surface and transfers some or all of its energy to that surface."""@en ;
  dcterms:modified "2026-02-12T08:59:15.821463Z"^^xsd:dateTime .

oakcurric:keyword-infrared-radiation
  a curric:Keyword ;
  schema:name "infrared radiation"@en ;
  schema:description """Infrared radiation means electromagnetic waves with frequencies in a range just lower than for red light."""@en ;
  dcterms:modified "2026-02-12T08:59:15.821467Z"^^xsd:dateTime .

oakcurric:keyword-star
  a curric:Keyword ;
  schema:name "star"@en ;
