# ----------------------------------------------------------------------
# Content Descriptors
# ----------------------------------------------------------------------

natcurric:contentdescriptor-objectivity-concern-for-accuracy-precision
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel """Pay attention to objectivity and concern for accuracy, precision, repeatability 
  and reproducibility."""@en ;
  curric:displayOrder "1"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-scientific-attitudes ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-scientific-methods-and-theories-develop
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel """Understand that scientific methods and theories develop as earlier explanations 
  are modified to take account of new evidence and ideas, together with the importance of 
  publishing results and peer review."""@en ;
  curric:displayOrder "2"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-scientific-attitudes ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-evaluate-risks
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Evaluate risks."@en ;
  curric:displayOrder "3"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-scientific-attitudes ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-enquiry-observations-of-real-world
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel """Ask questions and develop a line of enquiry based on observations of the real 
  world, alongside prior knowledge and experience."""@en ;
  curric:displayOrder "1"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-experimental-skills-and-investigations ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-predictions-using-scientific-knowledge-understanding
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Make predictions using scientific knowledge and understanding."@en ;
  curric:displayOrder "2"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-experimental-skills-and-investigations ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-scientific-enquiries-to-test-predictions
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel """Select, plan and carry out the most appropriate types of scientific enquiries 
  to test predictions, including identifying independent, dependent and control variables."""@en ;
  curric:displayOrder "3"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-experimental-skills-and-investigations ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-use-appropriate-techniques-apparatus-materials
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel """Use appropriate techniques, apparatus, and materials during fieldwork and 
  laboratory work, paying attention to health and safety."""@en ;
  curric:displayOrder "4"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-experimental-skills-and-investigations ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-make-record-observations-measurements
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel """Make and record observations and measurements using a range of methods for 
  different investigations; and evaluate the reliability of methods and suggest possible 
  improvements."""@en ;
  curric:displayOrder "5"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-experimental-skills-and-investigations ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-apply-sampling-techniques
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Apply sampling techniques."@en ;
  curric:displayOrder "6"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-experimental-skills-and-investigations ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-si-units-iupac-chemical-nomenclature
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel """Understand and use SI units and IUPAC (International Union of Pure and Applied 
  Chemistry) chemical nomenclature."""@en ;
  curric:displayOrder "1"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-scientific-measurement ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-simple-equations-and-calculations
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Use and derive simple equations and carry out appropriate calculations."@en ;
  curric:displayOrder "2"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-scientific-measurement ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-basic-data-analysis-statistical-techniques
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Undertake basic data analysis including simple statistical techniques."@en ;
  curric:displayOrder "3"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-scientific-measurement ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-scientific-methods-theories-over-time
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "The ways in which scientific methods and theories develop over time."@en ;
  curric:displayOrder "1"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-development-of-scientific-thinking ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-concepts-models-scientific-explanations
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel """Using a variety of concepts and models to develop scientific explanations and 
  understanding."""@en ;
  curric:displayOrder "2"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-development-of-scientific-thinking ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-01-16T17:33:58Z"^^xsd:dateTime .

natcurric:contentdescriptor-power-limitations-ethical-issues
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel """Appreciating the power and limitations of science and considering ethical issues 
  which may arise."""@en ;
  curric:displayOrder "3"^^xsd:positiveInteger ;
  skos:broader natcurric:substrand-development-of-scientific-thinking ;
