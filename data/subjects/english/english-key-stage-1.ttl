# ----------------------------------------------------------------------
# Misconceptions
# ----------------------------------------------------------------------

oakcurric:misconception-pupils-speak-quickly-quietly-look
  a curric:Misconception ;
  curric:statement """Pupils may speak very quickly, quietly and not look up from their page when
  presenting their report."""@en ;
  curric:correction """Techniques for effective presenting are explicitly identified, explained and
  modelled throughout both learning cycles."""@en ;
  dcterms:modified "2026-06-07T15:30:15.084072Z"^^xsd:dateTime .

oakcurric:misconception-children-want-take-their-pencil
  a curric:Misconception ;
  curric:statement """Children may want to take their pencil off before forming the suffix as they
  see it as separate to the root word."""@en ;
  curric:correction """Encourage children by modelling and emphasising that the pencil only comes
  off the page once the letter string is complete. Getting them to identify the last letter
  before starting can help to remind them of this."""@en ;
  dcterms:modified "2026-06-07T15:30:15.084166Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-understand-main-theme
  a curric:Misconception ;
  curric:statement "Pupils may struggle to understand the main theme in a story."@en ;
  curric:correction """Talk about the themes in well-known fairy tales and link these to the lesson
  learnt at the end of the story. For example, the theme in 'The Three Billy Goats Gruff' is
  courage. The goats' courage helps them get to the other side of the river."""@en ;
  dcterms:modified "2026-06-07T15:30:15.084177Z"^^xsd:dateTime .

oakcurric:misconception-pupils-miss-joining-word-writing
  a curric:Misconception ;
  curric:statement """Pupils often miss out the joining word 'and' when writing compound
  sentences."""@en ;
  curric:correction """Show pupils some examples of sentences missing the word 'and' and ask them to
  spot what is missing and where it should go. Encourage pupils to read back through their
  writing to check every sentence makes sense."""@en ;
  dcterms:modified "2026-06-07T15:30:15.084194Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-retrieve-personality-traits
  a curric:Misconception ;
  curric:statement """Pupils may struggle to retrieve personality traits from the book that aren't
  explicitly mentioned."""@en ;
  curric:correction """Refer to things that Ada does, what she is interested in and model how to
  retrieve this from the text and then infer what type of person this makes her."""@en ;
  dcterms:modified "2026-06-07T15:30:15.084224Z"^^xsd:dateTime .

oakcurric:misconception-children-already-thought-different-aspiration
  a curric:Misconception ;
  curric:statement """Children may have already thought about a different aspiration (e.g.
  footballer, singer etc.)"""@en ;
  curric:correction """Encourage pupils to choose a different job if they have requested and work
  with them to find a suitable adjective, such as 'unstoppable footballer' instead of
  'helpful footballer'. The purpose of the task is about aspiration, so any job is suitable."""@en ;
  dcterms:modified "2026-06-07T15:30:15.084230Z"^^xsd:dateTime .

oakcurric:misconception-drawing-large-size-j-dotting
  a curric:Misconception ;
  curric:statement "Drawing a large size j and dotting it to form the capital J."@en ;
  curric:correction """Reminder that the capital J has a horizontal line across the ascender
  line."""@en ;
  dcterms:modified "2026-06-07T15:30:15.084245Z"^^xsd:dateTime .

oakcurric:misconception-children-struggle-get-gap-size
  a curric:Misconception ;
  curric:statement """Children can struggle to get the gap size between the letters correct with
  this join."""@en ;
  curric:correction """Model this join lots emphasising 'we dip down and across and then form the
  next letter so they can still hold hands, we don't want them to be far away from each
  other'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.084251Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-identify-adjectives-within
  a curric:Misconception ;
  curric:statement """Pupils might struggle to identify adjectives within a sentence and confuse
  them with other words."""@en ;
  curric:correction """They will only be exposed to adjectives that come before nouns initially so
  that they become confident in identifying and using them."""@en ;
  dcterms:modified "2026-06-07T15:30:15.084257Z"^^xsd:dateTime .

oakcurric:misconception-confusion-direction-curl-y-j
  a curric:Misconception ;
  curric:statement "Confusion on the direction for the 'curl up' on the y and j."@en ;
  curric:correction """Be consistent with wording and modelling. Left direction is 'curl up' whereas
  'flick' is when the direction is to the right."""@en ;
  dcterms:modified "2026-06-07T15:30:15.084265Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-non-chronological-reports
  a curric:Misconception ;
  curric:statement "Pupils think that non-chronological reports can be informal."@en ;
  curric:correction """Identify key linguistic features, such as subject-specific vocabulary and
  fronted adverbials, which contribute to formal tone."""@en ;
  dcterms:modified "2026-06-07T15:30:15.084387Z"^^xsd:dateTime .

oakcurric:misconception-pupils-miss-double-letters-middle
  a curric:Misconception ;
  curric:statement """Pupils often miss the double letters in the middle of words that have a
  suffix."""@en ;
  curric:correction """Drawing attention to the patterns of how words are spelt when suffixes are
  added will help them to remember the double letter."""@en ;
  dcterms:modified "2026-06-07T15:30:15.084499Z"^^xsd:dateTime .

oakcurric:misconception-child-becomes-confident-keeping-their
  a curric:Misconception ;
  curric:statement """As a child becomes more confident at keeping their pencil on the page, they
  may forget to go back and add the 'dot' for the letter 'i' or the cross for the letter
  't'."""@en ;
  curric:correction """Model to the children that when you finish a word, you look back at it and
  check if anything is missing. Modelling this habit will create the habit for them."""@en ;
  dcterms:modified "2026-06-07T15:30:15.085012Z"^^xsd:dateTime .

oakcurric:misconception-children-struggle-shape-size-loop
  a curric:Misconception ;
  curric:statement """Children can struggle with the shape and size of the loop for the lead in and
  lead out when joining the letter f."""@en ;
  curric:correction """More tracing practice will support children to get a feel for the size and
  shape of the loop."""@en ;
  dcterms:modified "2026-06-07T15:30:15.085024Z"^^xsd:dateTime .

oakcurric:misconception-children-focused-joins-forget-importance
  a curric:Misconception ;
  curric:statement """Children might be so focused on the joins that they forget the importance of
  starting at the correct starting point for the first letter."""@en ;
  curric:correction """When modelling, emphasise to the children that the first time the pencil
  touches the page for the letter needs to be the starting point for the first letter."""@en ;
  dcterms:modified "2026-06-07T15:30:15.085076Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-idea-starting-because
  a curric:Misconception ;
  curric:statement """Pupils may think that an idea starting with 'because' makes complete sense on
  its own."""@en ;
  curric:correction """Make sure that 'because' always begins the second idea so that pupils can
  hear that the idea does not make complete sense by itself."""@en ;
  dcterms:modified "2026-06-07T15:30:15.085087Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-structure-questions
  a curric:Misconception ;
  curric:statement "Pupils may struggle to structure questions."@en ;
  curric:correction """Spend time in the lesson modelling examples of questions using different
  sentence stems and emphasise this using your voice to show you are asking something. Refer
  to the Year 1: simple sentences Grammar unit for a Grammar lesson to teach alongside."""@en ;
  dcterms:modified "2026-06-07T15:30:15.085133Z"^^xsd:dateTime .

oakcurric:misconception-pupils-muddle-letters-words-apostrophe
  a curric:Misconception ;
  curric:statement """Pupils can muddle which letters in the words the apostrophe should appear
  between."""@en ;
  curric:correction """Look at correct examples alongside non-examples and show and read
  non-examples so pupils can see or hear that they do not sound right."""@en ;
  dcterms:modified "2026-06-07T15:30:15.085149Z"^^xsd:dateTime .

oakcurric:misconception-children-struggle-generate-adjectives
  a curric:Misconception ;
  curric:statement "Children may struggle to generate adjectives."@en ;
  curric:correction """The adjectives in this lesson have been deliberately chosen. Repeat the
  adjectives together and emphasise them when reading."""@en ;
  dcterms:modified "2026-06-07T15:30:15.085158Z"^^xsd:dateTime .

oakcurric:misconception-children-unfamiliar-meaning-vocabulary-involved
  a curric:Misconception ;
  curric:statement """Children may be unfamiliar with the meaning of some of the vocabulary involved
  in exploring these author's lives. E.g. 'immerse', 'boarding school', 'hijab'."""@en ;
  curric:correction """Allow opportunities for children to highlight any words they do not know the
  meaning of within each cycle of the lesson and explain the meaning (providing visual aids
  where appropriate) to support children in understanding each author's life."""@en ;
  dcterms:modified "2026-06-07T15:30:15.085166Z"^^xsd:dateTime .

oakcurric:misconception-numeral-8-challenging-children-start
  a curric:Misconception ;
  curric:statement """The numeral 8 can be challenging for children and they may start to lift their
  pencil to form the numeral."""@en ;
  curric:correction """Ensure there are lots of opportunities for the children to trace the numeral
  8 so they can become familiar with how to form it without lifting their pencil."""@en ;
  dcterms:modified "2026-06-07T15:30:15.085172Z"^^xsd:dateTime .

oakcurric:misconception-pupils-find-challenging-differentiate-use
  a curric:Misconception ;
  curric:statement """Pupils may find it challenging to differentiate the use of 'euphoric' and
  'cheerful' in sentences."""@en ;
  curric:correction """'Euphoric' means extreme happiness. Share examples with pupils of when you
  may feel 'euphoric' compared to when you may feel 'cheerful'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.085178Z"^^xsd:dateTime .

oakcurric:misconception-pupils-find-hard-identify-rhythm
  a curric:Misconception ;
  curric:statement "Pupils may find it hard to identify the rhythm of the poem."@en ;
  curric:correction """The best way to model this is through clapping or marching out the rhythm and
  letting them hear the beat."""@en ;
  dcterms:modified "2026-06-07T15:30:15.085183Z"^^xsd:dateTime .

oakcurric:misconception-pupils-find-understanding-concept-non
  a curric:Misconception ;
  curric:statement """Pupils may find understanding the concept of non-chronological
  challenging."""@en ;
  curric:correction """Using examples they're very familiar with, such as the events in a school
  day, will help to explain the concept."""@en ;
  dcterms:modified "2026-06-07T15:30:15.085195Z"^^xsd:dateTime .

oakcurric:misconception-children-write-detailed-information-facts
  a curric:Misconception ;
  curric:statement """Children may write detailed information and facts about the fire in their
  introduction."""@en ;
  curric:correction """An introduction plays a key role in a report and entices the reader to keep
  reading. It should only include brief, general facts."""@en ;
  dcterms:modified "2026-06-07T15:30:15.085223Z"^^xsd:dateTime .

oakcurric:misconception-once-children-start-joining-words
  a curric:Misconception ;
  curric:statement """Once children start joining words they can forget the correct way to join the
  letters and just join them in a random manner."""@en ;
  curric:correction """Let them look at the word first and identify how the letters join, then
  practise and get them to self-assess their joins. Encourage them to identify any mistakes
  so they can learn from these."""@en ;
  dcterms:modified "2026-06-07T15:30:15.085245Z"^^xsd:dateTime .

oakcurric:misconception-children-want-add-cross-t
  a curric:Misconception ;
  curric:statement """Children often want to add the cross for the t when forming that letter rather
  than waiting to the end of the letter string."""@en ;
  curric:correction """Emphasise the flowing motion of cursive writing. The letters need to be
  joined together so the pencil needs to stay on the page."""@en ;
  dcterms:modified "2026-06-07T15:30:15.085652Z"^^xsd:dateTime .

oakcurric:misconception-children-want-add-dot-cross
  a curric:Misconception ;
  curric:statement """Children often want to add the dot for the i and the cross for the t when
  forming that letter rather than waiting to the end of the letter string."""@en ;
  curric:correction """Emphasise the flowing motion of cursive writing. The letters need to be
  joined together so the pencil needs to stay on the page."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087398Z"^^xsd:dateTime .

oakcurric:misconception-tendency-children-form-letter-z
  a curric:Misconception ;
  curric:statement "There is a tendency for children to form the letter z backwards."@en ;
  curric:correction """Model with directions in the room - 'straight across towards the door,
  diagonally back to the window, straight across to the door again'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.090436Z"^^xsd:dateTime .

oakcurric:misconception-pupils-find-difficult-generate-appearance
  a curric:Misconception ;
  curric:statement """Pupils may find it difficult to generate appearance words and may use words
  like 'scary' to describe his appearance as well."""@en ;
  curric:correction """Provide images to support them with generating ideas and explain that they
  can describe the appearance of specific parts of the troll e.g. 'bushy hair', 'sharp
  teeth', 'jagged claws', 'green skin' etc."""@en ;
  dcterms:modified "2026-06-07T15:30:15.090467Z"^^xsd:dateTime .

oakcurric:misconception-pupils-find-difficult-identify-main
  a curric:Misconception ;
  curric:statement """Pupils may find it difficult to identify the main events in the story and they
  may try and include too much on their story mountain."""@en ;
  curric:correction """Explain that the main events are the most important moments in the story.
  Without these moments, the story would not flow. Pick out some elements of the text that
  are minor moments and share these as non-examples."""@en ;
  dcterms:modified "2026-06-07T15:30:15.090482Z"^^xsd:dateTime .

oakcurric:misconception-pupils-try-vary-their-voice
  a curric:Misconception ;
  curric:statement """Pupils may try to vary their voice so much that it makes them difficult to
  hear e.g. speaking too quickly or too quietly."""@en ;
  curric:correction """Explain to the pupils that while we are trying to convey emotions through our
  voice, we also need to maintain a loud enough and clear enough volume for the audience to
  hear us. Model doing this well and not so well."""@en ;
  dcterms:modified "2026-06-07T15:30:15.090518Z"^^xsd:dateTime .

oakcurric:misconception-task-pupils-focus-trying-look
  a curric:Misconception ;
  curric:statement """In Task A, pupils might focus on trying to look like each animal with their
  gestures and facial expressions and not focus enough on the sound each animal would make."""@en ;
  curric:correction """To encourage pupils to think about the voice to use for each animal, you
  could ask them to close their eyes and listen to your voice to guess what animal you are."""@en ;
  dcterms:modified "2026-06-07T15:30:15.090569Z"^^xsd:dateTime .

oakcurric:misconception-pupils-want-use-repeatedly-creating
  a curric:Misconception ;
  curric:statement "Pupils may want to use 'and' repeatedly, creating a long sentence."@en ;
  curric:correction """Give the children an 'and' card. Tell them to keep it in their pockets and
  emphasise they only have one 'and' per sentence, so they have to decide when they have
  used it. Once they have used it for the sentence, they have to give it back!"""@en ;
  dcterms:modified "2026-06-07T15:30:15.090745Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-think-someone-elses
  a curric:Misconception ;
  curric:statement "Pupils may struggle to think from someone else's perspective."@en ;
  curric:correction """Use the 'I do, We do' to model turning yourself into the character. You could
  include props or masks to support as well as providing the stem sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:15.090760Z"^^xsd:dateTime .

oakcurric:misconception-pupils-use-viewpoint-fronted-adverbials
  a curric:Misconception ;
  curric:statement """Pupils may use viewpoint fronted adverbials inaccurately by selecting the
  wrong intensity. For example, using 'shockingly' before a piece of information that isn't
  shocking."""@en ;
  curric:correction """Teach children to accurately guage the intensity of a statement or fact and
  then choose the right viewpoint fronted adverbial to match. You could turn this into a
  game they play in pairs."""@en ;
  dcterms:modified "2026-06-07T15:30:15.090774Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-hedghogs-eat-milk
  a curric:Misconception ;
  curric:statement """Pupils may think that hedghogs can eat milk and bread, due to children's
  stories depicting this."""@en ;
  curric:correction """Explicitly teach the pupils that hedgehogs cannot eat milk or bread and
  instead eat insects and fruits. Watch videos online to support."""@en ;
  dcterms:modified "2026-06-07T15:30:15.090785Z"^^xsd:dateTime .

oakcurric:misconception-children-form-apostrophe-incorrectly-back
  a curric:Misconception ;
  curric:statement """Children may form the apostrophe incorrectly - back to front or locate it at
  the wrong height."""@en ;
  curric:correction """Spend time practising how and where to write the apostrophe, so that it is
  the correct height and orientation."""@en ;
  dcterms:modified "2026-06-07T15:30:15.090863Z"^^xsd:dateTime .

oakcurric:misconception-pupils-see-connections-words-same
  a curric:Misconception ;
  curric:statement """Pupils may not see the connections between words with the same root and
  mis-spell them."""@en ;
  curric:correction """Encourage pupils to use the root word when spelling the new word. 'Happy' is
  connected to 'happier'. They both have a double 'p'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.090869Z"^^xsd:dateTime .

oakcurric:misconception-children-think-words-similar-sounds
  a curric:Misconception ;
  curric:statement "Children may think that all words with similar sounds rhyme."@en ;
  curric:correction """Explain that words need to have the same sound at the end to rhyme. Look at
  words that rhyme and words that do not rhyme, but have the same sound in the middle."""@en ;
  dcterms:modified "2026-06-07T15:30:15.090877Z"^^xsd:dateTime .

oakcurric:misconception-capital-letter-k-look-like
  a curric:Misconception ;
  curric:statement "The capital letter 'K' may look like a lowercase 'k' (without the loop)."@en ;
  curric:correction """Emphasise where the diagonal lines need to go to and model using the capital
  'K' in words, such as 'Kevin' or 'Kick the ball!'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.091726Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-engage-story-dont
  a curric:Misconception ;
  curric:statement "Pupils may struggle to engage in the story if they don't like cats."@en ;
  curric:correction """Spend time discussing Lulu's interest in cats, inviting the children to join
  in by sharing their own passions. This serves as a captivating hook, fostering a
  connection between stories and the children's personal interests."""@en ;
  dcterms:modified "2026-06-07T15:30:15.091821Z"^^xsd:dateTime .

oakcurric:misconception-children-find-difficult-learn-distinguish
  a curric:Misconception ;
  curric:statement """Children sometimes find it difficult to learn and distinguish between raised
  voice and projection."""@en ;
  curric:correction """Model the differences and look at techniques for projection (e.g. breathing
  and speaking from our core)."""@en ;
  dcterms:modified "2026-06-07T15:30:15.091827Z"^^xsd:dateTime .

oakcurric:misconception-pupils-confuse-adverbs-adjectives
  a curric:Misconception ;
  curric:statement "Pupils may confuse adverbs with adjectives."@en ;
  curric:correction """Make sure pupils are exposed to both throughout the lesson so that you can
  discuss the differences. Only focus on -ly adverbs to begin with."""@en ;
  dcterms:modified "2026-06-07T15:30:15.091833Z"^^xsd:dateTime .

oakcurric:misconception-children-remember-one-loops-f
  a curric:Misconception ;
  curric:statement """Children will often remember one of the loops for the f but forget the
  other."""@en ;
  curric:correction """Provide lots of modelling and emphasising that the letter f needs to 'hold
  hands' with the letter in front and behind it."""@en ;
  dcterms:modified "2026-06-07T15:30:15.092406Z"^^xsd:dateTime .

oakcurric:misconception-pupils-look-word-e-associate
  a curric:Misconception ;
  curric:statement """Pupils will look for any word with ‘e’ in it and associate it with the long
  vowel 'ee'."""@en ;
  curric:correction """Teach that ‘e’ can be pronounced in different ways. Emphasise that in most
  words, the 'e' is making an 'e' phoneme."""@en ;
  dcterms:modified "2026-06-07T15:30:15.092480Z"^^xsd:dateTime .

oakcurric:misconception-letters-get-reversed
  a curric:Misconception ;
  curric:statement "Sometimes these letters get reversed."@en ;
  curric:correction """Emphasise the starting position and direction for each letter. You could use
  'landmarks' in your classroom, such as \"Start by the window.\""""@en ;
  dcterms:modified "2026-06-07T15:30:15.092492Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-sentences-make-compound
  a curric:Misconception ;
  curric:statement """Pupils may think that 'and', 'but' or 'or' in sentences always make a compound
  sentence."""@en ;
  curric:correction """Ensure pupils understand that to be a compound sentence, each idea on either
  side of 'and', 'but' or 'or' must have equal weight."""@en ;
  dcterms:modified "2026-06-07T15:30:15.092503Z"^^xsd:dateTime .

oakcurric:misconception-pupils-find-difficult-agree-word
  a curric:Misconception ;
  curric:statement """Pupils may find it difficult to agree on where each word should be placed on
  the scale of 'angry to angriest'."""@en ;
  curric:correction """Explain to pupils that this is subjective and some people may think 'grumpy'
  is more angry than 'annoyed'. Encourage pupils to justify their point using the
  conjunction,' because'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.092508Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-maintain-consistent-tense
  a curric:Misconception ;
  curric:statement """Pupils may struggle to maintain a consistent tense in their writing. Usually,
  this is moving betwen past and present tense."""@en ;
  curric:correction """Teach children that words such as 'was' and 'had' can change the tense of
  verbs to the past tense. Play a game where children have to change present tense verbs
  into past tense."""@en ;
  dcterms:modified "2026-06-07T15:30:15.092523Z"^^xsd:dateTime .

oakcurric:misconception-pupils-choose-inappropriate-fronted-adverbials
  a curric:Misconception ;
  curric:statement """Pupils may choose inappropriate fronted adverbials of manner, which do not
  describe the verb in the most effective way."""@en ;
  curric:correction """Give children printed sentences and printed fronted adverbials of manner and
  allow them to choose the most appropriate one to start each sentence. Children work in
  pairs and then compare with another pair."""@en ;
  dcterms:modified "2026-06-07T15:30:15.092535Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-recipe-require-introduction
  a curric:Misconception ;
  curric:statement "Pupils may think that a recipe would not require an introduction."@en ;
  curric:correction """Show pupils some examples of recipes that include introductions and let them
  analyse them. Teach pupils that an introduction can be effective in making the reader want
  to follow the instructions."""@en ;
  dcterms:modified "2026-06-07T15:30:15.092541Z"^^xsd:dateTime .

oakcurric:misconception-children-put-large-gap-two
  a curric:Misconception ;
  curric:statement """Children often put a large gap between the two digits when forming the number
  10."""@en ;
  curric:correction """When modelling, emphasise that these two digits are 'friends' and like to be
  close together but not touching."""@en ;
  dcterms:modified "2026-06-07T15:30:15.092552Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-link-related-ideas
  a curric:Misconception ;
  curric:statement "Pupils may struggle to link related ideas together."@en ;
  curric:correction """Give some non-examples to show what it sounds like when two ideas are
  unrelated e.g. Dad baked bread and she missed her sister."""@en ;
  dcterms:modified "2026-06-07T15:30:15.092557Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-spot-similarities-two
  a curric:Misconception ;
  curric:statement """Pupils may struggle to spot similarities between two traditional tales
  in LC3."""@en ;
  curric:correction """Throughout LC3, share statements as examples, such as \"The story is about
  three pigs. There were three goats in The Three Billy Goats Gruff\" in order to support
  the pupils to retrieve information from the story they have just read."""@en ;
  dcterms:modified "2026-06-07T15:30:15.092563Z"^^xsd:dateTime .

oakcurric:misconception-many-children-securely-use-correct
  a curric:Misconception ;
  curric:statement "Many children will not securely use the correct pencil grip."@en ;
  curric:correction """Ensure to spend sufficient time checking children's pencil grip and
  intervening where they need extra support."""@en ;
  dcterms:modified "2026-06-07T15:30:15.092581Z"^^xsd:dateTime .

oakcurric:misconception-many-words-high-frequency-common
  a curric:Misconception ;
  curric:statement "Many of these words are high frequency or common exception words."@en ;
  curric:correction """Be explicit about the difficulties in spelling these words and give time to
  practise spelling these common exception words."""@en ;
  dcterms:modified "2026-06-07T15:30:15.092699Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-know-separate-nouns
  a curric:Misconception ;
  curric:statement """Pupils may struggle to know when to separate nouns with a comma and when to
  use 'and'."""@en ;
  curric:correction """Get a list of nouns and discuss where the commas and 'and' will go. Move the
  nouns into a scaffold to ensure it is structured correctly. Spend more time on this as it
  is newer learning. If needed, remove expectation to include adjectives in the list."""@en ;
  dcterms:modified "2026-06-07T15:30:15.093264Z"^^xsd:dateTime .

oakcurric:misconception-children-think-one-setting-story
  a curric:Misconception ;
  curric:statement "Children may think that there can only be one setting in a story."@en ;
  curric:correction """Explain that the setting may change in a story and talk through the different
  settings in 'Grandad's Island'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.093270Z"^^xsd:dateTime .

oakcurric:misconception-students-struggle-direction-go-form
  a curric:Misconception ;
  curric:statement """Often students will struggle with which direction to go to form the numerals
  2, 3, 4 and 5."""@en ;
  curric:correction """Model clearly using physical things in the room to show which direction they
  will be drawing. 'To the left, towards the window' for example."""@en ;
  dcterms:modified "2026-06-07T15:30:15.093275Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-apply-their-knowledge
  a curric:Misconception ;
  curric:statement "Pupils may struggle to apply their knowledge of adverbs."@en ;
  curric:correction """Adapt outcomes or increase the scaffolds where necessary. Word banks should
  assist in generating the vocabulary, but if necessary, remove the expectation of adverb
  use, such as \"Paddington is a kind, friendly bear.\" to describe his personality."""@en ;
  dcterms:modified "2026-06-07T15:30:15.093281Z"^^xsd:dateTime .

oakcurric:misconception-children-struggle-gauge-size-gap
  a curric:Misconception ;
  curric:statement """Children can struggle to gauge the size of the gap between the letters
  joined."""@en ;
  curric:correction """Giving grey examples for the children to trace over can support children to
  become familiar with the distance between the letters."""@en ;
  dcterms:modified "2026-06-07T15:30:15.093292Z"^^xsd:dateTime .

oakcurric:misconception-children-find-difficult-read-words
  a curric:Misconception ;
  curric:statement """Children may find it difficult to read words that are unfamiliar or not
  decodable with phonics strategies, e.g. 'special'."""@en ;
  curric:correction """Pre-teach important vocabulary from the text and explore their
  definitions."""@en ;
  dcterms:modified "2026-06-07T15:30:15.093297Z"^^xsd:dateTime .

oakcurric:misconception-pupils-unable-spell-adjectives-generate
  a curric:Misconception ;
  curric:statement """Pupils may be unable to spell some of the adjectives you generate to describe
  the houses."""@en ;
  curric:correction """As you are generating, create a class word bank for the adjectives. This will
  help pupils to recall them when they are writing and help to spell them correctly."""@en ;
  dcterms:modified "2026-06-07T15:30:15.093325Z"^^xsd:dateTime .

oakcurric:misconception-children-think-ce-represents-s
  a curric:Misconception ;
  curric:statement "Children may think 'ce' represents the 's' sound in 'ice' and 'face'."@en ;
  curric:correction """Use sound buttoning as a strategy when you know it will reinforce the
  spelling pattern (it doesn't always work)."""@en ;
  dcterms:modified "2026-06-07T15:30:15.094165Z"^^xsd:dateTime .

oakcurric:misconception-children-get-confused-sounds-use
  a curric:Misconception ;
  curric:statement """Children can get confused by sounds that use the same spellings, such as 'ar'
  and 'or'."""@en ;
  curric:correction """Remind children that the same sound can be represented in a number of ways
  and the same spelling can represent a number of sounds."""@en ;
  dcterms:modified "2026-06-07T15:30:15.094837Z"^^xsd:dateTime .

oakcurric:misconception-children-overemphasise-w-words-containing
  a curric:Misconception ;
  curric:statement """Some children might overemphasise the w in words containing 'wr' e.g. w-right
  for the word write."""@en ;
  curric:correction """Treat 'wr' as a digraph of the 'r' sound to avoid this confusion and orally
  segment and blend some words with the 'wr' spelling in."""@en ;
  dcterms:modified "2026-06-07T15:30:15.094842Z"^^xsd:dateTime .

oakcurric:misconception-children-think-characters-portrayed-one
  a curric:Misconception ;
  curric:statement """Children may think characters can only be portrayed in one way, e.g. either as
  safe or dangerous."""@en ;
  curric:correction """A character can be described in a variety of ways. This can signal a change
  in their circumstances or demonstrate different impressions."""@en ;
  dcterms:modified "2026-06-07T15:30:15.094848Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-errors-checked-mistakes
  a curric:Misconception ;
  curric:statement """Pupils may think that they have no errors if they have checked for mistakes in
  the writing lesson."""@en ;
  curric:correction """Teach them that editing is a part of the writing process that needs time
  dedicated to improving the word choices and spotting mistakes."""@en ;
  dcterms:modified "2026-06-07T15:30:15.094859Z"^^xsd:dateTime .

oakcurric:misconception-pupils-use-inaccurate-fronted-adverbials
  a curric:Misconception ;
  curric:statement "Pupils may use inaccurate fronted adverbials of time."@en ;
  curric:correction """Teach pupils that the different fronted adverbials of time can control the
  speed of the action being described. Model them being used incorrectly and ask children to
  spot the errors."""@en ;
  dcterms:modified "2026-06-07T15:30:15.094867Z"^^xsd:dateTime .

oakcurric:misconception-children-think-break-letters-dont
  a curric:Misconception ;
  curric:statement """Some children might think the break letters don't join to any letters
  at all."""@en ;
  curric:correction """Model and frequently re-visit the concept that break letters do join to the
  letters before them but don't join to the letters after them. Over exaggerate when
  modelling that you lift your pencil after the break letter."""@en ;
  dcterms:modified "2026-06-07T15:30:15.094875Z"^^xsd:dateTime .

oakcurric:misconception-children-using-ge-dge-interchangeably
  a curric:Misconception ;
  curric:statement "Children may be using 'ge' and 'dge' interchangeably."@en ;
  curric:correction """Be very explicit about 'dge' being found alongside the short vowel and the
  'ge' spelling being found alongside other vowel sounds."""@en ;
  dcterms:modified "2026-06-07T15:30:15.095606Z"^^xsd:dateTime .

oakcurric:misconception-pupils-confused-adjective-included-use
  a curric:Misconception ;
  curric:statement "Pupils may be confused by the adjective 'included' and use it as a verb."@en ;
  curric:correction """Model using 'included' in sentences as a verb and also as an adjective. This
  is a good opportunity to recap word classes."""@en ;
  dcterms:modified "2026-06-07T15:30:15.095626Z"^^xsd:dateTime .

oakcurric:misconception-pupils-write-full-sentences-their
  a curric:Misconception ;
  curric:statement "Pupils may write full sentences in their plan."@en ;
  curric:correction """Teach children how to write notes which are short and capture key vocabulary
  and important information. Encourage children to include adverbs and joining words that
  they want to use, but written out of full sentences."""@en ;
  dcterms:modified "2026-06-07T15:30:15.095631Z"^^xsd:dateTime .

oakcurric:misconception-pupils-make-think-fronted-adverbials
  a curric:Misconception ;
  curric:statement """Pupils make think that fronted adverbials of time can be used in any
  order."""@en ;
  curric:correction """Teach pupils that while some fronted adverbials of time are interchangable,
  there are still many others which must be carefully positioned within a piece of writing
  e.g. First, Finally."""@en ;
  dcterms:modified "2026-06-07T15:30:15.095637Z"^^xsd:dateTime .

oakcurric:misconception-children-find-hard-understand-authorial
  a curric:Misconception ;
  curric:statement """Children may find it hard to understand how authorial word choice conveys
  deeper messaging throughout the story. E.g. 'whisper'."""@en ;
  curric:correction """Spend time discussing and exploring deeper meaning. For example ask the
  children to consider when or why they use a 'whisper'. Analyse how this is linked to the
  character's emotions."""@en ;
  dcterms:modified "2026-06-07T15:30:15.095648Z"^^xsd:dateTime .

oakcurric:misconception-children-become-confused-tramlines-start
  a curric:Misconception ;
  curric:statement """Children can become confused about which of the tramlines to start and end b
  and p on."""@en ;
  curric:correction "Explicit naming of the start and end points and modelling of this."@en ;
  dcterms:modified "2026-06-07T15:30:15.095654Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-recall-event-story
  a curric:Misconception ;
  curric:statement """Pupils may struggle to recall the event of the story to be able to express
  that part."""@en ;
  curric:correction """When you are re-reading the story at the start of the lesson, model the
  expression of the characters as you are reading and drip-feed in some vocabulary that you
  could use."""@en ;
  dcterms:modified "2026-06-07T15:30:15.096113Z"^^xsd:dateTime .

oakcurric:misconception-pupils-find-hard-generate-enough
  a curric:Misconception ;
  curric:statement """Pupils may find it hard to generate enough ambitious vocaulary for
  their plan."""@en ;
  curric:correction """Model each part of the climax and work as a class to generate vocabulary
  before they write their own plan. Pupils could complete plans in pairs or small groups."""@en ;
  dcterms:modified "2026-06-07T15:30:15.096119Z"^^xsd:dateTime .

oakcurric:misconception-children-find-difficult-understand-difference
  a curric:Misconception ;
  curric:statement """Children may find it difficult to understand the difference between stories
  within the genre of folklore."""@en ;
  curric:correction """Explore the differences between folktales and fairytales. For example,
  fairytales are more likely to involve magical or enchanting elements whereas folktales
  tend to reflect real-world settings and events."""@en ;
  dcterms:modified "2026-06-07T15:30:15.096136Z"^^xsd:dateTime .

oakcurric:misconception-pupils-want-introduce-new-ideas
  a curric:Misconception ;
  curric:statement "Pupils may want to introduce new ideas or information in the conclusion."@en ;
  curric:correction """A conclusion does not introduce new information. Its purpose is to summarise
  the key points made previously throughout the text."""@en ;
  dcterms:modified "2026-06-07T15:30:15.096151Z"^^xsd:dateTime .

oakcurric:misconception-pupils-believe-using-co-ordinating
  a curric:Misconception ;
  curric:statement """Pupils may believe using a co-ordinating conjunction always creates a compound
  sentence."""@en ;
  curric:correction """Using a co-ordinating conjunction only creates a compound sentence if the
  conjunction is joining main clauses."""@en ;
  dcterms:modified "2026-06-07T15:30:15.096792Z"^^xsd:dateTime .

oakcurric:misconception-pupils-unsure-constitutes-long-short
  a curric:Misconception ;
  curric:statement "Pupils may be unsure about what constitutes a long or short vowel sound."@en ;
  curric:correction """Be very explicit about what is the short vowel sound, like 'e' in 'ledge' and
  what is a long vowel sound, such as 'ar' in 'large'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.096831Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-generate-vocabulary-places
  a curric:Misconception ;
  curric:statement "Pupils may struggle to generate vocabulary about places or people."@en ;
  curric:correction """Refer back to the previous lessons in the unit where you have generated
  vocabulary and consider how you could use the vocabulary to describe your own experiences.
  Model the process of going back through the previous lesson's writing and word banks."""@en ;
  dcterms:modified "2026-06-07T15:30:15.096847Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-read-story-once
  a curric:Misconception ;
  curric:statement "Pupils may think they should only read a story once."@en ;
  curric:correction """Highlight the importance of reading and re-reading texts to develop greater
  fluency and understanding."""@en ;
  dcterms:modified "2026-06-07T15:30:15.096858Z"^^xsd:dateTime .

oakcurric:misconception-pupils-find-hard-work-together
  a curric:Misconception ;
  curric:statement "Pupils may find it hard to work together as a pair to perform the poem."@en ;
  curric:correction """Teach pupils that performing 'Please Mrs Butler' as a pair will help to
  create the scene and express how the characters are feeling. Model with another adult how
  to work together to perform and react to what the other one is saying."""@en ;
  dcterms:modified "2026-06-07T15:30:15.096872Z"^^xsd:dateTime .

oakcurric:misconception-pupils-find-hard-sequence-events
  a curric:Misconception ;
  curric:statement """Pupils may find it hard to sequence the events/ images after watching the
  animation once."""@en ;
  curric:correction """Provide an opportunity to re-watch the animation. For Task A, print off the
  images and children can work in pairs or small groups to sequence the story on large sugar
  paper."""@en ;
  dcterms:modified "2026-06-07T15:30:15.096892Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-fronted-adverbials-time
  a curric:Misconception ;
  curric:statement "Pupils may think that all fronted adverbials of time do the same job."@en ;
  curric:correction """Teach pupils that different fronted adverbials of time can have different
  impacts on the writing. In parituclar, to speed up or slow down the action."""@en ;
  dcterms:modified "2026-06-07T15:30:15.096903Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-instructions-recipes-looking
  a curric:Misconception ;
  curric:statement """Pupils may think that instructions are always recipes as this is what they are
  looking at in this lesson."""@en ;
  curric:correction """Provide pupils with a varied range of different instructions for them to look
  at and pull out the different features discussed in the lesson."""@en ;
  dcterms:modified "2026-06-07T15:30:15.096911Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-understand-fronted-adverbial
  a curric:Misconception ;
  curric:statement "Pupils may struggle to understand what a fronted adverbial is."@en ;
  curric:correction """Refer to the Year 1: Grammar: Word Class unit and teach alongside
  this unit."""@en ;
  dcterms:modified "2026-06-07T15:30:15.096920Z"^^xsd:dateTime .

oakcurric:misconception-students-struggle-concept-note-taking
  a curric:Misconception ;
  curric:statement """Students may struggle with the concept of note-taking and write in full
  sentences."""@en ;
  curric:correction """Model examples of note-taking by asking students to share their special item
  and demonstrating how to translate this into notes on a flipchart or whiteboard."""@en ;
  dcterms:modified "2026-06-07T15:30:15.096928Z"^^xsd:dateTime .

oakcurric:misconception-adjectives-adverbs-confused
  a curric:Misconception ;
  curric:statement "Adjectives and adverbs are confused."@en ;
  curric:correction """Explain adjectives describe nouns and adverbs describe a verb. Make sure to
  give sufficient examples before expecting the children to write."""@en ;
  dcterms:modified "2026-06-07T15:30:15.096934Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-think-adjectives-compare
  a curric:Misconception ;
  curric:statement "Pupils may struggle to think of adjectives to compare two nouns."@en ;
  curric:correction """Make use of physical objects, images and word banks to support them with
  generating vocabulary."""@en ;
  dcterms:modified "2026-06-07T15:30:15.096953Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-generate-interesting-vocabulary
  a curric:Misconception ;
  curric:statement """Pupils may struggle to generate interesting vocabulary to explain the
  expressions and movements."""@en ;
  curric:correction """The purpose of Learning Cycle 1 is to provide the children with vocabulary.
  Narrate how the children are feeling in their freeze-frames and get them to repeat. For
  example, you may say 'You look panicked.' and the children repeat 'We are panicked.'"""@en ;
  dcterms:modified "2026-06-07T15:30:15.097533Z"^^xsd:dateTime .

oakcurric:misconception-children-assume-rule-applies-verbs
  a curric:Misconception ;
  curric:statement "Children may assume the rule applies to all verbs with no exceptions."@en ;
  curric:correction """Remind children that rules are for most spellings, but not all. There are
  exceptions to the taught rule such as I play - She plays."""@en ;
  dcterms:modified "2026-06-07T15:30:15.097539Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-recount-needs-include
  a curric:Misconception ;
  curric:statement """Pupils may think a recount needs to include every single detail rather than
  just the most important moments."""@en ;
  curric:correction """Teach pupils to be selective about the most important parts when recounting.
  This could be taught by playing a game looking at a school day and choosing the most
  important parts (lunch, playtime, home time) compared to the least important."""@en ;
  dcterms:modified "2026-06-07T15:30:15.097545Z"^^xsd:dateTime .

oakcurric:misconception-children-spell-past-tense-sounds
  a curric:Misconception ;
  curric:statement """Children can often spell the past tense how it sounds, e.g. with a 'd' at the
  end rather than 'ed'."""@en ;
  curric:correction """Before writing the sentence, remind children that the suffix 'ed' can sound
  like 'd' or 'id' or 't'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.097550Z"^^xsd:dateTime .

oakcurric:misconception-children-find-difficult-generate-include
  a curric:Misconception ;
  curric:statement """Children may find it difficult to generate and include the different types of
  fronted adverbials."""@en ;
  curric:correction """Create a shared bank of fronted adverbials that are appropriate for the text
  type and make sure these are available for children to support them in their writing."""@en ;
  dcterms:modified "2026-06-07T15:30:15.097675Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-write-their-own
  a curric:Misconception ;
  curric:statement """Pupils may struggle to write their own sentence about what they are
  responsible for."""@en ;
  curric:correction """If necessary, pupils could just draw a picture and have the sentence scribed
  for them as the primary focus for this session is engaging with the text and understanding
  what responsibility means."""@en ;
  dcterms:modified "2026-06-07T15:30:15.097681Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-bats-nocturnal-because
  a curric:Misconception ;
  curric:statement """Pupils may think that bats are not nocturnal because they can be seen at zoos
  during the day."""@en ;
  curric:correction """Explain that zoos use carefully planned changes of lighting to help the bats
  think that it is night during the day."""@en ;
  dcterms:modified "2026-06-07T15:30:15.097687Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-est-suffix-spelt
  a curric:Misconception ;
  curric:statement """Pupils can think the -est suffix is spelt 'ist' or 'st' because that is what
  you can hear."""@en ;
  curric:correction """Review pupils' misconceptions after practice tasks. Even though the word can
  sound different, -est is always spelt in the same way."""@en ;
  dcterms:modified "2026-06-07T15:30:15.097703Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-make-prediction-know
  a curric:Misconception ;
  curric:statement "Pupils may struggle to make a prediction if they know the story already."@en ;
  curric:correction """Celebrate any stories the pupils know already. Play a game to imagine that
  the memory has gone from their heads and just get them to use the front cover as clues
  imagining they are detectives."""@en ;
  dcterms:modified "2026-06-07T15:30:15.097708Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-performing-poem-same
  a curric:Misconception ;
  curric:statement """Pupils may think that performing a poem is the same as reading a poem
  aloud."""@en ;
  curric:correction """Teach pupils that performing a poem involves carefully considering how to use
  volume and gestures to bring the poem to life for an audience."""@en ;
  dcterms:modified "2026-06-07T15:30:15.098460Z"^^xsd:dateTime .

oakcurric:misconception-writing-list-nouns-pupils-keep
  a curric:Misconception ;
  curric:statement """When writing a list of nouns, pupils may keep extending it or repeatedly use
  'and'."""@en ;
  curric:correction """Tell the children to focus on three nouns only and explicitly model that
  'and' is used before the last noun and the comma is used in between the others."""@en ;
  dcterms:modified "2026-06-07T15:30:15.098465Z"^^xsd:dateTime .

oakcurric:misconception-reasons-support-opinion-equally-convincing
  a curric:Misconception ;
  curric:statement "All reasons to support an opinion are equally convincing."@en ;
  curric:correction """Pupils should know that some reasons are more convincing than others and the
  one used should be the most convincing."""@en ;
  dcterms:modified "2026-06-07T15:30:15.098494Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-reading-expression-purely
  a curric:Misconception ;
  curric:statement "Pupils may think reading with expression is purely about volume."@en ;
  curric:correction """Model reading words, phrases or sentences with and without expression and
  varying volume, pitch and speed. Then model your thought process about why you read it
  that way."""@en ;
  dcterms:modified "2026-06-07T15:30:15.098524Z"^^xsd:dateTime .

oakcurric:misconception-children-mix-meaning-bought-brought
  a curric:Misconception ;
  curric:statement "Children can mix up the meaning of 'bought' and 'brought'."@en ;
  curric:correction """Say the words in sentences several times to establish the meaning, and link
  to the present tense 'buy' and bring'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.099725Z"^^xsd:dateTime .

oakcurric:misconception-children-form-print-version-letter
  a curric:Misconception ;
  curric:statement """Children may form the print version of the letter and then add the 'lead in'
  separately."""@en ;
  curric:correction """Model and emphasise saying 'Ready, line, go' to remind them that the letter
  starts with the lead in on the baseline for pre-cursive letters."""@en ;
  dcterms:modified "2026-06-07T15:30:15.099731Z"^^xsd:dateTime .

oakcurric:misconception-children-get-confused-direction-take
  a curric:Misconception ;
  curric:statement """Children can get confused about the direction to take when forming this
  letter."""@en ;
  curric:correction """Be very explicit about going anti-clockwise, use a clock to emphasise this to
  the children."""@en ;
  dcterms:modified "2026-06-07T15:30:15.101579Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-spelling-generalisations-true
  a curric:Misconception ;
  curric:statement """Pupils can think spelling generalisations are always true e.g. 'er' found at
  the end."""@en ;
  curric:correction """Careful with wording. Say 'ir' and 'ur' are 'often' not 'always' found in the
  middle. Show a familiar exception to the rule if necessary."""@en ;
  dcterms:modified "2026-06-07T15:30:15.101585Z"^^xsd:dateTime .

oakcurric:misconception-pupils-look-word-e-g
  a curric:Misconception ;
  curric:statement """Pupils will look for any word with ‘i’ in it e.g. carried. ‘I’ can be
  pronounced in different ways."""@en ;
  curric:correction """Always tell children to read the word with the most common phoneme for the
  grapheme and check if it makes sense."""@en ;
  dcterms:modified "2026-06-07T15:30:15.101611Z"^^xsd:dateTime .

oakcurric:misconception-dictated-sentence-pupils-write-word
  a curric:Misconception ;
  curric:statement """In the dictated sentence, pupils may write the word 'its' with an apostrophe
  for posession."""@en ;
  curric:correction """Explain this word is an exception and an apostrophe is only used for the
  contracted form of 'it is'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.101645Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-generate-descriptions-facts
  a curric:Misconception ;
  curric:statement "Pupils may struggle to generate descriptions or facts."@en ;
  curric:correction """Refer back to the setting description lesson and have pupils use their word
  banks and senses maps to help join ideas together. Facts are 'drip-fed' throughout the
  lesson. Keep referring back to them and tell pupils that they can choose one of these."""@en ;
  dcterms:modified "2026-06-07T15:30:15.101724Z"^^xsd:dateTime .

oakcurric:misconception-lead-pre-cursive-letter-r
  a curric:Misconception ;
  curric:statement """The lead out on the pre-cursive letter r can be challenging and children can
  sometimes dip too far."""@en ;
  curric:correction """Lots of modelling and opportunities to trace the grey examples will support
  correct formation."""@en ;
  dcterms:modified "2026-06-07T15:30:15.101730Z"^^xsd:dateTime .

oakcurric:misconception-children-struggle-generate-sentence-nouns
  a curric:Misconception ;
  curric:statement """Children may struggle to generate a sentence with these nouns in, such as
  improvement or darkness."""@en ;
  curric:correction """Model all the focus words simply and clearly in sentences to help demonstrate
  the meaning and their place within a sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:15.101735Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-identify-features-traditional
  a curric:Misconception ;
  curric:statement """Pupils may struggle to identify features of traditional tales
  independently."""@en ;
  curric:correction """Use tales that are relevant to your curriculum, including tales they already
  know well. If pupils know stories well, they will find it easier to make links and will
  find it easier to spot other similar features."""@en ;
  dcterms:modified "2026-06-07T15:30:15.101772Z"^^xsd:dateTime .

oakcurric:misconception-children-find-difficult-write-concise
  a curric:Misconception ;
  curric:statement """Children may find it difficult to write concise notes that also contain
  appropriate detail and description."""@en ;
  curric:correction """Developing precise adjectives for their writing is important but the main
  focus should be on recording precise and accurate information. You may wish to provide
  them with a structured planning frame."""@en ;
  dcterms:modified "2026-06-07T15:30:15.102444Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-joining-words-used
  a curric:Misconception ;
  curric:statement """Pupils may think that the joining words used in compound sentences can also be
  used in complex sentences."""@en ;
  curric:correction """Teach pupils that there are only certain joining words that can be used to
  join subordinate ideas to main ideas. Remind pupils that a compound sentence is made up of
  two ideas that make complete sense."""@en ;
  dcterms:modified "2026-06-07T15:30:15.102452Z"^^xsd:dateTime .

oakcurric:misconception-children-understand-able-protect-environment
  a curric:Misconception ;
  curric:statement """Children may not understand what they are able to do to protect the
  environment and animal habitats."""@en ;
  curric:correction """Explain to the children the different ways in which humans can make positive
  choices to combat climate change."""@en ;
  dcterms:modified "2026-06-07T15:30:15.102462Z"^^xsd:dateTime .

oakcurric:misconception-pupils-want-end-sentence-exclamation
  a curric:Misconception ;
  curric:statement "Pupils may want to end every sentence with an exclamation mark."@en ;
  curric:correction """Emphasise that exclamation marks show shock or surprise and lose impact if
  overused. Give pupils a paper exclamation mark to trade in when used, ensuring they use
  only one in this piece of writing."""@en ;
  dcterms:modified "2026-06-07T15:30:15.102468Z"^^xsd:dateTime .

oakcurric:misconception-depending-abilities-pupils-task-b
  a curric:Misconception ;
  curric:statement "Depending on the abilities of the pupils, Task B may be too challenging."@en ;
  curric:correction """Have an adult read the poem out loud to the children and the children echo
  read while also adding some of the actions and voices."""@en ;
  dcterms:modified "2026-06-07T15:30:15.102490Z"^^xsd:dateTime .

oakcurric:misconception-children-assume-muslim-women-wear
  a curric:Misconception ;
  curric:statement """Children may assume that all Muslim women wear a hijab or struggle to
  understand why some do and some don't."""@en ;
  curric:correction """Expand upon the cultural and religious significance of the hijab as well as
  individual choice."""@en ;
  dcterms:modified "2026-06-07T15:30:15.102504Z"^^xsd:dateTime .

oakcurric:misconception-children-find-difficult-distinguish-natural
  a curric:Misconception ;
  curric:statement """Children may find it difficult to distinguish between natural elements, human
  elements and items/belongings that could be pickled."""@en ;
  curric:correction """Explore the difference and definition of each of these as well as
  acknowledging things that may fit into multiple categories. E.g. An avocado is naturally
  grown and there may be a special sensory experience or memory related to it."""@en ;
  dcterms:modified "2026-06-07T15:30:15.102524Z"^^xsd:dateTime .

oakcurric:misconception-pupils-confuse-use-adjective-verb
  a curric:Misconception ;
  curric:statement "Pupils may confuse when to use an adjective or verb."@en ;
  curric:correction """Scaffold this for pupils using sentence stems throughout the lesson. Support
  pupils' grammar knowledge by referring to Lessons 3 and 6 in the 'Word class' unit."""@en ;
  dcterms:modified "2026-06-07T15:30:15.102546Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-fire-happened-recent
  a curric:Misconception ;
  curric:statement "Pupils might think that the fire happened in the more recent past."@en ;
  curric:correction """London was a very different city to what it is now and the buildings were
  entirely different, which played a key part in the fire spreading"""@en ;
  dcterms:modified "2026-06-07T15:30:15.102555Z"^^xsd:dateTime .

oakcurric:misconception-pupils-find-difficult-recognise-idea
  a curric:Misconception ;
  curric:statement """Pupils may find it difficult to recognise that an idea must make sense on its
  own."""@en ;
  curric:correction """Model identifying the two ideas lots of times throughout the lesson before
  challenging pupils to do this themselves."""@en ;
  dcterms:modified "2026-06-07T15:30:15.102620Z"^^xsd:dateTime .

oakcurric:misconception-ou-ui-spelling-pronounced-different
  a curric:Misconception ;
  curric:statement """The 'ou' and 'ui' spelling can be pronounced in different ways e.g. suit vs
  build or soup vs shout."""@en ;
  curric:correction """Be explicit with children about these different pronunciations and give them
  the opportunity to read words out loud to check."""@en ;
  dcterms:modified "2026-06-07T15:30:15.102654Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-sequence-their-sequencing
  a curric:Misconception ;
  curric:statement "Pupils may struggle to sequence their sequencing language."@en ;
  curric:correction """Either provide a word bank of sequencing words 'First,', 'Then,' etc. or
  encourage children who struggle with this to only sequence using numbers."""@en ;
  dcterms:modified "2026-06-07T15:30:15.102872Z"^^xsd:dateTime .

oakcurric:misconception-pupils-find-harder-describe-characters
  a curric:Misconception ;
  curric:statement """Pupils may find it harder to describe a character's personality, especially
  from an animation with nothing written down."""@en ;
  curric:correction """Encourage pupils to analyse the character's actions in the animation
  carefully, thinking about what this tells us about their personality. Model some examples
  e.g. Emily leaves her parents and enters the arcade alone - this tells us she is brave."""@en ;
  dcterms:modified "2026-06-07T15:30:15.102895Z"^^xsd:dateTime .

oakcurric:misconception-children-assume-pre-cursive-letters
  a curric:Misconception ;
  curric:statement "Children may assume all pre-cursive letters have a lead out."@en ;
  curric:correction """When modelling the break letters, ensure to emphasise 'break' to remind the
  children not to add a lead out."""@en ;
  dcterms:modified "2026-06-07T15:30:15.102917Z"^^xsd:dateTime .

oakcurric:misconception-pupils-use-add-another-word
  a curric:Misconception ;
  curric:statement """Pupils may just use 'and' to add on another word or phrase rather than another
  sentence."""@en ;
  curric:correction """Show two different sentences as two complete ideas. Ensure pupils understand
  that each sentence needs to make sense on its own."""@en ;
  dcterms:modified "2026-06-07T15:30:15.102923Z"^^xsd:dateTime .

oakcurric:misconception-pupils-try-join-two-ideas
  a curric:Misconception ;
  curric:statement "Pupils may try to join more than two ideas using \"and\"."@en ;
  curric:correction """Remind pupils that \"and\" only likes to be used once in a sentence, joining
  only two ideas."""@en ;
  dcterms:modified "2026-06-07T15:30:15.104175Z"^^xsd:dateTime .

oakcurric:misconception-pupils-add-capital-letter-full
  a curric:Misconception ;
  curric:statement """Pupils may add a capital letter and full stop to their caption e.g. 'Fresh
  cucumber.'."""@en ;
  curric:correction """When modelling, explain a caption is not a sentence. Model mistakes for
  children to discuss and check."""@en ;
  dcterms:modified "2026-06-07T15:30:15.104445Z"^^xsd:dateTime .

oakcurric:misconception-pupils-mistake-expanded-noun-phrase
  a curric:Misconception ;
  curric:statement "Pupils may mistake an expanded noun phrase as a sentence."@en ;
  curric:correction """Discuss what is missing from the expanded noun phrase to show it is not a
  sentence (a verb and a capital letter or punctuation mark to end a sentence). In the
  subsequent lessons, pupils will build their expanded noun phrases into sentences."""@en ;
  dcterms:modified "2026-06-07T15:30:15.104477Z"^^xsd:dateTime .

oakcurric:misconception-confusion-now-know-new-knew
  a curric:Misconception ;
  curric:statement """Confusion of 'now'/'know' and 'new'/'knew'. 'Ow' can be pronounced in
  different ways."""@en ;
  curric:correction """Teach examples of silent letters explicitly and get children to keep an eye
  out for them in their wider reading."""@en ;
  dcterms:modified "2026-06-07T15:30:15.104491Z"^^xsd:dateTime .

oakcurric:misconception-last-sentence-modelled-paragraph-command
  a curric:Misconception ;
  curric:statement """The last sentence of the modelled paragraph is a command and an exclamation.
  Children may form the misconception that a command is always an exclamation or visa versa."""@en ;
  curric:correction """Explore examples of imperative verbs used to form a command and show examples
  of commands without an exclamation. Explore examples of exclamations that are not a
  command."""@en ;
  dcterms:modified "2026-06-07T15:30:15.104938Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-know-whether-best
  a curric:Misconception ;
  curric:statement """Pupils might struggle to know whether 'and', 'but' or 'or' is best in a
  compound sentence."""@en ;
  curric:correction """Share and discuss many examples and non-examples where 'and', 'but' or 'or'
  works best in a sentence in comparison with the other options."""@en ;
  dcterms:modified "2026-06-07T15:30:15.104947Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-name-features-non
  a curric:Misconception ;
  curric:statement """Pupils may struggle to name the features of a non-fiction text (contents,
  glossary, caption etc.)"""@en ;
  curric:correction """This content will continue to be covered as the children move through school.
  The key learning here is understanding the difference between fiction and non-fiction.
  Continue to model the language and point out the differences for the children."""@en ;
  dcterms:modified "2026-06-07T15:30:15.104998Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-present-their-information
  a curric:Misconception ;
  curric:statement "Pupils may struggle to present their information independently."@en ;
  curric:correction """Create page layouts with boxes and lines for the children to use in order for
  presentation and handwriting to stay at their expected level. This may mean their reports
  go across multiple pages or use larger paper."""@en ;
  dcterms:modified "2026-06-07T15:30:15.105015Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-identify-similarities-differences
  a curric:Misconception ;
  curric:statement "Pupils may struggle to identify similarities and differences."@en ;
  curric:correction """Repeating the two nursery rhymes again is useful to support. Additionally,
  you can scaffold the discussion by asking questions and modelling your thought process,
  such as \"Do both nursery rhymes have animals?\" or \"Are both nursery rhymes set
  inside?\""""@en ;
  dcterms:modified "2026-06-07T15:30:15.105109Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-rhyming-words
  a curric:Misconception ;
  curric:statement "Pupils may struggle with the rhyming words."@en ;
  curric:correction """The purpose of this unit and lesson is to introduce poetry, discuss
  preferences and perform. Spend most time engaging with the rhyme through understanding,
  listening and practising singing. Provide more direct instruction for the rhyming
  elements."""@en ;
  dcterms:modified "2026-06-07T15:30:15.105140Z"^^xsd:dateTime .

oakcurric:misconception-children-hear-d-t-id
  a curric:Misconception ;
  curric:statement """Children hear 'd', 't' or 'id' at the end of the word and spell it
  that way."""@en ;
  curric:correction """Explain that sometimes the ending sounds like ‘t’, ‘d’ or ‘id’ but it is
  still spelt with the suffix -ed."""@en ;
  dcterms:modified "2026-06-07T15:30:15.105181Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-make-inferences
  a curric:Misconception ;
  curric:statement "Pupils may struggle to make inferences."@en ;
  curric:correction """Lots of inference skills are based on our knowledge and understanding of the
  world or prior experiences. Provide pupils with the knowledge to model the thought
  processes to then help them form their answers."""@en ;
  dcterms:modified "2026-06-07T15:30:15.105234Z"^^xsd:dateTime .

oakcurric:misconception-children-notice-familiar-word-used
  a curric:Misconception ;
  curric:statement """Children may notice a familiar word being used in a new way and not understand
  its meaning, e.g. making a \"toast\"."""@en ;
  curric:correction """Explore words that have more than one definition and how we can infer meaning
  through understanding the context in which it has been used."""@en ;
  dcterms:modified "2026-06-07T15:30:15.105336Z"^^xsd:dateTime .

oakcurric:misconception-students-commonly-forget-comma-fronted
  a curric:Misconception ;
  curric:statement "Students commonly forget the comma after fronted adverbials."@en ;
  curric:correction """Model sentences including fronted adverbials missing the comma and ask
  students to spot the punctuation error."""@en ;
  dcterms:modified "2026-06-07T15:30:15.106700Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-generate-vocabulary-explain
  a curric:Misconception ;
  curric:statement """Pupils may struggle to generate vocabulary to explain the expressions and
  movements."""@en ;
  curric:correction """The purpose of learning cycle 1 is to provide the children with vocabulary.
  Narrate how the children are feeling in their freeze-frames and get them to repeat. For
  example, you may say 'You look famished.' and the children repeat 'We are famished'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.106734Z"^^xsd:dateTime .

oakcurric:misconception-autumn-assumed-capital-letter-name
  a curric:Misconception ;
  curric:statement """Autumn can also be assumed to have a capital letter, as the name of a
  season."""@en ;
  curric:correction """Explain that convention is generally not to capitalise the names of the
  seasons."""@en ;
  dcterms:modified "2026-06-07T15:30:15.107451Z"^^xsd:dateTime .

oakcurric:misconception-common-exception-words-hard-sound
  a curric:Misconception ;
  curric:statement """Common exception words which are hard to sound out e.g. 'there' and 'where'
  may be misspelt."""@en ;
  curric:correction """Put these words into sentences and explain that often we have to learn to
  spell them by sight because spellings rules don't apply."""@en ;
  dcterms:modified "2026-06-07T15:30:15.107457Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-generate-descriptive-language
  a curric:Misconception ;
  curric:statement "Pupils may struggle to generate descriptive language for Task B."@en ;
  curric:correction """Provide pupils with a word bank that includes two columns: expanded noun
  phrases and verbs. Encourage pupils to pick at least one from each column and add it it to
  their story mountain."""@en ;
  dcterms:modified "2026-06-07T15:30:15.107500Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-need-plan-ordering
  a curric:Misconception ;
  curric:statement """Pupils may think that they do not need to plan the ordering fronted adverbials
  they'll use because they are self-explanatory, with 'First' at the beginning and 'Finally'
  at the end."""@en ;
  curric:correction """Teach them that there are lots of different ordering fronted adverbials and
  some of them can be interchanged, such as 'Next' and 'Then'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.107641Z"^^xsd:dateTime .

oakcurric:misconception-even-exception-rule-looking-generalisations
  a curric:Misconception ;
  curric:statement """Even is an exception to the rule when looking at generalisations for the e-e
  split digraph."""@en ;
  curric:correction """Explicitly refer to this during teaching and ensure practise is given to
  spelling exception words."""@en ;
  dcterms:modified "2026-06-07T15:30:15.108248Z"^^xsd:dateTime .

oakcurric:misconception-certain-spelling-exceptions-general-rules
  a curric:Misconception ;
  curric:statement """There are certain spelling exceptions to the general rules taught in this
  lesson."""@en ;
  curric:correction """Explicitly teach some of these exceptions ('crayon') and explain the addition
  of suffixes to root words ('playing' or 'rained')."""@en ;
  dcterms:modified "2026-06-07T15:30:15.108260Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-identify-noun-belongs
  a curric:Misconception ;
  curric:statement "Pupils may struggle to identify which noun belongs to another noun."@en ;
  curric:correction """Ensure pupils have a solid grasp of what a noun is and that they always
  identify the nouns in any example."""@en ;
  dcterms:modified "2026-06-07T15:30:15.108273Z"^^xsd:dateTime .

oakcurric:misconception-children-think-writing-diary-another
  a curric:Misconception ;
  curric:statement """Children may just think that writing a diary is just another task they have to
  do, rather than a personal and creative outlet."""@en ;
  curric:correction """Teach the children the benefits of keeping a diary. Link this to their mental
  health and how this will help them to maintain positive mental health."""@en ;
  dcterms:modified "2026-06-07T15:30:15.108282Z"^^xsd:dateTime .

oakcurric:misconception-children-find-difficult-understand-themes
  a curric:Misconception ;
  curric:statement """Children may find it difficult to understand some of the themes and the
  connections between them."""@en ;
  curric:correction """Allow time to discuss the connections between the three themes at the end of
  cycle 1. E.g. Collaboration can be a form of resourcefulness."""@en ;
  dcterms:modified "2026-06-07T15:30:15.108290Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-expanded-noun-phrases
  a curric:Misconception ;
  curric:statement "Pupils might think expanded noun phrases are full sentences."@en ;
  curric:correction """Clearly highlight that these groups of words are called phrases. Provide lots
  of exposure to phrases not sentences."""@en ;
  dcterms:modified "2026-06-07T15:30:15.108296Z"^^xsd:dateTime .

oakcurric:misconception-oo-yoo-sound-confused
  a curric:Misconception ;
  curric:statement "The 'oo' and 'yoo' sound are often confused."@en ;
  curric:correction """Show examples of words where the same grapheme is making the 'oo' and the
  'yoo' sound. Give practice reading aloud to hear the difference."""@en ;
  dcterms:modified "2026-06-07T15:30:15.109170Z"^^xsd:dateTime .

oakcurric:misconception-forming-capital-letter-lower-case
  a curric:Misconception ;
  curric:statement """Forming a capital letter is just doing the lower case letter formation
  bigger."""@en ;
  curric:correction """Highlight every time the lower case and capital letter is different so it is
  clear the formation is different not just the size."""@en ;
  dcterms:modified "2026-06-07T15:30:15.109186Z"^^xsd:dateTime .

oakcurric:misconception-getting-correct-position-angle-diagonal
  a curric:Misconception ;
  curric:statement """Getting the correct position and angle for the diagonal lines on the letters A
  and K can be challenging at first."""@en ;
  curric:correction """Give the children extra tracing opportunities for these letters to support
  their spatial awareness."""@en ;
  dcterms:modified "2026-06-07T15:30:15.109210Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-sequence-their-instructions
  a curric:Misconception ;
  curric:statement "Pupils may struggle to sequence their instructions."@en ;
  curric:correction """Complete lesson 8 first as this breaks down how to write commands needed for
  the lesson. Allow pupils to then use their instructions to present and add to their
  information page."""@en ;
  dcterms:modified "2026-06-07T15:30:15.109224Z"^^xsd:dateTime .

oakcurric:misconception-first-children-find-writing-full
  a curric:Misconception ;
  curric:statement """At first, children might find writing a full sentence in cursive overwhelming
  and forget the correct joins. This would result in the words being joined in a random
  manner."""@en ;
  curric:correction """Give them time to think about their sentence before starting. Model writing a
  sentence slowly and thinking out loud about which joins to use. This will encourage the
  children to do the same."""@en ;
  dcterms:modified "2026-06-07T15:30:15.109235Z"^^xsd:dateTime .

oakcurric:misconception-children-find-difficult-identify-main
  a curric:Misconception ;
  curric:statement """Children may find it difficult to identify the main events in the story and
  they may try to include too much information."""@en ;
  curric:correction """Explain that the main events are the most important moments in the story.
  Without these moments, the story would not flow. Pick out some elements of the text that
  are minor moments and share these as non-examples."""@en ;
  dcterms:modified "2026-06-07T15:30:15.109249Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-spell-put-christmas
  a curric:Misconception ;
  curric:statement "Pupils may struggle to spell 'put' and 'Christmas'."@en ;
  curric:correction """Point out the naughty letter 'u' in put and 't' in Christmas. The root word
  'Christ' is in Christmas, but it's pronounced differently. In some accents, the 'u' in
  'put' may not be an exception."""@en ;
  dcterms:modified "2026-06-07T15:30:15.110174Z"^^xsd:dateTime .

oakcurric:misconception-pupils-find-challenging-know-inspires
  a curric:Misconception ;
  curric:statement "Pupils may find it challenging to know what or who inspires them."@en ;
  curric:correction """When introducing 'inspired', talk about pupils' different sources of
  inspiration and how this impacts them."""@en ;
  dcterms:modified "2026-06-07T15:30:15.110185Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-think-reasons-their
  a curric:Misconception ;
  curric:statement "Pupils may struggle to think of reasons for their opinions."@en ;
  curric:correction """Give pupils some different possible reasons based on evidence from the text
  allowing them to choose from a list of reasons if necessary."""@en ;
  dcterms:modified "2026-06-07T15:30:15.110202Z"^^xsd:dateTime .

oakcurric:misconception-pupils-describe-setting-solely-based
  a curric:Misconception ;
  curric:statement "Pupils may describe the setting solely based on what can be seen."@en ;
  curric:correction """Teach pupils to use more than just one of their senses to create a more
  detailed description. Provide additional support e.g. playing beach sounds, bringing in
  sand for children to feel."""@en ;
  dcterms:modified "2026-06-07T15:30:15.110236Z"^^xsd:dateTime .

oakcurric:misconception-pupils-find-hard-describe-setting
  a curric:Misconception ;
  curric:statement """Pupils may find it hard to describe the setting and the reader may struggle to
  picture it in detail."""@en ;
  curric:correction """Teach pupils that describing the setting using expanded noun phrases will
  help to add detail. Refer back to Lesson 2 where children will have created a sensory map
  of the setting."""@en ;
  dcterms:modified "2026-06-07T15:30:15.110267Z"^^xsd:dateTime .

oakcurric:misconception-children-think-families-look-like
  a curric:Misconception ;
  curric:statement "Children might think that all families look like their own."@en ;
  curric:correction """Emphasise the idea that all families are different and families go beyond
  just the people you live with."""@en ;
  dcterms:modified "2026-06-07T15:30:15.110998Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-poem-cannot-written
  a curric:Misconception ;
  curric:statement """Pupils may think that a poem cannot be written from the perspective of an
  object that isn't alive."""@en ;
  curric:correction """Teach pupils that personification is a fun and imaginative poetic technique
  to know and use."""@en ;
  dcterms:modified "2026-06-07T15:30:15.111006Z"^^xsd:dateTime .

oakcurric:misconception-pupils-find-hard-think-reasons
  a curric:Misconception ;
  curric:statement "Pupils may find it hard to think of reasons they like the dark."@en ;
  curric:correction """Brainstorm ideas beforehand as a class and if possible use two adults to
  model hot-seating before the children start the task."""@en ;
  dcterms:modified "2026-06-07T15:30:15.111012Z"^^xsd:dateTime .

oakcurric:misconception-children-already-know-story-therefore
  a curric:Misconception ;
  curric:statement """Children may already know the story, so therefore will be unable to make a
  prediction."""@en ;
  curric:correction """Celebrate if children have heard a version before. Play a game to imagine
  that memory has gone from their heads and just get them to use the front cover as clues
  imagining they are detectives."""@en ;
  dcterms:modified "2026-06-07T15:30:15.111038Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-generate-their-own
  a curric:Misconception ;
  curric:statement """Pupils may struggle to generate their own vocabulary or understand the
  vocabulary given to them."""@en ;
  curric:correction """In LC2, look at the children's expression when they are freeze framing. Then,
  put the description into a sentence e.g. 'You look terrified.'. The children mirror the
  facial expression and tone from you and then repeat the sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:15.111058Z"^^xsd:dateTime .

oakcurric:misconception-ea-pronounced-number-different-ways
  a curric:Misconception ;
  curric:statement "'ea' can be pronounced in a number of different ways (/ee/, /ay/, /e/)"@en ;
  curric:correction """Explicitly teach the most common spellings of the 'ea' spelling for the 'e'
  sound. Give time to practising both reading and writing them."""@en ;
  dcterms:modified "2026-06-07T15:30:15.111649Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-words-rhyme-spelled
  a curric:Misconception ;
  curric:statement "Pupils may think that words can only rhyme if they are spelled the same."@en ;
  curric:correction """Teach pupils that sometimes words have different spellings at the end, but
  can still be rhyming words as they make the same sound."""@en ;
  dcterms:modified "2026-06-07T15:30:15.111657Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-words-ambitious-vocabulary
  a curric:Misconception ;
  curric:statement "Pupils may think that all words are ambitious vocabulary."@en ;
  curric:correction """Teach pupils that there can be multiple options when selecting vocabulary and
  they need to carefully choose the most precise words in their writing."""@en ;
  dcterms:modified "2026-06-07T15:30:15.111680Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-give-reason-their
  a curric:Misconception ;
  curric:statement "Pupils may struggle to give a reason for their opinion."@en ;
  curric:correction """Model lots of examples using 'because' to expand upon their choice. Call on
  confident pupils to share their reasons for their opinions and give lots of praise for
  using 'because' in a sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:15.111697Z"^^xsd:dateTime .

oakcurric:misconception-pupils-remember-question-mark-end
  a curric:Misconception ;
  curric:statement "Pupils may not remember the question mark at the end of a question."@en ;
  curric:correction """When saying the questions aloud, encourage pupils to draw the question mark
  in the air, or say 'question mark' out loud to help them remember."""@en ;
  dcterms:modified "2026-06-07T15:30:15.111702Z"^^xsd:dateTime .

oakcurric:misconception-children-ks1-project-their-voices
  a curric:Misconception ;
  curric:statement "Children in KS1 might not project their voices or speak loudly."@en ;
  curric:correction """Show children a simple volume scale or traffic light system to visually
  represent the desired volume level."""@en ;
  dcterms:modified "2026-06-07T15:30:15.111711Z"^^xsd:dateTime .

oakcurric:misconception-children-lift-their-pencils-form
  a curric:Misconception ;
  curric:statement "Children may lift their pencils to form the joins."@en ;
  curric:correction """Remind the children that the letters are joining and holding hands. If you
  lift your pencil then you are breaking the chain."""@en ;
  dcterms:modified "2026-06-07T15:30:15.111717Z"^^xsd:dateTime .

oakcurric:misconception-pupils-tick-their-success-criteria
  a curric:Misconception ;
  curric:statement "Pupils may tick their success criteria without checking and correcting."@en ;
  curric:correction """When you are modelling your write, continuously refer back to the success
  criteria yourself. Adapt the success criteria accordingly to help pupils experience
  success."""@en ;
  dcterms:modified "2026-06-07T15:30:15.112490Z"^^xsd:dateTime .

oakcurric:misconception-pupils-want-write-exact-same
  a curric:Misconception ;
  curric:statement """Pupils may want to write the exact same sentence from the non-fiction
  text."""@en ;
  curric:correction """In the first learning cycle, when repeating what they have learnt, re-phrase
  it into simple sentences that they could write in the next learning cycle. You could
  provide pictures linked to the facts to guide them towards specific ideas."""@en ;
  dcterms:modified "2026-06-07T15:30:15.112499Z"^^xsd:dateTime .

oakcurric:misconception-learning-cycle-2-pupils-think
  a curric:Misconception ;
  curric:statement """In Learning Cycle 2, pupils might think you are asking them if they agree,
  rather than asking them to identify who agrees out of the 3 characters - Aisha, Sofia and
  Alex."""@en ;
  curric:correction """Read each of the opinions in the speech bubbles out and ask the pupils who
  agrees that the class should get a pet."""@en ;
  dcterms:modified "2026-06-07T15:30:15.112505Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-spell-root-word
  a curric:Misconception ;
  curric:statement "Pupils may struggle to spell the root word."@en ;
  curric:correction """As we are adding new learning, it's key to refer back to prior learning (in
  prior Y2 units as well as Rec and Y1). Refer back to learning in line with your school's
  SSP to support cognitive load, so pupils can focus on the suffix."""@en ;
  dcterms:modified "2026-06-07T15:30:15.112615Z"^^xsd:dateTime .

oakcurric:misconception-children-struggle-judge-gap-two
  a curric:Misconception ;
  curric:statement """Children can struggle to judge the gap between the two letters with this join.
  Either making it too small or too big."""@en ;
  curric:correction """Lots of modelling to demonstrate to the children will help with this. Also
  showing them incorrect formations where the gap is too small or too big will help."""@en ;
  dcterms:modified "2026-06-07T15:30:15.112621Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-idea-starting-makes
  a curric:Misconception ;
  curric:statement """Pupils may think that an idea starting with 'when' or 'if' makes complete
  sense on its own."""@en ;
  curric:correction """Make sure 'when' and 'if' are always presented as part of the second idea so
  that pupils can hear the idea does not make complete sense."""@en ;
  dcterms:modified "2026-06-07T15:30:15.114717Z"^^xsd:dateTime .

oakcurric:misconception-children-confuse-th-f-v
  a curric:Misconception ;
  curric:statement """Children can confuse 'th' with 'f' and 'v' in some words because they
  pronounce it that way."""@en ;
  curric:correction """Focus on pronunciation of the sounds before spelling, and show the tongue
  moving forward for words with 'th' in them."""@en ;
  dcterms:modified "2026-06-07T15:30:15.114722Z"^^xsd:dateTime .

oakcurric:misconception-children-use-know-letter-names
  a curric:Misconception ;
  curric:statement """Children may not use or know the letter names and rely on the phoneme the
  letter makes instead."""@en ;
  curric:correction """Use the teaching of the formation as an opportunity to revisit letter names
  vs. letter sounds (e.g. M vs. mmmm)"""@en ;
  dcterms:modified "2026-06-07T15:30:15.114740Z"^^xsd:dateTime .

oakcurric:misconception-children-want-lift-their-pencil
  a curric:Misconception ;
  curric:statement """Children may want to lift their pencil to add the 'dot' to the letter i or the
  'cross' to the letter t half-way through the word."""@en ;
  curric:correction """Remind the children through modelling that the flow of joining is like a
  river. It only stops at the end or if there is a break letter. Once you complete the
  letter string, model thinking out loud 'is there anything I need to add to this word?'"""@en ;
  dcterms:modified "2026-06-07T15:30:15.114764Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-phrases-sentences-because
  a curric:Misconception ;
  curric:statement """Pupils may think some phrases are sentences because they can look longer than
  full simple sentences."""@en ;
  curric:correction """Ensure pupils understand that simple sentences must contain a verb in order
  to make sense. Note that phrases are often adjectives and nouns."""@en ;
  dcterms:modified "2026-06-07T15:30:15.114770Z"^^xsd:dateTime .

oakcurric:misconception-pupils-dont-notice-written-phrase
  a curric:Misconception ;
  curric:statement """Pupils often don't notice that they have written a phrase showing
  belonging."""@en ;
  curric:correction """Give chances to edit looking explicitly for where an apostrophe for
  possession is missing. Spot apostrophes in sentences when reading."""@en ;
  dcterms:modified "2026-06-07T15:30:15.114778Z"^^xsd:dateTime .

oakcurric:misconception-children-struggle-generate-individual-sentences
  a curric:Misconception ;
  curric:statement "Children may struggle to generate individual sentences per event."@en ;
  curric:correction """Refer to the story mountain that the children made in a previous lesson and
  make that available. When retelling and reading the story, refer back to the model story
  mountain to refer to those points. Explain that each picture is one sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:15.115595Z"^^xsd:dateTime .

oakcurric:misconception-pupils-say-incorrect-pronouns-speak
  a curric:Misconception ;
  curric:statement "Pupils may say the incorrect pronouns or speak in the incorrect person."@en ;
  curric:correction """Re-model sentences, emphasising the change of person \"**I** lived in a
  magical, enchanted forest.\" and get the children to repeat."""@en ;
  dcterms:modified "2026-06-07T15:30:15.115601Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-compare-fairy-tales
  a curric:Misconception ;
  curric:statement "Pupils may struggle to compare fairy tales."@en ;
  curric:correction """Use fairy tales that are relevant to your curriculum, including tales pupils
  already know well. If pupils know stories well, they will find it easier to make links and
  to spot other similar features."""@en ;
  dcterms:modified "2026-06-07T15:30:15.115621Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-link-their-own
  a curric:Misconception ;
  curric:statement """Pupils may struggle to link their own knowledge of the world to the texts to
  support their predictions."""@en ;
  curric:correction """Link the titles of the texts to what you have done in school, e.g. 'We drew
  symbols in our science experiment', 'A president is someone who leads something like our
  headteacher or the pupil council' etc."""@en ;
  dcterms:modified "2026-06-07T15:30:15.115649Z"^^xsd:dateTime .

oakcurric:misconception-children-ask-why-b-d
  a curric:Misconception ;
  curric:statement "Some children may ask why b, d, g, p, q and y are not x-height letters."@en ;
  curric:correction """Use pictures of these letters to emphasise to the children that they have
  ascenders or descenders."""@en ;
  dcterms:modified "2026-06-07T15:30:15.116392Z"^^xsd:dateTime .

oakcurric:misconception-pupils-able-think-adjectives-specific
  a curric:Misconception ;
  curric:statement """Pupils might be able to think of adjectives, but they may not be specific to
  the character of the goats."""@en ;
  curric:correction """Share examples and non-examples of adjectives that can be used to describe
  the goats. Read extracts of the story to help pupils to understand that a character can be
  described in a certain way because of their actions."""@en ;
  dcterms:modified "2026-06-07T15:30:15.116484Z"^^xsd:dateTime .

oakcurric:misconception-children-find-difficult-incorporate-linguistic
  a curric:Misconception ;
  curric:statement """Children may find it difficult to incorporate linguistic features that
  highlight chronology in their plan."""@en ;
  curric:correction """Highlight the use of 'after education' and 'eventually' in the model notes on
  slide 17 as examples of language that support in communicating the chronology of the
  author's career. Ask the children to brainstorm other examples."""@en ;
  dcterms:modified "2026-06-07T15:30:15.116604Z"^^xsd:dateTime .

oakcurric:misconception-children-think-days-week-capitalised
  a curric:Misconception ;
  curric:statement """Sometimes children can think days of the week are only capitalised if at the
  beginning of a sentence"""@en ;
  curric:correction """Model and show examples of the days of the week in the middle of a sentence
  with a capital letter."""@en ;
  dcterms:modified "2026-06-07T15:30:15.116621Z"^^xsd:dateTime .

oakcurric:misconception-pupils-find-challenging-use-sulky
  a curric:Misconception ;
  curric:statement """Pupils may find it challenging to use 'sulky' as an adjective and 'sulking' as
  a verb in sentences."""@en ;
  curric:correction """Model sentences using both 'sulky' and 'sulking'. Use this an opportunity to
  recap word classes."""@en ;
  dcterms:modified "2026-06-07T15:30:15.116643Z"^^xsd:dateTime .

oakcurric:misconception-pupils-want-include-details-their
  a curric:Misconception ;
  curric:statement """Pupils may want to include details in their plan from other times in
  Florence's life."""@en ;
  curric:correction """Ensure the children are clear that this entry is about just one day, the day
  she arrived at the hospital in Crimea. Use the three sections in the planning form to
  reiterate the key moments - arriving, seeing soldiers on the floor, the hospital food."""@en ;
  dcterms:modified "2026-06-07T15:30:15.116666Z"^^xsd:dateTime .

oakcurric:misconception-pupils-find-hard-emphasise-different
  a curric:Misconception ;
  curric:statement """Pupils may find it hard to emphasise the different people in the conversation
  when reading aloud."""@en ;
  curric:correction """You may wish to act out the poem using two people so the pupils can see it
  performed as a conversation. Model changing your voice and using gestures to show the
  pupils how this has an effect."""@en ;
  dcterms:modified "2026-06-07T15:30:15.116673Z"^^xsd:dateTime .

oakcurric:misconception-pupils-dont-see-spellings-words
  a curric:Misconception ;
  curric:statement """Pupils don't see the spellings of words with the same root word as
  connected."""@en ;
  curric:correction """Explicitly show how the spelling of the root word stays the same when the
  prefix is added."""@en ;
  dcterms:modified "2026-06-07T15:30:15.116684Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-proper-nouns-capital
  a curric:Misconception ;
  curric:statement """Pupils may think that proper nouns only have a capital letter at the start of
  a sentence."""@en ;
  curric:correction """Pupils will be exposed to a range of sentences in which proper nouns feature
  at the beginning, middle and end."""@en ;
  dcterms:modified "2026-06-07T15:30:15.116698Z"^^xsd:dateTime .

oakcurric:misconception-children-find-hard-think-time
  a curric:Misconception ;
  curric:statement """Children may find it hard to think of a time when they were greedy with
  something."""@en ;
  curric:correction """Make sure children are clear about the definition of greedy and share
  different examples of things you can feel greedy for. Give children opportunities for lots
  of discussion before Task B."""@en ;
  dcterms:modified "2026-06-07T15:30:15.116734Z"^^xsd:dateTime .

oakcurric:misconception-pupils-familiar-fireworks-look-sound
  a curric:Misconception ;
  curric:statement "Pupils may not be familiar with fireworks and how they look and sound."@en ;
  curric:correction """Find a video of a fireworks display to show the children. Ensure the video is
  a good example of the different sounds and sights that are synonymous with firework
  displays."""@en ;
  dcterms:modified "2026-06-07T15:30:15.116762Z"^^xsd:dateTime .

oakcurric:misconception-pupils-want-time-practise-their
  a curric:Misconception ;
  curric:statement "Pupils may want more time to practise their performances."@en ;
  curric:correction """You could teach the lesson across two lessons, with one lesson given for
  rehearsing."""@en ;
  dcterms:modified "2026-06-07T15:30:15.117500Z"^^xsd:dateTime .

oakcurric:misconception-pupils-find-vocabulary-chronological-non
  a curric:Misconception ;
  curric:statement """Pupils may find the vocabulary of 'chronological' and 'non-chronological'
  challenging."""@en ;
  curric:correction """Using examples that pupils are very familiar with, such as the events in a
  school day, will help to explain the concepts."""@en ;
  dcterms:modified "2026-06-07T15:30:15.117515Z"^^xsd:dateTime .

oakcurric:misconception-pupils-want-include-detail-writing
  a curric:Misconception ;
  curric:statement "Pupils may want to include every detail when writing their plan."@en ;
  curric:correction """Teach pupils that a plan will help them when writing by guiding them on what
  content to include in each sentence. Model a written plan."""@en ;
  dcterms:modified "2026-06-07T15:30:15.117529Z"^^xsd:dateTime .

oakcurric:misconception-children-find-use-subordination-difficult
  a curric:Misconception ;
  curric:statement """Children may find the use of subordination more difficult in their writing,
  especially finding ways to use subordinating conjunctions other than 'when'."""@en ;
  curric:correction """Focus more heavily on subordination than coordination during teaching. It is
  appropriate to focus on the subordinating conjunction 'when' as this is the most valuable
  for the text's purpose, but model the use of other subordinating conjunctions too."""@en ;
  dcterms:modified "2026-06-07T15:30:15.117546Z"^^xsd:dateTime .

oakcurric:misconception-pupils-unsure-noun-unable-understand
  a curric:Misconception ;
  curric:statement """Pupils may be unsure of what a noun is and so, unable to understand their
  caption is a noun."""@en ;
  curric:correction """Teach the 'Year 1 Word Class Grammar Unit' at the same time as this so the
  children can have explicit teaching of nouns and word class."""@en ;
  dcterms:modified "2026-06-07T15:30:15.117552Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-answer-questions
  a curric:Misconception ;
  curric:statement "Pupils may struggle to answer questions."@en ;
  curric:correction """Previous lessons in the unit have had similar sentence structures and stems.
  Refer back to these to help the children to make links and develop their own sentences."""@en ;
  dcterms:modified "2026-06-07T15:30:15.117574Z"^^xsd:dateTime .

oakcurric:misconception-pupils-confuse-al-il-spellings
  a curric:Misconception ;
  curric:statement """Pupils may confuse the 'al' and 'il' spellings with other similar-sounding
  endings or 'l' spellings."""@en ;
  curric:correction """Be explicit about the irregularities and exceptions in English and use
  phonics, word games and pattern spotting to reinforce spellings."""@en ;
  dcterms:modified "2026-06-07T15:30:15.117580Z"^^xsd:dateTime .

oakcurric:misconception-number-homophones-lesson-time-thyme
  a curric:Misconception ;
  curric:statement """There are a number of homophones in this lesson. Time and thyme. Sight and
  site."""@en ;
  curric:correction """Do explicitly teach these to children if they come up. Use images and
  sentence contexts to show how each spelling can be used."""@en ;
  dcterms:modified "2026-06-07T15:30:15.118112Z"^^xsd:dateTime .

oakcurric:misconception-pupils-uncertain-write-their-verb
  a curric:Misconception ;
  curric:statement "Pupils may be uncertain about how to write their verb e.g. dances or hugs."@en ;
  curric:correction """Provide children with a verbs word bank in the form they will use them e.g.
  jumps, hops, skip, hugs etc. to make sense within the sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:15.118126Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-adjectives-equally-precise
  a curric:Misconception ;
  curric:statement """Pupils may think that all adjectives are equally precise when describing a
  noun."""@en ;
  curric:correction """Teach pupils that adjectives need to be carefully chosen and selected because
  they describe the noun in the most precise way."""@en ;
  dcterms:modified "2026-06-07T15:30:15.118135Z"^^xsd:dateTime .

oakcurric:misconception-children-find-hard-identify-character
  a curric:Misconception ;
  curric:statement """Children may find it hard to identify character traits for Plop for the inside
  of the owl template."""@en ;
  curric:correction """Reread specific pages aloud to the children and discuss Plop's actions and
  what this tells us about his character e.g. when he hears noises he goes down from his
  tree to explore - this tells us he is curious."""@en ;
  dcterms:modified "2026-06-07T15:30:15.118140Z"^^xsd:dateTime .

oakcurric:misconception-letter-families-letters-appear-close
  a curric:Misconception ;
  curric:statement """Letter families are letters that appear close to each other within the
  alphabet."""@en ;
  curric:correction """Letters are within the same letter family if they are formed in a similar
  way."""@en ;
  dcterms:modified "2026-06-07T15:30:15.118201Z"^^xsd:dateTime .

oakcurric:misconception-children-struggle-understand-concept-identity
  a curric:Misconception ;
  curric:statement """Children may struggle to understand how the concept of identity links to
  family."""@en ;
  curric:correction """Explain that our family is a big part of who we are and can influence our
  identity. Offer a variety of examples demonstrating this."""@en ;
  dcterms:modified "2026-06-07T15:30:15.118483Z"^^xsd:dateTime .

oakcurric:misconception-pupils-understand-tongue-twister
  a curric:Misconception ;
  curric:statement "Pupils might not understand what a 'tongue twister' is."@en ;
  curric:correction """Use the example 'She sells seashells by the seashore' and discuss why this is
  a tongue twister. Use this example to demonstrate how it becomes easier to say if we slow
  down."""@en ;
  dcterms:modified "2026-06-07T15:30:15.118504Z"^^xsd:dateTime .

oakcurric:misconception-children-tend-forget-lead-first
  a curric:Misconception ;
  curric:statement "Children may tend to forget the lead in for the first letter."@en ;
  curric:correction """Keep reminding children to say to themselves 'ready, line, go' before
  starting to ensure they are prompted to start on the baseline with a lead in."""@en ;
  dcterms:modified "2026-06-07T15:30:15.118510Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-suffix-one-s
  a curric:Misconception ;
  curric:statement """Pupils may think the suffix only has one 's', like the suffix -ful, which only
  has one 'l'."""@en ;
  curric:correction """Draw a direct comparison: '-less' is how we would expect it to be spelt,
  whereas '-ful' is surprising and only has one 'l'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.118531Z"^^xsd:dateTime .

oakcurric:misconception-pupils-look-word-o-associate
  a curric:Misconception ;
  curric:statement """Pupils will look for any word with ‘o’ in it and associate it with the long
  vowel 'oa'."""@en ;
  curric:correction """Teach that ‘o’ can be pronounced in different ways. Emphasise that in most
  words, the 'o' is making an 'o' phoneme."""@en ;
  dcterms:modified "2026-06-07T15:30:15.119241Z"^^xsd:dateTime .

oakcurric:misconception-children-struggle-spell-complex-adjectives
  a curric:Misconception ;
  curric:statement """Children may struggle to spell more complex adjectives or nouns, such as
  soldier or ambulance."""@en ;
  curric:correction """Provide a word bank for more complex words to encourage pupils to use if
  necessary. Provide sentence stems and scaffolds if necessary."""@en ;
  dcterms:modified "2026-06-07T15:30:15.119247Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-used-sentence-recognise
  a curric:Misconception ;
  curric:statement """Pupils may think that 'but' can be used in any sentence and may not recognise
  where it is suitable."""@en ;
  curric:correction """Show compound sentence examples that use the same first idea and let pupils
  hear the different joining words in action with the second idea."""@en ;
  dcterms:modified "2026-06-07T15:30:15.119255Z"^^xsd:dateTime .

oakcurric:misconception-pupils-inaccurately-use-apostrophe-contraction
  a curric:Misconception ;
  curric:statement """Pupils may inaccurately use an apostrophe for contraction by not removing
  letters and just putting the words together with an apostrophe."""@en ;
  curric:correction """Teach them that the apostrophe indicates where letters have been omitted.
  Give children examples and non-examples to sort and explain why they are right/wrong."""@en ;
  dcterms:modified "2026-06-07T15:30:15.119319Z"^^xsd:dateTime .

oakcurric:misconception-pupils-aware-their-own-nationality
  a curric:Misconception ;
  curric:statement "Pupils may not be aware of their own nationality or background."@en ;
  curric:correction """Prepare this knowledge about pupils' backgrounds in advance. Use a globe or
  map to pinpoint and discuss different places around the world. Ensure you give children
  autonomy to discuss what they see as their culture regardless of place of birth."""@en ;
  dcterms:modified "2026-06-07T15:30:15.119338Z"^^xsd:dateTime .

oakcurric:misconception-pupils-try-give-extended-reasons
  a curric:Misconception ;
  curric:statement """Pupils may try to give extended reasons for their opinions and then lose their
  full sentence structure."""@en ;
  curric:correction """Provide clear speaking frames and model sentence stems for the children to
  encourage them to speak in full, clear sentences. They only need to give one reason for
  each opinion."""@en ;
  dcterms:modified "2026-06-07T15:30:15.119352Z"^^xsd:dateTime .

oakcurric:misconception-pupils-include-fronted-adverbials-suited
  a curric:Misconception ;
  curric:statement """Pupils may include fronted adverbials which are more suited to fiction writing
  e.g. In a heartbeat."""@en ;
  curric:correction """Explicitly teach the children that fronted adverbials in a report should be
  formal and give them plenty of examples."""@en ;
  dcterms:modified "2026-06-07T15:30:15.119377Z"^^xsd:dateTime .

oakcurric:misconception-pupils-find-hard-generate-adjectives
  a curric:Misconception ;
  curric:statement """Pupils might find it hard to generate adjectives and description about a
  character they do not have a clear illustration of."""@en ;
  curric:correction """You could ask the children to draw their version of the main character,
  Tristan, at the start of this lesson. They will then find it easier to generate the
  descriptive vocabulary."""@en ;
  dcterms:modified "2026-06-07T15:30:15.119579Z"^^xsd:dateTime .

oakcurric:misconception-common-exceptions-words-hard-sound
  a curric:Misconception ;
  curric:statement """Common exceptions words which are hard to sound out e.g. 'great' 'break'
  'steak'."""@en ;
  curric:correction """Put these words into sentences and explain that often we have to learn to
  spell them by sight because spellings rules don't apply."""@en ;
  dcterms:modified "2026-06-07T15:30:15.119901Z"^^xsd:dateTime .

oakcurric:misconception-pupils-confuse-commands-exclamations-particularly
  a curric:Misconception ;
  curric:statement """Pupils may confuse commands and exclamations particularly if a command ends in
  an exclamation mark."""@en ;
  curric:correction """Spend time unpicking the features of both commands and exclamations in order
  to highlight the difference between the two."""@en ;
  dcterms:modified "2026-06-07T15:30:15.119907Z"^^xsd:dateTime .

oakcurric:misconception-children-understand-physical-features-book
  a curric:Misconception ;
  curric:statement """Children may not understand that the physical features of a book can be used
  as a storytelling tool."""@en ;
  curric:correction """Authors and illustrators use a variety of techniques to tell stories. Show
  children a physical copy of the book and how the line is used."""@en ;
  dcterms:modified "2026-06-07T15:30:15.119917Z"^^xsd:dateTime .

oakcurric:misconception-children-write-full-sentences-their
  a curric:Misconception ;
  curric:statement "Children may write in full sentences in their plan."@en ;
  curric:correction """Model to the children how to use bullet points for notes and give them lots
  of examples."""@en ;
  dcterms:modified "2026-06-07T15:30:15.119924Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-joining-word-used
  a curric:Misconception ;
  curric:statement """Pupils may think that a joining word can be used at the start of a
  sentence."""@en ;
  curric:correction """Teach that the joining word acts as the link between two simple sentences and
  so no full stop is needed."""@en ;
  dcterms:modified "2026-06-07T15:30:15.119932Z"^^xsd:dateTime .

oakcurric:misconception-pupils-believe-bears-live-forests
  a curric:Misconception ;
  curric:statement "Pupils believe that bears live in forests in the United Kingdom."@en ;
  curric:correction """Although bears do live in the woods, they do not live in the United Kingdom.
  This helps to show us that \"Wild\" is a fictional story."""@en ;
  dcterms:modified "2026-06-07T15:30:15.120246Z"^^xsd:dateTime .

oakcurric:misconception-pupils-unfamiliar-terms-such-setting
  a curric:Misconception ;
  curric:statement "Pupils may be unfamiliar with terms such as setting and plot."@en ;
  curric:correction """Spend time contextualising the terms using stories they will know well, such
  as the deep, dark woods as the setting for 'The Gruffalo'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.120388Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-hospitals-clean-organised
  a curric:Misconception ;
  curric:statement """Pupils may think that hospitals have always been clean and organised as they
  are today."""@en ;
  curric:correction """Show pupils images of hospitals during the Crimean war and hospitals today
  and allow them to explore and make comparisons."""@en ;
  dcterms:modified "2026-06-07T15:30:15.120465Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-see-difference-fact
  a curric:Misconception ;
  curric:statement "Pupils might struggle to see the difference between a fact and an opinion."@en ;
  curric:correction """Explain to pupils that if something is a fact, we can find out the answer
  because there will only be one correct answer. You could give additional examples to those
  at the start of Learning Cycle 2."""@en ;
  dcterms:modified "2026-06-07T15:30:15.120548Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-plop-brave-because
  a curric:Misconception ;
  curric:statement """Pupils may think that Plop was not brave because he was scared of the
  dark."""@en ;
  curric:correction """Explain to the children that bravery/ courage is all about facing your fears
  and doing something even though it might frighten you."""@en ;
  dcterms:modified "2026-06-07T15:30:15.120554Z"^^xsd:dateTime .

oakcurric:misconception-children-questions-around-role-play
  a curric:Misconception ;
  curric:statement """Children may have questions around the role they can play in protecting the
  world. They may not understand the link between actions they can take and the positive
  effects of it globally."""@en ;
  curric:correction """Discuss some examples of simple actions we can take and how far reaching the
  impact can be even if we can't see it. E.g. Reducing our use of energy will combat global
  warming which will protect sea ice for polar bears."""@en ;
  dcterms:modified "2026-06-07T15:30:15.120583Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-describe-themselves
  a curric:Misconception ;
  curric:statement "Pupils may struggle to describe themselves."@en ;
  curric:correction """Before describing themselves, model sentences by describing your pupils
  providing them with vocabulary, 'You are...'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.122816Z"^^xsd:dateTime .

oakcurric:misconception-children-think-breaking-rules-bad
  a curric:Misconception ;
  curric:statement "Children may think that breaking rules is always a bad thing."@en ;
  curric:correction """Help the children to understand appropriate examples of when breaking rules
  or challenging authority is appropriate."""@en ;
  dcterms:modified "2026-06-07T15:30:15.122822Z"^^xsd:dateTime .

oakcurric:misconception-children-think-words-ending-tion
  a curric:Misconception ;
  curric:statement """Some children will think that all words ending in -tion should have a
  recognisable root word."""@en ;
  curric:correction """Show some words ending in -tion that don't have recognisable root words, e.g.
  potion."""@en ;
  dcterms:modified "2026-06-07T15:30:15.122850Z"^^xsd:dateTime .

oakcurric:misconception-children-understand-important-vocabulary-within
  a curric:Misconception ;
  curric:statement """Children may not understand important vocabulary within the story, e.g.
  \"preserve\" or why pickling items in a jar is a way to protect them."""@en ;
  curric:correction """Offering a simple explanation of the word \"preserve\" will support the
  children's understanding. Vocabulary and the meaning behind word choices will be explored
  in greater detail in the next lesson in the unit."""@en ;
  dcterms:modified "2026-06-07T15:30:15.122947Z"^^xsd:dateTime .

oakcurric:misconception-children-find-difficult-develop-appropriate
  a curric:Misconception ;
  curric:statement """Children may find it difficult to develop appropriate similes for their
  special item."""@en ;
  curric:correction """Model examples for a range of colours and powerful nouns they could be
  compared to. E.g. Green items could be compared to elements of a meadow or a tree."""@en ;
  dcterms:modified "2026-06-07T15:30:15.122967Z"^^xsd:dateTime .

oakcurric:misconception-pupils-know-fiction-text-based
  a curric:Misconception ;
  curric:statement """Pupils may not know that a fiction text can be based on real themes, events
  and issues."""@en ;
  curric:correction """Explain to the children that although the story 'Leaf' is a made up story, it
  is based on the real-life issue of climate change."""@en ;
  dcterms:modified "2026-06-07T15:30:15.123802Z"^^xsd:dateTime .

oakcurric:misconception-children-struggle-give-short-simple
  a curric:Misconception ;
  curric:statement """Children may struggle to give short, simple instructions and may add in too
  many steps."""@en ;
  curric:correction """Model short, simple instructions before children are asked to complete Task
  B. Share some non-examples of long or complicated instructions. Remind children to always
  stop and wait after each instruction."""@en ;
  dcterms:modified "2026-06-07T15:30:15.123808Z"^^xsd:dateTime .

oakcurric:misconception-subordination-joining-words-join-same
  a curric:Misconception ;
  curric:statement """Some subordination joining words can join the same sentences as others e.g.
  'because', 'so', 'when'."""@en ;
  curric:correction """Discuss this with pupils if it arises in the lesson and explain that they
  have different purposes within the sentence but can both function."""@en ;
  dcterms:modified "2026-06-07T15:30:15.124477Z"^^xsd:dateTime .

oakcurric:misconception-difficult-think-sentences
  a curric:Misconception ;
  curric:statement "It can be difficult to think of sentences with 'so' and 'that'."@en ;
  curric:correction """Provide lots of examples before expecting pupils to do this for
  themselves."""@en ;
  dcterms:modified "2026-06-07T15:30:15.124496Z"^^xsd:dateTime .

oakcurric:misconception-pupils-follow-instructions-know-make
  a curric:Misconception ;
  curric:statement """Pupils may not follow the instructions as they know how to make a sandwich
  themselves already."""@en ;
  curric:correction """Model the process with the printed instructions and slow the process down by
  going one step at a time, encouraging them to repeat the instruction. This could either be
  using 'I do, we do' as shown in the slides or in small groups."""@en ;
  dcterms:modified "2026-06-07T15:30:15.124501Z"^^xsd:dateTime .

oakcurric:misconception-pupils-find-hard-change-verb
  a curric:Misconception ;
  curric:statement """Pupils may find it hard to change the verb into the correct form to fit the
  rest of the sentence."""@en ;
  curric:correction """Provide plenty of opportunities to practise saying and reading present and
  past tense sentences."""@en ;
  dcterms:modified "2026-06-07T15:30:15.124512Z"^^xsd:dateTime .

oakcurric:misconception-pupils-speak-quietly-find-hard
  a curric:Misconception ;
  curric:statement "Pupils may speak too quietly and find it hard to speak in full sentences."@en ;
  curric:correction """Display the visuals for successful speaking and listening in your classroom.
  Ensure pupils are confident in what they are going to say - they could practise their show
  and tell at home or with a teacher prior to delivering it in front of the class."""@en ;
  dcterms:modified "2026-06-07T15:30:15.124521Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-performing-poetry-something
  a curric:Misconception ;
  curric:statement """Pupils may think that performing poetry is something that does not require
  rehearsal and careful consideration beforehand."""@en ;
  curric:correction """Teach pupils that to have the greatest impact on the audience, you should
  look through your poem and consider how you will perform it."""@en ;
  dcterms:modified "2026-06-07T15:30:15.124526Z"^^xsd:dateTime .

oakcurric:misconception-children-write-speak-past-tense
  a curric:Misconception ;
  curric:statement "Children may not write or speak in the past tense."@en ;
  curric:correction """Consistently use sentence stems for the children to build their descriptive
  sentences from that are always in the past tense."""@en ;
  dcterms:modified "2026-06-07T15:30:15.124558Z"^^xsd:dateTime .

oakcurric:misconception-spelling-rules-found-within-root
  a curric:Misconception ;
  curric:statement """Spelling rules are often found within root words, leading to confusion when
  suffixes are added."""@en ;
  curric:correction """Show examples of root words alongside words with suffixes added e.g. float
  and floating."""@en ;
  dcterms:modified "2026-06-07T15:30:15.125225Z"^^xsd:dateTime .

oakcurric:misconception-pupils-want-use-exclamation-mark
  a curric:Misconception ;
  curric:statement """Pupils may want to use an exclamation mark for every sentence or
  overuse them."""@en ;
  curric:correction """When you introduce exclamation marks, 'give' each child one exclamation mark
  to put in their pockets. Tell them they can only have one, so they should only get it out
  of their pocket when they think it is the best place to use it."""@en ;
  dcterms:modified "2026-06-07T15:30:15.125231Z"^^xsd:dateTime .

oakcurric:misconception-pupils-refer-nouns-modelled-them
  a curric:Misconception ;
  curric:statement "Pupils may only refer to nouns modelled to them."@en ;
  curric:correction """Make use of the illustrations in the book as well as other visuals of London
  to help pupils become more familiar and generate their own ideas. Videos can assist with
  creating a more sensory experience."""@en ;
  dcterms:modified "2026-06-07T15:30:15.125283Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-speak-fist-person
  a curric:Misconception ;
  curric:statement """Pupils may struggle to speak in the fist person imagining they are someone
  else."""@en ;
  curric:correction """The sentence stems should support. Teachers should ask the question, then say
  the sentence stem and provide children time to speak to someone to rehearse answers in
  full sentences. If they don't reply in full sentences, always re-phrase it for them."""@en ;
  dcterms:modified "2026-06-07T15:30:15.125331Z"^^xsd:dateTime .

oakcurric:misconception-two-loops-pre-cursive-letter
  a curric:Misconception ;
  curric:statement """The two loops on the pre-cursive letter f can be challenging for children at
  first."""@en ;
  curric:correction """Lots of modelling and opportunities to trace the grey examples will support
  correct formation."""@en ;
  dcterms:modified "2026-06-07T15:30:15.125339Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-know-difference-facts
  a curric:Misconception ;
  curric:statement "Pupils may struggle to know the difference between facts and opinions."@en ;
  curric:correction """Provide lots of examples and opportunities for pupils to share different
  opinions about things they are familiar with like TV programmes."""@en ;
  dcterms:modified "2026-06-07T15:30:15.125359Z"^^xsd:dateTime .

oakcurric:misconception-children-find-difficult-understand-concept
  a curric:Misconception ;
  curric:statement """Children may find it difficult to understand the concept of challenging the
  idea of what is 'normal'."""@en ;
  curric:correction """Explore examples of how 'normal' looks different everywhere. Encourage
  children to consider things that may feel normal to them but not to others as a a tool for
  exploring the concept."""@en ;
  dcterms:modified "2026-06-07T15:30:15.125364Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-recognise-verbs-sentences
  a curric:Misconception ;
  curric:statement "Pupils may struggle to recognise 'being' verbs in sentences."@en ;
  curric:correction """Identify being verbs by showing them in their simplest form, then eliminating
  the nouns and adjectives from the same sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:15.125384Z"^^xsd:dateTime .

oakcurric:misconception-children-think-vowel-sound-preceding
  a curric:Misconception ;
  curric:statement """Children may think that the vowel sound preceding the 'l' will always
  determine the spelling."""@en ;
  curric:correction """Showing examples of incorrect use of 'el' and 'le' alongside the correct can
  be very useful for children to spot the correct spelling."""@en ;
  dcterms:modified "2026-06-07T15:30:15.126180Z"^^xsd:dateTime .

oakcurric:misconception-identifying-spellings-s-ce-c
  a curric:Misconception ;
  curric:statement "When identifying spellings for 's', 'ce' and 'c' can be mixed up."@en ;
  curric:correction """Use sound buttoning to help, especially when looking at words with split
  digraphs."""@en ;
  dcterms:modified "2026-06-07T15:30:15.126199Z"^^xsd:dateTime .

oakcurric:misconception-pupils-confuse-fairy-tale-nursery
  a curric:Misconception ;
  curric:statement """Pupils may confuse the fairy tale and the nursery rhyme which both have the
  same name."""@en ;
  curric:correction """Use this as an opportunity to discuss the differences between fairy tales and
  nursery rhymes. Emphasise that most nursery rhymes include rhyme and repetition and this
  makes it different to the fairy tale."""@en ;
  dcterms:modified "2026-06-07T15:30:15.126284Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-coming-england-fictional
  a curric:Misconception ;
  curric:statement """Pupils may think that 'Coming to England' is a fictional book as it is
  presented as a story and is being directly compared to Paddington, a fictional story."""@en ;
  curric:correction """From the beginning, explain that the story is based on real events,
  supplementing the slides with photos of Floella Benjamin. When comparing, discuss the
  difference of fiction and non-fiction explicitly."""@en ;
  dcterms:modified "2026-06-07T15:30:15.126305Z"^^xsd:dateTime .

oakcurric:misconception-children-struggle-think-reasons-their
  a curric:Misconception ;
  curric:statement "Children may struggle to think of reasons for their opinions."@en ;
  curric:correction """Give children the option of choosing from a list of reasons to help generate
  ideas."""@en ;
  dcterms:modified "2026-06-07T15:30:15.126311Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-same-answer-their
  a curric:Misconception ;
  curric:statement """Pupils may think that they should always have the same answer as their
  partner."""@en ;
  curric:correction """Teach the pupils that when retrieving information, there is likely only one
  answer. However, discussion questions, like in Task B 4, the children's answers may be
  different and that is what makes the reading experience unique."""@en ;
  dcterms:modified "2026-06-07T15:30:15.126367Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-link-their-predictions
  a curric:Misconception ;
  curric:statement """Pupils may struggle to link their predictions to their own knowledge or
  experience."""@en ;
  curric:correction """Support pupils by contextualising prior learning (books they have read that
  may be similar, learning about animals, pets they may have at home etc.) Alternatively,
  provide them with some context e.g. \"I know that cats are difficult to look after.\""""@en ;
  dcterms:modified "2026-06-07T15:30:15.128641Z"^^xsd:dateTime .

oakcurric:misconception-children-think-narrative-fiction-completely
  a curric:Misconception ;
  curric:statement """Children might think that a narrative fiction is always a completely made up
  story."""@en ;
  curric:correction """Explain that authors often taken inspiration from real life events to develop
  narrative fiction texts."""@en ;
  dcterms:modified "2026-06-07T15:30:15.130435Z"^^xsd:dateTime .

oakcurric:misconception-pupils-sufficient-knowledge-different-fairy
  a curric:Misconception ;
  curric:statement """Some pupils may not have sufficient knowledge of different fairy tales and
  characters from them to be able to answer the questions."""@en ;
  curric:correction """Read and discuss the classic children's fairy tales regularly as part of
  story time with your class. These books could also be sent home. You could add more images
  to the slides as a prompt."""@en ;
  dcterms:modified "2026-06-07T15:30:15.130480Z"^^xsd:dateTime .

oakcurric:misconception-children-recognise-y-typed-computer
  a curric:Misconception ;
  curric:statement """Children recognise how 'Y' is typed on the computer and try to write it like
  that."""@en ;
  curric:correction """Discuss and show children different fonts and compare to how letters should
  look when we are writing them by hand."""@en ;
  dcterms:modified "2026-06-07T15:30:15.132511Z"^^xsd:dateTime .

oakcurric:misconception-narratives-fiction-stories
  a curric:Misconception ;
  curric:statement "All narratives are fiction stories."@en ;
  curric:correction """Some narratives tell the story of real life events, making them a non-fiction
  text. A biography is an example of this."""@en ;
  dcterms:modified "2026-06-07T15:30:15.132758Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-generate-questions
  a curric:Misconception ;
  curric:statement "Pupils may struggle to generate questions."@en ;
  curric:correction """When you are modelling, model the 'wondering' thought process and discuss
  what you want to know about, referring to why character's did certain things and how they
  felt at certain points."""@en ;
  dcterms:modified "2026-06-07T15:30:15.132784Z"^^xsd:dateTime .

oakcurric:misconception-children-struggle-spelling-certain-words
  a curric:Misconception ;
  curric:statement "Children may struggle with the spelling of certain words."@en ;
  curric:correction """Where possible, encourage the children to use phonics strategies to create
  phonetically plausible spellings. For other words, create a word bank for children to
  refer to. 'Decided', 'countryside' and 'adventure' would be useful words to include."""@en ;
  dcterms:modified "2026-06-07T15:30:15.132801Z"^^xsd:dateTime .

oakcurric:misconception-formation-y-z-challenging-children
  a curric:Misconception ;
  curric:statement """The formation of the Y and the Z can be challenging for children at first,
  particularly finding the correct position for the diagonal lines and forming the zig-zag."""@en ;
  curric:correction """Giving the children lots of opportunities to trace these letters will help
  them to become familiar with the formation and the sizing."""@en ;
  dcterms:modified "2026-06-07T15:30:15.134740Z"^^xsd:dateTime .

oakcurric:misconception-children-confuse-pairs-words-against
  a curric:Misconception ;
  curric:statement """Children might confuse pairs of words against compound words. e.g. bus
  stop."""@en ;
  curric:correction """Give examples of both and model mistakes. e.g. write butterfly as butter fly
  and discuss."""@en ;
  dcterms:modified "2026-06-07T15:30:15.134771Z"^^xsd:dateTime .

oakcurric:misconception-homophones-using-wrong-spelling-word
  a curric:Misconception ;
  curric:statement """Homophones - using the wrong spelling of a word containing the 'ay' sound e.g.
  plain vs plane."""@en ;
  curric:correction """Use of images alongside sentences and contexts containing the correct
  spelling is helpful."""@en ;
  dcterms:modified "2026-06-07T15:30:15.139564Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-remember-place-apostrophe
  a curric:Misconception ;
  curric:statement """Pupils may struggle to remember where to place the apostrophe when contacting
  some 'not' words."""@en ;
  curric:correction """All 'not' words lose the letter 'o' between 'n' and 't'. Check that pupils
  are not putting the apostrophe before the 'nt e.g. don't/do'nt."""@en ;
  dcterms:modified "2026-06-07T15:30:15.139575Z"^^xsd:dateTime .

oakcurric:misconception-capital-letters-bigger-versions-lower
  a curric:Misconception ;
  curric:statement "That capital letters are just bigger versions of the lower case letters."@en ;
  curric:correction """Emphasise that some lower case and upper case are similar but some look
  completely different."""@en ;
  dcterms:modified "2026-06-07T15:30:15.139581Z"^^xsd:dateTime .

oakcurric:misconception-pupils-recognise-joining-two-main
  a curric:Misconception ;
  curric:statement """Pupils may not recognise when 'or' is joining two main clauses and when it is
  joining two words."""@en ;
  curric:correction """Show, explain and say aloud many examples of 'or' joining two main clauses in
  compound sentence examples."""@en ;
  dcterms:modified "2026-06-07T15:30:15.139589Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-think-actions-certain
  a curric:Misconception ;
  curric:statement "Pupils may struggle to think of actions for certain lines of the rhyme."@en ;
  curric:correction """Demonstrate lots of examples of actions or movements you could do and ask
  other pupils to perform their ideas to the group."""@en ;
  dcterms:modified "2026-06-07T15:30:15.139597Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-poet-limited-putting
  a curric:Misconception ;
  curric:statement """Pupils may think that the poet is limited to putting real items into
  the box."""@en ;
  curric:correction """Teach pupils that with poetry the possibilities are endless and a good poet
  is creative."""@en ;
  dcterms:modified "2026-06-07T15:30:15.139817Z"^^xsd:dateTime .

oakcurric:misconception-pupils-order-instructions-incorrectly
  a curric:Misconception ;
  curric:statement "Pupils may order the instructions incorrectly."@en ;
  curric:correction """Children would benefit from having had some experience of following
  instructions to make a pizza in advance. Model how to follow a plan carefully to ensure
  the order of instructions is correct."""@en ;
  dcterms:modified "2026-06-07T15:30:15.142871Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-apostrophes-possession-used
  a curric:Misconception ;
  curric:statement """Pupils may think that apostrophes for possession are only used for physical
  nouns."""@en ;
  curric:correction """Teach pupils that nouns such as skills or senses can also be possessed, or
  owned. E.g. a bat's eyesight."""@en ;
  dcterms:modified "2026-06-07T15:30:15.142889Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-understand-others-perspectives
  a curric:Misconception ;
  curric:statement """Pupils may struggle to understand other's perspectives (i.e. where others feel
  they belong)."""@en ;
  curric:correction """Remind pupils that one person's feeling of belonging may be different to
  someone else's and the importance of perspective."""@en ;
  dcterms:modified "2026-06-07T15:30:15.143370Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-nouns-made-plural
  a curric:Misconception ;
  curric:statement "Pupils may think that all nouns can be made plural by adding an 's'."@en ;
  curric:correction """Remind pupils that there are some other ways to show more than one, such as
  one mouse, two mice or one child, two children."""@en ;
  dcterms:modified "2026-06-07T15:30:15.147338Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-noun-ending-s
  a curric:Misconception ;
  curric:statement "Pupils may think that any noun ending is 's' is a plural noun."@en ;
  curric:correction "Pupils are exposed to singular nouns that end in the letter 's'."@en ;
  dcterms:modified "2026-06-07T15:30:15.147479Z"^^xsd:dateTime .

oakcurric:misconception-word-woe-repeated-several-points
  a curric:Misconception ;
  curric:statement """The word 'woe' is repeated at several points by all characters in the story.
  Children may be unfamiliar with the meaning of this word or have questions around why it
  is repeated."""@en ;
  curric:correction """Provide the definition of 'woe' (great sorrow or distress). Ask the children
  to consider the different points at which the characters say the word and the impact this
  has on them as the reader, (e.g. not knowing the fate of each character)."""@en ;
  dcterms:modified "2026-06-07T15:30:15.147492Z"^^xsd:dateTime .

oakcurric:misconception-pupils-answer-questions-one-word
  a curric:Misconception ;
  curric:statement "Pupils will often answer questions with one word answers."@en ;
  curric:correction """Model to pupils speaking in full sentences and always provide speaking frames
  (this can be verbally) to support pupils answering in full sentences."""@en ;
  dcterms:modified "2026-06-07T15:30:15.147541Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-find-two-similar
  a curric:Misconception ;
  curric:statement "Pupils may struggle to find two similar facts."@en ;
  curric:correction """Start by generating as many facts as you can about Floella; as you are
  receiving facts from pupils, model the thought process by saying 'Those two are linked
  because ...'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.147546Z"^^xsd:dateTime .

oakcurric:misconception-ee-sound-spelt-ei-opposed
  a curric:Misconception ;
  curric:statement """The 'ee' sound can also be spelt 'ei' as opposed to 'ie' e.g. receive. This is
  far less common."""@en ;
  curric:correction """Children will learn the 'i before e except after c' rule later, but there are
  other exceptions. e.g. caffeine, protein, either."""@en ;
  dcterms:modified "2026-06-07T15:30:15.147555Z"^^xsd:dateTime .

oakcurric:misconception-children-see-connections-words-word
  a curric:Misconception ;
  curric:statement """Some children will not see connections between words in word families, like
  friend and friendship."""@en ;
  curric:correction """Draw attention to the link between friend and friendship. If you can spell
  friend, you can also spell friendship."""@en ;
  dcterms:modified "2026-06-07T15:30:15.147671Z"^^xsd:dateTime .

oakcurric:misconception-oe-o-commonly-confused-because
  a curric:Misconception ;
  curric:statement """'oe' and 'o' can be commonly confused because they often appear at the end of
  words."""@en ;
  curric:correction """Draw attention to how rare the 'oe' spelling is and that the 'o' spelling at
  the end has limited use in high frequency words."""@en ;
  dcterms:modified "2026-06-07T15:30:15.147678Z"^^xsd:dateTime .

oakcurric:misconception-pupils-unfamiliar-elements-story-such
  a curric:Misconception ;
  curric:statement """Pupils may be unfamiliar with some elements of the story, such as 'yams' and
  names of the Cousins."""@en ;
  curric:correction """When reading the story, gloss over key vocabulary and supplement with images
  or use of the illustrations where necessary. You can also use some of the explanation and
  check slides as you are reading to support their understanding further."""@en ;
  dcterms:modified "2026-06-07T15:30:15.147710Z"^^xsd:dateTime .

oakcurric:misconception-children-revert-forming-letters-baseline
  a curric:Misconception ;
  curric:statement """Children may revert to forming the letters between the baseline and the
  x-height line."""@en ;
  curric:correction """This is a good opportunity to show the children how supportive the tramlines
  are. Remind them to ensure all of their capital letters are sitting on the baseline,
  reaching up to the ascender line and are straight."""@en ;
  dcterms:modified "2026-06-07T15:30:15.147715Z"^^xsd:dateTime .

oakcurric:misconception-need-read-story-once-understand
  a curric:Misconception ;
  curric:statement "I only need to read a story once to understand it."@en ;
  curric:correction """Often stories have lots of new vocabulary and important information.
  Re-reading a story helps us with fluency and greater understanding."""@en ;
  dcterms:modified "2026-06-07T15:30:15.147735Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-examine-features-uncertain
  a curric:Misconception ;
  curric:statement """Pupils may struggle to examine the features if they are uncertain of word
  class."""@en ;
  curric:correction """The primary focus is for pupils to understand that sequencing language and
  verbs help to explain how to do something clearly in the correct order - focus on this
  more with pupils who find word class difficult."""@en ;
  dcterms:modified "2026-06-07T15:30:15.147741Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-poems-imaginative-things
  a curric:Misconception ;
  curric:statement """Pupils may think that poems are always about imaginative things and based in
  fantasy worlds."""@en ;
  curric:correction """Teach pupils that poems can also be about everyday experiences and familiar
  scenarios."""@en ;
  dcterms:modified "2026-06-07T15:30:15.147747Z"^^xsd:dateTime .

oakcurric:misconception-letters-children-finish-baseline-forget
  a curric:Misconception ;
  curric:statement """For these letters, children may finish on the baseline and forget the curved
  stroke as the lead out"""@en ;
  curric:correction """Emphasise to the children through modelling that there has to be a 'tail' for
  the letter to join to the next letter."""@en ;
  dcterms:modified "2026-06-07T15:30:15.147756Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-know-questions-ask
  a curric:Misconception ;
  curric:statement "Pupils may struggle to know what questions to ask someone about a trip."@en ;
  curric:correction """Provide question prompt words and model these words being used to pose
  questions in full sentences."""@en ;
  dcterms:modified "2026-06-07T15:30:15.147782Z"^^xsd:dateTime .

oakcurric:misconception-children-revert-back-taking-their
  a curric:Misconception ;
  curric:statement """Children will often revert back to taking their pencil off the page to add the
  dot to the letter i."""@en ;
  curric:correction """When modelling, ensure to talk out loud to yourself showing the children you
  are leaving the dot until the end. For example, 'I am forming the letter i, but I remember
  that I leave the dot until the end'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.147790Z"^^xsd:dateTime .

oakcurric:misconception-pupils-find-hard-read-poem
  a curric:Misconception ;
  curric:statement "Pupils may find it hard to read the poem aloud and with expression."@en ;
  curric:correction """Ensure pupils have an understanding of what the poem means and some of the
  key vocabulary that they may not know. Model reading the poem aloud with expression for
  the children to get ideas and talk through the different ways to use your voice."""@en ;
  dcterms:modified "2026-06-07T15:30:15.147796Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-speak-correctly-past
  a curric:Misconception ;
  curric:statement """Pupils may struggle to speak correctly in the past tense, particularly with
  irregular verbs (e.g. saying 'sawed' or 'seed' for saw)."""@en ;
  curric:correction """Use this lesson as an opportunity for as much oral rehearsal as possible to
  support children's errors in the moment. Repeat and re-model sentences back to them. Model
  incorrectly and ask the children to spot your mistakes."""@en ;
  dcterms:modified "2026-06-07T15:30:15.148571Z"^^xsd:dateTime .

oakcurric:misconception-children-become-confused-direction-go
  a curric:Misconception ;
  curric:statement """Children can become confused with which direction to go when 'going over' for
  the m, n and r."""@en ;
  curric:correction """Explicit modelling and using a point in the classroom to direct the children.
  Check teacher tip."""@en ;
  dcterms:modified "2026-06-07T15:30:15.149038Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-verbs-used-different
  a curric:Misconception ;
  curric:statement "Pupils may struggle with verbs being used in different tenses."@en ;
  curric:correction "When introducing verbs, keep it simple by using the simple present tense."@en ;
  dcterms:modified "2026-06-07T15:30:15.149044Z"^^xsd:dateTime .

oakcurric:misconception-children-think-traditional-tales-exactly
  a curric:Misconception ;
  curric:statement """Children may think that all traditional tales have exactly the same
  features."""@en ;
  curric:correction """Talk about different traditional tales and examine similarities and
  differences, such as some traditional tales contain magic, some do not. Make use of
  physical and visual copies of traditional tales children are familiar with."""@en ;
  dcterms:modified "2026-06-07T15:30:15.149053Z"^^xsd:dateTime .

oakcurric:misconception-pupils-find-challenging-generate-ambitious
  a curric:Misconception ;
  curric:statement """Pupils may find it challenging to generate ambitious verbs, adverbs, nouns and
  adjectives all at once."""@en ;
  curric:correction """Depending on the abilities in the class, you may wish to focus on just one of
  these aspects in the plan e.g. only adjectives and nouns. Alternatively, children could
  work in pairs or small groups to generate their plans."""@en ;
  dcterms:modified "2026-06-07T15:30:15.149059Z"^^xsd:dateTime .

oakcurric:misconception-pupils-unable-read-non-fiction
  a curric:Misconception ;
  curric:statement """Pupils may be unable to read the non-fiction book themselves due to their
  current phonics knowledge."""@en ;
  curric:correction """Before Task A, read the two pages to the children and discuss what we have
  learnt first. For Task B, you may wish to answer the questions collaboratively, modelling
  the strategies and reading only that section of text."""@en ;
  dcterms:modified "2026-06-07T15:30:15.149065Z"^^xsd:dateTime .

oakcurric:misconception-find-information-written-text
  a curric:Misconception ;
  curric:statement "We can only find out information that is written in the text."@en ;
  curric:correction """You can infer greater meaning about a person or event by looking for clues
  within the text."""@en ;
  dcterms:modified "2026-06-07T15:30:15.149073Z"^^xsd:dateTime .

oakcurric:misconception-ea-ee-spellings-commonly-confused
  a curric:Misconception ;
  curric:statement "The 'ea' and 'ee' spellings are commonly confused."@en ;
  curric:correction """Be clear that these spellings cannot be used interchangeably. It's important
  to learn the spellings of words individually to avoid mistakes."""@en ;
  dcterms:modified "2026-06-07T15:30:15.149082Z"^^xsd:dateTime .

oakcurric:misconception-pupils-uncertain-scientific-vocabulary-means
  a curric:Misconception ;
  curric:statement """Pupils may be uncertain of what some of the scientific vocabulary means,
  making the story difficult to follow."""@en ;
  curric:correction """As you are reading, gloss over key vocabulary, such as \"research\" and
  \"hypothesis\" by providing a definition linked to the events in the story using the
  illustrations."""@en ;
  dcterms:modified "2026-06-07T15:30:15.149088Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-written-compound-sentence
  a curric:Misconception ;
  curric:statement """Pupils may think they have written a compound sentence just because they have
  included 'and'."""@en ;
  curric:correction """Look at sentences on a balancing scale with 'and' in the middle. Highlight
  that both ideas either side of 'and' must make complete sense."""@en ;
  dcterms:modified "2026-06-07T15:30:15.149111Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-reply-respond-asked
  a curric:Misconception ;
  curric:statement """Pupils might think that you can only reply or respond when asked a
  question."""@en ;
  curric:correction """Give examples of how to respond to statements as well as questions. For
  example, how could you respond if someone said 'I love your coat'?"""@en ;
  dcterms:modified "2026-06-07T15:30:15.149116Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-know-storytelling-language
  a curric:Misconception ;
  curric:statement "Pupils may struggle to know what storytelling language to use."@en ;
  curric:correction """Provide the pupils with a word bank of options. Provide language starting
  with a capital letter followed by a comma to demonstrate the correct punctuation, such as
  'First,' or 'One day,'"""@en ;
  dcterms:modified "2026-06-07T15:30:15.149125Z"^^xsd:dateTime .

oakcurric:misconception-pupils-attach-stereotypes-preconceptions-around
  a curric:Misconception ;
  curric:statement """Pupils may attach stereotypes or preconceptions around the idea of a
  superhero."""@en ;
  curric:correction """As well as the images shown, supplement with more images to show a
  representative idea of a superhero, relevant to children's interests."""@en ;
  dcterms:modified "2026-06-07T15:30:15.149371Z"^^xsd:dateTime .

oakcurric:misconception-pupils-recall-written-far
  a curric:Misconception ;
  curric:statement "Pupils may not recall what they have written so far."@en ;
  curric:correction """Spend time in the lesson re-reading what they have written so far. Then,
  refer back to when you made the sandwiches to sequence the final instructions."""@en ;
  dcterms:modified "2026-06-07T15:30:15.149377Z"^^xsd:dateTime .

oakcurric:misconception-pupils-retell-nursery-rhyme-exactly
  a curric:Misconception ;
  curric:statement """Pupils may just retell the nursery rhyme exactly as it is in four
  sentences."""@en ;
  curric:correction """Explain that we are retelling 'Humpty Dumpty' as a story and need to add our
  own storytelling language and detail."""@en ;
  dcterms:modified "2026-06-07T15:30:15.149382Z"^^xsd:dateTime .

oakcurric:misconception-pupils-find-hard-think-imaginative
  a curric:Misconception ;
  curric:statement "Pupils may find it hard to think of imaginative ideas."@en ;
  curric:correction """Pupils could work in pairs or small groups to generate ideas for their poems.
  You may also wish to do some further work on adjectives to describe and come up with a
  class word bank of adjectives to refer to."""@en ;
  dcterms:modified "2026-06-07T15:30:15.149388Z"^^xsd:dateTime .

oakcurric:misconception-children-know-understand-owls-nocturnal
  a curric:Misconception ;
  curric:statement """Children may not know or understand that owls are nocturnal and therefore not
  find it unusual or funny for an owl to be scared of the dark."""@en ;
  curric:correction """Allow the children to research owls ahead of the lesson, using non-fiction
  texts and the internet."""@en ;
  dcterms:modified "2026-06-07T15:30:15.149393Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-know-adjectives-positive
  a curric:Misconception ;
  curric:statement "Pupils may struggle to know if adjectives are positive or negative."@en ;
  curric:correction """Display lists of positive and negative adjectives on the wall and generate
  example sentences together."""@en ;
  dcterms:modified "2026-06-07T15:30:15.150768Z"^^xsd:dateTime .

oakcurric:misconception-children-think-one-way-respond
  a curric:Misconception ;
  curric:statement """Children can think that there is only one way to respond to a poem and you can
  have the right or wrong understanding of it."""@en ;
  curric:correction """Avoid posing questions which may lead children to the idea that there is a
  right or wrong answer when discussing the poem. Try to encourage open responses to the
  poem, celebrating each unique response from individuals."""@en ;
  dcterms:modified "2026-06-07T15:30:15.150800Z"^^xsd:dateTime .

oakcurric:misconception-pupils-use-sequencing-descriptive-language
  a curric:Misconception ;
  curric:statement """Pupils may only use the sequencing or descriptive language you have
  modelled."""@en ;
  curric:correction """Encourage pupils to refer back to previous learning to generate their own
  vocabulary. Model different options to children."""@en ;
  dcterms:modified "2026-06-07T15:30:15.151022Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-scan
  a curric:Misconception ;
  curric:statement "Pupils may struggle to scan."@en ;
  curric:correction """Model the process for them, narrating your strategies. For example, \"I've
  found a capital letter in the middle of the sentence - it must be a proper noun.\" or \"I
  am searching for the word river. I will look for words beginning with 'r'.\""""@en ;
  dcterms:modified "2026-06-07T15:30:15.151042Z"^^xsd:dateTime .

oakcurric:misconception-pupils-find-difficult-know-command
  a curric:Misconception ;
  curric:statement """Pupils may find it difficult to know when a command ends in an exclamation
  mark and when it doesn't."""@en ;
  curric:correction """Choose clear examples that model strong emotion and calm emotion and use tone
  and intonation to support understanding."""@en ;
  dcterms:modified "2026-06-07T15:30:15.151897Z"^^xsd:dateTime .

oakcurric:misconception-writing-process-pupils-find-hard
  a curric:Misconception ;
  curric:statement """During the writing process, pupils may find it hard to come up with adjectives
  to describe the nouns they are using."""@en ;
  curric:correction """Teach the pupils that first we select a noun that will need to be described,
  then we select the most suitable adjectives to describe them. Encourage pupils to plan
  their expanded noun phrases first, so they can easily put these into their recount."""@en ;
  dcterms:modified "2026-06-07T15:30:15.151903Z"^^xsd:dateTime .

oakcurric:misconception-pupils-unsure-past-tense-form
  a curric:Misconception ;
  curric:statement """Pupils may be unsure about the past tense form of some verbs, particularly
  irregular verbs."""@en ;
  curric:correction """Use a range of past tense irregular verbs in modelled sentences. Give pupils
  a sentence scaffold including past tense verbs for Task B."""@en ;
  dcterms:modified "2026-06-07T15:30:15.151908Z"^^xsd:dateTime .

oakcurric:misconception-pupils-daunted-quantity-expected-write
  a curric:Misconception ;
  curric:statement "Pupils may be daunted by the quantity they are expected to write."@en ;
  curric:correction """Spend time emphasising the repeated aspects to show pupils that once they
  have written one sentence, the following sentences are very similar."""@en ;
  dcterms:modified "2026-06-07T15:30:15.151914Z"^^xsd:dateTime .

oakcurric:misconception-letters-h-b-d-k
  a curric:Misconception ;
  curric:statement "That the letters h, b, d and k are x-height letters."@en ;
  curric:correction """Modelling through the lesson that although parts of the letter are x-height,
  they are not x-height letters because they have ascenders."""@en ;
  dcterms:modified "2026-06-07T15:30:15.151920Z"^^xsd:dateTime .

oakcurric:misconception-pupils-know-nursery-rhyme-heart
  a curric:Misconception ;
  curric:statement "There may be pupils who do not know a nursery rhyme by heart."@en ;
  curric:correction """Use the Y1 'Nursery rhyme' unit prior to this lesson to familiarise children
  with a range of nursery rhymes. Spend time in class singing and reciting nursery rhymes
  together. Children may wish to choose their favourite nursery rhyme to perform."""@en ;
  dcterms:modified "2026-06-07T15:30:15.153016Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-share-their-aspiration
  a curric:Misconception ;
  curric:statement "Pupils may struggle to share what their aspiration is."@en ;
  curric:correction """As well as listing the jobs referred to in the lesson, refer to jobs or
  careers that your pupils have specific interests in, such as sports people, authors,
  singers as well as jobs that parents or family members may have."""@en ;
  dcterms:modified "2026-06-07T15:30:15.153037Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-distinguish-decodable-common
  a curric:Misconception ;
  curric:statement """Pupils may struggle to distinguish between decodable and common exception
  words."""@en ;
  curric:correction """Be explicit about the difficulties in spelling these words and give time to
  practise spelling these common exception words. Supplement the slides with any visuals
  linked to your school's SSP to support building on any learning from Rec and Y1."""@en ;
  dcterms:modified "2026-06-07T15:30:15.153130Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-rules-spelling-help
  a curric:Misconception ;
  curric:statement """Pupils can think the 'rules' for the spelling will always help to choose the
  right spelling."""@en ;
  curric:correction """Explain that rules can help us a certain amount. We also need to use our
  judgement of 'what looks right'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.153258Z"^^xsd:dateTime .

oakcurric:misconception-height-vertical-line-short-tall
  a curric:Misconception ;
  curric:statement "The height of the vertical line is sometimes too short or too tall."@en ;
  curric:correction """Emphasise starting the vertical line on the ascender line and finishing on
  the baseline."""@en ;
  dcterms:modified "2026-06-07T15:30:15.153265Z"^^xsd:dateTime .

oakcurric:misconception-pupils-copy-words-their-plans
  a curric:Misconception ;
  curric:statement "Pupils may just copy out the words from their plans."@en ;
  curric:correction """Explicitly model reading your plan and turning those notes into full
  sentences. This will also be modelled in Learning Cycle 1 where the children orally
  rehearse their sentences."""@en ;
  dcterms:modified "2026-06-07T15:30:15.153411Z"^^xsd:dateTime .

oakcurric:misconception-pupils-secure-listing-nouns-correctly
  a curric:Misconception ;
  curric:statement "Pupils may not be secure in listing nouns correctly."@en ;
  curric:correction """The model includes an adjective before each listed noun (e.g. green park). If
  necessary, model with or without the adjective to simplify the skill and ensure pupils
  meet the outcome. Go back to previous lessons where adjectives have been generated."""@en ;
  dcterms:modified "2026-06-07T15:30:15.153426Z"^^xsd:dateTime .

oakcurric:misconception-pupils-know-constitutes-one-single
  a curric:Misconception ;
  curric:statement """Pupils may not know what constitutes 'one single idea' to effectively create a
  compound sentence."""@en ;
  curric:correction """Use the sentence scaffolds as much as possible, so that pupils are only
  adding their own adjectives. The purpose of this lesson is initial introduction to joining
  two ideas, rather than expecting them to be secure, so model as much as is needed."""@en ;
  dcterms:modified "2026-06-07T15:30:15.153513Z"^^xsd:dateTime .

oakcurric:misconception-g-y-p-q-x
  a curric:Misconception ;
  curric:statement "That g, y, p and q are x-height letters."@en ;
  curric:correction """Model through the lesson that although part of the letter is x-height, they
  are not x-height letters as they have descenders."""@en ;
  dcterms:modified "2026-06-07T15:30:15.153597Z"^^xsd:dateTime .

oakcurric:misconception-pupils-read-ow-words-such
  a curric:Misconception ;
  curric:statement """Pupils may read the 'ow' in words such as 'below' and 'snow' as an 'ou' sound,
  such as in 'growl'."""@en ;
  curric:correction """Explain to pupils that when the 'ow' digraph appears at the end of the word,
  it is typically making an 'oa' sound."""@en ;
  dcterms:modified "2026-06-07T15:30:15.154281Z"^^xsd:dateTime .

oakcurric:misconception-pupils-confident-identifying-discussing-sounds
  a curric:Misconception ;
  curric:statement """Pupils may not be confident in identifying or discussing the sounds that a
  river makes."""@en ;
  curric:correction """Play pupils a video of river sounds before reading and exploring the poem. If
  you have access to the book 'Caterpillar Cake' by Matt Goodfellow, it would be beneficial
  to share the illustrations accompanying the poem with the children."""@en ;
  dcterms:modified "2026-06-07T15:30:15.154287Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-words-ending-ly
  a curric:Misconception ;
  curric:statement "Pupils may think all words ending in -ly are adverbs."@en ;
  curric:correction """Explain there are also adjectives that end in -ly, like friendly, lonely, or
  lovely."""@en ;
  dcterms:modified "2026-06-07T15:30:15.154293Z"^^xsd:dateTime .

oakcurric:misconception-pupils-link-sentences-incorrectly-formal
  a curric:Misconception ;
  curric:statement """Pupils may link sentences incorrectly with formal fronted adverbials that are
  unsuitable."""@en ;
  curric:correction """Focus on understanding the 'and' and 'but' categories of formal fronted
  adverbials and say the sentences out loud to hear if they make sense"""@en ;
  dcterms:modified "2026-06-07T15:30:15.154301Z"^^xsd:dateTime .

oakcurric:misconception-pupils-struggle-distinguish-makes-them
  a curric:Misconception ;
  curric:statement """Pupils may struggle to distinguish between what makes them happy and what they
  do to stay happy."""@en ;
  curric:correction """Use examples from your own experiences. Discuss that our feelings may change,
  but there are strategies you use to keep a positive mood going. Emphasise all of the
  things that the characters do to help to keep their happiness going."""@en ;
  dcterms:modified "2026-06-07T15:30:15.154718Z"^^xsd:dateTime .

oakcurric:misconception-pupils-find-hard-remember-action
  a curric:Misconception ;
  curric:statement "Pupils may find it hard to remember all the action in the climax."@en ;
  curric:correction """Teach pupils to break down the climax into smaller sections and then focus on
  what happened in that section. Provide children will printed images from the animation, to
  support them with planning their climax."""@en ;
  dcterms:modified "2026-06-07T15:30:15.154732Z"^^xsd:dateTime .

oakcurric:misconception-pupils-find-hard-sequence-stills
  a curric:Misconception ;
  curric:statement "Pupils may find it hard to sequence all the stills from memory."@en ;
  curric:correction """Allow pupils to watch the animation a few times, so that the story is clear
  in their heads. Pupils could work in pairs or small groups to sequence the images at their
  tables on sugar paper."""@en ;
  dcterms:modified "2026-06-07T15:30:15.154738Z"^^xsd:dateTime .

oakcurric:misconception-pupils-familiar-paddington-already-making
  a curric:Misconception ;
  curric:statement """Pupils may be familiar with Paddington already, making predicting
  difficult."""@en ;
  curric:correction """As shown in the slides, model the language of 'I predict ...' or 'I know that
  ...' and celebrate their existing knowledge. At the end of the lesson, ask the children
  what new information about the Paddington series they learnt in the lesson."""@en ;
  dcterms:modified "2026-06-07T15:30:15.154755Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-use-exclamation-marks
  a curric:Misconception ;
  curric:statement "Pupils may think you use exclamation marks at the end of every command."@en ;
  curric:correction """Clearly show pupils when and why an exclamation mark is needed with some
  commands but not others."""@en ;
  dcterms:modified "2026-06-07T15:30:15.154791Z"^^xsd:dateTime .

oakcurric:misconception-direction-movement-s-e-challenging
  a curric:Misconception ;
  curric:statement "Direction of movement for the s and e can be challenging."@en ;
  curric:correction """Use the clock in the classroom to remind children of the anti-clockwise
  direction. Put arrows on the children's page to support."""@en ;
  dcterms:modified "2026-06-07T15:30:15.154803Z"^^xsd:dateTime .

oakcurric:misconception-children-think-y-replaced-suffix
  a curric:Misconception ;
  curric:statement """Children may think the 'y' should be replaced with an 'i' when the suffix is
  added."""@en ;
  curric:correction """Show that we end up with two 'i's in a row if this happens: fly becoming
  fliing, so we keep the 'y'. Regularly repeat the rules as chants."""@en ;
  dcterms:modified "2026-06-07T15:30:15.155146Z"^^xsd:dateTime .

oakcurric:misconception-children-think-suffix-spelt-like
  a curric:Misconception ;
  curric:statement """Children can think the suffix is spelt like the word 'full' with a
  double 'l'."""@en ;
  curric:correction """Explicitly discuss the difference in spelling, and provide opportunities to
  look at words and identify those with the suffix in them."""@en ;
  dcterms:modified "2026-06-07T15:30:15.155153Z"^^xsd:dateTime .

oakcurric:misconception-children-use-apostrophe-plurals-ending
  a curric:Misconception ;
  curric:statement "Children may use an apostrophe for plurals ending in 's'."@en ;
  curric:correction """Explicitly look at non-examples where the apostrophe isn't used. Help the
  children to identify when and why the apostrophe isn't used."""@en ;
  dcterms:modified "2026-06-07T15:30:15.155158Z"^^xsd:dateTime .

oakcurric:misconception-lead-pre-cursive-letter-g
  a curric:Misconception ;
  curric:statement """The lead out on the pre-cursive letter g and q can be challenging for children
  at first."""@en ;
  curric:correction """Lots of modelling and opportunities to trace the grey examples will support
  correct formation."""@en ;
  dcterms:modified "2026-06-07T15:30:15.155164Z"^^xsd:dateTime .

oakcurric:misconception-digraph-trigraph-ear-make-different
  a curric:Misconception ;
  curric:statement "The digraph 'or' and trigraph 'ear' also make different long vowel sounds."@en ;
  curric:correction """Remind children that the same grapheme (digraph and trigraph) can represent
  different sounds. Say the words out loud to check."""@en ;
  dcterms:modified "2026-06-07T15:30:15.155170Z"^^xsd:dateTime .

oakcurric:misconception-gn-digraph-use-g-silent
  a curric:Misconception ;
  curric:statement "The 'gn' digraph does not always use the 'g' as a silent letter."@en ;
  curric:correction """Expose children to words with 'gn' where the 'g' is both silent and not
  silent."""@en ;
  dcterms:modified "2026-06-07T15:30:15.155175Z"^^xsd:dateTime .

oakcurric:misconception-pupils-nervous-perform-front-class
  a curric:Misconception ;
  curric:statement "Pupils may be nervous to perform in front of the class."@en ;
  curric:correction """Pupils can work in pairs or in small groups to perform the poem. You could
  teach the lesson across two lessons and provide pupils with more time to practise their
  performances."""@en ;
  dcterms:modified "2026-06-07T15:30:15.155198Z"^^xsd:dateTime .
