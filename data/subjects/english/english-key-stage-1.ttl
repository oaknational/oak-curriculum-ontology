    oakcurric:priorknowledge-645-7 ,
    oakcurric:priorknowledge-645-8 ;
  curric:id "645"^^xsd:positiveInteger;
  dcterms:modified "2026-06-07T15:29:24.752660Z"^^xsd:dateTime ;
