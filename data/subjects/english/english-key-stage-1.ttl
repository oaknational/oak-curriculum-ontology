    oakcurric:priorknowledge-456-6 ;
  curric:id "456"^^xsd:positiveInteger;
  dcterms:modified "2026-06-07T15:29:25.233481Z"^^xsd:dateTime ;
  curric:isUnitOf
    natcurric:scheme-english-key-stage-1 ;
  curric:includesThread
    oakcurric:thread-developing-handwriting-fluency .

oakcurric:unit-652
  a curric:Unit ;
  rdfs:label "School trip: recount writing"@en ;
  curric:slug "school-trip-recount-writing" ;
  rdfs:comment """In this unit, pupils write a recount in one paragraph about a school trip. Pupils
  use sequencing fronted adverbials with commas to order their recount chronologically and
  they focus on including expanded noun phrases - also punctuated with commas - to describe
  nouns."""@en ;
  curric:whyThisWhyNow """This unit uses and builds on pupils' knowledge of recount writing from the
  Year 1 unit 'School trip: writing a recount'. Here, pupils review what it means to write
  chronologically, including by using sequencing fronted adverbials followed by commas to order
  their sentences. Pupils focus on including expanded noun phrases to describe key nouns and on
  using 'because' and 'that' to stretch first ideas within their recounts. This unit prepares
  pupils for more non-fiction writing in the Year 2 unit 'Florence Nightingale and Mary
  Seacole: non-chronological report'.""" ;
  curric:hasPriorKnowledgeRequirement
    oakcurric:priorknowledge-652-1 ,
    oakcurric:priorknowledge-652-2 ,
    oakcurric:priorknowledge-652-3 ,
    oakcurric:priorknowledge-652-4 ;
  curric:id "652"^^xsd:positiveInteger;
  dcterms:modified "2026-06-07T15:29:25.235664Z"^^xsd:dateTime ;
  curric:isUnitOf
    natcurric:scheme-english-key-stage-1 ;
  curric:includesThread
    oakcurric:thread-reading-and-writing-texts-that-inform .

oakcurric:unit-770
  a curric:Unit ;
  rdfs:label "Humorous poetry"@en ;
  curric:slug "humorous-poetry" ;
  rdfs:comment """In this unit, pupils read and respond to a variety of humorous poems by different
  poets. They will learn about the poets, explore the meaning and themes within each poem
  and identify the poetic devices used. Pupils will practise reading each poem aloud with
  expression to convey meaning."""@en ;
  curric:whyThisWhyNow """This unit uses and builds on pupils' knowledge and understanding of a
  variety of poetic devices, which were explored in the prior unit, 'The Magic Box': reading
  imaginative poetry'. In this unit, pupils use a range of different poems from different poets
  to explore how they use language choice and poetic devices to create humour. Pupils will use
  their understanding of each poem to read aloud with expression and reflect on their reading.
  This unit prepares pupils for 'Performance Poetry', where they will respond to and perform a
  variety of different poems.""" ;
  curric:hasPriorKnowledgeRequirement
    oakcurric:priorknowledge-770-1 ,
    oakcurric:priorknowledge-770-2 ,
    oakcurric:priorknowledge-770-3 ,
    oakcurric:priorknowledge-770-4 ,
