oakcurric:keyword-joining-word
  a curric:Keyword ;
  schema:name "joining word"@en ;
  schema:description "a word that joins words or ideas"@en ;
  dcterms:modified "2026-06-07T15:30:02.348551Z"^^xsd:dateTime .

oakcurric:keyword-perspective
  a curric:Keyword ;
  schema:name "perspective"@en ;
  schema:description "creating depth and distance in a composition"@en ;
  dcterms:modified "2026-06-07T15:30:02.348595Z"^^xsd:dateTime .

oakcurric:keyword-character
  a curric:Keyword ;
  schema:name "character"@en ;
  schema:description "a person or animal in a story"@en ;
  dcterms:modified "2026-06-07T15:30:02.348600Z"^^xsd:dateTime .

oakcurric:keyword-description
  a curric:Keyword ;
  schema:name "description"@en ;
  schema:description "using words to help someone imagine what something is like"@en ;
