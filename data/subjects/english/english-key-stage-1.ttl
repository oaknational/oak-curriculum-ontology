# ----------------------------------------------------------------------
# Prior Knowledge Requirements
# ----------------------------------------------------------------------

oakcurric:priorknowledge-557-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Starting to use capital letters and full stops at the start and end of each
  sentence."""@en ;
  dcterms:modified "2026-06-07T15:29:23.312767Z"^^xsd:dateTime .

oakcurric:priorknowledge-557-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Exposure to and opportunities to listen and respond to a range of
  traditional tales."""@en ;
  dcterms:modified "2026-06-07T15:29:23.312778Z"^^xsd:dateTime .

oakcurric:priorknowledge-557-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Know that traditional tales have a beginning, middle and end."@en ;
  dcterms:modified "2026-06-07T15:29:23.312784Z"^^xsd:dateTime .

oakcurric:priorknowledge-557-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Know that some traditional tales have magical aspects."@en ;
  dcterms:modified "2026-06-07T15:29:23.312796Z"^^xsd:dateTime .

oakcurric:priorknowledge-557-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Ability to apply phonics knowledge to support decoding when reading and segmenting
  when spelling."""@en ;
  dcterms:modified "2026-06-07T15:29:23.312801Z"^^xsd:dateTime .

oakcurric:priorknowledge-557-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Ability to read and write some common exception words."@en ;
  dcterms:modified "2026-06-07T15:29:23.312806Z"^^xsd:dateTime .

oakcurric:priorknowledge-557-7
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Compose simple sentences by saying out loud what they are going to write and
  re-reading back to check it makes sense."""@en ;
  dcterms:modified "2026-06-07T15:29:23.312810Z"^^xsd:dateTime .

oakcurric:priorknowledge-557-8
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Ability to listen and respond to short stories that are read to them."@en ;
  dcterms:modified "2026-06-07T15:29:23.312814Z"^^xsd:dateTime .

oakcurric:priorknowledge-557-9
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Opportunities to sequence, retell and act out short stories."@en ;
  dcterms:modified "2026-06-07T15:29:23.312819Z"^^xsd:dateTime .

oakcurric:priorknowledge-646-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Ability to apply phonics knowledge to support decoding when reading and segmenting
  when spelling"""@en ;
  dcterms:modified "2026-06-07T15:29:23.316941Z"^^xsd:dateTime .

oakcurric:priorknowledge-646-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Join two simple clauses with the joining word 'and'"@en ;
  dcterms:modified "2026-06-07T15:29:23.316953Z"^^xsd:dateTime .

oakcurric:priorknowledge-646-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Use fronted adverbials of time at the start of a sentence"@en ;
  dcterms:modified "2026-06-07T15:29:23.316959Z"^^xsd:dateTime .

oakcurric:priorknowledge-646-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Understand that an adjective describes a noun"@en ;
  dcterms:modified "2026-06-07T15:29:23.316963Z"^^xsd:dateTime .

oakcurric:priorknowledge-646-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Understand that when you use two adjectives to describe a noun, a comma is placed
  between them"""@en ;
  dcterms:modified "2026-06-07T15:29:23.316967Z"^^xsd:dateTime .

oakcurric:priorknowledge-646-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Ability to write in the simple past tense"@en ;
  dcterms:modified "2026-06-07T15:29:23.316972Z"^^xsd:dateTime .

oakcurric:priorknowledge-646-7
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Ability to recall a past event in sequence"@en ;
  dcterms:modified "2026-06-07T15:29:23.316976Z"^^xsd:dateTime .

oakcurric:priorknowledge-646-8
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Ability to write questions punctuated by a question mark"@en ;
  dcterms:modified "2026-06-07T15:29:23.316980Z"^^xsd:dateTime .

oakcurric:priorknowledge-1053-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Ability to apply phonics knowledge to support decoding when reading and segmenting
  when spelling."""@en ;
  dcterms:modified "2026-06-07T15:29:23.328314Z"^^xsd:dateTime .

oakcurric:priorknowledge-1053-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Ability to read and write some common exception words."@en ;
  dcterms:modified "2026-06-07T15:29:23.328330Z"^^xsd:dateTime .

oakcurric:priorknowledge-1053-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Join two simple clauses with the joining word 'and'."@en ;
  dcterms:modified "2026-06-07T15:29:23.328336Z"^^xsd:dateTime .

oakcurric:priorknowledge-1053-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Ability to think from another person's perspective."@en ;
  dcterms:modified "2026-06-07T15:29:23.328341Z"^^xsd:dateTime .

oakcurric:priorknowledge-1053-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Understand that an adjective describes a noun."@en ;
  dcterms:modified "2026-06-07T15:29:23.328346Z"^^xsd:dateTime .

oakcurric:priorknowledge-1053-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Understand that when you use two adjectives to describe a noun, a comma is placed
  between them."""@en ;
  dcterms:modified "2026-06-07T15:29:23.328350Z"^^xsd:dateTime .

oakcurric:priorknowledge-1053-7
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Understands simple present, past and future tenses and their purposes."@en ;
  dcterms:modified "2026-06-07T15:29:23.328355Z"^^xsd:dateTime .

oakcurric:priorknowledge-1053-8
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Uses evidence from the text to explain answers."@en ;
  dcterms:modified "2026-06-07T15:29:23.328359Z"^^xsd:dateTime .

oakcurric:priorknowledge-1053-9
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Ability to answer questions about a personal event."@en ;
  dcterms:modified "2026-06-07T15:29:23.328372Z"^^xsd:dateTime .

oakcurric:priorknowledge-1042-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Participate in small group, class and one-to-one discussions, offering their own
  ideas, using recently introduced vocabulary"""@en ;
  dcterms:modified "2026-06-07T15:29:23.331536Z"^^xsd:dateTime .

oakcurric:priorknowledge-1042-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Offer explanations for why things might happen, making use of recently introduced
  vocabulary from stories."""@en ;
  dcterms:modified "2026-06-07T15:29:23.331552Z"^^xsd:dateTime .

oakcurric:priorknowledge-1042-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Express their ideas and feelings about their experiences using full sentences."@en ;
  dcterms:modified "2026-06-07T15:29:23.331558Z"^^xsd:dateTime .

oakcurric:priorknowledge-1042-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Draw on personal experiences and prior knowledge to what has been read"@en ;
  dcterms:modified "2026-06-07T15:29:23.331563Z"^^xsd:dateTime .

oakcurric:priorknowledge-1042-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Use and understand recently introduced vocabulary during discussions about stories
  and during role-play."""@en ;
  dcterms:modified "2026-06-07T15:29:23.331568Z"^^xsd:dateTime .

oakcurric:priorknowledge-1042-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Spell words by identifying sounds in them and representing the sounds with a letter
  or letters."""@en ;
  dcterms:modified "2026-06-07T15:29:23.331573Z"^^xsd:dateTime .

oakcurric:priorknowledge-1042-7
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Forms most letters correctly and places a space in between each word"@en ;
  dcterms:modified "2026-06-07T15:29:23.331577Z"^^xsd:dateTime .

oakcurric:priorknowledge-1042-8
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Write simple phrases and sentences that can be read by themselves and others."@en ;
  dcterms:modified "2026-06-07T15:29:23.331582Z"^^xsd:dateTime .

oakcurric:priorknowledge-454-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Know the difference between a capital letter and a lower case letter."@en ;
  dcterms:modified "2026-06-07T15:29:23.334542Z"^^xsd:dateTime .

oakcurric:priorknowledge-454-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "The grapheme phoneme correspondence (GPC) for all 26 letters of the alphabet."@en ;
