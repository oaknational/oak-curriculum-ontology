# ----------------------------------------------------------------------
# Keywords
# ----------------------------------------------------------------------

oakcurric:keyword-sequence
  a curric:Keyword ;
  schema:name "sequence"@en ;
  schema:description "a short melodic idea that is repeated in steps either rising or falling"@en ;
  dcterms:modified "2026-06-07T15:30:02.347512Z"^^xsd:dateTime .

oakcurric:keyword-present
  a curric:Keyword ;
  schema:name "present"@en ;
  schema:description "describes habitual events in the present, e.g. ‘I do’"@en ;
  dcterms:modified "2026-06-07T15:30:02.347769Z"^^xsd:dateTime .

oakcurric:keyword-tense
  a curric:Keyword ;
  schema:name "Tense"@en ;
  schema:description """A verb’s tense will tell you whether the action happened in the past,
  present or future."""@en ;
  dcterms:modified "2026-06-07T15:30:02.347923Z"^^xsd:dateTime .

oakcurric:keyword-homophones
  a curric:Keyword ;
  schema:name "Homophones"@en ;
  schema:description """If two words are pronounced the same way but spelled differently they can be
  described as homophones (e.g. here and hear)."""@en ;
  dcterms:modified "2026-06-07T15:30:02.347932Z"^^xsd:dateTime .

oakcurric:keyword-onomatopoeia
  a curric:Keyword ;
  schema:name "onomatopoeia"@en ;
  schema:description "a word that imitates or resembles the sound it describes"@en ;
  dcterms:modified "2026-06-07T15:30:02.348028Z"^^xsd:dateTime .

oakcurric:keyword-optimism
  a curric:Keyword ;
  schema:name "optimism"@en ;
  schema:description """Optimism means hopefulness or confidence about the future or the success of
  something."""@en ;
  dcterms:modified "2026-06-07T15:30:02.348061Z"^^xsd:dateTime .

oakcurric:keyword-root-word
  a curric:Keyword ;
  schema:name "root word"@en ;
  schema:description """the base word from which other words are formed often by adding prefixes or
  suffixes"""@en ;
  dcterms:modified "2026-06-07T15:30:02.348091Z"^^xsd:dateTime .

oakcurric:keyword-suffix
  a curric:Keyword ;
  schema:name "suffix"@en ;
  schema:description """a letter or group of letters added to the end of a word to change its
  meaning"""@en ;
  dcterms:modified "2026-06-07T15:30:02.348096Z"^^xsd:dateTime .

oakcurric:keyword-adjective
  a curric:Keyword ;
  schema:name "adjective"@en ;
  schema:description "describes a noun"@en ;
  dcterms:modified "2026-06-07T15:30:02.348100Z"^^xsd:dateTime .

oakcurric:keyword-noun
  a curric:Keyword ;
  schema:name "noun"@en ;
  schema:description "a naming word for people, places or things"@en ;
  dcterms:modified "2026-06-07T15:30:02.348107Z"^^xsd:dateTime .

oakcurric:keyword-verb
  a curric:Keyword ;
  schema:name "verb"@en ;
  schema:description "a doing, being or having word"@en ;
  dcterms:modified "2026-06-07T15:30:02.348112Z"^^xsd:dateTime .

oakcurric:keyword-phrase
  a curric:Keyword ;
  schema:name "Phrase"@en ;
  schema:description "a short section of a melody, often lasting 1, 2 or 4 bars"@en ;
  dcterms:modified "2026-06-07T15:30:02.348142Z"^^xsd:dateTime .

oakcurric:keyword-editing
  a curric:Keyword ;
  schema:name "editing"@en ;
  schema:description """the process of improving writing to improve text flow and overall
  quality"""@en ;
  dcterms:modified "2026-06-07T15:30:02.348149Z"^^xsd:dateTime .

oakcurric:keyword-punctuation
  a curric:Keyword ;
  schema:name "punctuation"@en ;
  schema:description """a set of standardised symbols and marks used in written language to
  structure sentences"""@en ;
  dcterms:modified "2026-06-07T15:30:02.348154Z"^^xsd:dateTime .

oakcurric:keyword-vocabulary
  a curric:Keyword ;
  schema:name "vocabulary"@en ;
  schema:description "the use of specific words and phrases to convey a meaning"@en ;
  dcterms:modified "2026-06-07T15:30:02.348165Z"^^xsd:dateTime .

oakcurric:keyword-setting
  a curric:Keyword ;
  schema:name "setting"@en ;
  schema:description "where the story takes place"@en ;
  dcterms:modified "2026-06-07T15:30:02.348192Z"^^xsd:dateTime .

oakcurric:keyword-inference
  a curric:Keyword ;
  schema:name "inference"@en ;
  schema:description "to use clues from within the text to draw conclusions"@en ;
  dcterms:modified "2026-06-07T15:30:02.348196Z"^^xsd:dateTime .

oakcurric:keyword-character-traits
  a curric:Keyword ;
  schema:name "character traits"@en ;
  schema:description """the special qualities that make a character in a story unique and
  interesting"""@en ;
  dcterms:modified "2026-06-07T15:30:02.348200Z"^^xsd:dateTime .

oakcurric:keyword-presenting
  a curric:Keyword ;
  schema:name "presenting"@en ;
  schema:description "speaking in front of others and listening to others"@en ;
  dcterms:modified "2026-06-07T15:30:02.348205Z"^^xsd:dateTime .

oakcurric:keyword-conclusion
  a curric:Keyword ;
  schema:name "conclusion"@en ;
  schema:description "the closing paragraph of a non-fiction text"@en ;
  dcterms:modified "2026-06-07T15:30:02.348234Z"^^xsd:dateTime .

oakcurric:keyword-summarise
  a curric:Keyword ;
  schema:name "summarise"@en ;
  schema:description "to sum up or conclude the main body of a text"@en ;
  dcterms:modified "2026-06-07T15:30:02.348247Z"^^xsd:dateTime .

oakcurric:keyword-synonym
  a curric:Keyword ;
  schema:name "synonym"@en ;
  schema:description "a word that has the same or similar meaning to another word"@en ;
  dcterms:modified "2026-06-07T15:30:02.348296Z"^^xsd:dateTime .

oakcurric:keyword-imagery
  a curric:Keyword ;
  schema:name "imagery"@en ;
  schema:description """the use of vivid and sensory language that appeals to the reader's senses,
  creating vivid mental pictures and enhancing the emotional impact of the poem"""@en ;
  dcterms:modified "2026-06-07T15:30:02.348368Z"^^xsd:dateTime .

oakcurric:keyword-adverb
  a curric:Keyword ;
  schema:name "adverb"@en ;
  schema:description "describes a verb"@en ;
  dcterms:modified "2026-06-07T15:30:02.348399Z"^^xsd:dateTime .

oakcurric:keyword-join
  a curric:Keyword ;
  schema:name "join"@en ;
  schema:description "how the letters are connected together"@en ;
  dcterms:modified "2026-06-07T15:30:02.348441Z"^^xsd:dateTime .

oakcurric:keyword-letter-string
  a curric:Keyword ;
  schema:name "letter string"@en ;
  schema:description "a group of letters that are written together in a word"@en ;
  dcterms:modified "2026-06-07T15:30:02.348445Z"^^xsd:dateTime .

oakcurric:keyword-lead-in
  a curric:Keyword ;
  schema:name "lead in"@en ;
  schema:description "the stroke or line that guides us into starting a letter"@en ;
  dcterms:modified "2026-06-07T15:30:02.348450Z"^^xsd:dateTime .

oakcurric:keyword-lead-out
  a curric:Keyword ;
  schema:name "lead out"@en ;
  schema:description "the stroke or line that guides us to smoothly finish a letter"@en ;
  dcterms:modified "2026-06-07T15:30:02.348454Z"^^xsd:dateTime .

oakcurric:keyword-first-person
  a curric:Keyword ;
  schema:name "first person"@en ;
  schema:description """the point of view where the narrator of the story is the ‘I’ character,
  providing a personal account of events or experiences"""@en ;
  dcterms:modified "2026-06-07T15:30:02.348459Z"^^xsd:dateTime .

oakcurric:keyword-fairy-tale
  a curric:Keyword ;
  schema:name "fairy tale"@en ;
  schema:description "a children's story about magical elements"@en ;
  dcterms:modified "2026-06-07T15:30:02.348485Z"^^xsd:dateTime .

oakcurric:keyword-compare
  a curric:Keyword ;
  schema:name "compare"@en ;
  schema:description "to identify how things are the same and different"@en ;
  dcterms:modified "2026-06-07T15:30:02.348490Z"^^xsd:dateTime .

oakcurric:keyword-theme
  a curric:Keyword ;
  schema:name "theme"@en ;
  schema:description "a main idea that the writer wants to focus on"@en ;
  dcterms:modified "2026-06-07T15:30:02.348497Z"^^xsd:dateTime .

oakcurric:keyword-fronted-adverbial-of-manner
  a curric:Keyword ;
  schema:name "fronted adverbial of manner"@en ;
  schema:description """a sentence starter that tells the reader how something happened or how a
