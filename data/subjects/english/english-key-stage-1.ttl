  dcterms:modified "2026-06-07T15:30:02.348542Z"^^xsd:dateTime .

oakcurric:keyword-compound-sentence
  a curric:Keyword ;
  schema:name "compound sentence"@en ;
  schema:description "a sentence formed of two simple sentences and a joining word"@en ;
