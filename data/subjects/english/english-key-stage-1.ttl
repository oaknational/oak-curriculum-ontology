# ----------------------------------------------------------------------
# Key Learning Points
# ----------------------------------------------------------------------

oakcurric:keylearningpoint-lesson-5476-1
  a curric:KeyLearningPoint ;
  rdfs:label "Comparing means exploring similarities and differences about something"@en ;
  dcterms:modified "2026-06-07T15:30:29.000084Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5476-2
  a curric:KeyLearningPoint ;
  rdfs:label "Characters, such as heroes and villains, tend to appear in most fairy tales"@en ;
  dcterms:modified "2026-06-07T15:30:29.000088Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5476-3
  a curric:KeyLearningPoint ;
  rdfs:label "Some fairy tales' main characters are people and some are animals"@en ;
  dcterms:modified "2026-06-07T15:30:29.000095Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5476-4
  a curric:KeyLearningPoint ;
  rdfs:label """Some fairy tales have magical aspects or creatures, such as the porridge pot or the
  troll"""@en ;
  dcterms:modified "2026-06-07T15:30:29.000099Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5476-5
  a curric:KeyLearningPoint ;
  rdfs:label "Most fairy tales aim to teach a lesson to the reader"@en ;
  dcterms:modified "2026-06-07T15:30:29.000103Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6180-1
  a curric:KeyLearningPoint ;
  rdfs:label "The climax should be the most exciting part of a story for the reader."@en ;
  dcterms:modified "2026-06-07T15:30:29.000183Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6180-2
  a curric:KeyLearningPoint ;
  rdfs:label """Two simple sentences joined together with a joining word is called a compound
  sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.000188Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6180-3
  a curric:KeyLearningPoint ;
  rdfs:label "We can use our plan to help form full sentences for writing."@en ;
  dcterms:modified "2026-06-07T15:30:29.000192Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6180-4
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials of manner tell the reader how something was done or how a
  character felt."""@en ;
  dcterms:modified "2026-06-07T15:30:29.000196Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6180-5
  a curric:KeyLearningPoint ;
  rdfs:label "Adverbs are words that describe a verb."@en ;
  dcterms:modified "2026-06-07T15:30:29.000200Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8902-1
  a curric:KeyLearningPoint ;
  rdfs:label "A character description can be generated using evidence from the text"@en ;
  dcterms:modified "2026-06-07T15:30:29.000248Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8902-2
  a curric:KeyLearningPoint ;
  rdfs:label "We know that Ada is curious because she asks lots of questions"@en ;
  dcterms:modified "2026-06-07T15:30:29.000253Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8902-3
  a curric:KeyLearningPoint ;
  rdfs:label "Adjectives can be used to describe a character"@en ;
  dcterms:modified "2026-06-07T15:30:29.000257Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8902-4
  a curric:KeyLearningPoint ;
  rdfs:label "Two similar ideas can be joined together using 'and'"@en ;
  dcterms:modified "2026-06-07T15:30:29.000261Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8902-5
  a curric:KeyLearningPoint ;
  rdfs:label "'Because' can be used to explain your ideas"@en ;
  dcterms:modified "2026-06-07T15:30:29.000265Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8692-1
  a curric:KeyLearningPoint ;
  rdfs:label """Writing about what someone will be when they grow up means writing in the future,
  using phrases such as 'I want to...'"""@en ;
  dcterms:modified "2026-06-07T15:30:29.000272Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8692-2
  a curric:KeyLearningPoint ;
  rdfs:label "Rehearsing a sentence out loud before writing it helps us to remember it"@en ;
  dcterms:modified "2026-06-07T15:30:29.000276Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8692-3
  a curric:KeyLearningPoint ;
  rdfs:label "Common exception words are words that cannot be sounded out easily"@en ;
  dcterms:modified "2026-06-07T15:30:29.000280Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8692-4
  a curric:KeyLearningPoint ;
  rdfs:label "Sounding out a word before writing helps to spell a word"@en ;
  dcterms:modified "2026-06-07T15:30:29.000285Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8692-5
  a curric:KeyLearningPoint ;
  rdfs:label "Reading back writing is important to check it is correct and makes sense"@en ;
  dcterms:modified "2026-06-07T15:30:29.000289Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4742-1
  a curric:KeyLearningPoint ;
  rdfs:label "The capital letters S, J and U all start at the top tramline."@en ;
  dcterms:modified "2026-06-07T15:30:29.000317Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4742-2
  a curric:KeyLearningPoint ;
  rdfs:label """The formation of capital letter J needs you to lift your pencil to add the other
  horizontal top line."""@en ;
  dcterms:modified "2026-06-07T15:30:29.000344Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4765-1
  a curric:KeyLearningPoint ;
  rdfs:label "The letters all have a lead in and a lead out."@en ;
  dcterms:modified "2026-06-07T15:30:29.000368Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4765-2
  a curric:KeyLearningPoint ;
  rdfs:label "The pencil does not lift when forming the join."@en ;
  dcterms:modified "2026-06-07T15:30:29.000372Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4765-3
  a curric:KeyLearningPoint ;
  rdfs:label """The third join starts at the x-height line and dips below the x-height line and back
  up to join the next letter."""@en ;
  dcterms:modified "2026-06-07T15:30:29.000377Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4765-4
  a curric:KeyLearningPoint ;
  rdfs:label """When joining from a \"w\" or an \"o\", remember the small 'dip down' to aid
  joining."""@en ;
  dcterms:modified "2026-06-07T15:30:29.000381Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4765-5
  a curric:KeyLearningPoint ;
  rdfs:label """When using the third join you leave enough space to ensure the letters are not
  touching without leaving a big gap."""@en ;
  dcterms:modified "2026-06-07T15:30:29.000385Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-901-1
  a curric:KeyLearningPoint ;
  rdfs:label "Adjectives are words that describe nouns."@en ;
  dcterms:modified "2026-06-07T15:30:29.000390Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-901-2
  a curric:KeyLearningPoint ;
  rdfs:label "Adjectives can describe singular or plural common nouns."@en ;
  dcterms:modified "2026-06-07T15:30:29.000394Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-901-3
  a curric:KeyLearningPoint ;
  rdfs:label "Adjectives can describe proper nouns."@en ;
  dcterms:modified "2026-06-07T15:30:29.000398Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-901-4
  a curric:KeyLearningPoint ;
  rdfs:label "An adjective often comes before the noun it is describing."@en ;
  dcterms:modified "2026-06-07T15:30:29.000419Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-901-5
  a curric:KeyLearningPoint ;
  rdfs:label "Adjectives help the reader picture the noun."@en ;
  dcterms:modified "2026-06-07T15:30:29.000423Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29-1
  a curric:KeyLearningPoint ;
  rdfs:label "The letter u is an x-height letter."@en ;
  dcterms:modified "2026-06-07T15:30:29.000427Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29-2
  a curric:KeyLearningPoint ;
  rdfs:label """The letter u is formed by going down, around, back up, down and finish with
  a flick."""@en ;
  dcterms:modified "2026-06-07T15:30:29.000431Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29-3
  a curric:KeyLearningPoint ;
  rdfs:label """The letter y is like a u but goes under the baseline to the descender line and curls
  up."""@en ;
  dcterms:modified "2026-06-07T15:30:29.000438Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29-4
  a curric:KeyLearningPoint ;
  rdfs:label """The letter j is formed by going down, curls up and finishes with a dot at
  the top."""@en ;
  dcterms:modified "2026-06-07T15:30:29.000442Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29-5
  a curric:KeyLearningPoint ;
  rdfs:label "The letter j and y have descenders."@en ;
  dcterms:modified "2026-06-07T15:30:29.000446Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4766-1
  a curric:KeyLearningPoint ;
  rdfs:label "The letters all have a lead in and a lead out."@en ;
  dcterms:modified "2026-06-07T15:30:29.001666Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4766-2
  a curric:KeyLearningPoint ;
  rdfs:label "The pencil does not lift when forming the join."@en ;
  dcterms:modified "2026-06-07T15:30:29.001672Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4766-3
  a curric:KeyLearningPoint ;
  rdfs:label "The fourth join goes from the x-height line up towards the ascender line."@en ;
  dcterms:modified "2026-06-07T15:30:29.001676Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4766-4
  a curric:KeyLearningPoint ;
  rdfs:label "When joining the letter string o to b, the direction of formation changes."@en ;
  dcterms:modified "2026-06-07T15:30:29.001680Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4766-5
  a curric:KeyLearningPoint ;
  rdfs:label """When forming the letter f, it has two loops: at the top of the lead in and at the
  bottom ready for the lead out."""@en ;
  dcterms:modified "2026-06-07T15:30:29.001685Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4797-1
  a curric:KeyLearningPoint ;
  rdfs:label "Common exception words do not follow regular spelling or phonics rules."@en ;
  dcterms:modified "2026-06-07T15:30:29.003584Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4797-2
  a curric:KeyLearningPoint ;
  rdfs:label """Letters in the common exception words will be joined using a range of joins
  depending on the letters in the word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.003589Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4797-3
  a curric:KeyLearningPoint ;
  rdfs:label "The first letter starts at the correct starting point."@en ;
  dcterms:modified "2026-06-07T15:30:29.003593Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4797-4
  a curric:KeyLearningPoint ;
  rdfs:label "There is appropriate spacing between the letters."@en ;
  dcterms:modified "2026-06-07T15:30:29.003597Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4797-5
  a curric:KeyLearningPoint ;
  rdfs:label """You don't lift your pencil to add the 'dot' for the letter i until the letter string
  is complete."""@en ;
  dcterms:modified "2026-06-07T15:30:29.003601Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4780-1
  a curric:KeyLearningPoint ;
  rdfs:label "The letters are formed by following the right starting point and direction."@en ;
  dcterms:modified "2026-06-07T15:30:29.003622Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4780-2
  a curric:KeyLearningPoint ;
  rdfs:label "The fourth join goes from the x-height line up towards the ascender line."@en ;
  dcterms:modified "2026-06-07T15:30:29.003626Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4780-3
  a curric:KeyLearningPoint ;
  rdfs:label "The letter f has a lead in and a lead out loop for joining."@en ;
  dcterms:modified "2026-06-07T15:30:29.003630Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4780-4
  a curric:KeyLearningPoint ;
  rdfs:label """The pencil does not lift in between the beginning and end of a letter string or
  word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.003636Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4780-5
  a curric:KeyLearningPoint ;
  rdfs:label "The letters l, k and f all reach up to the ascender line."@en ;
  dcterms:modified "2026-06-07T15:30:29.003641Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4796-1
  a curric:KeyLearningPoint ;
  rdfs:label "Common exception words do not follow regular spelling or phonics rules."@en ;
  dcterms:modified "2026-06-07T15:30:29.003788Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4796-2
  a curric:KeyLearningPoint ;
  rdfs:label """Letters in the common exception words will be joined using a range of joins
  depending on the letters in the word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.003792Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4796-3
  a curric:KeyLearningPoint ;
  rdfs:label "The first letter starts at the correct starting point."@en ;
  dcterms:modified "2026-06-07T15:30:29.003798Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4796-4
  a curric:KeyLearningPoint ;
  rdfs:label "There is appropriate spacing between the letters."@en ;
  dcterms:modified "2026-06-07T15:30:29.003803Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4796-5
  a curric:KeyLearningPoint ;
  rdfs:label """You don't lift your pencil to add the 'cross' for the letter t until the letter
  string is complete."""@en ;
  dcterms:modified "2026-06-07T15:30:29.003807Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-977-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Because' is a joining word."@en ;
  dcterms:modified "2026-06-07T15:30:29.003823Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-977-2
  a curric:KeyLearningPoint ;
  rdfs:label """A simple sentence can be stretched with 'because' to give a reason to the first
  idea."""@en ;
  dcterms:modified "2026-06-07T15:30:29.003827Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-977-3
  a curric:KeyLearningPoint ;
  rdfs:label """Joining the first idea with 'because' forms a second idea that is subordinate to the
  first."""@en ;
  dcterms:modified "2026-06-07T15:30:29.003831Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-977-4
  a curric:KeyLearningPoint ;
  rdfs:label """Using 'because' to stretch a simple sentence forms an adverbial complex
  sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.003835Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7182-1
  a curric:KeyLearningPoint ;
  rdfs:label "A letter may include questions which you have to reply to"@en ;
  dcterms:modified "2026-06-07T15:30:29.004255Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7182-2
  a curric:KeyLearningPoint ;
  rdfs:label "A further question might be asked at the end of the letter so someone can reply"@en ;
  dcterms:modified "2026-06-07T15:30:29.004259Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7182-3
  a curric:KeyLearningPoint ;
  rdfs:label "Questions must end in a question mark"@en ;
  dcterms:modified "2026-06-07T15:30:29.004265Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7182-4
  a curric:KeyLearningPoint ;
  rdfs:label "A question is a type of simple sentence that asks someone for an answer"@en ;
  dcterms:modified "2026-06-07T15:30:29.004270Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7182-5
  a curric:KeyLearningPoint ;
  rdfs:label """Letters need to end with a closing and the writer's name so the reader knows who the
  letter is from"""@en ;
  dcterms:modified "2026-06-07T15:30:29.004274Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1018-1
  a curric:KeyLearningPoint ;
  rdfs:label "An apostrophe is an important piece of punctuation."@en ;
  dcterms:modified "2026-06-07T15:30:29.004324Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1018-2
  a curric:KeyLearningPoint ;
  rdfs:label "An apostrophe has more than one purpose."@en ;
  dcterms:modified "2026-06-07T15:30:29.004328Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1018-3
  a curric:KeyLearningPoint ;
  rdfs:label "An apostrophe can contract two words together."@en ;
  dcterms:modified "2026-06-07T15:30:29.004332Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1018-4
  a curric:KeyLearningPoint ;
  rdfs:label "Apostrophes for contraction are useful in informal writing."@en ;
  dcterms:modified "2026-06-07T15:30:29.004336Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1018-5
  a curric:KeyLearningPoint ;
  rdfs:label "An apostrophe sits at the same height as the ascender of a letter."@en ;
  dcterms:modified "2026-06-07T15:30:29.004340Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8689-1
  a curric:KeyLearningPoint ;
  rdfs:label "An adjective describes a noun, such as \"helpful nurse\""@en ;
  dcterms:modified "2026-06-07T15:30:29.004347Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8689-2
  a curric:KeyLearningPoint ;
  rdfs:label "Adjectives are describing words"@en ;
  dcterms:modified "2026-06-07T15:30:29.004351Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8689-3
  a curric:KeyLearningPoint ;
  rdfs:label "Adjectives can describe a person's appearance and personality"@en ;
  dcterms:modified "2026-06-07T15:30:29.004355Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8689-4
  a curric:KeyLearningPoint ;
  rdfs:label "A person's character traits make that person who they are"@en ;
  dcterms:modified "2026-06-07T15:30:29.004359Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8689-5
  a curric:KeyLearningPoint ;
  rdfs:label """Certain jobs require certain character traits, such as \"patient\", \"caring\" and
  \"kind\""""@en ;
  dcterms:modified "2026-06-07T15:30:29.004363Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6205-1
  a curric:KeyLearningPoint ;
  rdfs:label """An information text about an author provides information about their life, e.g.
  childhood, inspiration, jobs and books."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004369Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6205-2
  a curric:KeyLearningPoint ;
  rdfs:label """Atinuke is a Nigerian born author whose stories are inspired by African culture and
  traditional storytelling."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004373Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6205-3
  a curric:KeyLearningPoint ;
  rdfs:label """Roald Dahl was a British author who wrote popular children’s literature containing
  imaginative and magical elements."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004378Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6205-4
  a curric:KeyLearningPoint ;
  rdfs:label """Ibtihaj Muhammad is an American fencer and author who was inspired to write stories
  celebrating the Muslim identity."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004382Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6205-5
  a curric:KeyLearningPoint ;
  rdfs:label """Developing a personal response to what we have read can inspire in writing our own
  information text."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004386Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27775-1
  a curric:KeyLearningPoint ;
  rdfs:label "A numeral is a digit that represents a number."@en ;
  dcterms:modified "2026-06-07T15:30:29.004390Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27775-2
  a curric:KeyLearningPoint ;
  rdfs:label """The numerals 6, 7, 8 and 9 are made using one continuous movement and without
  lifting your pencil."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004394Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27775-3
  a curric:KeyLearningPoint ;
  rdfs:label """The formation of the numeral 10 requires you to lift your pencil as it has two
  separate digits."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004398Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27775-4
  a curric:KeyLearningPoint ;
  rdfs:label "The numerals 6 to 10 all sit on the baseline."@en ;
  dcterms:modified "2026-06-07T15:30:29.004402Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7211-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Blissful' is an adjective which means feeling completely happy in every way."@en ;
  dcterms:modified "2026-06-07T15:30:29.004406Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7211-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Euphoric' is an adjective which means feeling extreme happiness and joy."@en ;
  dcterms:modified "2026-06-07T15:30:29.004410Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7211-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Cheerful' and 'elated' are other adjectives associated with happiness."@en ;
  dcterms:modified "2026-06-07T15:30:29.004414Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7211-4
  a curric:KeyLearningPoint ;
  rdfs:label "Word choices must be precise in writing and speaking."@en ;
  dcterms:modified "2026-06-07T15:30:29.004418Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28628-1
  a curric:KeyLearningPoint ;
  rdfs:label """The poem ‘Elephant Beat’ tells a story about the adventure of riding an
  elephant."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004425Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28628-2
  a curric:KeyLearningPoint ;
  rdfs:label "It has a structured rhythm, which gives it a marching feel."@en ;
  dcterms:modified "2026-06-07T15:30:29.004429Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28628-3
  a curric:KeyLearningPoint ;
  rdfs:label """‘Night Soup’ is a poem about creating an imaginary, magical ‘soup’ made from
  elements of the night."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004434Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28628-4
  a curric:KeyLearningPoint ;
  rdfs:label "When performing a poem, we can vary our volume to create different effects."@en ;
  dcterms:modified "2026-06-07T15:30:29.004438Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28628-5
  a curric:KeyLearningPoint ;
  rdfs:label """Using expression and gestures can make our performances fun and interesting for the
  audience to watch."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004442Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5646-1
  a curric:KeyLearningPoint ;
  rdfs:label "Non-chronological reports are non-fiction."@en ;
  dcterms:modified "2026-06-07T15:30:29.004465Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5646-2
  a curric:KeyLearningPoint ;
  rdfs:label "Non-chronological reports often have titles, subheadings and paragraphs."@en ;
  dcterms:modified "2026-06-07T15:30:29.004469Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5646-3
  a curric:KeyLearningPoint ;
  rdfs:label """An introduction followed by two paragraphs of information is how we can structure a
  non-chronological report."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004474Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5650-1
  a curric:KeyLearningPoint ;
  rdfs:label "A question to the reader should end with a question mark."@en ;
  dcterms:modified "2026-06-07T15:30:29.004529Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5650-2
  a curric:KeyLearningPoint ;
  rdfs:label """Using interesting general facts can gain the reader’s interest and make them want to
  read the full report."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004533Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5650-3
  a curric:KeyLearningPoint ;
  rdfs:label "A command should start with an imperative verb and entice the reader to read on."@en ;
  dcterms:modified "2026-06-07T15:30:29.004537Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4792-1
  a curric:KeyLearningPoint ;
  rdfs:label "High frequency words are words that appear most frequently in written texts."@en ;
  dcterms:modified "2026-06-07T15:30:29.004600Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4792-2
  a curric:KeyLearningPoint ;
  rdfs:label """Letters in the high frequency words will be joined using a range of joins depending
  on the letters in the word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004604Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4792-3
  a curric:KeyLearningPoint ;
  rdfs:label """The first letter of the word always has a lead in and the last letter has a lead
  out."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004608Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4792-4
  a curric:KeyLearningPoint ;
  rdfs:label "There is appropriate spacing between the letters."@en ;
  dcterms:modified "2026-06-07T15:30:29.004613Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4792-5
  a curric:KeyLearningPoint ;
  rdfs:label "You don’t lift your pencil until the letter string is complete."@en ;
  dcterms:modified "2026-06-07T15:30:29.004617Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4775-1
  a curric:KeyLearningPoint ;
  rdfs:label "The letters are formed by following the right starting point and direction."@en ;
  dcterms:modified "2026-06-07T15:30:29.251303Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4775-2
  a curric:KeyLearningPoint ;
  rdfs:label """The second join goes from the baseline to the ascender line when joining to a tall
  letter."""@en ;
  dcterms:modified "2026-06-07T15:30:29.251308Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4775-3
  a curric:KeyLearningPoint ;
  rdfs:label """The second join goes from the baseline to in between the x-height line and the
  ascender line when joining the letter t."""@en ;
  dcterms:modified "2026-06-07T15:30:29.251313Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4775-4
  a curric:KeyLearningPoint ;
  rdfs:label """The pencil only lifts to add the cross to the t once you have finished the letter
  string."""@en ;
  dcterms:modified "2026-06-07T15:30:29.251318Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4775-5
  a curric:KeyLearningPoint ;
  rdfs:label "When two letter ts are together, one cross can go across both."@en ;
  dcterms:modified "2026-06-07T15:30:29.251323Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4767-1
  a curric:KeyLearningPoint ;
  rdfs:label "The letters all have a lead in and a lead out."@en ;
  dcterms:modified "2026-06-07T15:30:29.252226Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4767-2
  a curric:KeyLearningPoint ;
  rdfs:label "The pencil does not lift when forming the join."@en ;
  dcterms:modified "2026-06-07T15:30:29.252231Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4767-3
  a curric:KeyLearningPoint ;
  rdfs:label "The fourth join goes from the x-height line up towards the ascender line."@en ;
  dcterms:modified "2026-06-07T15:30:29.252236Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4767-4
  a curric:KeyLearningPoint ;
  rdfs:label "The joins wl, ok and rl all reach the ascender line."@en ;
  dcterms:modified "2026-06-07T15:30:29.252241Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4767-5
  a curric:KeyLearningPoint ;
  rdfs:label "The join rt, reaches to between the x-height line and the ascender line."@en ;
  dcterms:modified "2026-06-07T15:30:29.252246Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4788-1
  a curric:KeyLearningPoint ;
  rdfs:label "Proper nouns name specific people, places and things."@en ;
  dcterms:modified "2026-06-07T15:30:29.252450Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4788-2
  a curric:KeyLearningPoint ;
  rdfs:label """After forming a capital letter, you need to lift your pencil to start the next part
  of the word with a lead in."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252454Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4788-3
  a curric:KeyLearningPoint ;
  rdfs:label "Capital letters do not join to the next letter, they sit on their own."@en ;
  dcterms:modified "2026-06-07T15:30:29.252459Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4788-4
  a curric:KeyLearningPoint ;
  rdfs:label """The remaining letters in the proper noun will be joined using a range of joins
  depending on the letters in the word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252464Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4788-5
  a curric:KeyLearningPoint ;
  rdfs:label "The last letter has a lead out."@en ;
  dcterms:modified "2026-06-07T15:30:29.252469Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4774-1
  a curric:KeyLearningPoint ;
  rdfs:label "The letters are formed by following the right starting point and direction."@en ;
  dcterms:modified "2026-06-07T15:30:29.257169Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4774-2
  a curric:KeyLearningPoint ;
  rdfs:label "All of the letters have a starting point on the x-height line."@en ;
  dcterms:modified "2026-06-07T15:30:29.257173Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4774-3
  a curric:KeyLearningPoint ;
  rdfs:label """The second join goes from the baseline to the ascender line when joining to a tall
  letter."""@en ;
  dcterms:modified "2026-06-07T15:30:29.257179Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4774-4
  a curric:KeyLearningPoint ;
  rdfs:label """The second join goes from the baseline to in between the x-height line and the
  ascender line when joining the letter t."""@en ;
  dcterms:modified "2026-06-07T15:30:29.257184Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4774-5
  a curric:KeyLearningPoint ;
  rdfs:label """The pencil only lifts to add the dot to the i and the cross to the t once you have
  finished the letter string."""@en ;
  dcterms:modified "2026-06-07T15:30:29.257188Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-36-1
  a curric:KeyLearningPoint ;
  rdfs:label "The letters v, w, x and z are all x-height letters."@en ;
  dcterms:modified "2026-06-07T15:30:29.265946Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-36-2
  a curric:KeyLearningPoint ;
  rdfs:label "The letters v and w are formed by \"going diagonally down and back up\"."@en ;
  dcterms:modified "2026-06-07T15:30:29.265950Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-36-3
  a curric:KeyLearningPoint ;
  rdfs:label """The letter x is formed by making two diagonal straight lines crossing in the
  centre."""@en ;
  dcterms:modified "2026-06-07T15:30:29.265954Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-36-4
  a curric:KeyLearningPoint ;
  rdfs:label """The letter z is formed by a zigzag pattern with a straight, then diagonal and then a
  straight line."""@en ;
  dcterms:modified "2026-06-07T15:30:29.265958Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6826-1
  a curric:KeyLearningPoint ;
  rdfs:label "An adjective describes a noun"@en ;
  dcterms:modified "2026-06-07T15:30:29.266060Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6826-2
  a curric:KeyLearningPoint ;
  rdfs:label "Using descriptions with adjectives makes writing more interesting"@en ;
  dcterms:modified "2026-06-07T15:30:29.266065Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6826-3
  a curric:KeyLearningPoint ;
  rdfs:label """Adjectives are often put in front of the noun in a sentence, such as 'a mean
  troll'"""@en ;
  dcterms:modified "2026-06-07T15:30:29.266069Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6826-4
  a curric:KeyLearningPoint ;
  rdfs:label """Adjectives can be used to describe what a character might look like, such as
  'huge'"""@en ;
  dcterms:modified "2026-06-07T15:30:29.266072Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6826-5
  a curric:KeyLearningPoint ;
  rdfs:label "Adjectives can also describe a character's personality, such as 'selfish'"@en ;
  dcterms:modified "2026-06-07T15:30:29.266076Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5477-1
  a curric:KeyLearningPoint ;
  rdfs:label """Retelling a story helps to remember the main events and use storytelling language,
  such as 'Once upon a time,'"""@en ;
  dcterms:modified "2026-06-07T15:30:29.266098Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5477-2
  a curric:KeyLearningPoint ;
  rdfs:label "Story mountains map out the beginning, middle and end"@en ;
  dcterms:modified "2026-06-07T15:30:29.266102Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5477-3
  a curric:KeyLearningPoint ;
  rdfs:label "Only the most important events in the story need to be on a story mountain"@en ;
  dcterms:modified "2026-06-07T15:30:29.266105Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5477-4
  a curric:KeyLearningPoint ;
  rdfs:label """Using sequencing language such as 'The next day,' at the start of the sentence helps
  the reader follow the story"""@en ;
  dcterms:modified "2026-06-07T15:30:29.266109Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5477-5
  a curric:KeyLearningPoint ;
  rdfs:label "Adding descriptive language will help when the story is being written"@en ;
  dcterms:modified "2026-06-07T15:30:29.266115Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4791-1
  a curric:KeyLearningPoint ;
  rdfs:label "Common exception words do not follow regular spelling or phonics rules."@en ;
  dcterms:modified "2026-06-07T15:30:29.266177Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4791-2
  a curric:KeyLearningPoint ;
  rdfs:label """Letters in the common exception words will be joined using a range of joins
  depending on the letters in the word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.266181Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4791-3
  a curric:KeyLearningPoint ;
  rdfs:label "The first letter always has a lead in and the last letter always has a lead out."@en ;
  dcterms:modified "2026-06-07T15:30:29.266185Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4791-4
  a curric:KeyLearningPoint ;
  rdfs:label "There is appropriate spacing between the letters."@en ;
  dcterms:modified "2026-06-07T15:30:29.266189Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4791-5
  a curric:KeyLearningPoint ;
  rdfs:label """You don't lift your pencil to add the 'dot' for the letter i until the letter string
  is complete."""@en ;
  dcterms:modified "2026-06-07T15:30:29.266192Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28630-1
  a curric:KeyLearningPoint ;
  rdfs:label "‘Say How You Feel’ is a poem that explores different emotions."@en ;
  dcterms:modified "2026-06-07T15:30:29.266196Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28630-2
  a curric:KeyLearningPoint ;
  rdfs:label """Each verse describes a different emotion using vivid imagery, metaphors and
  similes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.266200Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28630-3
  a curric:KeyLearningPoint ;
  rdfs:label "Joseph Coelho performs the poem using the voice of each emotion."@en ;
  dcterms:modified "2026-06-07T15:30:29.266204Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28630-4
  a curric:KeyLearningPoint ;
  rdfs:label "We can vary our voice to show different emotions."@en ;
  dcterms:modified "2026-06-07T15:30:29.266207Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28630-5
  a curric:KeyLearningPoint ;
  rdfs:label """Using facial expressions and gestures can help to add meaning to our
  performances."""@en ;
  dcterms:modified "2026-06-07T15:30:29.266211Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28631-1
  a curric:KeyLearningPoint ;
  rdfs:label "‘Animals’ is a collection of short poems that explore different animals."@en ;
  dcterms:modified "2026-06-07T15:30:29.266362Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28631-2
  a curric:KeyLearningPoint ;
  rdfs:label "Each poem describes an animal, using different imagery and poetic devices."@en ;
  dcterms:modified "2026-06-07T15:30:29.266365Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28631-3
  a curric:KeyLearningPoint ;
  rdfs:label "We can vary our voice to show how each animal might speak."@en ;
  dcterms:modified "2026-06-07T15:30:29.266371Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28631-4
  a curric:KeyLearningPoint ;
  rdfs:label """Using facial expressions and gestures can help to add meaning to our
  performances."""@en ;
  dcterms:modified "2026-06-07T15:30:29.266375Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20074-1
  a curric:KeyLearningPoint ;
  rdfs:label """An adjective or list of adjectives can describe a noun, such as 'sweet mango' or
  'noisy, chirping birds'"""@en ;
  dcterms:modified "2026-06-07T15:30:29.266841Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20074-2
  a curric:KeyLearningPoint ;
  rdfs:label """Describing a setting using senses helps the reader to imagine they are there or have
  been there."""@en ;
  dcterms:modified "2026-06-07T15:30:29.266845Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20074-3
  a curric:KeyLearningPoint ;
  rdfs:label """The joining word 'and' can be used to join two complete ideas into a full
  sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.266848Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20074-4
  a curric:KeyLearningPoint ;
  rdfs:label "Joining two simple sentences with the joining word 'and' is a compound sentence."@en ;
  dcterms:modified "2026-06-07T15:30:29.266852Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8687-1
  a curric:KeyLearningPoint ;
  rdfs:label """Thinking from the character's point of view helps to understand events in
  the story"""@en ;
  dcterms:modified "2026-06-07T15:30:29.266875Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8687-2
  a curric:KeyLearningPoint ;
  rdfs:label "Re-reading the story is useful to remembering the key events"@en ;
  dcterms:modified "2026-06-07T15:30:29.266879Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8687-3
  a curric:KeyLearningPoint ;
  rdfs:label "This story's plot is based around introducing different characters"@en ;
  dcterms:modified "2026-06-07T15:30:29.266882Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8687-4
  a curric:KeyLearningPoint ;
  rdfs:label """Meeting these characters makes the reader reconsider what they define a 'superhero'
  as"""@en ;
  dcterms:modified "2026-06-07T15:30:29.266886Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8687-5
  a curric:KeyLearningPoint ;
  rdfs:label "A job is what someone does for work"@en ;
  dcterms:modified "2026-06-07T15:30:29.266892Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6184-1
  a curric:KeyLearningPoint ;
  rdfs:label "A viewpoint is how you see or feel about something."@en ;
  dcterms:modified "2026-06-07T15:30:29.266911Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6184-2
  a curric:KeyLearningPoint ;
  rdfs:label """Viewpoint fronted adverbials are sentence starters that share the writer’s view on
  something."""@en ;
  dcterms:modified "2026-06-07T15:30:29.266915Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6184-3
  a curric:KeyLearningPoint ;
  rdfs:label "All fronted adverbials start with capital letters and have a comma after."@en ;
  dcterms:modified "2026-06-07T15:30:29.266919Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6184-4
  a curric:KeyLearningPoint ;
  rdfs:label """This section of the report contains interesting facts about Florence Nightingale's
  life."""@en ;
  dcterms:modified "2026-06-07T15:30:29.266923Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6184-5
  a curric:KeyLearningPoint ;
  rdfs:label """Sentences should be said aloud before writing to ensure they make sense and read
  back once written to check for errors."""@en ;
  dcterms:modified "2026-06-07T15:30:29.266927Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6196-1
  a curric:KeyLearningPoint ;
  rdfs:label "Hedgehogs have thousands of spikes on their backs which are called spines."@en ;
  dcterms:modified "2026-06-07T15:30:29.266945Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6196-2
  a curric:KeyLearningPoint ;
  rdfs:label """Hedgehogs protect themselves by curling up into a ball with their spines
  facing out."""@en ;
  dcterms:modified "2026-06-07T15:30:29.266949Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6196-3
  a curric:KeyLearningPoint ;
  rdfs:label "The name for an animal that tries to eat another animal is predator."@en ;
  dcterms:modified "2026-06-07T15:30:29.266953Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6196-4
  a curric:KeyLearningPoint ;
  rdfs:label "The name for an animal that other animals try to eat is prey."@en ;
  dcterms:modified "2026-06-07T15:30:29.266959Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6196-5
  a curric:KeyLearningPoint ;
  rdfs:label "Habitat is the name for the place that an animal lives."@en ;
  dcterms:modified "2026-06-07T15:30:29.266963Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-975-1
  a curric:KeyLearningPoint ;
  rdfs:label """In contractions, the apostrophe shows where a letter or letters would be if the
  words were written in full."""@en ;
  dcterms:modified "2026-06-07T15:30:29.267199Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-975-2
  a curric:KeyLearningPoint ;
  rdfs:label """Saying the expanded form of a contraction can help to identify where the apostrophe
  goes and how to spell it."""@en ;
  dcterms:modified "2026-06-07T15:30:29.267203Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-970-1
  a curric:KeyLearningPoint ;
  rdfs:label """A suffix is a letter or group of letters at the end of a word which creates another
  word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.267207Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-970-2
  a curric:KeyLearningPoint ;
  rdfs:label "Adding '-er' creates an extra syllable to the word."@en ;
  dcterms:modified "2026-06-07T15:30:29.267211Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-970-3
  a curric:KeyLearningPoint ;
  rdfs:label "If the adjective ends in two consonant letters, the ending is simply added on."@en ;
  dcterms:modified "2026-06-07T15:30:29.267215Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-970-4
  a curric:KeyLearningPoint ;
  rdfs:label """If the root word ends in a consonant + 'y', the 'y' is changed to 'i' before the
  suffix is added."""@en ;
  dcterms:modified "2026-06-07T15:30:29.267218Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-970-5
  a curric:KeyLearningPoint ;
  rdfs:label """If the root word ends in a consonant + 'e', the 'e' is removed before the suffix is
  added."""@en ;
  dcterms:modified "2026-06-07T15:30:29.267222Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5445-1
  a curric:KeyLearningPoint ;
  rdfs:label "A chorus is a part of a poem that repeats again and again."@en ;
  dcterms:modified "2026-06-07T15:30:29.267228Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5445-2
  a curric:KeyLearningPoint ;
  rdfs:label "Onomatopoeia is when a word sounds like what it is describing."@en ;
  dcterms:modified "2026-06-07T15:30:29.267232Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5445-3
  a curric:KeyLearningPoint ;
  rdfs:label "Poems can make the listener think about their own experiences."@en ;
  dcterms:modified "2026-06-07T15:30:29.267236Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5445-4
  a curric:KeyLearningPoint ;
  rdfs:label """Repetition adds to the rhythm of the poem helping to make it fun to read and easy to
  remember."""@en ;
  dcterms:modified "2026-06-07T15:30:29.267240Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5445-5
  a curric:KeyLearningPoint ;
  rdfs:label """Splish! Splash! Splosh! uses lots of descriptive words to talk about different
  sensory experiences about water."""@en ;
  dcterms:modified "2026-06-07T15:30:29.267244Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4768-1
  a curric:KeyLearningPoint ;
  rdfs:label "The letters all have a lead in and a lead out."@en ;
  dcterms:modified "2026-06-07T15:30:29.268785Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4768-2
  a curric:KeyLearningPoint ;
  rdfs:label "The pencil does not lift when forming the join."@en ;
  dcterms:modified "2026-06-07T15:30:29.268788Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4768-3
  a curric:KeyLearningPoint ;
  rdfs:label """The third join starts at the x-height line and dips below the x-height line and back
  up to join the next letter."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268792Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4768-4
  a curric:KeyLearningPoint ;
  rdfs:label """When connecting the letter e, with the third join, the dip down starts the formation
  of the letter e."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268798Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4741-1
  a curric:KeyLearningPoint ;
  rdfs:label "The capital letters A, H, K and T all start at the top tramline."@en ;
  dcterms:modified "2026-06-07T15:30:29.269687Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4741-2
  a curric:KeyLearningPoint ;
  rdfs:label """The formation of capital letters A, H, K and T need you to lift your pencil to add
  the other lines."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269692Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5411-1
  a curric:KeyLearningPoint ;
  rdfs:label "The plot is what happens in a story"@en ;
  dcterms:modified "2026-06-07T15:30:29.269922Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5411-2
  a curric:KeyLearningPoint ;
  rdfs:label """Fiction stories can sometimes teach us about real life experiences, such as how to
  care for a pet"""@en ;
  dcterms:modified "2026-06-07T15:30:29.269926Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5411-3
  a curric:KeyLearningPoint ;
  rdfs:label "Illustrations, as well as the text, can help us to engage and respond to a story"@en ;
  dcterms:modified "2026-06-07T15:30:29.269930Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5411-4
  a curric:KeyLearningPoint ;
  rdfs:label "Illustrations and the text can help us to describe the characters in stories"@en ;
  dcterms:modified "2026-06-07T15:30:29.269933Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5411-5
  a curric:KeyLearningPoint ;
  rdfs:label "People can have different personal responses to what they have read"@en ;
  dcterms:modified "2026-06-07T15:30:29.269937Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8132-1
  a curric:KeyLearningPoint ;
  rdfs:label "Reading aloud is a way to present your writing to an audience."@en ;
  dcterms:modified "2026-06-07T15:30:29.269972Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8132-2
  a curric:KeyLearningPoint ;
  rdfs:label """Volume, eye contact, body language and pace are important for connecting to the
  audience effectively."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269979Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8132-3
  a curric:KeyLearningPoint ;
  rdfs:label "Style of presentation is impacted by what you are reading aloud."@en ;
  dcterms:modified "2026-06-07T15:30:29.269983Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8132-4
  a curric:KeyLearningPoint ;
  rdfs:label """Personal writing should be delivered in an expressive and emotive way using emphasis
  where appropriate."""@en ;
  dcterms:modified "2026-06-07T15:30:29.269987Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8132-5
  a curric:KeyLearningPoint ;
  rdfs:label "Rehearsing reading aloud helps to prepare us for presenting."@en ;
  dcterms:modified "2026-06-07T15:30:29.269990Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-898-1
  a curric:KeyLearningPoint ;
  rdfs:label "Adverbs describe verbs."@en ;
  dcterms:modified "2026-06-07T15:30:29.269996Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-898-2
  a curric:KeyLearningPoint ;
  rdfs:label "Adverbs tell the reader how a verb is or was done."@en ;
  dcterms:modified "2026-06-07T15:30:29.270000Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-898-3
  a curric:KeyLearningPoint ;
  rdfs:label "Adverbs often end in -ly."@en ;
  dcterms:modified "2026-06-07T15:30:29.270004Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-898-4
  a curric:KeyLearningPoint ;
  rdfs:label "An adverb is often paired with the verb it is describing."@en ;
  dcterms:modified "2026-06-07T15:30:29.270008Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-926-1
  a curric:KeyLearningPoint ;
  rdfs:label """'e' is a representation of the 'ee' phoneme that is often found in short high
  frequency words."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271593Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-926-2
  a curric:KeyLearningPoint ;
  rdfs:label """'y' is a representation of the 'ee' phoneme that is often found at the end of a
  word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271599Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-926-3
  a curric:KeyLearningPoint ;
  rdfs:label """'ey' is a representation of the 'ee' phoneme that is often found at the end of a
  word, such as money."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271603Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-926-4
  a curric:KeyLearningPoint ;
  rdfs:label """'ie' is a representation of the 'ee' phoneme that is often found in the middle of a
  word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271609Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-926-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the common exception words: fast, last, past and plant."@en ;
  dcterms:modified "2026-06-07T15:30:29.271613Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4739-1
  a curric:KeyLearningPoint ;
  rdfs:label "The capital letters B, D, P and R all start at the top tramline."@en ;
  dcterms:modified "2026-06-07T15:30:29.271636Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4739-2
  a curric:KeyLearningPoint ;
  rdfs:label "The capital letters B, D, P and R all go straight down and back up and around."@en ;
  dcterms:modified "2026-06-07T15:30:29.271640Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4739-3
  a curric:KeyLearningPoint ;
  rdfs:label """The capital letters are formed by one continuous movement and you do not need to
  lift your pencil."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271643Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-918-1
  a curric:KeyLearningPoint ;
  rdfs:label "Joining two simple sentences with 'and', 'but' or 'or' is called co-ordination."@en ;
  dcterms:modified "2026-06-07T15:30:29.271668Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-918-2
  a curric:KeyLearningPoint ;
  rdfs:label "'And', 'but' and 'or' are three different co-ordinating conjunctions."@en ;
  dcterms:modified "2026-06-07T15:30:29.271672Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-918-3
  a curric:KeyLearningPoint ;
  rdfs:label """A compound sentence is formed of at least two equal ideas and at least one
  co-ordinating conjunction."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271676Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-918-4
  a curric:KeyLearningPoint ;
  rdfs:label "A compound sentence has at least two different verbs."@en ;
  dcterms:modified "2026-06-07T15:30:29.271680Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7213-1
  a curric:KeyLearningPoint ;
  rdfs:label """'Fuming' is an adjective which means you are feeling lots of anger building up
  inside."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271683Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7213-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Grumpy' is an adjective which means you are feeling stuck in a bad mood."@en ;
  dcterms:modified "2026-06-07T15:30:29.271689Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7213-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Annoyed' and 'frustrated' are other adjectives associated with anger."@en ;
  dcterms:modified "2026-06-07T15:30:29.271693Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7213-4
  a curric:KeyLearningPoint ;
  rdfs:label "Word choices must be precise in writing and speaking."@en ;
  dcterms:modified "2026-06-07T15:30:29.271697Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6282-1
  a curric:KeyLearningPoint ;
  rdfs:label "Perspective is the way someone thinks, feels or sees something."@en ;
  dcterms:modified "2026-06-07T15:30:29.271720Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6282-2
  a curric:KeyLearningPoint ;
  rdfs:label "Writing in a diary will mostly be in the past tense."@en ;
  dcterms:modified "2026-06-07T15:30:29.271724Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6282-3
  a curric:KeyLearningPoint ;
  rdfs:label "A diary entry should be written in the first person."@en ;
  dcterms:modified "2026-06-07T15:30:29.271728Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6282-4
  a curric:KeyLearningPoint ;
  rdfs:label """First person is a point of view in writing or storytelling where the narrator or
  speaker refers to themselves."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271733Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6170-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the climax is to describe the significant challenge and create the
  highest point of tension."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271753Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6170-2
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials of manner tell the reader how something was done or how a
  character felt."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271757Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6170-3
  a curric:KeyLearningPoint ;
  rdfs:label """Rhetorical questions are questions addressed directly to the reader where an answer
  is not expected."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271760Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5643-1
  a curric:KeyLearningPoint ;
  rdfs:label "Instructions use a title to tell the reader what they are about."@en ;
  dcterms:modified "2026-06-07T15:30:29.271764Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5643-2
  a curric:KeyLearningPoint ;
  rdfs:label "Instructions can use an introduction to capture the reader’s interest."@en ;
  dcterms:modified "2026-06-07T15:30:29.271768Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5643-3
  a curric:KeyLearningPoint ;
  rdfs:label "Recipes can contain an ingredients list to tell the reader what they will need."@en ;
  dcterms:modified "2026-06-07T15:30:29.271772Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4747-1
  a curric:KeyLearningPoint ;
  rdfs:label """The formation of the numerals 6, 7, 8 and 9 can be done with one continuous motion
  without lifting your pencil."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271787Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4747-2
  a curric:KeyLearningPoint ;
  rdfs:label """The formation of the numeral 10 requires you to lift your pencil as it has two
  digits."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271790Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4747-3
  a curric:KeyLearningPoint ;
  rdfs:label """The numerals 6, 7, 8, 9 and 10 all sit between the baseline and the ascender
  line."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271794Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-911-1
  a curric:KeyLearningPoint ;
  rdfs:label "And is a type of joining word."@en ;
  dcterms:modified "2026-06-07T15:30:29.271798Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-911-2
  a curric:KeyLearningPoint ;
  rdfs:label "A joining word can join two simple sentences."@en ;
  dcterms:modified "2026-06-07T15:30:29.271804Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-911-3
  a curric:KeyLearningPoint ;
  rdfs:label "Each simple sentence is about one idea and makes complete sense."@en ;
  dcterms:modified "2026-06-07T15:30:29.271808Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-911-4
  a curric:KeyLearningPoint ;
  rdfs:label "The second idea builds on to the first idea if ‘and’ is used to join them."@en ;
  dcterms:modified "2026-06-07T15:30:29.271812Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-911-5
  a curric:KeyLearningPoint ;
  rdfs:label """Grammatically accurate sentences start with capital letters and most often end with
  full stops."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271819Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29013-1
  a curric:KeyLearningPoint ;
  rdfs:label "There may be similarities and differences when comparing two traditional tales."@en ;
  dcterms:modified "2026-06-07T15:30:29.271823Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29013-2
  a curric:KeyLearningPoint ;
  rdfs:label """Thinking about characters, events in the plot and the setting can be helpful when
  comparing two traditional tales."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271827Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29013-3
  a curric:KeyLearningPoint ;
  rdfs:label """Traditional tales often start by introducing the characters, such as seeing the
  three pigs leaving their homes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271831Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29013-4
  a curric:KeyLearningPoint ;
  rdfs:label "'The Three Little Pigs' teaches us about teamwork."@en ;
  dcterms:modified "2026-06-07T15:30:29.271835Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29013-5
  a curric:KeyLearningPoint ;
  rdfs:label """Traditional tales mostly end happily, such as feeling safe and secure in your home
  with your family."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271841Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27-1
  a curric:KeyLearningPoint ;
  rdfs:label "Sitting position is important for handwriting."@en ;
  dcterms:modified "2026-06-07T15:30:29.271875Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27-2
  a curric:KeyLearningPoint ;
  rdfs:label "A comfortable pencil grip can make handwriting easier."@en ;
  dcterms:modified "2026-06-07T15:30:29.271880Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27-3
  a curric:KeyLearningPoint ;
  rdfs:label "It takes practice to be able to form a letter correctly."@en ;
  dcterms:modified "2026-06-07T15:30:29.271884Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27-4
  a curric:KeyLearningPoint ;
  rdfs:label "Handwriting patterns can help prepare to form letters."@en ;
  dcterms:modified "2026-06-07T15:30:29.271888Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27-5
  a curric:KeyLearningPoint ;
  rdfs:label """There are some letter formations that require you to lift the pencil to add a dot or
  a cross."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271892Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8903-1
  a curric:KeyLearningPoint ;
  rdfs:label """a character description of yourself can be made about your personality and your
  appearance"""@en ;
  dcterms:modified "2026-06-07T15:30:29.273826Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8903-2
  a curric:KeyLearningPoint ;
  rdfs:label """describing your personality is about what you are like on the inside and how you
  feel, such as \"curious\", \"resilient\""""@en ;
  dcterms:modified "2026-06-07T15:30:29.273832Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8903-3
  a curric:KeyLearningPoint ;
  rdfs:label """describing your appearance is about what you look like such as \"curly,
  brown hair\""""@en ;
  dcterms:modified "2026-06-07T15:30:29.273836Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8903-4
  a curric:KeyLearningPoint ;
  rdfs:label """descriptions can create expanded noun phrases or be listed as nouns separated by a
  comma, like ‘socks, jumper and hat’"""@en ;
  dcterms:modified "2026-06-07T15:30:29.273840Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8903-5
  a curric:KeyLearningPoint ;
  rdfs:label """using verbs and adverbs can help to explain the adjectives you have chosen to
  describe yourself"""@en ;
  dcterms:modified "2026-06-07T15:30:29.273844Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8527-1
  a curric:KeyLearningPoint ;
  rdfs:label """We can find out what a character is like in a variety of ways, including using the
  illustrations."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273848Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8527-2
  a curric:KeyLearningPoint ;
  rdfs:label """The setting is where the story takes place, such as the island, or Grandad's
  house."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273851Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8527-3
  a curric:KeyLearningPoint ;
  rdfs:label "In this story the plot is developed through words and illustrations."@en ;
  dcterms:modified "2026-06-07T15:30:29.273855Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8527-4
  a curric:KeyLearningPoint ;
  rdfs:label "Reading aloud can help to bring the story alive."@en ;
  dcterms:modified "2026-06-07T15:30:29.273861Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8527-5
  a curric:KeyLearningPoint ;
  rdfs:label """Imagining how a character is feeling helps us to think from their perspective, such
  as Syd feeling sad."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273865Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4746-1
  a curric:KeyLearningPoint ;
  rdfs:label "The numerals 0, 1, 2, 3 and 5 are formed using one contionous motion."@en ;
  dcterms:modified "2026-06-07T15:30:29.273869Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4746-2
  a curric:KeyLearningPoint ;
  rdfs:label "The numeral 4 needs you to lift your pencil to add another line."@en ;
  dcterms:modified "2026-06-07T15:30:29.273872Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4746-3
  a curric:KeyLearningPoint ;
  rdfs:label "A numeral is a digit which represents a number."@en ;
  dcterms:modified "2026-06-07T15:30:29.273876Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8925-1
  a curric:KeyLearningPoint ;
  rdfs:label "An adjective describes a noun"@en ;
  dcterms:modified "2026-06-07T15:30:29.273880Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8925-2
  a curric:KeyLearningPoint ;
  rdfs:label "A character can feel different emotions at different points of a story"@en ;
  dcterms:modified "2026-06-07T15:30:29.273884Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8925-3
  a curric:KeyLearningPoint ;
  rdfs:label """Including a range of adjectives to describe the same feeling stops repetition and
  makes writing more interesting"""@en ;
  dcterms:modified "2026-06-07T15:30:29.273918Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8925-4
  a curric:KeyLearningPoint ;
  rdfs:label "Two descriptions can be joined together to form one sentence using \"and\""@en ;
  dcterms:modified "2026-06-07T15:30:29.273923Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8925-5
  a curric:KeyLearningPoint ;
  rdfs:label "An adverb describes or adds detail to a verb"@en ;
  dcterms:modified "2026-06-07T15:30:29.273927Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4798-1
  a curric:KeyLearningPoint ;
  rdfs:label "High frequency words are words that appear most frequently in written texts."@en ;
  dcterms:modified "2026-06-07T15:30:29.273949Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4798-2
  a curric:KeyLearningPoint ;
  rdfs:label """Letters in the high frequency words will be joined using a range of joins depending
  on the letters in the word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273953Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4798-3
  a curric:KeyLearningPoint ;
  rdfs:label "You start at the correct starting point for the first letter."@en ;
  dcterms:modified "2026-06-07T15:30:29.273957Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4798-4
  a curric:KeyLearningPoint ;
  rdfs:label "There is appropriate spacing between the letters."@en ;
  dcterms:modified "2026-06-07T15:30:29.273963Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4798-5
  a curric:KeyLearningPoint ;
  rdfs:label "You don’t lift your pencil until the letter string is complete."@en ;
  dcterms:modified "2026-06-07T15:30:29.273967Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8126-1
  a curric:KeyLearningPoint ;
  rdfs:label """'The Proudest Blue' is a children's picture book, written by Ibtihaj Muhammad, that
  celebrates being proud of the hijab."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273992Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8126-2
  a curric:KeyLearningPoint ;
  rdfs:label """The story is told from the perspective of Faiza and it is about her big sister Asiya
  getting her very first hijab."""@en ;
  dcterms:modified "2026-06-07T15:30:29.273998Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8126-3
  a curric:KeyLearningPoint ;
  rdfs:label """Sounding out using phonics strategies is our most helpful way to decode unfamiliar
  words."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274003Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8126-4
  a curric:KeyLearningPoint ;
  rdfs:label """Searching for a 'word within a word' is a useful strategy to decode and comprehend
  words."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274006Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8126-5
  a curric:KeyLearningPoint ;
  rdfs:label """Re-reading a sentence fluently after decoding helps to make meaning of what has been
  read."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274010Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29015-1
  a curric:KeyLearningPoint ;
  rdfs:label "Adjectives can be used to describe the appearance of something."@en ;
  dcterms:modified "2026-06-07T15:30:29.274064Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29015-2
  a curric:KeyLearningPoint ;
  rdfs:label """An appearance is what someone or something looks like, in this case what the houses
  looks like."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274068Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29015-3
  a curric:KeyLearningPoint ;
  rdfs:label """When you use two adjectives to describe a noun, you need to separate them with a
  comma."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274072Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29015-4
  a curric:KeyLearningPoint ;
  rdfs:label "Two ideas can be joined together using 'and' to form one sentence."@en ;
  dcterms:modified "2026-06-07T15:30:29.274075Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29015-5
  a curric:KeyLearningPoint ;
  rdfs:label "In a compound sentence, each idea must make complete sense."@en ;
  dcterms:modified "2026-06-07T15:30:29.274079Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-946-1
  a curric:KeyLearningPoint ;
  rdfs:label "'s' is the most common representation of the 's' phoneme at the start of a word."@en ;
  dcterms:modified "2026-06-07T15:30:29.276249Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-946-2
  a curric:KeyLearningPoint ;
  rdfs:label "'c' is sometimes used to represent the 's' phoneme before 'i','e' or 'y'."@en ;
  dcterms:modified "2026-06-07T15:30:29.276253Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-946-3
  a curric:KeyLearningPoint ;
  rdfs:label "ss' is often used at the end of a word after a short vowel."@en ;
  dcterms:modified "2026-06-07T15:30:29.276257Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-946-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the common exception words: path and bath."@en ;
  dcterms:modified "2026-06-07T15:30:29.276263Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-957-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘ore’ is a representation of the 'or' phoneme that usually comes at the end of a
  word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.278634Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-957-2
  a curric:KeyLearningPoint ;
  rdfs:label "'ough' and 'a' are alternative spellings of the 'or' phoneme."@en ;
  dcterms:modified "2026-06-07T15:30:29.278638Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-957-3
  a curric:KeyLearningPoint ;
  rdfs:label "Most words using the 'ough' spelling are past tense verbs."@en ;
  dcterms:modified "2026-06-07T15:30:29.278641Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-957-4
  a curric:KeyLearningPoint ;
  rdfs:label "The 'or' sound is usually spelt as 'a' before 'l' or 'll'."@en ;
  dcterms:modified "2026-06-07T15:30:29.278645Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-957-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the common exception words: war, warm and towards."@en ;
  dcterms:modified "2026-06-07T15:30:29.278649Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-945-1
  a curric:KeyLearningPoint ;
  rdfs:label "'wr' can be a representation of the 'r' phoneme."@en ;
  dcterms:modified "2026-06-07T15:30:29.278652Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-945-2
  a curric:KeyLearningPoint ;
  rdfs:label "The representation 'wr' is usually found at the start of a word."@en ;
  dcterms:modified "2026-06-07T15:30:29.278656Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-945-3
  a curric:KeyLearningPoint ;
  rdfs:label """Words connected in word families often have similar spellings, such as write, wrote
  and written."""@en ;
  dcterms:modified "2026-06-07T15:30:29.278660Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-945-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the common exception words: ask and says."@en ;
  dcterms:modified "2026-06-07T15:30:29.278664Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8538-1
  a curric:KeyLearningPoint ;
  rdfs:label """Vocabulary in a story can generate a description of a character, such as the use of
  \"stomping\" and \"destructive\"."""@en ;
  dcterms:modified "2026-06-07T15:30:29.278670Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8538-2
  a curric:KeyLearningPoint ;
  rdfs:label """Descriptions of a character may change throughout the story as demonstrated through
  vocabulary, such as \"lonely\"."""@en ;
  dcterms:modified "2026-06-07T15:30:29.278674Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8538-3
  a curric:KeyLearningPoint ;
  rdfs:label """Powerful verbs and adjectives are used to help the reader build an image in their
  mind."""@en ;
  dcterms:modified "2026-06-07T15:30:29.278677Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6171-1
  a curric:KeyLearningPoint ;
  rdfs:label "Editing is the process of making any changes needed to improve our writing."@en ;
  dcterms:modified "2026-06-07T15:30:29.278722Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6171-2
  a curric:KeyLearningPoint ;
  rdfs:label """Punctuation is the name for the marks used to make our sentences clearer and easier
  to read."""@en ;
  dcterms:modified "2026-06-07T15:30:29.278726Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6171-3
  a curric:KeyLearningPoint ;
  rdfs:label """When we edit word choices, we carefully review and make changes to the words in our
  writing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.278730Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6178-1
  a curric:KeyLearningPoint ;
  rdfs:label "The purpose of the build-up is to develop the plot and characters."@en ;
  dcterms:modified "2026-06-07T15:30:29.278734Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6178-2
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials of time tell the reader how much time has passed between each
  sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.278737Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6178-3
  a curric:KeyLearningPoint ;
  rdfs:label "Fronted adverbials of time can speed up or slow down the action being described."@en ;
  dcterms:modified "2026-06-07T15:30:29.278741Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6178-4
  a curric:KeyLearningPoint ;
  rdfs:label "We can use our plan to help form full sentences for writing."@en ;
  dcterms:modified "2026-06-07T15:30:29.278745Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4782-1
  a curric:KeyLearningPoint ;
  rdfs:label """In cursive handwriting, letters with descenders use a lead out loop to join with the
  next letter in the letter string."""@en ;
  dcterms:modified "2026-06-07T15:30:29.278749Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4782-2
  a curric:KeyLearningPoint ;
  rdfs:label "The descenders for y, g, j and f have a loop to aid joining."@en ;
  dcterms:modified "2026-06-07T15:30:29.278753Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4782-3
  a curric:KeyLearningPoint ;
  rdfs:label "The letter f has a lead in and a lead out loop to aid joining."@en ;
  dcterms:modified "2026-06-07T15:30:29.278758Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4782-4
  a curric:KeyLearningPoint ;
  rdfs:label """Break letters are letters in the alphabet that do not join to the next letter in the
  letter string."""@en ;
  dcterms:modified "2026-06-07T15:30:29.278763Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4782-5
  a curric:KeyLearningPoint ;
  rdfs:label "The letters x and z are break letters."@en ;
  dcterms:modified "2026-06-07T15:30:29.278766Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-948-1
  a curric:KeyLearningPoint ;
  rdfs:label """The letter 'j' is never used to represent the 'j' phoneme at the end of the
  word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.280818Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-948-2
  a curric:KeyLearningPoint ;
  rdfs:label "The spelling 'dge' is usually used after short vowels."@en ;
  dcterms:modified "2026-06-07T15:30:29.280822Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-948-3
  a curric:KeyLearningPoint ;
  rdfs:label "The spelling 'ge' is usually used after consonants and other vowel sounds."@en ;
  dcterms:modified "2026-06-07T15:30:29.280826Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-948-4
  a curric:KeyLearningPoint ;
  rdfs:label "The spelling 'g' is often used before 'i', 'e' and 'y'."@en ;
  dcterms:modified "2026-06-07T15:30:29.280830Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-948-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the common exception word: because."@en ;
  dcterms:modified "2026-06-07T15:30:29.280834Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8124-1
  a curric:KeyLearningPoint ;
  rdfs:label """'Compassionate' is an adjective which means feeling somebody else’s pain and wanting
  to help."""@en ;
  dcterms:modified "2026-06-07T15:30:29.280869Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8124-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Shy' is an adjective which means feeling nervous around other people."@en ;
  dcterms:modified "2026-06-07T15:30:29.280873Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8124-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Included' and 'respectful' are other adjectives that are associated with
  friendship."""@en ;
  dcterms:modified "2026-06-07T15:30:29.280879Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8124-4
  a curric:KeyLearningPoint ;
  rdfs:label "Word choices must be precise in writing and speaking."@en ;
  dcterms:modified "2026-06-07T15:30:29.280883Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6283-1
  a curric:KeyLearningPoint ;
  rdfs:label "Writing in a diary will mostly be in the past tense."@en ;
  dcterms:modified "2026-06-07T15:30:29.280887Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6283-2
  a curric:KeyLearningPoint ;
  rdfs:label "Past tense tells the reader something happened before now."@en ;
  dcterms:modified "2026-06-07T15:30:29.280890Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6283-3
  a curric:KeyLearningPoint ;
  rdfs:label """Notes are used when making a plan and they are short and only capture key vocabulary
  and important information."""@en ;
  dcterms:modified "2026-06-07T15:30:29.280894Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4748-1
  a curric:KeyLearningPoint ;
  rdfs:label "Sitting position is important for handwriting"@en ;
  dcterms:modified "2026-06-07T15:30:29.280898Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4748-2
  a curric:KeyLearningPoint ;
  rdfs:label "A comfortable tripod pencil grip can make handwriting easier"@en ;
  dcterms:modified "2026-06-07T15:30:29.280901Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4748-3
  a curric:KeyLearningPoint ;
  rdfs:label "Handwriting patterns can help prepare us to form letters"@en ;
  dcterms:modified "2026-06-07T15:30:29.280905Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4748-4
  a curric:KeyLearningPoint ;
  rdfs:label "It takes practice to be able to form patterns correctly"@en ;
  dcterms:modified "2026-06-07T15:30:29.280909Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4748-5
  a curric:KeyLearningPoint ;
  rdfs:label "Posture, pencil grip and paper position are important for handwriting"@en ;
  dcterms:modified "2026-06-07T15:30:29.280912Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6213-1
  a curric:KeyLearningPoint ;
  rdfs:label "A recount is written in the past tense."@en ;
  dcterms:modified "2026-06-07T15:30:29.280916Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6213-2
  a curric:KeyLearningPoint ;
  rdfs:label """A recount is written in chronological order and will use fronted adverbials
  of time."""@en ;
  dcterms:modified "2026-06-07T15:30:29.280920Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6213-3
  a curric:KeyLearningPoint ;
  rdfs:label "A recount is written in the first person."@en ;
  dcterms:modified "2026-06-07T15:30:29.280923Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8127-1
  a curric:KeyLearningPoint ;
  rdfs:label "We use a range of strategies to build comprehension of a text."@en ;
  dcterms:modified "2026-06-07T15:30:29.280927Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8127-2
  a curric:KeyLearningPoint ;
  rdfs:label "Skimming and scanning can help us to retrieve key information."@en ;
  dcterms:modified "2026-06-07T15:30:29.280931Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8127-3
  a curric:KeyLearningPoint ;
  rdfs:label "We can use inference to draw conclusions about the text by searching for clues."@en ;
  dcterms:modified "2026-06-07T15:30:29.280937Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8127-4
  a curric:KeyLearningPoint ;
  rdfs:label """Discussing the text with others improves our understanding and offers opportunities
  for hearing different perspectives."""@en ;
  dcterms:modified "2026-06-07T15:30:29.280941Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8127-5
  a curric:KeyLearningPoint ;
  rdfs:label """'The Proudest Blue' challenges negative ideas around 'difference' and encourages
  pride of expressing religious identity."""@en ;
  dcterms:modified "2026-06-07T15:30:29.280945Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-32-1
  a curric:KeyLearningPoint ;
  rdfs:label "The letter b has an ascender."@en ;
  dcterms:modified "2026-06-07T15:30:29.280950Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-32-2
  a curric:KeyLearningPoint ;
  rdfs:label "The letter p has a descender."@en ;
  dcterms:modified "2026-06-07T15:30:29.280954Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-32-3
  a curric:KeyLearningPoint ;
  rdfs:label "The letters b and p are formed by \"going down and back up and around\"."@en ;
  dcterms:modified "2026-06-07T15:30:29.280958Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-32-4
  a curric:KeyLearningPoint ;
  rdfs:label """The middle part of the letters b and p are x-height letters and sit in the middle
  set of the tramlines."""@en ;
  dcterms:modified "2026-06-07T15:30:29.280962Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7179-1
  a curric:KeyLearningPoint ;
  rdfs:label """One way of inferring a character's feelings is looking at their expressions in an
  illustration"""@en ;
  dcterms:modified "2026-06-07T15:30:29.282495Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7179-2
  a curric:KeyLearningPoint ;
  rdfs:label """One way of inferring a character's feelings is reading about how they move, what
  they do and what they say"""@en ;
  dcterms:modified "2026-06-07T15:30:29.282499Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7179-3
  a curric:KeyLearningPoint ;
  rdfs:label """Discussing the feelings of others helps to generate powerful adjectives to describe
  an emotion or event"""@en ;
  dcterms:modified "2026-06-07T15:30:29.282503Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7179-4
  a curric:KeyLearningPoint ;
  rdfs:label "Using 'I', 'me', 'my', 'we' or 'us' is a way of speaking in the first person"@en ;
  dcterms:modified "2026-06-07T15:30:29.282507Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6179-1
  a curric:KeyLearningPoint ;
  rdfs:label "Planning is an important part of preparing to write."@en ;
  dcterms:modified "2026-06-07T15:30:29.282511Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6179-2
  a curric:KeyLearningPoint ;
  rdfs:label "The climax should be the most exciting part of the story for the reader."@en ;
  dcterms:modified "2026-06-07T15:30:29.282515Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6179-3
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the climax is to describe the problem and create the highest point of
  tension."""@en ;
  dcterms:modified "2026-06-07T15:30:29.282521Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6179-4
  a curric:KeyLearningPoint ;
  rdfs:label """Using ambitious vocabulary helps to paint a vivid picture in the reader’s mind and
  make writing exciting to read."""@en ;
  dcterms:modified "2026-06-07T15:30:29.282525Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6175-1
  a curric:KeyLearningPoint ;
  rdfs:label "The purpose of the opening is to introduce the main characters and the setting."@en ;
  dcterms:modified "2026-06-07T15:30:29.282569Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6175-2
  a curric:KeyLearningPoint ;
  rdfs:label "Planning is an important part of preparing to write."@en ;
  dcterms:modified "2026-06-07T15:30:29.282573Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6175-3
  a curric:KeyLearningPoint ;
  rdfs:label "Our plan will contain ambitious vocabulary."@en ;
  dcterms:modified "2026-06-07T15:30:29.282598Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6175-4
  a curric:KeyLearningPoint ;
  rdfs:label "Our plan will contain nouns, adjectives, verbs and adverbs."@en ;
  dcterms:modified "2026-06-07T15:30:29.282602Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-981-1
  a curric:KeyLearningPoint ;
  rdfs:label "An adverbial complex sentence is a main idea joined with a subordinate idea."@en ;
  dcterms:modified "2026-06-07T15:30:29.284437Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-981-2
  a curric:KeyLearningPoint ;
  rdfs:label "Subordination joining words are 'because', 'so', 'when', 'if' and 'that'."@en ;
  dcterms:modified "2026-06-07T15:30:29.284441Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-981-3
  a curric:KeyLearningPoint ;
  rdfs:label "A compound sentence is a sentence formed of two main ideas and a joining word."@en ;
  dcterms:modified "2026-06-07T15:30:29.284447Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-981-4
  a curric:KeyLearningPoint ;
  rdfs:label "Co-ordination joins two simple sentences."@en ;
  dcterms:modified "2026-06-07T15:30:29.284451Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-981-5
  a curric:KeyLearningPoint ;
  rdfs:label "Co-ordination joining words are 'and', 'but' and 'or'."@en ;
  dcterms:modified "2026-06-07T15:30:29.284469Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-949-1
  a curric:KeyLearningPoint ;
  rdfs:label "The spelling 'dge' is usually used after short vowels."@en ;
  dcterms:modified "2026-06-07T15:30:29.284599Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-949-2
  a curric:KeyLearningPoint ;
  rdfs:label "The spelling 'ge' is usually used after consonants and other vowel sounds."@en ;
  dcterms:modified "2026-06-07T15:30:29.284603Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-949-3
  a curric:KeyLearningPoint ;
  rdfs:label "The spelling 'g' is often used before 'i', 'e' and 'y'."@en ;
  dcterms:modified "2026-06-07T15:30:29.284607Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-949-4
  a curric:KeyLearningPoint ;
  rdfs:label "The spelling 'j' is usually used before 'a', 'o' and 'u'."@en ;
  dcterms:modified "2026-06-07T15:30:29.284610Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-949-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the common exception word: laugh."@en ;
  dcterms:modified "2026-06-07T15:30:29.284616Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7181-1
  a curric:KeyLearningPoint ;
  rdfs:label "A letter may include questions which you have to reply to."@en ;
  dcterms:modified "2026-06-07T15:30:29.284651Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7181-2
  a curric:KeyLearningPoint ;
  rdfs:label "Expanded noun phrases can help someone to imagine something or somewhere."@en ;
  dcterms:modified "2026-06-07T15:30:29.284655Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7181-3
  a curric:KeyLearningPoint ;
  rdfs:label """When using two adjectives, a comma is placed in between them, such as 'fun,
  adventurous places'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.284659Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7181-4
  a curric:KeyLearningPoint ;
  rdfs:label "Adverbs can add detail to how someone does something."@en ;
  dcterms:modified "2026-06-07T15:30:29.284662Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7181-5
  a curric:KeyLearningPoint ;
  rdfs:label "Writing in the first person uses words such as 'I', 'we' or 'mine'."@en ;
  dcterms:modified "2026-06-07T15:30:29.284666Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8528-1
  a curric:KeyLearningPoint ;
  rdfs:label "Listening to and reading books is a way to learn new vocabulary."@en ;
  dcterms:modified "2026-06-07T15:30:29.284681Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8528-2
  a curric:KeyLearningPoint ;
  rdfs:label """Powerful verbs are used to show how characters are speaking, such as \"boomed\" and
  \"shouted\"."""@en ;
  dcterms:modified "2026-06-07T15:30:29.284685Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8528-3
  a curric:KeyLearningPoint ;
  rdfs:label "We can use different strategies to work out the meaning of unknown words."@en ;
  dcterms:modified "2026-06-07T15:30:29.284690Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8528-4
  a curric:KeyLearningPoint ;
  rdfs:label "Re-reading a story helps to develop our fluency."@en ;
  dcterms:modified "2026-06-07T15:30:29.284694Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7218-1
  a curric:KeyLearningPoint ;
  rdfs:label """Allan Ahlberg is one of Britain’s most popular and successful children’s writers and
  is known for his fun storytelling."""@en ;
  dcterms:modified "2026-06-07T15:30:29.284719Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7218-2
  a curric:KeyLearningPoint ;
  rdfs:label "‘Please Mrs Butler’ is a poem about a child asking their teacher for help."@en ;
  dcterms:modified "2026-06-07T15:30:29.284722Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7218-3
  a curric:KeyLearningPoint ;
  rdfs:label """‘Please Mrs Butler’ is written as a conversation between two characters and can be
  performed in a pair."""@en ;
  dcterms:modified "2026-06-07T15:30:29.284726Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7218-4
  a curric:KeyLearningPoint ;
  rdfs:label """Performing a poem using expression and gestures will help to express to an audience
  how a character is feeling."""@en ;
  dcterms:modified "2026-06-07T15:30:29.284730Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6162-1
  a curric:KeyLearningPoint ;
  rdfs:label "‘Lucky Dip’ is an animated short story."@en ;
  dcterms:modified "2026-06-07T15:30:29.284762Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6162-2
  a curric:KeyLearningPoint ;
  rdfs:label "‘Lucky Dip’ is set at the seaside and takes place mostly in an old arcade."@en ;
  dcterms:modified "2026-06-07T15:30:29.284766Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6162-3
  a curric:KeyLearningPoint ;
  rdfs:label "Sequencing means putting the events in the right order so they make sense."@en ;
  dcterms:modified "2026-06-07T15:30:29.284770Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6162-4
  a curric:KeyLearningPoint ;
  rdfs:label "Retell means to tell a story or explain something again in our own words."@en ;
  dcterms:modified "2026-06-07T15:30:29.284775Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6162-5
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials of time tell the reader when the events in the sentence took
  place."""@en ;
  dcterms:modified "2026-06-07T15:30:29.284779Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6168-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the build-up is to develop the plot/characters, introduce a problem
  and build up tension and excitement."""@en ;
  dcterms:modified "2026-06-07T15:30:29.284794Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6168-2
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials of time tell the reader how much time has passed between each
  sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.284798Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6168-3
  a curric:KeyLearningPoint ;
  rdfs:label "Fronted adverbials of time can speed up or slow down the action being described."@en ;
  dcterms:modified "2026-06-07T15:30:29.284802Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5640-1
  a curric:KeyLearningPoint ;
  rdfs:label """Instructions are a set of steps or guidelines for someone to follow to complete a
  specific task."""@en ;
  dcterms:modified "2026-06-07T15:30:29.284806Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5640-2
  a curric:KeyLearningPoint ;
  rdfs:label "Instructions contain numbers or ordering fronted adverbials."@en ;
  dcterms:modified "2026-06-07T15:30:29.284809Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5640-3
  a curric:KeyLearningPoint ;
  rdfs:label "Instructions contain imperative verbs."@en ;
  dcterms:modified "2026-06-07T15:30:29.284813Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5640-4
  a curric:KeyLearningPoint ;
  rdfs:label "Instructions contain adverbs."@en ;
  dcterms:modified "2026-06-07T15:30:29.284819Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4757-1
  a curric:KeyLearningPoint ;
  rdfs:label "The letters m, n, r, h, k, b and p are in same letter family"@en ;
  dcterms:modified "2026-06-07T15:30:29.284822Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4757-2
  a curric:KeyLearningPoint ;
  rdfs:label """The letters m, n, r, h, k, b and p are all formed by going down, back up and
  over"""@en ;
  dcterms:modified "2026-06-07T15:30:29.284826Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4757-3
  a curric:KeyLearningPoint ;
  rdfs:label "The letters m, n and r are x-height letters"@en ;
  dcterms:modified "2026-06-07T15:30:29.284830Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4757-4
  a curric:KeyLearningPoint ;
  rdfs:label "The letters h, k and b have ascenders"@en ;
  dcterms:modified "2026-06-07T15:30:29.284834Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4757-5
  a curric:KeyLearningPoint ;
  rdfs:label "The letter p has a descender"@en ;
  dcterms:modified "2026-06-07T15:30:29.284837Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5327-1
  a curric:KeyLearningPoint ;
  rdfs:label "Recounts are mostly told in chronological or time order"@en ;
  dcterms:modified "2026-06-07T15:30:29.284841Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5327-2
  a curric:KeyLearningPoint ;
  rdfs:label "Events in a trip can be placed on a timeline to help remember the sequence"@en ;
  dcterms:modified "2026-06-07T15:30:29.284847Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5327-3
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials of time such as 'First,' 'Then,' 'After that,' and 'Finally,' can
  be used to structure a recount"""@en ;
  dcterms:modified "2026-06-07T15:30:29.284851Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5327-4
  a curric:KeyLearningPoint ;
  rdfs:label "Recounting orally helps to remember the events of a trip before writing"@en ;
  dcterms:modified "2026-06-07T15:30:29.284854Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8129-1
  a curric:KeyLearningPoint ;
  rdfs:label "The hijab is a very special item for the main character in 'The Proudest Blue'."@en ;
  dcterms:modified "2026-06-07T15:30:29.284858Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8129-2
  a curric:KeyLearningPoint ;
  rdfs:label "We can identify our own special belongings which hold meaning."@en ;
  dcterms:modified "2026-06-07T15:30:29.284862Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8129-3
  a curric:KeyLearningPoint ;
  rdfs:label """Sentimental items are ones that remind us of a special person, place, time or
  feeling."""@en ;
  dcterms:modified "2026-06-07T15:30:29.284866Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8129-4
  a curric:KeyLearningPoint ;
  rdfs:label """A plan is written in note format, using bullet points to write the key information
  in a few words."""@en ;
  dcterms:modified "2026-06-07T15:30:29.284869Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6845-1
  a curric:KeyLearningPoint ;
  rdfs:label """Adverbs can be used to describe how a character moves or speaks, such as
  \"calmly\"."""@en ;
  dcterms:modified "2026-06-07T15:30:29.284873Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6845-2
  a curric:KeyLearningPoint ;
  rdfs:label """Sequencing language can be used at the start of a sentence, such as \"Then,\" and
  \"Suddenly,\"."""@en ;
  dcterms:modified "2026-06-07T15:30:29.284880Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6845-3
  a curric:KeyLearningPoint ;
  rdfs:label "Two ideas can be joined using the joining word \"and\"."@en ;
  dcterms:modified "2026-06-07T15:30:29.284884Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6845-4
  a curric:KeyLearningPoint ;
  rdfs:label """Exclamation marks can be used to show emotion, such as anger when the girl has a
  tantrum."""@en ;
  dcterms:modified "2026-06-07T15:30:29.284888Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-902-1
  a curric:KeyLearningPoint ;
  rdfs:label "Adjectives are words that can compare nouns."@en ;
  dcterms:modified "2026-06-07T15:30:29.284957Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-902-2
  a curric:KeyLearningPoint ;
  rdfs:label "Comparing nouns is another way to describe them."@en ;
  dcterms:modified "2026-06-07T15:30:29.284961Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-902-3
  a curric:KeyLearningPoint ;
  rdfs:label "Adjectives most often compare common nouns."@en ;
  dcterms:modified "2026-06-07T15:30:29.284964Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5478-1
  a curric:KeyLearningPoint ;
  rdfs:label """Imagining you are the character helps to understand events and generate descriptions
  of the story"""@en ;
  dcterms:modified "2026-06-07T15:30:29.287047Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5478-2
  a curric:KeyLearningPoint ;
  rdfs:label "Acting out stories helps to understand character's feelings and actions"@en ;
  dcterms:modified "2026-06-07T15:30:29.287054Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5478-3
  a curric:KeyLearningPoint ;
  rdfs:label """By acting out parts of the story, vocabulary can be generated to help
  writing later"""@en ;
  dcterms:modified "2026-06-07T15:30:29.287058Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5478-4
  a curric:KeyLearningPoint ;
  rdfs:label """Facial expressions and movements help the audience understand what is happening,
  such as shock from the girl"""@en ;
  dcterms:modified "2026-06-07T15:30:29.287062Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5478-5
  a curric:KeyLearningPoint ;
  rdfs:label """Moving like the characters and objects can generate verbs, such as 'poured', 'raced'
  or 'hid'"""@en ;
  dcterms:modified "2026-06-07T15:30:29.287066Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-967-1
  a curric:KeyLearningPoint ;
  rdfs:label """A suffix is a letter or group of letters at the end of a word which creates another
  word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.287069Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-967-2
  a curric:KeyLearningPoint ;
  rdfs:label "The 'y' is changed to 'i' before '-es' is added."@en ;
  dcterms:modified "2026-06-07T15:30:29.287073Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-967-3
  a curric:KeyLearningPoint ;
  rdfs:label "Verbs agree with the noun they are paired with."@en ;
  dcterms:modified "2026-06-07T15:30:29.287078Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6211-1
  a curric:KeyLearningPoint ;
  rdfs:label """When we are recounting, the information we are sharing with someone is called a
  recount."""@en ;
  dcterms:modified "2026-06-07T15:30:29.287081Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6211-2
  a curric:KeyLearningPoint ;
  rdfs:label "A recount is written in the first person because it happened to you."@en ;
  dcterms:modified "2026-06-07T15:30:29.287085Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6211-3
  a curric:KeyLearningPoint ;
  rdfs:label "A recount is written in the past tense because the events have already happened."@en ;
  dcterms:modified "2026-06-07T15:30:29.287089Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6211-4
  a curric:KeyLearningPoint ;
  rdfs:label "A recount is written in chronological order."@en ;
  dcterms:modified "2026-06-07T15:30:29.287092Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-943-1
  a curric:KeyLearningPoint ;
  rdfs:label "'kn' can be a representation of the 'n' phoneme."@en ;
  dcterms:modified "2026-06-07T15:30:29.287096Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-943-2
  a curric:KeyLearningPoint ;
  rdfs:label "The representation 'kn' is usually found at the start of a word."@en ;
  dcterms:modified "2026-06-07T15:30:29.287100Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-943-3
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the common exception words: push and pull."@en ;
  dcterms:modified "2026-06-07T15:30:29.287104Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-943-4
  a curric:KeyLearningPoint ;
  rdfs:label "Words connected in word families often have similar spellings."@en ;
  dcterms:modified "2026-06-07T15:30:29.287108Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6209-1
  a curric:KeyLearningPoint ;
  rdfs:label """Notes from a written plan support in writing and ensure important information is
  included in an information text."""@en ;
  dcterms:modified "2026-06-07T15:30:29.287417Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6209-2
  a curric:KeyLearningPoint ;
  rdfs:label """Using a range of sentence types (simple, compound and complex) in our writing helps
  it to flow."""@en ;
  dcterms:modified "2026-06-07T15:30:29.287421Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6209-3
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials are sentence starters followed by a comma and they support text
  flow."""@en ;
  dcterms:modified "2026-06-07T15:30:29.287425Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6209-4
  a curric:KeyLearningPoint ;
  rdfs:label """Viewpoint fronted adverbials express the writer’s opinion and fronted adverbials of
  time state when something happened."""@en ;
  dcterms:modified "2026-06-07T15:30:29.287429Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5417-1
  a curric:KeyLearningPoint ;
  rdfs:label "Re-reading a story can help to summarise the plot and remember the main events"@en ;
  dcterms:modified "2026-06-07T15:30:29.287433Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5417-2
  a curric:KeyLearningPoint ;
  rdfs:label """A theme is a main idea in a story that often tries to teach the reader about
  something"""@en ;
  dcterms:modified "2026-06-07T15:30:29.287437Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5417-3
  a curric:KeyLearningPoint ;
  rdfs:label "Relating the theme to ourselves can link the book to our own experiences"@en ;
  dcterms:modified "2026-06-07T15:30:29.287440Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5417-4
  a curric:KeyLearningPoint ;
  rdfs:label "Linking a story to our own experiences is thinking from our own perspective"@en ;
  dcterms:modified "2026-06-07T15:30:29.287446Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5417-5
  a curric:KeyLearningPoint ;
  rdfs:label "Responsibility means taking care of something, someone or completing some tasks"@en ;
  dcterms:modified "2026-06-07T15:30:29.287450Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6195-1
  a curric:KeyLearningPoint ;
  rdfs:label """Bats are nocturnal animals, which means they sleep during the day and are awake at
  night."""@en ;
  dcterms:modified "2026-06-07T15:30:29.287454Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6195-2
  a curric:KeyLearningPoint ;
  rdfs:label """Bats have very poor eyesight, but use echolocation to help them navigate their way
  around."""@en ;
  dcterms:modified "2026-06-07T15:30:29.287458Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6195-3
  a curric:KeyLearningPoint ;
  rdfs:label "Bats have leathery wings which help them to fly quickly."@en ;
  dcterms:modified "2026-06-07T15:30:29.287462Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6195-4
  a curric:KeyLearningPoint ;
  rdfs:label "Over millions of years, bats have developed adaptations to help them survive."@en ;
  dcterms:modified "2026-06-07T15:30:29.287465Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-971-1
  a curric:KeyLearningPoint ;
  rdfs:label """A suffix is a letter or group of letters at the end of a word which creates another
  word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.287512Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-971-2
  a curric:KeyLearningPoint ;
  rdfs:label "If the adjective ends in two consonant letters, the ending is simply added on."@en ;
  dcterms:modified "2026-06-07T15:30:29.287516Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-971-3
  a curric:KeyLearningPoint ;
  rdfs:label """If the root word ends in a consonant + 'y', the 'y' is changed to 'i' before the
  suffix is added."""@en ;
  dcterms:modified "2026-06-07T15:30:29.287519Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-971-4
  a curric:KeyLearningPoint ;
  rdfs:label """If the root word ends in a consonant + 'e', the 'e' is removed before the suffix is
  added."""@en ;
  dcterms:modified "2026-06-07T15:30:29.287523Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4770-1
  a curric:KeyLearningPoint ;
  rdfs:label "The letters are formed by following the right starting point and direction."@en ;
  dcterms:modified "2026-06-07T15:30:29.287527Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4770-2
  a curric:KeyLearningPoint ;
  rdfs:label "Cursive letter joins refer to how the letters connect together."@en ;
  dcterms:modified "2026-06-07T15:30:29.287531Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4770-3
  a curric:KeyLearningPoint ;
  rdfs:label "The pencil does not lift when forming the join."@en ;
  dcterms:modified "2026-06-07T15:30:29.287535Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4770-4
  a curric:KeyLearningPoint ;
  rdfs:label "The first join goes from the baseline to the x-height line."@en ;
  dcterms:modified "2026-06-07T15:30:29.287538Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4770-5
  a curric:KeyLearningPoint ;
  rdfs:label "The dot for the letter i gets added once the letter string is complete."@en ;
  dcterms:modified "2026-06-07T15:30:29.287542Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5475-1
  a curric:KeyLearningPoint ;
  rdfs:label """Predictions can be made based on illustrations, what has already been read and the
  front cover"""@en ;
  dcterms:modified "2026-06-07T15:30:29.287567Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5475-2
  a curric:KeyLearningPoint ;
  rdfs:label "One person's prediction may be different to another person's"@en ;
  dcterms:modified "2026-06-07T15:30:29.287573Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5475-3
  a curric:KeyLearningPoint ;
  rdfs:label """Traditional tales often start by introducing the characters, such as the little girl
  and setting the scene"""@en ;
  dcterms:modified "2026-06-07T15:30:29.287577Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5475-4
  a curric:KeyLearningPoint ;
  rdfs:label "'The Magic Porridge Pot' teaches us to be generous and helpful to others"@en ;
  dcterms:modified "2026-06-07T15:30:29.287581Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5475-5
  a curric:KeyLearningPoint ;
  rdfs:label """Traditional tales mostly end happily, such as having enough food and sharing with
  others"""@en ;
  dcterms:modified "2026-06-07T15:30:29.287585Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7215-1
  a curric:KeyLearningPoint ;
  rdfs:label """Performing poetry can be an effective way to bring a poem to life for an
  audience."""@en ;
  dcterms:modified "2026-06-07T15:30:29.289432Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7215-2
  a curric:KeyLearningPoint ;
  rdfs:label "Physical gestures and actions help to make a poem more engaging to watch."@en ;
  dcterms:modified "2026-06-07T15:30:29.289435Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7215-3
  a curric:KeyLearningPoint ;
  rdfs:label "We can improve our performances of poetry through practice."@en ;
  dcterms:modified "2026-06-07T15:30:29.289439Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7215-4
  a curric:KeyLearningPoint ;
  rdfs:label """Varying the volume and tone of your voice when performing a poem can make a poem
  more engaging to listen to."""@en ;
  dcterms:modified "2026-06-07T15:30:29.289445Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5413-1
  a curric:KeyLearningPoint ;
  rdfs:label "Instructions or commands tell someone what to do."@en ;
  dcterms:modified "2026-06-07T15:30:29.289449Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5413-2
  a curric:KeyLearningPoint ;
  rdfs:label """Giving an instruction to someone can be useful in teaching them something or giving
  them information."""@en ;
  dcterms:modified "2026-06-07T15:30:29.289453Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5413-3
  a curric:KeyLearningPoint ;
  rdfs:label """Instructions mostly start with verbs, such as 'feed your cat twice a day' or 'give
  your cat a bowl of water'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.289457Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5413-4
  a curric:KeyLearningPoint ;
  rdfs:label """Instructions can come in a sequence using sequencing language, such as 'First, put a
  bed down for your cat.'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.289461Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5413-5
  a curric:KeyLearningPoint ;
  rdfs:label "A command can include a list, such as 'Give your cat water, food and love.'."@en ;
  dcterms:modified "2026-06-07T15:30:29.289464Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8111-1
  a curric:KeyLearningPoint ;
  rdfs:label "An audience is a group of people listening or watching a performance or speaker"@en ;
  dcterms:modified "2026-06-07T15:30:29.289543Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8111-2
  a curric:KeyLearningPoint ;
  rdfs:label "An audience can be convinced to feel a certain way"@en ;
  dcterms:modified "2026-06-07T15:30:29.289547Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8111-3
  a curric:KeyLearningPoint ;
  rdfs:label "Convincing an audience requires strong reasons"@en ;
  dcterms:modified "2026-06-07T15:30:29.289551Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-972-1
  a curric:KeyLearningPoint ;
  rdfs:label """A suffix is a letter or group of letters at the end of a word which creates another
  word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.289555Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-972-2
  a curric:KeyLearningPoint ;
  rdfs:label """If the root word has a short vowel and a single consonant, the consonant letter is
  doubled when the suffix is added."""@en ;
  dcterms:modified "2026-06-07T15:30:29.289559Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-972-3
  a curric:KeyLearningPoint ;
  rdfs:label "The letter 'x' is never doubled, such as words like mixing, mixed or boxer."@en ;
  dcterms:modified "2026-06-07T15:30:29.289562Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5147-1
  a curric:KeyLearningPoint ;
  rdfs:label "Taking note of punctuation allows us to read with expression."@en ;
  dcterms:modified "2026-06-07T15:30:29.289622Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5147-2
  a curric:KeyLearningPoint ;
  rdfs:label "Different punctuation marks mean different things."@en ;
  dcterms:modified "2026-06-07T15:30:29.289625Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5147-3
  a curric:KeyLearningPoint ;
  rdfs:label """Re-reading words that you have read before gives you a chance to concentrate on
  reading with expression."""@en ;
  dcterms:modified "2026-06-07T15:30:29.289629Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5147-4
  a curric:KeyLearningPoint ;
  rdfs:label """Using different types of voice and different tones makes reading aloud more
  interesting for those who are listening."""@en ;
  dcterms:modified "2026-06-07T15:30:29.289633Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5147-5
  a curric:KeyLearningPoint ;
  rdfs:label "You must decode and understand words to be able to add expression."@en ;
  dcterms:modified "2026-06-07T15:30:29.289637Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-956-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘ore’ is a representation of the 'or' phoneme that usually comes at the end of a
  word, such as more."""@en ;
  dcterms:modified "2026-06-07T15:30:29.293761Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-956-2
  a curric:KeyLearningPoint ;
  rdfs:label "'ough' and 'a' are alternative spellings of the 'or' phoneme."@en ;
  dcterms:modified "2026-06-07T15:30:29.293765Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-956-3
  a curric:KeyLearningPoint ;
  rdfs:label "The 'or' phoneme is usually spelt as 'a' before 'l' or 'll'."@en ;
  dcterms:modified "2026-06-07T15:30:29.293769Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-956-4
  a curric:KeyLearningPoint ;
  rdfs:label "Most words using the 'ough' spelling are past tense verbs."@en ;
  dcterms:modified "2026-06-07T15:30:29.293773Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-956-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the common exception words: water, always, walk and talk."@en ;
  dcterms:modified "2026-06-07T15:30:29.293777Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4752-1
  a curric:KeyLearningPoint ;
  rdfs:label "The pre-cursive letters b, p, h and k all have a lead in and a lead out"@en ;
  dcterms:modified "2026-06-07T15:30:29.293783Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4752-2
  a curric:KeyLearningPoint ;
  rdfs:label "The pre-cursive letters b, p, h and k all start on the baseline"@en ;
  dcterms:modified "2026-06-07T15:30:29.293787Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4752-3
  a curric:KeyLearningPoint ;
  rdfs:label """The pre-cursive letters h and k finish with a curved up stroke on the baseline as
  the lead out"""@en ;
  dcterms:modified "2026-06-07T15:30:29.293793Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4752-4
  a curric:KeyLearningPoint ;
  rdfs:label "The letters b, h and k have ascenders"@en ;
  dcterms:modified "2026-06-07T15:30:29.293798Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4752-5
  a curric:KeyLearningPoint ;
  rdfs:label "The letter p has a descender"@en ;
  dcterms:modified "2026-06-07T15:30:29.293802Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-33-1
  a curric:KeyLearningPoint ;
  rdfs:label "The letters c, a and d are all formed by going round anti-clockwise."@en ;
  dcterms:modified "2026-06-07T15:30:29.295585Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-33-2
  a curric:KeyLearningPoint ;
  rdfs:label "The letter a is formed by \"going all the way round, down and flick\"."@en ;
  dcterms:modified "2026-06-07T15:30:29.295589Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-33-3
  a curric:KeyLearningPoint ;
  rdfs:label """The letter d is formed by \"going round and back up, down and ending with a
  flick\"."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295593Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-33-4
  a curric:KeyLearningPoint ;
  rdfs:label "The letters a and c are x-height letters."@en ;
  dcterms:modified "2026-06-07T15:30:29.295597Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-33-5
  a curric:KeyLearningPoint ;
  rdfs:label "The letter d has an ascender."@en ;
  dcterms:modified "2026-06-07T15:30:29.295601Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1056-1
  a curric:KeyLearningPoint ;
  rdfs:label "er', 'ir' and 'ur' are common representations of the 'er' phoneme."@en ;
  dcterms:modified "2026-06-07T15:30:29.295605Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1056-2
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the common exception words: some and come."@en ;
  dcterms:modified "2026-06-07T15:30:29.295609Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1056-3
  a curric:KeyLearningPoint ;
  rdfs:label "A mnemonic can help us to remember tricky spellings."@en ;
  dcterms:modified "2026-06-07T15:30:29.295613Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-930-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘y’ is the most common representation of the 'igh' phoneme when it appears at the
  end of a word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295662Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-930-2
  a curric:KeyLearningPoint ;
  rdfs:label """‘i’ is a representation of the 'igh' phoneme found in the high frequency words:
  find, kind, mind, wild and behind."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295667Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-930-3
  a curric:KeyLearningPoint ;
  rdfs:label """‘ie’ is a representation of the 'igh' phoneme found in the middle and end of
  words."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295671Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-930-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the common exception words: what, when and eye."@en ;
  dcterms:modified "2026-06-07T15:30:29.295675Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1057-1
  a curric:KeyLearningPoint ;
  rdfs:label "er', 'ir' and 'ur' are common representations of the 'er' phoneme."@en ;
  dcterms:modified "2026-06-07T15:30:29.295771Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1057-2
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the common exception words: have, live and love."@en ;
  dcterms:modified "2026-06-07T15:30:29.295776Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8928-1
  a curric:KeyLearningPoint ;
  rdfs:label """Adding descriptive language to a postcard helps the reader imagine what the place is
  like."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295960Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8928-2
  a curric:KeyLearningPoint ;
  rdfs:label """Two adjective sentences need a comma in between the two adjectives, such as 'black,
  zooming taxi'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295964Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8928-3
  a curric:KeyLearningPoint ;
  rdfs:label """Asking a 'Did you know ...?' question teaches someone a fact about something, in
  this case, London."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295968Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8928-4
  a curric:KeyLearningPoint ;
  rdfs:label """A postcard should end with naming who the postcard is from, in this case,
  Paddington."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295972Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4751-1
  a curric:KeyLearningPoint ;
  rdfs:label "The pre-cursive letters m, n and r all have a lead in and a lead out"@en ;
  dcterms:modified "2026-06-07T15:30:29.295976Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4751-2
  a curric:KeyLearningPoint ;
  rdfs:label "The pre-cursive letters m, n and r are all x-height letters"@en ;
  dcterms:modified "2026-06-07T15:30:29.295980Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4751-3
  a curric:KeyLearningPoint ;
  rdfs:label "The pre-cursive letter r has a dip down below the x-height line as the lead out"@en ;
  dcterms:modified "2026-06-07T15:30:29.295984Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4751-4
  a curric:KeyLearningPoint ;
  rdfs:label "The pre-cursive letters m, n and r all start on the baseline for their lead in"@en ;
  dcterms:modified "2026-06-07T15:30:29.295988Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4751-5
  a curric:KeyLearningPoint ;
  rdfs:label "The pre-cursive letters m and n are formed in similar ways"@en ;
  dcterms:modified "2026-06-07T15:30:29.295992Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-965-1
  a curric:KeyLearningPoint ;
  rdfs:label """A suffix is a letter or group of letters at the end of a word which creates another
  word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295996Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-965-2
  a curric:KeyLearningPoint ;
  rdfs:label """If the suffix starts with a consonant letter, it is usually added without any change
  to the root word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.296000Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-965-3
  a curric:KeyLearningPoint ;
  rdfs:label """If a root word has more than one syllable and ends in a consonant + 'y', then 'y' is
  replaced by 'i' before the suffix."""@en ;
  dcterms:modified "2026-06-07T15:30:29.296004Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6823-1
  a curric:KeyLearningPoint ;
  rdfs:label """Traditional tales are stories that are retold again and again and can be retold in
  different ways"""@en ;
  dcterms:modified "2026-06-07T15:30:29.296088Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6823-2
  a curric:KeyLearningPoint ;
  rdfs:label """Traditional tales often have heroes, such as the goats and villains, such as the
  troll"""@en ;
  dcterms:modified "2026-06-07T15:30:29.296093Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6823-3
  a curric:KeyLearningPoint ;
  rdfs:label "Most traditional tales start by introducing the characters and the settings"@en ;
  dcterms:modified "2026-06-07T15:30:29.296098Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6823-4
  a curric:KeyLearningPoint ;
  rdfs:label "Traditional tales have lots of similarities"@en ;
  dcterms:modified "2026-06-07T15:30:29.296102Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6823-5
  a curric:KeyLearningPoint ;
  rdfs:label "Usually, a problem is solved by the end of the story"@en ;
  dcterms:modified "2026-06-07T15:30:29.296106Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6824-1
  a curric:KeyLearningPoint ;
  rdfs:label """Retelling a story helps us to remember main events in a story and use storytelling
  language, such as 'Once upon a time'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.296110Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6824-2
  a curric:KeyLearningPoint ;
  rdfs:label "Story mountains sequence the beginning, middle and end of a story."@en ;
  dcterms:modified "2026-06-07T15:30:29.296114Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6824-3
  a curric:KeyLearningPoint ;
  rdfs:label "Only the most important events in the story need to be on a story mountain."@en ;
  dcterms:modified "2026-06-07T15:30:29.296118Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6824-4
  a curric:KeyLearningPoint ;
  rdfs:label """Using words such as 'First,' and 'The next day,' at the start of the sentence helps
  the reader follow the story."""@en ;
  dcterms:modified "2026-06-07T15:30:29.296122Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6824-5
  a curric:KeyLearningPoint ;
  rdfs:label "Story mountains can be used to retell the story aloud."@en ;
  dcterms:modified "2026-06-07T15:30:29.296126Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6206-1
  a curric:KeyLearningPoint ;
  rdfs:label """The subheading ‘Childhood and inspiration’ tells the reader what the section will be
  about."""@en ;
  dcterms:modified "2026-06-07T15:30:29.298172Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6206-2
  a curric:KeyLearningPoint ;
  rdfs:label """The plan should include when and where the author was born, important or interesting
  facts and inspiration."""@en ;
  dcterms:modified "2026-06-07T15:30:29.298176Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6206-3
  a curric:KeyLearningPoint ;
  rdfs:label """Notes are used when making a plan and capture key vocabulary and important
  information."""@en ;
  dcterms:modified "2026-06-07T15:30:29.298180Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6206-4
  a curric:KeyLearningPoint ;
  rdfs:label """Notes are not written in full sentences and do not require capital letters or full
  stops."""@en ;
  dcterms:modified "2026-06-07T15:30:29.298184Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6206-5
  a curric:KeyLearningPoint ;
  rdfs:label """Notes for an information text should include precise, accurate and descriptive
  vocabulary."""@en ;
  dcterms:modified "2026-06-07T15:30:29.298190Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6186-1
  a curric:KeyLearningPoint ;
  rdfs:label """A complex sentence is a sentence formed of a simple sentence joined with
  subordination."""@en ;
  dcterms:modified "2026-06-07T15:30:29.298194Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6186-2
  a curric:KeyLearningPoint ;
  rdfs:label """Subordination means joining a simple sentence with a second idea of lower
  importance."""@en ;
  dcterms:modified "2026-06-07T15:30:29.298198Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6186-3
  a curric:KeyLearningPoint ;
  rdfs:label "Mary Seacole was a doctress who helped injured soldiers during the Crimean war."@en ;
  dcterms:modified "2026-06-07T15:30:29.298204Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6186-4
  a curric:KeyLearningPoint ;
  rdfs:label "Mary set up her own hospital in Crimea called the British Hotel."@en ;
  dcterms:modified "2026-06-07T15:30:29.298208Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8264-1
  a curric:KeyLearningPoint ;
  rdfs:label """Re-reading a story helps to build deeper understanding and identify underlying
  themes and messages."""@en ;
  dcterms:modified "2026-06-07T15:30:29.298212Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8264-2
  a curric:KeyLearningPoint ;
  rdfs:label "A theme is a big idea, topic or message that appears within a story."@en ;
  dcterms:modified "2026-06-07T15:30:29.298216Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8264-3
  a curric:KeyLearningPoint ;
  rdfs:label """In \"Leaf\", the themes of belonging, kindness, environment and climate change are
  explored."""@en ;
  dcterms:modified "2026-06-07T15:30:29.298220Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8264-4
  a curric:KeyLearningPoint ;
  rdfs:label "A sense of belonging is essential for the survival of all living things."@en ;
  dcterms:modified "2026-06-07T15:30:29.298224Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8264-5
  a curric:KeyLearningPoint ;
  rdfs:label """Leaf may help the reader to reflect on respect for the environment and how to
  support others' sense of belonging."""@en ;
  dcterms:modified "2026-06-07T15:30:29.298228Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5651-1
  a curric:KeyLearningPoint ;
  rdfs:label """A plan helps a writer to organise their ideas, thoughts and the information they
  want to include in their writing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.298232Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5651-2
  a curric:KeyLearningPoint ;
  rdfs:label """The fire started on Sunday 2nd September 1666 in a bakery on Pudding Lane in
  London."""@en ;
  dcterms:modified "2026-06-07T15:30:29.298236Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5651-3
  a curric:KeyLearningPoint ;
  rdfs:label "The fire was accidentally started by a baker named Thomas Farriner."@en ;
  dcterms:modified "2026-06-07T15:30:29.298240Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5651-4
  a curric:KeyLearningPoint ;
  rdfs:label """Notes can be used in a plan to help organise key information and are not written in
  full sentences."""@en ;
  dcterms:modified "2026-06-07T15:30:29.298244Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29020-1
  a curric:KeyLearningPoint ;
  rdfs:label "Traditional tales often end happily by finding a solution to a problem."@en ;
  dcterms:modified "2026-06-07T15:30:29.298248Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29020-2
  a curric:KeyLearningPoint ;
  rdfs:label """Using adjectives, like ‘scorching’, and powerful verbs, like ‘plunged’, help the
  reader picture the events of a story."""@en ;
  dcterms:modified "2026-06-07T15:30:29.298252Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29020-3
  a curric:KeyLearningPoint ;
  rdfs:label "Exclamation marks can help to express a feeling of shock or surprise."@en ;
  dcterms:modified "2026-06-07T15:30:29.298256Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29020-4
  a curric:KeyLearningPoint ;
  rdfs:label """The sequencing word ‘Suddenly,’ helps to sequence events and to show something
  sudden has happened."""@en ;
  dcterms:modified "2026-06-07T15:30:29.298260Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5446-1
  a curric:KeyLearningPoint ;
  rdfs:label "James Carter tries to create pictures in the listener's head."@en ;
  dcterms:modified "2026-06-07T15:30:29.298325Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5446-2
  a curric:KeyLearningPoint ;
  rdfs:label """Descriptions using onomatopoeia, verbs and nouns help to imagine how the bear
  sounds, looks and moves."""@en ;
  dcterms:modified "2026-06-07T15:30:29.298329Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5446-3
  a curric:KeyLearningPoint ;
  rdfs:label "These words can be spoken with expression and intonation."@en ;
  dcterms:modified "2026-06-07T15:30:29.298333Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5446-4
  a curric:KeyLearningPoint ;
  rdfs:label "Poems feel different to read depending on their rhythm."@en ;
  dcterms:modified "2026-06-07T15:30:29.298339Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5446-5
  a curric:KeyLearningPoint ;
  rdfs:label "The way we read a poem can make it entertaining for people listening."@en ;
  dcterms:modified "2026-06-07T15:30:29.298345Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8125-1
  a curric:KeyLearningPoint ;
  rdfs:label """The author of 'The Proudest Blue' is Ibtihaj Muhammad, written alongside S.
  K. Ali."""@en ;
  dcterms:modified "2026-06-07T15:30:29.298374Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8125-2
  a curric:KeyLearningPoint ;
  rdfs:label """'The Proudest Blue' is a children's picture book which celebrates the importance and
  beauty of the hijab."""@en ;
  dcterms:modified "2026-06-07T15:30:29.298378Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8125-3
  a curric:KeyLearningPoint ;
  rdfs:label "'The Proudest Blue' is inspired by the author's own life."@en ;
  dcterms:modified "2026-06-07T15:30:29.298382Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8125-4
  a curric:KeyLearningPoint ;
  rdfs:label """Ibtihaj Muhammad was the first American fencing player to wear the hijab and
  participate in the Olympics."""@en ;
  dcterms:modified "2026-06-07T15:30:29.298386Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8125-5
  a curric:KeyLearningPoint ;
  rdfs:label """Ibtihaj wrote 'The Proudest Blue' so that young girls who wear the hijab can see
  themselves represented and feel proud."""@en ;
  dcterms:modified "2026-06-07T15:30:29.298390Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8265-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘The Planet in a Pickle Jar’ contains precise vocabulary that is crucial for
  understanding the meaning behind the story."""@en ;
  dcterms:modified "2026-06-07T15:30:29.298424Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8265-2
  a curric:KeyLearningPoint ;
  rdfs:label """The grandma describes the planet as “fragile” and wants to “preserve” it so she
  creates a “sanctuary”."""@en ;
  dcterms:modified "2026-06-07T15:30:29.298428Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8265-3
  a curric:KeyLearningPoint ;
  rdfs:label "Special things are pickled in jars because pickling is a method of preservation."@en ;
  dcterms:modified "2026-06-07T15:30:29.298432Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8265-4
  a curric:KeyLearningPoint ;
  rdfs:label """The story explores the preservation of the world’s natural elements, human elements
  and items/belongings."""@en ;
  dcterms:modified "2026-06-07T15:30:29.298436Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8265-5
  a curric:KeyLearningPoint ;
  rdfs:label """The illustrations communicate additional meaning behind the vocabulary in
  the story."""@en ;
  dcterms:modified "2026-06-07T15:30:29.298440Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5482-1
  a curric:KeyLearningPoint ;
  rdfs:label """The last sequencing word used should show the story is coming to a close, such as
  'Last,' or 'Finally,'"""@en ;
  dcterms:modified "2026-06-07T15:30:29.298500Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5482-2
  a curric:KeyLearningPoint ;
  rdfs:label "The ending of a story usually solves the problem and ends happily."@en ;
  dcterms:modified "2026-06-07T15:30:29.298504Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5482-3
  a curric:KeyLearningPoint ;
  rdfs:label "Rehearsing a sentence out loud before writing it helps us to remember it"@en ;
  dcterms:modified "2026-06-07T15:30:29.298508Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5482-4
  a curric:KeyLearningPoint ;
  rdfs:label "Reading a sentence back after writing helps to check it makes sense"@en ;
  dcterms:modified "2026-06-07T15:30:29.298512Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5482-5
  a curric:KeyLearningPoint ;
  rdfs:label """Every sentence must start with a capital letter and end with a full stop (or other
  closing punctuation)"""@en ;
  dcterms:modified "2026-06-07T15:30:29.298516Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5647-1
  a curric:KeyLearningPoint ;
  rdfs:label "The Great Fire of London happened in the past."@en ;
  dcterms:modified "2026-06-07T15:30:29.298520Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5647-2
  a curric:KeyLearningPoint ;
  rdfs:label "The fire started on Sunday 2nd September 1666."@en ;
  dcterms:modified "2026-06-07T15:30:29.298524Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5647-3
  a curric:KeyLearningPoint ;
  rdfs:label "The fire started in Pudding Lane in Thomas Farriner’s bakery."@en ;
  dcterms:modified "2026-06-07T15:30:29.298528Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5647-4
  a curric:KeyLearningPoint ;
  rdfs:label """The fire spread quickly due to the houses being made of wood, being close together
  and the windy conditions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.298533Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5647-5
  a curric:KeyLearningPoint ;
  rdfs:label "The fire lasted for four days before it was stopped."@en ;
  dcterms:modified "2026-06-07T15:30:29.298537Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-912-1
  a curric:KeyLearningPoint ;
  rdfs:label "A joining word can join two simple sentences."@en ;
  dcterms:modified "2026-06-07T15:30:29.298541Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-912-2
  a curric:KeyLearningPoint ;
  rdfs:label "The second idea builds on to the first idea if 'and' is used to join them."@en ;
  dcterms:modified "2026-06-07T15:30:29.298544Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-912-3
  a curric:KeyLearningPoint ;
  rdfs:label "Joining with 'and' is a type of co-ordination."@en ;
  dcterms:modified "2026-06-07T15:30:29.298548Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-912-4
  a curric:KeyLearningPoint ;
  rdfs:label """Grammatically accurate sentences start with capital letters and most often end with
  full stops."""@en ;
  dcterms:modified "2026-06-07T15:30:29.298552Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-912-5
  a curric:KeyLearningPoint ;
  rdfs:label """Grammatically accurate sentences do not have capital letters in the middle of them,
  except for proper nouns."""@en ;
  dcterms:modified "2026-06-07T15:30:29.298556Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6203-1
  a curric:KeyLearningPoint ;
  rdfs:label "Presentations can be spoken aloud to an audience."@en ;
  dcterms:modified "2026-06-07T15:30:29.298659Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6203-2
  a curric:KeyLearningPoint ;
  rdfs:label "Presentations are effective ways to share information."@en ;
  dcterms:modified "2026-06-07T15:30:29.298662Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6203-3
  a curric:KeyLearningPoint ;
  rdfs:label """Presentations should be spoken clearly and at a suitable volume for the space you
  are in."""@en ;
  dcterms:modified "2026-06-07T15:30:29.298666Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5429-1
  a curric:KeyLearningPoint ;
  rdfs:label """Adjectives can be used to describe a character's appearance and personality, such as
  'enormous, greedy' giant."""@en ;
  dcterms:modified "2026-06-07T15:30:29.298682Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5429-2
  a curric:KeyLearningPoint ;
  rdfs:label """When using two adjectives, a comma is placed in between them, such as 'the enormous,
  greedy giant'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.298688Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5429-3
  a curric:KeyLearningPoint ;
  rdfs:label "Two ideas can be joined together using 'and' to form one sentence."@en ;
  dcterms:modified "2026-06-07T15:30:29.298693Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5429-4
  a curric:KeyLearningPoint ;
  rdfs:label "Using 'and' connects two ideas together."@en ;
  dcterms:modified "2026-06-07T15:30:29.298697Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5429-5
  a curric:KeyLearningPoint ;
  rdfs:label "Referring to the giant as 'he' after naming him makes writing less repetitive."@en ;
  dcterms:modified "2026-06-07T15:30:29.298701Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-938-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘ue’ is a representation of the 'oo' phoneme that often comes at the end of
  a word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.298724Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-938-2
  a curric:KeyLearningPoint ;
  rdfs:label "ue', 'ui' and 'ou' are alternative spellings of the 'oo' phoneme."@en ;
  dcterms:modified "2026-06-07T15:30:29.298729Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-938-3
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the common exception words: many and after."@en ;
  dcterms:modified "2026-06-07T15:30:29.298733Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28999-1
  a curric:KeyLearningPoint ;
  rdfs:label """Rehearsing what we want to write aloud helps us to hold the information in
  our head."""@en ;
  dcterms:modified "2026-06-07T15:30:29.299552Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28999-2
  a curric:KeyLearningPoint ;
  rdfs:label "Instructions start with a title, such as ‘How to make a sandwich’."@en ;
  dcterms:modified "2026-06-07T15:30:29.299574Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28999-3
  a curric:KeyLearningPoint ;
  rdfs:label """Instructions often include a list of what you will need, in this case,
  ingredients."""@en ;
  dcterms:modified "2026-06-07T15:30:29.299578Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28999-4
  a curric:KeyLearningPoint ;
  rdfs:label """A list might be put into a sentence or written as listed objects on separate
  lines."""@en ;
  dcterms:modified "2026-06-07T15:30:29.299582Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5430-1
  a curric:KeyLearningPoint ;
  rdfs:label """Adjectives can be used to describe a character's appearance and personality, such as
  'small, sneaky Jack'"""@en ;
  dcterms:modified "2026-06-07T15:30:29.299654Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5430-2
  a curric:KeyLearningPoint ;
  rdfs:label """When using two adjectives, a comma is placed in between them, such as 'small, sneaky
  Jack'"""@en ;
  dcterms:modified "2026-06-07T15:30:29.299658Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5430-3
  a curric:KeyLearningPoint ;
  rdfs:label "Two ideas can be joined together using 'and' to form one sentence"@en ;
  dcterms:modified "2026-06-07T15:30:29.299662Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5430-4
  a curric:KeyLearningPoint ;
  rdfs:label "Using 'and' connects two ideas together"@en ;
  dcterms:modified "2026-06-07T15:30:29.299666Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5430-5
  a curric:KeyLearningPoint ;
  rdfs:label "Referring to Jack as 'he' after naming him makes writing less repetitive."@en ;
  dcterms:modified "2026-06-07T15:30:29.299670Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6164-1
  a curric:KeyLearningPoint ;
  rdfs:label "An adjective is a word that describes a noun."@en ;
  dcterms:modified "2026-06-07T15:30:29.299674Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6164-2
  a curric:KeyLearningPoint ;
  rdfs:label "Two adjectives describing a noun is called an expanded noun phrase."@en ;
  dcterms:modified "2026-06-07T15:30:29.299678Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6164-3
  a curric:KeyLearningPoint ;
  rdfs:label "A comma should be used to separate adjectives in an expanded noun phrase."@en ;
  dcterms:modified "2026-06-07T15:30:29.299684Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6164-4
  a curric:KeyLearningPoint ;
  rdfs:label """A character is a person or animal in a fictional story. They are not real and have
  been created by the writer."""@en ;
  dcterms:modified "2026-06-07T15:30:29.299688Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5115-1
  a curric:KeyLearningPoint ;
  rdfs:label "The pre-cursive letters v, w, x and z are all x-height letters"@en ;
  dcterms:modified "2026-06-07T15:30:29.299716Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5115-2
  a curric:KeyLearningPoint ;
  rdfs:label "The pre-cursive letters v and w have a lead out on the x-height line"@en ;
  dcterms:modified "2026-06-07T15:30:29.299720Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5115-3
  a curric:KeyLearningPoint ;
  rdfs:label "The pre-cursive letters x and z don't have a lead out"@en ;
  dcterms:modified "2026-06-07T15:30:29.299724Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5115-4
  a curric:KeyLearningPoint ;
  rdfs:label "Break letters are letters that don't join other letters"@en ;
  dcterms:modified "2026-06-07T15:30:29.299728Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5115-5
  a curric:KeyLearningPoint ;
  rdfs:label "The pre-cursive letters x and z are break letters"@en ;
  dcterms:modified "2026-06-07T15:30:29.299731Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5328-1
  a curric:KeyLearningPoint ;
  rdfs:label """Writing about when and where the trip was should come at the beginning of a
  recount"""@en ;
  dcterms:modified "2026-06-07T15:30:29.299735Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5328-2
  a curric:KeyLearningPoint ;
  rdfs:label "Explaining why the trip happened can come at the beginning of a recount"@en ;
  dcterms:modified "2026-06-07T15:30:29.299739Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5328-3
  a curric:KeyLearningPoint ;
  rdfs:label "Explaining how you travelled to the trip can come at the beginning of a recount"@en ;
  dcterms:modified "2026-06-07T15:30:29.299743Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5328-4
  a curric:KeyLearningPoint ;
  rdfs:label "Adding interesting adjectives and adverbs makes a recount more interesting"@en ;
  dcterms:modified "2026-06-07T15:30:29.299747Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5328-5
  a curric:KeyLearningPoint ;
  rdfs:label "Two events in a recount can be joined together using the joining word, 'and'"@en ;
  dcterms:modified "2026-06-07T15:30:29.299753Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5146-1
  a curric:KeyLearningPoint ;
  rdfs:label """Proper nouns have capital letters and can involve more decoding skills than
  understanding skills."""@en ;
  dcterms:modified "2026-06-07T15:30:29.303887Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5146-2
  a curric:KeyLearningPoint ;
  rdfs:label """Sounding out using phonics strategies is our most helpful way to decode unfamiliar
  words, such as \"whispered\"."""@en ;
  dcterms:modified "2026-06-07T15:30:29.303891Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5146-3
  a curric:KeyLearningPoint ;
  rdfs:label "Common exception words are important to learn and remember, such as 'said'."@en ;
  dcterms:modified "2026-06-07T15:30:29.303895Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5146-4
  a curric:KeyLearningPoint ;
  rdfs:label "Re-reading a sentence can help us make sense of it and ensure understanding."@en ;
  dcterms:modified "2026-06-07T15:30:29.303899Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5146-5
  a curric:KeyLearningPoint ;
  rdfs:label "Looking at the illustrations can support comprehension."@en ;
  dcterms:modified "2026-06-07T15:30:29.303903Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6840-1
  a curric:KeyLearningPoint ;
  rdfs:label "Senses help us to experience and describe the setting, in this case, the forest."@en ;
  dcterms:modified "2026-06-07T15:30:29.303921Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6840-2
  a curric:KeyLearningPoint ;
  rdfs:label "The five senses are sight, smell, hearing, touch and taste."@en ;
  dcterms:modified "2026-06-07T15:30:29.303925Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6840-3
  a curric:KeyLearningPoint ;
  rdfs:label """An adjective or list of 2 adjectives can describe a noun, such as \"wild forest\" or
  \"noisy, chirping birds\"."""@en ;
  dcterms:modified "2026-06-07T15:30:29.303929Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6840-4
  a curric:KeyLearningPoint ;
  rdfs:label "Using descriptions with adjectives makes writing more interesting."@en ;
  dcterms:modified "2026-06-07T15:30:29.303933Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6840-5
  a curric:KeyLearningPoint ;
  rdfs:label """The joining word \"and\" can be used to join to complete ideas into a full
  sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.303937Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6181-1
  a curric:KeyLearningPoint ;
  rdfs:label "Editing is the process of making any changes needed to improve our writing."@en ;
  dcterms:modified "2026-06-07T15:30:29.304166Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6181-2
  a curric:KeyLearningPoint ;
  rdfs:label """Punctuation is the name for the marks used to make our sentences clearer and easier
  to read."""@en ;
  dcterms:modified "2026-06-07T15:30:29.304170Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6181-3
  a curric:KeyLearningPoint ;
  rdfs:label """When we edit word choices, we carefully review and make changes to the words in our
  writing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.304174Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6181-4
  a curric:KeyLearningPoint ;
  rdfs:label "Our choice of adjectives, adverbs and verbs should be precise and descriptive."@en ;
  dcterms:modified "2026-06-07T15:30:29.304180Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28996-1
  a curric:KeyLearningPoint ;
  rdfs:label """A design is a drawn and labelled plan for what something is intended to look like
  when complete."""@en ;
  dcterms:modified "2026-06-07T15:30:29.304234Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28996-2
  a curric:KeyLearningPoint ;
  rdfs:label "A design includes labels and captions."@en ;
  dcterms:modified "2026-06-07T15:30:29.304238Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28996-3
  a curric:KeyLearningPoint ;
  rdfs:label "A design includes what materials or things you will need to make it."@en ;
  dcterms:modified "2026-06-07T15:30:29.304242Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28996-4
  a curric:KeyLearningPoint ;
  rdfs:label "A noun is a naming word for a person, place or thing."@en ;
  dcterms:modified "2026-06-07T15:30:29.304246Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28996-5
  a curric:KeyLearningPoint ;
  rdfs:label "An adjective describes or adds detail to a noun."@en ;
  dcterms:modified "2026-06-07T15:30:29.304252Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7177-1
  a curric:KeyLearningPoint ;
  rdfs:label "Senses can be used to describe and imagine a setting"@en ;
  dcterms:modified "2026-06-07T15:30:29.304324Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7177-2
  a curric:KeyLearningPoint ;
  rdfs:label """When using two adjectives, a comma is placed in between them, such as 'warm, vibrant
  Nigeria'"""@en ;
  dcterms:modified "2026-06-07T15:30:29.304327Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7177-3
  a curric:KeyLearningPoint ;
  rdfs:label "An adjective describes a noun"@en ;
  dcterms:modified "2026-06-07T15:30:29.304331Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7177-4
  a curric:KeyLearningPoint ;
  rdfs:label """When we place more than one noun before an adjective, it is called an expanded noun
  phrase"""@en ;
  dcterms:modified "2026-06-07T15:30:29.304335Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-936-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘ew’ is a representation of the 'oo' phoneme that often comes at the end of
  a word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.304355Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-936-2
  a curric:KeyLearningPoint ;
  rdfs:label "The ‘oo’ phoneme can be pronounced in two different ways: 'oo' and 'yoo'."@en ;
  dcterms:modified "2026-06-07T15:30:29.304359Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-936-3
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the high frequency word: now."@en ;
  dcterms:modified "2026-06-07T15:30:29.304364Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-936-4
  a curric:KeyLearningPoint ;
  rdfs:label "'New' and 'knew' are homophones."@en ;
  dcterms:modified "2026-06-07T15:30:29.304369Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8173-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the introduction is to engage the reader, introduce the author and
  provide general information."""@en ;
  dcterms:modified "2026-06-07T15:30:29.305127Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8173-2
  a curric:KeyLearningPoint ;
  rdfs:label """An information text begins with a heading about the whole text and a subheading for
  the introduction."""@en ;
  dcterms:modified "2026-06-07T15:30:29.305131Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8173-3
  a curric:KeyLearningPoint ;
  rdfs:label """There are four main sentence types (a statement, a question, a command and an
  exclamation)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.305135Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8173-4
  a curric:KeyLearningPoint ;
  rdfs:label """Using a variety of sentence types in your introduction helps to engage and inform
  the reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.305138Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8173-5
  a curric:KeyLearningPoint ;
  rdfs:label """The text is mainly written in third person to inform the reader, with the use of
  some second person to engage them."""@en ;
  dcterms:modified "2026-06-07T15:30:29.305142Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-919-1
  a curric:KeyLearningPoint ;
  rdfs:label "'And', 'but' and 'or' are three different co-ordinating conjunctions."@en ;
  dcterms:modified "2026-06-07T15:30:29.305146Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-919-2
  a curric:KeyLearningPoint ;
  rdfs:label "The co-ordinating conjunction used changes the meaning of the compound sentence."@en ;
  dcterms:modified "2026-06-07T15:30:29.305150Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-919-3
  a curric:KeyLearningPoint ;
  rdfs:label "Co-ordination helps our writing flow."@en ;
  dcterms:modified "2026-06-07T15:30:29.305154Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6187-1
  a curric:KeyLearningPoint ;
  rdfs:label """Comparing means looking at how things are the same and contrasting means looking at
  how things are different."""@en ;
  dcterms:modified "2026-06-07T15:30:29.305233Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6187-2
  a curric:KeyLearningPoint ;
  rdfs:label "The purpose of the conclusion is to summarise the information from the report."@en ;
  dcterms:modified "2026-06-07T15:30:29.305237Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6187-3
  a curric:KeyLearningPoint ;
  rdfs:label "No new information is given in the conclusion."@en ;
  dcterms:modified "2026-06-07T15:30:29.305241Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5409-1
  a curric:KeyLearningPoint ;
  rdfs:label """Fiction books are made up by the author and non-fiction books provide information
  based on facts."""@en ;
  dcterms:modified "2026-06-07T15:30:29.305283Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5409-2
  a curric:KeyLearningPoint ;
  rdfs:label """Fiction books have fictional characters and places and non-fiction books provide
  information about real subjects."""@en ;
  dcterms:modified "2026-06-07T15:30:29.305287Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5409-3
  a curric:KeyLearningPoint ;
  rdfs:label """Fiction books often have illustrations and non-fiction books often have photographs
  or diagrams of real things."""@en ;
  dcterms:modified "2026-06-07T15:30:29.305291Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5409-4
  a curric:KeyLearningPoint ;
  rdfs:label """Fiction books usually follow a story structure and non-fiction books are usually
  organised by topic or subject."""@en ;
  dcterms:modified "2026-06-07T15:30:29.305297Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5409-5
  a curric:KeyLearningPoint ;
  rdfs:label """Fiction books often have a moral and non-fiction books are designed to provide
  information and teach new things."""@en ;
  dcterms:modified "2026-06-07T15:30:29.305301Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5414-1
  a curric:KeyLearningPoint ;
  rdfs:label "An information page needs to be easy to read and understand."@en ;
  dcterms:modified "2026-06-07T15:30:29.305340Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5414-2
  a curric:KeyLearningPoint ;
  rdfs:label "An information page needs a title such as 'How to look after cats'."@en ;
  dcterms:modified "2026-06-07T15:30:29.305344Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5414-3
  a curric:KeyLearningPoint ;
  rdfs:label """An information page needs to include subject-specific vocabulary such as 'shelter'
  or 'healthy'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.305348Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5414-4
  a curric:KeyLearningPoint ;
  rdfs:label "When listing what a cat needs, a comma must be placed between each noun."@en ;
  dcterms:modified "2026-06-07T15:30:29.305352Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5414-5
  a curric:KeyLearningPoint ;
  rdfs:label """'Fun Facts' or 'Did you know?' questions can be added to make the writing more
  interesting."""@en ;
  dcterms:modified "2026-06-07T15:30:29.305356Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5440-1
  a curric:KeyLearningPoint ;
  rdfs:label """'Five Little Ducks Went Swimming One Day' has some rhyming words, such as 'day' and
  'away'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.305610Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5440-2
  a curric:KeyLearningPoint ;
  rdfs:label """Knowing the tune, words, rhythm and actions of a nursery rhyme makes it more
  entertaining for an audience."""@en ;
  dcterms:modified "2026-06-07T15:30:29.305613Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5440-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Hickory Dickory Dock' and 'Five Little Ducks Went Swimming One Day' are similar
  because they both include counting."""@en ;
  dcterms:modified "2026-06-07T15:30:29.305617Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5440-4
  a curric:KeyLearningPoint ;
  rdfs:label """Personal responses are a way of sharing your own thoughts, feelings, and opinions
  about a poem."""@en ;
  dcterms:modified "2026-06-07T15:30:29.305621Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5438-1
  a curric:KeyLearningPoint ;
  rdfs:label "Nursery rhymes are aimed at children."@en ;
  dcterms:modified "2026-06-07T15:30:29.305746Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5438-2
  a curric:KeyLearningPoint ;
  rdfs:label """Nursery rhymes might have words that rhyme in them, which are words that end in the
  same sound or sounds."""@en ;
  dcterms:modified "2026-06-07T15:30:29.305751Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5438-3
  a curric:KeyLearningPoint ;
  rdfs:label "Nursery rhymes are often sung in a tune."@en ;
  dcterms:modified "2026-06-07T15:30:29.305754Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5438-4
  a curric:KeyLearningPoint ;
  rdfs:label "Nursery rhymes are often easy to learn and have repeated elements or refrains."@en ;
  dcterms:modified "2026-06-07T15:30:29.305758Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5438-5
  a curric:KeyLearningPoint ;
  rdfs:label "Nursery rhymes often link to historical events or periods."@en ;
  dcterms:modified "2026-06-07T15:30:29.305762Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-969-1
  a curric:KeyLearningPoint ;
  rdfs:label """A suffix is a letter or group of letters at the end of a word which creates another
  word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.305856Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-969-2
  a curric:KeyLearningPoint ;
  rdfs:label """The past tense of some verbs may sound like they end in 'id', 't' or 'd', but they
  are spelt using '-ed'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.305860Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-969-3
  a curric:KeyLearningPoint ;
  rdfs:label "If the verb ends in two consonant letters, the ending is simply added on."@en ;
  dcterms:modified "2026-06-07T15:30:29.305864Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-969-4
  a curric:KeyLearningPoint ;
  rdfs:label """If the verb ends in a consonant + 'y', the 'y' is changed to 'i' before 'ed' is
  added."""@en ;
  dcterms:modified "2026-06-07T15:30:29.305868Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-969-5
  a curric:KeyLearningPoint ;
  rdfs:label """If the root word ends in a consonant + 'e', the 'e' is removed before the suffix is
  added."""@en ;
  dcterms:modified "2026-06-07T15:30:29.305872Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5197-1
  a curric:KeyLearningPoint ;
  rdfs:label """Looking out for clues in the text and illustrations can help answer questions that
  may not have obvious answers."""@en ;
  dcterms:modified "2026-06-07T15:30:29.306007Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5197-2
  a curric:KeyLearningPoint ;
  rdfs:label "Inference skills can help to develop a deeper understanding of a text."@en ;
  dcterms:modified "2026-06-07T15:30:29.306011Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5197-3
  a curric:KeyLearningPoint ;
  rdfs:label "An opinion is a view about something, somewhere or someone that is personal."@en ;
  dcterms:modified "2026-06-07T15:30:29.306015Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5197-4
  a curric:KeyLearningPoint ;
  rdfs:label "One person’s opinion can differ from someone else’s opinion."@en ;
  dcterms:modified "2026-06-07T15:30:29.306019Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5197-5
  a curric:KeyLearningPoint ;
  rdfs:label "Opinions should be able to be justified or explained in a respectful way."@en ;
  dcterms:modified "2026-06-07T15:30:29.306024Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4763-1
  a curric:KeyLearningPoint ;
  rdfs:label "The letters all have a lead in and a lead out."@en ;
  dcterms:modified "2026-06-07T15:30:29.306203Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4763-2
  a curric:KeyLearningPoint ;
  rdfs:label "The pencil only lifts to add the dot to the i and the cross to the t."@en ;
  dcterms:modified "2026-06-07T15:30:29.306209Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4763-3
  a curric:KeyLearningPoint ;
  rdfs:label """The second join goes from the baseline to above the x-height line towards the
  ascender line."""@en ;
  dcterms:modified "2026-06-07T15:30:29.306213Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4763-4
  a curric:KeyLearningPoint ;
  rdfs:label """When forming the letter f it has two loops; one at the top of the lead in and one at
  the bottom ready for the lead out."""@en ;
  dcterms:modified "2026-06-07T15:30:29.306217Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8481-1
  a curric:KeyLearningPoint ;
  rdfs:label """The author’s choice of vocabulary is precise and ambitious and is used to convey
  meaning to the reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.306342Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8481-2
  a curric:KeyLearningPoint ;
  rdfs:label "Repetition of keywords can enhance and support storytelling."@en ;
  dcterms:modified "2026-06-07T15:30:29.306346Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8481-3
  a curric:KeyLearningPoint ;
  rdfs:label """Multiple words can be used to describe the same thing, e.g. “gobbled”, “munched” and
  “feasted”."""@en ;
  dcterms:modified "2026-06-07T15:30:29.306350Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8481-4
  a curric:KeyLearningPoint ;
  rdfs:label """Character speech is used to show the perspective and feelings of different
  characters and this impacts how it is read."""@en ;
  dcterms:modified "2026-06-07T15:30:29.306356Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8481-5
  a curric:KeyLearningPoint ;
  rdfs:label """Summarising a story helps us to build our understanding of a text and the meaning
  behind it."""@en ;
  dcterms:modified "2026-06-07T15:30:29.306360Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8130-1
  a curric:KeyLearningPoint ;
  rdfs:label "Notes from a written plan support in writing a sequence of senences."@en ;
  dcterms:modified "2026-06-07T15:30:29.310417Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8130-2
  a curric:KeyLearningPoint ;
  rdfs:label """Co-ordination can be used to join two simple sentences that carry equal
  importance."""@en ;
  dcterms:modified "2026-06-07T15:30:29.310421Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8130-3
  a curric:KeyLearningPoint ;
  rdfs:label """Subordination can be used to stretch a main clause and explain ideas to the
  reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.310425Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8130-4
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials followed by a comma can be used to sequence sentences and add
  detail to the main clause."""@en ;
  dcterms:modified "2026-06-07T15:30:29.310429Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5431-1
  a curric:KeyLearningPoint ;
  rdfs:label """Expressions and actions of characters help us to infer how a character feels, such
  as when Jack races up the beanstalk"""@en ;
  dcterms:modified "2026-06-07T15:30:29.310518Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5431-2
  a curric:KeyLearningPoint ;
  rdfs:label """Recalling parts of a story help us to remember what happened, such as remembering
  the order of what Jack steals."""@en ;
  dcterms:modified "2026-06-07T15:30:29.310522Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5431-3
  a curric:KeyLearningPoint ;
  rdfs:label "Asking questions to the character helps us to consider key events and themes"@en ;
  dcterms:modified "2026-06-07T15:30:29.310526Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5431-4
  a curric:KeyLearningPoint ;
  rdfs:label """Illustrations can offer clues as to how characters might feel or what might happen
  next"""@en ;
  dcterms:modified "2026-06-07T15:30:29.310532Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5431-5
  a curric:KeyLearningPoint ;
  rdfs:label """Thinking from different character's perspectives helps us to decide which character
  is in the right or wrong"""@en ;
  dcterms:modified "2026-06-07T15:30:29.310537Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-955-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘aw’ is a representation of the 'or' phoneme that often comes at the end of a word
  and sometimes in the middle."""@en ;
  dcterms:modified "2026-06-07T15:30:29.312968Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-955-2
  a curric:KeyLearningPoint ;
  rdfs:label """‘oor’ is a representation of the 'or' phoneme that sometimes comes at the end of a
  word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.312974Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-955-3
  a curric:KeyLearningPoint ;
  rdfs:label "The proper noun 'August' is spelt using a capital letter."@en ;
  dcterms:modified "2026-06-07T15:30:29.312980Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-955-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the common exception words: busy, sure and sugar."@en ;
  dcterms:modified "2026-06-07T15:30:29.312985Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-929-1
  a curric:KeyLearningPoint ;
  rdfs:label """'igh' is a representation of the 'igh' phoneme that is often found in the middle of
  a word and 'loves a t'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.312989Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-929-2
  a curric:KeyLearningPoint ;
  rdfs:label """‘i-e’ is a representation of the ‘igh’ phoneme that is often found ‘last but
  one'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.312993Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-929-3
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the common exception words: there and where."@en ;
  dcterms:modified "2026-06-07T15:30:29.312997Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4784-1
  a curric:KeyLearningPoint ;
  rdfs:label "A numeral is a digit that represents a number."@en ;
  dcterms:modified "2026-06-07T15:30:29.313097Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4784-2
  a curric:KeyLearningPoint ;
  rdfs:label """The numerals 0, 1, 2, 3 and 5 are made using one continuous movement and without
  lifting your pencil."""@en ;
  dcterms:modified "2026-06-07T15:30:29.313101Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4784-3
  a curric:KeyLearningPoint ;
  rdfs:label "The numeral 4 needs the pencil lifted to add a second line."@en ;
  dcterms:modified "2026-06-07T15:30:29.313105Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4784-4
  a curric:KeyLearningPoint ;
  rdfs:label "The numerals 0 to 5 all sit on the baseline."@en ;
  dcterms:modified "2026-06-07T15:30:29.313109Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5432-1
  a curric:KeyLearningPoint ;
  rdfs:label """Retelling a story helps us to remember the main events and use storytelling
  language, such as 'Once upon a time'"""@en ;
  dcterms:modified "2026-06-07T15:30:29.313113Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5432-2
  a curric:KeyLearningPoint ;
  rdfs:label "Using storytelling language helps us to sequence events and provide a structure"@en ;
  dcterms:modified "2026-06-07T15:30:29.313117Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5432-3
  a curric:KeyLearningPoint ;
  rdfs:label "Story mountains map out the beginning, middle and end"@en ;
  dcterms:modified "2026-06-07T15:30:29.313123Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5432-4
  a curric:KeyLearningPoint ;
  rdfs:label """Powerful adjectives, verbs and adverbs can be added to a story mountain, such as
  'enormous', 'crept', 'angrily'"""@en ;
  dcterms:modified "2026-06-07T15:30:29.313127Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5432-5
  a curric:KeyLearningPoint ;
  rdfs:label "Story mountains help to plan a story"@en ;
  dcterms:modified "2026-06-07T15:30:29.313131Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5433-1
  a curric:KeyLearningPoint ;
  rdfs:label "Traditional tales are mostly told in the past tense"@en ;
  dcterms:modified "2026-06-07T15:30:29.313347Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5433-2
  a curric:KeyLearningPoint ;
  rdfs:label "The beginning of a story introduces the main characters, setting and plot"@en ;
  dcterms:modified "2026-06-07T15:30:29.313353Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5433-3
  a curric:KeyLearningPoint ;
  rdfs:label "Two ideas can be joined using a joining word, 'and'"@en ;
  dcterms:modified "2026-06-07T15:30:29.313357Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5433-4
  a curric:KeyLearningPoint ;
  rdfs:label """Two adjective sentences need a comma in between the two adjectives, such as 'noisy,
  hungry cow'"""@en ;
  dcterms:modified "2026-06-07T15:30:29.313361Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5433-5
  a curric:KeyLearningPoint ;
  rdfs:label """Exclamation marks can be used to show anger, such as when mother throws the beans
  out of the window"""@en ;
  dcterms:modified "2026-06-07T15:30:29.313368Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5642-1
  a curric:KeyLearningPoint ;
  rdfs:label """Imperative verbs make the instructions very similar to commands as they are bossy
  and tell the reader what to do."""@en ;
  dcterms:modified "2026-06-07T15:30:29.313426Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5642-2
  a curric:KeyLearningPoint ;
  rdfs:label """Instructions are written in chronological order and use ordering fronted adverbials
  to sequence them."""@en ;
  dcterms:modified "2026-06-07T15:30:29.313430Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5642-3
  a curric:KeyLearningPoint ;
  rdfs:label "A plan is written in note form and will help guide us when writing."@en ;
  dcterms:modified "2026-06-07T15:30:29.313434Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-925-1
  a curric:KeyLearningPoint ;
  rdfs:label "'ee' and 'ea' are common spellings of the 'ee' phoneme."@en ;
  dcterms:modified "2026-06-07T15:30:29.315178Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-925-2
  a curric:KeyLearningPoint ;
  rdfs:label "e-e' is a representation of the 'ee' phoneme that is often found 'last but one'."@en ;
  dcterms:modified "2026-06-07T15:30:29.315182Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-925-3
  a curric:KeyLearningPoint ;
  rdfs:label """Some words do not follow the rule, meaning they are an exception, such as
  'even'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.315186Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-925-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the common exception words: door, floor and poor."@en ;
  dcterms:modified "2026-06-07T15:30:29.315192Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-920-1
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the common exception words: all, ball and call."@en ;
  dcterms:modified "2026-06-07T15:30:29.315215Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-920-2
  a curric:KeyLearningPoint ;
  rdfs:label """‘ai’ is a representation of the ay phoneme that often is found in the middle of a
  word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.315219Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-920-3
  a curric:KeyLearningPoint ;
  rdfs:label """‘a-e’ is a representation of the ‘ay’ phoneme that is often found ‘last but
  one'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.315223Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-920-4
  a curric:KeyLearningPoint ;
  rdfs:label """‘ay’ is a representation of the ay phoneme that often comes at the end of a
  word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.315230Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1019-1
  a curric:KeyLearningPoint ;
  rdfs:label "An apostrophe is an important piece of punctuation."@en ;
  dcterms:modified "2026-06-07T15:30:29.315234Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1019-2
  a curric:KeyLearningPoint ;
  rdfs:label "An apostrophe has more than one purpose."@en ;
  dcterms:modified "2026-06-07T15:30:29.315240Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1019-3
  a curric:KeyLearningPoint ;
  rdfs:label "An apostrophe can show if a noun belongs to another singular noun."@en ;
  dcterms:modified "2026-06-07T15:30:29.315244Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1019-4
  a curric:KeyLearningPoint ;
  rdfs:label "Apostrophes for singular possession are useful to make our writing clear."@en ;
  dcterms:modified "2026-06-07T15:30:29.315281Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1019-5
  a curric:KeyLearningPoint ;
  rdfs:label "An apostrophe sits at the same height as the ascender of a letter."@en ;
  dcterms:modified "2026-06-07T15:30:29.315286Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6280-1
  a curric:KeyLearningPoint ;
  rdfs:label """A diary is a personal book where you write about your thoughts, feelings and
  experiences."""@en ;
  dcterms:modified "2026-06-07T15:30:29.315293Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6280-2
  a curric:KeyLearningPoint ;
  rdfs:label "Features are distinctive qualities or characteristics of something."@en ;
  dcterms:modified "2026-06-07T15:30:29.315297Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6280-3
  a curric:KeyLearningPoint ;
  rdfs:label """The features of a diary entry include writing in the first person and past
  tense."""@en ;
  dcterms:modified "2026-06-07T15:30:29.315301Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6280-4
  a curric:KeyLearningPoint ;
  rdfs:label "Diary entries usually include feelings and emotions."@en ;
  dcterms:modified "2026-06-07T15:30:29.315306Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4776-1
  a curric:KeyLearningPoint ;
  rdfs:label "The letters are formed by following the right starting point and direction."@en ;
  dcterms:modified "2026-06-07T15:30:29.315331Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4776-2
  a curric:KeyLearningPoint ;
  rdfs:label """The third join starts at the x-height line and dips below the x-height line and back
  up to join the next letter."""@en ;
  dcterms:modified "2026-06-07T15:30:29.315335Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4776-3
  a curric:KeyLearningPoint ;
  rdfs:label """When using the third join, you leave enough space to ensure the letters are not
  touching without leaving a big gap."""@en ;
  dcterms:modified "2026-06-07T15:30:29.315338Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4776-4
  a curric:KeyLearningPoint ;
  rdfs:label """The pencil does not lift in between the beginning and end of a letter string or
  word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.315345Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8482-1
  a curric:KeyLearningPoint ;
  rdfs:label """A theme is a big idea or lesson that the author wants you to explore & understand
  through reading the story."""@en ;
  dcterms:modified "2026-06-07T15:30:29.315349Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8482-2
  a curric:KeyLearningPoint ;
  rdfs:label """Readers can interpret themes and their importance within a story in
  different ways."""@en ;
  dcterms:modified "2026-06-07T15:30:29.315353Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8482-3
  a curric:KeyLearningPoint ;
  rdfs:label """‘The Wolf, The Duck and The Mouse’ explores the themes of collaboration, optimism,
  and resourcefulness."""@en ;
  dcterms:modified "2026-06-07T15:30:29.315357Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8482-4
  a curric:KeyLearningPoint ;
  rdfs:label "Collaboration is the action of working with someone to achieve something."@en ;
  dcterms:modified "2026-06-07T15:30:29.315361Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8482-5
  a curric:KeyLearningPoint ;
  rdfs:label """Collaboration is a skill that we learn and practise which has a variety of positive
  impacts on us."""@en ;
  dcterms:modified "2026-06-07T15:30:29.315367Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-903-1
  a curric:KeyLearningPoint ;
  rdfs:label "One adjective can be used to describe a noun."@en ;
  dcterms:modified "2026-06-07T15:30:29.315371Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-903-2
  a curric:KeyLearningPoint ;
  rdfs:label "Two adjectives can be used to describe a noun with more detail."@en ;
  dcterms:modified "2026-06-07T15:30:29.315375Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-903-3
  a curric:KeyLearningPoint ;
  rdfs:label "If two adjectives are used to describe a noun, they are listed with a comma."@en ;
  dcterms:modified "2026-06-07T15:30:29.315380Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-903-4
  a curric:KeyLearningPoint ;
  rdfs:label """A list of two adjectives followed by a noun is called an expanded noun
  phrase (ENP)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.315384Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-939-1
  a curric:KeyLearningPoint ;
  rdfs:label "ue', 'ui' and 'ou' are alternative spellings of the 'oo' phoneme."@en ;
  dcterms:modified "2026-06-07T15:30:29.318831Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-939-2
  a curric:KeyLearningPoint ;
  rdfs:label """‘ue’ is a representation of the 'oo' phoneme that often comes at the end of
  a word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.318835Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-939-3
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the common exception words: move, prove and improve."@en ;
  dcterms:modified "2026-06-07T15:30:29.318839Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4745-1
  a curric:KeyLearningPoint ;
  rdfs:label "Capital letters are upper case formations of a letter."@en ;
  dcterms:modified "2026-06-07T15:30:29.318865Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4745-2
  a curric:KeyLearningPoint ;
  rdfs:label "Every lower case letter has a matching capital letter."@en ;
  dcterms:modified "2026-06-07T15:30:29.318869Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4745-3
  a curric:KeyLearningPoint ;
  rdfs:label """Lower case letters and their capital letter can be formed in similar or different
  ways."""@en ;
  dcterms:modified "2026-06-07T15:30:29.318873Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4787-1
  a curric:KeyLearningPoint ;
  rdfs:label """All of the letters start on the ascender line except for the letter S which starts
  just below the ascender line."""@en ;
  dcterms:modified "2026-06-07T15:30:29.318926Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4787-2
  a curric:KeyLearningPoint ;
  rdfs:label """Letters A, H, K and T all have either one or two vertical or diagonal lines going
  down to the baseline."""@en ;
  dcterms:modified "2026-06-07T15:30:29.318930Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4787-3
  a curric:KeyLearningPoint ;
  rdfs:label """Letters A, H, K and T all need the pencil to be lifted to form the horizontal or
  diagonal lines."""@en ;
  dcterms:modified "2026-06-07T15:30:29.318933Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4787-4
  a curric:KeyLearningPoint ;
  rdfs:label "You do not lift your pencil when forming the letter S."@en ;
  dcterms:modified "2026-06-07T15:30:29.318938Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4787-5
  a curric:KeyLearningPoint ;
  rdfs:label "The letter S curls around twice."@en ;
  dcterms:modified "2026-06-07T15:30:29.318943Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5415-1
  a curric:KeyLearningPoint ;
  rdfs:label """Instructions can be added to an information report to tell someone what to do and
  how to do it, such as 'Feed your cat'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.318968Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5415-2
  a curric:KeyLearningPoint ;
  rdfs:label """Instructions can also be called commands as they are commanding someone to do
  something."""@en ;
  dcterms:modified "2026-06-07T15:30:29.318972Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5415-3
  a curric:KeyLearningPoint ;
  rdfs:label "Instructions can also start with adverbials of time to sequence points."@en ;
  dcterms:modified "2026-06-07T15:30:29.318976Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5415-4
  a curric:KeyLearningPoint ;
  rdfs:label """Limiting the amount of instructions or information can help the reader to understand
  more clearly."""@en ;
  dcterms:modified "2026-06-07T15:30:29.318980Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5415-5
  a curric:KeyLearningPoint ;
  rdfs:label """Adding photos or drawings can help the reader understand the information being
  given."""@en ;
  dcterms:modified "2026-06-07T15:30:29.318984Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4789-1
  a curric:KeyLearningPoint ;
  rdfs:label """A sentence always begins with a capital letter and a proper noun always has a
  capital letter."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319009Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4789-2
  a curric:KeyLearningPoint ;
  rdfs:label """After forming a capital letter, you need to lift your pencil to start the next part
  of the word with a lead in."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319013Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4789-3
  a curric:KeyLearningPoint ;
  rdfs:label "The letters all have a lead in and a lead out."@en ;
  dcterms:modified "2026-06-07T15:30:29.319017Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4789-4
  a curric:KeyLearningPoint ;
  rdfs:label "The pencil does not lift when forming the joins."@en ;
  dcterms:modified "2026-06-07T15:30:29.319021Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4789-5
  a curric:KeyLearningPoint ;
  rdfs:label "There is appropriate spacing between the letters and between the words."@en ;
  dcterms:modified "2026-06-07T15:30:29.319027Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5195-1
  a curric:KeyLearningPoint ;
  rdfs:label """Adjectives that describe how someone is feeling help to read speech with
  expression."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319031Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5195-2
  a curric:KeyLearningPoint ;
  rdfs:label "Adverbs may describe how a character has said something."@en ;
  dcterms:modified "2026-06-07T15:30:29.319035Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5195-3
  a curric:KeyLearningPoint ;
  rdfs:label """Taking note of punctuation allows us to read with expression and communicate
  meaning."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319039Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5195-4
  a curric:KeyLearningPoint ;
  rdfs:label """Using different types of voice and different tones makes reading aloud more
  interesting for those who are listening."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319044Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5195-5
  a curric:KeyLearningPoint ;
  rdfs:label "You must decode and understand words to be able to add expression."@en ;
  dcterms:modified "2026-06-07T15:30:29.319048Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5149-1
  a curric:KeyLearningPoint ;
  rdfs:label "Traditional tales often have a theme that is central to the story."@en ;
  dcterms:modified "2026-06-07T15:30:29.319067Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5149-2
  a curric:KeyLearningPoint ;
  rdfs:label "The theme often leads to a moral that can teach us a lesson about something."@en ;
  dcterms:modified "2026-06-07T15:30:29.319071Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5149-3
  a curric:KeyLearningPoint ;
  rdfs:label "Thinking about the moral can help us change something in our lives."@en ;
  dcterms:modified "2026-06-07T15:30:29.319077Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5149-4
  a curric:KeyLearningPoint ;
  rdfs:label "When we sequence events in a story, we put them in chronological order."@en ;
  dcterms:modified "2026-06-07T15:30:29.319084Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5149-5
  a curric:KeyLearningPoint ;
  rdfs:label "Sequencing the main events of the story helps to summarise the whole story."@en ;
  dcterms:modified "2026-06-07T15:30:29.319089Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-937-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘ew’ is a representation of the 'oo' phoneme that often comes at the end of
  a word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.321886Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-937-2
  a curric:KeyLearningPoint ;
  rdfs:label "The 'oo' phoneme can be pronounced in two ways: 'oo' and 'yoo'."@en ;
  dcterms:modified "2026-06-07T15:30:29.321890Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-937-3
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the common exception words: put and Christmas."@en ;
  dcterms:modified "2026-06-07T15:30:29.321894Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8172-1
  a curric:KeyLearningPoint ;
  rdfs:label """'Inspired' is an adjective which means feeling full of ideas and excited to do
  something."""@en ;
  dcterms:modified "2026-06-07T15:30:29.321923Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8172-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Passionate' is an adjective which means feeling a strong love or enthusiasm for
  something."""@en ;
  dcterms:modified "2026-06-07T15:30:29.321927Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8172-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Curious' and 'imaginative' are other adjectives associated with inspiration."@en ;
  dcterms:modified "2026-06-07T15:30:29.321930Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8172-4
  a curric:KeyLearningPoint ;
  rdfs:label "Word choices must be precise in writing and speaking."@en ;
  dcterms:modified "2026-06-07T15:30:29.321934Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5436-1
  a curric:KeyLearningPoint ;
  rdfs:label """Personal responses are a way of sharing your own thoughts, feelings and opinions
  about a text."""@en ;
  dcterms:modified "2026-06-07T15:30:29.321953Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5436-2
  a curric:KeyLearningPoint ;
  rdfs:label """Making connections between the text and your own experiences can help you make
  personal responses and draw conclusions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.321957Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5436-3
  a curric:KeyLearningPoint ;
  rdfs:label """When making personal responses, it's important to support your opinions with
  evidence from the text."""@en ;
  dcterms:modified "2026-06-07T15:30:29.321961Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5436-4
  a curric:KeyLearningPoint ;
  rdfs:label """Some people may believe Jack was the villain of the story for stealing and
  trespassing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.321965Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5436-5
  a curric:KeyLearningPoint ;
  rdfs:label """Some people may believe the giant was the villain for not sharing and for reacting
  in an angry, scary manner."""@en ;
  dcterms:modified "2026-06-07T15:30:29.321968Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6163-1
  a curric:KeyLearningPoint ;
  rdfs:label "A setting is where the story takes place."@en ;
  dcterms:modified "2026-06-07T15:30:29.322043Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6163-2
  a curric:KeyLearningPoint ;
  rdfs:label "Two adjectives describing a noun is called an expanded noun phrase."@en ;
  dcterms:modified "2026-06-07T15:30:29.322047Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6163-3
  a curric:KeyLearningPoint ;
  rdfs:label "A comma should be used to separate adjectives in an expanded noun phrase."@en ;
  dcterms:modified "2026-06-07T15:30:29.322051Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6163-4
  a curric:KeyLearningPoint ;
  rdfs:label "We can use our senses to describe a setting."@en ;
  dcterms:modified "2026-06-07T15:30:29.322055Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6166-1
  a curric:KeyLearningPoint ;
  rdfs:label "An opening will introduce the setting and main characters."@en ;
  dcterms:modified "2026-06-07T15:30:29.322135Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6166-2
  a curric:KeyLearningPoint ;
  rdfs:label "A descriptive opening will contain expanded noun phrases."@en ;
  dcterms:modified "2026-06-07T15:30:29.322141Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6166-3
  a curric:KeyLearningPoint ;
  rdfs:label "A descriptive opening will contain adverbs and verbs."@en ;
  dcterms:modified "2026-06-07T15:30:29.322147Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4759-1
  a curric:KeyLearningPoint ;
  rdfs:label "The letters e, s, v, w, x and z are all x-height letters."@en ;
  dcterms:modified "2026-06-07T15:30:29.322173Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4759-2
  a curric:KeyLearningPoint ;
  rdfs:label "The letter f has an ascender and a descender."@en ;
  dcterms:modified "2026-06-07T15:30:29.322177Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4759-3
  a curric:KeyLearningPoint ;
  rdfs:label "The letters v and w are both formed by going diagonally down and back up."@en ;
  dcterms:modified "2026-06-07T15:30:29.322181Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4759-4
  a curric:KeyLearningPoint ;
  rdfs:label """The letter x is formed by making two diagonal straight lines crossing in the
  centre."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322185Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4759-5
  a curric:KeyLearningPoint ;
  rdfs:label """The letter z is formed by a zig-zag pattern with a straight, then diagonal and then
  a straight line."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322189Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4795-1
  a curric:KeyLearningPoint ;
  rdfs:label """A sentence always begins with a capital letter and a proper noun always has a
  capital letter."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322338Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4795-2
  a curric:KeyLearningPoint ;
  rdfs:label """After forming a capital letter, you need to lift your pencil to start the next part
  of the word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322342Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4795-3
  a curric:KeyLearningPoint ;
  rdfs:label "The letters all have a lead out, except for the capital letters."@en ;
  dcterms:modified "2026-06-07T15:30:29.322346Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4795-4
  a curric:KeyLearningPoint ;
  rdfs:label "There is appropriate spacing between the letters."@en ;
  dcterms:modified "2026-06-07T15:30:29.322350Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4795-5
  a curric:KeyLearningPoint ;
  rdfs:label "The pencil does not lift when forming the joins."@en ;
  dcterms:modified "2026-06-07T15:30:29.322355Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8529-1
  a curric:KeyLearningPoint ;
  rdfs:label """Texts often have a theme, or big idea, which is repeated through the story in
  different ways."""@en ;
  dcterms:modified "2026-06-07T15:30:29.324485Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8529-2
  a curric:KeyLearningPoint ;
  rdfs:label """A theme is a big idea or lesson that the author wants you to explore or
  understand."""@en ;
  dcterms:modified "2026-06-07T15:30:29.324489Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8529-3
  a curric:KeyLearningPoint ;
  rdfs:label "In \"Grandad's Island\", the themes of family and separation are explored."@en ;
  dcterms:modified "2026-06-07T15:30:29.324493Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7217-1
  a curric:KeyLearningPoint ;
  rdfs:label "Home Time is a poem about the end of the school day."@en ;
  dcterms:modified "2026-06-07T15:30:29.324497Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7217-2
  a curric:KeyLearningPoint ;
  rdfs:label "Home Time is a poem written from the perspective of the classroom clock."@en ;
  dcterms:modified "2026-06-07T15:30:29.324501Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7217-3
  a curric:KeyLearningPoint ;
  rdfs:label "Home Time is a poem that uses personification."@en ;
  dcterms:modified "2026-06-07T15:30:29.324505Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7217-4
  a curric:KeyLearningPoint ;
  rdfs:label "Personification and perspective can be an imaginitive way to create humour."@en ;
  dcterms:modified "2026-06-07T15:30:29.324509Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8889-1
  a curric:KeyLearningPoint ;
  rdfs:label "Making a prediction means deciding what you think will happen next in a story."@en ;
  dcterms:modified "2026-06-07T15:30:29.324513Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8889-2
  a curric:KeyLearningPoint ;
  rdfs:label "One person's prediction may be different to another person's."@en ;
  dcterms:modified "2026-06-07T15:30:29.324517Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8889-3
  a curric:KeyLearningPoint ;
  rdfs:label "Narrative openings introduce the characters, setting and plot."@en ;
  dcterms:modified "2026-06-07T15:30:29.324521Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8889-4
  a curric:KeyLearningPoint ;
  rdfs:label "Plop meets an old woman who likes the dark and says it is 'kind'."@en ;
  dcterms:modified "2026-06-07T15:30:29.324525Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6822-1
  a curric:KeyLearningPoint ;
  rdfs:label """Predictions can be made based on illustrations, what has already been read and the
  front cover"""@en ;
  dcterms:modified "2026-06-07T15:30:29.324585Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6822-2
  a curric:KeyLearningPoint ;
  rdfs:label "One person's prediction may be different to another person's"@en ;
  dcterms:modified "2026-06-07T15:30:29.324589Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6822-3
  a curric:KeyLearningPoint ;
  rdfs:label """Traditional tales often start by introducing the characters, such as the three goats
  and setting the scene"""@en ;
  dcterms:modified "2026-06-07T15:30:29.324593Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6822-4
  a curric:KeyLearningPoint ;
  rdfs:label "The Three Billy Goats Gruff teaches the reader to be kind to others"@en ;
  dcterms:modified "2026-06-07T15:30:29.324597Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6822-5
  a curric:KeyLearningPoint ;
  rdfs:label "Traditional tales mostly end happily, such as being able to cross the bridge"@en ;
  dcterms:modified "2026-06-07T15:30:29.324601Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29016-1
  a curric:KeyLearningPoint ;
  rdfs:label "Using 'I', 'me', 'my', 'we' or 'us' is a way of speaking in the first person."@en ;
  dcterms:modified "2026-06-07T15:30:29.324642Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29016-2
  a curric:KeyLearningPoint ;
  rdfs:label """One way of inferring a character's feelings is looking at their expressions in an
  illustration."""@en ;
  dcterms:modified "2026-06-07T15:30:29.324646Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29016-3
  a curric:KeyLearningPoint ;
  rdfs:label """Another way of inferring a character's feelings is reading about how they move, what
  they do and what they say."""@en ;
  dcterms:modified "2026-06-07T15:30:29.324650Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29016-4
  a curric:KeyLearningPoint ;
  rdfs:label """Discussing the feelings of others helps to generate powerful adjectives to describe
  an emotion or event."""@en ;
  dcterms:modified "2026-06-07T15:30:29.324654Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29016-5
  a curric:KeyLearningPoint ;
  rdfs:label """Considering an event in the story from a character's point of view helps us to
  understand the plot of the story better."""@en ;
  dcterms:modified "2026-06-07T15:30:29.324658Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-953-1
  a curric:KeyLearningPoint ;
  rdfs:label "'ea' can be used to represent the 'e' phoneme."@en ;
  dcterms:modified "2026-06-07T15:30:29.326638Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-953-2
  a curric:KeyLearningPoint ;
  rdfs:label "'tch' is the representation of 'ch' usually used after a short vowel."@en ;
  dcterms:modified "2026-06-07T15:30:29.326644Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-953-3
  a curric:KeyLearningPoint ;
  rdfs:label "Exceptions to the 'tch' principle include the words: rich, which, much and such."@en ;
  dcterms:modified "2026-06-07T15:30:29.326649Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-953-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the common exception words: any and many."@en ;
  dcterms:modified "2026-06-07T15:30:29.326653Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8209-1
  a curric:KeyLearningPoint ;
  rdfs:label """Robert Hull is a British writer who is mostly known for his stories, poetry and
  books written for children."""@en ;
  dcterms:modified "2026-06-07T15:30:29.326656Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8209-2
  a curric:KeyLearningPoint ;
  rdfs:label """‘Please do not feed the animals…’ is a humorous poem that reminds children of what
  not to feed the animals."""@en ;
  dcterms:modified "2026-06-07T15:30:29.326660Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8209-3
  a curric:KeyLearningPoint ;
  rdfs:label """This poem uses unexpected rhyming words at the end of each line to create
  humour."""@en ;
  dcterms:modified "2026-06-07T15:30:29.326664Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8209-4
  a curric:KeyLearningPoint ;
  rdfs:label """When we read aloud, we can use our voice to put emphasis on the rhyming words to
  convey the humour."""@en ;
  dcterms:modified "2026-06-07T15:30:29.326668Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6165-1
  a curric:KeyLearningPoint ;
  rdfs:label """Creating a plan is a good way to help you prepare before completing a piece of
  writing"""@en ;
  dcterms:modified "2026-06-07T15:30:29.326703Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6165-2
  a curric:KeyLearningPoint ;
  rdfs:label "Our plans will contain ambitious vocabulary"@en ;
  dcterms:modified "2026-06-07T15:30:29.326707Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6165-3
  a curric:KeyLearningPoint ;
  rdfs:label "Two adjectives in an expanded noun phrase should be separated by a comma"@en ;
  dcterms:modified "2026-06-07T15:30:29.326710Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6165-4
  a curric:KeyLearningPoint ;
  rdfs:label "Adverbs should be used to describe a verb"@en ;
  dcterms:modified "2026-06-07T15:30:29.326714Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5442-1
  a curric:KeyLearningPoint ;
  rdfs:label """Knowing the tune, words, rhythm and actions of a nursery rhyme makes it entertaining
  for the audience."""@en ;
  dcterms:modified "2026-06-07T15:30:29.326756Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5442-2
  a curric:KeyLearningPoint ;
  rdfs:label """Nursery rhymes follow either a rhythm or tune to keep to or in some nursery rhymes,
  both."""@en ;
  dcterms:modified "2026-06-07T15:30:29.326762Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5442-3
  a curric:KeyLearningPoint ;
  rdfs:label "Some nursery rhymes can be preferred by others compared to other nursery rhymes."@en ;
  dcterms:modified "2026-06-07T15:30:29.326768Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5442-4
  a curric:KeyLearningPoint ;
  rdfs:label """Commenting on performances by highlighting what went well supports others to improve
  their performance."""@en ;
  dcterms:modified "2026-06-07T15:30:29.326772Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5442-5
  a curric:KeyLearningPoint ;
  rdfs:label "Your personal response can be explained by using because."@en ;
  dcterms:modified "2026-06-07T15:30:29.326776Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6172-1
  a curric:KeyLearningPoint ;
  rdfs:label """An animated story is a narrative brought to life through the medium of
  animation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.326780Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6172-2
  a curric:KeyLearningPoint ;
  rdfs:label """A question is a type of simple sentence that asks the reader for an answer and ends
  with a question mark."""@en ;
  dcterms:modified "2026-06-07T15:30:29.326784Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6172-3
  a curric:KeyLearningPoint ;
  rdfs:label "Questions start with question words and these need a capital letter."@en ;
  dcterms:modified "2026-06-07T15:30:29.326788Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6172-4
  a curric:KeyLearningPoint ;
  rdfs:label "A question always ends with a question mark"@en ;
  dcterms:modified "2026-06-07T15:30:29.326792Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6172-5
  a curric:KeyLearningPoint ;
  rdfs:label "We can ask questions about characters to help us engage with a story."@en ;
  dcterms:modified "2026-06-07T15:30:29.326798Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8109-1
  a curric:KeyLearningPoint ;
  rdfs:label "Things you think or believe are called your opinions"@en ;
  dcterms:modified "2026-06-07T15:30:29.326802Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8109-2
  a curric:KeyLearningPoint ;
  rdfs:label """An audience is a group of people listening to or watching a performance or
  speaker"""@en ;
  dcterms:modified "2026-06-07T15:30:29.326806Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8109-3
  a curric:KeyLearningPoint ;
  rdfs:label "Speaking loudly and clearly is important when talking in front of an audience"@en ;
  dcterms:modified "2026-06-07T15:30:29.326810Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4779-1
  a curric:KeyLearningPoint ;
  rdfs:label "The letters are formed by following the right starting point and direction."@en ;
  dcterms:modified "2026-06-07T15:30:29.326814Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4779-2
  a curric:KeyLearningPoint ;
  rdfs:label "The fourth join goes from the x-height line up towards the ascender line."@en ;
  dcterms:modified "2026-06-07T15:30:29.326839Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4779-3
  a curric:KeyLearningPoint ;
  rdfs:label """The letters l and h reach up to the ascender line. The letter t reaches between the
  x-height line and the ascender line."""@en ;
  dcterms:modified "2026-06-07T15:30:29.326843Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4779-4
  a curric:KeyLearningPoint ;
  rdfs:label "You do not lift your pencil when joining until the letter string is complete."@en ;
  dcterms:modified "2026-06-07T15:30:29.326868Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4779-5
  a curric:KeyLearningPoint ;
  rdfs:label "The cross for the letter t is added once the letter string is complete."@en ;
  dcterms:modified "2026-06-07T15:30:29.326872Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5435-1
  a curric:KeyLearningPoint ;
  rdfs:label "Two ideas can be joined using a joining word, 'and'"@en ;
  dcterms:modified "2026-06-07T15:30:29.328754Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5435-2
  a curric:KeyLearningPoint ;
  rdfs:label """Exclamation marks can be used to show surprise, such as when the giant follows Jack
  down the beanstalk."""@en ;
  dcterms:modified "2026-06-07T15:30:29.328760Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5435-3
  a curric:KeyLearningPoint ;
  rdfs:label """Some adverbs describing how characters may move can be used at the start of a
  sentence, such as 'quickly'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.328765Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5435-4
  a curric:KeyLearningPoint ;
  rdfs:label "Some adverbials of time build suspense, such as 'suddenly'"@en ;
  dcterms:modified "2026-06-07T15:30:29.328769Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5435-5
  a curric:KeyLearningPoint ;
  rdfs:label "When we start a sentence with an adverb, we call it a fronted adverbial."@en ;
  dcterms:modified "2026-06-07T15:30:29.328773Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5412-1
  a curric:KeyLearningPoint ;
  rdfs:label "Re-reading key information can help to learn and remember it."@en ;
  dcterms:modified "2026-06-07T15:30:29.328777Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5412-2
  a curric:KeyLearningPoint ;
  rdfs:label "Facts can be recalled from information in books."@en ;
  dcterms:modified "2026-06-07T15:30:29.328781Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5412-3
  a curric:KeyLearningPoint ;
  rdfs:label "A fact is a statement that is true, such as 'cats enjoy playing with toys'."@en ;
  dcterms:modified "2026-06-07T15:30:29.328785Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5412-4
  a curric:KeyLearningPoint ;
  rdfs:label "Facts can be written in simple sentences."@en ;
  dcterms:modified "2026-06-07T15:30:29.328789Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5412-5
  a curric:KeyLearningPoint ;
  rdfs:label "When listing what a cat needs, a comma must be placed between each noun."@en ;
  dcterms:modified "2026-06-07T15:30:29.328793Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5645-1
  a curric:KeyLearningPoint ;
  rdfs:label "Editing is the process of making any changes needed to improve our writing."@en ;
  dcterms:modified "2026-06-07T15:30:29.328809Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5645-2
  a curric:KeyLearningPoint ;
  rdfs:label """Punctuation is the name for the marks used to make our sentences clearer and easier
  to read."""@en ;
  dcterms:modified "2026-06-07T15:30:29.328813Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5645-3
  a curric:KeyLearningPoint ;
  rdfs:label """When we edit word choices, we carefully review and make changes to the words in our
  writing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.328817Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27621-1
  a curric:KeyLearningPoint ;
  rdfs:label "Things you believe are called your opinions."@en ;
  dcterms:modified "2026-06-07T15:30:29.328821Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27621-2
  a curric:KeyLearningPoint ;
  rdfs:label "People can agree or disagree with an opinion."@en ;
  dcterms:modified "2026-06-07T15:30:29.328825Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27621-3
  a curric:KeyLearningPoint ;
  rdfs:label """Using the word 'because' will allow you to explain why you agree or disagree with an
  opinion."""@en ;
  dcterms:modified "2026-06-07T15:30:29.328829Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27621-4
  a curric:KeyLearningPoint ;
  rdfs:label "Speaking in full sentences helps the listener understand what is being said."@en ;
  dcterms:modified "2026-06-07T15:30:29.328835Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27621-5
  a curric:KeyLearningPoint ;
  rdfs:label """Successful listening includes looking at the person speaking and paying close
  attention."""@en ;
  dcterms:modified "2026-06-07T15:30:29.328839Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-960-1
  a curric:KeyLearningPoint ;
  rdfs:label "tion' is the most common spelling of /shun/."@en ;
  dcterms:modified "2026-06-07T15:30:29.328878Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-960-2
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the common exception word: Monday."@en ;
  dcterms:modified "2026-06-07T15:30:29.328882Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-960-3
  a curric:KeyLearningPoint ;
  rdfs:label "Monday is a proper noun and is spelt using a capital letter."@en ;
  dcterms:modified "2026-06-07T15:30:29.328886Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-960-4
  a curric:KeyLearningPoint ;
  rdfs:label """A suffix is a letter or group of letters at the end of a word which creates another
  word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.328890Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4778-1
  a curric:KeyLearningPoint ;
  rdfs:label "The letters are formed by following the right starting point and direction."@en ;
  dcterms:modified "2026-06-07T15:30:29.328894Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4778-2
  a curric:KeyLearningPoint ;
  rdfs:label """The third join starts at the x-height line and dips below the x-height line and back
  up to join the next letter."""@en ;
  dcterms:modified "2026-06-07T15:30:29.328898Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4778-3
  a curric:KeyLearningPoint ;
  rdfs:label "The letter strings are all x-height letters."@en ;
  dcterms:modified "2026-06-07T15:30:29.328902Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4778-4
  a curric:KeyLearningPoint ;
  rdfs:label """When using the third join you leave enough space to ensure the letters are not
  touching without leaving a big gap."""@en ;
  dcterms:modified "2026-06-07T15:30:29.328906Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4778-5
  a curric:KeyLearningPoint ;
  rdfs:label """You don't lift your pencil until the letter string is complete. The dot for the i is
  added at the end."""@en ;
  dcterms:modified "2026-06-07T15:30:29.328912Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5443-1
  a curric:KeyLearningPoint ;
  rdfs:label "A poet is someone who writes poems."@en ;
  dcterms:modified "2026-06-07T15:30:29.328954Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5443-2
  a curric:KeyLearningPoint ;
  rdfs:label "Poems try to use words in a special way to create a feeling or to tell a story."@en ;
  dcterms:modified "2026-06-07T15:30:29.328958Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5443-3
  a curric:KeyLearningPoint ;
  rdfs:label "James Carter is a poet who uses rhyming words in his poems."@en ;
  dcterms:modified "2026-06-07T15:30:29.328962Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5443-4
  a curric:KeyLearningPoint ;
  rdfs:label "Repetition in poems can make the poem fun to say and easy to remember."@en ;
  dcterms:modified "2026-06-07T15:30:29.328966Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5443-5
  a curric:KeyLearningPoint ;
  rdfs:label """James Carter uses onomatopoeia which helps us to imagine what sounds can be heard in
  a story or a poem."""@en ;
  dcterms:modified "2026-06-07T15:30:29.328971Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-978-1
  a curric:KeyLearningPoint ;
  rdfs:label "'When' and 'if' are types of joining word."@en ;
  dcterms:modified "2026-06-07T15:30:29.335221Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-978-2
  a curric:KeyLearningPoint ;
  rdfs:label """A simple sentence can be stretched with 'when' to give a time frame to the first
  idea."""@en ;
  dcterms:modified "2026-06-07T15:30:29.335225Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-978-3
  a curric:KeyLearningPoint ;
  rdfs:label """A simple sentence can be stretched with 'if' to give conditions to the first
  idea."""@en ;
  dcterms:modified "2026-06-07T15:30:29.335229Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-978-4
  a curric:KeyLearningPoint ;
  rdfs:label """Joining the first idea with 'when' or 'if' forms a second idea that is subordinate
  to the first."""@en ;
  dcterms:modified "2026-06-07T15:30:29.335233Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-978-5
  a curric:KeyLearningPoint ;
  rdfs:label """Using 'when' or 'if' to stretch a simple sentence forms an adverbial complex
  sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.335237Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-952-1
  a curric:KeyLearningPoint ;
  rdfs:label "'a' is the most common spelling for the 'o' phoneme after 'w' and 'qu'."@en ;
  dcterms:modified "2026-06-07T15:30:29.335241Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-952-2
  a curric:KeyLearningPoint ;
  rdfs:label """How to spell the common exception words: other, mother, brother, another and
  nothing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.335245Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4738-1
  a curric:KeyLearningPoint ;
  rdfs:label """The capital letters M, N, W and V all have the same starting point and go down and
  back up."""@en ;
  dcterms:modified "2026-06-07T15:30:29.335269Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4738-2
  a curric:KeyLearningPoint ;
  rdfs:label """These capital letters are formed by one continuous movement and you do not need to
  lift your pencil."""@en ;
  dcterms:modified "2026-06-07T15:30:29.335275Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4799-1
  a curric:KeyLearningPoint ;
  rdfs:label "High frequency words are words that appear most frequently in written texts."@en ;
  dcterms:modified "2026-06-07T15:30:29.335328Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4799-2
  a curric:KeyLearningPoint ;
  rdfs:label """Letters in the high frequency words will be joined using a range of joins depending
  on the letters in the word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.335332Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4799-3
  a curric:KeyLearningPoint ;
  rdfs:label "You start at the correct starting point for the first letter."@en ;
  dcterms:modified "2026-06-07T15:30:29.335336Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4799-4
  a curric:KeyLearningPoint ;
  rdfs:label "There is appropriate spacing between the letters."@en ;
  dcterms:modified "2026-06-07T15:30:29.335340Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4799-5
  a curric:KeyLearningPoint ;
  rdfs:label "You don’t lift your pencil until the letter string is complete."@en ;
  dcterms:modified "2026-06-07T15:30:29.335344Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-906-1
  a curric:KeyLearningPoint ;
  rdfs:label "A simple sentence is about one idea and it makes complete sense."@en ;
  dcterms:modified "2026-06-07T15:30:29.335348Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-906-2
  a curric:KeyLearningPoint ;
  rdfs:label "A simple sentence can be written in the present tense."@en ;
  dcterms:modified "2026-06-07T15:30:29.335352Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-906-3
  a curric:KeyLearningPoint ;
  rdfs:label "A simple sentence contains one verb and at least one noun."@en ;
  dcterms:modified "2026-06-07T15:30:29.335356Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-906-4
  a curric:KeyLearningPoint ;
  rdfs:label "The verb carries the tense of a sentence."@en ;
  dcterms:modified "2026-06-07T15:30:29.335360Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-906-5
  a curric:KeyLearningPoint ;
  rdfs:label """Grammatically accurate sentences start with capital letters and most often end with
  full stops."""@en ;
  dcterms:modified "2026-06-07T15:30:29.335364Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-976-1
  a curric:KeyLearningPoint ;
  rdfs:label "An apostrophe has more than one purpose."@en ;
  dcterms:modified "2026-06-07T15:30:29.335368Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-976-2
  a curric:KeyLearningPoint ;
  rdfs:label "An apostrophe can show possession."@en ;
  dcterms:modified "2026-06-07T15:30:29.335375Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-976-3
  a curric:KeyLearningPoint ;
  rdfs:label "An 's is used to show belonging after the first noun."@en ;
  dcterms:modified "2026-06-07T15:30:29.335379Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6828-1
  a curric:KeyLearningPoint ;
  rdfs:label "Rehearsing a sentence out loud before writing it helps us to remember it"@en ;
  dcterms:modified "2026-06-07T15:30:29.337979Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6828-2
  a curric:KeyLearningPoint ;
  rdfs:label "Reading a sentence back after writing helps to check it makes sense"@en ;
  dcterms:modified "2026-06-07T15:30:29.337983Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6828-3
  a curric:KeyLearningPoint ;
  rdfs:label "Every sentence must start with a capital letter and end with a full stop"@en ;
  dcterms:modified "2026-06-07T15:30:29.337987Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6828-4
  a curric:KeyLearningPoint ;
  rdfs:label "Narrating a story means the writer is saying what happens"@en ;
  dcterms:modified "2026-06-07T15:30:29.337992Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6828-5
  a curric:KeyLearningPoint ;
  rdfs:label "Word banks help to find keywords to include in writing"@en ;
  dcterms:modified "2026-06-07T15:30:29.337997Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6841-1
  a curric:KeyLearningPoint ;
  rdfs:label """This story will be told from the girl's perspective, using the words \"I\", \"me\"
  and \"my\"."""@en ;
  dcterms:modified "2026-06-07T15:30:29.338001Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6841-2
  a curric:KeyLearningPoint ;
  rdfs:label "Thinking from someone else's perspective includes imagining how they might feel."@en ;
  dcterms:modified "2026-06-07T15:30:29.338005Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6841-3
  a curric:KeyLearningPoint ;
  rdfs:label """Thinking from someone else's perspective includes imagining why they do certain
  things."""@en ;
  dcterms:modified "2026-06-07T15:30:29.338009Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6841-4
  a curric:KeyLearningPoint ;
  rdfs:label """Thinking from someone else's perspective includes imagining what they like or
  dislike."""@en ;
  dcterms:modified "2026-06-07T15:30:29.338013Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6841-5
  a curric:KeyLearningPoint ;
  rdfs:label """Facial expressions and movements help us understand what is happening in a story
  even when words have not been used."""@en ;
  dcterms:modified "2026-06-07T15:30:29.338017Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4777-1
  a curric:KeyLearningPoint ;
  rdfs:label "The letters are formed by following the right starting point and direction."@en ;
  dcterms:modified "2026-06-07T15:30:29.338021Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4777-2
  a curric:KeyLearningPoint ;
  rdfs:label """The third join starts at the x-height line and dips below the x-height line and back
  up to join the next letter."""@en ;
  dcterms:modified "2026-06-07T15:30:29.338024Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4777-3
  a curric:KeyLearningPoint ;
  rdfs:label "The letter strings are all x-height letters."@en ;
  dcterms:modified "2026-06-07T15:30:29.338028Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4777-4
  a curric:KeyLearningPoint ;
  rdfs:label """When using the third join you leave enough space to ensure the letters are not
  touching without leaving a big gap."""@en ;
  dcterms:modified "2026-06-07T15:30:29.338032Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4777-5
  a curric:KeyLearningPoint ;
  rdfs:label """You don't lift your pencil until the letter string is complete. The dot for the i is
  added at the end."""@en ;
  dcterms:modified "2026-06-07T15:30:29.338036Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5428-1
  a curric:KeyLearningPoint ;
  rdfs:label """Traditional tales are stories that are retold again and again and can be retold in
  different ways."""@en ;
  dcterms:modified "2026-06-07T15:30:29.338081Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5428-2
  a curric:KeyLearningPoint ;
  rdfs:label "Some traditional tales have magical aspects such as magic beans or beanstalks."@en ;
  dcterms:modified "2026-06-07T15:30:29.338085Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5428-3
  a curric:KeyLearningPoint ;
  rdfs:label "Traditional tales try to teach us a lesson about something."@en ;
  dcterms:modified "2026-06-07T15:30:29.338091Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5428-4
  a curric:KeyLearningPoint ;
  rdfs:label "Traditional tales often have heroes and villains."@en ;
  dcterms:modified "2026-06-07T15:30:29.338095Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5428-5
  a curric:KeyLearningPoint ;
  rdfs:label "Jack could be described as the hero or the villain from different perspectives."@en ;
  dcterms:modified "2026-06-07T15:30:29.338102Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8900-1
  a curric:KeyLearningPoint ;
  rdfs:label """Predictions about the plot can be made using the front cover, title, illustrations
  and what we know"""@en ;
  dcterms:modified "2026-06-07T15:30:29.338171Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8900-2
  a curric:KeyLearningPoint ;
  rdfs:label """A front cover shares the title, \"Ada Twist, Scientist\", the author, Andrea Beaty
  and illustrations"""@en ;
  dcterms:modified "2026-06-07T15:30:29.338175Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8900-3
  a curric:KeyLearningPoint ;
  rdfs:label "Sometimes, authors write a range of books with similarities"@en ;
  dcterms:modified "2026-06-07T15:30:29.338200Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8900-4
  a curric:KeyLearningPoint ;
  rdfs:label "Looking at other books by the same author can help us to make links"@en ;
  dcterms:modified "2026-06-07T15:30:29.338205Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8900-5
  a curric:KeyLearningPoint ;
  rdfs:label """Front covers and our own interests help us to decide which books we'd most like to
  read"""@en ;
  dcterms:modified "2026-06-07T15:30:29.338232Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-37-1
  a curric:KeyLearningPoint ;
  rdfs:label "x-height letters can be called small letters"@en ;
  dcterms:modified "2026-06-07T15:30:29.340373Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-37-2
  a curric:KeyLearningPoint ;
  rdfs:label "x-height letters sit between the baseline and the x-height line"@en ;
  dcterms:modified "2026-06-07T15:30:29.340379Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-37-3
  a curric:KeyLearningPoint ;
  rdfs:label "The letters are formed by following the right starting point and direction"@en ;
  dcterms:modified "2026-06-07T15:30:29.340383Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-37-4
  a curric:KeyLearningPoint ;
  rdfs:label "X-height letters are all the same height"@en ;
  dcterms:modified "2026-06-07T15:30:29.340387Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-37-5
  a curric:KeyLearningPoint ;
  rdfs:label "The small letters are: a, c, o, e, i, m, n, r, s, u, v, w, x and z"@en ;
  dcterms:modified "2026-06-07T15:30:29.340391Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6827-1
  a curric:KeyLearningPoint ;
  rdfs:label "An adjective describes a noun"@en ;
  dcterms:modified "2026-06-07T15:30:29.340662Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6827-2
  a curric:KeyLearningPoint ;
  rdfs:label """Adjectives are often put in front of the noun in a sentence, such as 'scared
  goat'"""@en ;
  dcterms:modified "2026-06-07T15:30:29.340665Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6827-3
  a curric:KeyLearningPoint ;
  rdfs:label """Adjectives can be used to describe what a character might look like, such as
  'small'"""@en ;
  dcterms:modified "2026-06-07T15:30:29.340669Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6827-4
  a curric:KeyLearningPoint ;
  rdfs:label "Adjectives can be used to describe a character's personality, such as 'brave'"@en ;
  dcterms:modified "2026-06-07T15:30:29.340673Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6208-1
  a curric:KeyLearningPoint ;
  rdfs:label "The subheading ‘Jobs and books’ tells the reader what the section will be about."@en ;
  dcterms:modified "2026-06-07T15:30:29.341019Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6208-2
  a curric:KeyLearningPoint ;
  rdfs:label """The plan should include any other jobs the author had and their journey to becoming
  an author in chronological order."""@en ;
  dcterms:modified "2026-06-07T15:30:29.341023Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6208-3
  a curric:KeyLearningPoint ;
  rdfs:label """The plan should include a piece of current information about the author or other
  books by them to end the section."""@en ;
  dcterms:modified "2026-06-07T15:30:29.341027Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6208-4
  a curric:KeyLearningPoint ;
  rdfs:label """Notes are used when making a plan and capture key vocabulary and important
  information."""@en ;
  dcterms:modified "2026-06-07T15:30:29.341031Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6208-5
  a curric:KeyLearningPoint ;
  rdfs:label """Notes are not written in full sentences and do not require capital letters or full
  stops."""@en ;
  dcterms:modified "2026-06-07T15:30:29.341035Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4744-1
  a curric:KeyLearningPoint ;
  rdfs:label "Capital letters are used for proper nouns"@en ;
  dcterms:modified "2026-06-07T15:30:29.341080Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4744-2
  a curric:KeyLearningPoint ;
  rdfs:label "Days of the week start with a capital letter as they are proper nouns"@en ;
  dcterms:modified "2026-06-07T15:30:29.341086Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4744-3
  a curric:KeyLearningPoint ;
  rdfs:label "Capital letters are all the same size"@en ;
  dcterms:modified "2026-06-07T15:30:29.341092Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4744-4
  a curric:KeyLearningPoint ;
  rdfs:label "Capital letters sit between the baseline and the ascender line"@en ;
  dcterms:modified "2026-06-07T15:30:29.341096Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7212-1
  a curric:KeyLearningPoint ;
  rdfs:label """'Heartbroken' is an adjective which means feeling very upset and sad about
  something."""@en ;
  dcterms:modified "2026-06-07T15:30:29.341138Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7212-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Sulky' is an adjective which means being quiet and grumpy and moping about."@en ;
  dcterms:modified "2026-06-07T15:30:29.341141Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7212-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Disappointed' and 'miserable' are other adjectives associated with sadness."@en ;
  dcterms:modified "2026-06-07T15:30:29.341145Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7212-4
  a curric:KeyLearningPoint ;
  rdfs:label "Word choices must be precise in writing and speaking."@en ;
  dcterms:modified "2026-06-07T15:30:29.341149Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6281-1
  a curric:KeyLearningPoint ;
  rdfs:label "Perspective is the way someone thinks, feels or sees something."@en ;
  dcterms:modified "2026-06-07T15:30:29.341192Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6281-2
  a curric:KeyLearningPoint ;
  rdfs:label """Florence Nightingale went to the Crimean War to help the wounded soldiers. She was
  shocked by what she saw."""@en ;
  dcterms:modified "2026-06-07T15:30:29.341198Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6281-3
  a curric:KeyLearningPoint ;
  rdfs:label """Notes are used when making a plan and they are short and only capture key vocabulary
  and important information."""@en ;
  dcterms:modified "2026-06-07T15:30:29.341202Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6281-4
  a curric:KeyLearningPoint ;
  rdfs:label """Notes are not written in full sentences and do not require capital letters, full
  stops or commas."""@en ;
  dcterms:modified "2026-06-07T15:30:29.341206Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8210-1
  a curric:KeyLearningPoint ;
  rdfs:label """James Carter is a British poet who is mostly known for his entertaining poetry
  written for children."""@en ;
  dcterms:modified "2026-06-07T15:30:29.341210Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8210-2
  a curric:KeyLearningPoint ;
  rdfs:label "'What Did You Do at School Today?’ is a humorous poem."@en ;
  dcterms:modified "2026-06-07T15:30:29.341214Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8210-3
  a curric:KeyLearningPoint ;
  rdfs:label """The poem is written as a conversation between a child and their mother about what
  the child did at school."""@en ;
  dcterms:modified "2026-06-07T15:30:29.341220Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8210-4
  a curric:KeyLearningPoint ;
  rdfs:label """The poet uses a particular layout and structure in the poem to show the reader that
  it is a conversation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.341226Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8210-5
  a curric:KeyLearningPoint ;
  rdfs:label "'Wide Open' is humorous poem by Rachel Rooney."@en ;
  dcterms:modified "2026-06-07T15:30:29.341231Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-973-1
  a curric:KeyLearningPoint ;
  rdfs:label """A prefix is a letter or group of letters at the start of a word which creates
  another word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.341251Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-973-2
  a curric:KeyLearningPoint ;
  rdfs:label """The prefix 'un-' is added to the beginning of a word without changing the spelling
  of the root word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.341255Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-973-3
  a curric:KeyLearningPoint ;
  rdfs:label "The prefix 'un-' usually means not."@en ;
  dcterms:modified "2026-06-07T15:30:29.341259Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6843-1
  a curric:KeyLearningPoint ;
  rdfs:label "This narrative is told in the past tense."@en ;
  dcterms:modified "2026-06-07T15:30:29.341285Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6843-2
  a curric:KeyLearningPoint ;
  rdfs:label """This narrative is written from the girl's perspective, using \"I\", \"me\" and
  \"my\"."""@en ;
  dcterms:modified "2026-06-07T15:30:29.341291Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6843-3
  a curric:KeyLearningPoint ;
  rdfs:label "The beginning of a story introduces the main characters, setting and plot."@en ;
  dcterms:modified "2026-06-07T15:30:29.341295Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6843-4
  a curric:KeyLearningPoint ;
  rdfs:label "Two ideas can be joined using a joining word \"and\"."@en ;
  dcterms:modified "2026-06-07T15:30:29.341299Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6843-5
  a curric:KeyLearningPoint ;
  rdfs:label """Two adjective sentences describing characters and settings need a comma in between,
  such as \"magical, dark forest\"."""@en ;
  dcterms:modified "2026-06-07T15:30:29.341303Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-899-1
  a curric:KeyLearningPoint ;
  rdfs:label "Nouns are words that name people, places or things."@en ;
  dcterms:modified "2026-06-07T15:30:29.341307Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-899-2
  a curric:KeyLearningPoint ;
  rdfs:label "Common nouns do not need capital letters."@en ;
  dcterms:modified "2026-06-07T15:30:29.341310Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-899-3
  a curric:KeyLearningPoint ;
  rdfs:label "Proper nouns need capital letters."@en ;
  dcterms:modified "2026-06-07T15:30:29.341314Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-31-1
  a curric:KeyLearningPoint ;
  rdfs:label "The letters h and k are tall letters."@en ;
  dcterms:modified "2026-06-07T15:30:29.341411Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-31-2
  a curric:KeyLearningPoint ;
  rdfs:label "The letters h and k are formed by \"going down, up and over\"."@en ;
  dcterms:modified "2026-06-07T15:30:29.341415Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-31-3
  a curric:KeyLearningPoint ;
  rdfs:label "The letters h and k start at the ascender line."@en ;
  dcterms:modified "2026-06-07T15:30:29.341419Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5145-1
  a curric:KeyLearningPoint ;
  rdfs:label """Traditional tales can be set in real or fictional places. This traditional tale is
  set in Japan."""@en ;
  dcterms:modified "2026-06-07T15:30:29.341423Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5145-2
  a curric:KeyLearningPoint ;
  rdfs:label """Illustrations can be a way to help us to predict and understand the story. We can
  'read' the illustrations in a book."""@en ;
  dcterms:modified "2026-06-07T15:30:29.341429Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5145-3
  a curric:KeyLearningPoint ;
  rdfs:label "Predictions can be made based on making connections and pattern seeking."@en ;
  dcterms:modified "2026-06-07T15:30:29.341433Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5145-4
  a curric:KeyLearningPoint ;
  rdfs:label """Making links to our own experiences is a way to help to understand the actions of a
  character."""@en ;
  dcterms:modified "2026-06-07T15:30:29.341438Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5145-5
  a curric:KeyLearningPoint ;
  rdfs:label "Greed is one of the main themes in 'Yoshi the Stonecutter'."@en ;
  dcterms:modified "2026-06-07T15:30:29.341444Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5444-1
  a curric:KeyLearningPoint ;
  rdfs:label """Using the first person helps us think from someone or something else’s
  perspective."""@en ;
  dcterms:modified "2026-06-07T15:30:29.341521Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5444-2
  a curric:KeyLearningPoint ;
  rdfs:label "Using \"I\" allows us to imagine we are someone or something else."@en ;
  dcterms:modified "2026-06-07T15:30:29.341525Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5444-3
  a curric:KeyLearningPoint ;
  rdfs:label """Using exciting nouns and verbs help us to use our imagination to know what something
  looks or sounds like."""@en ;
  dcterms:modified "2026-06-07T15:30:29.341529Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5444-4
  a curric:KeyLearningPoint ;
  rdfs:label "James Carter is a poet who uses words that rhyme and onomatopoeia in his poems."@en ;
  dcterms:modified "2026-06-07T15:30:29.341533Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5444-5
  a curric:KeyLearningPoint ;
  rdfs:label "Onomatopoeia is when a word sounds like what it is describing."@en ;
  dcterms:modified "2026-06-07T15:30:29.341537Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4750-1
  a curric:KeyLearningPoint ;
  rdfs:label "The letters u, y and j all have a lead in and a lead out"@en ;
  dcterms:modified "2026-06-07T15:30:29.343646Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4750-2
  a curric:KeyLearningPoint ;
  rdfs:label "The letters u, y and j all start on the baseline"@en ;
  dcterms:modified "2026-06-07T15:30:29.343651Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4750-3
  a curric:KeyLearningPoint ;
  rdfs:label """The letters y and j have a loop at the bottom of the descender as the lead
  out line"""@en ;
  dcterms:modified "2026-06-07T15:30:29.343655Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4750-4
  a curric:KeyLearningPoint ;
  rdfs:label "The letters u and y are similarly formed but the y has a descender"@en ;
  dcterms:modified "2026-06-07T15:30:29.343659Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28943-1
  a curric:KeyLearningPoint ;
  rdfs:label "Matt Goodfellow is an award-winning poet and former teacher."@en ;
  dcterms:modified "2026-06-07T15:30:29.343663Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28943-2
  a curric:KeyLearningPoint ;
  rdfs:label """‘Hide and Seek’ is a playful and imaginative poem about the game ‘hide and
  seek'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.343667Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28943-3
  a curric:KeyLearningPoint ;
  rdfs:label """The poet uses different poetic devices including rhyme and rhythm to make the poem
  fun and lively to read."""@en ;
  dcterms:modified "2026-06-07T15:30:29.343671Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28943-4
  a curric:KeyLearningPoint ;
  rdfs:label "When performing a poem, we can experiment with our voice and volume."@en ;
  dcterms:modified "2026-06-07T15:30:29.343675Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28943-5
  a curric:KeyLearningPoint ;
  rdfs:label "It is important to have fun when performing."@en ;
  dcterms:modified "2026-06-07T15:30:29.343679Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6197-1
  a curric:KeyLearningPoint ;
  rdfs:label "Non-chronological reports are non-fiction."@en ;
  dcterms:modified "2026-06-07T15:30:29.343697Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6197-2
  a curric:KeyLearningPoint ;
  rdfs:label "Non-chronological reports often have titles, subheadings and paragraphs."@en ;
  dcterms:modified "2026-06-07T15:30:29.343701Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6197-3
  a curric:KeyLearningPoint ;
  rdfs:label """An introduction followed by two paragraphs of information is how we can structure a
  non-chronological report."""@en ;
  dcterms:modified "2026-06-07T15:30:29.343705Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6197-4
  a curric:KeyLearningPoint ;
  rdfs:label """A non-chronological report must be written in a formal tone, avoiding language
  choices associated with fiction writing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.343709Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6197-5
  a curric:KeyLearningPoint ;
  rdfs:label "Contractions are not used in formal writing."@en ;
  dcterms:modified "2026-06-07T15:30:29.343713Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6183-1
  a curric:KeyLearningPoint ;
  rdfs:label "A non-chronological report is a type of non-fiction text."@en ;
  dcterms:modified "2026-06-07T15:30:29.343739Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6183-2
  a curric:KeyLearningPoint ;
  rdfs:label "A non-chronological report provides information on a subject, person or event."@en ;
  dcterms:modified "2026-06-07T15:30:29.343744Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6183-3
  a curric:KeyLearningPoint ;
  rdfs:label """Notes are used when making a plan and they are short and only capture key vocabulary
  and important information."""@en ;
  dcterms:modified "2026-06-07T15:30:29.343748Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6183-4
  a curric:KeyLearningPoint ;
  rdfs:label """Notes are not written in full sentences and do not require capital letters, full
  stops or commas."""@en ;
  dcterms:modified "2026-06-07T15:30:29.343752Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6207-1
  a curric:KeyLearningPoint ;
  rdfs:label """Notes from a written plan support in writing and ensure important information is
  included in an information text."""@en ;
  dcterms:modified "2026-06-07T15:30:29.343796Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6207-2
  a curric:KeyLearningPoint ;
  rdfs:label "Using a range of sentence types in our writing helps it to flow."@en ;
  dcterms:modified "2026-06-07T15:30:29.343800Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6207-3
  a curric:KeyLearningPoint ;
  rdfs:label """Co-ordination can be used to join two simple sentences that carry equal
  importance."""@en ;
  dcterms:modified "2026-06-07T15:30:29.343804Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6207-4
  a curric:KeyLearningPoint ;
  rdfs:label "Subordination can be used to stretch a main clause and add greater detail."@en ;
  dcterms:modified "2026-06-07T15:30:29.343808Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8688-1
  a curric:KeyLearningPoint ;
  rdfs:label "A noun is a naming word, such as a \"dentist\""@en ;
  dcterms:modified "2026-06-07T15:30:29.343812Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8688-2
  a curric:KeyLearningPoint ;
  rdfs:label "A noun is a person, place or thing"@en ;
  dcterms:modified "2026-06-07T15:30:29.343816Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8688-3
  a curric:KeyLearningPoint ;
  rdfs:label """If a noun has a specific name of someone or something, it needs a capital letter,
  such as \"Lily\" or \"England\""""@en ;
  dcterms:modified "2026-06-07T15:30:29.343820Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8688-4
  a curric:KeyLearningPoint ;
  rdfs:label "Sounding out a word before writing helps to spell a word"@en ;
  dcterms:modified "2026-06-07T15:30:29.343823Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8688-5
  a curric:KeyLearningPoint ;
  rdfs:label "Reading back writing is important to check it is correct and makes sense"@en ;
  dcterms:modified "2026-06-07T15:30:29.343827Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7180-1
  a curric:KeyLearningPoint ;
  rdfs:label "Writing a letter is a way to communicate to someone"@en ;
  dcterms:modified "2026-06-07T15:30:29.344435Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7180-2
  a curric:KeyLearningPoint ;
  rdfs:label "Letters start with a greeting such as 'Dear Anna' or 'To Anna'"@en ;
  dcterms:modified "2026-06-07T15:30:29.344439Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7180-3
  a curric:KeyLearningPoint ;
  rdfs:label "Writing in the first person uses words such as 'I', 'me' or 'my'"@en ;
  dcterms:modified "2026-06-07T15:30:29.344443Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7180-4
  a curric:KeyLearningPoint ;
  rdfs:label """When answering questions, you can include part of the question in the answer to
  create a full sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.344447Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-951-1
  a curric:KeyLearningPoint ;
  rdfs:label "The 'il' and 'al' representations are usually found in polysyllabic words."@en ;
  dcterms:modified "2026-06-07T15:30:29.344451Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-951-2
  a curric:KeyLearningPoint ;
  rdfs:label "There are not many words ending in 'il'."@en ;
  dcterms:modified "2026-06-07T15:30:29.344456Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-951-3
  a curric:KeyLearningPoint ;
  rdfs:label "Not many nouns end in 'al', but many adjectives do."@en ;
  dcterms:modified "2026-06-07T15:30:29.344460Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-951-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the common exception words: father and clothes."@en ;
  dcterms:modified "2026-06-07T15:30:29.344463Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-941-1
  a curric:KeyLearningPoint ;
  rdfs:label """Two or more words that sound the same but have different meanings or spellings are
  called homophones."""@en ;
  dcterms:modified "2026-06-07T15:30:29.345800Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-941-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Hear' and 'here' are homophones."@en ;
  dcterms:modified "2026-06-07T15:30:29.345804Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-941-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Quiet' and 'quite' are homophones."@en ;
  dcterms:modified "2026-06-07T15:30:29.345808Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-941-4
  a curric:KeyLearningPoint ;
  rdfs:label "'Night' and 'knight' are homophones."@en ;
  dcterms:modified "2026-06-07T15:30:29.345812Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-941-5
  a curric:KeyLearningPoint ;
  rdfs:label "'Buy', 'by' and 'buy' are homophones."@en ;
  dcterms:modified "2026-06-07T15:30:29.345816Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-928-1
  a curric:KeyLearningPoint ;
  rdfs:label """igh' is a representation of the 'igh' phoneme that is often found in the middle of a
  word and 'loves a t'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.345820Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-928-2
  a curric:KeyLearningPoint ;
  rdfs:label """‘i-e’ is a representation of the ‘igh’ phoneme that is often found ‘last but
  one'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.345824Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-928-3
  a curric:KeyLearningPoint ;
  rdfs:label "i-e' is a split digraph."@en ;
  dcterms:modified "2026-06-07T15:30:29.345830Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-928-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the common exception words: so and do."@en ;
  dcterms:modified "2026-06-07T15:30:29.345834Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7175-1
  a curric:KeyLearningPoint ;
  rdfs:label "Vocabulary can be generated and used in different ways using a word bank"@en ;
  dcterms:modified "2026-06-07T15:30:29.345876Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7175-2
  a curric:KeyLearningPoint ;
  rdfs:label "Adjectives describe a noun"@en ;
  dcterms:modified "2026-06-07T15:30:29.345882Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7175-3
  a curric:KeyLearningPoint ;
  rdfs:label """When using two adjectives, a comma is placed in between them, such as 'kind,
  friendly'"""@en ;
  dcterms:modified "2026-06-07T15:30:29.345886Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7175-4
  a curric:KeyLearningPoint ;
  rdfs:label "Using adverbs can add detail to how family members do something"@en ;
  dcterms:modified "2026-06-07T15:30:29.345890Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7175-5
  a curric:KeyLearningPoint ;
  rdfs:label """Two ideas can be joined using a joining word like 'and' to form a compound
  sentence"""@en ;
  dcterms:modified "2026-06-07T15:30:29.345894Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5641-1
  a curric:KeyLearningPoint ;
  rdfs:label "Your imagination can help you to think of things that do not exist in real life."@en ;
  dcterms:modified "2026-06-07T15:30:29.345912Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5641-2
  a curric:KeyLearningPoint ;
  rdfs:label "A noun is a naming word for people, places or things."@en ;
  dcterms:modified "2026-06-07T15:30:29.345916Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5641-3
  a curric:KeyLearningPoint ;
  rdfs:label "An adjective is a word that describes a noun."@en ;
  dcterms:modified "2026-06-07T15:30:29.345920Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5641-4
  a curric:KeyLearningPoint ;
  rdfs:label """It is easier for the reader to picture the nouns we are writing about if we describe
  them using an adjective."""@en ;
  dcterms:modified "2026-06-07T15:30:29.345924Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8891-1
  a curric:KeyLearningPoint ;
  rdfs:label """Characterisation is the way an author describes and develops the characters in a
  story."""@en ;
  dcterms:modified "2026-06-07T15:30:29.345928Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8891-2
  a curric:KeyLearningPoint ;
  rdfs:label "Appearance is how a character looks on the outside."@en ;
  dcterms:modified "2026-06-07T15:30:29.345932Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8891-3
  a curric:KeyLearningPoint ;
  rdfs:label "Personality refers to what a character is like on the inside."@en ;
  dcterms:modified "2026-06-07T15:30:29.345936Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8891-4
  a curric:KeyLearningPoint ;
  rdfs:label "Plop is a cute, fluffy barn owl who is clumsy but friendly."@en ;
  dcterms:modified "2026-06-07T15:30:29.345940Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8891-5
  a curric:KeyLearningPoint ;
  rdfs:label """The author’s characterisation of Plop makes him a likeable character, which is
  engaging for the reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.345944Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28-1
  a curric:KeyLearningPoint ;
  rdfs:label "The letter i, l and t are formed by \"going down and finish with a flick\"."@en ;
  dcterms:modified "2026-06-07T15:30:29.346099Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28-2
  a curric:KeyLearningPoint ;
  rdfs:label "The letters l and t are tall letters."@en ;
  dcterms:modified "2026-06-07T15:30:29.346103Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28-3
  a curric:KeyLearningPoint ;
  rdfs:label "The letter i has a dot at the top and the letter t has a cross."@en ;
  dcterms:modified "2026-06-07T15:30:29.346107Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28-4
  a curric:KeyLearningPoint ;
  rdfs:label "Letters that are formed in similar ways can be called letter families."@en ;
  dcterms:modified "2026-06-07T15:30:29.346111Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9209-1
  a curric:KeyLearningPoint ;
  rdfs:label "A theme is a big idea, topic or message that appears in a story."@en ;
  dcterms:modified "2026-06-07T15:30:29.347123Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9209-2
  a curric:KeyLearningPoint ;
  rdfs:label "'And Tango Makes Three' tells the story of a penguin family that has two dads."@en ;
  dcterms:modified "2026-06-07T15:30:29.347127Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9209-3
  a curric:KeyLearningPoint ;
  rdfs:label "'And Tango Makes Three' explores themes of love, family and identity."@en ;
  dcterms:modified "2026-06-07T15:30:29.347131Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9209-4
  a curric:KeyLearningPoint ;
  rdfs:label "Families come in many different forms, shapes and sizes."@en ;
  dcterms:modified "2026-06-07T15:30:29.347138Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9209-5
  a curric:KeyLearningPoint ;
  rdfs:label "Love is the most important element in a family."@en ;
  dcterms:modified "2026-06-07T15:30:29.347142Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28629-1
  a curric:KeyLearningPoint ;
  rdfs:label """The poem ‘The Shockadile Crocodile!’ is an interactive poem where the audience join
  in saying parts of the poem."""@en ;
  dcterms:modified "2026-06-07T15:30:29.347177Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28629-2
  a curric:KeyLearningPoint ;
  rdfs:label "When performing a poem, we can use actions to make it more exciting."@en ;
  dcterms:modified "2026-06-07T15:30:29.347180Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28629-3
  a curric:KeyLearningPoint ;
  rdfs:label """The poem ‘The Shockadile Crocodile!’ is a tongue twister, so it is important to slow
  down when we perform it."""@en ;
  dcterms:modified "2026-06-07T15:30:29.347184Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28629-4
  a curric:KeyLearningPoint ;
  rdfs:label "We should think about volume as well as pace when we perform poetry."@en ;
  dcterms:modified "2026-06-07T15:30:29.347188Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4793-1
  a curric:KeyLearningPoint ;
  rdfs:label "High frequency words are words that appear most frequently in written texts."@en ;
  dcterms:modified "2026-06-07T15:30:29.347192Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4793-2
  a curric:KeyLearningPoint ;
  rdfs:label """Letters in the high frequency words will be joined using a range of joins depending
  on the letters in the word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.347199Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4793-3
  a curric:KeyLearningPoint ;
  rdfs:label """The first letter of the word always has a lead in and the last letter has a lead
  out."""@en ;
  dcterms:modified "2026-06-07T15:30:29.347203Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4793-4
  a curric:KeyLearningPoint ;
  rdfs:label "There is appropriate spacing between the letters."@en ;
  dcterms:modified "2026-06-07T15:30:29.347207Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4793-5
  a curric:KeyLearningPoint ;
  rdfs:label "You don’t lift your pencil until the letter string is complete."@en ;
  dcterms:modified "2026-06-07T15:30:29.347211Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-964-1
  a curric:KeyLearningPoint ;
  rdfs:label """A suffix is a letter or group of letters at the end of a word which creates another
  word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.347250Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-964-2
  a curric:KeyLearningPoint ;
  rdfs:label """If the suffix starts with a consonant letter, it is usually added without any change
  to the root word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.347254Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-964-3
  a curric:KeyLearningPoint ;
  rdfs:label """If a root word has more than one syllable and ends in a consonant + 'y', then 'y' is
  replaced by 'i' before the suffix."""@en ;
  dcterms:modified "2026-06-07T15:30:29.347258Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4769-1
  a curric:KeyLearningPoint ;
  rdfs:label "The letters all have a lead in and a lead out."@en ;
  dcterms:modified "2026-06-07T15:30:29.347262Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4769-2
  a curric:KeyLearningPoint ;
  rdfs:label "The pencil does not lift when forming the join."@en ;
  dcterms:modified "2026-06-07T15:30:29.347266Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4769-3
  a curric:KeyLearningPoint ;
  rdfs:label """The third join starts at the x-height line and dips below the x-height line and back
  up to join the next letter."""@en ;
  dcterms:modified "2026-06-07T15:30:29.347270Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4769-4
  a curric:KeyLearningPoint ;
  rdfs:label """When using the third join you leave enough space to ensure the letters are not
  touching without leaving a big gap."""@en ;
  dcterms:modified "2026-06-07T15:30:29.347274Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4772-1
  a curric:KeyLearningPoint ;
  rdfs:label "The letters are formed by following the right starting point and direction."@en ;
  dcterms:modified "2026-06-07T15:30:29.347321Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4772-2
  a curric:KeyLearningPoint ;
  rdfs:label "Cursive letter joins refer to how the letters connect together."@en ;
  dcterms:modified "2026-06-07T15:30:29.347325Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4772-3
  a curric:KeyLearningPoint ;
  rdfs:label "The pencil does not lift when forming the join."@en ;
  dcterms:modified "2026-06-07T15:30:29.347329Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4772-4
  a curric:KeyLearningPoint ;
  rdfs:label "The first join goes from the baseline to the x-height line."@en ;
  dcterms:modified "2026-06-07T15:30:29.347333Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4772-5
  a curric:KeyLearningPoint ;
  rdfs:label "The cross for the letter t gets added once the letter string is complete."@en ;
  dcterms:modified "2026-06-07T15:30:29.347337Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-934-1
  a curric:KeyLearningPoint ;
  rdfs:label "'o' and 'oe' are rarer representations of the 'oa' phoneme."@en ;
  dcterms:modified "2026-06-07T15:30:29.349598Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-934-2
  a curric:KeyLearningPoint ;
  rdfs:label """‘oe’ is a representation of the 'oa' phoneme most commonly found at the end of a
  word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.349602Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-934-3
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the common exception words: your and here."@en ;
  dcterms:modified "2026-06-07T15:30:29.349606Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-934-4
  a curric:KeyLearningPoint ;
  rdfs:label "'Your' and 'you're' are homophones."@en ;
  dcterms:modified "2026-06-07T15:30:29.349610Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-934-5
  a curric:KeyLearningPoint ;
  rdfs:label "'Here' and 'hear' are homophones."@en ;
  dcterms:modified "2026-06-07T15:30:29.349614Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8690-1
  a curric:KeyLearningPoint ;
  rdfs:label "A sentence is one idea that makes complete sense"@en ;
  dcterms:modified "2026-06-07T15:30:29.349618Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8690-2
  a curric:KeyLearningPoint ;
  rdfs:label "A space must be left in between each word so someone can read our writing"@en ;
  dcterms:modified "2026-06-07T15:30:29.349624Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8690-3
  a curric:KeyLearningPoint ;
  rdfs:label "Sounding out a word before writing helps to spell a word"@en ;
  dcterms:modified "2026-06-07T15:30:29.349628Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8690-4
  a curric:KeyLearningPoint ;
  rdfs:label "Rehearsing a sentence out loud before writing it helps us to remember it"@en ;
  dcterms:modified "2026-06-07T15:30:29.349632Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8690-5
  a curric:KeyLearningPoint ;
  rdfs:label "A sentence starts with a capital letter and mostly ends with a full stop"@en ;
  dcterms:modified "2026-06-07T15:30:29.349637Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-916-1
  a curric:KeyLearningPoint ;
  rdfs:label "'But' is a type of joining word."@en ;
  dcterms:modified "2026-06-07T15:30:29.349641Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-916-2
  a curric:KeyLearningPoint ;
  rdfs:label "Joining two simple sentences with 'but' forms a compound sentence."@en ;
  dcterms:modified "2026-06-07T15:30:29.349645Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-916-3
  a curric:KeyLearningPoint ;
  rdfs:label "The two ideas in a compound sentence joined with 'but' oppose each other."@en ;
  dcterms:modified "2026-06-07T15:30:29.349649Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-916-4
  a curric:KeyLearningPoint ;
  rdfs:label "The 'but' joining word has a different meaning to the 'and' joining word."@en ;
  dcterms:modified "2026-06-07T15:30:29.349653Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-916-5
  a curric:KeyLearningPoint ;
  rdfs:label "Each of the two ideas holds equal grammatical weight in the sentence."@en ;
  dcterms:modified "2026-06-07T15:30:29.349657Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6284-1
  a curric:KeyLearningPoint ;
  rdfs:label "A diary is an informal piece of writing."@en ;
  dcterms:modified "2026-06-07T15:30:29.349661Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6284-2
  a curric:KeyLearningPoint ;
  rdfs:label "One of the features of informal writing is contracted words."@en ;
  dcterms:modified "2026-06-07T15:30:29.349665Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6284-3
  a curric:KeyLearningPoint ;
  rdfs:label """When writing informally, we use apostrophes for contraction to show two words
  connected together."""@en ;
  dcterms:modified "2026-06-07T15:30:29.349671Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8921-1
  a curric:KeyLearningPoint ;
  rdfs:label "A theme is a big idea and focus of a book."@en ;
  dcterms:modified "2026-06-07T15:30:29.349713Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8921-2
  a curric:KeyLearningPoint ;
  rdfs:label """A theme in 'Paddington' and 'Coming to England' is identity as both books explore
  characters moving from their home."""@en ;
  dcterms:modified "2026-06-07T15:30:29.349717Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8921-3
  a curric:KeyLearningPoint ;
  rdfs:label "Identity means who or what a person or thing is."@en ;
  dcterms:modified "2026-06-07T15:30:29.349721Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8921-4
  a curric:KeyLearningPoint ;
  rdfs:label """Someone's identity may include their background, personality traits and
  interests."""@en ;
  dcterms:modified "2026-06-07T15:30:29.349727Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8921-5
  a curric:KeyLearningPoint ;
  rdfs:label """How someone perceives their own identity is personal to them and may be different to
  how others perceive them."""@en ;
  dcterms:modified "2026-06-07T15:30:29.349732Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27907-1
  a curric:KeyLearningPoint ;
  rdfs:label "Things you like or dislike are called your 'opinions'."@en ;
  dcterms:modified "2026-06-07T15:30:29.349780Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27907-2
  a curric:KeyLearningPoint ;
  rdfs:label """Using the word 'because' will allow you to explain why you like or dislike
  something."""@en ;
  dcterms:modified "2026-06-07T15:30:29.349819Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27907-3
  a curric:KeyLearningPoint ;
  rdfs:label "Speaking in full sentences helps the listener understand what is being said."@en ;
  dcterms:modified "2026-06-07T15:30:29.349824Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27907-4
  a curric:KeyLearningPoint ;
  rdfs:label """When talking with someone, it is important to take turns and listen to what the
  other person is saying."""@en ;
  dcterms:modified "2026-06-07T15:30:29.349828Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5652-1
  a curric:KeyLearningPoint ;
  rdfs:label "A subheading is a mini-heading given to a specific section of a report."@en ;
  dcterms:modified "2026-06-07T15:30:29.349883Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5652-2
  a curric:KeyLearningPoint ;
  rdfs:label "Fronted adverbials are sentence starters followed by a comma."@en ;
  dcterms:modified "2026-06-07T15:30:29.349889Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5652-3
  a curric:KeyLearningPoint ;
  rdfs:label "The Great Fire of London started on Sunday 2nd September 1666."@en ;
  dcterms:modified "2026-06-07T15:30:29.349894Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5652-4
  a curric:KeyLearningPoint ;
  rdfs:label "The fire started in a bakery on Pudding Lane owned by Thomas Farriner."@en ;
  dcterms:modified "2026-06-07T15:30:29.349900Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5652-5
  a curric:KeyLearningPoint ;
  rdfs:label "The fire started from a spark in Thomas Farriner's oven."@en ;
  dcterms:modified "2026-06-07T15:30:29.349904Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-923-1
  a curric:KeyLearningPoint ;
  rdfs:label "'a', 'eigh' and 'ey' are alternative spellings for the 'ay' phoneme."@en ;
  dcterms:modified "2026-06-07T15:30:29.351359Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-923-2
  a curric:KeyLearningPoint ;
  rdfs:label "Words in word families often have similar spellings."@en ;
  dcterms:modified "2026-06-07T15:30:29.351363Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-923-3
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the common exception words: great, break and steak."@en ;
  dcterms:modified "2026-06-07T15:30:29.351367Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-914-1
  a curric:KeyLearningPoint ;
  rdfs:label "An exclamation is the fourth type of simple sentence."@en ;
  dcterms:modified "2026-06-07T15:30:29.351371Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-914-2
  a curric:KeyLearningPoint ;
  rdfs:label "An exclamation contains a verb."@en ;
  dcterms:modified "2026-06-07T15:30:29.351375Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-914-3
  a curric:KeyLearningPoint ;
  rdfs:label "An exclamation expresses strong emotion or surprise."@en ;
  dcterms:modified "2026-06-07T15:30:29.351379Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-914-4
  a curric:KeyLearningPoint ;
  rdfs:label "An exclamation ends with an exclamation mark."@en ;
  dcterms:modified "2026-06-07T15:30:29.351383Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-914-5
  a curric:KeyLearningPoint ;
  rdfs:label "An exclamation starts with 'What' or 'How'."@en ;
  dcterms:modified "2026-06-07T15:30:29.351387Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8484-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Don't Cross the Line!' is a book that is mostly told through illustrations."@en ;
  dcterms:modified "2026-06-07T15:30:29.351391Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8484-2
  a curric:KeyLearningPoint ;
  rdfs:label "Layout refers to how the content is presented on the page."@en ;
  dcterms:modified "2026-06-07T15:30:29.351395Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8484-3
  a curric:KeyLearningPoint ;
  rdfs:label "The layout of 'Don't Cross the Line!' is a crucial part of telling the story."@en ;
  dcterms:modified "2026-06-07T15:30:29.351399Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8484-4
  a curric:KeyLearningPoint ;
  rdfs:label """Stories that have few words are open to interpretation and designed to generate an
  opinion."""@en ;
  dcterms:modified "2026-06-07T15:30:29.351403Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8484-5
  a curric:KeyLearningPoint ;
  rdfs:label """You can justify an interpretation or opinion by offering a clear reason or
  explanation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.351407Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6201-1
  a curric:KeyLearningPoint ;
  rdfs:label "Planning is an important part of preparing to write."@en ;
  dcterms:modified "2026-06-07T15:30:29.351413Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6201-2
  a curric:KeyLearningPoint ;
  rdfs:label """A plan helps a writer to organise their ideas, thoughts and the information they
  want to include in their writing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.351417Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6201-3
  a curric:KeyLearningPoint ;
  rdfs:label """Notes can be used in a plan to help organise key information and are not written in
  full sentences."""@en ;
  dcterms:modified "2026-06-07T15:30:29.351421Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6201-4
  a curric:KeyLearningPoint ;
  rdfs:label """Hedgehogs are nocturnal animals, which means they sleep during the day and are awake
  at night."""@en ;
  dcterms:modified "2026-06-07T15:30:29.351425Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6201-5
  a curric:KeyLearningPoint ;
  rdfs:label """Hedgehogs have thousands of spines that they use to protect themselves from
  predators."""@en ;
  dcterms:modified "2026-06-07T15:30:29.351429Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6202-1
  a curric:KeyLearningPoint ;
  rdfs:label """Compound sentences are sentences formed of two simple sentences and a
  joining word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.351433Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6202-2
  a curric:KeyLearningPoint ;
  rdfs:label "Co-ordination means joining two simple sentences with 'and', 'but' or 'or'."@en ;
  dcterms:modified "2026-06-07T15:30:29.351437Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6202-3
  a curric:KeyLearningPoint ;
  rdfs:label "A joining word is a word that joins words or ideas."@en ;
  dcterms:modified "2026-06-07T15:30:29.351441Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6202-4
  a curric:KeyLearningPoint ;
  rdfs:label "The second section of the report will be all about hedgehogs."@en ;
  dcterms:modified "2026-06-07T15:30:29.351445Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6829-1
  a curric:KeyLearningPoint ;
  rdfs:label "Rehearsing a sentence out loud before writing it helps us to remember it"@en ;
  dcterms:modified "2026-06-07T15:30:29.351451Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6829-2
  a curric:KeyLearningPoint ;
  rdfs:label "Reading a sentence back after writing helps to check it makes sense"@en ;
  dcterms:modified "2026-06-07T15:30:29.351455Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6829-3
  a curric:KeyLearningPoint ;
  rdfs:label "Every sentence must start with a capital letter and end with a full stop"@en ;
  dcterms:modified "2026-06-07T15:30:29.351459Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6829-4
  a curric:KeyLearningPoint ;
  rdfs:label "Traditional tales tend to end with a happy ending"@en ;
  dcterms:modified "2026-06-07T15:30:29.351463Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6829-5
  a curric:KeyLearningPoint ;
  rdfs:label "Word banks help to find keywords to include in writing"@en ;
  dcterms:modified "2026-06-07T15:30:29.351467Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6838-1
  a curric:KeyLearningPoint ;
  rdfs:label """Information about a character and setting can be found in the text and in
  illustrations."""@en ;
  dcterms:modified "2026-06-07T15:30:29.352492Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6838-2
  a curric:KeyLearningPoint ;
  rdfs:label """A front cover shares the title, 'Wild', the author, Emily Hughes and
  illustrations."""@en ;
  dcterms:modified "2026-06-07T15:30:29.352496Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6838-3
  a curric:KeyLearningPoint ;
  rdfs:label """Knowing some key information about the book, such as the setting being a forest,
  helps to make a prediction."""@en ;
  dcterms:modified "2026-06-07T15:30:29.352500Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6838-4
  a curric:KeyLearningPoint ;
  rdfs:label "A setting means where a story takes place."@en ;
  dcterms:modified "2026-06-07T15:30:29.352504Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6838-5
  a curric:KeyLearningPoint ;
  rdfs:label "The plot is what the story is about."@en ;
  dcterms:modified "2026-06-07T15:30:29.352508Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8686-1
  a curric:KeyLearningPoint ;
  rdfs:label "Most stories start by introducing the main characters and setting"@en ;
  dcterms:modified "2026-06-07T15:30:29.352947Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8686-2
  a curric:KeyLearningPoint ;
  rdfs:label "The plot means what happens in a story"@en ;
  dcterms:modified "2026-06-07T15:30:29.352951Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8686-3
  a curric:KeyLearningPoint ;
  rdfs:label "Illustrations are important to help to tell a story"@en ;
  dcterms:modified "2026-06-07T15:30:29.352958Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8686-4
  a curric:KeyLearningPoint ;
  rdfs:label "Most stories explore a theme, which is a big idea"@en ;
  dcterms:modified "2026-06-07T15:30:29.352995Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8686-5
  a curric:KeyLearningPoint ;
  rdfs:label "Community, care and aspiration are themes that are explored in this story"@en ;
  dcterms:modified "2026-06-07T15:30:29.353000Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6182-1
  a curric:KeyLearningPoint ;
  rdfs:label "Florence Nightingale was a nurse during the Crimean War."@en ;
  dcterms:modified "2026-06-07T15:30:29.353036Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6182-2
  a curric:KeyLearningPoint ;
  rdfs:label "Florence Nightingale helped to train nurses and make hospitals cleaner."@en ;
  dcterms:modified "2026-06-07T15:30:29.353040Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6182-3
  a curric:KeyLearningPoint ;
  rdfs:label "Mary Seacole was born in Jamaica and was a doctress."@en ;
  dcterms:modified "2026-06-07T15:30:29.353044Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6182-4
  a curric:KeyLearningPoint ;
  rdfs:label """Mary Seacole went to the Crimean War and set up a hospital called the ‘British
  Hotel’ to look after wounded soldiers."""@en ;
  dcterms:modified "2026-06-07T15:30:29.353048Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6199-1
  a curric:KeyLearningPoint ;
  rdfs:label "Planning is an important part of preparing to write."@en ;
  dcterms:modified "2026-06-07T15:30:29.353052Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6199-2
  a curric:KeyLearningPoint ;
  rdfs:label """A plan helps a writer to organise their ideas, thoughts and the information they
  want to include in their writing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.353059Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6199-3
  a curric:KeyLearningPoint ;
  rdfs:label """Notes can be used in a plan to help organise key information and are not written in
  full sentences."""@en ;
  dcterms:modified "2026-06-07T15:30:29.353063Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6199-4
  a curric:KeyLearningPoint ;
  rdfs:label """Bats are nocturnal animals, which means they sleep during the day and are awake at
  night."""@en ;
  dcterms:modified "2026-06-07T15:30:29.353069Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6199-5
  a curric:KeyLearningPoint ;
  rdfs:label """Bats have very poor eyesight but use echolocation to help them navigate their way
  around."""@en ;
  dcterms:modified "2026-06-07T15:30:29.353076Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6198-1
  a curric:KeyLearningPoint ;
  rdfs:label """An introduction of a non-chronological report should entice the reader to read the
  main report."""@en ;
  dcterms:modified "2026-06-07T15:30:29.353319Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6198-2
  a curric:KeyLearningPoint ;
  rdfs:label "An introduction should make the report itself seem interesting and informative."@en ;
  dcterms:modified "2026-06-07T15:30:29.353323Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6198-3
  a curric:KeyLearningPoint ;
  rdfs:label """A question is a type of simple sentence that asks the reader for an answer and ends
  with a question mark."""@en ;
  dcterms:modified "2026-06-07T15:30:29.353327Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6198-4
  a curric:KeyLearningPoint ;
  rdfs:label "A question mark is a punctuation mark used at the end of a question."@en ;
  dcterms:modified "2026-06-07T15:30:29.353331Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6198-5
  a curric:KeyLearningPoint ;
  rdfs:label """A command is a type of simple sentence that tells someone to do something and can
  end with an exclamation mark"""@en ;
  dcterms:modified "2026-06-07T15:30:29.353335Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27622-1
  a curric:KeyLearningPoint ;
  rdfs:label "People can agree or disagree with an opinion."@en ;
  dcterms:modified "2026-06-07T15:30:29.353381Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27622-2
  a curric:KeyLearningPoint ;
  rdfs:label "Using the word 'because' allows us to explain our opinions."@en ;
  dcterms:modified "2026-06-07T15:30:29.353385Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27622-3
  a curric:KeyLearningPoint ;
  rdfs:label """Successful listening includes looking at the person speaking and paying close
  attention."""@en ;
  dcterms:modified "2026-06-07T15:30:29.353412Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27622-4
  a curric:KeyLearningPoint ;
  rdfs:label """Speaking in full sentences and in a loud, clear voice helps the listener understand
  what is being said."""@en ;
  dcterms:modified "2026-06-07T15:30:29.353416Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8892-1
  a curric:KeyLearningPoint ;
  rdfs:label """Plop is a young barn owl who is initially scared of the dark but gradually learns to
  appreciate the night time."""@en ;
  dcterms:modified "2026-06-07T15:30:29.353440Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8892-2
  a curric:KeyLearningPoint ;
  rdfs:label """Plop meets lots of characters who all help him in overcoming his fear of the
  dark."""@en ;
  dcterms:modified "2026-06-07T15:30:29.353445Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8892-3
  a curric:KeyLearningPoint ;
  rdfs:label """A personal response is what you think and how you feel about the story, including
  whether you liked it or not."""@en ;
  dcterms:modified "2026-06-07T15:30:29.353449Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8892-4
  a curric:KeyLearningPoint ;
  rdfs:label """The theme in a story is the big idea or lesson that the author wants you to explore
  and understand through reading."""@en ;
  dcterms:modified "2026-06-07T15:30:29.353453Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8892-5
  a curric:KeyLearningPoint ;
  rdfs:label "Key themes in ‘The Owl who was Afraid of the Dark’ are curiosity and courage."@en ;
  dcterms:modified "2026-06-07T15:30:29.353486Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8483-1
  a curric:KeyLearningPoint ;
  rdfs:label """A theme is a big idea or lesson that the author wants you to explore and understand
  through reading the story."""@en ;
  dcterms:modified "2026-06-07T15:30:29.353668Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8483-2
  a curric:KeyLearningPoint ;
  rdfs:label """Readers can interpret themes and their importance within a story in
  different ways."""@en ;
  dcterms:modified "2026-06-07T15:30:29.353672Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8483-3
  a curric:KeyLearningPoint ;
  rdfs:label """‘The Planet in a Pickle Jar’ explores the theme of protection relating to
  environment, family and belongings."""@en ;
  dcterms:modified "2026-06-07T15:30:29.353676Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8483-4
  a curric:KeyLearningPoint ;
  rdfs:label """The importance of protecting the world’s natural wonders and the environment is a
  key lesson communicated in the story."""@en ;
  dcterms:modified "2026-06-07T15:30:29.353680Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8483-5
  a curric:KeyLearningPoint ;
  rdfs:label """There are many natural elements in our world that need protecting and a variety of
  ways to help with this."""@en ;
  dcterms:modified "2026-06-07T15:30:29.353688Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8691-1
  a curric:KeyLearningPoint ;
  rdfs:label "An adjective describes a noun, including ourselves, such as \"I am helpful.\""@en ;
  dcterms:modified "2026-06-07T15:30:29.355703Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8691-2
  a curric:KeyLearningPoint ;
  rdfs:label "Adjectives are describing words"@en ;
  dcterms:modified "2026-06-07T15:30:29.355707Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8691-3
  a curric:KeyLearningPoint ;
  rdfs:label "A person's character traits make that person who they are"@en ;
  dcterms:modified "2026-06-07T15:30:29.355711Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8691-4
  a curric:KeyLearningPoint ;
  rdfs:label "Someone's personality or character traits may be different to others'"@en ;
  dcterms:modified "2026-06-07T15:30:29.355715Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8691-5
  a curric:KeyLearningPoint ;
  rdfs:label """Certain character traits are better suited to some jobs, such as bravery for a
  firefighter"""@en ;
  dcterms:modified "2026-06-07T15:30:29.355719Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8485-1
  a curric:KeyLearningPoint ;
  rdfs:label "A theme is a big idea, topic or message that appears in a story."@en ;
  dcterms:modified "2026-06-07T15:30:29.355723Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8485-2
  a curric:KeyLearningPoint ;
  rdfs:label "Themes in a story are used to convey deeper meaning and messages to the reader."@en ;
  dcterms:modified "2026-06-07T15:30:29.355727Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8485-3
  a curric:KeyLearningPoint ;
  rdfs:label "Readers can interpret themes and their importance in a story in different ways."@en ;
  dcterms:modified "2026-06-07T15:30:29.355733Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8485-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Don't Cross the Line!' explores the themes of authority, rule-breaking, identity
  and collaboration."""@en ;
  dcterms:modified "2026-06-07T15:30:29.355737Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8485-5
  a curric:KeyLearningPoint ;
  rdfs:label """Stories can create a personal response linked to the reader's own views or personal
  experiences."""@en ;
  dcterms:modified "2026-06-07T15:30:29.355743Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4756-1
  a curric:KeyLearningPoint ;
  rdfs:label "The letters i and u are x-height letters"@en ;
  dcterms:modified "2026-06-07T15:30:29.355759Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4756-2
  a curric:KeyLearningPoint ;
  rdfs:label "The letters l and t have an ascender"@en ;
  dcterms:modified "2026-06-07T15:30:29.355763Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4756-3
  a curric:KeyLearningPoint ;
  rdfs:label "The letters y and j have a desecender"@en ;
  dcterms:modified "2026-06-07T15:30:29.355767Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4756-4
  a curric:KeyLearningPoint ;
  rdfs:label "The letters i, l, t and u finish with a flick on the baseline"@en ;
  dcterms:modified "2026-06-07T15:30:29.355771Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4756-5
  a curric:KeyLearningPoint ;
  rdfs:label "The letters y and j finish with a curl up on the descender line"@en ;
  dcterms:modified "2026-06-07T15:30:29.355775Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-961-1
  a curric:KeyLearningPoint ;
  rdfs:label "tion' is the most common spelling of /shun/."@en ;
  dcterms:modified "2026-06-07T15:30:29.355834Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-961-2
  a curric:KeyLearningPoint ;
  rdfs:label """Words ending in 'tion' are often nouns, like 'action', 'collection', 'question' and
  'section'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.355838Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-961-3
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the common exception words: every and everybody."@en ;
  dcterms:modified "2026-06-07T15:30:29.355841Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4764-1
  a curric:KeyLearningPoint ;
  rdfs:label "The letters all have a lead in and a lead out."@en ;
  dcterms:modified "2026-06-07T15:30:29.355867Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4764-2
  a curric:KeyLearningPoint ;
  rdfs:label "The pencil does not lift when forming the join."@en ;
  dcterms:modified "2026-06-07T15:30:29.355871Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4764-3
  a curric:KeyLearningPoint ;
  rdfs:label """The third join starts at the x-height line and dips below the x-height line and back
  up to join the next letter."""@en ;
  dcterms:modified "2026-06-07T15:30:29.355875Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4764-4
  a curric:KeyLearningPoint ;
  rdfs:label """When using the third join you leave enough space to ensure the letters are not
  touching without leaving a big gap."""@en ;
  dcterms:modified "2026-06-07T15:30:29.355879Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4764-5
  a curric:KeyLearningPoint ;
  rdfs:label "All of the letters are x-height letters."@en ;
  dcterms:modified "2026-06-07T15:30:29.355883Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5480-1
  a curric:KeyLearningPoint ;
  rdfs:label "Every sentence must start with a capital letter and end with a full stop"@en ;
  dcterms:modified "2026-06-07T15:30:29.355887Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5480-2
  a curric:KeyLearningPoint ;
  rdfs:label "The beginning of a story introduces the main characters, setting and plot"@en ;
  dcterms:modified "2026-06-07T15:30:29.355893Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5480-3
  a curric:KeyLearningPoint ;
  rdfs:label """Word banks can be used to find key vocabulary or words that may be difficult to
  spell, such as 'cottage' or 'magical'"""@en ;
  dcterms:modified "2026-06-07T15:30:29.355897Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5480-4
  a curric:KeyLearningPoint ;
  rdfs:label "Rehearsing a sentence out loud before writing it helps us to remember it"@en ;
  dcterms:modified "2026-06-07T15:30:29.355901Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5480-5
  a curric:KeyLearningPoint ;
  rdfs:label "Reading a sentence back after writing helps to check it makes sense"@en ;
  dcterms:modified "2026-06-07T15:30:29.355905Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6852-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘The Planet in a Pickle Jar’ is told through narrative writing and illustrations and
  it includes magical elements."""@en ;
  dcterms:modified "2026-06-07T15:30:29.356127Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6852-2
  a curric:KeyLearningPoint ;
  rdfs:label """The grandchildren are characters and the narrators of the story which means it is
  told from their perspective."""@en ;
  dcterms:modified "2026-06-07T15:30:29.356131Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6852-3
  a curric:KeyLearningPoint ;
  rdfs:label """At the beginning, the illustrations show a different story to the one being told by
  the narrators."""@en ;
  dcterms:modified "2026-06-07T15:30:29.356139Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6852-4
  a curric:KeyLearningPoint ;
  rdfs:label "The story contains multiple settings and it moves quickly between them."@en ;
  dcterms:modified "2026-06-07T15:30:29.356143Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6852-5
  a curric:KeyLearningPoint ;
  rdfs:label """The plot follows the grandchildren as they uncover their grandma’s desire to protect
  the world’s wonders."""@en ;
  dcterms:modified "2026-06-07T15:30:29.356147Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8131-1
  a curric:KeyLearningPoint ;
  rdfs:label """The colour blue is referred to repeatedly throughout the story and is part of what
  makes Asiya's hijab special to her."""@en ;
  dcterms:modified "2026-06-07T15:30:29.356190Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8131-2
  a curric:KeyLearningPoint ;
  rdfs:label """The author states what the hijab isn't as a way of communicating its special
  nature."""@en ;
  dcterms:modified "2026-06-07T15:30:29.356194Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8131-3
  a curric:KeyLearningPoint ;
  rdfs:label "Colours can be used to represent ideas, objects and feelings."@en ;
  dcterms:modified "2026-06-07T15:30:29.356200Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8131-4
  a curric:KeyLearningPoint ;
  rdfs:label "Precise adjectives can enhance the description of colours and nouns."@en ;
  dcterms:modified "2026-06-07T15:30:29.356204Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8131-5
  a curric:KeyLearningPoint ;
  rdfs:label "Similes can be used to compare two things using 'like' or 'as'."@en ;
  dcterms:modified "2026-06-07T15:30:29.356208Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6204-1
  a curric:KeyLearningPoint ;
  rdfs:label """Information texts are a form of non-fiction writing that provide information about
  someone or something."""@en ;
  dcterms:modified "2026-06-07T15:30:29.360184Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6204-2
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of an information text is to provide true and factual information to
  inform the reader on a topic."""@en ;
  dcterms:modified "2026-06-07T15:30:29.360188Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6204-3
  a curric:KeyLearningPoint ;
  rdfs:label """Information texts are written in the third person, using some second person to
  engage the reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.360192Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6204-4
  a curric:KeyLearningPoint ;
  rdfs:label """Headings and subheadings are key features that organise an information text into
  sections for the reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.360196Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6204-5
  a curric:KeyLearningPoint ;
  rdfs:label """An information text about an author provides information about their life, e.g.
  childhood, inspiration, jobs and books."""@en ;
  dcterms:modified "2026-06-07T15:30:29.360200Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6851-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Leaf' is a fiction text where all of the characters are animals with voices."@en ;
  dcterms:modified "2026-06-07T15:30:29.360204Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6851-2
  a curric:KeyLearningPoint ;
  rdfs:label """Making predictions means deciding what you think will happen in a story using
  illustration and the text as evidence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.360208Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6851-3
  a curric:KeyLearningPoint ;
  rdfs:label "Fiction books can be based on a real life issue or event, e.g. climate change."@en ;
  dcterms:modified "2026-06-07T15:30:29.360214Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6851-4
  a curric:KeyLearningPoint ;
  rdfs:label """Developing deeper understanding of 'Leaf' can allow us to learn important lessons
  from the story."""@en ;
  dcterms:modified "2026-06-07T15:30:29.360218Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6851-5
  a curric:KeyLearningPoint ;
  rdfs:label """One person's prediction or the lesson they interpret may be different to another
  person's."""@en ;
  dcterms:modified "2026-06-07T15:30:29.360222Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27604-1
  a curric:KeyLearningPoint ;
  rdfs:label "Instructions are sentences that tell us how to do something."@en ;
  dcterms:modified "2026-06-07T15:30:29.360281Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27604-2
  a curric:KeyLearningPoint ;
  rdfs:label """Successful speaking includes speaking loudly and clearly enough for everyone to
  hear."""@en ;
  dcterms:modified "2026-06-07T15:30:29.360287Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27604-3
  a curric:KeyLearningPoint ;
  rdfs:label """Successful listening includes looking at the person speaking and paying close
  attention."""@en ;
  dcterms:modified "2026-06-07T15:30:29.360291Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4762-1
  a curric:KeyLearningPoint ;
  rdfs:label "The letters all have a lead in and a lead out."@en ;
  dcterms:modified "2026-06-07T15:30:29.360294Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4762-2
  a curric:KeyLearningPoint ;
  rdfs:label "Cursive letter joins refer to how the letters connect together."@en ;
  dcterms:modified "2026-06-07T15:30:29.360298Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4762-3
  a curric:KeyLearningPoint ;
  rdfs:label "The pencil does not lift when forming the join."@en ;
  dcterms:modified "2026-06-07T15:30:29.360302Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4762-4
  a curric:KeyLearningPoint ;
  rdfs:label "The second join goes from the baseline to the ascender line."@en ;
  dcterms:modified "2026-06-07T15:30:29.360306Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-980-1
  a curric:KeyLearningPoint ;
  rdfs:label """An adverbial complex sentence is formed of one main idea joined with
  subordination."""@en ;
  dcterms:modified "2026-06-07T15:30:29.362644Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-980-2
  a curric:KeyLearningPoint ;
  rdfs:label "Subordination joining words are 'because', 'so', 'when', 'if' and 'that'."@en ;
  dcterms:modified "2026-06-07T15:30:29.362648Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-980-3
  a curric:KeyLearningPoint ;
  rdfs:label "An adverbial complex sentence can be written in the past or present tense."@en ;
  dcterms:modified "2026-06-07T15:30:29.362652Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-979-1
  a curric:KeyLearningPoint ;
  rdfs:label "'So' and 'that' are types of joining word."@en ;
  dcterms:modified "2026-06-07T15:30:29.362668Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-979-2
  a curric:KeyLearningPoint ;
  rdfs:label "A simple sentence can be stretched with 'so' to give a result to the first idea."@en ;
  dcterms:modified "2026-06-07T15:30:29.362672Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-979-3
  a curric:KeyLearningPoint ;
  rdfs:label """A simple sentence can be stretched with 'that' to give more detail about the first
  idea."""@en ;
  dcterms:modified "2026-06-07T15:30:29.362678Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-979-4
  a curric:KeyLearningPoint ;
  rdfs:label """Joining the first idea with 'so' or 'that' forms a second idea that is subordinate
  to the first."""@en ;
  dcterms:modified "2026-06-07T15:30:29.362683Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-979-5
  a curric:KeyLearningPoint ;
  rdfs:label """Using 'so' or 'that' to stretch a simple sentence forms an adverbial complex
  sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.362687Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28998-1
  a curric:KeyLearningPoint ;
  rdfs:label "Instructions must be followed in the correct order."@en ;
  dcterms:modified "2026-06-07T15:30:29.362691Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28998-2
  a curric:KeyLearningPoint ;
  rdfs:label """Using numbers and sequencing language helps us to follow instructions in the correct
  order."""@en ;
  dcterms:modified "2026-06-07T15:30:29.362695Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28998-3
  a curric:KeyLearningPoint ;
  rdfs:label """The verb in the instruction tells us what to do, such as ‘slice’, ‘cut’ or
  ‘put’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.362699Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28998-4
  a curric:KeyLearningPoint ;
  rdfs:label """Including adjectives in instructions can help us picture what we are going to be
  doing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.362703Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5329-1
  a curric:KeyLearningPoint ;
  rdfs:label """Writing about what happened on a trip can come at the middle and end of a
  recount"""@en ;
  dcterms:modified "2026-06-07T15:30:29.362707Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5329-2
  a curric:KeyLearningPoint ;
  rdfs:label "Using time adverbials helps the reader to understand the sequence of events"@en ;
  dcterms:modified "2026-06-07T15:30:29.362711Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5329-3
  a curric:KeyLearningPoint ;
  rdfs:label "Expressing an opinion about the event can come at the end of the recount"@en ;
  dcterms:modified "2026-06-07T15:30:29.362717Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5329-4
  a curric:KeyLearningPoint ;
  rdfs:label """Adding a 'Did you know...?' question at the end of a recount shows the reader what
  you learnt on the trip"""@en ;
  dcterms:modified "2026-06-07T15:30:29.362721Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-908-1
  a curric:KeyLearningPoint ;
  rdfs:label "A simple sentence can be written in the past or present tense."@en ;
  dcterms:modified "2026-06-07T15:30:29.362741Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-908-2
  a curric:KeyLearningPoint ;
  rdfs:label "The tense of a simple sentence changes the time frame of the action."@en ;
  dcterms:modified "2026-06-07T15:30:29.362745Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27905-1
  a curric:KeyLearningPoint ;
  rdfs:label """Successful speaking includes speaking loudly and clearly enough for everyone to
  hear."""@en ;
  dcterms:modified "2026-06-07T15:30:29.362751Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27905-2
  a curric:KeyLearningPoint ;
  rdfs:label """Successful listening includes looking at the person speaking and paying close
  attention."""@en ;
  dcterms:modified "2026-06-07T15:30:29.362755Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27905-3
  a curric:KeyLearningPoint ;
  rdfs:label "Speaking in full sentences helps the listener understand what is being said."@en ;
  dcterms:modified "2026-06-07T15:30:29.362759Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27905-4
  a curric:KeyLearningPoint ;
  rdfs:label "Standing to speak helps to get the audience’s attention."@en ;
  dcterms:modified "2026-06-07T15:30:29.362763Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5196-1
  a curric:KeyLearningPoint ;
  rdfs:label "Traditional tales try to teach us a lesson about something."@en ;
  dcterms:modified "2026-06-07T15:30:29.362767Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5196-2
  a curric:KeyLearningPoint ;
  rdfs:label "Thinking about those lessons can help us change something in our lives."@en ;
  dcterms:modified "2026-06-07T15:30:29.362773Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5196-3
  a curric:KeyLearningPoint ;
  rdfs:label "The Children of Lir teaches us to be resilient in the face of challenges."@en ;
  dcterms:modified "2026-06-07T15:30:29.362779Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5196-4
  a curric:KeyLearningPoint ;
  rdfs:label """Sequencing events in a story means we put them in the order in which they
  happened."""@en ;
  dcterms:modified "2026-06-07T15:30:29.362784Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5196-5
  a curric:KeyLearningPoint ;
  rdfs:label "Sequencing key parts of the story helps to summarise the whole story."@en ;
  dcterms:modified "2026-06-07T15:30:29.362788Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7196-1
  a curric:KeyLearningPoint ;
  rdfs:label """Performing poetry to an audience is an important part of the process of creating
  poetry."""@en ;
  dcterms:modified "2026-06-07T15:30:29.362792Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7196-2
  a curric:KeyLearningPoint ;
  rdfs:label "When performing poetry, you must speak at a suitable volume."@en ;
  dcterms:modified "2026-06-07T15:30:29.362797Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7196-3
  a curric:KeyLearningPoint ;
  rdfs:label """Using gestures and expression will make your performance fun and engaging for the
  audience."""@en ;
  dcterms:modified "2026-06-07T15:30:29.362802Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7196-4
  a curric:KeyLearningPoint ;
  rdfs:label "We can improve our performances of poetry through practice."@en ;
  dcterms:modified "2026-06-07T15:30:29.362805Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5479-1
  a curric:KeyLearningPoint ;
  rdfs:label """An adjective describes a noun. Adjectives are often put in front of the noun in a
  sentence, such as 'green forest'"""@en ;
  dcterms:modified "2026-06-07T15:30:29.362896Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5479-2
  a curric:KeyLearningPoint ;
  rdfs:label "Using descriptions with adjectives makes writing more interesting"@en ;
  dcterms:modified "2026-06-07T15:30:29.362900Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5479-3
  a curric:KeyLearningPoint ;
  rdfs:label "Verbs are doing or being words"@en ;
  dcterms:modified "2026-06-07T15:30:29.362903Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5479-4
  a curric:KeyLearningPoint ;
  rdfs:label """Verbs are chosen carefully to help us imagine how someone has done something, such
  as “whizzed”"""@en ;
  dcterms:modified "2026-06-07T15:30:29.362907Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5479-5
  a curric:KeyLearningPoint ;
  rdfs:label """Adjectives can describe the appearance of someone or something as well as the
  personality of someone"""@en ;
  dcterms:modified "2026-06-07T15:30:29.362911Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-933-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘ow’ is a representation of the 'oa' phoneme that often comes at the end of
  a word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.364912Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-933-2
  a curric:KeyLearningPoint ;
  rdfs:label """‘o-e’ is a representation of the 'oa' phoneme that is often found 'last but
  one'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.364915Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-933-3
  a curric:KeyLearningPoint ;
  rdfs:label """‘oa’ is a representation of the 'oa' phoneme that is often found in the middle of a
  word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.364919Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-933-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the common exception word: want."@en ;
  dcterms:modified "2026-06-07T15:30:29.364925Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5434-1
  a curric:KeyLearningPoint ;
  rdfs:label """Nouns can be written in a list using commas and 'and' used before the final noun,
  such as 'the coins, a hen and a harp.'"""@en ;
  dcterms:modified "2026-06-07T15:30:29.364930Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5434-2
  a curric:KeyLearningPoint ;
  rdfs:label """Some adverbs describing how characters move can be used at the start of a sentence,
  such as 'Quickly,'"""@en ;
  dcterms:modified "2026-06-07T15:30:29.364934Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5434-3
  a curric:KeyLearningPoint ;
  rdfs:label """Exclamation marks can be used to show strong emotion, such as shock at finding an
  enormous beanstalk."""@en ;
  dcterms:modified "2026-06-07T15:30:29.364937Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5434-4
  a curric:KeyLearningPoint ;
  rdfs:label "Powerful verbs can be used to describe what characters do, such as 'crept'"@en ;
  dcterms:modified "2026-06-07T15:30:29.364941Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5434-5
  a curric:KeyLearningPoint ;
  rdfs:label "Two ideas can be joined using a joining word, 'and'"@en ;
  dcterms:modified "2026-06-07T15:30:29.364945Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8924-1
  a curric:KeyLearningPoint ;
  rdfs:label "A character's emotions can change at different points of the story."@en ;
  dcterms:modified "2026-06-07T15:30:29.365096Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8924-2
  a curric:KeyLearningPoint ;
  rdfs:label "An emotion describes how someone is feeling."@en ;
  dcterms:modified "2026-06-07T15:30:29.365100Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8924-3
  a curric:KeyLearningPoint ;
  rdfs:label """Emotions can be different and shown in different ways, so descriptions must be
  chosen carefully."""@en ;
  dcterms:modified "2026-06-07T15:30:29.365103Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8924-4
  a curric:KeyLearningPoint ;
  rdfs:label """Including a range of adjectives to describe the same feeling stops repetition and
  makes writing more interesting."""@en ;
  dcterms:modified "2026-06-07T15:30:29.365107Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8924-5
  a curric:KeyLearningPoint ;
  rdfs:label """When you choose two adjectives to describe a noun, this is called an expanded noun
  phrase."""@en ;
  dcterms:modified "2026-06-07T15:30:29.365111Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8926-1
  a curric:KeyLearningPoint ;
  rdfs:label "Senses help us to experience and describe the setting, in this case, London"@en ;
  dcterms:modified "2026-06-07T15:30:29.365115Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8926-2
  a curric:KeyLearningPoint ;
  rdfs:label "The five senses are sight, smell, hearing, touch and taste"@en ;
  dcterms:modified "2026-06-07T15:30:29.365119Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8926-3
  a curric:KeyLearningPoint ;
  rdfs:label """Expanded noun phrases need a comma in between the two adjectives, such as 'long,
  grand bridge'"""@en ;
  dcterms:modified "2026-06-07T15:30:29.365123Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8926-4
  a curric:KeyLearningPoint ;
  rdfs:label "A sentence must include a verb"@en ;
  dcterms:modified "2026-06-07T15:30:29.365127Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8926-5
  a curric:KeyLearningPoint ;
  rdfs:label "Using descriptions with adjectives make writing more interesting"@en ;
  dcterms:modified "2026-06-07T15:30:29.365130Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8922-1
  a curric:KeyLearningPoint ;
  rdfs:label """One way of inferring a character's feelings is looking at their expressions in an
  illustration."""@en ;
  dcterms:modified "2026-06-07T15:30:29.365272Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8922-2
  a curric:KeyLearningPoint ;
  rdfs:label """One way of inferring a character's feelings is reading about how they move, what
  they do and what they say."""@en ;
  dcterms:modified "2026-06-07T15:30:29.365276Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8922-3
  a curric:KeyLearningPoint ;
  rdfs:label """Imagining how people might feel because of certain actions can help to understand
  the perspective of others."""@en ;
  dcterms:modified "2026-06-07T15:30:29.365279Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8922-4
  a curric:KeyLearningPoint ;
  rdfs:label """Discussing feelings of others helps to generate alternative & more powerful
  adjectives to describe an emotion or event."""@en ;
  dcterms:modified "2026-06-07T15:30:29.365283Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8922-5
  a curric:KeyLearningPoint ;
  rdfs:label "Using 'I', 'me' or 'my' is a way of speaking in the first person."@en ;
  dcterms:modified "2026-06-07T15:30:29.365287Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4755-1
  a curric:KeyLearningPoint ;
  rdfs:label "The pre-cursive letters e, s and f all have a lead in and a lead out"@en ;
  dcterms:modified "2026-06-07T15:30:29.365291Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4755-2
  a curric:KeyLearningPoint ;
  rdfs:label "The pre-cursive letter f has a loop as the lead in and a loop as the lead out"@en ;
  dcterms:modified "2026-06-07T15:30:29.365295Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4755-3
  a curric:KeyLearningPoint ;
  rdfs:label "The letters e and s are x-height letters"@en ;
  dcterms:modified "2026-06-07T15:30:29.365299Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4755-4
  a curric:KeyLearningPoint ;
  rdfs:label "The pre-cursive letter f has an ascender and a descender"@en ;
  dcterms:modified "2026-06-07T15:30:29.365303Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4758-1
  a curric:KeyLearningPoint ;
  rdfs:label """The letters c, a, d, o, g and q all start just below the x-height line and go round
  in an anti-clockwise direction."""@en ;
  dcterms:modified "2026-06-07T15:30:29.365331Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4758-2
  a curric:KeyLearningPoint ;
  rdfs:label "The letters c, a and o are x-height letters."@en ;
  dcterms:modified "2026-06-07T15:30:29.365335Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4758-3
  a curric:KeyLearningPoint ;
  rdfs:label "The letters g and q have descenders and d has an ascender."@en ;
  dcterms:modified "2026-06-07T15:30:29.365339Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4758-4
  a curric:KeyLearningPoint ;
  rdfs:label "The letter g finishes with a curl up at the descender line."@en ;
  dcterms:modified "2026-06-07T15:30:29.365343Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4758-5
  a curric:KeyLearningPoint ;
  rdfs:label """The letter q finishes with a diagonal line out to the side at the descender
  line."""@en ;
  dcterms:modified "2026-06-07T15:30:29.365347Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-909-1
  a curric:KeyLearningPoint ;
  rdfs:label "There are four types of simple sentence."@en ;
  dcterms:modified "2026-06-07T15:30:29.365359Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-909-2
  a curric:KeyLearningPoint ;
  rdfs:label "Each type of simple sentence has a different purpose for the reader."@en ;
  dcterms:modified "2026-06-07T15:30:29.365366Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-909-3
  a curric:KeyLearningPoint ;
  rdfs:label "Any simple sentence is a sentence about one idea that makes complete sense."@en ;
  dcterms:modified "2026-06-07T15:30:29.365371Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-909-4
  a curric:KeyLearningPoint ;
  rdfs:label """A statement is a simple sentence that expresses a fact or an opinion and ends with a
  full stop."""@en ;
  dcterms:modified "2026-06-07T15:30:29.365375Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-909-5
  a curric:KeyLearningPoint ;
  rdfs:label """A question is a simple sentence that asks the reader for an answer and ends with a
  question mark."""@en ;
  dcterms:modified "2026-06-07T15:30:29.365378Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8128-1
  a curric:KeyLearningPoint ;
  rdfs:label "A theme is a big idea, topic or message that appears in a story."@en ;
  dcterms:modified "2026-06-07T15:30:29.365382Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8128-2
  a curric:KeyLearningPoint ;
  rdfs:label "Themes in a story are used to convey deeper meaning and messages to the reader."@en ;
  dcterms:modified "2026-06-07T15:30:29.365420Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8128-3
  a curric:KeyLearningPoint ;
  rdfs:label """'The Proudest Blue' explores themes of identity, pride and differences, among many
  others."""@en ;
  dcterms:modified "2026-06-07T15:30:29.365425Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8128-4
  a curric:KeyLearningPoint ;
  rdfs:label """Stories can create a personal response linked to the reader's own views or personal
  experiences."""@en ;
  dcterms:modified "2026-06-07T15:30:29.365430Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8128-5
  a curric:KeyLearningPoint ;
  rdfs:label """Many different factors can contribute to a person's identity and everyone deserves
  to feel normal and proud."""@en ;
  dcterms:modified "2026-06-07T15:30:29.365434Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-905-1
  a curric:KeyLearningPoint ;
  rdfs:label "Verbs are doing and being words."@en ;
  dcterms:modified "2026-06-07T15:30:29.365473Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-905-2
  a curric:KeyLearningPoint ;
  rdfs:label "Being verbs are \"is\", \"are\", \"was\" and \"were\"."@en ;
  dcterms:modified "2026-06-07T15:30:29.365481Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-905-3
  a curric:KeyLearningPoint ;
  rdfs:label "Verbs can be in different tenses."@en ;
  dcterms:modified "2026-06-07T15:30:29.365486Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-905-4
  a curric:KeyLearningPoint ;
  rdfs:label "A being verb can be the only verb in a complete sentence."@en ;
  dcterms:modified "2026-06-07T15:30:29.365490Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-950-1
  a curric:KeyLearningPoint ;
  rdfs:label """The 'll' representation of the 'l' sound is often found after short vowels in single
  syllable words."""@en ;
  dcterms:modified "2026-06-07T15:30:29.367863Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-950-2
  a curric:KeyLearningPoint ;
  rdfs:label "The 'el' and 'le' representations are usually found in polysyllabic words."@en ;
  dcterms:modified "2026-06-07T15:30:29.367867Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-950-3
  a curric:KeyLearningPoint ;
  rdfs:label "The 'el' spelling is much less common than 'le'."@en ;
  dcterms:modified "2026-06-07T15:30:29.367871Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-950-4
  a curric:KeyLearningPoint ;
  rdfs:label "The 'el' spelling is often used after 'm', 'n', 'r', 's', 'v' and 'w'."@en ;
  dcterms:modified "2026-06-07T15:30:29.367875Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-950-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the common exception words: child and children."@en ;
  dcterms:modified "2026-06-07T15:30:29.367880Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-947-1
  a curric:KeyLearningPoint ;
  rdfs:label "'ce' is sometimes used to represent the 's' phoneme at the end of a word."@en ;
  dcterms:modified "2026-06-07T15:30:29.367929Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-947-2
  a curric:KeyLearningPoint ;
  rdfs:label "'se' is sometimes used to represent the 's' phoneme at the end of a word."@en ;
  dcterms:modified "2026-06-07T15:30:29.367933Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-947-3
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the common exception word 'once' and high frequnecy word 'going'."@en ;
  dcterms:modified "2026-06-07T15:30:29.367937Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-922-1
  a curric:KeyLearningPoint ;
  rdfs:label "a', 'eigh' and 'ey' are alternative spellings for the 'ay' phoneme."@en ;
  dcterms:modified "2026-06-07T15:30:29.368004Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-922-2
  a curric:KeyLearningPoint ;
  rdfs:label "Words in word families often have similar spellings."@en ;
  dcterms:modified "2026-06-07T15:30:29.368008Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-922-3
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the common exception words: told, hold and oh."@en ;
  dcterms:modified "2026-06-07T15:30:29.368012Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5441-1
  a curric:KeyLearningPoint ;
  rdfs:label """'The Magic Porridge Pot' has some words in that sound like what it is describing,
  such as 'split, splat, splot'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.368177Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5441-2
  a curric:KeyLearningPoint ;
  rdfs:label "This is called onomatopoeia."@en ;
  dcterms:modified "2026-06-07T15:30:29.368181Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5441-3
  a curric:KeyLearningPoint ;
  rdfs:label "These words can be spoken and sung with expression and intonation."@en ;
  dcterms:modified "2026-06-07T15:30:29.368185Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5441-4
  a curric:KeyLearningPoint ;
  rdfs:label """Personal responses are a way of sharing your own thoughts, feelings, and opinions
  about a poem."""@en ;
  dcterms:modified "2026-06-07T15:30:29.368191Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8919-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Coming to England' is a book based on the true story about Floella Benjamin."@en ;
  dcterms:modified "2026-06-07T15:30:29.368220Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8919-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Coming to England' is a non-fiction book written and illustrated in the style of a
  fiction book."""@en ;
  dcterms:modified "2026-06-07T15:30:29.368224Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8919-3
  a curric:KeyLearningPoint ;
  rdfs:label "Floella Benjamin emigrated from Trinidad to the United Kingdom."@en ;
  dcterms:modified "2026-06-07T15:30:29.368228Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8919-4
  a curric:KeyLearningPoint ;
  rdfs:label "Similarities and differences can be made about two books with the same theme."@en ;
  dcterms:modified "2026-06-07T15:30:29.368232Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8110-1
  a curric:KeyLearningPoint ;
  rdfs:label """Opinions are views that a person has about something and can be known as a 'point of
  view'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.368236Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8110-2
  a curric:KeyLearningPoint ;
  rdfs:label "Reasons should be used to explain why we have a particular opinion."@en ;
  dcterms:modified "2026-06-07T15:30:29.368240Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8110-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Because' is the joining word that allows you to explain why you have that
  opinion."""@en ;
  dcterms:modified "2026-06-07T15:30:29.368244Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8899-1
  a curric:KeyLearningPoint ;
  rdfs:label "Using a range of strategies helps to build our understanding of a text."@en ;
  dcterms:modified "2026-06-07T15:30:29.368361Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8899-2
  a curric:KeyLearningPoint ;
  rdfs:label "Retrieving means finding information directly from the text."@en ;
  dcterms:modified "2026-06-07T15:30:29.368366Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8899-3
  a curric:KeyLearningPoint ;
  rdfs:label """Searching for clues within the text helps us to infer greater meaning and draw
  conclusions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.368370Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8899-4
  a curric:KeyLearningPoint ;
  rdfs:label """Having rich discussions improves our understanding and offers opportunities for
  hearing different ideas."""@en ;
  dcterms:modified "2026-06-07T15:30:29.368373Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8899-5
  a curric:KeyLearningPoint ;
  rdfs:label "Plop met a Scout who told him about why he thinks night time is ‘fun’."@en ;
  dcterms:modified "2026-06-07T15:30:29.368378Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5408-1
  a curric:KeyLearningPoint ;
  rdfs:label """A front cover often shows the title, an illustration, the author's name and the
  illustrator's name"""@en ;
  dcterms:modified "2026-06-07T15:30:29.372727Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5408-2
  a curric:KeyLearningPoint ;
  rdfs:label """The title and illustrations can generate a prediction about what a book might be
  about"""@en ;
  dcterms:modified "2026-06-07T15:30:29.372732Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5408-3
  a curric:KeyLearningPoint ;
  rdfs:label "One person's prediction might be different to another person's"@en ;
  dcterms:modified "2026-06-07T15:30:29.372736Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5408-4
  a curric:KeyLearningPoint ;
  rdfs:label "Looking closely at some illustrations can help to make more detailed predictions"@en ;
  dcterms:modified "2026-06-07T15:30:29.372740Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5408-5
  a curric:KeyLearningPoint ;
  rdfs:label """Looking at illustrations and discussing a book before reading builds excitement
  about reading it"""@en ;
  dcterms:modified "2026-06-07T15:30:29.372744Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9208-1
  a curric:KeyLearningPoint ;
  rdfs:label "'And Tango Makes Three’ is a narrative fiction that is based on a true story."@en ;
  dcterms:modified "2026-06-07T15:30:29.375430Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9208-2
  a curric:KeyLearningPoint ;
  rdfs:label """The main characters in the story are two boy penguins, one named Roy and one named
  Silo."""@en ;
  dcterms:modified "2026-06-07T15:30:29.375434Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9208-3
  a curric:KeyLearningPoint ;
  rdfs:label "The story is set inside Central Park Zoo in New York City."@en ;
  dcterms:modified "2026-06-07T15:30:29.375438Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9208-4
  a curric:KeyLearningPoint ;
  rdfs:label """The plot follows the story of how Roy and Silo find a way to become parents and have
  their own family."""@en ;
  dcterms:modified "2026-06-07T15:30:29.375442Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9208-5
  a curric:KeyLearningPoint ;
  rdfs:label """Roy and Silo are the first family in the zoo to have two dads but they live and love
  just like all the other families."""@en ;
  dcterms:modified "2026-06-07T15:30:29.375448Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6177-1
  a curric:KeyLearningPoint ;
  rdfs:label "Planning is an important part of preparing to write."@en ;
  dcterms:modified "2026-06-07T15:30:29.375452Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6177-2
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the build-up of a story is to develop the plot and characters and
  introduce a problem."""@en ;
  dcterms:modified "2026-06-07T15:30:29.375456Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6177-3
  a curric:KeyLearningPoint ;
  rdfs:label "Our plan will contain ambitious vocabulary."@en ;
  dcterms:modified "2026-06-07T15:30:29.375460Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6177-4
  a curric:KeyLearningPoint ;
  rdfs:label "Our plan will contain nouns, adjectives, verbs and adverbs."@en ;
  dcterms:modified "2026-06-07T15:30:29.375464Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4749-1
  a curric:KeyLearningPoint ;
  rdfs:label "Pre-cursive letters all start on the baseline with a lead in"@en ;
  dcterms:modified "2026-06-07T15:30:29.375507Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4749-2
  a curric:KeyLearningPoint ;
  rdfs:label "The letters i, l and t all have a lead in and a lead out"@en ;
  dcterms:modified "2026-06-07T15:30:29.375511Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4749-3
  a curric:KeyLearningPoint ;
  rdfs:label "We remember where to start by saying 'Ready, line, go'"@en ;
  dcterms:modified "2026-06-07T15:30:29.375550Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4749-4
  a curric:KeyLearningPoint ;
  rdfs:label "The letters i, l and t are all formed by going up and then down"@en ;
  dcterms:modified "2026-06-07T15:30:29.375558Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4794-1
  a curric:KeyLearningPoint ;
  rdfs:label "Proper nouns name specific people, places and things."@en ;
  dcterms:modified "2026-06-07T15:30:29.375562Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4794-2
  a curric:KeyLearningPoint ;
  rdfs:label """After forming a capital letter, you lift your pencil and place it on the correct
  starting point for the next letter."""@en ;
  dcterms:modified "2026-06-07T15:30:29.375566Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4794-3
  a curric:KeyLearningPoint ;
  rdfs:label "Capital letters do not join to the next letter, they sit on their own."@en ;
  dcterms:modified "2026-06-07T15:30:29.375573Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4794-4
  a curric:KeyLearningPoint ;
  rdfs:label """The remaining letters in the proper noun will be joined using a range of joins
  depending on the letters in the word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.375577Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4794-5
  a curric:KeyLearningPoint ;
  rdfs:label "There is appropriate spacing between the letters."@en ;
  dcterms:modified "2026-06-07T15:30:29.375581Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27908-1
  a curric:KeyLearningPoint ;
  rdfs:label "Things you like or dislike are called your 'opinions'."@en ;
  dcterms:modified "2026-06-07T15:30:29.375650Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27908-2
  a curric:KeyLearningPoint ;
  rdfs:label "People can agree or disagree with an opinion."@en ;
  dcterms:modified "2026-06-07T15:30:29.375654Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27908-3
  a curric:KeyLearningPoint ;
  rdfs:label """Using the word 'because' will allow you to explain why you like or dislike
  something."""@en ;
  dcterms:modified "2026-06-07T15:30:29.375658Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27908-4
  a curric:KeyLearningPoint ;
  rdfs:label "Speaking in full sentences helps the listener understand what is being said."@en ;
  dcterms:modified "2026-06-07T15:30:29.375662Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27908-5
  a curric:KeyLearningPoint ;
  rdfs:label """Successful speaking includes speaking loudly and clearly enough for everyone to
  hear."""@en ;
  dcterms:modified "2026-06-07T15:30:29.375666Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5654-1
  a curric:KeyLearningPoint ;
  rdfs:label "The fire spread quickly because the weather was dry, hot and windy."@en ;
  dcterms:modified "2026-06-07T15:30:29.375856Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5654-2
  a curric:KeyLearningPoint ;
  rdfs:label """There was no fire brigade so Londoners used leather buckets, axes and water squirts
  to try and fight the fire."""@en ;
  dcterms:modified "2026-06-07T15:30:29.375859Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5654-3
  a curric:KeyLearningPoint ;
  rdfs:label """A plan helps a writer to organise their ideas, thoughts and the information they
  want to include in their writing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.375863Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5654-4
  a curric:KeyLearningPoint ;
  rdfs:label """Notes can be used in a plan to help organise key information and are not written in
  full sentences."""@en ;
  dcterms:modified "2026-06-07T15:30:29.375869Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6825-1
  a curric:KeyLearningPoint ;
  rdfs:label """Imagining you are the character helps to understand events and generate descriptions
  of the story"""@en ;
  dcterms:modified "2026-06-07T15:30:29.375874Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6825-2
  a curric:KeyLearningPoint ;
  rdfs:label """Describing how a character is looking or what they are doing helps us to understand
  the plot of a story."""@en ;
  dcterms:modified "2026-06-07T15:30:29.375878Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6825-3
  a curric:KeyLearningPoint ;
  rdfs:label """Facial expressions and movements help the audience understand what is happening,
  such as fear from the goat"""@en ;
  dcterms:modified "2026-06-07T15:30:29.375882Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6825-4
  a curric:KeyLearningPoint ;
  rdfs:label """There are different ways to express emotions. Facial expressions and actions help us
  to show feelings and emotions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.375886Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6825-5
  a curric:KeyLearningPoint ;
  rdfs:label "The feelings we have can result in actions."@en ;
  dcterms:modified "2026-06-07T15:30:29.375890Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5447-1
  a curric:KeyLearningPoint ;
  rdfs:label "Poems can be learnt by heart by listening to them again and again."@en ;
  dcterms:modified "2026-06-07T15:30:29.375937Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5447-2
  a curric:KeyLearningPoint ;
  rdfs:label """Making comparisons means finding similarities and differences in a poem, such as the
  use of rhyme and onomatopoeia."""@en ;
  dcterms:modified "2026-06-07T15:30:29.375943Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5447-3
  a curric:KeyLearningPoint ;
  rdfs:label """Personal responses are a way of sharing your own thoughts, feelings, and opinions
  about the text."""@en ;
  dcterms:modified "2026-06-07T15:30:29.375947Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5447-4
  a curric:KeyLearningPoint ;
  rdfs:label "Actions and sound effects help to add to a poem's meaning."@en ;
  dcterms:modified "2026-06-07T15:30:29.375951Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5447-5
  a curric:KeyLearningPoint ;
  rdfs:label "Expression and volume help to hold an audience's attention."@en ;
  dcterms:modified "2026-06-07T15:30:29.375955Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4743-1
  a curric:KeyLearningPoint ;
  rdfs:label "The capital letters X, Y and Z all start at the top tramline."@en ;
  dcterms:modified "2026-06-07T15:30:29.380185Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4743-2
  a curric:KeyLearningPoint ;
  rdfs:label """The formation of capital letters X and Y needs you to lift your pencil to add the
  other line."""@en ;
  dcterms:modified "2026-06-07T15:30:29.380189Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8831-1
  a curric:KeyLearningPoint ;
  rdfs:label "A biography is a non-fiction text"@en ;
  dcterms:modified "2026-06-07T15:30:29.380549Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8831-2
  a curric:KeyLearningPoint ;
  rdfs:label "A biography tells the true story of a person's life"@en ;
  dcterms:modified "2026-06-07T15:30:29.380556Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8831-3
  a curric:KeyLearningPoint ;
  rdfs:label "Biographies are written in chronological order"@en ;
  dcterms:modified "2026-06-07T15:30:29.380567Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8831-4
  a curric:KeyLearningPoint ;
  rdfs:label "Biographies are often written about significant figures"@en ;
  dcterms:modified "2026-06-07T15:30:29.380572Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8831-5
  a curric:KeyLearningPoint ;
  rdfs:label "Emmeline Pankhurst was a significant historical figure"@en ;
  dcterms:modified "2026-06-07T15:30:29.380576Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5416-1
  a curric:KeyLearningPoint ;
  rdfs:label """A character's facial expressions and actions help infer how they feel, such as when
  Lulu is told she can have a cat"""@en ;
  dcterms:modified "2026-06-07T15:30:29.380646Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5416-2
  a curric:KeyLearningPoint ;
  rdfs:label "Asking questions to the character helps to consider key events and themes"@en ;
  dcterms:modified "2026-06-07T15:30:29.380651Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5416-3
  a curric:KeyLearningPoint ;
  rdfs:label """Illustrations can offer clues as to how characters might feel or what might happen
  next"""@en ;
  dcterms:modified "2026-06-07T15:30:29.380655Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5416-4
  a curric:KeyLearningPoint ;
  rdfs:label "Thinking from a character's perspective helps us to understand the story better."@en ;
  dcterms:modified "2026-06-07T15:30:29.380659Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29018-1
  a curric:KeyLearningPoint ;
  rdfs:label "Traditional tales are mostly told in the past tense."@en ;
  dcterms:modified "2026-06-07T15:30:29.380679Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29018-2
  a curric:KeyLearningPoint ;
  rdfs:label "The beginning of a story introduces the main characters, setting and plot."@en ;
  dcterms:modified "2026-06-07T15:30:29.380683Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29018-3
  a curric:KeyLearningPoint ;
  rdfs:label "Two ideas can be joined using the joining word 'and'."@en ;
  dcterms:modified "2026-06-07T15:30:29.380687Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29018-4
  a curric:KeyLearningPoint ;
  rdfs:label """When a sentence has two adjectives before a noun, a comma is needed between them,
  such as 'excited, adventurous pigs'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.380691Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29018-5
  a curric:KeyLearningPoint ;
  rdfs:label """An adverb describes a verb; adverbs can describe how something happened, such as
  ‘proudly’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.380697Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-942-1
  a curric:KeyLearningPoint ;
  rdfs:label "mb' can be a representation of the 'm' phoneme."@en ;
  dcterms:modified "2026-06-07T15:30:29.386634Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-942-2
  a curric:KeyLearningPoint ;
  rdfs:label "The representation 'mb' is often found at the end of a word, such as climb."@en ;
  dcterms:modified "2026-06-07T15:30:29.386638Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-942-3
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the common exception word: parents."@en ;
  dcterms:modified "2026-06-07T15:30:29.386641Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27776-1
  a curric:KeyLearningPoint ;
  rdfs:label "The capital letters J, U, X, Y and Z start on the ascender line."@en ;
  dcterms:modified "2026-06-07T15:30:29.386663Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27776-2
  a curric:KeyLearningPoint ;
  rdfs:label """The capital letters J, U, X, Y and Z all have either one or two vertical or diagonal
  lines going down to the baseline."""@en ;
  dcterms:modified "2026-06-07T15:30:29.386667Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27776-3
  a curric:KeyLearningPoint ;
  rdfs:label """The letters J, X and Y all need the pencil to be lifted to form the horizontal or
  diagonal lines."""@en ;
  dcterms:modified "2026-06-07T15:30:29.386673Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27776-4
  a curric:KeyLearningPoint ;
  rdfs:label "You do not lift your pencil when forming the letters U and Z."@en ;
  dcterms:modified "2026-06-07T15:30:29.386678Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27776-5
  a curric:KeyLearningPoint ;
  rdfs:label "The letter Z has a zigzag pattern."@en ;
  dcterms:modified "2026-06-07T15:30:29.386682Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-974-1
  a curric:KeyLearningPoint ;
  rdfs:label "Compound words are two or more words joined together."@en ;
  dcterms:modified "2026-06-07T15:30:29.386770Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-974-2
  a curric:KeyLearningPoint ;
  rdfs:label "In a compound word, the spelling of the original words stays the same."@en ;
  dcterms:modified "2026-06-07T15:30:29.386774Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-974-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Football', 'notebook', 'inside' and 'sometimes' are all compound words."@en ;
  dcterms:modified "2026-06-07T15:30:29.386778Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-921-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘ay’ is a representation of the ay phoneme that often comes at the end of a
  word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.398006Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-921-2
  a curric:KeyLearningPoint ;
  rdfs:label """‘ai’ is a representation of the ay phoneme that often is found in the middle of a
  word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.398009Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-921-3
  a curric:KeyLearningPoint ;
  rdfs:label "‘a-e’ is a representation of the ay phoneme that is often found ‘last but one’."@en ;
  dcterms:modified "2026-06-07T15:30:29.398013Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-921-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the common exception words: old, cold and gold."@en ;
  dcterms:modified "2026-06-07T15:30:29.398017Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-921-5
  a curric:KeyLearningPoint ;
  rdfs:label """How to write a complete sentence containing words and spellings previously and
  recently learnt."""@en ;
  dcterms:modified "2026-06-07T15:30:29.398023Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1020-1
  a curric:KeyLearningPoint ;
  rdfs:label "An apostrophe is an important piece of punctuation with more than one purpose."@en ;
  dcterms:modified "2026-06-07T15:30:29.398049Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1020-2
  a curric:KeyLearningPoint ;
  rdfs:label "An apostrophe can contract two words together."@en ;
  dcterms:modified "2026-06-07T15:30:29.398053Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1020-3
  a curric:KeyLearningPoint ;
  rdfs:label "An apostrophe can show if a noun belongs to another singular noun."@en ;
  dcterms:modified "2026-06-07T15:30:29.398057Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1020-4
  a curric:KeyLearningPoint ;
  rdfs:label """Apostrophes for contraction and singular possession are useful in writing for
  different reasons."""@en ;
  dcterms:modified "2026-06-07T15:30:29.398061Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1020-5
  a curric:KeyLearningPoint ;
  rdfs:label "Apostrophes are most deeply understood when word class is understood."@en ;
  dcterms:modified "2026-06-07T15:30:29.398064Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4737-1
  a curric:KeyLearningPoint ;
  rdfs:label "Capital letters are the upper case formations of a letter"@en ;
  dcterms:modified "2026-06-07T15:30:29.398090Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4737-2
  a curric:KeyLearningPoint ;
  rdfs:label """Capital letters and lower case letters can be formed in a similar or
  different way"""@en ;
  dcterms:modified "2026-06-07T15:30:29.398094Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4737-3
  a curric:KeyLearningPoint ;
  rdfs:label """Capital letters are used at the start of a sentence, for a proper noun and for the
  pronoun I"""@en ;
  dcterms:modified "2026-06-07T15:30:29.398098Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4737-4
  a curric:KeyLearningPoint ;
  rdfs:label "Capital letters sit on the baseline and reach up to the ascender line"@en ;
  dcterms:modified "2026-06-07T15:30:29.398104Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4737-5
  a curric:KeyLearningPoint ;
  rdfs:label """The capital letters C, G, O and Q are formed by curling round in an anti-clockwise
  direction"""@en ;
  dcterms:modified "2026-06-07T15:30:29.398108Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-917-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Or' is a type of joining word."@en ;
  dcterms:modified "2026-06-07T15:30:29.398112Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-917-2
  a curric:KeyLearningPoint ;
  rdfs:label "Joining two simple sentences with 'or' forms a compound sentence."@en ;
  dcterms:modified "2026-06-07T15:30:29.398116Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-917-3
  a curric:KeyLearningPoint ;
  rdfs:label """The second idea offers an option or result of the first idea if 'or' is used to join
  them."""@en ;
  dcterms:modified "2026-06-07T15:30:29.398120Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-917-4
  a curric:KeyLearningPoint ;
  rdfs:label "Each of the two ideas holds equal grammatical weight in the sentence."@en ;
  dcterms:modified "2026-06-07T15:30:29.398123Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-917-5
  a curric:KeyLearningPoint ;
  rdfs:label """Grammatically accurate sentences start with capital letters and most often end with
  full stops."""@en ;
  dcterms:modified "2026-06-07T15:30:29.398127Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5439-1
  a curric:KeyLearningPoint ;
  rdfs:label """Nursery rhymes are a good way to introduce us to rhythms of language, new vocabulary
  and sentence structures."""@en ;
  dcterms:modified "2026-06-07T15:30:29.398143Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5439-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Hickory Dickory Dock' has some rhyming words, such as 'clock', 'tick-tock' and
  'Dock'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.398146Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5439-3
  a curric:KeyLearningPoint ;
  rdfs:label """Knowing the tune, words, rhythm and actions of a Nursery Rhyme make it entertaining
  for whoever is watching."""@en ;
  dcterms:modified "2026-06-07T15:30:29.398152Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5439-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Hickory Dickory Dock' and 'Little Bo Peep' are similar because they both include
  animals."""@en ;
  dcterms:modified "2026-06-07T15:30:29.398157Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5439-5
  a curric:KeyLearningPoint ;
  rdfs:label """Personal responses are a way of sharing your own thoughts, feelings, and opinions
  about a poem."""@en ;
  dcterms:modified "2026-06-07T15:30:29.398160Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5194-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘The Children of Lir’ is divided into short chapters and has a beginning, middle and
  end, like all traditional tales."""@en ;
  dcterms:modified "2026-06-07T15:30:29.398322Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5194-2
  a curric:KeyLearningPoint ;
  rdfs:label """Sounding out using phonics strategies is our most helpful way to decode unfamiliar
  words."""@en ;
  dcterms:modified "2026-06-07T15:30:29.398326Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5194-3
  a curric:KeyLearningPoint ;
  rdfs:label "Searching for a ‘word within a word’ is a useful strategy to comprehend words."@en ;
  dcterms:modified "2026-06-07T15:30:29.398330Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5194-4
  a curric:KeyLearningPoint ;
  rdfs:label """Read to the end of the sentence to help to decide the meaning of an
  unfamiliar word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.398333Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5194-5
  a curric:KeyLearningPoint ;
  rdfs:label """Re-reading a sentence fluently after decoding helps to make sense of what has been
  read."""@en ;
  dcterms:modified "2026-06-07T15:30:29.398337Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7194-1
  a curric:KeyLearningPoint ;
  rdfs:label "Kit Wright is a poet and is known for writing imaginative poetry for children."@en ;
  dcterms:modified "2026-06-07T15:30:29.398859Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7194-2
  a curric:KeyLearningPoint ;
  rdfs:label """‘The Magic Box’ by Kit Wright is a poem about putting a variety of unique and
  wonderful items into a special box."""@en ;
  dcterms:modified "2026-06-07T15:30:29.398863Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7194-3
  a curric:KeyLearningPoint ;
  rdfs:label """The poem explores themes including: imagination, magic and wonder, childhood, family
  and memories."""@en ;
  dcterms:modified "2026-06-07T15:30:29.398869Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7194-4
  a curric:KeyLearningPoint ;
  rdfs:label "We can read with expression to show meaning and emphasise words."@en ;
  dcterms:modified "2026-06-07T15:30:29.398873Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5644-1
  a curric:KeyLearningPoint ;
  rdfs:label """Instructions use numbers and ordering fronted adverbials to add order and
  sequence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.407433Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5644-2
  a curric:KeyLearningPoint ;
  rdfs:label "Instructions can contain adjectives to describe the nouns."@en ;
  dcterms:modified "2026-06-07T15:30:29.407437Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5644-3
  a curric:KeyLearningPoint ;
  rdfs:label "Instructions contain imperative verbs."@en ;
  dcterms:modified "2026-06-07T15:30:29.407441Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6200-1
  a curric:KeyLearningPoint ;
  rdfs:label "The first section of the report will be all about bats."@en ;
  dcterms:modified "2026-06-07T15:30:29.407481Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6200-2
  a curric:KeyLearningPoint ;
  rdfs:label "An apostrophe can show if a noun belongs to another singular noun."@en ;
  dcterms:modified "2026-06-07T15:30:29.407485Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6200-3
  a curric:KeyLearningPoint ;
  rdfs:label "Apostrophes for singular possession are useful to make our writing clear."@en ;
  dcterms:modified "2026-06-07T15:30:29.407489Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6200-4
  a curric:KeyLearningPoint ;
  rdfs:label "An apostrophe sits at the same height as the ascender of a letter."@en ;
  dcterms:modified "2026-06-07T15:30:29.407493Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6174-1
  a curric:KeyLearningPoint ;
  rdfs:label "A setting is where the story takes place."@en ;
  dcterms:modified "2026-06-07T15:30:29.407499Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6174-2
  a curric:KeyLearningPoint ;
  rdfs:label "We can use our senses to describe a setting in detail."@en ;
  dcterms:modified "2026-06-07T15:30:29.407503Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6174-3
  a curric:KeyLearningPoint ;
  rdfs:label """An expanded noun phrase can contain two adjectives to describe a noun, separated by
  a comma."""@en ;
  dcterms:modified "2026-06-07T15:30:29.407507Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6174-4
  a curric:KeyLearningPoint ;
  rdfs:label "A character’s appearance is what they look like."@en ;
  dcterms:modified "2026-06-07T15:30:29.407512Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6174-5
  a curric:KeyLearningPoint ;
  rdfs:label """A character’s personality is what kind of person they are on the inside and how they
  behave."""@en ;
  dcterms:modified "2026-06-07T15:30:29.407516Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4760-1
  a curric:KeyLearningPoint ;
  rdfs:label "All the letters have a lead in and a lead out."@en ;
  dcterms:modified "2026-06-07T15:30:29.407538Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4760-2
  a curric:KeyLearningPoint ;
  rdfs:label "Cursive handwriting involves joining letters together."@en ;
  dcterms:modified "2026-06-07T15:30:29.407542Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4760-3
  a curric:KeyLearningPoint ;
  rdfs:label "Cursive letter joins refer to how the letters connect together."@en ;
  dcterms:modified "2026-06-07T15:30:29.407548Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4760-4
  a curric:KeyLearningPoint ;
  rdfs:label "The pencil does not lift when forming the join."@en ;
  dcterms:modified "2026-06-07T15:30:29.407553Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4760-5
  a curric:KeyLearningPoint ;
  rdfs:label "The first join goes from the baseline to the x-height line."@en ;
  dcterms:modified "2026-06-07T15:30:29.407557Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5648-1
  a curric:KeyLearningPoint ;
  rdfs:label """A non-chronological report must be written in a formal tone, avoiding language
  choices associated with fiction writing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.407811Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5648-2
  a curric:KeyLearningPoint ;
  rdfs:label "Contractions are not used in formal writing."@en ;
  dcterms:modified "2026-06-07T15:30:29.407817Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5648-3
  a curric:KeyLearningPoint ;
  rdfs:label "Information can be shared with the reader by phrasing it as a question."@en ;
  dcterms:modified "2026-06-07T15:30:29.407822Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5481-1
  a curric:KeyLearningPoint ;
  rdfs:label "Sequencing language can be used at the start of a sentence, such as 'Suddenly,'"@en ;
  dcterms:modified "2026-06-07T15:30:29.407963Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5481-2
  a curric:KeyLearningPoint ;
  rdfs:label """The middle of a story introduces the main plot and problem, such as the porridge
  overflowing"""@en ;
  dcterms:modified "2026-06-07T15:30:29.407967Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5481-3
  a curric:KeyLearningPoint ;
  rdfs:label "Rehearsing a sentence out loud before writing it helps us to remember it"@en ;
  dcterms:modified "2026-06-07T15:30:29.407971Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5481-4
  a curric:KeyLearningPoint ;
  rdfs:label "Reading a sentence back after writing helps to check it makes sense"@en ;
  dcterms:modified "2026-06-07T15:30:29.407978Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5481-5
  a curric:KeyLearningPoint ;
  rdfs:label "Using an exclamation mark at the end shows shock or excitement"@en ;
  dcterms:modified "2026-06-07T15:30:29.407982Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6839-1
  a curric:KeyLearningPoint ;
  rdfs:label """Information about a character and setting can be found in the text and in
  illustrations."""@en ;
  dcterms:modified "2026-06-07T15:30:29.408854Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6839-2
  a curric:KeyLearningPoint ;
  rdfs:label "Some adjectives describe feelings and emotions."@en ;
  dcterms:modified "2026-06-07T15:30:29.408858Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6839-3
  a curric:KeyLearningPoint ;
  rdfs:label "A character's feelings and emotion can change throughout the story."@en ;
  dcterms:modified "2026-06-07T15:30:29.408862Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6839-4
  a curric:KeyLearningPoint ;
  rdfs:label """Linking our own experiences to what we are reading helps us to understand the
  character's feelings and actions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.408867Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6839-5
  a curric:KeyLearningPoint ;
  rdfs:label "The feeling of belonging means being accepted, feeling included and safe."@en ;
  dcterms:modified "2026-06-07T15:30:29.408871Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-900-1
  a curric:KeyLearningPoint ;
  rdfs:label "Common nouns can be singular or plural."@en ;
  dcterms:modified "2026-06-07T15:30:29.416845Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-900-2
  a curric:KeyLearningPoint ;
  rdfs:label "The spelling of a common noun changes if it is plural."@en ;
  dcterms:modified "2026-06-07T15:30:29.416850Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-900-3
  a curric:KeyLearningPoint ;
  rdfs:label "A plural common noun is not always denoted with -s."@en ;
  dcterms:modified "2026-06-07T15:30:29.416854Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8480-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘The Wolf, The Duck and The Mouse’ is a children’s story told through narrative
  writing and illustrations."""@en ;
  dcterms:modified "2026-06-07T15:30:29.416858Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8480-2
  a curric:KeyLearningPoint ;
  rdfs:label """Using what we know to make a prediction can help to build our understanding of a
  text."""@en ;
  dcterms:modified "2026-06-07T15:30:29.416862Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8480-3
  a curric:KeyLearningPoint ;
  rdfs:label """There can be multiple main characters in a story, e.g. the wolf, the duck and the
  mouse are all main characters."""@en ;
  dcterms:modified "2026-06-07T15:30:29.416866Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8480-4
  a curric:KeyLearningPoint ;
  rdfs:label "The main setting of the story is inside the stomach of the wolf."@en ;
  dcterms:modified "2026-06-07T15:30:29.416870Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8480-5
  a curric:KeyLearningPoint ;
  rdfs:label """The plot follows the story of how the duck and the mouse decide to make a home
  inside the wolf’s stomach."""@en ;
  dcterms:modified "2026-06-07T15:30:29.416874Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27603-1
  a curric:KeyLearningPoint ;
  rdfs:label """Successful listening includes looking at the person speaking and paying close
  attention."""@en ;
  dcterms:modified "2026-06-07T15:30:29.417026Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27603-2
  a curric:KeyLearningPoint ;
  rdfs:label """Successful speaking includes speaking loudly and clearly enough for everyone to
  hear."""@en ;
  dcterms:modified "2026-06-07T15:30:29.417030Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27603-3
  a curric:KeyLearningPoint ;
  rdfs:label "Questions are sentences which ask something and require an answer."@en ;
  dcterms:modified "2026-06-07T15:30:29.417034Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27603-4
  a curric:KeyLearningPoint ;
  rdfs:label "When answering questions, the response should be about the question."@en ;
  dcterms:modified "2026-06-07T15:30:29.417038Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27603-5
  a curric:KeyLearningPoint ;
  rdfs:label "Speaking in full sentences helps the listener understand what is being said."@en ;
  dcterms:modified "2026-06-07T15:30:29.417045Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8920-1
  a curric:KeyLearningPoint ;
  rdfs:label "A fact is a statement of truth."@en ;
  dcterms:modified "2026-06-07T15:30:29.417050Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8920-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Coming to England' is about Floella Benjamin's life so it can be used to learn
  information and facts."""@en ;
  dcterms:modified "2026-06-07T15:30:29.417054Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8920-3
  a curric:KeyLearningPoint ;
  rdfs:label "Two facts can be joined together using the joining word 'and'."@en ;
  dcterms:modified "2026-06-07T15:30:29.417058Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8920-4
  a curric:KeyLearningPoint ;
  rdfs:label "Two complete ideas can become one sentence by placing 'and' in between them."@en ;
  dcterms:modified "2026-06-07T15:30:29.417062Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8920-5
  a curric:KeyLearningPoint ;
  rdfs:label "A proper noun is a type of noun that needs a capital letter."@en ;
  dcterms:modified "2026-06-07T15:30:29.417066Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-927-1
  a curric:KeyLearningPoint ;
  rdfs:label """'e' is a representation of the 'ee' phoneme that is often found in short high
  frequency words."""@en ;
  dcterms:modified "2026-06-07T15:30:29.417070Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-927-2
  a curric:KeyLearningPoint ;
  rdfs:label """'y' is a representation of the 'ee' phoneme that is often found at the end of a
  word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.417074Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-927-3
  a curric:KeyLearningPoint ;
  rdfs:label """'ey' is a representation of the 'ee' phoneme that is often found at the end of a
  word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.417078Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-927-4
  a curric:KeyLearningPoint ;
  rdfs:label """'ie' is a representation of the 'ee' phoneme that is often found in the middle of a
  word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.417082Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-927-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the common exception words: class, grass and pass."@en ;
  dcterms:modified "2026-06-07T15:30:29.417086Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1059-1
  a curric:KeyLearningPoint ;
  rdfs:label """ear' is a representation of the 'er' phoneme that can ben found at the beginning or
  middle of a word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.417237Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1059-2
  a curric:KeyLearningPoint ;
  rdfs:label """The 'or' representation of the 'er' phoneme is found after a 'w', such as 'word' and
  'worm'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.417241Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1059-3
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the common exception word: friend."@en ;
  dcterms:modified "2026-06-07T15:30:29.417247Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1059-4
  a curric:KeyLearningPoint ;
  rdfs:label "Words in word families can have linked spelling, such as friend and friendly."@en ;
  dcterms:modified "2026-06-07T15:30:29.417251Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-935-1
  a curric:KeyLearningPoint ;
  rdfs:label "o' and 'oe' are representations of the 'oa' phoneme."@en ;
  dcterms:modified "2026-06-07T15:30:29.417264Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-935-2
  a curric:KeyLearningPoint ;
  rdfs:label """‘oe’ is a representation of the 'oa' phoneme most commonly found at the end of a
  word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.417268Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-935-3
  a curric:KeyLearningPoint ;
  rdfs:label """The 'o' representation of the 'oa' phoneme is in the high frequency words only, both
  and over."""@en ;
  dcterms:modified "2026-06-07T15:30:29.417272Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-935-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the common exception words: half and again."@en ;
  dcterms:modified "2026-06-07T15:30:29.417276Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7173-1
  a curric:KeyLearningPoint ;
  rdfs:label """Making a prediction means making a guess about what you think will happen in a story
  using what you already know"""@en ;
  dcterms:modified "2026-06-07T15:30:29.417375Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7173-2
  a curric:KeyLearningPoint ;
  rdfs:label """Using illustrations, the title and knowledge that we already have helps us to make a
  prediction"""@en ;
  dcterms:modified "2026-06-07T15:30:29.417379Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7173-3
  a curric:KeyLearningPoint ;
  rdfs:label "Nigeria is a country in the continent of Africa"@en ;
  dcterms:modified "2026-06-07T15:30:29.417383Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7173-4
  a curric:KeyLearningPoint ;
  rdfs:label "Because Nigeria is close to the equator, it is a warm country"@en ;
  dcterms:modified "2026-06-07T15:30:29.417390Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7173-5
  a curric:KeyLearningPoint ;
  rdfs:label "People can have different personal responses to what they have read"@en ;
  dcterms:modified "2026-06-07T15:30:29.417394Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4785-1
  a curric:KeyLearningPoint ;
  rdfs:label """Capital letters are used at the beginning of a sentence, for proper nouns and for
  the pronoun I."""@en ;
  dcterms:modified "2026-06-07T15:30:29.417398Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4785-2
  a curric:KeyLearningPoint ;
  rdfs:label "Capital letters sit between the baseline and the ascender line."@en ;
  dcterms:modified "2026-06-07T15:30:29.417402Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4785-3
  a curric:KeyLearningPoint ;
  rdfs:label """The letters C, G, O and Q all start on the ascender line and curl round in an
  anti-clockwise direction."""@en ;
  dcterms:modified "2026-06-07T15:30:29.417406Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4785-4
  a curric:KeyLearningPoint ;
  rdfs:label "The letters C, O, M, N, W and V are all made using one continuous movement."@en ;
  dcterms:modified "2026-06-07T15:30:29.417410Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4785-5
  a curric:KeyLearningPoint ;
  rdfs:label "The letters M, N, W and V are all made using vertical lines or diagonal lines."@en ;
  dcterms:modified "2026-06-07T15:30:29.417414Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8832-1
  a curric:KeyLearningPoint ;
  rdfs:label "It is useful to pick out the important parts when retelling a story"@en ;
  dcterms:modified "2026-06-07T15:30:29.417460Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8832-2
  a curric:KeyLearningPoint ;
  rdfs:label "Re-reading a text helps to build fluency and understanding"@en ;
  dcterms:modified "2026-06-07T15:30:29.417464Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8832-3
  a curric:KeyLearningPoint ;
  rdfs:label "Searching for a \"word within a word\" is a strategy to understand words"@en ;
  dcterms:modified "2026-06-07T15:30:29.417468Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8832-4
  a curric:KeyLearningPoint ;
  rdfs:label "Retrieving key information helps to build greater understanding of a story"@en ;
  dcterms:modified "2026-06-07T15:30:29.417472Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28997-1
  a curric:KeyLearningPoint ;
  rdfs:label "Instructions tell us how something should be done."@en ;
  dcterms:modified "2026-06-07T15:30:29.417476Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28997-2
  a curric:KeyLearningPoint ;
  rdfs:label """Instructions are written as commands using verbs to tell us how something should be
  done."""@en ;
  dcterms:modified "2026-06-07T15:30:29.417480Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28997-3
  a curric:KeyLearningPoint ;
  rdfs:label "Instructions are often in a set order or sequence."@en ;
  dcterms:modified "2026-06-07T15:30:29.417484Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28997-4
  a curric:KeyLearningPoint ;
  rdfs:label """Instructions often have sequencing language and are numbered to help to follow the
  order."""@en ;
  dcterms:modified "2026-06-07T15:30:29.417488Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28997-5
  a curric:KeyLearningPoint ;
  rdfs:label "Instructions may include pictures or diagrams to help to show what they do."@en ;
  dcterms:modified "2026-06-07T15:30:29.417492Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7214-1
  a curric:KeyLearningPoint ;
  rdfs:label "John Foster is a poet and is known for writing humorous poetry for children."@en ;
  dcterms:modified "2026-06-07T15:30:29.417496Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7214-2
  a curric:KeyLearningPoint ;
  rdfs:label """Foster’s poetry often explores everyday experiences that are familiar to
  children."""@en ;
  dcterms:modified "2026-06-07T15:30:29.417533Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7214-3
  a curric:KeyLearningPoint ;
  rdfs:label """‘The Morning Rush’ is a poem about getting ready for school in the morning and how
  rushed the experience can be."""@en ;
  dcterms:modified "2026-06-07T15:30:29.417539Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7214-4
  a curric:KeyLearningPoint ;
  rdfs:label "Repetition is used to create a sense of speed and urgency."@en ;
  dcterms:modified "2026-06-07T15:30:29.417543Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4753-1
  a curric:KeyLearningPoint ;
  rdfs:label "The pre-cursive letters c, a and d all start on the baseline with a lead in"@en ;
  dcterms:modified "2026-06-07T15:30:29.417547Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4753-2
  a curric:KeyLearningPoint ;
  rdfs:label """The pre-cursive letters c, a and d all have a curved up stroke on the baseline as
  the lead out"""@en ;
  dcterms:modified "2026-06-07T15:30:29.417555Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4753-3
  a curric:KeyLearningPoint ;
  rdfs:label "The letters c and a are x-height letters"@en ;
  dcterms:modified "2026-06-07T15:30:29.417562Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4753-4
  a curric:KeyLearningPoint ;
  rdfs:label "The letter d has an ascender"@en ;
  dcterms:modified "2026-06-07T15:30:29.417566Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4753-5
  a curric:KeyLearningPoint ;
  rdfs:label """The letters c, a and d are all formed by curling round in an anti-clockwise
  direction"""@en ;
  dcterms:modified "2026-06-07T15:30:29.417570Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5326-1
  a curric:KeyLearningPoint ;
  rdfs:label "Answering questions helps us to remember the details of the school trip"@en ;
  dcterms:modified "2026-06-07T15:30:29.417635Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5326-2
  a curric:KeyLearningPoint ;
  rdfs:label "Detail can be added to answers using descriptive adjectives and adverbs"@en ;
  dcterms:modified "2026-06-07T15:30:29.417639Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5326-3
  a curric:KeyLearningPoint ;
  rdfs:label "It is important to share when and where the trip happened in a recount"@en ;
  dcterms:modified "2026-06-07T15:30:29.417643Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5326-4
  a curric:KeyLearningPoint ;
  rdfs:label """Sharing why you went, how you travelled there and what you did adds additional
  information"""@en ;
  dcterms:modified "2026-06-07T15:30:29.417647Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5326-5
  a curric:KeyLearningPoint ;
  rdfs:label """Noting down ideas and key words or phrases about the trip creates a plan for
  writing"""@en ;
  dcterms:modified "2026-06-07T15:30:29.417651Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4761-1
  a curric:KeyLearningPoint ;
  rdfs:label "All the letters have a lead in and a lead out."@en ;
  dcterms:modified "2026-06-07T15:30:29.417656Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4761-2
  a curric:KeyLearningPoint ;
  rdfs:label "Cursive letter joins refer to how the letters connect together."@en ;
  dcterms:modified "2026-06-07T15:30:29.417660Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4761-3
  a curric:KeyLearningPoint ;
  rdfs:label "The pencil does not lift when forming the join."@en ;
  dcterms:modified "2026-06-07T15:30:29.417664Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4761-4
  a curric:KeyLearningPoint ;
  rdfs:label "The letter r lead out has a dip down to aid joining."@en ;
  dcterms:modified "2026-06-07T15:30:29.417668Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4761-5
  a curric:KeyLearningPoint ;
  rdfs:label "The letter w lead out finishes with a dip to aid joining."@en ;
  dcterms:modified "2026-06-07T15:30:29.417672Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4771-1
  a curric:KeyLearningPoint ;
  rdfs:label "The letters are formed by following the right starting point and direction."@en ;
  dcterms:modified "2026-06-07T15:30:29.417676Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4771-2
  a curric:KeyLearningPoint ;
  rdfs:label "Cursive letter joins refer to how the letters connect together."@en ;
  dcterms:modified "2026-06-07T15:30:29.417680Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4771-3
  a curric:KeyLearningPoint ;
  rdfs:label "The pencil does not lift when forming the join."@en ;
  dcterms:modified "2026-06-07T15:30:29.417684Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4771-4
  a curric:KeyLearningPoint ;
  rdfs:label "The first join goes from the baseline to the x-height line."@en ;
  dcterms:modified "2026-06-07T15:30:29.417689Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4771-5
  a curric:KeyLearningPoint ;
  rdfs:label "The dot for the letter i gets added once the letter string is complete."@en ;
  dcterms:modified "2026-06-07T15:30:29.417695Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7195-1
  a curric:KeyLearningPoint ;
  rdfs:label "Mandy Coe is a poet and is known for writing imaginative poetry for children."@en ;
  dcterms:modified "2026-06-07T15:30:29.417701Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7195-2
  a curric:KeyLearningPoint ;
  rdfs:label """‘If You Could See Laughter’ by Mandy Coe is a poem about what laughter would look
  like if you could actually see it."""@en ;
  dcterms:modified "2026-06-07T15:30:29.417706Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7195-3
  a curric:KeyLearningPoint ;
  rdfs:label "The poem is imaginative and creates vivid imagery in the reader’s mind."@en ;
  dcterms:modified "2026-06-07T15:30:29.417710Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7195-4
  a curric:KeyLearningPoint ;
  rdfs:label "The poem explores themes of the joys of childhood and imagination."@en ;
  dcterms:modified "2026-06-07T15:30:29.417716Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7195-5
  a curric:KeyLearningPoint ;
  rdfs:label "We can read with expression to convey a sense of fun and joy."@en ;
  dcterms:modified "2026-06-07T15:30:29.417721Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5325-1
  a curric:KeyLearningPoint ;
  rdfs:label "A recount is a type of writing which retells something that has already happened"@en ;
  dcterms:modified "2026-06-07T15:30:29.419833Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5325-2
  a curric:KeyLearningPoint ;
  rdfs:label "Recounts are mostly told in chronological or time order"@en ;
  dcterms:modified "2026-06-07T15:30:29.419837Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5325-3
  a curric:KeyLearningPoint ;
  rdfs:label "Recounts are mostly written in the first person using 'I', 'me' and 'my'"@en ;
  dcterms:modified "2026-06-07T15:30:29.419841Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5325-4
  a curric:KeyLearningPoint ;
  rdfs:label "Personal recounts can include facts and opinions"@en ;
  dcterms:modified "2026-06-07T15:30:29.419845Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5325-5
  a curric:KeyLearningPoint ;
  rdfs:label "Recounts are told in the past tense"@en ;
  dcterms:modified "2026-06-07T15:30:29.419849Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-30-1
  a curric:KeyLearningPoint ;
  rdfs:label "The letters are all formed by \"going down, up and over\"."@en ;
  dcterms:modified "2026-06-07T15:30:29.421026Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-30-2
  a curric:KeyLearningPoint ;
  rdfs:label "The letters m, n and r are all x-height letters."@en ;
  dcterms:modified "2026-06-07T15:30:29.421030Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-30-3
  a curric:KeyLearningPoint ;
  rdfs:label "The letters m, n and r are in the same letter family."@en ;
  dcterms:modified "2026-06-07T15:30:29.421034Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-904-1
  a curric:KeyLearningPoint ;
  rdfs:label "Verbs are doing words."@en ;
  dcterms:modified "2026-06-07T15:30:29.421038Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-904-2
  a curric:KeyLearningPoint ;
  rdfs:label "Verbs agree with the noun they are paired with."@en ;
  dcterms:modified "2026-06-07T15:30:29.421042Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-904-3
  a curric:KeyLearningPoint ;
  rdfs:label "A complete sentence must contain a verb."@en ;
  dcterms:modified "2026-06-07T15:30:29.421048Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-904-4
  a curric:KeyLearningPoint ;
  rdfs:label "A doing verb can be the only verb in a complete sentence."@en ;
  dcterms:modified "2026-06-07T15:30:29.421053Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5193-1
  a curric:KeyLearningPoint ;
  rdfs:label """Traditional tales are stories that are retold again and again and can be retold in
  different ways."""@en ;
  dcterms:modified "2026-06-07T15:30:29.421057Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5193-2
  a curric:KeyLearningPoint ;
  rdfs:label "Traditional tales can be set in real or fictional places."@en ;
  dcterms:modified "2026-06-07T15:30:29.421061Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5193-3
  a curric:KeyLearningPoint ;
  rdfs:label "Some traditional tales have magical aspects such as magical potions."@en ;
  dcterms:modified "2026-06-07T15:30:29.421065Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5193-4
  a curric:KeyLearningPoint ;
  rdfs:label """Lots of traditional tales involve talking animals or characters being turned into
  animals."""@en ;
  dcterms:modified "2026-06-07T15:30:29.421069Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5193-5
  a curric:KeyLearningPoint ;
  rdfs:label "Traditional tales often have heroes and villains. The villain is the stepmother."@en ;
  dcterms:modified "2026-06-07T15:30:29.421073Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6167-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the build-up is to develop the plot/characters, introduce a problem
  and build up tension and excitement."""@en ;
  dcterms:modified "2026-06-07T15:30:29.421079Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6167-2
  a curric:KeyLearningPoint ;
  rdfs:label "Our plan will contain ambitious vocabulary."@en ;
  dcterms:modified "2026-06-07T15:30:29.421084Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6167-3
  a curric:KeyLearningPoint ;
  rdfs:label "Our plan will contain nouns, adjectives, verbs and adverbs."@en ;
  dcterms:modified "2026-06-07T15:30:29.421090Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6167-4
  a curric:KeyLearningPoint ;
  rdfs:label """Using ambitious vocabulary helps to paint a vivid picture in the reader’s mind and
  make writing exciting to read."""@en ;
  dcterms:modified "2026-06-07T15:30:29.421095Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5410-1
  a curric:KeyLearningPoint ;
  rdfs:label "The contents page can help direct you to a particular topic, such as 'feeding'."@en ;
  dcterms:modified "2026-06-07T15:30:29.421099Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5410-2
  a curric:KeyLearningPoint ;
  rdfs:label """Non-fiction books have photographs, captions and headings to make the information
  easier to understand."""@en ;
  dcterms:modified "2026-06-07T15:30:29.421103Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5410-3
  a curric:KeyLearningPoint ;
  rdfs:label """Non-fiction books teach information about a topic, such as how to care for a cat or
  kitten."""@en ;
  dcterms:modified "2026-06-07T15:30:29.421107Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5410-4
  a curric:KeyLearningPoint ;
  rdfs:label """Re-listening to or re-reading a page from a non-fiction book helps to retain and
  recall facts."""@en ;
  dcterms:modified "2026-06-07T15:30:29.421111Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8835-1
  a curric:KeyLearningPoint ;
  rdfs:label "A person's actions and words can tell us about their character."@en ;
  dcterms:modified "2026-06-07T15:30:29.421115Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8835-2
  a curric:KeyLearningPoint ;
  rdfs:label """Emmeline Pankhurst showed determination and bravery in pursuit of fighting for
  women's rights."""@en ;
  dcterms:modified "2026-06-07T15:30:29.421119Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8835-3
  a curric:KeyLearningPoint ;
  rdfs:label "Emmeline Pankhurst showed resilience and never gave up."@en ;
  dcterms:modified "2026-06-07T15:30:29.421123Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8835-4
  a curric:KeyLearningPoint ;
  rdfs:label "Emmeline Pankhurst influenced many others through her actions."@en ;
  dcterms:modified "2026-06-07T15:30:29.421129Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8835-5
  a curric:KeyLearningPoint ;
  rdfs:label "Emmeline Pankhurst contributed to significant historical change."@en ;
  dcterms:modified "2026-06-07T15:30:29.421133Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-924-1
  a curric:KeyLearningPoint ;
  rdfs:label "'ee' and 'ea' are common spellings of the 'ee' phoneme."@en ;
  dcterms:modified "2026-06-07T15:30:29.421138Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-924-2
  a curric:KeyLearningPoint ;
  rdfs:label """'e-e' is a representation of the 'ee' phoneme that is often found 'last but
  one'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.421142Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-924-3
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the common exception words 'find', 'kind', 'mind' and 'behind'."@en ;
  dcterms:modified "2026-06-07T15:30:29.421146Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8901-1
  a curric:KeyLearningPoint ;
  rdfs:label "Reading a story helps us to consider themes or big ideas told through the plot"@en ;
  dcterms:modified "2026-06-07T15:30:29.421150Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8901-2
  a curric:KeyLearningPoint ;
  rdfs:label """A character's feelings and emotions change depending on what they are doing or what
  challenges they may be facing"""@en ;
  dcterms:modified "2026-06-07T15:30:29.421154Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8901-3
  a curric:KeyLearningPoint ;
  rdfs:label "Some adjectives describe feelings and emotions"@en ;
  dcterms:modified "2026-06-07T15:30:29.421158Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8901-4
  a curric:KeyLearningPoint ;
  rdfs:label """Linking our own experiences to what we are reading helps us to understand the
  characters' feelings and actions"""@en ;
  dcterms:modified "2026-06-07T15:30:29.421162Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8901-5
  a curric:KeyLearningPoint ;
  rdfs:label """Resilience means never giving up and keeping trying even when things may be
  difficult"""@en ;
  dcterms:modified "2026-06-07T15:30:29.421166Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7178-1
  a curric:KeyLearningPoint ;
  rdfs:label """Emotions can be different and shown in different ways, so descriptions must be
  chosen carefully"""@en ;
  dcterms:modified "2026-06-07T15:30:29.421213Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7178-2
  a curric:KeyLearningPoint ;
  rdfs:label "An emotion describes how someone is feeling"@en ;
  dcterms:modified "2026-06-07T15:30:29.421220Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7178-3
  a curric:KeyLearningPoint ;
  rdfs:label "A character can feel different emotions at different points of a story"@en ;
  dcterms:modified "2026-06-07T15:30:29.421224Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7178-4
  a curric:KeyLearningPoint ;
  rdfs:label """Including a range of adjectives to describe the same feeling stops repetition and
  makes writing more interesting"""@en ;
  dcterms:modified "2026-06-07T15:30:29.421230Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7178-5
  a curric:KeyLearningPoint ;
  rdfs:label """Adverbs can be used to show how someone feels when they do something, such as
  'counts quietly' or 'cartwheels happily'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.421235Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-915-1
  a curric:KeyLearningPoint ;
  rdfs:label "'And' is a type of joining word."@en ;
  dcterms:modified "2026-06-07T15:30:29.421239Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-915-2
  a curric:KeyLearningPoint ;
  rdfs:label "Joining two simple sentences with 'and' forms a compound sentence."@en ;
  dcterms:modified "2026-06-07T15:30:29.421243Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-915-3
  a curric:KeyLearningPoint ;
  rdfs:label "The second idea builds on to the first idea if 'and' is used to join them."@en ;
  dcterms:modified "2026-06-07T15:30:29.421247Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-915-4
  a curric:KeyLearningPoint ;
  rdfs:label "Each of the two ideas holds equal grammatical weight in the sentence."@en ;
  dcterms:modified "2026-06-07T15:30:29.421251Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-915-5
  a curric:KeyLearningPoint ;
  rdfs:label """Grammatically accurate sentences start with capital letters and most often end with
  full stops."""@en ;
  dcterms:modified "2026-06-07T15:30:29.421255Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27623-1
  a curric:KeyLearningPoint ;
  rdfs:label """A conversation is when two or more people take turns talking and listening to each
  other."""@en ;
  dcterms:modified "2026-06-07T15:30:29.421259Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27623-2
  a curric:KeyLearningPoint ;
  rdfs:label "Listening when someone else is speaking is important in a conversation."@en ;
  dcterms:modified "2026-06-07T15:30:29.421263Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27623-3
  a curric:KeyLearningPoint ;
  rdfs:label """Sharing your opinion and explaining why you have that opinion is important in a
  conversation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.421267Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27623-4
  a curric:KeyLearningPoint ;
  rdfs:label "Asking and answering questions are important parts of having a conversation."@en ;
  dcterms:modified "2026-06-07T15:30:29.421271Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29017-1
  a curric:KeyLearningPoint ;
  rdfs:label """Retelling a story helps us to remember the main events and use storytelling
  language, such as 'Once upon a time,'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.421276Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29017-2
  a curric:KeyLearningPoint ;
  rdfs:label "Story mountains map out the beginning, middle and end of a story."@en ;
  dcterms:modified "2026-06-07T15:30:29.421280Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29017-3
  a curric:KeyLearningPoint ;
  rdfs:label "Traditional tales often have repeated main events."@en ;
  dcterms:modified "2026-06-07T15:30:29.421286Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29017-4
  a curric:KeyLearningPoint ;
  rdfs:label """Using sequencing language such as 'The next day,' at the start of the sentence helps
  the reader follow the story."""@en ;
  dcterms:modified "2026-06-07T15:30:29.421290Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29017-5
  a curric:KeyLearningPoint ;
  rdfs:label "Using descriptive language will make the story more interesting when writing."@en ;
  dcterms:modified "2026-06-07T15:30:29.421296Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-931-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘y’ is the most common representation of the 'igh' phoneme when it appears at the
  end of a word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.422079Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-931-2
  a curric:KeyLearningPoint ;
  rdfs:label """‘i’ is a representation of the 'igh' phoneme found in the high frequency words:
  find, kind, mind, wild and behind."""@en ;
  dcterms:modified "2026-06-07T15:30:29.422086Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-931-3
  a curric:KeyLearningPoint ;
  rdfs:label """‘ie’ is a representation of the 'igh' phoneme found in the middle and end of
  words."""@en ;
  dcterms:modified "2026-06-07T15:30:29.422090Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-931-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the common exception words: could, would and should."@en ;
  dcterms:modified "2026-06-07T15:30:29.422095Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8685-1
  a curric:KeyLearningPoint ;
  rdfs:label "Superheroes are fictional characters that have a special superpower"@en ;
  dcterms:modified "2026-06-07T15:30:29.422101Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8685-2
  a curric:KeyLearningPoint ;
  rdfs:label "Superheroes are often described as \"brave\", \"strong\" and \"powerful\""@en ;
  dcterms:modified "2026-06-07T15:30:29.422105Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8685-3
  a curric:KeyLearningPoint ;
  rdfs:label "Superheroes are known for wearing masks and capes"@en ;
  dcterms:modified "2026-06-07T15:30:29.422109Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8685-4
  a curric:KeyLearningPoint ;
  rdfs:label """Predictions can be made using the front cover, the title and information that we
  already know about the topic"""@en ;
  dcterms:modified "2026-06-07T15:30:29.422113Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8685-5
  a curric:KeyLearningPoint ;
  rdfs:label """A front cover often reveals the title, author, illustrator and some
  illustrations"""@en ;
  dcterms:modified "2026-06-07T15:30:29.422119Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6285-1
  a curric:KeyLearningPoint ;
  rdfs:label "Presentations can be spoken aloud to an audience."@en ;
  dcterms:modified "2026-06-07T15:30:29.422124Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6285-2
  a curric:KeyLearningPoint ;
  rdfs:label "Presentations are effective ways to share information."@en ;
  dcterms:modified "2026-06-07T15:30:29.422128Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6285-3
  a curric:KeyLearningPoint ;
  rdfs:label """Presentations should be spoken clearly and at a suitable volume for the space you
  are in."""@en ;
  dcterms:modified "2026-06-07T15:30:29.422132Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29000-1
  a curric:KeyLearningPoint ;
  rdfs:label """Re-reading what has been written so far will help to know what instruction will come
  next."""@en ;
  dcterms:modified "2026-06-07T15:30:29.422136Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29000-2
  a curric:KeyLearningPoint ;
  rdfs:label """Each instruction should be numbered followed by sequencing language, such as ‘4.
  Finally,’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.422140Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29000-3
  a curric:KeyLearningPoint ;
  rdfs:label """Each instruction should include a verb to tell the reader what they should
  be doing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.422144Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29000-4
  a curric:KeyLearningPoint ;
  rdfs:label """Command sentences in non-urgent instruction pages start with a capital letter and
  end with a full stop."""@en ;
  dcterms:modified "2026-06-07T15:30:29.422148Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29000-5
  a curric:KeyLearningPoint ;
  rdfs:label """Reading your writing back and checking the success criteria helps to check that our
  writing makes sense"""@en ;
  dcterms:modified "2026-06-07T15:30:29.422152Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27605-1
  a curric:KeyLearningPoint ;
  rdfs:label """Successful speaking includes speaking loudly and clearly enough for everyone to
  hear."""@en ;
  dcterms:modified "2026-06-07T15:30:29.422156Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27605-2
  a curric:KeyLearningPoint ;
  rdfs:label "Speaking in full sentences helps the listener understand what is being said."@en ;
  dcterms:modified "2026-06-07T15:30:29.422160Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27605-3
  a curric:KeyLearningPoint ;
  rdfs:label """When retelling a story with someone, it is important to take turns and listen to
  what the other person is saying."""@en ;
  dcterms:modified "2026-06-07T15:30:29.422166Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27605-4
  a curric:KeyLearningPoint ;
  rdfs:label "Storytelling language can help a listener to understand and enjoy a story."@en ;
  dcterms:modified "2026-06-07T15:30:29.422171Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-966-1
  a curric:KeyLearningPoint ;
  rdfs:label """A suffix is a letter or group of letters at the end of a word which creates another
  word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.422175Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-966-2
  a curric:KeyLearningPoint ;
  rdfs:label "Adding '-s' or '-es' to a noun creates a plural."@en ;
  dcterms:modified "2026-06-07T15:30:29.422179Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-966-3
  a curric:KeyLearningPoint ;
  rdfs:label "The 'y' is changed to 'i' before '-es' is added."@en ;
  dcterms:modified "2026-06-07T15:30:29.422184Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7197-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘The Magic Box’ by Kit Wright is a poem about putting a variety of unique and
  wonderful items into a special box."""@en ;
  dcterms:modified "2026-06-07T15:30:29.422188Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7197-2
  a curric:KeyLearningPoint ;
  rdfs:label "We can use poems by other poets as inspiration for our own poetry."@en ;
  dcterms:modified "2026-06-07T15:30:29.422192Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7197-3
  a curric:KeyLearningPoint ;
  rdfs:label "The structure of a poem is how it is organised and put together."@en ;
  dcterms:modified "2026-06-07T15:30:29.422198Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7197-4
  a curric:KeyLearningPoint ;
  rdfs:label "‘The Magic Box’ is organised into verses that mostly follow the same structure."@en ;
  dcterms:modified "2026-06-07T15:30:29.422202Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7197-5
  a curric:KeyLearningPoint ;
  rdfs:label "Kit Wright is well-known for using contrasts in his poems."@en ;
  dcterms:modified "2026-06-07T15:30:29.422206Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8888-1
  a curric:KeyLearningPoint ;
  rdfs:label "Fiction is a story which is made up or imagined."@en ;
  dcterms:modified "2026-06-07T15:30:29.422210Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8888-2
  a curric:KeyLearningPoint ;
  rdfs:label "The opening of a story introduces the characters and the setting."@en ;
  dcterms:modified "2026-06-07T15:30:29.422215Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8888-3
  a curric:KeyLearningPoint ;
  rdfs:label "Plop is a baby barn owl who is afraid of the dark."@en ;
  dcterms:modified "2026-06-07T15:30:29.422219Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8888-4
  a curric:KeyLearningPoint ;
  rdfs:label "Plop's mother wants Plop to learn not to be afraid of the dark."@en ;
  dcterms:modified "2026-06-07T15:30:29.422223Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4790-1
  a curric:KeyLearningPoint ;
  rdfs:label "Common exception words do not follow regular spelling or phonics rules."@en ;
  dcterms:modified "2026-06-07T15:30:29.426806Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4790-2
  a curric:KeyLearningPoint ;
  rdfs:label """Letters in the common exception words will be joined using a range of joins
  depending on the letters in the word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.426810Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4790-3
  a curric:KeyLearningPoint ;
  rdfs:label "The first letter always has a lead in and the last letter always has a lead out."@en ;
  dcterms:modified "2026-06-07T15:30:29.426815Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4790-4
  a curric:KeyLearningPoint ;
  rdfs:label "There is appropriate spacing between the letters."@en ;
  dcterms:modified "2026-06-07T15:30:29.426819Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4790-5
  a curric:KeyLearningPoint ;
  rdfs:label """You don't lift your pencil to add the 'cross' for the letter t until the letter
  string is complete."""@en ;
  dcterms:modified "2026-06-07T15:30:29.426823Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5649-1
  a curric:KeyLearningPoint ;
  rdfs:label """The introduction of an information text should hook the reader in and make them want
  to read the full report."""@en ;
  dcterms:modified "2026-06-07T15:30:29.426827Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5649-2
  a curric:KeyLearningPoint ;
  rdfs:label "Introductions often contain questions to the reader."@en ;
  dcterms:modified "2026-06-07T15:30:29.426832Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5649-3
  a curric:KeyLearningPoint ;
  rdfs:label """An introduction may contain some general facts and information to gain the reader’s
  interest."""@en ;
  dcterms:modified "2026-06-07T15:30:29.426836Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5649-4
  a curric:KeyLearningPoint ;
  rdfs:label """An introduction may end with a command which is a direct order or instruction
  telling the reader to continue reading."""@en ;
  dcterms:modified "2026-06-07T15:30:29.426840Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8272-1
  a curric:KeyLearningPoint ;
  rdfs:label """Rachel Rooney is a poet and is known for writing imaginative poetry for
  children."""@en ;
  dcterms:modified "2026-06-07T15:30:29.427062Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8272-2
  a curric:KeyLearningPoint ;
  rdfs:label """‘Wide Open’ by Rachel Rooney is a poem about a special eye that can see
  anything."""@en ;
  dcterms:modified "2026-06-07T15:30:29.427067Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8272-3
  a curric:KeyLearningPoint ;
  rdfs:label "The poem is imaginative and has themes of wonder and discovery."@en ;
  dcterms:modified "2026-06-07T15:30:29.427071Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8272-4
  a curric:KeyLearningPoint ;
  rdfs:label "The poem explores themes of imagination, wonder and discovery."@en ;
  dcterms:modified "2026-06-07T15:30:29.427075Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4781-1
  a curric:KeyLearningPoint ;
  rdfs:label "The letters are formed by following the right starting point and direction."@en ;
  dcterms:modified "2026-06-07T15:30:29.427681Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4781-2
  a curric:KeyLearningPoint ;
  rdfs:label "The fourth join goes from the x-height line up towards the ascender line."@en ;
  dcterms:modified "2026-06-07T15:30:29.427685Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4781-3
  a curric:KeyLearningPoint ;
  rdfs:label """The letters l and k reach up to the ascender line. The letter t reaches between the
  x-height line and the ascender line."""@en ;
  dcterms:modified "2026-06-07T15:30:29.427689Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4781-4
  a curric:KeyLearningPoint ;
  rdfs:label "You do not lift your pencil when joining until the letter string is complete."@en ;
  dcterms:modified "2026-06-07T15:30:29.427693Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4781-5
  a curric:KeyLearningPoint ;
  rdfs:label "The cross for the letter t is added once the letter string is complete."@en ;
  dcterms:modified "2026-06-07T15:30:29.427698Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6842-1
  a curric:KeyLearningPoint ;
  rdfs:label """Retelling a story helps us to remember the main events in a story and think about
  the different parts."""@en ;
  dcterms:modified "2026-06-07T15:30:29.427758Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6842-2
  a curric:KeyLearningPoint ;
  rdfs:label "Some events in a story can be joined using a joining \"and\"."@en ;
  dcterms:modified "2026-06-07T15:30:29.427762Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6842-3
  a curric:KeyLearningPoint ;
  rdfs:label "Story mountains map out the beginning, middle and end."@en ;
  dcterms:modified "2026-06-07T15:30:29.427766Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6842-4
  a curric:KeyLearningPoint ;
  rdfs:label """Powerful adjectives can be added to a story mountain, such as \"ferocious\",
  \"vibrant\" and \"playful\"."""@en ;
  dcterms:modified "2026-06-07T15:30:29.427770Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6842-5
  a curric:KeyLearningPoint ;
  rdfs:label """Retelling the story in the first person means we have to imagine we are the main
  character."""@en ;
  dcterms:modified "2026-06-07T15:30:29.427774Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5148-1
  a curric:KeyLearningPoint ;
  rdfs:label """Summarising what we have read can help us to remember and understand a story
  better."""@en ;
  dcterms:modified "2026-06-07T15:30:29.427821Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5148-2
  a curric:KeyLearningPoint ;
  rdfs:label """Skimming and scanning using your finger is a way to retrieve information quickly and
  accurately from a text."""@en ;
  dcterms:modified "2026-06-07T15:30:29.427825Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5148-3
  a curric:KeyLearningPoint ;
  rdfs:label "Searching for capital letters helps us to find proper nouns quickly."@en ;
  dcterms:modified "2026-06-07T15:30:29.427829Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5148-4
  a curric:KeyLearningPoint ;
  rdfs:label "Searching for keywords can help us find answers quickly."@en ;
  dcterms:modified "2026-06-07T15:30:29.427833Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5148-5
  a curric:KeyLearningPoint ;
  rdfs:label "Responding to texts with discussions can help to deepen our understanding."@en ;
  dcterms:modified "2026-06-07T15:30:29.427837Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-913-1
  a curric:KeyLearningPoint ;
  rdfs:label "There are four types of simple sentence."@en ;
  dcterms:modified "2026-06-07T15:30:29.430584Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-913-2
  a curric:KeyLearningPoint ;
  rdfs:label "Any simple sentence is a sentence about one idea that makes complete sense."@en ;
  dcterms:modified "2026-06-07T15:30:29.430589Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-913-3
  a curric:KeyLearningPoint ;
  rdfs:label "Each type of simple sentence has a different purpose for the reader."@en ;
  dcterms:modified "2026-06-07T15:30:29.430595Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-913-4
  a curric:KeyLearningPoint ;
  rdfs:label """A statement often ends with a full stop, a question with a question mark and a
  command can end with an exclamation mark."""@en ;
  dcterms:modified "2026-06-07T15:30:29.430599Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-913-5
  a curric:KeyLearningPoint ;
  rdfs:label "A command starts with an imperative verb."@en ;
  dcterms:modified "2026-06-07T15:30:29.430604Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6212-1
  a curric:KeyLearningPoint ;
  rdfs:label "A recount will involve you describing events and experiences in detail."@en ;
  dcterms:modified "2026-06-07T15:30:29.430608Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6212-2
  a curric:KeyLearningPoint ;
  rdfs:label """An expanded noun phrase is a group of words with no verb that adds detail to
  a noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.430614Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6212-3
  a curric:KeyLearningPoint ;
  rdfs:label "Expanded noun phrases contain two adjectives, separated by a comma."@en ;
  dcterms:modified "2026-06-07T15:30:29.430620Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6212-4
  a curric:KeyLearningPoint ;
  rdfs:label "When we write a plan, we use notes."@en ;
  dcterms:modified "2026-06-07T15:30:29.430626Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-907-1
  a curric:KeyLearningPoint ;
  rdfs:label "The tense of a simple sentence changes the time frame of the action."@en ;
  dcterms:modified "2026-06-07T15:30:29.430631Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-907-2
  a curric:KeyLearningPoint ;
  rdfs:label "Fronted adverbials of time tell the reader the time frame of the action."@en ;
  dcterms:modified "2026-06-07T15:30:29.430635Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-907-3
  a curric:KeyLearningPoint ;
  rdfs:label "A simple sentence is about one idea."@en ;
  dcterms:modified "2026-06-07T15:30:29.430639Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-907-4
  a curric:KeyLearningPoint ;
  rdfs:label "A simple sentence makes complete sense."@en ;
  dcterms:modified "2026-06-07T15:30:29.430643Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29019-1
  a curric:KeyLearningPoint ;
  rdfs:label """Traditional tales often have repeated elements, making them easier to remember and
  retell."""@en ;
  dcterms:modified "2026-06-07T15:30:29.430647Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29019-2
  a curric:KeyLearningPoint ;
  rdfs:label """The repeated element of ‘The Three Little Pigs’ is each pig building their house to
  have it blown down by the wolf."""@en ;
  dcterms:modified "2026-06-07T15:30:29.430651Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29019-3
  a curric:KeyLearningPoint ;
  rdfs:label """The pig building the house and the wolf blowing it down are two ideas that are
  related, so can be joined using ‘and’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.430655Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29019-4
  a curric:KeyLearningPoint ;
  rdfs:label """Adjectives can be used to describe things and characters, such as the houses and the
  wolf."""@en ;
  dcterms:modified "2026-06-07T15:30:29.430659Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29019-5
  a curric:KeyLearningPoint ;
  rdfs:label """When using more than one adjective to describe a noun, they must be separated with a
  comma."""@en ;
  dcterms:modified "2026-06-07T15:30:29.430663Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5114-1
  a curric:KeyLearningPoint ;
  rdfs:label """The part of the letter that reaches above the x-height line is called the
  ascender"""@en ;
  dcterms:modified "2026-06-07T15:30:29.430667Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5114-2
  a curric:KeyLearningPoint ;
  rdfs:label "The letters b, d, h, k and l all have starting points on the ascender line"@en ;
  dcterms:modified "2026-06-07T15:30:29.430672Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5114-3
  a curric:KeyLearningPoint ;
  rdfs:label """The letters f and t have starting points between the x-height line and the ascender
  line"""@en ;
  dcterms:modified "2026-06-07T15:30:29.430676Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5114-4
  a curric:KeyLearningPoint ;
  rdfs:label "The letters with ascenders are b, d, h, k, l, f and t"@en ;
  dcterms:modified "2026-06-07T15:30:29.430680Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27906-1
  a curric:KeyLearningPoint ;
  rdfs:label "Standing to speak helps to get the audience's attention."@en ;
  dcterms:modified "2026-06-07T15:30:29.434011Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27906-2
  a curric:KeyLearningPoint ;
  rdfs:label """Successful speaking includes speaking loudly and clearly enough for everyone to
  hear."""@en ;
  dcterms:modified "2026-06-07T15:30:29.434016Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27906-3
  a curric:KeyLearningPoint ;
  rdfs:label """Successful listening includes looking at the person speaking and paying close
  attention."""@en ;
  dcterms:modified "2026-06-07T15:30:29.434019Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27906-4
  a curric:KeyLearningPoint ;
  rdfs:label "Speaking with volume helps to hold an audience's attention."@en ;
  dcterms:modified "2026-06-07T15:30:29.434024Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27906-5
  a curric:KeyLearningPoint ;
  rdfs:label "Actions and sound effects help add to a poem's meaning."@en ;
  dcterms:modified "2026-06-07T15:30:29.434028Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8904-1
  a curric:KeyLearningPoint ;
  rdfs:label """An aspiration is a hope or ambition of achieving something, such as what someone
  wants to be when they grow up"""@en ;
  dcterms:modified "2026-06-07T15:30:29.434066Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8904-2
  a curric:KeyLearningPoint ;
  rdfs:label """To achieve an ambition or goal, a person must work for it and have certain character
  traits"""@en ;
  dcterms:modified "2026-06-07T15:30:29.434073Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8904-3
  a curric:KeyLearningPoint ;
  rdfs:label """Someone's future ambition may be different to another person's and it is important
  to respect other people's opinions"""@en ;
  dcterms:modified "2026-06-07T15:30:29.434077Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8904-4
  a curric:KeyLearningPoint ;
  rdfs:label "Certain character traits can be linked to specific ambitions or aspirations"@en ;
  dcterms:modified "2026-06-07T15:30:29.434081Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-940-1
  a curric:KeyLearningPoint ;
  rdfs:label """Two or more words that sound the same but have different meanings or spellings are
  called homophones."""@en ;
  dcterms:modified "2026-06-07T15:30:29.434354Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-940-2
  a curric:KeyLearningPoint ;
  rdfs:label "'There', 'their' and 'they're' are homophones."@en ;
  dcterms:modified "2026-06-07T15:30:29.434359Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-940-3
  a curric:KeyLearningPoint ;
  rdfs:label "'To', 'too' and 'two' are homophones."@en ;
  dcterms:modified "2026-06-07T15:30:29.434363Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-940-4
  a curric:KeyLearningPoint ;
  rdfs:label "'Won' and 'one' are homophones."@en ;
  dcterms:modified "2026-06-07T15:30:29.434367Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-940-5
  a curric:KeyLearningPoint ;
  rdfs:label "'Our', 'hour' and 'are' are homophones."@en ;
  dcterms:modified "2026-06-07T15:30:29.434403Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-954-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘aw’ is a representation of the 'or' phoneme that often comes at the end of a word
  and sometimes in the middle."""@en ;
  dcterms:modified "2026-06-07T15:30:29.434568Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-954-2
  a curric:KeyLearningPoint ;
  rdfs:label """‘oor’ is a representation of the 'or' phoneme that sometimes comes at the end of a
  word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.434572Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-954-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Paw' and 'poor' are homophones."@en ;
  dcterms:modified "2026-06-07T15:30:29.434576Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-954-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the common exception words: people, Mr and Mrs."@en ;
  dcterms:modified "2026-06-07T15:30:29.434581Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4786-1
  a curric:KeyLearningPoint ;
  rdfs:label "A capital letter is the upper case formation of a letter."@en ;
  dcterms:modified "2026-06-07T15:30:29.434587Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4786-2
  a curric:KeyLearningPoint ;
  rdfs:label "The letters B, D, P, R, I, E, F and L all start on the ascender line."@en ;
  dcterms:modified "2026-06-07T15:30:29.434591Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4786-3
  a curric:KeyLearningPoint ;
  rdfs:label """The capital letters B, D, P, R and L are formed by one continuous movement and you
  do not need to lift your pencil."""@en ;
  dcterms:modified "2026-06-07T15:30:29.434595Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4786-4
  a curric:KeyLearningPoint ;
  rdfs:label """The letters B, D, P and R all make a vertical line down, go back up and around in a
  clockwise direction."""@en ;
  dcterms:modified "2026-06-07T15:30:29.434605Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4786-5
  a curric:KeyLearningPoint ;
  rdfs:label """The letters I, E and F need the pencil to be lifted to form the horizontal
  lines."""@en ;
  dcterms:modified "2026-06-07T15:30:29.434609Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6185-1
  a curric:KeyLearningPoint ;
  rdfs:label "A non-chronological report is a type of non-fiction text."@en ;
  dcterms:modified "2026-06-07T15:30:29.434861Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6185-2
  a curric:KeyLearningPoint ;
  rdfs:label "A non-chronological report provides information on a subject, person or event."@en ;
  dcterms:modified "2026-06-07T15:30:29.434865Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6185-3
  a curric:KeyLearningPoint ;
  rdfs:label """Notes are used when making a plan and they are short and only capture key vocabulary
  and important information."""@en ;
  dcterms:modified "2026-06-07T15:30:29.434869Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6185-4
  a curric:KeyLearningPoint ;
  rdfs:label """Notes are not written in full sentences and do not require capital letters, full
  stops or commas."""@en ;
  dcterms:modified "2026-06-07T15:30:29.434876Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6176-1
  a curric:KeyLearningPoint ;
  rdfs:label "An opening will introduce the setting and main characters."@en ;
  dcterms:modified "2026-06-07T15:30:29.434880Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6176-2
  a curric:KeyLearningPoint ;
  rdfs:label "A descriptive opening will contain expanded noun phrases."@en ;
  dcterms:modified "2026-06-07T15:30:29.434884Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6176-3
  a curric:KeyLearningPoint ;
  rdfs:label "A descriptive opening will contain adverbs and verbs."@en ;
  dcterms:modified "2026-06-07T15:30:29.434888Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6176-4
  a curric:KeyLearningPoint ;
  rdfs:label "We can use notes from our plan to form full sentences."@en ;
  dcterms:modified "2026-06-07T15:30:29.434908Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8927-1
  a curric:KeyLearningPoint ;
  rdfs:label """A postcard is written to someone when you are away somewhere, in this case
  Paddington in London."""@en ;
  dcterms:modified "2026-06-07T15:30:29.434929Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8927-2
  a curric:KeyLearningPoint ;
  rdfs:label "Postcards are written in the first person, using 'I', 'me' or 'my'."@en ;
  dcterms:modified "2026-06-07T15:30:29.434933Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8927-3
  a curric:KeyLearningPoint ;
  rdfs:label """Adding descriptive language about places and feelings can help the person reading it
  imagine the experience."""@en ;
  dcterms:modified "2026-06-07T15:30:29.434939Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8927-4
  a curric:KeyLearningPoint ;
  rdfs:label """A postcard needs to start with a greeting to who you are writing to, using 'Dear
  ...' or 'To ...'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.434943Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8927-5
  a curric:KeyLearningPoint ;
  rdfs:label """A list of places you have seen can be included in a postcard, with a comma in
  between and 'and' before the final place."""@en ;
  dcterms:modified "2026-06-07T15:30:29.434947Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4773-1
  a curric:KeyLearningPoint ;
  rdfs:label "The letters are formed by following the right starting point and direction."@en ;
  dcterms:modified "2026-06-07T15:30:29.434971Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4773-2
  a curric:KeyLearningPoint ;
  rdfs:label "Cursive letter joins refer to how the letters connect together."@en ;
  dcterms:modified "2026-06-07T15:30:29.434975Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4773-3
  a curric:KeyLearningPoint ;
  rdfs:label "The pencil does not lift when forming the join."@en ;
  dcterms:modified "2026-06-07T15:30:29.434979Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4773-4
  a curric:KeyLearningPoint ;
  rdfs:label "The second join goes from the baseline to the ascender line."@en ;
  dcterms:modified "2026-06-07T15:30:29.434983Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29014-1
  a curric:KeyLearningPoint ;
  rdfs:label """Adjectives can be used to describe a character's personality, such as 'cunning'
  wolf."""@en ;
  dcterms:modified "2026-06-07T15:30:29.435056Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29014-2
  a curric:KeyLearningPoint ;
  rdfs:label """Adjectives can be used to describe a character's appearance, such as 'furry'
  wolf."""@en ;
  dcterms:modified "2026-06-07T15:30:29.435060Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29014-3
  a curric:KeyLearningPoint ;
  rdfs:label """When you use two adjectives to describe a noun, you need to separate them with a
  comma."""@en ;
  dcterms:modified "2026-06-07T15:30:29.435064Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29014-4
  a curric:KeyLearningPoint ;
  rdfs:label "Two ideas can be joined together using 'and' to form one compound sentence."@en ;
  dcterms:modified "2026-06-07T15:30:29.435069Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29014-5
  a curric:KeyLearningPoint ;
  rdfs:label "In a compound sentence, each idea must make complete sense."@en ;
  dcterms:modified "2026-06-07T15:30:29.435073Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-34-1
  a curric:KeyLearningPoint ;
  rdfs:label "The letters o, g and q are all formed by going round anti-clockwise."@en ;
  dcterms:modified "2026-06-07T15:30:29.435147Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-34-2
  a curric:KeyLearningPoint ;
  rdfs:label "The letters g and q have descenders."@en ;
  dcterms:modified "2026-06-07T15:30:29.435151Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-34-3
  a curric:KeyLearningPoint ;
  rdfs:label "The letter g is formed by \"going round and down and curling up\"."@en ;
  dcterms:modified "2026-06-07T15:30:29.435155Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-34-4
  a curric:KeyLearningPoint ;
  rdfs:label """The letter q is formed by \"going round and down and a diagonal line out to the
  side\"."""@en ;
  dcterms:modified "2026-06-07T15:30:29.435159Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-38-1
  a curric:KeyLearningPoint ;
  rdfs:label "The part of the letter that goes below the baseline is called the descender"@en ;
  dcterms:modified "2026-06-07T15:30:29.435300Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-38-2
  a curric:KeyLearningPoint ;
  rdfs:label "Letters with descenders reach down towards the descender line"@en ;
  dcterms:modified "2026-06-07T15:30:29.435304Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-38-3
  a curric:KeyLearningPoint ;
  rdfs:label "The letters g, j, p, q and y all start on the x-height line"@en ;
  dcterms:modified "2026-06-07T15:30:29.435310Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-38-4
  a curric:KeyLearningPoint ;
  rdfs:label "The letters with descenders are: g, j, p, q, f and y"@en ;
  dcterms:modified "2026-06-07T15:30:29.435315Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-932-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘ow’ is a representation of the 'oa' phoneme that often comes at the end of
  a word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.438300Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-932-2
  a curric:KeyLearningPoint ;
  rdfs:label """‘o-e’ is a representation of the 'oa' phoneme that is often found 'last but
  one'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.438305Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-932-3
  a curric:KeyLearningPoint ;
  rdfs:label """‘oa’ is a representation of the 'oa' phoneme that is often found in the middle of a
  word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.438309Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-932-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the common exception words: who and how."@en ;
  dcterms:modified "2026-06-07T15:30:29.438313Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28942-1
  a curric:KeyLearningPoint ;
  rdfs:label "Matt Goodfellow is an award-winning poet and former teacher."@en ;
  dcterms:modified "2026-06-07T15:30:29.438317Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28942-2
  a curric:KeyLearningPoint ;
  rdfs:label "The poem ‘River Lullaby’ tells a story about the journey of a river."@en ;
  dcterms:modified "2026-06-07T15:30:29.438321Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28942-3
  a curric:KeyLearningPoint ;
  rdfs:label """The poet uses different poetic devices including onomatopoeia, alliteration and
  repetition."""@en ;
  dcterms:modified "2026-06-07T15:30:29.438325Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28942-4
  a curric:KeyLearningPoint ;
  rdfs:label "When performing a poem, we should try to have fun."@en ;
  dcterms:modified "2026-06-07T15:30:29.438329Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28942-5
  a curric:KeyLearningPoint ;
  rdfs:label """Using gestures can make our performances fun and interesting for the audience to
  watch."""@en ;
  dcterms:modified "2026-06-07T15:30:29.438333Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-962-1
  a curric:KeyLearningPoint ;
  rdfs:label """A suffix is a letter or group of letters at the end of a word which creates another
  word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.438340Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-962-2
  a curric:KeyLearningPoint ;
  rdfs:label """If the suffix starts with a consonant letter, it is usually added without any change
  to the root word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.438344Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-962-3
  a curric:KeyLearningPoint ;
  rdfs:label """If a root word has more than one syllable and ends in a consonant + 'y', then 'y' is
  replaced by 'i' before the suffix."""@en ;
  dcterms:modified "2026-06-07T15:30:29.438348Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-962-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the common exception word: whole."@en ;
  dcterms:modified "2026-06-07T15:30:29.438352Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4783-1
  a curric:KeyLearningPoint ;
  rdfs:label """Cursive handwriting involves joining letters together without lifting your
  pencil."""@en ;
  dcterms:modified "2026-06-07T15:30:29.438356Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4783-2
  a curric:KeyLearningPoint ;
  rdfs:label "The first join connects from the baseline to the x-height line."@en ;
  dcterms:modified "2026-06-07T15:30:29.438360Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4783-3
  a curric:KeyLearningPoint ;
  rdfs:label "The second join connects from the baseline to the ascender line."@en ;
  dcterms:modified "2026-06-07T15:30:29.438366Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4783-4
  a curric:KeyLearningPoint ;
  rdfs:label "The third join connects from the x-height line to the x-height line."@en ;
  dcterms:modified "2026-06-07T15:30:29.438371Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4783-5
  a curric:KeyLearningPoint ;
  rdfs:label "The fourth join connects from the x-height line to the ascender line."@en ;
  dcterms:modified "2026-06-07T15:30:29.438375Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5653-1
  a curric:KeyLearningPoint ;
  rdfs:label """A subheading is a mini-heading given to a paragraph within a main piece of
  writing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.438379Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5653-2
  a curric:KeyLearningPoint ;
  rdfs:label "Formal fronted adverbials link two sentences together."@en ;
  dcterms:modified "2026-06-07T15:30:29.438383Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5653-3
  a curric:KeyLearningPoint ;
  rdfs:label """The second section of the report should inform the reader of how the fire spread and
  stopped."""@en ;
  dcterms:modified "2026-06-07T15:30:29.438387Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6844-1
  a curric:KeyLearningPoint ;
  rdfs:label """Adverbs of time sequence events in the story, and can be used at the start of a
  sentence, such as \"One day,\"."""@en ;
  dcterms:modified "2026-06-07T15:30:29.438391Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6844-2
  a curric:KeyLearningPoint ;
  rdfs:label """Adverbs of manner describe how characters move and speak, such as \"roughly\" or
  \"weirdly\"."""@en ;
  dcterms:modified "2026-06-07T15:30:29.438395Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6844-3
  a curric:KeyLearningPoint ;
  rdfs:label """Exclamation marks can be used to show expression and emotion, such as \"I was fed
  up!\"."""@en ;
  dcterms:modified "2026-06-07T15:30:29.438399Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6844-4
  a curric:KeyLearningPoint ;
  rdfs:label """Writing from the girl's perspective allows us to write about the girl's thoughts,
  such as \"Where were we going?\"."""@en ;
  dcterms:modified "2026-06-07T15:30:29.438403Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6844-5
  a curric:KeyLearningPoint ;
  rdfs:label "Two ideas can be joined using the joining word \"and\"."@en ;
  dcterms:modified "2026-06-07T15:30:29.438407Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7174-1
  a curric:KeyLearningPoint ;
  rdfs:label "Recalling events in the story helps to summarise the most important parts"@en ;
  dcterms:modified "2026-06-07T15:30:29.584880Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7174-2
  a curric:KeyLearningPoint ;
  rdfs:label "The actions of a character are what the character does or says"@en ;
  dcterms:modified "2026-06-07T15:30:29.584885Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7174-3
  a curric:KeyLearningPoint ;
  rdfs:label """This story is different from traditional tales because it does not have a clear
  beginning, middle and end"""@en ;
  dcterms:modified "2026-06-07T15:30:29.584890Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7174-4
  a curric:KeyLearningPoint ;
  rdfs:label """Instead, this story follows each family member and the discussions that the main
  character has with them"""@en ;
  dcterms:modified "2026-06-07T15:30:29.584894Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7174-5
  a curric:KeyLearningPoint ;
  rdfs:label """This story demonstrates there are different ways to show happiness and explores the
  themes of family and happiness"""@en ;
  dcterms:modified "2026-06-07T15:30:29.584902Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4740-1
  a curric:KeyLearningPoint ;
  rdfs:label "The capital letters I, E, F, and L all start at the top tramline."@en ;
  dcterms:modified "2026-06-07T15:30:29.584908Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4740-2
  a curric:KeyLearningPoint ;
  rdfs:label "The capital letters I, E, F, and L all go straight down."@en ;
  dcterms:modified "2026-06-07T15:30:29.584913Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4740-3
  a curric:KeyLearningPoint ;
  rdfs:label """The formation of capital letters I, E and F need you to lift your pencil to add the
  other horizontal lines."""@en ;
  dcterms:modified "2026-06-07T15:30:29.584918Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6169-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the climax is to describe the problem and create the highest point of
  tension."""@en ;
  dcterms:modified "2026-06-07T15:30:29.584923Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6169-2
  a curric:KeyLearningPoint ;
  rdfs:label "Our plan will contain ambitious vocabulary."@en ;
  dcterms:modified "2026-06-07T15:30:29.584928Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6169-3
  a curric:KeyLearningPoint ;
  rdfs:label "Our plan will contain nouns, adjectives, verbs and adverbs."@en ;
  dcterms:modified "2026-06-07T15:30:29.584935Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6169-4
  a curric:KeyLearningPoint ;
  rdfs:label """Using ambitious vocabulary helps to paint a vivid picture in the reader’s mind and
  make writing exciting to read."""@en ;
  dcterms:modified "2026-06-07T15:30:29.584941Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6173-1
  a curric:KeyLearningPoint ;
  rdfs:label "Sequencing means putting the events in the right order so they make sense."@en ;
  dcterms:modified "2026-06-07T15:30:29.584946Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6173-2
  a curric:KeyLearningPoint ;
  rdfs:label """‘Otherwise’ is an animation which follows Anders, a red chameleon, who is different
  to the others."""@en ;
  dcterms:modified "2026-06-07T15:30:29.584951Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6173-3
  a curric:KeyLearningPoint ;
  rdfs:label "Retell means to summarise a story in your own words."@en ;
  dcterms:modified "2026-06-07T15:30:29.584956Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6173-4
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials of time tell the reader when the events in the sentence took
  place."""@en ;
  dcterms:modified "2026-06-07T15:30:29.584961Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8918-1
  a curric:KeyLearningPoint ;
  rdfs:label "Stories have a beginning, middle and end."@en ;
  dcterms:modified "2026-06-07T15:30:29.585011Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8918-2
  a curric:KeyLearningPoint ;
  rdfs:label """The Paddington book series is now also told through film and television
  programmes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.585016Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8918-3
  a curric:KeyLearningPoint ;
  rdfs:label "Paddington is a a fictional story set in London."@en ;
  dcterms:modified "2026-06-07T15:30:29.585021Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8918-4
  a curric:KeyLearningPoint ;
  rdfs:label """People may have different responses to a story, such as their favourite part and
  favourite character."""@en ;
  dcterms:modified "2026-06-07T15:30:29.585026Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-910-1
  a curric:KeyLearningPoint ;
  rdfs:label "There are four types of simple sentence."@en ;
  dcterms:modified "2026-06-07T15:30:29.585080Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-910-2
  a curric:KeyLearningPoint ;
  rdfs:label "Each type of simple sentence has a different purpose for the reader."@en ;
  dcterms:modified "2026-06-07T15:30:29.585088Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-910-3
  a curric:KeyLearningPoint ;
  rdfs:label "Any simple sentence is a sentence about one idea that makes complete sense."@en ;
  dcterms:modified "2026-06-07T15:30:29.585095Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-910-4
  a curric:KeyLearningPoint ;
  rdfs:label """A question is a simple sentence that asks the reader for an answer and ends with a
  question mark."""@en ;
  dcterms:modified "2026-06-07T15:30:29.585102Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-910-5
  a curric:KeyLearningPoint ;
  rdfs:label """A command is a simple sentence that tells someone to do something and can end with
  an exclamation mark."""@en ;
  dcterms:modified "2026-06-07T15:30:29.585107Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-35-1
  a curric:KeyLearningPoint ;
  rdfs:label "The letters e and s are x-height letters."@en ;
  dcterms:modified "2026-06-07T15:30:29.585137Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-35-2
  a curric:KeyLearningPoint ;
  rdfs:label "The letter is e is formed by \"going across and around\"."@en ;
  dcterms:modified "2026-06-07T15:30:29.585142Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-35-3
  a curric:KeyLearningPoint ;
  rdfs:label """The letter s is formed by \"starting at the top, curling up and around and back
  round again\"."""@en ;
  dcterms:modified "2026-06-07T15:30:29.585147Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-35-4
  a curric:KeyLearningPoint ;
  rdfs:label """The letter f \"starts by curling up, straight down and curls up just above the
  descender line\"."""@en ;
  dcterms:modified "2026-06-07T15:30:29.585152Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-35-5
  a curric:KeyLearningPoint ;
  rdfs:label "The letter f has a cross on the x-height line"@en ;
  dcterms:modified "2026-06-07T15:30:29.585157Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-968-1
  a curric:KeyLearningPoint ;
  rdfs:label """A suffix is a letter or group of letters at the end of a word which creates another
  word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.586446Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-968-2
  a curric:KeyLearningPoint ;
  rdfs:label "Adding '-ing' creates an extra syllable to the word."@en ;
  dcterms:modified "2026-06-07T15:30:29.586451Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-968-3
  a curric:KeyLearningPoint ;
  rdfs:label """If the root word ends in a consonant + 'e', the 'e' is removed before the suffix is
  added."""@en ;
  dcterms:modified "2026-06-07T15:30:29.586456Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-968-4
  a curric:KeyLearningPoint ;
  rdfs:label """If the root word has a short vowel and ends in a consonant, the consonant is doubled
  before the suffix is added."""@en ;
  dcterms:modified "2026-06-07T15:30:29.586461Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-963-1
  a curric:KeyLearningPoint ;
  rdfs:label """A suffix is a letter or group of letters at the end of a word which creates another
  word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.586466Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-963-2
  a curric:KeyLearningPoint ;
  rdfs:label """If the suffix starts with a consonant letter, it is usually added without any change
  to the root word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.586470Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-963-3
  a curric:KeyLearningPoint ;
  rdfs:label """If a root word has more than one syllable and ends in a consonant + 'y', then 'y' is
  replaced by 'i' before the suffix."""@en ;
  dcterms:modified "2026-06-07T15:30:29.586475Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-963-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the common exception word: beautiful."@en ;
  dcterms:modified "2026-06-07T15:30:29.586480Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2714-1
  a curric:KeyLearningPoint ;
  rdfs:label "An apostrophe has more than one purpose."@en ;
  dcterms:modified "2026-06-07T15:30:29.586484Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2714-2
  a curric:KeyLearningPoint ;
  rdfs:label "An apostrophe can show contraction or possession."@en ;
  dcterms:modified "2026-06-07T15:30:29.586491Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2714-3
  a curric:KeyLearningPoint ;
  rdfs:label "It's is the contracted form of 'it is' and does not show possession."@en ;
  dcterms:modified "2026-06-07T15:30:29.586496Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2714-4
  a curric:KeyLearningPoint ;
  rdfs:label "Plural nouns that end in 's' do not use an apostrophe."@en ;
  dcterms:modified "2026-06-07T15:30:29.586501Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4754-1
  a curric:KeyLearningPoint ;
  rdfs:label """The pre-cursive letters o, g and q all have a lead in which starts at the
  baseline"""@en ;
  dcterms:modified "2026-06-07T15:30:29.586510Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4754-2
  a curric:KeyLearningPoint ;
  rdfs:label "The pre-cursive letter o has a lead out at the x-height line"@en ;
  dcterms:modified "2026-06-07T15:30:29.586515Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4754-3
  a curric:KeyLearningPoint ;
  rdfs:label "The pre-cursive letter g has a loop at the end of its descender as the lead out"@en ;
  dcterms:modified "2026-06-07T15:30:29.586520Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4754-4
  a curric:KeyLearningPoint ;
  rdfs:label """The pre-cursive letter q has a diagonal line from the descender line to the baseline
  as the lead out"""@en ;
  dcterms:modified "2026-06-07T15:30:29.586525Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1058-1
  a curric:KeyLearningPoint ;
  rdfs:label """'ear' is a representation of the 'er' phoneme that can ben found at the beginning or
  middle of a word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.586530Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1058-2
  a curric:KeyLearningPoint ;
  rdfs:label """The 'or' representation of the 'er' phoneme is found after a 'w', such as 'word' and
  'worm'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.586535Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1058-3
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the common exception words: said and were."@en ;
  dcterms:modified "2026-06-07T15:30:29.586539Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-944-1
  a curric:KeyLearningPoint ;
  rdfs:label "'gn' can be a representation of the 'n' phoneme."@en ;
  dcterms:modified "2026-06-07T15:30:29.586544Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-944-2
  a curric:KeyLearningPoint ;
  rdfs:label "The representation 'gn' is usually found at the start or end of a word."@en ;
  dcterms:modified "2026-06-07T15:30:29.586549Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-944-3
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the common exception word: school."@en ;
  dcterms:modified "2026-06-07T15:30:29.586554Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-944-4
  a curric:KeyLearningPoint ;
  rdfs:label """Words connected in word families often have similar spellings, such as sign and
  signal."""@en ;
  dcterms:modified "2026-06-07T15:30:29.586558Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28627-1
  a curric:KeyLearningPoint ;
  rdfs:label "James Carter is a poet and he loves words."@en ;
  dcterms:modified "2026-06-07T15:30:29.586631Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28627-2
  a curric:KeyLearningPoint ;
  rdfs:label "‘A Ticket to Kalamazoo!’ is a fun poem about going on an imaginary adventure."@en ;
  dcterms:modified "2026-06-07T15:30:29.586636Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28627-3
  a curric:KeyLearningPoint ;
  rdfs:label """‘A Ticket to Kalamazoo!’ uses rhyme and repetition, which make it fun to say and
  easy to remember."""@en ;
  dcterms:modified "2026-06-07T15:30:29.586640Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28627-4
  a curric:KeyLearningPoint ;
  rdfs:label "When performing a poem, we should speak loudly and slowly."@en ;
  dcterms:modified "2026-06-07T15:30:29.586645Z"^^xsd:dateTime .

