# ----------------------------------------------------------------------
# Key Learning Points
# ----------------------------------------------------------------------

oakcurric:keylearningpoint-lesson-1733-1
  a curric:KeyLearningPoint ;
  rdfs:label """Non-fiction encompasses a wide range of texts and can use literary devices to engage a reader or audience."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481023Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1733-2
  a curric:KeyLearningPoint ;
  rdfs:label "Societal attitudes shift and change."@en ;
  dcterms:modified "2026-02-12T08:59:21.481057Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1733-3
  a curric:KeyLearningPoint ;
  rdfs:label """In the 18th and 19th century it was a societal expectation that people would get married."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481064Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1733-4
  a curric:KeyLearningPoint ;
  rdfs:label "Ideas of femininity were based on stereotypes of gentleness and politeness."@en ;
  dcterms:modified "2026-02-12T08:59:21.481069Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1733-5
  a curric:KeyLearningPoint ;
  rdfs:label "Non-fiction texts can reveal a lot about societal attitudes."@en ;
  dcterms:modified "2026-02-12T08:59:21.481073Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1963-1
  a curric:KeyLearningPoint ;
  rdfs:label """The books in Martha’s room move on their own, introducing an element of the supernatural."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481078Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1963-2
  a curric:KeyLearningPoint ;
  rdfs:label "Ravens help to create an ominous atmosphere in the novel."@en ;
  dcterms:modified "2026-02-12T08:59:21.481082Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1963-3
  a curric:KeyLearningPoint ;
  rdfs:label """Key themes in the novel include the supernatural, good vs. evil, fate and being an outsider."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481091Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1963-4
  a curric:KeyLearningPoint ;
  rdfs:label """A theme is an important idea in a text that is explored in a number of different ways."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481096Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1963-5
  a curric:KeyLearningPoint ;
  rdfs:label """As students of English, the first step is to work out what are a text’s most important themes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481101Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1830-1
  a curric:KeyLearningPoint ;
  rdfs:label "Alliteration is when two or more words start with the same consonant."@en ;
  dcterms:modified "2026-02-12T08:59:21.481134Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1830-2
  a curric:KeyLearningPoint ;
  rdfs:label """A writer makes use of plosives when they use the letters 'p', 't', 'k', 'b', 'd' or 'g' for effect."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481138Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1830-3
  a curric:KeyLearningPoint ;
  rdfs:label "Sibilance is the repeated use of the letter 's' for effect."@en ;
  dcterms:modified "2026-02-12T08:59:21.481142Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1830-4
  a curric:KeyLearningPoint ;
  rdfs:label """Alliteration, plosives and sibilance can be a sophisticated way to create a sense of sound."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481146Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1962-1
  a curric:KeyLearningPoint ;
  rdfs:label "Stig and Martha have dinner, but are interrupted by a guttural howl outside."@en ;
  dcterms:modified "2026-02-12T08:59:21.481183Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1962-2
  a curric:KeyLearningPoint ;
  rdfs:label """Martha finds a letter from Mormor that tells her she also can feel emotions through clothes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481188Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1962-3
  a curric:KeyLearningPoint ;
  rdfs:label "Mormor tells Martha that she must continue to water the tree in the garden."@en ;
  dcterms:modified "2026-02-12T08:59:21.481192Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1962-4
  a curric:KeyLearningPoint ;
  rdfs:label """Letters are an effective method to relay important information in a novel and explore a character's feelings."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481195Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1524-1
  a curric:KeyLearningPoint ;
  rdfs:label "Men from every part of the British Empire fought in the war."@en ;
  dcterms:modified "2026-02-12T08:59:21.481307Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1524-2
  a curric:KeyLearningPoint ;
  rdfs:label "War poetry is not exclusively written by those who fought during a war."@en ;
  dcterms:modified "2026-02-12T08:59:21.481311Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1524-3
  a curric:KeyLearningPoint ;
  rdfs:label """During the First World War, governments relied on patriotism and propaganda to get people to enlist."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481315Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1524-4
  a curric:KeyLearningPoint ;
  rdfs:label """Conditions for soldiers during the war were extremely gruelling and taxed them physically, mentally and emotionally."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481319Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1743-1
  a curric:KeyLearningPoint ;
  rdfs:label """A writer's perspective refers to their unique point of view, beliefs, values and experiences."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481326Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1743-2
  a curric:KeyLearningPoint ;
  rdfs:label """Identifying a writer's perspective involves understanding the underlying motivations, assumptions, and attitudes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481330Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1743-3
  a curric:KeyLearningPoint ;
  rdfs:label """Looking for patterns in a text can help develop an understanding of the writer’s perspective."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481334Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1743-4
  a curric:KeyLearningPoint ;
  rdfs:label """Semantic fields and extended metaphors can be used by writers to present and develop their perspective."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481337Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1832-1
  a curric:KeyLearningPoint ;
  rdfs:label "A complex sentence is made up of a main clause and a subordinate clause."@en ;
  dcterms:modified "2026-02-12T08:59:21.481350Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1832-2
  a curric:KeyLearningPoint ;
  rdfs:label """Complex sentences are divided by a comma when the subordinate clause begins the sentence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481355Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1832-3
  a curric:KeyLearningPoint ;
  rdfs:label """Writers use a range of sentence types and lengths in their work to create rhythm and pace."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481361Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1832-4
  a curric:KeyLearningPoint ;
  rdfs:label """You should consider the rhythm of your own writing just as you would consider which word to use, or which technique."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481365Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1827-1
  a curric:KeyLearningPoint ;
  rdfs:label """Sensory language is writing that includes reference to some, or all, of the five senses."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481386Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1827-2
  a curric:KeyLearningPoint ;
  rdfs:label """You don't need to write, 'They could see, feel, taste, touch, hear ...' when using sensory language."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481392Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1827-3
  a curric:KeyLearningPoint ;
  rdfs:label """Instead, you can evoke the senses by starting with the noun you wish to describe."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481396Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1827-4
  a curric:KeyLearningPoint ;
  rdfs:label "Adjectives should be chosen carefully so that they create particular effects."@en ;
  dcterms:modified "2026-02-12T08:59:21.481400Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1828-1
  a curric:KeyLearningPoint ;
  rdfs:label """A third person omniscient narrator can move between the thoughts, feelings and experiences of all characters."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481404Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1828-2
  a curric:KeyLearningPoint ;
  rdfs:label "Paragraphs can allow us to signal shifts in focus to a different character."@en ;
  dcterms:modified "2026-02-12T08:59:21.481408Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1828-3
  a curric:KeyLearningPoint ;
  rdfs:label """To structure your piece, your first and final paragraph could focus on the same character."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481412Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1828-4
  a curric:KeyLearningPoint ;
  rdfs:label """To further structure your piece, you could link the concluding sentence of paragraphs to the next topic sentence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481415Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1966-1
  a curric:KeyLearningPoint ;
  rdfs:label "Martha thinks the dead have escaped from the tree in the form of a draugr."@en ;
  dcterms:modified "2026-02-12T08:59:21.481419Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1966-2
  a curric:KeyLearningPoint ;
  rdfs:label "Martha can see faces appearing in the shadows around the cabin."@en ;
  dcterms:modified "2026-02-12T08:59:21.481424Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1966-3
  a curric:KeyLearningPoint ;
  rdfs:label "A howl sounds close to the cabin."@en ;
  dcterms:modified "2026-02-12T08:59:21.481428Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1966-4
  a curric:KeyLearningPoint ;
  rdfs:label "A villain can be considered an antagonist and has an evil and scary presence."@en ;
  dcterms:modified "2026-02-12T08:59:21.481432Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1966-5
  a curric:KeyLearningPoint ;
  rdfs:label """The draugr is an effective villain with its malevolent presence and unpredictability."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481438Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1829-1
  a curric:KeyLearningPoint ;
  rdfs:label """In descriptive writing, sometimes developing the description of small details can be very engaging."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481466Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1829-2
  a curric:KeyLearningPoint ;
  rdfs:label """To structure your piece, you could link the concluding sentence of paragraphs to the next topic sentence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481472Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1829-3
  a curric:KeyLearningPoint ;
  rdfs:label """To structure your piece, your first and final paragraph could repeat selected ideas or images."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481477Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1768-1
  a curric:KeyLearningPoint ;
  rdfs:label """Levy describes her parents' experiences of migration and the disparity between expectations and reality."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481529Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1768-2
  a curric:KeyLearningPoint ;
  rdfs:label """The term "Small Island" refers not just to the geographical space but also to the mindset of people living there."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481533Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1768-3
  a curric:KeyLearningPoint ;
  rdfs:label "The term ‘Mother Country’ is a powerful concept."@en ;
  dcterms:modified "2026-02-12T08:59:21.481537Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1768-4
  a curric:KeyLearningPoint ;
  rdfs:label """Levy wants to foreground the voices of those absent from history like the Caribbean soldiers who fought in WWII."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481541Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1768-5
  a curric:KeyLearningPoint ;
  rdfs:label """Levy has pride in her ancestry and believes that the Caribbean should be recognised, as part of Britain's history."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481546Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1961-1
  a curric:KeyLearningPoint ;
  rdfs:label "Yrsa and Olav, the neighbours, are concerned that Martha is at the house alone."@en ;
  dcterms:modified "2026-02-12T08:59:21.481550Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1961-2
  a curric:KeyLearningPoint ;
  rdfs:label "Martha sees a picture of her ancestors who conjure spells."@en ;
  dcterms:modified "2026-02-12T08:59:21.481554Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1961-3
  a curric:KeyLearningPoint ;
  rdfs:label "Martha feels Mormor's clothes and realises she died in anguish."@en ;
  dcterms:modified "2026-02-12T08:59:21.481558Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1961-4
  a curric:KeyLearningPoint ;
  rdfs:label "Fog in literature often symbolises secrecy or foreboding."@en ;
  dcterms:modified "2026-02-12T08:59:21.481562Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1961-5
  a curric:KeyLearningPoint ;
  rdfs:label "The tree seems unnatural and decaying."@en ;
  dcterms:modified "2026-02-12T08:59:21.481566Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1736-1
  a curric:KeyLearningPoint ;
  rdfs:label """Forms of personal texts include: letters, diaries, autobiographies, memoirs and travelogues."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481569Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1736-2
  a curric:KeyLearningPoint ;
  rdfs:label """Writers of autobiographies will use literary devices to convey emotions and document events in detail."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481573Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1736-3
  a curric:KeyLearningPoint ;
  rdfs:label """Features of autobiographical writing include: first person, past tense, use of descriptive and emotive language."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481577Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1736-4
  a curric:KeyLearningPoint ;
  rdfs:label """Mary Seacole effectively conveys the horror of war through her use of vivid imagery."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481581Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1736-5
  a curric:KeyLearningPoint ;
  rdfs:label """Seacole's use of first person and emotive language create an intimate and authentic account of war."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481585Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1770-1
  a curric:KeyLearningPoint ;
  rdfs:label """Hortense narrates her origins directly to the audience, joined by a younger Hortense."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481626Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1770-2
  a curric:KeyLearningPoint ;
  rdfs:label """Windrush tales often have a male bias, yet this story foregrounds Hortense's experience."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481631Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1770-3
  a curric:KeyLearningPoint ;
  rdfs:label """Hortense's comment about being the "heroine" of the situation opens questions about the dominance of 'white' history."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481635Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1770-4
  a curric:KeyLearningPoint ;
  rdfs:label """Hortense is forced to change her behaviour and accent to become "decent", according to her adoptive family."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481639Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1769-1
  a curric:KeyLearningPoint ;
  rdfs:label """Edmundson adapted the novel which means she developed Levy's original ideas to suit the form of a play."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481643Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1769-2
  a curric:KeyLearningPoint ;
  rdfs:label """Edmundson is responsible for writing stage directions, chronology of events and developing characters through dialogue."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481646Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1769-3
  a curric:KeyLearningPoint ;
  rdfs:label """Edmundson develops the multiplicity of Levy's original narratives using dramatic techniques."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481650Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1769-4
  a curric:KeyLearningPoint ;
  rdfs:label """Edmundson uses patois, dialect and colloquial language to develop Levy's realistic characters."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481654Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1769-5
  a curric:KeyLearningPoint ;
  rdfs:label """The use of direct address in the play mirrors the first person narratives in the novel, giving characters unique voices."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481658Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1734-1
  a curric:KeyLearningPoint ;
  rdfs:label """There were societal expectations placed on women’s behaviour in the 18th century."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481662Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1734-2
  a curric:KeyLearningPoint ;
  rdfs:label """The ‘Spectator’ article reveals the dominant attitudes towards women and how they were objectified."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481666Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1734-3
  a curric:KeyLearningPoint ;
  rdfs:label """Effective discussions will take turns, develop ideas, use evidence and respond to the other speaker."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481672Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1735-1
  a curric:KeyLearningPoint ;
  rdfs:label """Both men and women were subject to societal expectations, however men had more freedom and power."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481676Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1735-2
  a curric:KeyLearningPoint ;
  rdfs:label """The term ‘gentleman’ has evolved from simply meaning wealth and status to expectations of etiquette and lifestyle."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481680Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1735-3
  a curric:KeyLearningPoint ;
  rdfs:label "Modal verbs can be used to show possibility and necessity."@en ;
  dcterms:modified "2026-02-12T08:59:21.481684Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1735-4
  a curric:KeyLearningPoint ;
  rdfs:label "Modal verbs can be used to instruct and advise a reader."@en ;
  dcterms:modified "2026-02-12T08:59:21.481688Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1965-1
  a curric:KeyLearningPoint ;
  rdfs:label "Martha tells Stig about her supernatural abilities."@en ;
  dcterms:modified "2026-02-12T08:59:21.481705Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1965-2
  a curric:KeyLearningPoint ;
  rdfs:label """Martha's mother tells them to leave the cabin immediately, making the reader feel apprehensive for them."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481709Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1965-3
  a curric:KeyLearningPoint ;
  rdfs:label """Tension increases as they discover the murdered bodies of Yrsa and Olav and hear another howl."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481713Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1965-4
  a curric:KeyLearningPoint ;
  rdfs:label "Tension is the feeling of suspense and excitement that keeps readers interested."@en ;
  dcterms:modified "2026-02-12T08:59:21.481717Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1965-5
  a curric:KeyLearningPoint ;
  rdfs:label "Time conjunctions can be used to explain a writer's development of tension."@en ;
  dcterms:modified "2026-02-12T08:59:21.481721Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1964-1
  a curric:KeyLearningPoint ;
  rdfs:label "Odin is the god of wisdom who sacrificed an eye for greater understanding."@en ;
  dcterms:modified "2026-02-12T08:59:21.481724Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1964-2
  a curric:KeyLearningPoint ;
  rdfs:label "Martha is believed to be a descendant of Odin."@en ;
  dcterms:modified "2026-02-12T08:59:21.481728Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1964-3
  a curric:KeyLearningPoint ;
  rdfs:label "Martha sees a face in the tree."@en ;
  dcterms:modified "2026-02-12T08:59:21.481732Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1964-4
  a curric:KeyLearningPoint ;
  rdfs:label "The novel is inspired by Norse mythology."@en ;
  dcterms:modified "2026-02-12T08:59:21.481736Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1738-1
  a curric:KeyLearningPoint ;
  rdfs:label """When writing analytical responses, you should begin by identifying and comparing  a ‘big idea’."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481742Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1738-2
  a curric:KeyLearningPoint ;
  rdfs:label """Using correlative and comparative conjunctions can help to draw close comparisons."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481748Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1738-3
  a curric:KeyLearningPoint ;
  rdfs:label "Superlatives can help you to compare and evaluate texts."@en ;
  dcterms:modified "2026-02-12T08:59:21.481753Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1738-4
  a curric:KeyLearningPoint ;
  rdfs:label """Tentative language can be used to add additional arguments and put forward your ideas."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481757Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1737-1
  a curric:KeyLearningPoint ;
  rdfs:label """Many texts about war and conflict are presented from the perspective of male soldiers or men."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481760Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1737-2
  a curric:KeyLearningPoint ;
  rdfs:label "Seacole and Nightingale offer an alternative perspective of conflict."@en ;
  dcterms:modified "2026-02-12T08:59:21.481765Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1737-3
  a curric:KeyLearningPoint ;
  rdfs:label """Athough writing about similar events, Seacole and Nightingale have different experiences and use different forms."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481769Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1737-4
  a curric:KeyLearningPoint ;
  rdfs:label """Both writers use first person accounts to reveal the shocking realities of war and life as a nurse on the front line."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481773Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1741-1
  a curric:KeyLearningPoint ;
  rdfs:label "Comparing one text to another can often help you evaluate it more clearly."@en ;
  dcterms:modified "2026-02-12T08:59:21.481843Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1741-2
  a curric:KeyLearningPoint ;
  rdfs:label """You can compare what each writer chose to write about, and how they chose to write about it."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481847Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1741-3
  a curric:KeyLearningPoint ;
  rdfs:label """The opening of comparative paragraphs could start with a topic sentence which states the paragraph’s main idea."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481851Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1741-4
  a curric:KeyLearningPoint ;
  rdfs:label """The next sentences of a comparative paragraph could focus on the differences between the two texts you wish to compare."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481855Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1777-1
  a curric:KeyLearningPoint ;
  rdfs:label """Pathos is created when Arthur is shot - he is an innocent victim of this incident."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481859Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1777-2
  a curric:KeyLearningPoint ;
  rdfs:label """As a WW1 veteran, Arthur dies in a violent incident at home rather than enjoying the freedom and safety he fought for."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481862Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1777-3
  a curric:KeyLearningPoint ;
  rdfs:label """Arthur is characterised as more open-minded than his son, showing that racism is not just a generational issue."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481866Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1777-4
  a curric:KeyLearningPoint ;
  rdfs:label "Arthur's death shows that racism is deeply damaging to society as a whole."@en ;
  dcterms:modified "2026-02-12T08:59:21.481870Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1781-1
  a curric:KeyLearningPoint ;
  rdfs:label """Act 1 is considered a very important part of a play’s structure- it is sometimes referred to as the ‘set-up’."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481909Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1781-2
  a curric:KeyLearningPoint ;
  rdfs:label "‘Small Island’ is comprised of an ensemble cast and multiple narratives."@en ;
  dcterms:modified "2026-02-12T08:59:21.481913Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1781-3
  a curric:KeyLearningPoint ;
  rdfs:label """Queenie’s pregnancy and the sailing of the Empire Windrush at the end of Act 1, create a dramatic transition into Act 2."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481916Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1781-4
  a curric:KeyLearningPoint ;
  rdfs:label """The themes of ambition, betrayal, hope and belonging are prevalent in Act 1 and connect many of the characters."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481920Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1783-1
  a curric:KeyLearningPoint ;
  rdfs:label """Edmundson shows the link between class and race - migrants automatically fell to the bottom of the social hierarchy."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481924Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1783-2
  a curric:KeyLearningPoint ;
  rdfs:label """Hope and betrayal remain important themes as the couple do not achieve their middle class ambitions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481957Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1783-3
  a curric:KeyLearningPoint ;
  rdfs:label """Pride emerges as an important value among the migrant population - Gilbert does not warn Hortense about life in London."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481963Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1783-4
  a curric:KeyLearningPoint ;
  rdfs:label """Neither Hortense's "pale skin" nor Gilbert's time in the military gain them additional status."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481967Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1783-5
  a curric:KeyLearningPoint ;
  rdfs:label """There is a stark contrast between Act 1 and Act 2, showing the realisation that expectations do not match the reality."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481971Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1774-1
  a curric:KeyLearningPoint ;
  rdfs:label "Both Queenie and Hortense tell their story by directly addressing the audience."@en ;
  dcterms:modified "2026-02-12T08:59:21.482008Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1774-2
  a curric:KeyLearningPoint ;
  rdfs:label """Class is a key dimension here - Bernard offers Queenie the hope of a middle class life."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482013Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1774-3
  a curric:KeyLearningPoint ;
  rdfs:label """Bernard is a caricature of a repressed English gentleman, who is fearful of all that is unfamiliar."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482017Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1774-4
  a curric:KeyLearningPoint ;
  rdfs:label """The setting of Bernard's cold, closed-off Edwardian house mirrors his personality and is opposite to Queenie's warmth."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482021Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1774-5
  a curric:KeyLearningPoint ;
  rdfs:label "The playwright uses humour to show the lack of passion between the couple."@en ;
  dcterms:modified "2026-02-12T08:59:21.482025Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1745-1
  a curric:KeyLearningPoint ;
  rdfs:label """Tone in writing refers to the attitude or feeling conveyed by a writer towards the subject matter and audience."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482029Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1745-2
  a curric:KeyLearningPoint ;
  rdfs:label """Tone is conveyed through word choice, sentence structure, punctuation, and overall language usage."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482032Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1745-3
  a curric:KeyLearningPoint ;
  rdfs:label """Writers will ensure their tone is appropriate for the text’s purpose, audience and form."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482037Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1745-4
  a curric:KeyLearningPoint ;
  rdfs:label """Writers will adapt specific language features and rhetorical devices to match the tone of their writing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482041Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1778-1
  a curric:KeyLearningPoint ;
  rdfs:label """Scene 4 marks the end of the war and the hopeful, celebratory atmosphere post WWII."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482099Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1778-2
  a curric:KeyLearningPoint ;
  rdfs:label """Edmundson explores the aftermath of WWII and its impacts on women like Queenie and Hortense."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482103Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1778-3
  a curric:KeyLearningPoint ;
  rdfs:label "Britain represents opportunities and an aspirational life."@en ;
  dcterms:modified "2026-02-12T08:59:21.482107Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1778-4
  a curric:KeyLearningPoint ;
  rdfs:label "Gilbert and Elwood represent oppositional attitudes towards migration."@en ;
  dcterms:modified "2026-02-12T08:59:21.482110Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1778-5
  a curric:KeyLearningPoint ;
  rdfs:label "Fronted adverbials can be used to develop comments and introduce evidence."@en ;
  dcterms:modified "2026-02-12T08:59:21.482114Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1776-1
  a curric:KeyLearningPoint ;
  rdfs:label """Gilbert is motivated by a desire to fight against Hitler and his Nazi racial theories."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482134Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1776-2
  a curric:KeyLearningPoint ;
  rdfs:label """Gilbert is portrayed as gullible, whereas his cousin Elwood is more cynical about their 'mother country'."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482138Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1776-3
  a curric:KeyLearningPoint ;
  rdfs:label """Gilbert breaks the fourth wall, addressing the audience to show them the reality of his posting with the RAF."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482142Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1776-4
  a curric:KeyLearningPoint ;
  rdfs:label """The sarcasm and demeaning tone of the Sergeant in Lincolnshire is deliberately contrasted with the recruiting officer."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482146Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1776-5
  a curric:KeyLearningPoint ;
  rdfs:label """Gilbert joins the RAF to fight for the British Empire, yet he finds that in Britain there's no sense of shared identity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482150Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1772-1
  a curric:KeyLearningPoint ;
  rdfs:label """Stella's attitude to the hurricane shows her ignorance - she views it as an exotic experience, neglecting the danger."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482154Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1772-2
  a curric:KeyLearningPoint ;
  rdfs:label """The hurricane is a powerful natural force that exposes truths about the human relations between characters."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482159Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1772-3
  a curric:KeyLearningPoint ;
  rdfs:label """The stage directions show Hortense preparing the schoolhouse, whereas the naive Mrs. Ryder looks out from the open door."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482164Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1772-4
  a curric:KeyLearningPoint ;
  rdfs:label "Hortense’s calmness in the storm suggests she has been shaped by strong forces."@en ;
  dcterms:modified "2026-02-12T08:59:21.482168Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1772-5
  a curric:KeyLearningPoint ;
  rdfs:label "Freytag’s pyramid can be used to track events and characters."@en ;
  dcterms:modified "2026-02-12T08:59:21.482172Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1740-1
  a curric:KeyLearningPoint ;
  rdfs:label """The article is a profile piece, written in third person. However, it also conveys the subject's perspective."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482212Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1740-2
  a curric:KeyLearningPoint ;
  rdfs:label """The writer uses hyperbole, imagery and lists to bring Hine's experiences to life."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482216Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1740-3
  a curric:KeyLearningPoint ;
  rdfs:label "Direct quotations use the exact words from an original source."@en ;
  dcterms:modified "2026-02-12T08:59:21.482220Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1740-4
  a curric:KeyLearningPoint ;
  rdfs:label """Indirect quotations use your own words to paraphrase or express ideas from another source."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482224Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1740-5
  a curric:KeyLearningPoint ;
  rdfs:label """Writers will use direct and indirect quotations to capture the subject's voice authentically."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482228Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1773-1
  a curric:KeyLearningPoint ;
  rdfs:label "Edmundson uses the literary trope of the storm to create a dramatic setting."@en ;
  dcterms:modified "2026-02-12T08:59:21.482235Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1773-2
  a curric:KeyLearningPoint ;
  rdfs:label """The hurricane establishes a foreboding atmosphere and foreshadows the dramatic events to come."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482241Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1773-3
  a curric:KeyLearningPoint ;
  rdfs:label "The hurricane parallels the rising tensions between the characters."@en ;
  dcterms:modified "2026-02-12T08:59:21.482245Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1773-4
  a curric:KeyLearningPoint ;
  rdfs:label """The hurricane is a powerful natural force that exposes truths about the human relations between characters."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482249Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1739-1
  a curric:KeyLearningPoint ;
  rdfs:label "‘Around the World in 72 Days’ is an example of a travelogue."@en ;
  dcterms:modified "2026-02-12T08:59:21.482265Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1739-2
  a curric:KeyLearningPoint ;
  rdfs:label "Nellie Bly challenges societal expectations of women in the 19th century."@en ;
  dcterms:modified "2026-02-12T08:59:21.482268Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1739-3
  a curric:KeyLearningPoint ;
  rdfs:label "Opinions should be informed by available information or evidence."@en ;
  dcterms:modified "2026-02-12T08:59:21.482273Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1739-4
  a curric:KeyLearningPoint ;
  rdfs:label """Effective discussions will involve taking turns, developing ideas, using evidence and responding to other speakers."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482276Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1779-1
  a curric:KeyLearningPoint ;
  rdfs:label """Gilbert and Hortense share visions of the middle class life that they will enjoy in England, as a teacher and lawyer."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482281Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1779-2
  a curric:KeyLearningPoint ;
  rdfs:label """Gender is important as well as race - Hortense realises that marriage is her only opportunity to travel."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482284Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1779-3
  a curric:KeyLearningPoint ;
  rdfs:label """Hortense is confident that her "pale skin" and education will buy her status in England."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482288Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1779-4
  a curric:KeyLearningPoint ;
  rdfs:label "The pact between Gilbert and Hortense is more like a business deal."@en ;
  dcterms:modified "2026-02-12T08:59:21.482294Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1779-5
  a curric:KeyLearningPoint ;
  rdfs:label "Comparative conjunctions can be used to explore similarities and differences."@en ;
  dcterms:modified "2026-02-12T08:59:21.482298Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1744-1
  a curric:KeyLearningPoint ;
  rdfs:label """Through the experience of motherhood, Adichie explores the issue of gender roles and stereotypes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482323Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1744-2
  a curric:KeyLearningPoint ;
  rdfs:label "Both Adichie and Pankhurst present a feminist perspective on gender inequality."@en ;
  dcterms:modified "2026-02-12T08:59:21.482327Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1744-3
  a curric:KeyLearningPoint ;
  rdfs:label """Adichie and Pankhurst use different forms to address their audiences and achieve their different purposes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482330Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1744-4
  a curric:KeyLearningPoint ;
  rdfs:label """A comparative sentence needs to make the link between the texts clear, for example through a comparative conjunction."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482334Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1744-5
  a curric:KeyLearningPoint ;
  rdfs:label "Correlative conjunctions can be used to create close comparisons."@en ;
  dcterms:modified "2026-02-12T08:59:21.482338Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1771-1
  a curric:KeyLearningPoint ;
  rdfs:label """Hortense is encouraged by the colonial system of shade hierarchy, to see herself as superior because of her light skin."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482362Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1771-2
  a curric:KeyLearningPoint ;
  rdfs:label """The values of this 'shadist' society are instilled from childhood, when she is taken from her birth mother."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482366Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1771-3
  a curric:KeyLearningPoint ;
  rdfs:label """Hortense is placed with wealthy cousins of her father; social position is more important than maternal connection."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482370Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1771-4
  a curric:KeyLearningPoint ;
  rdfs:label """Although Hortense views herself as superior, her class and illegitimacy mean she has less status in society."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482374Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1780-1
  a curric:KeyLearningPoint ;
  rdfs:label """The Windrush Generation are those who arrived from Caribbean countries between 1948 and 1973."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482473Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1780-2
  a curric:KeyLearningPoint ;
  rdfs:label """The Windrush Generation took up jobs in sectors affected by the post World War Two labour shortage."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482477Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1780-3
  a curric:KeyLearningPoint ;
  rdfs:label """The ‘mother country’ promised not only jobs and opportunities, but unity, collective identity and openness."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482481Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1780-4
  a curric:KeyLearningPoint ;
  rdfs:label "Like ‘Small Island’ Windrush history is made up of many voices."@en ;
  dcterms:modified "2026-02-12T08:59:21.482485Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1780-5
  a curric:KeyLearningPoint ;
  rdfs:label """Levy and Edmundson want to foreground the real experiences and stories of those absent from historical narratives."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482489Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1747-1
  a curric:KeyLearningPoint ;
  rdfs:label "Single words can provide an opportunity for rich analysis."@en ;
  dcterms:modified "2026-02-12T08:59:21.482531Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1747-2
  a curric:KeyLearningPoint ;
  rdfs:label """To find the best words you should consider if they evoke a feeling, create a description or present a perspective."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482536Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1747-3
  a curric:KeyLearningPoint ;
  rdfs:label "Layering your word analysis means saying a lot about a little."@en ;
  dcterms:modified "2026-02-12T08:59:21.482539Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1747-4
  a curric:KeyLearningPoint ;
  rdfs:label """Considering word types, connotations, reader reaction and writer’s intention can help to create a layered analysis."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482545Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1742-1
  a curric:KeyLearningPoint ;
  rdfs:label """The opening of comparative paragraphs could start with a topic sentence which states the paragraph's main idea."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482549Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1742-2
  a curric:KeyLearningPoint ;
  rdfs:label """The next sentences of a comparative paragraph could focus on the differences between the two texts you wish to compare."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482553Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1742-3
  a curric:KeyLearningPoint ;
  rdfs:label "Including multiple quotations from both texts is key to a comparative paragraph."@en ;
  dcterms:modified "2026-02-12T08:59:21.482557Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1742-4
  a curric:KeyLearningPoint ;
  rdfs:label "Comparing the methods writers have used can help to develop the comparison."@en ;
  dcterms:modified "2026-02-12T08:59:21.482561Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1742-5
  a curric:KeyLearningPoint ;
  rdfs:label "The final sentence of a comparative paragraph should link to the topic sentence."@en ;
  dcterms:modified "2026-02-12T08:59:21.482565Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1746-1
  a curric:KeyLearningPoint ;
  rdfs:label """Before reading, it can be useful to consider the purpose, form and audience of a text."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482569Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1746-2
  a curric:KeyLearningPoint ;
  rdfs:label "Identifying complex ideas in a text can help deepen your understanding."@en ;
  dcterms:modified "2026-02-12T08:59:21.482573Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1746-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Big ideas' include: representation, attitudes and values and historical perspectives."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482577Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1746-4
  a curric:KeyLearningPoint ;
  rdfs:label """Considering how texts challenge or conform to stereotypes and dominant narratives can create sophisticated statements."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482581Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1748-1
  a curric:KeyLearningPoint ;
  rdfs:label "Single paragraph outlines are a useful tool in the planning process."@en ;
  dcterms:modified "2026-02-12T08:59:21.482586Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1748-2
  a curric:KeyLearningPoint ;
  rdfs:label """Topic sentences should include words from the question and link to writer’s purpose."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482590Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1748-3
  a curric:KeyLearningPoint ;
  rdfs:label "Quotations need to be judiciously chosen and can be embedded into your response."@en ;
  dcterms:modified "2026-02-12T08:59:21.482597Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1748-4
  a curric:KeyLearningPoint ;
  rdfs:label "Using conclusive discourse markers is an effective way to end your paragraph."@en ;
  dcterms:modified "2026-02-12T08:59:21.482601Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1748-5
  a curric:KeyLearningPoint ;
  rdfs:label """Concluding sentences should link to your topic sentence and summarise your main ideas."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482605Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1975-1
  a curric:KeyLearningPoint ;
  rdfs:label """Headlines will give the reader an indication of what the story is likely to be about."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482882Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1975-2
  a curric:KeyLearningPoint ;
  rdfs:label "The purpose of a headline is to grab the reader's attention."@en ;
  dcterms:modified "2026-02-12T08:59:21.482886Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1975-3
  a curric:KeyLearningPoint ;
  rdfs:label "A headline should give an indication of the content of a news article."@en ;
  dcterms:modified "2026-02-12T08:59:21.482890Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1975-4
  a curric:KeyLearningPoint ;
  rdfs:label "Language devices are often used in headlines."@en ;
  dcterms:modified "2026-02-12T08:59:21.482894Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1975-5
  a curric:KeyLearningPoint ;
  rdfs:label "Subheadings can be used to give more detail about a story."@en ;
  dcterms:modified "2026-02-12T08:59:21.482898Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1523-1
  a curric:KeyLearningPoint ;
  rdfs:label """The home front refers to the idea that civilians in Britain felt the impact of World War One in their daily lives."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483205Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1523-2
  a curric:KeyLearningPoint ;
  rdfs:label """It was common for those on the home front to feel fear and impotence whilst their loved ones were on the front line."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483209Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1523-3
  a curric:KeyLearningPoint ;
  rdfs:label """Brittain’s ‘Testament of Youth’ captures and expresses feelings of fear, impotence and anger during the war years."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483213Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1523-4
  a curric:KeyLearningPoint ;
  rdfs:label """Using contextual knowledge and inspiration from other texts can help create a convincing persona in your own writing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483217Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1508-1
  a curric:KeyLearningPoint ;
  rdfs:label "Writers spend time crafting the rhythm of their writing, as well as the words."@en ;
  dcterms:modified "2026-02-12T08:59:21.483392Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1508-2
  a curric:KeyLearningPoint ;
  rdfs:label "In writing, rhythm is created through sentence construction and punctuation."@en ;
  dcterms:modified "2026-02-12T08:59:21.483396Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1508-3
  a curric:KeyLearningPoint ;
  rdfs:label "Rhythm creates energy, pace and tension."@en ;
  dcterms:modified "2026-02-12T08:59:21.483400Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1508-4
  a curric:KeyLearningPoint ;
  rdfs:label "Rhythm can engage the reader, and draw their attention to certain things."@en ;
  dcterms:modified "2026-02-12T08:59:21.483404Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29489-1
  a curric:KeyLearningPoint ;
  rdfs:label "Simon Armitage is the current UK Poet Laureate."@en ;
  dcterms:modified "2026-02-12T08:59:21.485244Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29489-2
  a curric:KeyLearningPoint ;
  rdfs:label """Armitage was commissioned to write ‘We’ll Sing’ by the Huddersfield Choral society."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485248Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29489-3
  a curric:KeyLearningPoint ;
  rdfs:label """Armitage suggests that there are elements of resistance, defiance, hope and optimism about ‘We’ll Sing’."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485252Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29489-4
  a curric:KeyLearningPoint ;
  rdfs:label """Armitage was commissioned to write ‘Only Human’ for a service in remembrance of lives lost during Covid-19."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485256Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29489-5
  a curric:KeyLearningPoint ;
  rdfs:label """Armitage suggests that ‘Only Human’ was trying to communicate ideas of hope and positivity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485262Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1749-1
  a curric:KeyLearningPoint ;
  rdfs:label """When expressing a viewpoint in a persuasive piece of writing, it’s important to create a rapport with the audience."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485382Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1749-2
  a curric:KeyLearningPoint ;
  rdfs:label "Considering your tone can help to engage and persuade your audience."@en ;
  dcterms:modified "2026-02-12T08:59:21.485386Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1749-3
  a curric:KeyLearningPoint ;
  rdfs:label """Using a range of sentence types can help you create subtle changes of tone throughout your writing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485390Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1749-4
  a curric:KeyLearningPoint ;
  rdfs:label "Anecdotes are a useful way to engage your audience."@en ;
  dcterms:modified "2026-02-12T08:59:21.485394Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1749-5
  a curric:KeyLearningPoint ;
  rdfs:label "An effective anecdote will not be too long and link to your viewpoint."@en ;
  dcterms:modified "2026-02-12T08:59:21.485400Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1752-1
  a curric:KeyLearningPoint ;
  rdfs:label "It is important to consider the overall structure of your writing."@en ;
  dcterms:modified "2026-02-12T08:59:21.485514Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1752-2
  a curric:KeyLearningPoint ;
  rdfs:label """Creating a specific focus for each section of your writing can help develop your viewpoint."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485518Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1752-3
  a curric:KeyLearningPoint ;
  rdfs:label "You should consider the order of your writing to ensure it is engaging."@en ;
  dcterms:modified "2026-02-12T08:59:21.485522Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1752-4
  a curric:KeyLearningPoint ;
  rdfs:label """Anaphora and epistrophe both use repetition and can be used to reinforce key ideas and create an urgent tone."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485526Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1751-1
  a curric:KeyLearningPoint ;
  rdfs:label "Statistics and facts can be used to make your speeches sound authoritative."@en ;
  dcterms:modified "2026-02-12T08:59:21.485601Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1751-2
  a curric:KeyLearningPoint ;
  rdfs:label """Statistics and facts need to be realistic in order to add credibility to your writing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485608Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1751-3
  a curric:KeyLearningPoint ;
  rdfs:label "Statistics should not be overused or they risk losing their impact."@en ;
  dcterms:modified "2026-02-12T08:59:21.485612Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1751-4
  a curric:KeyLearningPoint ;
  rdfs:label """Creating and using experts in your persuasive writing can add interest and help to support your argument."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485616Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1751-5
  a curric:KeyLearningPoint ;
  rdfs:label "Using both direct and indirect quotations can help to develop your argument."@en ;
  dcterms:modified "2026-02-12T08:59:21.485620Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1750-1
  a curric:KeyLearningPoint ;
  rdfs:label """Emma Watson adapts her tone and language to suit the audience and purpose of her speech."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485678Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1750-2
  a curric:KeyLearningPoint ;
  rdfs:label """Watson’s speech emphasises men’s involvement, challenges gender stereotypes and critiques social perception of feminism."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485682Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1750-3
  a curric:KeyLearningPoint ;
  rdfs:label "The speech uses a range of well chosen rhetorical devices for effect."@en ;
  dcterms:modified "2026-02-12T08:59:21.485686Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1750-4
  a curric:KeyLearningPoint ;
  rdfs:label """Rhetorical devices should be used to engage the audience and help achieve the purpose of the speech."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485690Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1754-1
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to consider how the tone of a speech opening will engage the audience and establish your viewpoint."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485829Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1754-2
  a curric:KeyLearningPoint ;
  rdfs:label "An introduction should hook your audience in, regardless of the topic."@en ;
  dcterms:modified "2026-02-12T08:59:21.485833Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1754-3
  a curric:KeyLearningPoint ;
  rdfs:label """The ending of your persuasive speech presents the last opportunity to influence your audience."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485837Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1754-4
  a curric:KeyLearningPoint ;
  rdfs:label """At the end of your persuasive speech, your audience should know exactly how to help or what to think or feel."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485843Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1754-5
  a curric:KeyLearningPoint ;
  rdfs:label "Using rhetorical devices can elevate your opening and closing paragraphs."@en ;
  dcterms:modified "2026-02-12T08:59:21.485847Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1755-1
  a curric:KeyLearningPoint ;
  rdfs:label """Proofreading is an active process, that enables us to spot and correct errors in written work."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485883Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1755-2
  a curric:KeyLearningPoint ;
  rdfs:label """Reading your work aloud can help you spot errors and ensure your writing is correctly punctuated."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485887Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1755-3
  a curric:KeyLearningPoint ;
  rdfs:label "You should spell check any homophones and words you are unsure of."@en ;
  dcterms:modified "2026-02-12T08:59:21.485891Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1755-4
  a curric:KeyLearningPoint ;
  rdfs:label "Find opportunities to include interesting structural features like mirroring."@en ;
  dcterms:modified "2026-02-12T08:59:21.485895Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1755-5
  a curric:KeyLearningPoint ;
  rdfs:label "The overall structure of a speech should be varied and engaging."@en ;
  dcterms:modified "2026-02-12T08:59:21.485898Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1753-1
  a curric:KeyLearningPoint ;
  rdfs:label """Considering the purpose, audience and form of writing can help you begin to make choices about language and structure."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486106Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1753-2
  a curric:KeyLearningPoint ;
  rdfs:label """Thinking about your own opinions and knowledge of a topic can help generate initial ideas."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486110Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1753-3
  a curric:KeyLearningPoint ;
  rdfs:label """You should consider the overall structure of your writing before breaking it down into more detailed plans."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486114Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1753-4
  a curric:KeyLearningPoint ;
  rdfs:label """Single paragraph outlines provide an effective and efficient way to plan writing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486118Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29637-1
  a curric:KeyLearningPoint ;
  rdfs:label """Edmundson says a key challenge in writing is making the audience feel secure and engaged."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486498Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29637-2
  a curric:KeyLearningPoint ;
  rdfs:label """Edmundson and Norris both address how to overcome challenges in keeping the audience engaged, using clarity and pace."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486502Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29637-3
  a curric:KeyLearningPoint ;
  rdfs:label """Norris says the first scenes focus on individual stories, which could slow the plot and ask more from the audience."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486508Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29637-4
  a curric:KeyLearningPoint ;
  rdfs:label """Rufus Norris believes seamless scene changes energise the play and keep audiences engaged."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486514Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29637-5
  a curric:KeyLearningPoint ;
  rdfs:label """Norris highlights that action and humour in Gilbert’s story help keep the audience engaged."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486518Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29492-1
  a curric:KeyLearningPoint ;
  rdfs:label "Armitage’s ‘Resistance’ was written about the Russian invasion of Ukraine."@en ;
  dcterms:modified "2026-02-12T08:59:21.487717Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29492-2
  a curric:KeyLearningPoint ;
  rdfs:label "Armitage suggests that poetry can be a form of resistance and support."@en ;
  dcterms:modified "2026-02-12T08:59:21.487721Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29492-3
  a curric:KeyLearningPoint ;
  rdfs:label "Armitage's ‘Out of the Blue’ was written to be part of a film about 9/11."@en ;
  dcterms:modified "2026-02-12T08:59:21.487724Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29492-4
  a curric:KeyLearningPoint ;
  rdfs:label """Armitage suggests that you have a responsibility and accountability when writing about world events."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487728Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29492-5
  a curric:KeyLearningPoint ;
  rdfs:label """Armitage also says that you need to reflect how you personally feel about world events in your writing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487734Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29490-1
  a curric:KeyLearningPoint ;
  rdfs:label """Armitage’s ‘Transmission Report’ was commissioned by the BBC to celebrate their 100th anniversary."""@en ;
  dcterms:modified "2026-02-12T08:59:21.488209Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29490-2
  a curric:KeyLearningPoint ;
  rdfs:label """Armitage wrote ‘Transmission Report’ from the perspective of someone in outer space choosing to tune into the BBC."""@en ;
  dcterms:modified "2026-02-12T08:59:21.488213Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29490-3
  a curric:KeyLearningPoint ;
  rdfs:label """Armitage suggests that, when reading a poem silently, you should highlight the five words that stand out to you."""@en ;
  dcterms:modified "2026-02-12T08:59:21.488217Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29490-4
  a curric:KeyLearningPoint ;
  rdfs:label """In doing so, Armitage states that it will help you remember/realise how intentional language choices are."""@en ;
  dcterms:modified "2026-02-12T08:59:21.488221Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29490-5
  a curric:KeyLearningPoint ;
  rdfs:label """When reading a poem aloud, Armitage says that you should honour the language and the line breaks."""@en ;
  dcterms:modified "2026-02-12T08:59:21.488227Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29493-1
  a curric:KeyLearningPoint ;
  rdfs:label "Armitage suggests that daydreaming is an important part of finding inspiration."@en ;
  dcterms:modified "2026-02-12T08:59:21.597129Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29493-2
  a curric:KeyLearningPoint ;
  rdfs:label """Armitage worries that we don’t give ourselves enough time to just let our minds wander in modern society."""@en ;
  dcterms:modified "2026-02-12T08:59:21.597141Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29493-3
  a curric:KeyLearningPoint ;
  rdfs:label "Armitage suggests that poetry is all to do with metaphors and comparisons."@en ;
  dcterms:modified "2026-02-12T08:59:21.597151Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29493-4
  a curric:KeyLearningPoint ;
  rdfs:label """Armitage says that often you have to approach poetry writing through a different angle rather than head-on."""@en ;
  dcterms:modified "2026-02-12T08:59:21.597161Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29641-1
  a curric:KeyLearningPoint ;
  rdfs:label """Norris explains the challenge of staging Queenie’s birth due to multiple technical and emotional factors."""@en ;
  dcterms:modified "2026-02-12T08:59:21.598509Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29641-2
  a curric:KeyLearningPoint ;
  rdfs:label """Norris found Queenie asking Hortense and Gilbert to take her baby the most emotionally difficult scene."""@en ;
  dcterms:modified "2026-02-12T08:59:21.598518Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29641-3
  a curric:KeyLearningPoint ;
  rdfs:label "Norris chose the final image for its powerful and lasting impact."@en ;
  dcterms:modified "2026-02-12T08:59:21.598531Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29641-4
  a curric:KeyLearningPoint ;
  rdfs:label """Edmundson says Queenie’s decision to give up her baby is a loving act shaped by harsh realities."""@en ;
  dcterms:modified "2026-02-12T08:59:21.598541Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29641-5
  a curric:KeyLearningPoint ;
  rdfs:label """Edmundson thinks the ending shows an uncertain future coupled with love and fragile hope."""@en ;
  dcterms:modified "2026-02-12T08:59:21.598550Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29633-1
  a curric:KeyLearningPoint ;
  rdfs:label """Edmundson notes the Windrush scandal emerged during production, powerfully deepening the play’s relevance."""@en ;
  dcterms:modified "2026-02-12T08:59:21.599512Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29633-2
  a curric:KeyLearningPoint ;
  rdfs:label """Edmundson suggests that Hortense experiences deep feelings of abandonment that influence her actions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.599527Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29633-3
  a curric:KeyLearningPoint ;
  rdfs:label """Edmundson highlights the stark contrast in Michael and Gilbert’s upbringings and how it shapes their identities."""@en ;
  dcterms:modified "2026-02-12T08:59:21.599536Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29633-4
  a curric:KeyLearningPoint ;
  rdfs:label """Edmundson suggests hope and progress come through compromise and by honestly addressing reality."""@en ;
  dcterms:modified "2026-02-12T08:59:21.599545Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29633-5
  a curric:KeyLearningPoint ;
  rdfs:label "Edmundson describes 'Small Island' as a hopeful, but realistic play."@en ;
  dcterms:modified "2026-02-12T08:59:21.599554Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29491-1
  a curric:KeyLearningPoint ;
  rdfs:label "Armitage was inspired to write ‘Futurama’ by the COP 26 climate crisis summit."@en ;
  dcterms:modified "2026-02-12T08:59:21.599563Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29491-2
  a curric:KeyLearningPoint ;
  rdfs:label "Armitage suggests that ‘Futurama’ describes ideas of uncertainty and anxiety."@en ;
  dcterms:modified "2026-02-12T08:59:21.599571Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29491-3
  a curric:KeyLearningPoint ;
  rdfs:label """Armitage suggests that writing from an individual perspective is important because we all have different opinions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.599580Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29491-4
  a curric:KeyLearningPoint ;
  rdfs:label """Moreover, Armitage suggests that writing from a mass perspective can sound too much like political speech."""@en ;
  dcterms:modified "2026-02-12T08:59:21.599589Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29639-1
  a curric:KeyLearningPoint ;
  rdfs:label "Edmundson wanted a strong contrast between Act 1 and Act 2."@en ;
  dcterms:modified "2026-02-12T08:59:21.600351Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29639-2
  a curric:KeyLearningPoint ;
  rdfs:label """Act 1 is expansive, playful, and full of dreams, with direct address creating a story-like feel."""@en ;
  dcterms:modified "2026-02-12T08:59:21.600359Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29639-3
  a curric:KeyLearningPoint ;
  rdfs:label """Act 2 brings characters “back to Earth” into a more disappointing and compromised reality."""@en ;
  dcterms:modified "2026-02-12T08:59:21.600368Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29639-4
  a curric:KeyLearningPoint ;
  rdfs:label """Act 1 has a "fluidity" of movement, while Act 2 has structured, realistic spaces."""@en ;
  dcterms:modified "2026-02-12T08:59:21.600377Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29639-5
  a curric:KeyLearningPoint ;
  rdfs:label """Direct address is removed in Act 2 (until the end) to reflect a more grounded, serious tone."""@en ;
  dcterms:modified "2026-02-12T08:59:21.600385Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1941-1
  a curric:KeyLearningPoint ;
  rdfs:label "The purpose of a headline is to grab a reader's attention"@en ;
  dcterms:modified "2026-02-12T08:59:21.601358Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1941-2
  a curric:KeyLearningPoint ;
  rdfs:label "A headline should give an indication of the content of the news article"@en ;
  dcterms:modified "2026-02-12T08:59:21.601366Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1941-3
  a curric:KeyLearningPoint ;
  rdfs:label "Language devices are often used in headlines"@en ;
  dcterms:modified "2026-02-12T08:59:21.601374Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1941-4
  a curric:KeyLearningPoint ;
  rdfs:label "Sub-headings can be used to give more detail about a story"@en ;
  dcterms:modified "2026-02-12T08:59:21.601382Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1941-5
  a curric:KeyLearningPoint ;
  rdfs:label "Subheadings ought to short and snappy"@en ;
  dcterms:modified "2026-02-12T08:59:21.601390Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29486-1
  a curric:KeyLearningPoint ;
  rdfs:label """Armitage was inspired to write ‘About his person’ by reading news reports of people who were found dead."""@en ;
  dcterms:modified "2026-02-12T08:59:21.604508Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29486-2
  a curric:KeyLearningPoint ;
  rdfs:label """He liked the idea that you could build a picture of someone’s character from the objects they had on them."""@en ;
  dcterms:modified "2026-02-12T08:59:21.604515Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29486-3
  a curric:KeyLearningPoint ;
  rdfs:label """Armitage was inspired to write ‘Poem’ from reading different biographies and autobiographies."""@en ;
  dcterms:modified "2026-02-12T08:59:21.604523Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29486-4
  a curric:KeyLearningPoint ;
  rdfs:label """He suggests that reading different biographies can give us a completely different impression of the same person."""@en ;
  dcterms:modified "2026-02-12T08:59:21.604535Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29484-1
  a curric:KeyLearningPoint ;
  rdfs:label "Simon Armitage is the UK poet laureate."@en ;
  dcterms:modified "2026-02-12T08:59:21.605455Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29484-2
  a curric:KeyLearningPoint ;
  rdfs:label """Armitage suggests that there is something secretive about poetry - it can create a refuge."""@en ;
  dcterms:modified "2026-02-12T08:59:21.605468Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29484-3
  a curric:KeyLearningPoint ;
  rdfs:label """Armitage suggests that poetry has more similarities with sculpture, photography or painting than prose."""@en ;
  dcterms:modified "2026-02-12T08:59:21.605476Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29484-4
  a curric:KeyLearningPoint ;
  rdfs:label """Armitage suggests that poetry is different to song lyrics because poetry needs to bring musicality through language."""@en ;
  dcterms:modified "2026-02-12T08:59:21.605484Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29484-5
  a curric:KeyLearningPoint ;
  rdfs:label "Armitage suggests that poetry is a more thoughtful way of approaching the world."@en ;
  dcterms:modified "2026-02-12T08:59:21.605492Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1565-1
  a curric:KeyLearningPoint ;
  rdfs:label """Victor is presented as a highly irresponsible character, whose negligence has disastrous consequences."""@en ;
  dcterms:modified "2026-02-12T08:59:21.610542Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1565-2
  a curric:KeyLearningPoint ;
  rdfs:label "If given an extract, annotate it with ideas in response to the question."@en ;
  dcterms:modified "2026-02-12T08:59:21.610550Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1565-3
  a curric:KeyLearningPoint ;
  rdfs:label """Single paragraph outlines are useful for organising your ideas into a coherent structure."""@en ;
  dcterms:modified "2026-02-12T08:59:21.610557Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1565-4
  a curric:KeyLearningPoint ;
  rdfs:label """Single paragraph outlines contain a topic sentence, supporting detail and a concluding sentence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.610564Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1565-5
  a curric:KeyLearningPoint ;
  rdfs:label "A single paragraph outline should be planned for each section of your response."@en ;
  dcterms:modified "2026-02-12T08:59:21.610575Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1505-1
  a curric:KeyLearningPoint ;
  rdfs:label """Beck is interested in exploring both the physical and psychological effects of World War One on Alfred."""@en ;
  dcterms:modified "2026-02-12T08:59:21.610630Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1505-2
  a curric:KeyLearningPoint ;
  rdfs:label "Some of Alfred’s actions and thoughts suggest he has some form of PTSD."@en ;
  dcterms:modified "2026-02-12T08:59:21.610638Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1505-3
  a curric:KeyLearningPoint ;
  rdfs:label """Many soldiers suffered from PTSD (or what was then known as 'shell shock') following World War One."""@en ;
  dcterms:modified "2026-02-12T08:59:21.610645Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1505-4
  a curric:KeyLearningPoint ;
  rdfs:label "PTSD was not well understood in the early 20th century."@en ;
  dcterms:modified "2026-02-12T08:59:21.610652Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1505-5
  a curric:KeyLearningPoint ;
  rdfs:label """Beck’s short story is part of a body of literature which explores the experiences of PTSD caused by World War One."""@en ;
  dcterms:modified "2026-02-12T08:59:21.610659Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1838-1
  a curric:KeyLearningPoint ;
  rdfs:label """A flashback is a transition in a story to an earlier time in the life of one or more characters."""@en ;
  dcterms:modified "2026-02-12T08:59:21.610667Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1838-2
  a curric:KeyLearningPoint ;
  rdfs:label "Flashbacks are often vivid and give us further information about a character."@en ;
  dcterms:modified "2026-02-12T08:59:21.610674Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1838-3
  a curric:KeyLearningPoint ;
  rdfs:label """Natasha Bowen makes use of flashback in the opening chapter to hint at Simidele's life before she became a Mami Wata."""@en ;
  dcterms:modified "2026-02-12T08:59:21.610681Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1838-4
  a curric:KeyLearningPoint ;
  rdfs:label """Bowen relies on the present participle verb and imagery to make the flashback vivid."""@en ;
  dcterms:modified "2026-02-12T08:59:21.610689Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1522-1
  a curric:KeyLearningPoint ;
  rdfs:label "Vera Brittain (1893-1970) was a British writer and nurse."@en ;
  dcterms:modified "2026-02-12T08:59:21.611002Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1522-2
  a curric:KeyLearningPoint ;
  rdfs:label "Brittain is best known for her 1933 memoir ‘Testament of Youth’."@en ;
  dcterms:modified "2026-02-12T08:59:21.611010Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1522-3
  a curric:KeyLearningPoint ;
  rdfs:label """‘Testament of Youth’ recounts Brittain’s personal experiences of loneliness and loss during World War One."""@en ;
  dcterms:modified "2026-02-12T08:59:21.611017Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1522-4
  a curric:KeyLearningPoint ;
  rdfs:label """Skimming and scanning a text involves quickly reading something, and gathering its main ideas and overall tone."""@en ;
  dcterms:modified "2026-02-12T08:59:21.611028Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1522-5
  a curric:KeyLearningPoint ;
  rdfs:label """Close reading involves carefully considering a writer’s methods and their effects."""@en ;
  dcterms:modified "2026-02-12T08:59:21.611036Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28407-1
  a curric:KeyLearningPoint ;
  rdfs:label "Planning is an important part of the debating process."@en ;
  dcterms:modified "2026-02-12T08:59:21.611284Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28407-2
  a curric:KeyLearningPoint ;
  rdfs:label """Being prepared will mean you can confidently deliver your arguments and rebuttals."""@en ;
  dcterms:modified "2026-02-12T08:59:21.611291Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28407-3
  a curric:KeyLearningPoint ;
  rdfs:label "Positive body language can help if you feel nervous."@en ;
  dcterms:modified "2026-02-12T08:59:21.611302Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28407-4
  a curric:KeyLearningPoint ;
  rdfs:label """It’s important to reflect after a debate so you can understand what to improve next time."""@en ;
  dcterms:modified "2026-02-12T08:59:21.611313Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-859-1
  a curric:KeyLearningPoint ;
  rdfs:label """Use the first reading of an unseen extract to establish key information about plot, character and setting"""@en ;
  dcterms:modified "2026-02-12T08:59:21.611614Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-859-2
  a curric:KeyLearningPoint ;
  rdfs:label """Next, read the text more closely to consider the meaning of specific words and phrases"""@en ;
  dcterms:modified "2026-02-12T08:59:21.611622Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-859-3
  a curric:KeyLearningPoint ;
  rdfs:label "Writers use specific words and phrases to create a clear atmosphere"@en ;
  dcterms:modified "2026-02-12T08:59:21.611629Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1511-1
  a curric:KeyLearningPoint ;
  rdfs:label """To write convincingly, you must have a secure understanding of tone, audience and purpose."""@en ;
  dcterms:modified "2026-02-12T08:59:21.612657Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1511-2
  a curric:KeyLearningPoint ;
  rdfs:label "Tone is created through carefully crafted methods."@en ;
  dcterms:modified "2026-02-12T08:59:21.612664Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29634-1
  a curric:KeyLearningPoint ;
  rdfs:label """Edmundson suggests there is a “freedom” to writing adaptations that requires you to think differently."""@en ;
  dcterms:modified "2026-02-12T08:59:21.613643Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29634-2
  a curric:KeyLearningPoint ;
  rdfs:label "Edmundson describes the challenge of shortening or reworking character stories."@en ;
  dcterms:modified "2026-02-12T08:59:21.613650Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29634-3
  a curric:KeyLearningPoint ;
  rdfs:label """Edmundson explains the significance of direct address and its link to the personal stories the characters tell."""@en ;
  dcterms:modified "2026-02-12T08:59:21.613657Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29634-4
  a curric:KeyLearningPoint ;
  rdfs:label """Edmundson describes the importance of the close working relationship she had with Andrea Levy."""@en ;
  dcterms:modified "2026-02-12T08:59:21.613664Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29634-5
  a curric:KeyLearningPoint ;
  rdfs:label """Edmundson and Levy made a conscious decision to keep challenging scenes and moments in the play."""@en ;
  dcterms:modified "2026-02-12T08:59:21.613670Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1756-1
  a curric:KeyLearningPoint ;
  rdfs:label """The pitch, tempo, loudness and tone of voice used in speeches can enhance the content."""@en ;
  dcterms:modified "2026-02-12T08:59:21.615916Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1756-2
  a curric:KeyLearningPoint ;
  rdfs:label """Gesture and posture can be used to engage the audience and to add emphasis to important points."""@en ;
  dcterms:modified "2026-02-12T08:59:21.615922Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1756-3
  a curric:KeyLearningPoint ;
  rdfs:label "Spoken language often needs to be slower than feels natural."@en ;
  dcterms:modified "2026-02-12T08:59:21.615929Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1756-4
  a curric:KeyLearningPoint ;
  rdfs:label """You need to consider your spatial behaviour - too much movement can be distracting but too little can be wooden."""@en ;
  dcterms:modified "2026-02-12T08:59:21.615939Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1926-1
  a curric:KeyLearningPoint ;
  rdfs:label "The process of moving home can be very difficult and emotional."@en ;
  dcterms:modified "2026-02-12T08:59:21.617520Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1926-2
  a curric:KeyLearningPoint ;
  rdfs:label "The poem ‘Island Man’ is based on Nichols’ own experience of migration"@en ;
  dcterms:modified "2026-02-12T08:59:21.617526Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1926-3
  a curric:KeyLearningPoint ;
  rdfs:label "‘Island Man’ suggests a fondness and nostalgia for life in the Caribbean."@en ;
  dcterms:modified "2026-02-12T08:59:21.617532Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1926-4
  a curric:KeyLearningPoint ;
  rdfs:label "‘Island Man’ shows the difficulties one might face adjusting to a new home."@en ;
  dcterms:modified "2026-02-12T08:59:21.617538Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1926-5
  a curric:KeyLearningPoint ;
  rdfs:label """‘Island Man’ is arranged in two sections perhaps reflecting the dual nature of the man’s identity after migration."""@en ;
  dcterms:modified "2026-02-12T08:59:21.617545Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1757-1
  a curric:KeyLearningPoint ;
  rdfs:label """Reading from a script, or memorising a speech word for word, can lead to a less engaging delivery."""@en ;
  dcterms:modified "2026-02-12T08:59:21.618267Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1757-2
  a curric:KeyLearningPoint ;
  rdfs:label """If you take questions at the end, you should respond with new content rather than repeating parts of the speech."""@en ;
  dcterms:modified "2026-02-12T08:59:21.618273Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1757-3
  a curric:KeyLearningPoint ;
  rdfs:label "Asking open questions can invite developed responses."@en ;
  dcterms:modified "2026-02-12T08:59:21.618279Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1757-4
  a curric:KeyLearningPoint ;
  rdfs:label "Body language and eye contact support the successful delivery of a speech."@en ;
  dcterms:modified "2026-02-12T08:59:21.618285Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1757-5
  a curric:KeyLearningPoint ;
  rdfs:label """Speeches are much more engaging when the speaker does not simply read off a page."""@en ;
  dcterms:modified "2026-02-12T08:59:21.618291Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1600-1
  a curric:KeyLearningPoint ;
  rdfs:label "Body language and eye contact support the successful delivery of a speech."@en ;
  dcterms:modified "2026-02-12T08:59:21.621233Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1600-2
  a curric:KeyLearningPoint ;
  rdfs:label "Pace, pitch and tone can help to emphasise important words."@en ;
  dcterms:modified "2026-02-12T08:59:21.621239Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1600-3
  a curric:KeyLearningPoint ;
  rdfs:label """Gesture and posture can be used to engage the audience and to add emphasis to important points."""@en ;
  dcterms:modified "2026-02-12T08:59:21.621245Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1600-4
  a curric:KeyLearningPoint ;
  rdfs:label "Spoken language often needs to be slower than feels natural."@en ;
  dcterms:modified "2026-02-12T08:59:21.621251Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1600-5
  a curric:KeyLearningPoint ;
  rdfs:label """Speeches are much more engaging when the speaker does not simply read off a page."""@en ;
  dcterms:modified "2026-02-12T08:59:21.621257Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1509-1
  a curric:KeyLearningPoint ;
  rdfs:label """Writers spend as long choosing deliberate verbs and precise adjectives as they do on other methods."""@en ;
  dcterms:modified "2026-02-12T08:59:21.621607Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1509-2
  a curric:KeyLearningPoint ;
  rdfs:label """Verbs tell us how an action is done, and so can give an insight into character, atmosphere and tone."""@en ;
  dcterms:modified "2026-02-12T08:59:21.621612Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1509-3
  a curric:KeyLearningPoint ;
  rdfs:label "Adjectives describe nouns and also impact tone."@en ;
  dcterms:modified "2026-02-12T08:59:21.621618Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27916-1
  a curric:KeyLearningPoint ;
  rdfs:label """Careful selection of verbs and adverbs are key in description as they strongly impact meaning."""@en ;
  dcterms:modified "2026-02-12T08:59:21.622748Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27916-2
  a curric:KeyLearningPoint ;
  rdfs:label """Changing a verb or adverb in your creative writing can change the way the reader views a character."""@en ;
  dcterms:modified "2026-02-12T08:59:21.622756Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27916-3
  a curric:KeyLearningPoint ;
  rdfs:label "Using specific language can reveal a character’s intentions and emotions."@en ;
  dcterms:modified "2026-02-12T08:59:21.622762Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27916-4
  a curric:KeyLearningPoint ;
  rdfs:label """Being clear what your intention is before writing will help you make more effective word choices."""@en ;
  dcterms:modified "2026-02-12T08:59:21.622768Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1823-1
  a curric:KeyLearningPoint ;
  rdfs:label """The opening of a comparative paragraph could start with a topic sentence which states the paragraphs main idea."""@en ;
  dcterms:modified "2026-02-12T08:59:21.624775Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1823-2
  a curric:KeyLearningPoint ;
  rdfs:label "Next, the comparative paragraph could focus on analysing the first text."@en ;
  dcterms:modified "2026-02-12T08:59:21.624781Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1823-3
  a curric:KeyLearningPoint ;
  rdfs:label """Then, a comparative paragraph could focus on the second text, comparing it to the first."""@en ;
  dcterms:modified "2026-02-12T08:59:21.624786Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1823-4
  a curric:KeyLearningPoint ;
  rdfs:label "Comparing the methods writers have used can help to develop the comparison."@en ;
  dcterms:modified "2026-02-12T08:59:21.624792Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1823-5
  a curric:KeyLearningPoint ;
  rdfs:label "The final sentence of a comparative paragraph could link to the topic sentence."@en ;
  dcterms:modified "2026-02-12T08:59:21.624797Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1775-1
  a curric:KeyLearningPoint ;
  rdfs:label """Context can refer to key concepts, such as colourism or colonial attitudes, which inform our understanding of the text."""@en ;
  dcterms:modified "2026-02-12T08:59:21.630380Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1775-2
  a curric:KeyLearningPoint ;
  rdfs:label "Context refers to historical, social, literary and biographical information."@en ;
  dcterms:modified "2026-02-12T08:59:21.630385Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1775-3
  a curric:KeyLearningPoint ;
  rdfs:label "Context should not be presented as isolated facts."@en ;
  dcterms:modified "2026-02-12T08:59:21.630394Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1775-4
  a curric:KeyLearningPoint ;
  rdfs:label "Context should be relevant to the analysis and woven in the response."@en ;
  dcterms:modified "2026-02-12T08:59:21.630401Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1775-5
  a curric:KeyLearningPoint ;
  rdfs:label """Context should develop your ideas and give an insight into the writer’s purpose and intention."""@en ;
  dcterms:modified "2026-02-12T08:59:21.630406Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29642-1
  a curric:KeyLearningPoint ;
  rdfs:label """Norris explains how the production coincided with the Windrush scandal and helped highlight its story."""@en ;
  dcterms:modified "2026-02-12T08:59:21.631081Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29642-2
  a curric:KeyLearningPoint ;
  rdfs:label """Norris emphasises the importance of direct address in creating a connection between the characters and the audience."""@en ;
  dcterms:modified "2026-02-12T08:59:21.631086Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29642-3
  a curric:KeyLearningPoint ;
  rdfs:label """Norris says focusing on three characters strengthened the metaphor of Jamaica and the UK as two connected islands."""@en ;
  dcterms:modified "2026-02-12T08:59:21.631091Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29642-4
  a curric:KeyLearningPoint ;
  rdfs:label """Norris explains the challenge of producing the play during the significant events of 2019 to 2022."""@en ;
  dcterms:modified "2026-02-12T08:59:21.631095Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29642-5
  a curric:KeyLearningPoint ;
  rdfs:label """Norris suggests that the play is hopeful because there is “love”, but it remains realistic."""@en ;
  dcterms:modified "2026-02-12T08:59:21.631103Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1789-1
  a curric:KeyLearningPoint ;
  rdfs:label "An introduction and conclusion should follow a three part structure."@en ;
  dcterms:modified "2026-02-12T08:59:21.631506Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1789-2
  a curric:KeyLearningPoint ;
  rdfs:label "An excellent introduction should start with a general statement about the text."@en ;
  dcterms:modified "2026-02-12T08:59:21.631510Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1789-3
  a curric:KeyLearningPoint ;
  rdfs:label """An introduction should then have a more specific statement about the focus of the question, followed by a thesis."""@en ;
  dcterms:modified "2026-02-12T08:59:21.631517Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1789-4
  a curric:KeyLearningPoint ;
  rdfs:label """A thesis statement should include a clear, overarching argument referring to the writer's purpose."""@en ;
  dcterms:modified "2026-02-12T08:59:21.631522Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1789-5
  a curric:KeyLearningPoint ;
  rdfs:label """A conclusion should summarise, evaluate and consider the timeless nature of the text."""@en ;
  dcterms:modified "2026-02-12T08:59:21.631527Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1790-1
  a curric:KeyLearningPoint ;
  rdfs:label "The characters in ‘Small Island’ have tumultuous journies."@en ;
  dcterms:modified "2026-02-12T08:59:21.631575Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1790-2
  a curric:KeyLearningPoint ;
  rdfs:label "The characters are changed as a result of their experiences."@en ;
  dcterms:modified "2026-02-12T08:59:21.631583Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1790-3
  a curric:KeyLearningPoint ;
  rdfs:label "Edmundson creates tension through the use of dramatic irony."@en ;
  dcterms:modified "2026-02-12T08:59:21.631588Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1790-4
  a curric:KeyLearningPoint ;
  rdfs:label "Edmundson uses a motif in her settings to create tension."@en ;
  dcterms:modified "2026-02-12T08:59:21.631593Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1785-1
  a curric:KeyLearningPoint ;
  rdfs:label "A thesis statement is a clear, overarching argument."@en ;
  dcterms:modified "2026-02-12T08:59:21.632370Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1785-2
  a curric:KeyLearningPoint ;
  rdfs:label "Topic sentences give focus to individual paragraphs."@en ;
  dcterms:modified "2026-02-12T08:59:21.632375Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1785-3
  a curric:KeyLearningPoint ;
  rdfs:label "Select main quotations and supporting quotations to include in an essay."@en ;
  dcterms:modified "2026-02-12T08:59:21.632380Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1785-4
  a curric:KeyLearningPoint ;
  rdfs:label """Main quotations should be analysed; supporting quotations don’t need to be analysed."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632385Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1786-1
  a curric:KeyLearningPoint ;
  rdfs:label """Edmundson uses stage directions to present the emotional turmoil of the characters."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632773Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1786-2
  a curric:KeyLearningPoint ;
  rdfs:label "Setting is used to reflect the characters’ situations and key themes."@en ;
  dcterms:modified "2026-02-12T08:59:21.632777Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1786-3
  a curric:KeyLearningPoint ;
  rdfs:label """Edmundson uses imagery to present the idealistic view of England held by Gilbert and other characters."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632782Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1786-4
  a curric:KeyLearningPoint ;
  rdfs:label "Edmundson reveals the reality of racism that Hortense and Gilbert endure."@en ;
  dcterms:modified "2026-02-12T08:59:21.632787Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29636-1
  a curric:KeyLearningPoint ;
  rdfs:label "Act 1 Scene 2 transitions from Kingston Jamaica, 1939, to London England, 1941."@en ;
  dcterms:modified "2026-02-12T08:59:21.633095Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29636-2
  a curric:KeyLearningPoint ;
  rdfs:label """In Act 1 Scene 2 we are introduced to Queenie who uses direct address until her story “catches up with her”."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633099Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29636-3
  a curric:KeyLearningPoint ;
  rdfs:label """Norris explains the use of video footage in creating specific atmospheres and settings."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633104Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29636-4
  a curric:KeyLearningPoint ;
  rdfs:label """Norris uses actors, shadows, and props to overcome staging challenges and vividly create the impact of the bombing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633109Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29636-5
  a curric:KeyLearningPoint ;
  rdfs:label "Norris acknowledges the humour in the scene compared to Scene 1."@en ;
  dcterms:modified "2026-02-12T08:59:21.633113Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1787-1
  a curric:KeyLearningPoint ;
  rdfs:label """Bernard's behaviour is a poignant reminder of the racist and discriminatory attitudes of the time."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633694Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1787-2
  a curric:KeyLearningPoint ;
  rdfs:label "Parallels can be drawn between Bernard and Miss Todd."@en ;
  dcterms:modified "2026-02-12T08:59:21.633699Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1787-3
  a curric:KeyLearningPoint ;
  rdfs:label "Edmundson uses symbolism to explore the theme of hope."@en ;
  dcterms:modified "2026-02-12T08:59:21.633704Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1787-4
  a curric:KeyLearningPoint ;
  rdfs:label "Bernard's reaction to the baby encapsulates a promise of reparation and hope."@en ;
  dcterms:modified "2026-02-12T08:59:21.633708Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1788-1
  a curric:KeyLearningPoint ;
  rdfs:label """Queenie asks Hortense and Gilbert to adopt her baby, revealing the impact of societal attitudes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633732Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1788-2
  a curric:KeyLearningPoint ;
  rdfs:label "Hortense’s feelings for Gilbert transform into love and pride."@en ;
  dcterms:modified "2026-02-12T08:59:21.633737Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1788-3
  a curric:KeyLearningPoint ;
  rdfs:label "Hope is a central theme to the play."@en ;
  dcterms:modified "2026-02-12T08:59:21.633742Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1788-4
  a curric:KeyLearningPoint ;
  rdfs:label """Edmundson reveals the uncertainty of the future in the lack of resolution and cyclical structure."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633746Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1788-5
  a curric:KeyLearningPoint ;
  rdfs:label """Offering a balanced argument and exploration of different themes, adds nuance to your evaluative responses."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633751Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1782-1
  a curric:KeyLearningPoint ;
  rdfs:label "Annotating an essay question is a good way to understand the focus."@en ;
  dcterms:modified "2026-02-12T08:59:21.634226Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1782-2
  a curric:KeyLearningPoint ;
  rdfs:label "A thesis is a clear overarching argument supported by the whole text."@en ;
  dcterms:modified "2026-02-12T08:59:21.634231Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1782-3
  a curric:KeyLearningPoint ;
  rdfs:label """An effective thesis statement will focus on the big ideas and make reference to the whole text."""@en ;
  dcterms:modified "2026-02-12T08:59:21.634235Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1782-4
  a curric:KeyLearningPoint ;
  rdfs:label """Topic sentences start each paragraph and will focus on a specific character or moment in the text."""@en ;
  dcterms:modified "2026-02-12T08:59:21.634243Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1974-1
  a curric:KeyLearningPoint ;
  rdfs:label """Inferences usually rely on things that haven’t been explicitly stated, but rather, hinted at or suggested."""@en ;
  dcterms:modified "2026-02-12T08:59:21.634403Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1974-2
  a curric:KeyLearningPoint ;
  rdfs:label """We can use connotations to help us make inferences about a particular word or phrase."""@en ;
  dcterms:modified "2026-02-12T08:59:21.634408Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1974-3
  a curric:KeyLearningPoint ;
  rdfs:label """Making links to the Gothic can make our inferences about 'The Twisted Tree' stronger."""@en ;
  dcterms:modified "2026-02-12T08:59:21.634413Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1974-4
  a curric:KeyLearningPoint ;
  rdfs:label "Effective analysis is developed and can include an additional inference."@en ;
  dcterms:modified "2026-02-12T08:59:21.634418Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29635-1
  a curric:KeyLearningPoint ;
  rdfs:label """Norris explains the importance of the Pathé news clips in positioning the audience in a specific time and place."""@en ;
  dcterms:modified "2026-02-12T08:59:21.634906Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29635-2
  a curric:KeyLearningPoint ;
  rdfs:label """Direct address establishes Hortense as a confident character and fades as her heart is broken."""@en ;
  dcterms:modified "2026-02-12T08:59:21.634911Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29635-3
  a curric:KeyLearningPoint ;
  rdfs:label """Norris describes the audience’s “agreement” that allows imagination and make-believe in theatre staging."""@en ;
  dcterms:modified "2026-02-12T08:59:21.634915Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29635-4
  a curric:KeyLearningPoint ;
  rdfs:label "Act 1 Scene 1 begins with a hurricane and introduces the character Hortense."@en ;
  dcterms:modified "2026-02-12T08:59:21.634920Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1792-1
  a curric:KeyLearningPoint ;
  rdfs:label "An essay should establish, develop and sustain an argument."@en ;
  dcterms:modified "2026-02-12T08:59:21.635076Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1792-2
  a curric:KeyLearningPoint ;
  rdfs:label "Using a checklist can help to create specific feedback."@en ;
  dcterms:modified "2026-02-12T08:59:21.635111Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1792-3
  a curric:KeyLearningPoint ;
  rdfs:label """Thesis statements and topic sentences should link and focus on writer's intentions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.635117Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1792-4
  a curric:KeyLearningPoint ;
  rdfs:label """Quotations should be included and analysed considering a range of methods and audience reactions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.635124Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1792-5
  a curric:KeyLearningPoint ;
  rdfs:label "Using specific sentence structures and phrases can help to rewrite essays."@en ;
  dcterms:modified "2026-02-12T08:59:21.635129Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29640-1
  a curric:KeyLearningPoint ;
  rdfs:label """Norris explains that Act 2 mostly takes place in the house, as opposed to Act 1, which has different environments."""@en ;
  dcterms:modified "2026-02-12T08:59:21.635555Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29640-2
  a curric:KeyLearningPoint ;
  rdfs:label """Act 2 uses the revolving stage to show different views of the house without changing sets."""@en ;
  dcterms:modified "2026-02-12T08:59:21.635562Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29640-3
  a curric:KeyLearningPoint ;
  rdfs:label """Norris describes how the use of video becomes less apparent in Act 2 as the characters’ lives become more serious."""@en ;
  dcterms:modified "2026-02-12T08:59:21.635567Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29640-4
  a curric:KeyLearningPoint ;
  rdfs:label """There is no direct address in Act 2, making it feel more serious and less hopeful."""@en ;
  dcterms:modified "2026-02-12T08:59:21.635575Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29640-5
  a curric:KeyLearningPoint ;
  rdfs:label """Norris describes subtle “flights of fancy” with “Aunty” and “Michael” as reminders of the hope from Act 1."""@en ;
  dcterms:modified "2026-02-12T08:59:21.635579Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29638-1
  a curric:KeyLearningPoint ;
  rdfs:label """Norris explains that the second half of Act 1 is where the characters’ stories start to intertwine."""@en ;
  dcterms:modified "2026-02-12T08:59:21.635669Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29638-2
  a curric:KeyLearningPoint ;
  rdfs:label """Norris highlights the theatrical transition from Arthur’s death to the war’s end as a striking use of juxtaposition."""@en ;
  dcterms:modified "2026-02-12T08:59:21.635674Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29638-3
  a curric:KeyLearningPoint ;
  rdfs:label "Norris suggests that Hortense is a flawed and complex character."@en ;
  dcterms:modified "2026-02-12T08:59:21.635678Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29638-4
  a curric:KeyLearningPoint ;
  rdfs:label """Norris emphasises the effective use of staging in moving deftly between the different settings and situations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.635683Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29638-5
  a curric:KeyLearningPoint ;
  rdfs:label """Rufus Norris ends Act 1 with the iconic Windrush image to create a powerful symbol of hope and new beginnings."""@en ;
  dcterms:modified "2026-02-12T08:59:21.635687Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1784-1
  a curric:KeyLearningPoint ;
  rdfs:label """Miss Todd, much like Bernard, represents the racist and outdated attitudes present in society."""@en ;
  dcterms:modified "2026-02-12T08:59:21.636192Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1784-2
  a curric:KeyLearningPoint ;
  rdfs:label """Edmundson includes brutal dialogue, to show the racial slurs and abuse endured by Gilbert and Hortense."""@en ;
  dcterms:modified "2026-02-12T08:59:21.636197Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1784-3
  a curric:KeyLearningPoint ;
  rdfs:label """Hortense and Gilbert see important characters from their lives which allows the audience to see their internal thoughts."""@en ;
  dcterms:modified "2026-02-12T08:59:21.636201Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1784-4
  a curric:KeyLearningPoint ;
  rdfs:label "Edmundson explores the concept of home and belonging."@en ;
  dcterms:modified "2026-02-12T08:59:21.636209Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1784-5
  a curric:KeyLearningPoint ;
  rdfs:label "Edmundson foregrounds the emotional experiences of the Caribbean diaspora."@en ;
  dcterms:modified "2026-02-12T08:59:21.636214Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1791-1
  a curric:KeyLearningPoint ;
  rdfs:label """You need to include an introduction and thesis statement about the writer's intention."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649626Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1791-2
  a curric:KeyLearningPoint ;
  rdfs:label """Each paragraph begins with a topic sentence, also based on the writer's intention."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649631Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1791-3
  a curric:KeyLearningPoint ;
  rdfs:label """Form is important - we need to consider stagecraft and the ways in which the novel was adapted."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649637Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1791-4
  a curric:KeyLearningPoint ;
  rdfs:label "Comment on a range of methods, including characterisation and setting."@en ;
  dcterms:modified "2026-02-12T08:59:21.649645Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1791-5
  a curric:KeyLearningPoint ;
  rdfs:label "Planning is an important part of the writing process."@en ;
  dcterms:modified "2026-02-12T08:59:21.649650Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1983-1
  a curric:KeyLearningPoint ;
  rdfs:label "Topic sentences state a paragraph's main idea."@en ;
  dcterms:modified "2026-02-12T08:59:21.684593Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1983-2
  a curric:KeyLearningPoint ;
  rdfs:label "Topic sentences should develop and maintain your thesis."@en ;
  dcterms:modified "2026-02-12T08:59:21.684597Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1983-3
  a curric:KeyLearningPoint ;
  rdfs:label "Each analytical paragraph should have at least two relevant quotations."@en ;
  dcterms:modified "2026-02-12T08:59:21.684602Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1983-4
  a curric:KeyLearningPoint ;
  rdfs:label "Select main quotations and supporting quotations to include in a response."@en ;
  dcterms:modified "2026-02-12T08:59:21.684606Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1983-5
  a curric:KeyLearningPoint ;
  rdfs:label """Main quotations should be analysed; supporting quotations don't need to be analysed."""@en ;
  dcterms:modified "2026-02-12T08:59:21.684611Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1892-1
  a curric:KeyLearningPoint ;
  rdfs:label """When performing a poem, you should make informed decisions about the pace, volume and tone of your voice."""@en ;
  dcterms:modified "2026-02-12T08:59:21.684615Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1892-2
  a curric:KeyLearningPoint ;
  rdfs:label """Your pace, volume and tone could be very different at different moments of a poem."""@en ;
  dcterms:modified "2026-02-12T08:59:21.684620Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1892-3
  a curric:KeyLearningPoint ;
  rdfs:label """Experimenting with different ways of saying a poem can be a good way to decide on how you ultimately want to perform it."""@en ;
  dcterms:modified "2026-02-12T08:59:21.684628Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1892-4
  a curric:KeyLearningPoint ;
  rdfs:label """You will also want to consider body language and eye contact when performing a poem."""@en ;
  dcterms:modified "2026-02-12T08:59:21.684633Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1892-5
  a curric:KeyLearningPoint ;
  rdfs:label """When you don't know a poem by heart, consider how you will maintain a good level of eye contact with your audience."""@en ;
  dcterms:modified "2026-02-12T08:59:21.684638Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1795-1
  a curric:KeyLearningPoint ;
  rdfs:label """Shakespeare's tragedies, like many Jacobean tragedies, focus on the consequences of the disruption of social order"""@en ;
  dcterms:modified "2026-02-12T08:59:21.684642Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1795-2
  a curric:KeyLearningPoint ;
  rdfs:label """Elizabethan social order was based on ideas about creation from Genesis, where God gave everything a place in the world"""@en ;
  dcterms:modified "2026-02-12T08:59:21.684646Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1795-3
  a curric:KeyLearningPoint ;
  rdfs:label """Order, disorder and chaos are key themes and motifs. As civil order is disrupted, the natural world responds with chaos"""@en ;
  dcterms:modified "2026-02-12T08:59:21.684651Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1795-4
  a curric:KeyLearningPoint ;
  rdfs:label """The five-act structure tracks the downfall of a noble tragic hero, causing disorder and finally restoring order"""@en ;
  dcterms:modified "2026-02-12T08:59:21.684655Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1796-1
  a curric:KeyLearningPoint ;
  rdfs:label """Iago is an agent of disorder - his motive is less important than the impact of his actions on the tragic hero."""@en ;
  dcterms:modified "2026-02-12T08:59:21.684660Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1796-2
  a curric:KeyLearningPoint ;
  rdfs:label "Iago might be described as a malcontent."@en ;
  dcterms:modified "2026-02-12T08:59:21.684665Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1796-3
  a curric:KeyLearningPoint ;
  rdfs:label """Iago's diabolical nature is established in the line "I am not what I am", reflecting reversal and disorder."""@en ;
  dcterms:modified "2026-02-12T08:59:21.684669Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1796-4
  a curric:KeyLearningPoint ;
  rdfs:label """Iago causes disorder in the mind of Brabantio, by revealing his daughter's deceit."""@en ;
  dcterms:modified "2026-02-12T08:59:21.684674Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1712-1
  a curric:KeyLearningPoint ;
  rdfs:label """Ralph and Simon are the only boys interested in trying to build shelters for warmth and safety."""@en ;
  dcterms:modified "2026-02-12T08:59:21.684679Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1712-2
  a curric:KeyLearningPoint ;
  rdfs:label """Instead, the other boys' instincts is to play in the sea, free from the law and order of adults."""@en ;
  dcterms:modified "2026-02-12T08:59:21.684685Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1712-3
  a curric:KeyLearningPoint ;
  rdfs:label """A rift forms as Ralph criticises Jack's lack of support in hut-building and failures with hunting."""@en ;
  dcterms:modified "2026-02-12T08:59:21.684690Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1712-4
  a curric:KeyLearningPoint ;
  rdfs:label "Simon is presented as being helpful and seems at home in the beauty of nature."@en ;
  dcterms:modified "2026-02-12T08:59:21.684695Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1712-5
  a curric:KeyLearningPoint ;
  rdfs:label "Jack, on the other hand, wants to dominate nature by killing pigs."@en ;
  dcterms:modified "2026-02-12T08:59:21.684699Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1570-1
  a curric:KeyLearningPoint ;
  rdfs:label "Atmosphere is the mood or feeling of a piece of writing."@en ;
  dcterms:modified "2026-02-12T08:59:21.694971Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1570-2
  a curric:KeyLearningPoint ;
  rdfs:label """We would expect to find an ominous or tense atmosphere in Gothic literature, as this unsettles the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.694978Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1570-3
  a curric:KeyLearningPoint ;
  rdfs:label """Thornfield Hall is described as a very old, dark and Gothic setting with an ominous atmosphere."""@en ;
  dcterms:modified "2026-02-12T08:59:21.694982Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1570-4
  a curric:KeyLearningPoint ;
  rdfs:label """Brontë creates an unnerving atmosphere in Chapter 11 of ‘Jane Eyre’ through Jane's interaction with Mrs Fairfax."""@en ;
  dcterms:modified "2026-02-12T08:59:21.694987Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27917-1
  a curric:KeyLearningPoint ;
  rdfs:label """Figurative language is non-literal language. Examples of methods which are figurative include simile and metaphor."""@en ;
  dcterms:modified "2026-02-12T08:59:21.695034Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27917-2
  a curric:KeyLearningPoint ;
  rdfs:label """Using figurative language can help enhance your descriptions as it creates more vivid detail for the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.695039Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27917-3
  a curric:KeyLearningPoint ;
  rdfs:label """You should avoid using clichéd examples when crafting similes and metaphors. It's better to be original in thought."""@en ;
  dcterms:modified "2026-02-12T08:59:21.695043Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27917-4
  a curric:KeyLearningPoint ;
  rdfs:label """One way to avoid clichés is to add additional detail to make it specific to your character."""@en ;
  dcterms:modified "2026-02-12T08:59:21.695048Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2001-1
  a curric:KeyLearningPoint ;
  rdfs:label "Imagery uses words that create a clear image in the reader’s mind."@en ;
  dcterms:modified "2026-02-12T08:59:21.701215Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2001-2
  a curric:KeyLearningPoint ;
  rdfs:label "Similes compare two things using words such as 'like' or 'as'."@en ;
  dcterms:modified "2026-02-12T08:59:21.701219Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2001-3
  a curric:KeyLearningPoint ;
  rdfs:label "Personification gives human characteristics to something that is not human."@en ;
  dcterms:modified "2026-02-12T08:59:21.701224Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2001-4
  a curric:KeyLearningPoint ;
  rdfs:label "A metaphor compares two things, by saying one thing is another."@en ;
  dcterms:modified "2026-02-12T08:59:21.701229Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2001-5
  a curric:KeyLearningPoint ;
  rdfs:label "Language devices should match the tone that you have created."@en ;
  dcterms:modified "2026-02-12T08:59:21.701233Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1710-1
  a curric:KeyLearningPoint ;
  rdfs:label """In Chapter 1, we meet the characters Ralph, Piggy and Jack who have contrasting personalities."""@en ;
  dcterms:modified "2026-02-12T08:59:21.701237Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1710-2
  a curric:KeyLearningPoint ;
  rdfs:label "Piggy seems to be the weakest because he has a number of physical ailments."@en ;
  dcterms:modified "2026-02-12T08:59:21.701242Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1710-3
  a curric:KeyLearningPoint ;
  rdfs:label """Ralph uses the conch (a beautiful shell) to summon the other children on the island."""@en ;
  dcterms:modified "2026-02-12T08:59:21.701246Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1710-4
  a curric:KeyLearningPoint ;
  rdfs:label "Both Jack and Ralph want to be leader and Ralph is elected."@en ;
  dcterms:modified "2026-02-12T08:59:21.701251Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1710-5
  a curric:KeyLearningPoint ;
  rdfs:label "Jack uses his knife to try to kill a pig, but he is unable to strike the blow."@en ;
  dcterms:modified "2026-02-12T08:59:21.701255Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1825-1
  a curric:KeyLearningPoint ;
  rdfs:label """Symbolism is when writers use something tangible to represent an intangible idea."""@en ;
  dcterms:modified "2026-02-12T08:59:21.701262Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1825-2
  a curric:KeyLearningPoint ;
  rdfs:label """The Lady of Shalott symbolises the isolated artist and the sacrifices some make to create great art."""@en ;
  dcterms:modified "2026-02-12T08:59:21.701267Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1825-3
  a curric:KeyLearningPoint ;
  rdfs:label """Throughout the poem, Tennyson emphasises that the Lady of Shalott is a great artist."""@en ;
  dcterms:modified "2026-02-12T08:59:21.701272Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1825-4
  a curric:KeyLearningPoint ;
  rdfs:label """However, Tennyson also emphasises how much the Lady of Shalott sacrifices to create her beautiful art."""@en ;
  dcterms:modified "2026-02-12T08:59:21.701276Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1825-5
  a curric:KeyLearningPoint ;
  rdfs:label """It is up to the reader to decide whether the Lady of Shalott made the right decision to leave her isolated tower."""@en ;
  dcterms:modified "2026-02-12T08:59:21.701281Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1940-1
  a curric:KeyLearningPoint ;
  rdfs:label """Some Victorian readers had prejudiced views about people who were from and spent time in British colonies"""@en ;
  dcterms:modified "2026-02-12T08:59:21.701285Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1940-2
  a curric:KeyLearningPoint ;
  rdfs:label "Dr. Roylott is presented as an aggressive and brutal man"@en ;
  dcterms:modified "2026-02-12T08:59:21.701290Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1940-3
  a curric:KeyLearningPoint ;
  rdfs:label """Dr. Roylott has a strong motive for killing Julia Stoner: he would lose money if she survived and married"""@en ;
  dcterms:modified "2026-02-12T08:59:21.701295Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1940-4
  a curric:KeyLearningPoint ;
  rdfs:label "Holmes believes Dr. Roylott is behind the murder"@en ;
  dcterms:modified "2026-02-12T08:59:21.701299Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1940-5
  a curric:KeyLearningPoint ;
  rdfs:label """You can construct a convincing argument using emotive language and range of rhetorical devices"""@en ;
  dcterms:modified "2026-02-12T08:59:21.701304Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1890-1
  a curric:KeyLearningPoint ;
  rdfs:label """When writing a poem inspired by a particular writer, their ideas and / or methods might inspire you."""@en ;
  dcterms:modified "2026-02-12T08:59:21.701308Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1890-2
  a curric:KeyLearningPoint ;
  rdfs:label """You could use Angelou's writing routine to spark your creativity e.g. generating ideas about a particular theme."""@en ;
  dcterms:modified "2026-02-12T08:59:21.701315Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1890-3
  a curric:KeyLearningPoint ;
  rdfs:label """When selecting which methods you want to use in a poem, consider how each method will help you convey your ideas."""@en ;
  dcterms:modified "2026-02-12T08:59:21.701322Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1970-1
  a curric:KeyLearningPoint ;
  rdfs:label "Martha and her mother resolve their disagreement."@en ;
  dcterms:modified "2026-02-12T08:59:21.701327Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1970-2
  a curric:KeyLearningPoint ;
  rdfs:label "Stig and Gandalf are revealed to be alive."@en ;
  dcterms:modified "2026-02-12T08:59:21.701332Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1970-3
  a curric:KeyLearningPoint ;
  rdfs:label "Martha's mother decides to move so she can tend to the tree."@en ;
  dcterms:modified "2026-02-12T08:59:21.701336Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1970-4
  a curric:KeyLearningPoint ;
  rdfs:label "Martha feels more confident in herself by the end of the novel."@en ;
  dcterms:modified "2026-02-12T08:59:21.701341Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1970-5
  a curric:KeyLearningPoint ;
  rdfs:label "Burge offers an effective resolution, but there are still unanswered questions."@en ;
  dcterms:modified "2026-02-12T08:59:21.701345Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1929-1
  a curric:KeyLearningPoint ;
  rdfs:label """Effective discussions will take turns, develop ideas, use evidence and respond to the other speaker."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705332Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1929-2
  a curric:KeyLearningPoint ;
  rdfs:label """You can agree, build upon or challenge ideas to develop better communication between you and peers."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705337Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1929-3
  a curric:KeyLearningPoint ;
  rdfs:label """Many different things can help to define a city such as architecture, social factors and heritage."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705341Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1929-4
  a curric:KeyLearningPoint ;
  rdfs:label "Cities often help to shape our identity."@en ;
  dcterms:modified "2026-02-12T08:59:21.705346Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27918-1
  a curric:KeyLearningPoint ;
  rdfs:label "Juxtaposition is a useful tool when describing contrasting characters."@en ;
  dcterms:modified "2026-02-12T08:59:21.707947Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27918-2
  a curric:KeyLearningPoint ;
  rdfs:label """Contrasting characters can deepen our understanding of their roles and personalities."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707951Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27918-3
  a curric:KeyLearningPoint ;
  rdfs:label """Placing contrasting characters in opposition can create dramatic tension and conflict."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707956Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27918-4
  a curric:KeyLearningPoint ;
  rdfs:label "Careful consideration of vocabulary choices aids our crafting of juxtaposition."@en ;
  dcterms:modified "2026-02-12T08:59:21.707960Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28406-1
  a curric:KeyLearningPoint ;
  rdfs:label """A rebuttal means having to track the opposing team’s argument and identifying any flaws."""@en ;
  dcterms:modified "2026-02-12T08:59:21.708022Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28406-2
  a curric:KeyLearningPoint ;
  rdfs:label """You will usually have time to prepare for a debate, this will help in creating effective rebuttals."""@en ;
  dcterms:modified "2026-02-12T08:59:21.708027Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28406-3
  a curric:KeyLearningPoint ;
  rdfs:label "Evidence can look like: statistics, expert testimonials and credible studies."@en ;
  dcterms:modified "2026-02-12T08:59:21.708031Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28406-4
  a curric:KeyLearningPoint ;
  rdfs:label """In a rebuttal you should aim to explain why and how you are challenging the argument."""@en ;
  dcterms:modified "2026-02-12T08:59:21.708036Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1586-1
  a curric:KeyLearningPoint ;
  rdfs:label """When planning an opinion article, the message needs to be consistent - your opinion is your message."""@en ;
  dcterms:modified "2026-02-12T08:59:21.709191Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1586-2
  a curric:KeyLearningPoint ;
  rdfs:label "You should identify between 3 and 4 reasons or examples to support your opinion."@en ;
  dcterms:modified "2026-02-12T08:59:21.709198Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1586-3
  a curric:KeyLearningPoint ;
  rdfs:label "Topic sentences help you to maintain a cohesive and convincing argument."@en ;
  dcterms:modified "2026-02-12T08:59:21.709203Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1586-4
  a curric:KeyLearningPoint ;
  rdfs:label """Aim to make your topic sentences as engaging as possible, as they introduce each new section of your argument."""@en ;
  dcterms:modified "2026-02-12T08:59:21.709207Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1586-5
  a curric:KeyLearningPoint ;
  rdfs:label """Rhetorical devices (such as direct address) can be used to elevate your topic sentences."""@en ;
  dcterms:modified "2026-02-12T08:59:21.709212Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1889-1
  a curric:KeyLearningPoint ;
  rdfs:label """We can make comments about Angelou's poetic voice by considering a number of her poems at the same time."""@en ;
  dcterms:modified "2026-02-12T08:59:21.709216Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1889-2
  a curric:KeyLearningPoint ;
  rdfs:label """When considering Angelou's poetic voice in an analytical paragraph, you should include (and explore) quotations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.709221Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1889-3
  a curric:KeyLearningPoint ;
  rdfs:label """When considering Angelou's poetic voice in an analytical paragraph, you could include context to develop your ideas."""@en ;
  dcterms:modified "2026-02-12T08:59:21.709225Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1889-4
  a curric:KeyLearningPoint ;
  rdfs:label "A single paragraph outline is a way of planning a paragraph."@en ;
  dcterms:modified "2026-02-12T08:59:21.709230Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1889-5
  a curric:KeyLearningPoint ;
  rdfs:label """First and final sentences of a single paragraph outline are written in full; supporting detail is written in note form."""@en ;
  dcterms:modified "2026-02-12T08:59:21.709234Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1894-1
  a curric:KeyLearningPoint ;
  rdfs:label """Shakespeare’s plays were performed at the Globe, which was and still is playing, at the South Bank in London"""@en ;
  dcterms:modified "2026-02-12T08:59:21.709982Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1894-2
  a curric:KeyLearningPoint ;
  rdfs:label """The South Bank was full of improper activities, such as animal fighting, drinking and the theatre"""@en ;
  dcterms:modified "2026-02-12T08:59:21.709988Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1894-3
  a curric:KeyLearningPoint ;
  rdfs:label "Some people, particularly Puritans, thought the theatre was immoral"@en ;
  dcterms:modified "2026-02-12T08:59:21.709996Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1894-4
  a curric:KeyLearningPoint ;
  rdfs:label "Going to the Globe in Shakespeare’s time would have been a noisy, riotous affair"@en ;
  dcterms:modified "2026-02-12T08:59:21.710001Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1894-5
  a curric:KeyLearningPoint ;
  rdfs:label """Going to the theatre now is different because the audience is much more polite and quiet"""@en ;
  dcterms:modified "2026-02-12T08:59:21.710005Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1898-1
  a curric:KeyLearningPoint ;
  rdfs:label "Prospero, Caliban and Ariel are the key characters in the text."@en ;
  dcterms:modified "2026-02-12T08:59:21.710125Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1898-2
  a curric:KeyLearningPoint ;
  rdfs:label "Ariel was freed from his imprisonment in a tree by Prospero."@en ;
  dcterms:modified "2026-02-12T08:59:21.710130Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1898-3
  a curric:KeyLearningPoint ;
  rdfs:label "At times, both Caliban and Ariel feel wronged by Prospero."@en ;
  dcterms:modified "2026-02-12T08:59:21.710134Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1898-4
  a curric:KeyLearningPoint ;
  rdfs:label """A character profile includes all the key information about a character, such as family and relationships."""@en ;
  dcterms:modified "2026-02-12T08:59:21.710139Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-861-1
  a curric:KeyLearningPoint ;
  rdfs:label "A simple sentence has one main clause."@en ;
  dcterms:modified "2026-02-12T08:59:21.710197Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-861-2
  a curric:KeyLearningPoint ;
  rdfs:label """Compound sentences are two main clauses joined together with a coordinating conjunction or semicolon."""@en ;
  dcterms:modified "2026-02-12T08:59:21.710201Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-861-3
  a curric:KeyLearningPoint ;
  rdfs:label "Complex sentences are one main clause and at least one subordinate clause."@en ;
  dcterms:modified "2026-02-12T08:59:21.710206Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-861-4
  a curric:KeyLearningPoint ;
  rdfs:label "The subordinate clause can go at the beginning, middle and end of a sentence."@en ;
  dcterms:modified "2026-02-12T08:59:21.710210Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1995-1
  a curric:KeyLearningPoint ;
  rdfs:label "Accurate puncutation helps make your writing clear"@en ;
  dcterms:modified "2026-02-12T08:59:21.710757Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1995-2
  a curric:KeyLearningPoint ;
  rdfs:label "Each piece of punctuation has a different purpose"@en ;
  dcterms:modified "2026-02-12T08:59:21.710762Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1995-3
  a curric:KeyLearningPoint ;
  rdfs:label "You should use each piece of punctuation accurately and for effect"@en ;
  dcterms:modified "2026-02-12T08:59:21.710767Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1995-4
  a curric:KeyLearningPoint ;
  rdfs:label "You should vary punctuation throughout your writing"@en ;
  dcterms:modified "2026-02-12T08:59:21.710771Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1804-1
  a curric:KeyLearningPoint ;
  rdfs:label """Othello’s fit robs him of his ability to speak, the trait that distinguishes humans from animals."""@en ;
  dcterms:modified "2026-02-12T08:59:21.710776Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1804-2
  a curric:KeyLearningPoint ;
  rdfs:label """Consumed by jealousy, he has become the animal that the prejudiced characters have described him as being."""@en ;
  dcterms:modified "2026-02-12T08:59:21.710780Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1804-3
  a curric:KeyLearningPoint ;
  rdfs:label """Formally, Othello was the centre of attention as the military hero, he now lurks on the periphery, an outsider."""@en ;
  dcterms:modified "2026-02-12T08:59:21.710785Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1804-4
  a curric:KeyLearningPoint ;
  rdfs:label "Lodovico is used to draw attention, almost like a chorus to Othello's change."@en ;
  dcterms:modified "2026-02-12T08:59:21.710790Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1923-1
  a curric:KeyLearningPoint ;
  rdfs:label """Berry uses sensory language in 'Childhood Tracks' to evoke a vivid image of his hometown, Jamaica."""@en ;
  dcterms:modified "2026-02-12T08:59:21.710794Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1923-2
  a curric:KeyLearningPoint ;
  rdfs:label """Berry describes details unique to Jamaica to help us have an insight into what it is like to live there."""@en ;
  dcterms:modified "2026-02-12T08:59:21.710799Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1923-3
  a curric:KeyLearningPoint ;
  rdfs:label "Berry also uses prepositions to add detail to each of his memories."@en ;
  dcterms:modified "2026-02-12T08:59:21.710804Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1923-4
  a curric:KeyLearningPoint ;
  rdfs:label "Berry creates a nostalgic tone throughout the poem."@en ;
  dcterms:modified "2026-02-12T08:59:21.710808Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1923-5
  a curric:KeyLearningPoint ;
  rdfs:label "Using triplets can add even more detail when writing about our memories."@en ;
  dcterms:modified "2026-02-12T08:59:21.710815Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1955-1
  a curric:KeyLearningPoint ;
  rdfs:label "John Turner used to be a bushranger: an armed robber that stole gold."@en ;
  dcterms:modified "2026-02-12T08:59:21.710820Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1955-2
  a curric:KeyLearningPoint ;
  rdfs:label """Some members of the public had sympathy towards bushrangers for defying the elite."""@en ;
  dcterms:modified "2026-02-12T08:59:21.710827Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1955-3
  a curric:KeyLearningPoint ;
  rdfs:label """John Turner’s description has many layers to it and thus many interpretations of his character."""@en ;
  dcterms:modified "2026-02-12T08:59:21.710832Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1955-4
  a curric:KeyLearningPoint ;
  rdfs:label """You can make good inferences by zooming in on key words and phrases from an extract."""@en ;
  dcterms:modified "2026-02-12T08:59:21.710839Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1944-1
  a curric:KeyLearningPoint ;
  rdfs:label "The final part of an article is called the tail"@en ;
  dcterms:modified "2026-02-12T08:59:21.710846Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1944-2
  a curric:KeyLearningPoint ;
  rdfs:label """The tail of an article contains background information, interesting facts and a conclusive tone"""@en ;
  dcterms:modified "2026-02-12T08:59:21.710851Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1944-3
  a curric:KeyLearningPoint ;
  rdfs:label """A conclusive tone is important as it shows the reader that you are bringing your article to an end"""@en ;
  dcterms:modified "2026-02-12T08:59:21.710855Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1944-4
  a curric:KeyLearningPoint ;
  rdfs:label """One way to create a conclusive tone is to talk about future plans in the aftermath of the event"""@en ;
  dcterms:modified "2026-02-12T08:59:21.710860Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-880-1
  a curric:KeyLearningPoint ;
  rdfs:label """In analytical writing, use conjunctions and connectives (as/because/therefore) to clearly explain ideas."""@en ;
  dcterms:modified "2026-02-12T08:59:21.710865Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-880-2
  a curric:KeyLearningPoint ;
  rdfs:label """In analytical writing, use discourse markers like 'Additionally’ and 'In particular’ to develop your analysis."""@en ;
  dcterms:modified "2026-02-12T08:59:21.710869Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-880-3
  a curric:KeyLearningPoint ;
  rdfs:label """In analytical writing, use modal verbs to develop a tentative style – use 'could' or 'might' to explain inferences."""@en ;
  dcterms:modified "2026-02-12T08:59:21.710874Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-880-4
  a curric:KeyLearningPoint ;
  rdfs:label "Use single paragraph outlines to plan detailed, cohesive paragraphs."@en ;
  dcterms:modified "2026-02-12T08:59:21.710878Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28388-1
  a curric:KeyLearningPoint ;
  rdfs:label "Discussion can be more spontaneous than other forms of spoken language."@en ;
  dcterms:modified "2026-02-12T08:59:21.710883Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28388-2
  a curric:KeyLearningPoint ;
  rdfs:label """Using the ABC strategy can help you to respond in a discussion and develop comments."""@en ;
  dcterms:modified "2026-02-12T08:59:21.710887Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28388-3
  a curric:KeyLearningPoint ;
  rdfs:label "Using active listening skills can help you to ask relevant questions."@en ;
  dcterms:modified "2026-02-12T08:59:21.710892Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28388-4
  a curric:KeyLearningPoint ;
  rdfs:label """Open questions allow the speaker to respond in a developed way and move the discussion forward."""@en ;
  dcterms:modified "2026-02-12T08:59:21.710896Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1895-1
  a curric:KeyLearningPoint ;
  rdfs:label "The theatre was a full sensory experience."@en ;
  dcterms:modified "2026-02-12T08:59:21.710901Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1895-2
  a curric:KeyLearningPoint ;
  rdfs:label "The theatre used special effects to simulate battles, injuries and storms."@en ;
  dcterms:modified "2026-02-12T08:59:21.710906Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1895-3
  a curric:KeyLearningPoint ;
  rdfs:label """These special effects added to the mood of the play and made it more realistic for the audience."""@en ;
  dcterms:modified "2026-02-12T08:59:21.710910Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1899-1
  a curric:KeyLearningPoint ;
  rdfs:label "Ariel is magical and carries out Prospero’s work, such as creating the tempest."@en ;
  dcterms:modified "2026-02-12T08:59:21.710936Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1899-2
  a curric:KeyLearningPoint ;
  rdfs:label "We know very little about how Ariel feels and what Ariel looks like."@en ;
  dcterms:modified "2026-02-12T08:59:21.710941Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1899-3
  a curric:KeyLearningPoint ;
  rdfs:label "Ariel’s resolution comes at the end, when Prospero grants their freedom."@en ;
  dcterms:modified "2026-02-12T08:59:21.710948Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1900-1
  a curric:KeyLearningPoint ;
  rdfs:label "Ariel’s language shows both deference and frustration towards Prospero."@en ;
  dcterms:modified "2026-02-12T08:59:21.710971Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1900-2
  a curric:KeyLearningPoint ;
  rdfs:label """Ariel is forced to be obedient to Prospero because of his threats to return Ariel to the tree."""@en ;
  dcterms:modified "2026-02-12T08:59:21.710975Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1900-3
  a curric:KeyLearningPoint ;
  rdfs:label """Prospero having more lines than Ariel suggests that his voice is considered more important."""@en ;
  dcterms:modified "2026-02-12T08:59:21.710980Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1896-1
  a curric:KeyLearningPoint ;
  rdfs:label """Shakespeare's company was supported by King James I which meant Shakespeare would likely want to appeal to the King."""@en ;
  dcterms:modified "2026-02-12T08:59:21.711045Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1896-2
  a curric:KeyLearningPoint ;
  rdfs:label "'The Tempest' is a comedy which means it has a happy ending."@en ;
  dcterms:modified "2026-02-12T08:59:21.711050Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1896-3
  a curric:KeyLearningPoint ;
  rdfs:label "Prospero is served by a spirit, Ariel, and a creature, Caliban."@en ;
  dcterms:modified "2026-02-12T08:59:21.711055Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1896-4
  a curric:KeyLearningPoint ;
  rdfs:label "Prospero uses his magic to manipulate and control others."@en ;
  dcterms:modified "2026-02-12T08:59:21.711059Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1896-5
  a curric:KeyLearningPoint ;
  rdfs:label """Prospero eventually forgives the traitors and frees Ariel and the play ends with a celebration."""@en ;
  dcterms:modified "2026-02-12T08:59:21.711064Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1865-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘A Midsummer Night’s Dream’ ends with an epilogue given by the character of Puck."""@en ;
  dcterms:modified "2026-02-12T08:59:21.711289Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1865-2
  a curric:KeyLearningPoint ;
  rdfs:label """Puck’s epilogue breaks the fourth wall and offers to make “amends” for any offence caused by the play."""@en ;
  dcterms:modified "2026-02-12T08:59:21.711293Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1865-3
  a curric:KeyLearningPoint ;
  rdfs:label """Puck’s characterisation in the epilogue could be considered different to his characterisation in the rest of the play."""@en ;
  dcterms:modified "2026-02-12T08:59:21.711298Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1865-4
  a curric:KeyLearningPoint ;
  rdfs:label """Perceptive analysis can involve making thoughtful connections between different moments in a text."""@en ;
  dcterms:modified "2026-02-12T08:59:21.711305Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-863-1
  a curric:KeyLearningPoint ;
  rdfs:label "Adding an adverb can help to add emotion and detail to your descriptive writing."@en ;
  dcterms:modified "2026-02-12T08:59:21.711335Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-863-2
  a curric:KeyLearningPoint ;
  rdfs:label """Varying your sentences allows you to mimic the sensation of the reader discovering the scene for the first time."""@en ;
  dcterms:modified "2026-02-12T08:59:21.711340Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-863-3
  a curric:KeyLearningPoint ;
  rdfs:label """Varying your sentences can also allow you to add more detail and allow the reader to better visualise the scene."""@en ;
  dcterms:modified "2026-02-12T08:59:21.711344Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-863-4
  a curric:KeyLearningPoint ;
  rdfs:label """Creating a compound sentence can help the reader see how information is connected together."""@en ;
  dcterms:modified "2026-02-12T08:59:21.711349Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1539-1
  a curric:KeyLearningPoint ;
  rdfs:label "Hillary Clinton is an American politician and advocate for women’s rights."@en ;
  dcterms:modified "2026-02-12T08:59:21.711353Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1539-2
  a curric:KeyLearningPoint ;
  rdfs:label """The United Nations is an international organisation aimed at increasing cooperation and peace between nations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.711358Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1539-3
  a curric:KeyLearningPoint ;
  rdfs:label "Hillary Clinton’s speech is about the struggles facing women around the world."@en ;
  dcterms:modified "2026-02-12T08:59:21.711362Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1539-4
  a curric:KeyLearningPoint ;
  rdfs:label """She uses time and place references to show the scale of the problem and to establish a sense of urgency."""@en ;
  dcterms:modified "2026-02-12T08:59:21.711367Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1897-1
  a curric:KeyLearningPoint ;
  rdfs:label "Prospero is the most powerful character."@en ;
  dcterms:modified "2026-02-12T08:59:21.711419Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1897-2
  a curric:KeyLearningPoint ;
  rdfs:label "Prospero exploits Caliban and Ariel and forces them to serve him."@en ;
  dcterms:modified "2026-02-12T08:59:21.711424Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1897-3
  a curric:KeyLearningPoint ;
  rdfs:label "Prospero uses his power to create an unjust society on the island."@en ;
  dcterms:modified "2026-02-12T08:59:21.711428Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1897-4
  a curric:KeyLearningPoint ;
  rdfs:label "Specifically, magic is used by Prospero to control others."@en ;
  dcterms:modified "2026-02-12T08:59:21.711433Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-866-1
  a curric:KeyLearningPoint ;
  rdfs:label "Book covers can be useful tools in making predictions about a text."@en ;
  dcterms:modified "2026-02-12T08:59:21.711647Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-866-2
  a curric:KeyLearningPoint ;
  rdfs:label """Use the first reading of an unseen extract to establish key information about plot, character and setting."""@en ;
  dcterms:modified "2026-02-12T08:59:21.711652Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-866-3
  a curric:KeyLearningPoint ;
  rdfs:label """Next, read the text more closely to consider the meaning of specific words and phrases."""@en ;
  dcterms:modified "2026-02-12T08:59:21.711659Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1904-1
  a curric:KeyLearningPoint ;
  rdfs:label "Caliban inhabited the island before Prospero and Miranda."@en ;
  dcterms:modified "2026-02-12T08:59:21.711729Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1904-2
  a curric:KeyLearningPoint ;
  rdfs:label "Prospero treats Caliban cruelly by threatening him with physical violence."@en ;
  dcterms:modified "2026-02-12T08:59:21.711734Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1904-3
  a curric:KeyLearningPoint ;
  rdfs:label "At the end of the play, Caliban is left alone on the island."@en ;
  dcterms:modified "2026-02-12T08:59:21.711738Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1904-4
  a curric:KeyLearningPoint ;
  rdfs:label """The language around Caliban in ‘The Tempest’ creates a particularly violent and negative impression."""@en ;
  dcterms:modified "2026-02-12T08:59:21.711743Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1905-1
  a curric:KeyLearningPoint ;
  rdfs:label """The staging of a performance can influence our interpretation of the scene and the characters."""@en ;
  dcterms:modified "2026-02-12T08:59:21.711750Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1905-2
  a curric:KeyLearningPoint ;
  rdfs:label "The language used by Prospero and Caliban shows a mutual animosity."@en ;
  dcterms:modified "2026-02-12T08:59:21.711755Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1905-3
  a curric:KeyLearningPoint ;
  rdfs:label "Prospero uses imperative language to show his superiority to Caliban."@en ;
  dcterms:modified "2026-02-12T08:59:21.711759Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1907-1
  a curric:KeyLearningPoint ;
  rdfs:label """Analysing language means looking at specific words in close detail and explaining their effect on the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.711764Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1907-2
  a curric:KeyLearningPoint ;
  rdfs:label """An argument is where you present your idea about the text and convince the reader that it is correct."""@en ;
  dcterms:modified "2026-02-12T08:59:21.711768Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1907-3
  a curric:KeyLearningPoint ;
  rdfs:label """An essay plan should include a thesis statement which explains the overarching argument."""@en ;
  dcterms:modified "2026-02-12T08:59:21.711773Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1907-4
  a curric:KeyLearningPoint ;
  rdfs:label "Prospero treats Caliban cruelly through his language and actions."@en ;
  dcterms:modified "2026-02-12T08:59:21.711777Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1907-5
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, Shakespeare may have been suggesting that the colonists' treatment of indigenous people was cruel."""@en ;
  dcterms:modified "2026-02-12T08:59:21.711782Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1901-1
  a curric:KeyLearningPoint ;
  rdfs:label "Shakespeare presents Ariel as mistreated and exploited by Prospero."@en ;
  dcterms:modified "2026-02-12T08:59:21.711789Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1901-2
  a curric:KeyLearningPoint ;
  rdfs:label """Shakespeare also presents Prospero’s kindness to Ariel, as ultimately he frees Ariel."""@en ;
  dcterms:modified "2026-02-12T08:59:21.711794Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1901-3
  a curric:KeyLearningPoint ;
  rdfs:label """It important to choose relevant quotations that answer the question and support the topic sentence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.711800Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1901-4
  a curric:KeyLearningPoint ;
  rdfs:label "It is important to zoom in on words and techniques and explain their effects."@en ;
  dcterms:modified "2026-02-12T08:59:21.711805Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1901-5
  a curric:KeyLearningPoint ;
  rdfs:label """Alternative interpretations can be explored using discourse markers such as 'alternatively'."""@en ;
  dcterms:modified "2026-02-12T08:59:21.711810Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1906-1
  a curric:KeyLearningPoint ;
  rdfs:label "Prospero repeatedly calls Caliban his slave, emphasising Caliban’s inferiority."@en ;
  dcterms:modified "2026-02-12T08:59:21.711814Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1906-2
  a curric:KeyLearningPoint ;
  rdfs:label "Prospero rules Caliban through fear."@en ;
  dcterms:modified "2026-02-12T08:59:21.711819Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1906-3
  a curric:KeyLearningPoint ;
  rdfs:label "‘The Tempest’ is considered by many scholars to be a comment on colonialism."@en ;
  dcterms:modified "2026-02-12T08:59:21.711823Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1906-4
  a curric:KeyLearningPoint ;
  rdfs:label """Caliban could be considered representative of indigenous people controlled by colonists."""@en ;
  dcterms:modified "2026-02-12T08:59:21.711827Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1903-1
  a curric:KeyLearningPoint ;
  rdfs:label "Creating a plan helps you to organise your thoughts."@en ;
  dcterms:modified "2026-02-12T08:59:21.711832Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1903-2
  a curric:KeyLearningPoint ;
  rdfs:label """To create a clear character voice you need to consider what tone matches the character’s experiences."""@en ;
  dcterms:modified "2026-02-12T08:59:21.711839Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1903-3
  a curric:KeyLearningPoint ;
  rdfs:label """Language devices and short sentences can be used to help add to the tone of your monologue."""@en ;
  dcterms:modified "2026-02-12T08:59:21.711843Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1902-1
  a curric:KeyLearningPoint ;
  rdfs:label "A monologue is a long speech by one character."@en ;
  dcterms:modified "2026-02-12T08:59:21.711967Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1902-2
  a curric:KeyLearningPoint ;
  rdfs:label """Vocabulary including adjectives and verbs, should be carefully chosen to match the voice of the character."""@en ;
  dcterms:modified "2026-02-12T08:59:21.711972Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1902-3
  a curric:KeyLearningPoint ;
  rdfs:label """Language techniques such as metaphors can be used to describe the emotions of the character."""@en ;
  dcterms:modified "2026-02-12T08:59:21.711979Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1902-4
  a curric:KeyLearningPoint ;
  rdfs:label "Short sentences can be used to display heightened emotions such as anger."@en ;
  dcterms:modified "2026-02-12T08:59:21.711983Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1918-1
  a curric:KeyLearningPoint ;
  rdfs:label """We can use our body language, posture and eye contact to convey certain emotions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712081Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1918-2
  a curric:KeyLearningPoint ;
  rdfs:label """We can vary the pitch and pace of our voice to convey different emotions and influence the tone of our monologue."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712086Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1918-3
  a curric:KeyLearningPoint ;
  rdfs:label """You can trick yourself into feeling more confident about a performance through deep breathing and smiling."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712091Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1919-1
  a curric:KeyLearningPoint ;
  rdfs:label "Shakespearean society was a patriarchal society."@en ;
  dcterms:modified "2026-02-12T08:59:21.712095Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1919-2
  a curric:KeyLearningPoint ;
  rdfs:label """Women had less legal rights than men and faced social pressure to be subservient to men."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712100Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1919-3
  a curric:KeyLearningPoint ;
  rdfs:label "Miranda is shown as compassionate, beautiful, intelligent and optimistic."@en ;
  dcterms:modified "2026-02-12T08:59:21.712105Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1919-4
  a curric:KeyLearningPoint ;
  rdfs:label "Miranda is also shown as questioning her father’s decisions."@en ;
  dcterms:modified "2026-02-12T08:59:21.712110Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1919-5
  a curric:KeyLearningPoint ;
  rdfs:label """Miranda could be considered as both subverting and meeting the expectations of patriarchal society."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712114Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1908-1
  a curric:KeyLearningPoint ;
  rdfs:label "A thesis statement summarises the overall argument of an essay."@en ;
  dcterms:modified "2026-02-12T08:59:21.712241Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1908-2
  a curric:KeyLearningPoint ;
  rdfs:label "A topic sentence explains the focus of the paragraph."@en ;
  dcterms:modified "2026-02-12T08:59:21.712245Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1908-3
  a curric:KeyLearningPoint ;
  rdfs:label "Supporting detail from the text should be used as evidence for your argument."@en ;
  dcterms:modified "2026-02-12T08:59:21.712252Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1908-4
  a curric:KeyLearningPoint ;
  rdfs:label """A range of analytical verbs should be used throughout the essay to explain meaning."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712257Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1564-1
  a curric:KeyLearningPoint ;
  rdfs:label "Many critics read 'Frankenstein' as a criticism of the Scientific Revolution."@en ;
  dcterms:modified "2026-02-12T08:59:21.712262Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1564-2
  a curric:KeyLearningPoint ;
  rdfs:label """The Scientific Revolution ushered in a new era, where assumptions about the natural world were questioned."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712267Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1564-3
  a curric:KeyLearningPoint ;
  rdfs:label """Some saw the progress of science as limitless and, in some cases, immoral and unethical."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712271Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1564-4
  a curric:KeyLearningPoint ;
  rdfs:label """The novel's alternative title is 'The Modern Prometheus' suggesting that, like Prometheus, Frankenstein stole from God."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712275Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1564-5
  a curric:KeyLearningPoint ;
  rdfs:label """'Frankenstein' could be a warning about what happens when science is not paired with individual moral conscience."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712280Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1949-1
  a curric:KeyLearningPoint ;
  rdfs:label """Holmes and Watson undertake a dreadful vigil whilst they wait for more evidence to be revealed"""@en ;
  dcterms:modified "2026-02-12T08:59:21.712284Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1949-2
  a curric:KeyLearningPoint ;
  rdfs:label "Julia Stoner died after being bitten by a venomous snake"@en ;
  dcterms:modified "2026-02-12T08:59:21.712289Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1949-3
  a curric:KeyLearningPoint ;
  rdfs:label "Dr. Roylott attempts to kill Helen in the same way"@en ;
  dcterms:modified "2026-02-12T08:59:21.712296Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1949-4
  a curric:KeyLearningPoint ;
  rdfs:label """Instead, Holmes sends the snake back to Dr. Roylott’s room and Roylott himself is bitten and dies"""@en ;
  dcterms:modified "2026-02-12T08:59:21.712301Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1949-5
  a curric:KeyLearningPoint ;
  rdfs:label """We can write a summary of how Julia Stoner died by including the key details: who, what, where, when and why"""@en ;
  dcterms:modified "2026-02-12T08:59:21.712305Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1545-1
  a curric:KeyLearningPoint ;
  rdfs:label """Creating content for a presentation can mean using facts, experts and an appropriate tone to take a stand."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712312Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1545-2
  a curric:KeyLearningPoint ;
  rdfs:label "A metaphor involves the transfer of qualities from one thing to another."@en ;
  dcterms:modified "2026-02-12T08:59:21.712317Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1545-3
  a curric:KeyLearningPoint ;
  rdfs:label """An extended metaphor will help direct your choice of vocabulary throughout the presentation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712322Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1545-4
  a curric:KeyLearningPoint ;
  rdfs:label """An effective way to structure your presentation is to begin and end in the same place."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712326Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1545-5
  a curric:KeyLearningPoint ;
  rdfs:label "Presenting visual ideas at the start of a presentation can be very impactful."@en ;
  dcterms:modified "2026-02-12T08:59:21.712331Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1977-1
  a curric:KeyLearningPoint ;
  rdfs:label "A range of metaphors are used to describe the draugr."@en ;
  dcterms:modified "2026-02-12T08:59:21.712335Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1977-2
  a curric:KeyLearningPoint ;
  rdfs:label """The draugr is associated with death to heighten its terror and make the reader fear for Martha’s life."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712340Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1977-3
  a curric:KeyLearningPoint ;
  rdfs:label """Burge waits until the end of the novel to introduce a full description of the draugr, in order to create mystery."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712344Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1977-4
  a curric:KeyLearningPoint ;
  rdfs:label "The draugr’s curved claws are a symbol of its terrifying violence."@en ;
  dcterms:modified "2026-02-12T08:59:21.712349Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1909-1
  a curric:KeyLearningPoint ;
  rdfs:label """While we may not know Shakespeare’s intentions, we can make an educated guess through looking at the language used."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712354Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1909-2
  a curric:KeyLearningPoint ;
  rdfs:label """The audience might interpret Caliban as a threatening figure or a sympathetic figure."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712358Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1909-3
  a curric:KeyLearningPoint ;
  rdfs:label """Persuasive devices can be used to convince the audience that your argument is correct."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712363Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1909-4
  a curric:KeyLearningPoint ;
  rdfs:label """A debate is where two teams offer their arguments either for or against a debate statement."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712368Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1912-1
  a curric:KeyLearningPoint ;
  rdfs:label """A monologue from Caliban’s perspective needs to present Caliban’s views and emotions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712390Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1912-2
  a curric:KeyLearningPoint ;
  rdfs:label """A monologue should include ambitious vocabulary to help the audience understand the emotion."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712397Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1912-3
  a curric:KeyLearningPoint ;
  rdfs:label """A monologue should link the first and last sentence of each paragraph to help create a convincing character voice."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712401Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1916-1
  a curric:KeyLearningPoint ;
  rdfs:label "Your introduction should be powerful and attention-grabbing."@en ;
  dcterms:modified "2026-02-12T08:59:21.712406Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1916-2
  a curric:KeyLearningPoint ;
  rdfs:label """One way to structure your monologue is to set up a problem for your character and then provide the resolution."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712411Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1916-3
  a curric:KeyLearningPoint ;
  rdfs:label """You might also think about linking the end of your monologue back to the beginning to show that resolution."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712415Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1916-4
  a curric:KeyLearningPoint ;
  rdfs:label """You might use literary devices in order to create an emotive effect on the audience."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712420Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1915-1
  a curric:KeyLearningPoint ;
  rdfs:label """Characters such as Caliban can be used as inspiration, when creating characters who are outsiders"""@en ;
  dcterms:modified "2026-02-12T08:59:21.712531Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1915-2
  a curric:KeyLearningPoint ;
  rdfs:label """Ariel, Caliban and Miranda can be considered outsiders because they are all somehow considered different."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712536Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1915-3
  a curric:KeyLearningPoint ;
  rdfs:label """Caliban and Miranda in particular don’t always conform to how Shakespearean society would have expected them to behave."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712543Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1915-4
  a curric:KeyLearningPoint ;
  rdfs:label """Shakespearean society had different expectations and legal restrictions than today’s society."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712548Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1913-1
  a curric:KeyLearningPoint ;
  rdfs:label """Having accurate spelling, punctuation and grammar allows your work to be clearly understood."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712587Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1913-2
  a curric:KeyLearningPoint ;
  rdfs:label """Using synonyms for key words in the question shows a secure understanding of the task."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712591Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1913-3
  a curric:KeyLearningPoint ;
  rdfs:label "Responding to feedback helps to elevate your work."@en ;
  dcterms:modified "2026-02-12T08:59:21.712596Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1920-1
  a curric:KeyLearningPoint ;
  rdfs:label "In Shakespeare’s time, daughters were expected to obey their fathers."@en ;
  dcterms:modified "2026-02-12T08:59:21.712636Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1920-2
  a curric:KeyLearningPoint ;
  rdfs:label "Prospero hides Miranda’s backstory from her which shows how controlling he is."@en ;
  dcterms:modified "2026-02-12T08:59:21.712641Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1920-3
  a curric:KeyLearningPoint ;
  rdfs:label "Prospero intends for Ferdinand and Miranda to fall in love."@en ;
  dcterms:modified "2026-02-12T08:59:21.712645Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1920-4
  a curric:KeyLearningPoint ;
  rdfs:label """While Miranda seems to disobey Prospero to fight for Ferdinand, she is actually unwittingly following Prospero’s plan."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712650Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1914-1
  a curric:KeyLearningPoint ;
  rdfs:label """Inequality is the unfair situation where some people have more opportunities, money, or power than others."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712744Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1914-2
  a curric:KeyLearningPoint ;
  rdfs:label """People in Shakespearean times faced inequality because of their race, gender and religion."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712749Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1914-3
  a curric:KeyLearningPoint ;
  rdfs:label "Arguably, Ariel, Caliban and Miranda face inequality in ‘The Tempest’."@en ;
  dcterms:modified "2026-02-12T08:59:21.712753Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1914-4
  a curric:KeyLearningPoint ;
  rdfs:label "Shakespeare arguably links colonialism with inequality."@en ;
  dcterms:modified "2026-02-12T08:59:21.712758Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1921-1
  a curric:KeyLearningPoint ;
  rdfs:label """A diary is a person’s private record of events, thoughts, or feelings that are written down every day."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712765Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1921-2
  a curric:KeyLearningPoint ;
  rdfs:label "A diary should be written in first person narrative voice and past tense."@en ;
  dcterms:modified "2026-02-12T08:59:21.712781Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1921-3
  a curric:KeyLearningPoint ;
  rdfs:label "A diary is usually written in chronological order."@en ;
  dcterms:modified "2026-02-12T08:59:21.712790Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1921-4
  a curric:KeyLearningPoint ;
  rdfs:label """Using descriptions that show the senses can help to create a convincing character voice."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712795Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1921-5
  a curric:KeyLearningPoint ;
  rdfs:label "We don’t know what happens to Miranda after the end of the play."@en ;
  dcterms:modified "2026-02-12T08:59:21.712799Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1822-1
  a curric:KeyLearningPoint ;
  rdfs:label "Walter de la Mare's 'Brueghel’s Winter' is an ekphrastic poem."@en ;
  dcterms:modified "2026-02-12T08:59:21.713191Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1822-2
  a curric:KeyLearningPoint ;
  rdfs:label """An ekphrastic poem is a poem which describes a piece of art, and is inspired by it."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713196Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1822-3
  a curric:KeyLearningPoint ;
  rdfs:label """You can look at a poem as a whole and consider how the descriptions work together to create a particular tone or mood."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713201Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1822-4
  a curric:KeyLearningPoint ;
  rdfs:label "You can look at the descriptions individually and consider the effect they have."@en ;
  dcterms:modified "2026-02-12T08:59:21.713205Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1822-5
  a curric:KeyLearningPoint ;
  rdfs:label """You can consider the tone you wish to create in your own writing, and then select words and phrases to create this tone."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713210Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1910-1
  a curric:KeyLearningPoint ;
  rdfs:label """Trinculo and Stephano’s first impressions of Caliban suggest that they see him as unnatural and inhuman."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713252Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1910-2
  a curric:KeyLearningPoint ;
  rdfs:label """Trinculo’s repeated use of ‘monster’ to describe Caliban suggests that he sees him as an abomination."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713259Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1910-3
  a curric:KeyLearningPoint ;
  rdfs:label """Stephano’s use of imperative language implies he sees himself as superior to Caliban."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713264Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1910-4
  a curric:KeyLearningPoint ;
  rdfs:label """Caliban’s language may show that he sees himself as inferior and is desperate to prove his worth."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713268Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1911-1
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, Caliban’s language and actions demonstrate that he sees himself as someone who isn’t equal and doesn’t belong."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713273Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1911-2
  a curric:KeyLearningPoint ;
  rdfs:label """Some would argue Caliban acts in an animalistic manner, which further sets him apart from society."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713278Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1911-3
  a curric:KeyLearningPoint ;
  rdfs:label "Stephano and Trinculo’s language positions Caliban as an outsider."@en ;
  dcterms:modified "2026-02-12T08:59:21.713282Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1917-1
  a curric:KeyLearningPoint ;
  rdfs:label """Descriptive devices are used to help the reader feel almost as if they are a part of the scene or event being described."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713490Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1917-2
  a curric:KeyLearningPoint ;
  rdfs:label "Examples of descriptive devices might be personification or pathetic fallacy."@en ;
  dcterms:modified "2026-02-12T08:59:21.713495Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1917-3
  a curric:KeyLearningPoint ;
  rdfs:label """Rhetorical devices are literary devices that are designed to have an effect on the audience."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713500Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1917-4
  a curric:KeyLearningPoint ;
  rdfs:label """A combination of rhetorical and descriptive devices is effective in conveying emotion."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713504Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1917-5
  a curric:KeyLearningPoint ;
  rdfs:label "Examples of rhetorical devices might be triplets and emotive language."@en ;
  dcterms:modified "2026-02-12T08:59:21.713509Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1880-1
  a curric:KeyLearningPoint ;
  rdfs:label """An extended metaphor is a detailed comparison which develops one idea over a number of lines, paragraphs or stanzas."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713745Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1880-2
  a curric:KeyLearningPoint ;
  rdfs:label """In 'Caged Bird', the idea of a bird in a cage is an extended metaphor for the unjust experiences of the Black community."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713750Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1880-3
  a curric:KeyLearningPoint ;
  rdfs:label """In 'Caged Bird', Angelou is perhaps referencing the racial segregation enforced by the 19th-20th century Jim Crow laws."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713754Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1880-4
  a curric:KeyLearningPoint ;
  rdfs:label """When comparing two poems, it can be useful to first think about what connects them."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713759Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1880-5
  a curric:KeyLearningPoint ;
  rdfs:label """After finding a point of connection between poems, you could consider the differences within this point of connection."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713766Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1555-1
  a curric:KeyLearningPoint ;
  rdfs:label "Open a speech in a dynamic way to engage your audience."@en ;
  dcterms:modified "2026-02-12T08:59:21.713774Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1555-2
  a curric:KeyLearningPoint ;
  rdfs:label "Rhetorical devices should be used to support arguments in persuasive speeches."@en ;
  dcterms:modified "2026-02-12T08:59:21.713779Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1555-3
  a curric:KeyLearningPoint ;
  rdfs:label """If you are trying to persuade a listener, include a call to action so they can make a tangible change."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713783Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1555-4
  a curric:KeyLearningPoint ;
  rdfs:label "Punctuate speeches accurately to support with delivery."@en ;
  dcterms:modified "2026-02-12T08:59:21.713788Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1554-1
  a curric:KeyLearningPoint ;
  rdfs:label """Emotive language requires you to select the sensitivity of your words to elicit specific emotions from the audience."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713793Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1554-2
  a curric:KeyLearningPoint ;
  rdfs:label """Excellent rhetorical questions use emotive language to enhance the complexity of the question."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713800Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1554-3
  a curric:KeyLearningPoint ;
  rdfs:label """Great rhetorical questions should use direct address subtly, avoiding overuse of ‘you’."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713805Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1554-4
  a curric:KeyLearningPoint ;
  rdfs:label "Anaphora is a useful tool is structuring persuasive writing."@en ;
  dcterms:modified "2026-02-12T08:59:21.713810Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1998-1
  a curric:KeyLearningPoint ;
  rdfs:label "A semantic field is a group of words related in meaning"@en ;
  dcterms:modified "2026-02-12T08:59:21.713815Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1998-2
  a curric:KeyLearningPoint ;
  rdfs:label """Linking your adjectives and verbs to a specific idea can help you create a semantic field"""@en ;
  dcterms:modified "2026-02-12T08:59:21.713819Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1998-3
  a curric:KeyLearningPoint ;
  rdfs:label "Different semantic fields reflect different tones"@en ;
  dcterms:modified "2026-02-12T08:59:21.713823Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1998-4
  a curric:KeyLearningPoint ;
  rdfs:label """You can use the semantic field of decay in to reflect a bleak tone typical of the dystopian genre"""@en ;
  dcterms:modified "2026-02-12T08:59:21.713828Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1556-1
  a curric:KeyLearningPoint ;
  rdfs:label "Varying pace and rhythm can help support with presenting the meaning of a text."@en ;
  dcterms:modified "2026-02-12T08:59:21.713876Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1556-2
  a curric:KeyLearningPoint ;
  rdfs:label "Pauses can help vary pace and rhythm."@en ;
  dcterms:modified "2026-02-12T08:59:21.713881Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1556-3
  a curric:KeyLearningPoint ;
  rdfs:label "Facial expressions can help support with expressing mood or attitude."@en ;
  dcterms:modified "2026-02-12T08:59:21.713885Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1556-4
  a curric:KeyLearningPoint ;
  rdfs:label "Eye contact and hand gestures are useful for holding an audience's attention."@en ;
  dcterms:modified "2026-02-12T08:59:21.713892Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1876-1
  a curric:KeyLearningPoint ;
  rdfs:label "Maya Angelou (1928-2014) was an American poet and civil rights activist."@en ;
  dcterms:modified "2026-02-12T08:59:21.713897Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1876-2
  a curric:KeyLearningPoint ;
  rdfs:label "Angelou's poems have a distinctive voice."@en ;
  dcterms:modified "2026-02-12T08:59:21.713902Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1876-3
  a curric:KeyLearningPoint ;
  rdfs:label """Figurative language, repetition and an assertive tone are three ways Angelou creates a distinctive voice in her work."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713906Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1876-4
  a curric:KeyLearningPoint ;
  rdfs:label "Arguably, the speaker in 'Life Doesn’t Frighten Me' is presented as assertive."@en ;
  dcterms:modified "2026-02-12T08:59:21.713911Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1876-5
  a curric:KeyLearningPoint ;
  rdfs:label """You could argue that the speaker in 'Life Doesn’t Frighten Me' is only pretending to be assertive."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713916Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1874-1
  a curric:KeyLearningPoint ;
  rdfs:label """Maya Angelou uses stanzas and a refrain to structure her poem, 'Life Doesn't Frighten Me'."""@en ;
  dcterms:modified "2026-02-12T08:59:21.714010Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1874-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Life Doesn't Frighten Me' uses monosyllables at points for effect."@en ;
  dcterms:modified "2026-02-12T08:59:21.714014Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1874-3
  a curric:KeyLearningPoint ;
  rdfs:label "You can use a poet's work to inspire your own creativity."@en ;
  dcterms:modified "2026-02-12T08:59:21.714019Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1874-4
  a curric:KeyLearningPoint ;
  rdfs:label """You can plan each stanza of a poem by considering its focus and the details, including the methods, you want to include."""@en ;
  dcterms:modified "2026-02-12T08:59:21.714024Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1874-5
  a curric:KeyLearningPoint ;
  rdfs:label "Reading your poem aloud can help you identify areas you would like to improve."@en ;
  dcterms:modified "2026-02-12T08:59:21.714028Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1553-1
  a curric:KeyLearningPoint ;
  rdfs:label """Topic sentences should outline the specific argument that will be covered in a section of our speech."""@en ;
  dcterms:modified "2026-02-12T08:59:21.714033Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1553-2
  a curric:KeyLearningPoint ;
  rdfs:label """When planning a speech, supporting details should include rhetorical devices, structural devices and vocabulary."""@en ;
  dcterms:modified "2026-02-12T08:59:21.714038Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1553-3
  a curric:KeyLearningPoint ;
  rdfs:label """A hook grabs the listeners attention, whilst focusing on the subject of the speech."""@en ;
  dcterms:modified "2026-02-12T08:59:21.714042Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1553-4
  a curric:KeyLearningPoint ;
  rdfs:label "Your opening should alude to the three topic sentences you are going to write."@en ;
  dcterms:modified "2026-02-12T08:59:21.714047Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1553-5
  a curric:KeyLearningPoint ;
  rdfs:label """Mirroring your closing to your opening creates a sense of cohesion in your writing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.714052Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1875-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Phenomenal Woman' was first published in 1978."@en ;
  dcterms:modified "2026-02-12T08:59:21.714149Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1875-2
  a curric:KeyLearningPoint ;
  rdfs:label "The poem sees a confident speaker tell us how and why she is \"phenomenal\"."@en ;
  dcterms:modified "2026-02-12T08:59:21.714153Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1875-3
  a curric:KeyLearningPoint ;
  rdfs:label """The poem is perhaps a response to the sexist and racist discrimination Angelou faced in her life."""@en ;
  dcterms:modified "2026-02-12T08:59:21.714161Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1875-4
  a curric:KeyLearningPoint ;
  rdfs:label "Angelou performed 'Phenomenal Woman' many times in her lifetime."@en ;
  dcterms:modified "2026-02-12T08:59:21.714165Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1875-5
  a curric:KeyLearningPoint ;
  rdfs:label "The poem remains very popular because of its powerful and uplifting message."@en ;
  dcterms:modified "2026-02-12T08:59:21.714170Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1991-1
  a curric:KeyLearningPoint ;
  rdfs:label """A subordinate clause must be combined with a main clause, for the sentence to make sense"""@en ;
  dcterms:modified "2026-02-12T08:59:21.714230Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1991-2
  a curric:KeyLearningPoint ;
  rdfs:label "A complex sentence combines a main clause and a subordinate clause"@en ;
  dcterms:modified "2026-02-12T08:59:21.714235Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1991-3
  a curric:KeyLearningPoint ;
  rdfs:label """A subordinate clause can be placed at the beginning, middle or end of the sentence"""@en ;
  dcterms:modified "2026-02-12T08:59:21.714239Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1991-4
  a curric:KeyLearningPoint ;
  rdfs:label """The placement of the subordinate clause in the sentence can change its precise effect"""@en ;
  dcterms:modified "2026-02-12T08:59:21.714249Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1991-5
  a curric:KeyLearningPoint ;
  rdfs:label """Complex sentences should be used alongside simple and compound sentences, to create an interesting and varied paragraph"""@en ;
  dcterms:modified "2026-02-12T08:59:21.714254Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1879-1
  a curric:KeyLearningPoint ;
  rdfs:label """There is a contrast between the way the speaker and those who have oppressed her are presented in 'Still I Rise'."""@en ;
  dcterms:modified "2026-02-12T08:59:21.714385Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1879-2
  a curric:KeyLearningPoint ;
  rdfs:label """When performing a poem, you should consider how you want to engage with your audience."""@en ;
  dcterms:modified "2026-02-12T08:59:21.714389Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1879-3
  a curric:KeyLearningPoint ;
  rdfs:label """You should make informed decisions about the pace, volume and tone of your voice."""@en ;
  dcterms:modified "2026-02-12T08:59:21.714394Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1879-4
  a curric:KeyLearningPoint ;
  rdfs:label """You should aim to know your material off by heart so you can look at the audience most of the time."""@en ;
  dcterms:modified "2026-02-12T08:59:21.714398Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1932-1
  a curric:KeyLearningPoint ;
  rdfs:label """Punctuation is important in poetry as it shows the reader when to pause for meaning or dramatic effect."""@en ;
  dcterms:modified "2026-02-12T08:59:21.714403Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1932-2
  a curric:KeyLearningPoint ;
  rdfs:label "The same punctuation we use to write ordinarily can also be used in poetry."@en ;
  dcterms:modified "2026-02-12T08:59:21.714408Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1932-3
  a curric:KeyLearningPoint ;
  rdfs:label "Colons can be used to introduce an idea or list."@en ;
  dcterms:modified "2026-02-12T08:59:21.714413Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1932-4
  a curric:KeyLearningPoint ;
  rdfs:label "Enjambment is when lines of poetry flow onto each other, creating a fast pace."@en ;
  dcterms:modified "2026-02-12T08:59:21.714417Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1932-5
  a curric:KeyLearningPoint ;
  rdfs:label """Caesura is when there is a pause in the middle of a line, to draw attention to a particular idea or slow the pace."""@en ;
  dcterms:modified "2026-02-12T08:59:21.714422Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1990-1
  a curric:KeyLearningPoint ;
  rdfs:label "Effective descriptions include some short sentences and some longer ones"@en ;
  dcterms:modified "2026-02-12T08:59:21.714450Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1990-2
  a curric:KeyLearningPoint ;
  rdfs:label "A simple sentence has one subject and one verb"@en ;
  dcterms:modified "2026-02-12T08:59:21.714455Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1990-3
  a curric:KeyLearningPoint ;
  rdfs:label """A compound sentence has at least two subjects and two verbs, often linked by a conjunction"""@en ;
  dcterms:modified "2026-02-12T08:59:21.714462Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1990-4
  a curric:KeyLearningPoint ;
  rdfs:label "Conjunctions such as and, or, but, so can be used in compound sentences"@en ;
  dcterms:modified "2026-02-12T08:59:21.714485Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1550-1
  a curric:KeyLearningPoint ;
  rdfs:label "There was no compulsory schooling in Victorian Britain."@en ;
  dcterms:modified "2026-02-12T08:59:21.714512Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1550-2
  a curric:KeyLearningPoint ;
  rdfs:label "Education was a luxury only the rich could afford."@en ;
  dcterms:modified "2026-02-12T08:59:21.714517Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1550-3
  a curric:KeyLearningPoint ;
  rdfs:label "Ragged schools were designed to provide education to the poorest in society."@en ;
  dcterms:modified "2026-02-12T08:59:21.714521Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1550-4
  a curric:KeyLearningPoint ;
  rdfs:label """When analysing a writer's language choices, topic sentences should focus on effect rather than subject terminology."""@en ;
  dcterms:modified "2026-02-12T08:59:21.714526Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1550-5
  a curric:KeyLearningPoint ;
  rdfs:label """Topic sentences which focus on effect give opportunity to make connections between quotations from across a text."""@en ;
  dcterms:modified "2026-02-12T08:59:21.714530Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1877-1
  a curric:KeyLearningPoint ;
  rdfs:label """'Still I Rise' was first published in 1978 in a collection of Angelou's poems entitled 'And Still I Rise'."""@en ;
  dcterms:modified "2026-02-12T08:59:21.714658Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1877-2
  a curric:KeyLearningPoint ;
  rdfs:label """The collection 'And Still I Rise' explores ideas about overcoming adversity, particularly racism and sexism."""@en ;
  dcterms:modified "2026-02-12T08:59:21.714662Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1877-3
  a curric:KeyLearningPoint ;
  rdfs:label """The poems celebrate the tenacity of the Black community, especially women ('Phenomenal Woman' is also in the collection)"""@en ;
  dcterms:modified "2026-02-12T08:59:21.714667Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1877-4
  a curric:KeyLearningPoint ;
  rdfs:label """Considering your personal preference to a poem is an important aspect of being a student of English."""@en ;
  dcterms:modified "2026-02-12T08:59:21.714671Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1549-1
  a curric:KeyLearningPoint ;
  rdfs:label "Attitudes towards child labour were less strict in the Victorian era."@en ;
  dcterms:modified "2026-02-12T08:59:21.714698Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1549-2
  a curric:KeyLearningPoint ;
  rdfs:label """There are more laws today than in Victorian Britain to protect children from unsafe working conditions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.714703Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1549-3
  a curric:KeyLearningPoint ;
  rdfs:label """Young boys from lower social classes were expected to do dangerous jobs in the Victorian era."""@en ;
  dcterms:modified "2026-02-12T08:59:21.714707Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1549-4
  a curric:KeyLearningPoint ;
  rdfs:label "Comparative conjunctions are useful for connecting sentences to previous ideas."@en ;
  dcterms:modified "2026-02-12T08:59:21.714712Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1549-5
  a curric:KeyLearningPoint ;
  rdfs:label """Comparisons are useful when comparing differences between authors’ attitudes or ideas."""@en ;
  dcterms:modified "2026-02-12T08:59:21.714716Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1551-1
  a curric:KeyLearningPoint ;
  rdfs:label "Victorians were tough on crime to deter people from offending."@en ;
  dcterms:modified "2026-02-12T08:59:21.714745Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1551-2
  a curric:KeyLearningPoint ;
  rdfs:label "Victorians valued discipline and responsibility."@en ;
  dcterms:modified "2026-02-12T08:59:21.714750Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1551-3
  a curric:KeyLearningPoint ;
  rdfs:label """It was a middle class myth designed to uphold the class system, that most criminals were working class."""@en ;
  dcterms:modified "2026-02-12T08:59:21.714757Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1551-4
  a curric:KeyLearningPoint ;
  rdfs:label """Rhetorical questions, emotive language and direct address are all types of persuasive language."""@en ;
  dcterms:modified "2026-02-12T08:59:21.714764Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1551-5
  a curric:KeyLearningPoint ;
  rdfs:label "Connectives and repetition are all useful for structuring a persuasive response."@en ;
  dcterms:modified "2026-02-12T08:59:21.714771Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27915-1
  a curric:KeyLearningPoint ;
  rdfs:label """Listening is an important skill - it helps to create a supportive environment and can make you better at responding."""@en ;
  dcterms:modified "2026-02-12T08:59:21.714930Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27915-2
  a curric:KeyLearningPoint ;
  rdfs:label """Active listening means you are completely engaged and focused on what is being delivered."""@en ;
  dcterms:modified "2026-02-12T08:59:21.714940Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27915-3
  a curric:KeyLearningPoint ;
  rdfs:label """Using positive body language can help demonstrate active listening and keep you focused on the content."""@en ;
  dcterms:modified "2026-02-12T08:59:21.714946Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27915-4
  a curric:KeyLearningPoint ;
  rdfs:label "Part of being an active listener, is being able to respond effectively."@en ;
  dcterms:modified "2026-02-12T08:59:21.714950Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27915-5
  a curric:KeyLearningPoint ;
  rdfs:label "Open questions can develop comments and encourage discussion."@en ;
  dcterms:modified "2026-02-12T08:59:21.714955Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1548-1
  a curric:KeyLearningPoint ;
  rdfs:label "Body language and eye contact support the successful delivery of a presentation."@en ;
  dcterms:modified "2026-02-12T08:59:21.715026Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1548-2
  a curric:KeyLearningPoint ;
  rdfs:label """Gesture and posture can be used to engage the audience and to add emphasis to important points."""@en ;
  dcterms:modified "2026-02-12T08:59:21.715031Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1548-3
  a curric:KeyLearningPoint ;
  rdfs:label "Spoken language often needs to be slower than feels natural."@en ;
  dcterms:modified "2026-02-12T08:59:21.715035Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1548-4
  a curric:KeyLearningPoint ;
  rdfs:label """You need to consider your spatial behaviour- too much movement can be distracting but too little can be wooden."""@en ;
  dcterms:modified "2026-02-12T08:59:21.715039Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1548-5
  a curric:KeyLearningPoint ;
  rdfs:label "It's okay to feel nervous, find the strategies that work for you."@en ;
  dcterms:modified "2026-02-12T08:59:21.715044Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1818-1
  a curric:KeyLearningPoint ;
  rdfs:label """Greek myths are stories originally told by the ancient Greeks as a way of explaining the origin and nature of the world."""@en ;
  dcterms:modified "2026-02-12T08:59:21.715073Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1818-2
  a curric:KeyLearningPoint ;
  rdfs:label "Sometimes Greek myths contain morals."@en ;
  dcterms:modified "2026-02-12T08:59:21.715077Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1818-3
  a curric:KeyLearningPoint ;
  rdfs:label "The moral of the Fall of Icarus is that hubris is dangerous."@en ;
  dcterms:modified "2026-02-12T08:59:21.715082Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1818-4
  a curric:KeyLearningPoint ;
  rdfs:label """Pieter Bruegel’s 'Landscape with the Fall of Icarus' (c. 1558) was inspired by the Greek myth."""@en ;
  dcterms:modified "2026-02-12T08:59:21.715086Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1818-5
  a curric:KeyLearningPoint ;
  rdfs:label """Bruegel’s painting celebrates the humility of labourers by making them the focus of the painting."""@en ;
  dcterms:modified "2026-02-12T08:59:21.715090Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1881-1
  a curric:KeyLearningPoint ;
  rdfs:label """When performing a poem, you should make informed decisions about the pace, volume, and tone of your voice."""@en ;
  dcterms:modified "2026-02-12T08:59:21.715095Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1881-2
  a curric:KeyLearningPoint ;
  rdfs:label """Your pace, volume and tone could be very different at different moments of the poem."""@en ;
  dcterms:modified "2026-02-12T08:59:21.715099Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1881-3
  a curric:KeyLearningPoint ;
  rdfs:label """Experimenting with different ways of saying a poem can be a good way to decide on how you ultimately want to perform it."""@en ;
  dcterms:modified "2026-02-12T08:59:21.715104Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1881-4
  a curric:KeyLearningPoint ;
  rdfs:label """You will also want to consider body language and eye contact when performing a poem."""@en ;
  dcterms:modified "2026-02-12T08:59:21.715108Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1881-5
  a curric:KeyLearningPoint ;
  rdfs:label """When you don't know a poem by heart, you should consider how to maintain a good level of eye contact with your audience."""@en ;
  dcterms:modified "2026-02-12T08:59:21.715112Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1882-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Equality' sees a speaker demand equality so that she can be \"free\"."@en ;
  dcterms:modified "2026-02-12T08:59:21.715179Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1882-2
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, the poem presents racial and gender inequality that Angelou experienced as a Black American woman."""@en ;
  dcterms:modified "2026-02-12T08:59:21.715184Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1882-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Equality' starts with the word "you" and we could argue that the speaker has an accusatory tone at points in the poem."""@en ;
  dcterms:modified "2026-02-12T08:59:21.715188Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1882-4
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, the speaker's response to the inequality she sees makes it a poem about resilience in the face of inequality."""@en ;
  dcterms:modified "2026-02-12T08:59:21.715193Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1882-5
  a curric:KeyLearningPoint ;
  rdfs:label """Linking quotations together when you explore a poem can make your idea more powerful."""@en ;
  dcterms:modified "2026-02-12T08:59:21.715197Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1878-1
  a curric:KeyLearningPoint ;
  rdfs:label """Figurative language sees writers use non-literal words and phrases to develop complex ideas about something, or someone."""@en ;
  dcterms:modified "2026-02-12T08:59:21.715229Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1878-2
  a curric:KeyLearningPoint ;
  rdfs:label """Maya Angelou uses figurative language in 'Phenomenal Woman' to develop complex ideas about the speaker."""@en ;
  dcterms:modified "2026-02-12T08:59:21.715233Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1878-3
  a curric:KeyLearningPoint ;
  rdfs:label """When writing figuratively, you should consider the ideas you are trying to convey and use words which develop this idea."""@en ;
  dcterms:modified "2026-02-12T08:59:21.715238Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1820-1
  a curric:KeyLearningPoint ;
  rdfs:label "W.H. Auden’s poem ‘Musée des Beaux Arts’ is an ekphrastic poem."@en ;
  dcterms:modified "2026-02-12T08:59:21.715242Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1820-2
  a curric:KeyLearningPoint ;
  rdfs:label """An ekphrastic poem is a poem which describes a piece of art, and is inspired by it."""@en ;
  dcterms:modified "2026-02-12T08:59:21.715247Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1820-3
  a curric:KeyLearningPoint ;
  rdfs:label "Each painting which inspired Auden’s ekphrastic poem depicts tragic events."@en ;
  dcterms:modified "2026-02-12T08:59:21.715251Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1820-4
  a curric:KeyLearningPoint ;
  rdfs:label """However, what inspired Auden were the people in the paintings who seem to have apathetic responses to the tragic events."""@en ;
  dcterms:modified "2026-02-12T08:59:21.715255Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1820-5
  a curric:KeyLearningPoint ;
  rdfs:label """Auden focuses particularly on the apathy of the ploughman in Bruegel’s painting ‘Landscape with the Fall of Icarus’."""@en ;
  dcterms:modified "2026-02-12T08:59:21.715260Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1958-1
  a curric:KeyLearningPoint ;
  rdfs:label """The cover, blurb and dedication of a book can give you important details about the themes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.715284Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1958-2
  a curric:KeyLearningPoint ;
  rdfs:label "The novel is dedicated to Odin, who is a Norse god and an inspiration to poets."@en ;
  dcterms:modified "2026-02-12T08:59:21.715289Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1958-3
  a curric:KeyLearningPoint ;
  rdfs:label "A protagonist refers to the main character of a story."@en ;
  dcterms:modified "2026-02-12T08:59:21.715293Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1958-4
  a curric:KeyLearningPoint ;
  rdfs:label "Martha is blind in one eye because of an accident."@en ;
  dcterms:modified "2026-02-12T08:59:21.715298Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1958-5
  a curric:KeyLearningPoint ;
  rdfs:label "Martha can feel other people’s emotions and thoughts through their clothing."@en ;
  dcterms:modified "2026-02-12T08:59:21.715302Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1959-1
  a curric:KeyLearningPoint ;
  rdfs:label "Mormor's cabin is very isolated and the surrounding forest is dark."@en ;
  dcterms:modified "2026-02-12T08:59:21.715336Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1959-2
  a curric:KeyLearningPoint ;
  rdfs:label "A strange boy is living in the cabin and tells Martha that Mormor is dead."@en ;
  dcterms:modified "2026-02-12T08:59:21.715342Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1959-3
  a curric:KeyLearningPoint ;
  rdfs:label "The setting makes the reader feel uneasy and scared for Martha."@en ;
  dcterms:modified "2026-02-12T08:59:21.715346Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1959-4
  a curric:KeyLearningPoint ;
  rdfs:label "'The Twisted Tree' can be described as a Nordic thriller."@en ;
  dcterms:modified "2026-02-12T08:59:21.715350Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1959-5
  a curric:KeyLearningPoint ;
  rdfs:label """Pathetic fallacy can be used to create a specific atmosphere and reflect the feelings of the main character."""@en ;
  dcterms:modified "2026-02-12T08:59:21.715355Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1720-1
  a curric:KeyLearningPoint ;
  rdfs:label """Piggy insists that Ralph and the twins go with him to Castle Rock and demand the return of his glasses."""@en ;
  dcterms:modified "2026-02-12T08:59:21.715449Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1720-2
  a curric:KeyLearningPoint ;
  rdfs:label """Piggy carries the conch as a reminder of the ordered society they once hoped to create."""@en ;
  dcterms:modified "2026-02-12T08:59:21.715454Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1720-3
  a curric:KeyLearningPoint ;
  rdfs:label "Piggy bravely challenges the morality of Jack's tribe."@en ;
  dcterms:modified "2026-02-12T08:59:21.715458Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1720-4
  a curric:KeyLearningPoint ;
  rdfs:label "Roger pushes a boulder onto Piggy who falls to his death."@en ;
  dcterms:modified "2026-02-12T08:59:21.715467Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1720-5
  a curric:KeyLearningPoint ;
  rdfs:label "Ralph is chased out of the camp by the boys with spears."@en ;
  dcterms:modified "2026-02-12T08:59:21.715475Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1592-1
  a curric:KeyLearningPoint ;
  rdfs:label "Performing a poem means bringing out the drama of the poem."@en ;
  dcterms:modified "2026-02-12T08:59:21.715570Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1592-2
  a curric:KeyLearningPoint ;
  rdfs:label "It is important to vary the pace and tone in your performance."@en ;
  dcterms:modified "2026-02-12T08:59:21.715574Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1592-3
  a curric:KeyLearningPoint ;
  rdfs:label "It's best to learn the poem so you can perform the poem and not just say it."@en ;
  dcterms:modified "2026-02-12T08:59:21.715579Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1592-4
  a curric:KeyLearningPoint ;
  rdfs:label "You should make eye contact with the audience when performing a poem."@en ;
  dcterms:modified "2026-02-12T08:59:21.715583Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1592-5
  a curric:KeyLearningPoint ;
  rdfs:label """Peer-assessment is a useful tool to help each other make a range of improvements."""@en ;
  dcterms:modified "2026-02-12T08:59:21.715588Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1588-1
  a curric:KeyLearningPoint ;
  rdfs:label "The poem is about a man who is visited by a foreboding raven, in the night."@en ;
  dcterms:modified "2026-02-12T08:59:21.715646Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1588-2
  a curric:KeyLearningPoint ;
  rdfs:label "In the poem, the raven symbolises death and the speaker’s grief."@en ;
  dcterms:modified "2026-02-12T08:59:21.715651Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1588-3
  a curric:KeyLearningPoint ;
  rdfs:label """Poe presents the narrator as griefstricken; he has perhaps been influenced by the tragedy in his own life."""@en ;
  dcterms:modified "2026-02-12T08:59:21.715658Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1588-4
  a curric:KeyLearningPoint ;
  rdfs:label "The poem links to the Gothic through the dark, isolated setting."@en ;
  dcterms:modified "2026-02-12T08:59:21.715663Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1588-5
  a curric:KeyLearningPoint ;
  rdfs:label """The poem links to the Gothic through its portrayal of a speaker, in a state of heightened emotion."""@en ;
  dcterms:modified "2026-02-12T08:59:21.715667Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1819-1
  a curric:KeyLearningPoint ;
  rdfs:label """William Carlos Williams's 'Landscape with the Fall of Icarus' is an ekphrastic poem."""@en ;
  dcterms:modified "2026-02-12T08:59:21.715672Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1819-2
  a curric:KeyLearningPoint ;
  rdfs:label """An ekphrastic poem is a poem which describes a piece of art, and is inspired by it."""@en ;
  dcterms:modified "2026-02-12T08:59:21.715676Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1819-3
  a curric:KeyLearningPoint ;
  rdfs:label """Each of Williams’s seven stanzas refers to something in Pieter Bruegel's painting 'Landscape with the Fall of Icarus'."""@en ;
  dcterms:modified "2026-02-12T08:59:21.715681Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1819-4
  a curric:KeyLearningPoint ;
  rdfs:label "Like Bruegel, Williams focuses on the natural world rather than Icarus himself."@en ;
  dcterms:modified "2026-02-12T08:59:21.715685Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1819-5
  a curric:KeyLearningPoint ;
  rdfs:label """Each line of Williams’s poem is enjambed - there is no punctuation at the end of any of the lines."""@en ;
  dcterms:modified "2026-02-12T08:59:21.715690Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1587-1
  a curric:KeyLearningPoint ;
  rdfs:label "Edgar Allan Poe wrote brilliant ghost stories and detective fiction."@en ;
  dcterms:modified "2026-02-12T08:59:21.715711Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1587-2
  a curric:KeyLearningPoint ;
  rdfs:label """The Gothic genre is a form of literature that emerged in the middle of the 18th century and is still popular today ."""@en ;
  dcterms:modified "2026-02-12T08:59:21.715716Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1587-3
  a curric:KeyLearningPoint ;
  rdfs:label """'The Raven’ was Poe's masterpiece and it likely draws on his own experiences of grief and devastation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.715720Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1587-4
  a curric:KeyLearningPoint ;
  rdfs:label """‘The Raven’ is about a bereaved man who is visited by a raven who torments him into madness."""@en ;
  dcterms:modified "2026-02-12T08:59:21.715725Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1821-1
  a curric:KeyLearningPoint ;
  rdfs:label "William Carlos Williams's 'The Hunters in the Snow' is an ekphrastic poem."@en ;
  dcterms:modified "2026-02-12T08:59:21.715800Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1821-2
  a curric:KeyLearningPoint ;
  rdfs:label """An ekphrastic poem is a poem which describes a piece of art, and is inspired by it."""@en ;
  dcterms:modified "2026-02-12T08:59:21.715804Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1821-3
  a curric:KeyLearningPoint ;
  rdfs:label """Each of Williams's seven stanzas refers to something in Pieter Bruegel’s painting 'The Hunters in the Snow'."""@en ;
  dcterms:modified "2026-02-12T08:59:21.715809Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1821-4
  a curric:KeyLearningPoint ;
  rdfs:label "Bruegel's 'The Hunters in the Snow' depicts a rural scene in winter."@en ;
  dcterms:modified "2026-02-12T08:59:21.715815Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1960-1
  a curric:KeyLearningPoint ;
  rdfs:label "Martha has a vivid nightmare about the tree."@en ;
  dcterms:modified "2026-02-12T08:59:21.715823Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1960-2
  a curric:KeyLearningPoint ;
  rdfs:label "Martha allows Stig to stay."@en ;
  dcterms:modified "2026-02-12T08:59:21.715830Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1960-3
  a curric:KeyLearningPoint ;
  rdfs:label "The tree has a symbolic meaning that will be revealed throughout the novel."@en ;
  dcterms:modified "2026-02-12T08:59:21.715835Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1960-4
  a curric:KeyLearningPoint ;
  rdfs:label """Similes can be used to create vivid imagery and help the reader experience what is being described."""@en ;
  dcterms:modified "2026-02-12T08:59:21.715839Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1960-5
  a curric:KeyLearningPoint ;
  rdfs:label """When crafting similes, they need to be plausible, draw relevant comparisons and not be confusing for the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.715844Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1558-1
  a curric:KeyLearningPoint ;
  rdfs:label """Gothic literature is literature that evokes feelings of mystery, fear and terror."""@en ;
  dcterms:modified "2026-02-12T08:59:21.715943Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1558-2
  a curric:KeyLearningPoint ;
  rdfs:label """The horrifying events narrated in Gothic texts are often metaphors for characters' psychological struggles."""@en ;
  dcterms:modified "2026-02-12T08:59:21.715948Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1558-3
  a curric:KeyLearningPoint ;
  rdfs:label "Gothic atmospheres are often tense, created by a fear of the unknown."@en ;
  dcterms:modified "2026-02-12T08:59:21.715952Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1558-4
  a curric:KeyLearningPoint ;
  rdfs:label "The supernatural is also an important element of Gothic literature."@en ;
  dcterms:modified "2026-02-12T08:59:21.715957Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1558-5
  a curric:KeyLearningPoint ;
  rdfs:label """Frankenstein tells the story of a scientist who pushes knowledge to its limit by creating a creature out of human parts."""@en ;
  dcterms:modified "2026-02-12T08:59:21.715961Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6224-1
  a curric:KeyLearningPoint ;
  rdfs:label """A script can transform key moments from stories into structured, performable scenes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716039Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6224-2
  a curric:KeyLearningPoint ;
  rdfs:label """Scripts must include the act and scene number, character profiles, character names, stage directions and dialogue."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716043Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6224-3
  a curric:KeyLearningPoint ;
  rdfs:label """Stage directions can describe the setting, time of day, weather, mood and characters' actions and emotions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716048Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6224-4
  a curric:KeyLearningPoint ;
  rdfs:label """Dialogue specifies what each character says, with accompanying stage directions on how to deliver the lines."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716052Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6224-5
  a curric:KeyLearningPoint ;
  rdfs:label """Effective script writing requires detailed opening stage directions to establish the scene's atmosphere and context."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716057Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1967-1
  a curric:KeyLearningPoint ;
  rdfs:label "Martha falls into a dream and sees Karina, her great-grandmother."@en ;
  dcterms:modified "2026-02-12T08:59:21.716062Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1967-2
  a curric:KeyLearningPoint ;
  rdfs:label "Karina warns her that Mormor is trapped because nobody has watered the tree."@en ;
  dcterms:modified "2026-02-12T08:59:21.716066Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1967-3
  a curric:KeyLearningPoint ;
  rdfs:label "The light attracts the draugr."@en ;
  dcterms:modified "2026-02-12T08:59:21.716071Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1967-4
  a curric:KeyLearningPoint ;
  rdfs:label "Fate is the idea that our lives are laid out for us before we are even born."@en ;
  dcterms:modified "2026-02-12T08:59:21.716076Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1967-5
  a curric:KeyLearningPoint ;
  rdfs:label "Martha believes you can alter the course of your life through your actions."@en ;
  dcterms:modified "2026-02-12T08:59:21.716080Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-874-1
  a curric:KeyLearningPoint ;
  rdfs:label """Dorothy meets three companions on her way to Oz: the Scarecrow, the Tin-Man and the Lion."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716085Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-874-2
  a curric:KeyLearningPoint ;
  rdfs:label """Baum uses language to show the reader that Dorothy is not frightened by meeting any of these characters."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716092Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-874-3
  a curric:KeyLearningPoint ;
  rdfs:label """When creating your own unknown character, you need to consider how your language will make the reader perceive them."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716097Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1937-1
  a curric:KeyLearningPoint ;
  rdfs:label """The Victorian era saw the police force take an interest in solving previous crimes"""@en ;
  dcterms:modified "2026-02-12T08:59:21.716102Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1937-2
  a curric:KeyLearningPoint ;
  rdfs:label """The popularity of detective fiction grew at this time, in particular the Sherlock Holmes stories"""@en ;
  dcterms:modified "2026-02-12T08:59:21.716106Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1937-3
  a curric:KeyLearningPoint ;
  rdfs:label """In The Speckled Band, Helen Stoner, who is frightened and distressed, comes to visit Sherlock Holmes"""@en ;
  dcterms:modified "2026-02-12T08:59:21.716111Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1937-4
  a curric:KeyLearningPoint ;
  rdfs:label "Helen may have visited Holmes to help her solve a crime"@en ;
  dcterms:modified "2026-02-12T08:59:21.716115Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1922-1
  a curric:KeyLearningPoint ;
  rdfs:label "We can read between the lines to better understand people's attitudes on 'home'."@en ;
  dcterms:modified "2026-02-12T08:59:21.716120Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1922-2
  a curric:KeyLearningPoint ;
  rdfs:label """Brontë presents home as imperfect, whilst Swain emphasises that love makes a home."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716129Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1922-3
  a curric:KeyLearningPoint ;
  rdfs:label "George The Poet provides a realistic portrayal of London in 'My City'."@en ;
  dcterms:modified "2026-02-12T08:59:21.716134Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1922-4
  a curric:KeyLearningPoint ;
  rdfs:label """George The Poet values diversity of his home but criticises the widespread inequality."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716141Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1808-1
  a curric:KeyLearningPoint ;
  rdfs:label """Othello may be considered a tragic hero as he recognises the root of his downfall."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716146Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1808-2
  a curric:KeyLearningPoint ;
  rdfs:label "Othello's hamartia might be his jealousy or his naive trust of Iago."@en ;
  dcterms:modified "2026-02-12T08:59:21.716151Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1808-3
  a curric:KeyLearningPoint ;
  rdfs:label """Othello’s hubris may be shown when he won’t consider Desdemona’s viewpoint or when he views himself as a godly figure."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716155Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1808-4
  a curric:KeyLearningPoint ;
  rdfs:label "Othello's demise is also triggered by his stubbornness."@en ;
  dcterms:modified "2026-02-12T08:59:21.716160Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1873-1
  a curric:KeyLearningPoint ;
  rdfs:label "Topic sentences should link to the question."@en ;
  dcterms:modified "2026-02-12T08:59:21.717079Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1873-2
  a curric:KeyLearningPoint ;
  rdfs:label "Include multiple quotations in each paragraph from across the play."@en ;
  dcterms:modified "2026-02-12T08:59:21.717083Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1873-3
  a curric:KeyLearningPoint ;
  rdfs:label "Consider writer’s methods when analysing quotations."@en ;
  dcterms:modified "2026-02-12T08:59:21.717088Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1873-4
  a curric:KeyLearningPoint ;
  rdfs:label "Include relevant context to develop your analysis."@en ;
  dcterms:modified "2026-02-12T08:59:21.717092Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1813-1
  a curric:KeyLearningPoint ;
  rdfs:label "Context refers to the historical, social, literary and biographical."@en ;
  dcterms:modified "2026-02-12T08:59:21.717097Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1813-2
  a curric:KeyLearningPoint ;
  rdfs:label "Context should not be presented as isolated facts or generalisations."@en ;
  dcterms:modified "2026-02-12T08:59:21.717101Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1813-3
  a curric:KeyLearningPoint ;
  rdfs:label "Context should be relevant to the analysis and embedded in the response."@en ;
  dcterms:modified "2026-02-12T08:59:21.717110Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1813-4
  a curric:KeyLearningPoint ;
  rdfs:label """Context should develop your ideas and give an insight into the writer’s purpose and intention."""@en ;
  dcterms:modified "2026-02-12T08:59:21.717115Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1813-5
  a curric:KeyLearningPoint ;
  rdfs:label """Context can be used to analyse specific word choices or images, considering historic connotations or social importance."""@en ;
  dcterms:modified "2026-02-12T08:59:21.717121Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-884-1
  a curric:KeyLearningPoint ;
  rdfs:label "Writers often use patterns of words, phrases and images across a text."@en ;
  dcterms:modified "2026-02-12T08:59:21.717126Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-884-2
  a curric:KeyLearningPoint ;
  rdfs:label """Writers may use contrast in addition to patterns in order to emphasise the importance of the pattern."""@en ;
  dcterms:modified "2026-02-12T08:59:21.717131Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-884-3
  a curric:KeyLearningPoint ;
  rdfs:label """Patterns are effective because our brains are wired to recognise and remember patterns."""@en ;
  dcterms:modified "2026-02-12T08:59:21.717135Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-884-4
  a curric:KeyLearningPoint ;
  rdfs:label """In the same way that words have deeper meanings and connotations, images can also symbolise something more."""@en ;
  dcterms:modified "2026-02-12T08:59:21.717140Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-875-1
  a curric:KeyLearningPoint ;
  rdfs:label "Though sad to leave her companions, Dorothy was glad to return to Kansas."@en ;
  dcterms:modified "2026-02-12T08:59:21.717144Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-875-2
  a curric:KeyLearningPoint ;
  rdfs:label "A theme of a story is a central topic, subject, or message within a narrative."@en ;
  dcterms:modified "2026-02-12T08:59:21.717149Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-875-3
  a curric:KeyLearningPoint ;
  rdfs:label "Baum used Dorothy’s time in the unknown to convey a message to the reader."@en ;
  dcterms:modified "2026-02-12T08:59:21.717153Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-875-4
  a curric:KeyLearningPoint ;
  rdfs:label """The message is arguably that we have the tools to help ourselves and don’t need to rely on others."""@en ;
  dcterms:modified "2026-02-12T08:59:21.717157Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1981-1
  a curric:KeyLearningPoint ;
  rdfs:label """The novel gets more frightening and tense as it progresses, because of the increasing threat to Martha's life."""@en ;
  dcterms:modified "2026-02-12T08:59:21.717162Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1981-2
  a curric:KeyLearningPoint ;
  rdfs:label """Writers often raise tension by introducing uncertainty, conflict or time pressure into stories."""@en ;
  dcterms:modified "2026-02-12T08:59:21.717166Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1981-3
  a curric:KeyLearningPoint ;
  rdfs:label "Inferences should be developed to include additional interpretations."@en ;
  dcterms:modified "2026-02-12T08:59:21.717171Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1981-4
  a curric:KeyLearningPoint ;
  rdfs:label """Burge uses elements of the Gothic to raise the tension when Martha enters the twisted tree for the first time."""@en ;
  dcterms:modified "2026-02-12T08:59:21.717175Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1987-1
  a curric:KeyLearningPoint ;
  rdfs:label "A script contains stage directions, character names and dialogue."@en ;
  dcterms:modified "2026-02-12T08:59:21.717180Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1987-2
  a curric:KeyLearningPoint ;
  rdfs:label """Scripts are structured for performance and must be formatted differently from prose."""@en ;
  dcterms:modified "2026-02-12T08:59:21.717184Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1987-3
  a curric:KeyLearningPoint ;
  rdfs:label """Stage directions provide instructions for actors on movement, behaviour and speech."""@en ;
  dcterms:modified "2026-02-12T08:59:21.717189Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1987-4
  a curric:KeyLearningPoint ;
  rdfs:label """Characters are clearly identified in a script with profiles and names labelled for dialogue."""@en ;
  dcterms:modified "2026-02-12T08:59:21.717196Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1987-5
  a curric:KeyLearningPoint ;
  rdfs:label """Setting the scene in a script includes detailed descriptions of time, place and atmosphere."""@en ;
  dcterms:modified "2026-02-12T08:59:21.717200Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1513-1
  a curric:KeyLearningPoint ;
  rdfs:label "Mr. Woodifield and the boss are foils to one another."@en ;
  dcterms:modified "2026-02-12T08:59:21.717245Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1513-2
  a curric:KeyLearningPoint ;
  rdfs:label "Symbolism is when writers use something to represent intangible ideas."@en ;
  dcterms:modified "2026-02-12T08:59:21.717249Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1513-3
  a curric:KeyLearningPoint ;
  rdfs:label "The fly is a powerful symbol in ‘The Fly’."@en ;
  dcterms:modified "2026-02-12T08:59:21.717256Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1513-4
  a curric:KeyLearningPoint ;
  rdfs:label """The fly could symbolise the boss’s son and the idea that his life was short, and perhaps even needlessly wasted."""@en ;
  dcterms:modified "2026-02-12T08:59:21.717261Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1513-5
  a curric:KeyLearningPoint ;
  rdfs:label """The fly could also symbolise the boss’s feelings of powerlessness and despair over his son’s death."""@en ;
  dcterms:modified "2026-02-12T08:59:21.717266Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1589-1
  a curric:KeyLearningPoint ;
  rdfs:label """The poem is about a palace that was once beautiful and majestic but is now ruined and full of sorrow."""@en ;
  dcterms:modified "2026-02-12T08:59:21.717270Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1589-2
  a curric:KeyLearningPoint ;
  rdfs:label "The poem is a metaphor for the physical effects of depression on the human mind."@en ;
  dcterms:modified "2026-02-12T08:59:21.717275Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1589-3
  a curric:KeyLearningPoint ;
  rdfs:label """The poem links to the Gothic through its setting and its portrayal of a decaying and haunted house."""@en ;
  dcterms:modified "2026-02-12T08:59:21.717281Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1803-1
  a curric:KeyLearningPoint ;
  rdfs:label "Act 3, Scene 3 can be seen as the moment of peripeteia in the tragedy."@en ;
  dcterms:modified "2026-02-12T08:59:21.717286Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1803-2
  a curric:KeyLearningPoint ;
  rdfs:label """The fragmented structure of the scene highlights the increasingly disordered nature of the play."""@en ;
  dcterms:modified "2026-02-12T08:59:21.717290Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1803-3
  a curric:KeyLearningPoint ;
  rdfs:label """The symbolic setting of the garden alludes to the biblical temptation in that it mirrors Iago's satanic role."""@en ;
  dcterms:modified "2026-02-12T08:59:21.717297Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1803-4
  a curric:KeyLearningPoint ;
  rdfs:label "Dramatic irony heightens the tension in Act 3, Scene 3."@en ;
  dcterms:modified "2026-02-12T08:59:21.717302Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1985-1
  a curric:KeyLearningPoint ;
  rdfs:label """Effective planning starts with a 'brain dump' where you recall as much relevant information about the task as possible."""@en ;
  dcterms:modified "2026-02-12T08:59:21.717306Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1985-2
  a curric:KeyLearningPoint ;
  rdfs:label "Language devices should match the tone of the article."@en ;
  dcterms:modified "2026-02-12T08:59:21.717311Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1985-3
  a curric:KeyLearningPoint ;
  rdfs:label """Exclamatory sentences are not appropriate for an article about Mormor's death as it's a factual article."""@en ;
  dcterms:modified "2026-02-12T08:59:21.717315Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1985-4
  a curric:KeyLearningPoint ;
  rdfs:label """A 5-paragraph structure is effective for an article, including an introduction, 3 supporting details and a conclusion."""@en ;
  dcterms:modified "2026-02-12T08:59:21.717319Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-886-1
  a curric:KeyLearningPoint ;
  rdfs:label """Good analytical paragraphs begin with a clear topic sentence, supported by a range of evidence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.717360Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-886-2
  a curric:KeyLearningPoint ;
  rdfs:label "Good analytical paragraphs mention what method the writer is using."@en ;
  dcterms:modified "2026-02-12T08:59:21.717366Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-886-3
  a curric:KeyLearningPoint ;
  rdfs:label """Good analytical paragraphs are cohesive – discourse markers are used to link ideas together."""@en ;
  dcterms:modified "2026-02-12T08:59:21.717371Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-886-4
  a curric:KeyLearningPoint ;
  rdfs:label """Comment on the effects of specific language devices to develop your analysis in detail."""@en ;
  dcterms:modified "2026-02-12T08:59:21.717376Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6214-1
  a curric:KeyLearningPoint ;
  rdfs:label "Free writing is designed to help you unleash your creativity."@en ;
  dcterms:modified "2026-02-12T08:59:21.717380Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6214-2
  a curric:KeyLearningPoint ;
  rdfs:label """Rewriting is the process of rewriting sentences, adding, dropping or reframing ideas and choosing more precise words."""@en ;
  dcterms:modified "2026-02-12T08:59:21.717385Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6214-3
  a curric:KeyLearningPoint ;
  rdfs:label """You want to be precise and ambitious in your use of language devices in order to evoke specific emotions in the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.717389Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6214-4
  a curric:KeyLearningPoint ;
  rdfs:label "The way you use colour imagery can also affect the mood of a piece of writing."@en ;
  dcterms:modified "2026-02-12T08:59:21.717394Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1986-1
  a curric:KeyLearningPoint ;
  rdfs:label """Writing with focus – one sentence at a time – allows you to carefully craft each sentence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.717520Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1986-2
  a curric:KeyLearningPoint ;
  rdfs:label "A paragraph should include simple, compound and complex sentences."@en ;
  dcterms:modified "2026-02-12T08:59:21.717525Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1986-3
  a curric:KeyLearningPoint ;
  rdfs:label """Starting a sentence with an adverb can be effective, to set the tone and add further detail."""@en ;
  dcterms:modified "2026-02-12T08:59:21.717529Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1580-1
  a curric:KeyLearningPoint ;
  rdfs:label "Poe shows us how guilt drives the narrator further into insanity and delusion."@en ;
  dcterms:modified "2026-02-12T08:59:21.718145Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1580-2
  a curric:KeyLearningPoint ;
  rdfs:label """Single paragraph outlines are useful for organising your ideas into a coherent structure."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718149Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1580-3
  a curric:KeyLearningPoint ;
  rdfs:label """Single paragraph outlines contain a topic sentence, supporting detail and a summary sentence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718153Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1580-4
  a curric:KeyLearningPoint ;
  rdfs:label "Quotations will be needed to support each topic sentence."@en ;
  dcterms:modified "2026-02-12T08:59:21.718158Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1580-5
  a curric:KeyLearningPoint ;
  rdfs:label """A cohesive argument aims to prove one 'big idea'. All your ideas and evidence should work together to prove one idea."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718162Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1575-1
  a curric:KeyLearningPoint ;
  rdfs:label """Your Gothic writing should not simply be a horror story - you can create fear through atmosphere and mood."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718321Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1575-2
  a curric:KeyLearningPoint ;
  rdfs:label """Gothic literature is characterised by a sense of threat, but this does not have to be violent threat."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718325Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1575-3
  a curric:KeyLearningPoint ;
  rdfs:label """Semantic fields, pathetic fallacy and figurative language are methods that Gothic writers can use to create atmosphere."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718329Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1575-4
  a curric:KeyLearningPoint ;
  rdfs:label """It can be useful to plan your use of methods before you begin writing, to make sure you are using them effectively."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718334Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1835-1
  a curric:KeyLearningPoint ;
  rdfs:label """Chaucer creates 30 convincing characters in the opening section of his poem, 'The Canterbury Tales'."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718361Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1835-2
  a curric:KeyLearningPoint ;
  rdfs:label """To create each character, Chaucer describes how they look, how they speak, how they act and how others respond to them."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718367Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1835-3
  a curric:KeyLearningPoint ;
  rdfs:label """Chaucer also includes intriguing details so that we are curious to know more about each character."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718372Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1835-4
  a curric:KeyLearningPoint ;
  rdfs:label """These methods of characterisation are employed by many writers and can be used in your own writing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718377Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1811-1
  a curric:KeyLearningPoint ;
  rdfs:label """Motif analysis should address both the overall purpose of the motif and the meaning of individual examples."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718395Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1811-2
  a curric:KeyLearningPoint ;
  rdfs:label """The motif of plants and gardening surrounds Iago, suggesting that he is in control."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718399Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1811-3
  a curric:KeyLearningPoint ;
  rdfs:label """Many of Iago's quotes about plants are focused on poison, suggesting that he taints those around him."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718404Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1811-4
  a curric:KeyLearningPoint ;
  rdfs:label """The motif of animals and light and dark allows racist stereotypes to be exposed and subverted, respectively."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718408Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1811-5
  a curric:KeyLearningPoint ;
  rdfs:label "The motif of demons, hell and monsters is concerned with characters’ morality."@en ;
  dcterms:modified "2026-02-12T08:59:21.718412Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1530-1
  a curric:KeyLearningPoint ;
  rdfs:label "The poem begins by introducing the symbol of the poppy"@en ;
  dcterms:modified "2026-02-12T08:59:21.718512Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1530-2
  a curric:KeyLearningPoint ;
  rdfs:label """There are crosses marking the graves of the many fallen soldiers, who died in these fields in Belgium"""@en ;
  dcterms:modified "2026-02-12T08:59:21.718517Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1530-3
  a curric:KeyLearningPoint ;
  rdfs:label """The second stanza focuses on the men and how they once were, creating empathy for the dead"""@en ;
  dcterms:modified "2026-02-12T08:59:21.718521Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1530-4
  a curric:KeyLearningPoint ;
  rdfs:label """The final stanza is a call to arms, encouraging others to continue to fight for freedom"""@en ;
  dcterms:modified "2026-02-12T08:59:21.718525Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28477-1
  a curric:KeyLearningPoint ;
  rdfs:label """Performing a slam poem is about more than just reading the words from a page, it is about giving a dynamic performance."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718530Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28477-2
  a curric:KeyLearningPoint ;
  rdfs:label "Considering non-verbal features and physicality can elevate your performance."@en ;
  dcterms:modified "2026-02-12T08:59:21.718534Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28477-3
  a curric:KeyLearningPoint ;
  rdfs:label """Annotating your poem with non-verbal features can be a useful way to help prepare for a performance."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718541Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28477-4
  a curric:KeyLearningPoint ;
  rdfs:label """Audience participation is a part of slam poetry, but it must be respectful and supportive."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718546Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28477-5
  a curric:KeyLearningPoint ;
  rdfs:label """It is ok to feel nervous before a performance. Considering your body language, posture and breath can help with nerves."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718550Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28389-1
  a curric:KeyLearningPoint ;
  rdfs:label "Discussions can be elevated with the inclusion of evidence."@en ;
  dcterms:modified "2026-02-12T08:59:21.718554Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28389-2
  a curric:KeyLearningPoint ;
  rdfs:label "Written responses, textual evidence can also be used in discussions."@en ;
  dcterms:modified "2026-02-12T08:59:21.718559Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28389-3
  a curric:KeyLearningPoint ;
  rdfs:label """Different types of evidence can be used, depending on the question, for example: anecdotal evidence or speculation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718563Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28389-4
  a curric:KeyLearningPoint ;
  rdfs:label """It is a good idea to use tentative phrases when evidence is not verified or anecdotal."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718568Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28404-1
  a curric:KeyLearningPoint ;
  rdfs:label """Debates are a formal type of communication that help us build knowledge and develop critical thinking skills"""@en ;
  dcterms:modified "2026-02-12T08:59:21.718718Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28404-2
  a curric:KeyLearningPoint ;
  rdfs:label "A debate is focused around a motion which is a clear statement."@en ;
  dcterms:modified "2026-02-12T08:59:21.718722Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28404-3
  a curric:KeyLearningPoint ;
  rdfs:label "The proposition is in favour of the motion."@en ;
  dcterms:modified "2026-02-12T08:59:21.718727Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28404-4
  a curric:KeyLearningPoint ;
  rdfs:label "The opposition is against the motion."@en ;
  dcterms:modified "2026-02-12T08:59:21.718731Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28404-5
  a curric:KeyLearningPoint ;
  rdfs:label "A debate requires a range of roles and skills."@en ;
  dcterms:modified "2026-02-12T08:59:21.718736Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1593-1
  a curric:KeyLearningPoint ;
  rdfs:label """The invading Angles, Saxons and Jutes brought useful language, for describing everyday things."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718923Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1593-2
  a curric:KeyLearningPoint ;
  rdfs:label """The English population adopted Latin words through the Church and French words through the Norman invasion."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718927Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1593-3
  a curric:KeyLearningPoint ;
  rdfs:label """Both Shakespeare and the King James Bible gave the English language many of the phrases that we use today."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718932Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1593-4
  a curric:KeyLearningPoint ;
  rdfs:label "Scientific developments led to the creation of many new words."@en ;
  dcterms:modified "2026-02-12T08:59:21.718938Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1593-5
  a curric:KeyLearningPoint ;
  rdfs:label """The expansion of the British Empire led to new words being adopted and the English language travelling globally."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718943Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1726-1
  a curric:KeyLearningPoint ;
  rdfs:label """Golding uses contrasting imagery to present the island as a utopian paradise that has the potential to corrupt."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718947Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1726-2
  a curric:KeyLearningPoint ;
  rdfs:label "Golding uses the setting to reflect the condition of the boys."@en ;
  dcterms:modified "2026-02-12T08:59:21.718954Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1726-3
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, Golding uses the setting to foreshadow the boys' descent into savagery by the end of the novel."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718958Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1726-4
  a curric:KeyLearningPoint ;
  rdfs:label """By the end of the novel, the island is unrecognisable due to the environmental damage the boys have caused."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718963Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1726-5
  a curric:KeyLearningPoint ;
  rdfs:label """The boys harm their environment as much as they harm each other, showing mankind's capacity for destruction."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718969Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1727-1
  a curric:KeyLearningPoint ;
  rdfs:label """The deaths in the novel drive the plot - they escalate in brutality and intention as the novel progresses."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718974Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1727-2
  a curric:KeyLearningPoint ;
  rdfs:label """Golding foreshadows the death of Piggy and the attempted murder of Ralph from the beginning of the novel."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718978Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1727-3
  a curric:KeyLearningPoint ;
  rdfs:label """Golding's novel is an allegory about the importance of rules and the innate evil of mankind."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718983Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1727-4
  a curric:KeyLearningPoint ;
  rdfs:label """Golding alludes to 'Coral Island' throughout the novel, arguably to offer a different perspective of the same situation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718987Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1727-5
  a curric:KeyLearningPoint ;
  rdfs:label """Golding subverts the children's adventure novel genre to create a horrifying allegory about the true nature of evil."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718992Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1725-1
  a curric:KeyLearningPoint ;
  rdfs:label """Piggy is dehumanised and ostracised by the group of boys because of his physical appearance."""@en ;
  dcterms:modified "2026-02-12T08:59:21.720299Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1725-2
  a curric:KeyLearningPoint ;
  rdfs:label """Piggy's glasses, weight, asthma and lower-class upbringing all give him vulnerabilities that the other boys exploit."""@en ;
  dcterms:modified "2026-02-12T08:59:21.720305Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1725-3
  a curric:KeyLearningPoint ;
  rdfs:label """The boys treat Piggy like an animal, but he is ironically the most human and civilised character."""@en ;
  dcterms:modified "2026-02-12T08:59:21.720309Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1725-4
  a curric:KeyLearningPoint ;
  rdfs:label "Piggy is pragmatic: he arguably represents rationality, reason and civilisation."@en ;
  dcterms:modified "2026-02-12T08:59:21.720313Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1725-5
  a curric:KeyLearningPoint ;
  rdfs:label """Piggy's death metaphorically represents the death of civilisation and the abandonment of rationality."""@en ;
  dcterms:modified "2026-02-12T08:59:21.720318Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28405-1
  a curric:KeyLearningPoint ;
  rdfs:label """In a debate you need to be prepared to take the role of proposition or opposition, regardless of personal stance."""@en ;
  dcterms:modified "2026-02-12T08:59:21.720322Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28405-2
  a curric:KeyLearningPoint ;
  rdfs:label """An opening argument should use formal vocabulary, specific examples and address the motion clearly."""@en ;
  dcterms:modified "2026-02-12T08:59:21.720326Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28405-3
  a curric:KeyLearningPoint ;
  rdfs:label "Discourse markers can be used to create  a clear and logical line of argument."@en ;
  dcterms:modified "2026-02-12T08:59:21.720331Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28405-4
  a curric:KeyLearningPoint ;
  rdfs:label "It is important to practise presenting your arguments."@en ;
  dcterms:modified "2026-02-12T08:59:21.720338Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28405-5
  a curric:KeyLearningPoint ;
  rdfs:label """You should consider how you present your argument including body language and use of voice."""@en ;
  dcterms:modified "2026-02-12T08:59:21.720342Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1945-1
  a curric:KeyLearningPoint ;
  rdfs:label """Rhetorical devices are used to evoke an emotion in the reader or to persuade them of something"""@en ;
  dcterms:modified "2026-02-12T08:59:21.720347Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1945-2
  a curric:KeyLearningPoint ;
  rdfs:label "Newspaper articles typically use a range of rhetorical devices"@en ;
  dcterms:modified "2026-02-12T08:59:21.720351Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1945-3
  a curric:KeyLearningPoint ;
  rdfs:label "Each rhetorical device will serve a different purpose depending on the context"@en ;
  dcterms:modified "2026-02-12T08:59:21.720355Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1945-4
  a curric:KeyLearningPoint ;
  rdfs:label "You should create your own rhetorical devices with an intended purpose in mind"@en ;
  dcterms:modified "2026-02-12T08:59:21.720360Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-878-1
  a curric:KeyLearningPoint ;
  rdfs:label "Writers use imagery in order to have an effect on the reader."@en ;
  dcterms:modified "2026-02-12T08:59:21.720364Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-878-2
  a curric:KeyLearningPoint ;
  rdfs:label """Writers might use images of light in order to create a positive, happy atmosphere."""@en ;
  dcterms:modified "2026-02-12T08:59:21.720373Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-878-3
  a curric:KeyLearningPoint ;
  rdfs:label """Writers might use images of darkness in order to create a negative, frightening atmosphere."""@en ;
  dcterms:modified "2026-02-12T08:59:21.720378Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1982-1
  a curric:KeyLearningPoint ;
  rdfs:label "An introduction to an analytical essay should include a clear thesis statement."@en ;
  dcterms:modified "2026-02-12T08:59:21.720382Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1982-2
  a curric:KeyLearningPoint ;
  rdfs:label """A clear thesis statement should introduce your over-arching argument for the essay and clearly answer the question."""@en ;
  dcterms:modified "2026-02-12T08:59:21.720387Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1982-3
  a curric:KeyLearningPoint ;
  rdfs:label """A clear thesis statement should deal with the whole of the novel and how the theme or character develops."""@en ;
  dcterms:modified "2026-02-12T08:59:21.720391Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1982-4
  a curric:KeyLearningPoint ;
  rdfs:label "A thoughtful thesis statement should consider the writer's intentions."@en ;
  dcterms:modified "2026-02-12T08:59:21.720396Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1972-1
  a curric:KeyLearningPoint ;
  rdfs:label """Lots of stories, particularly fables and fairy tales, fit into a traditional narrative arc."""@en ;
  dcterms:modified "2026-02-12T08:59:21.720563Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1972-2
  a curric:KeyLearningPoint ;
  rdfs:label "A narrative arc starts with an exposition."@en ;
  dcterms:modified "2026-02-12T08:59:21.720567Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1972-3
  a curric:KeyLearningPoint ;
  rdfs:label "A story’s rising action leads to its climax."@en ;
  dcterms:modified "2026-02-12T08:59:21.720571Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1972-4
  a curric:KeyLearningPoint ;
  rdfs:label "After the climax, falling action leads to a resolution."@en ;
  dcterms:modified "2026-02-12T08:59:21.720576Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1972-5
  a curric:KeyLearningPoint ;
  rdfs:label """'The Twisted Tree’ mostly follows this traditional structure, however there are arguably two climaxes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.720580Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1870-1
  a curric:KeyLearningPoint ;
  rdfs:label """Introductions can follow a three part structure moving from the general to the specific."""@en ;
  dcterms:modified "2026-02-12T08:59:21.721360Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1870-2
  a curric:KeyLearningPoint ;
  rdfs:label """The first sentence of an introduction could be a general statement about the text."""@en ;
  dcterms:modified "2026-02-12T08:59:21.721364Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1870-3
  a curric:KeyLearningPoint ;
  rdfs:label """The second sentence of the introduction could be a general statement about the given character or theme."""@en ;
  dcterms:modified "2026-02-12T08:59:21.721369Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1870-4
  a curric:KeyLearningPoint ;
  rdfs:label "The final sentence of your introduction could be your thesis."@en ;
  dcterms:modified "2026-02-12T08:59:21.721373Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1867-1
  a curric:KeyLearningPoint ;
  rdfs:label "Shakespeare explored the supernatural in many of his plays."@en ;
  dcterms:modified "2026-02-12T08:59:21.721406Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1867-2
  a curric:KeyLearningPoint ;
  rdfs:label "Sometimes Shakespeare presents the supernatural as clearly evil."@en ;
  dcterms:modified "2026-02-12T08:59:21.721411Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1867-3
  a curric:KeyLearningPoint ;
  rdfs:label """In ‘A Midsummer Night’s Dream’, the character of Puck is presented in an ambiguous way."""@en ;
  dcterms:modified "2026-02-12T08:59:21.721415Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1867-4
  a curric:KeyLearningPoint ;
  rdfs:label """Despite this ambiguous presentation, Puck is central to making ‘A Midsummer Night’s Dream’ a comedy."""@en ;
  dcterms:modified "2026-02-12T08:59:21.721420Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1948-1
  a curric:KeyLearningPoint ;
  rdfs:label "Holmes and Watson go to Stoke Moran to investigate the rooms"@en ;
  dcterms:modified "2026-02-12T08:59:21.721426Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1948-2
  a curric:KeyLearningPoint ;
  rdfs:label """Conan Doyle juxtaposes the atmosphere before getting to Stoke Moran and after they have arrived to convey danger"""@en ;
  dcterms:modified "2026-02-12T08:59:21.721431Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1948-3
  a curric:KeyLearningPoint ;
  rdfs:label "They find curious items in Helen’s room such as a dummy bell rope and ventilator"@en ;
  dcterms:modified "2026-02-12T08:59:21.721436Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1948-4
  a curric:KeyLearningPoint ;
  rdfs:label """They find curious items in Dr. Roylott’s room such as a saucer of milk and a dog-leash"""@en ;
  dcterms:modified "2026-02-12T08:59:21.721440Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1948-5
  a curric:KeyLearningPoint ;
  rdfs:label "After inspecting the rooms, Holmes believes Helen is in great danger"@en ;
  dcterms:modified "2026-02-12T08:59:21.721444Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1973-1
  a curric:KeyLearningPoint ;
  rdfs:label """The Gothic genre is characterised by the use of desolate, remote settings and macabre, mysterious or violent incidents."""@en ;
  dcterms:modified "2026-02-12T08:59:21.721449Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1973-2
  a curric:KeyLearningPoint ;
  rdfs:label """The setting in 'The Twisted Tree' is Gothic because the cabin is isolated and lots of the action happens in the dark."""@en ;
  dcterms:modified "2026-02-12T08:59:21.721453Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1973-3
  a curric:KeyLearningPoint ;
  rdfs:label """There is a motif of fog in the novel which adds a sense of mystery and concealment."""@en ;
  dcterms:modified "2026-02-12T08:59:21.721460Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1973-4
  a curric:KeyLearningPoint ;
  rdfs:label """The plot of the novel follows Gothic conventions because there is a supernatural enemy who must be defeated."""@en ;
  dcterms:modified "2026-02-12T08:59:21.721464Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1973-5
  a curric:KeyLearningPoint ;
  rdfs:label """The Gothic genre often includes curses or prophecies, which are found in the novel."""@en ;
  dcterms:modified "2026-02-12T08:59:21.721469Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1846-1
  a curric:KeyLearningPoint ;
  rdfs:label "‘A Midsummer Night’s Dream’ is a Shakespearean comedy."@en ;
  dcterms:modified "2026-02-12T08:59:21.721810Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1846-2
  a curric:KeyLearningPoint ;
  rdfs:label "There are three sets of characters in the play."@en ;
  dcterms:modified "2026-02-12T08:59:21.721815Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1846-3
  a curric:KeyLearningPoint ;
  rdfs:label """The play starts and ends in Athens; in the middle, the play is set in a magical forest."""@en ;
  dcterms:modified "2026-02-12T08:59:21.721819Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1846-4
  a curric:KeyLearningPoint ;
  rdfs:label "The play ends with a number of marriages."@en ;
  dcterms:modified "2026-02-12T08:59:21.721823Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1846-5
  a curric:KeyLearningPoint ;
  rdfs:label "A summary of the plot helps us understand some of the play’s main themes."@en ;
  dcterms:modified "2026-02-12T08:59:21.721828Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1504-1
  a curric:KeyLearningPoint ;
  rdfs:label """The Home Front refers to the idea that those in Britain felt the impact of World War One in their day to day lives."""@en ;
  dcterms:modified "2026-02-12T08:59:21.721832Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1504-2
  a curric:KeyLearningPoint ;
  rdfs:label """Food shortages, bombs and fear of invasion are some of the ways civilians in Britain were affected by World War One."""@en ;
  dcterms:modified "2026-02-12T08:59:21.721837Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1504-3
  a curric:KeyLearningPoint ;
  rdfs:label """When loved ones returned home from the front line, there were often complex and conflicting emotions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.721841Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1504-4
  a curric:KeyLearningPoint ;
  rdfs:label """Many women found employment during World War One, filling the labour shortage because so many men were fighting."""@en ;
  dcterms:modified "2026-02-12T08:59:21.721845Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1504-5
  a curric:KeyLearningPoint ;
  rdfs:label "Telegrams were a common method of communication during World War One."@en ;
  dcterms:modified "2026-02-12T08:59:21.721850Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1518-1
  a curric:KeyLearningPoint ;
  rdfs:label "Wilfred Owen (1893-1918) was a British poet and soldier."@en ;
  dcterms:modified "2026-02-12T08:59:21.721854Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1518-2
  a curric:KeyLearningPoint ;
  rdfs:label """Owen is best known for his stark, unflinching and graphic poems about World War One."""@en ;
  dcterms:modified "2026-02-12T08:59:21.721861Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1518-3
  a curric:KeyLearningPoint ;
  rdfs:label """Making predictions about what a text might be about is a helpful preparatory step before reading something."""@en ;
  dcterms:modified "2026-02-12T08:59:21.721866Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1518-4
  a curric:KeyLearningPoint ;
  rdfs:label """Skimming and scanning a text involves quickly reading something, and gathering its main ideas and overall tone."""@en ;
  dcterms:modified "2026-02-12T08:59:21.721870Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1518-5
  a curric:KeyLearningPoint ;
  rdfs:label """Close reading involves carefully considering a writer’s methods and their effects."""@en ;
  dcterms:modified "2026-02-12T08:59:21.721875Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1989-1
  a curric:KeyLearningPoint ;
  rdfs:label "A complete sentence needs a subject and a verb"@en ;
  dcterms:modified "2026-02-12T08:59:21.721879Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1989-2
  a curric:KeyLearningPoint ;
  rdfs:label """A subject is a person or thing doing the action and a verb is the word which describes this"""@en ;
  dcterms:modified "2026-02-12T08:59:21.721884Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1989-3
  a curric:KeyLearningPoint ;
  rdfs:label """A sentence fragment is grammatically incorrect because it does not include either a subject or a verb"""@en ;
  dcterms:modified "2026-02-12T08:59:21.721888Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1989-4
  a curric:KeyLearningPoint ;
  rdfs:label """Sentence fragments should be identified and corrected if they are found in your writing"""@en ;
  dcterms:modified "2026-02-12T08:59:21.721893Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1989-5
  a curric:KeyLearningPoint ;
  rdfs:label """Subjects and verbs need to be in agreement with each other, meaning the verb needs the correct ending"""@en ;
  dcterms:modified "2026-02-12T08:59:21.721897Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1590-1
  a curric:KeyLearningPoint ;
  rdfs:label "Poe uses persona to create a nostalgic mood towards the past."@en ;
  dcterms:modified "2026-02-12T08:59:21.721902Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1590-2
  a curric:KeyLearningPoint ;
  rdfs:label "Poe uses a semantic field to chart the decline of power and beauty."@en ;
  dcterms:modified "2026-02-12T08:59:21.721906Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1590-3
  a curric:KeyLearningPoint ;
  rdfs:label "Poe uses similes to depict the destruction of the palace."@en ;
  dcterms:modified "2026-02-12T08:59:21.721910Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1942-1
  a curric:KeyLearningPoint ;
  rdfs:label "An article opening begins a newspaper article"@en ;
  dcterms:modified "2026-02-12T08:59:21.721917Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1942-2
  a curric:KeyLearningPoint ;
  rdfs:label "The opening must contain main information about the event"@en ;
  dcterms:modified "2026-02-12T08:59:21.721922Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1942-3
  a curric:KeyLearningPoint ;
  rdfs:label """The main information about an event covers the who, what, where, when and why of the event"""@en ;
  dcterms:modified "2026-02-12T08:59:21.721927Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1942-4
  a curric:KeyLearningPoint ;
  rdfs:label """You should be as precise as possible when reporting on the who, what, where, when and why of an event"""@en ;
  dcterms:modified "2026-02-12T08:59:21.721931Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-872-1
  a curric:KeyLearningPoint ;
  rdfs:label """Pathetic fallacy is a literary technique in which emotions are ascribed to non-human objects and things."""@en ;
  dcterms:modified "2026-02-12T08:59:21.721935Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-872-2
  a curric:KeyLearningPoint ;
  rdfs:label "Pathetic fallacy helps to show the mood of a piece of writing."@en ;
  dcterms:modified "2026-02-12T08:59:21.721940Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-872-3
  a curric:KeyLearningPoint ;
  rdfs:label """Pathetic fallacy helps the reader visualise the scene and reflects the character’s emotion."""@en ;
  dcterms:modified "2026-02-12T08:59:21.721946Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-876-1
  a curric:KeyLearningPoint ;
  rdfs:label """Language analysis means exploring how writers convey meaning through their language choices."""@en ;
  dcterms:modified "2026-02-12T08:59:21.721951Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-876-2
  a curric:KeyLearningPoint ;
  rdfs:label "Connotations mean the ideas or feelings that a word gives us."@en ;
  dcterms:modified "2026-02-12T08:59:21.721956Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-876-3
  a curric:KeyLearningPoint ;
  rdfs:label "Connotations will vary depending on our individual experiences or memories."@en ;
  dcterms:modified "2026-02-12T08:59:21.721960Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-876-4
  a curric:KeyLearningPoint ;
  rdfs:label """Explanations need to clearly show the reader how you have reached your conclusions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.721964Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1856-1
  a curric:KeyLearningPoint ;
  rdfs:label """Elizabethans believed that everyone had their place in society, a hierarchy they called The Great Chain of Being."""@en ;
  dcterms:modified "2026-02-12T08:59:21.722246Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1856-2
  a curric:KeyLearningPoint ;
  rdfs:label "To question or disrupt this hierarchy was a threat to society."@en ;
  dcterms:modified "2026-02-12T08:59:21.722251Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1856-3
  a curric:KeyLearningPoint ;
  rdfs:label """The theatre was a place you could explore disorder because what was on stage wasn’t real life."""@en ;
  dcterms:modified "2026-02-12T08:59:21.722255Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1856-4
  a curric:KeyLearningPoint ;
  rdfs:label """It was even safer to explore disorder in a setting that wasn’t associated with law and order, a setting like a forest."""@en ;
  dcterms:modified "2026-02-12T08:59:21.722260Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1856-5
  a curric:KeyLearningPoint ;
  rdfs:label """Whilst much disorder takes place in ‘A Midsummer Night’s Dream’, order is restored at the end of the play."""@en ;
  dcterms:modified "2026-02-12T08:59:21.722264Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1798-1
  a curric:KeyLearningPoint ;
  rdfs:label """Epithets are used to establish how characters are perceived by one another and society."""@en ;
  dcterms:modified "2026-02-12T08:59:21.722269Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1798-2
  a curric:KeyLearningPoint ;
  rdfs:label """Othello is established as calm, powerful and eloquent, which makes his later disturbance all the more shocking."""@en ;
  dcterms:modified "2026-02-12T08:59:21.722275Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1798-3
  a curric:KeyLearningPoint ;
  rdfs:label """Visually, Othello is an outsider but morally he embodies all that would be seen as respectable, chivalrous and moral."""@en ;
  dcterms:modified "2026-02-12T08:59:21.722280Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1798-4
  a curric:KeyLearningPoint ;
  rdfs:label """Othello's honourable speech contrasts the way in which Iago presented him as boastful."""@en ;
  dcterms:modified "2026-02-12T08:59:21.722284Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-860-1
  a curric:KeyLearningPoint ;
  rdfs:label """Descriptive writing is designed create a clear atmosphere for the reader and paint a picture of an image."""@en ;
  dcterms:modified "2026-02-12T08:59:21.722424Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-860-2
  a curric:KeyLearningPoint ;
  rdfs:label "Semantic fields can be used to create that picture for the reader."@en ;
  dcterms:modified "2026-02-12T08:59:21.722428Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-860-3
  a curric:KeyLearningPoint ;
  rdfs:label "A semantic field is a group of words or expressions that are related in meaning."@en ;
  dcterms:modified "2026-02-12T08:59:21.722433Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-860-4
  a curric:KeyLearningPoint ;
  rdfs:label """Choose your adjectives carefully in a descriptive paragraph in order to create a semantic field."""@en ;
  dcterms:modified "2026-02-12T08:59:21.722438Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1594-1
  a curric:KeyLearningPoint ;
  rdfs:label "The Anglo-Saxons inhabited Great Britain from the 5th Century."@en ;
  dcterms:modified "2026-02-12T08:59:21.722903Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1594-2
  a curric:KeyLearningPoint ;
  rdfs:label """The Anglo-Saxons included people from Germanic tribes, who migrated from mainland Europe."""@en ;
  dcterms:modified "2026-02-12T08:59:21.722907Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1594-3
  a curric:KeyLearningPoint ;
  rdfs:label "The Anglo-Saxons were very important in the development of Old English."@en ;
  dcterms:modified "2026-02-12T08:59:21.722912Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1594-4
  a curric:KeyLearningPoint ;
  rdfs:label """Whilst a lot of words have changed over the years, modern words linked to the church are similar to Old English."""@en ;
  dcterms:modified "2026-02-12T08:59:21.722916Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1594-5
  a curric:KeyLearningPoint ;
  rdfs:label """A noun appositive is a phrase that gives a piece of extra information about a noun."""@en ;
  dcterms:modified "2026-02-12T08:59:21.722920Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1709-1
  a curric:KeyLearningPoint ;
  rdfs:label """Rules and laws are put in place to try and ensure that society remains civilised and peaceful."""@en ;
  dcterms:modified "2026-02-12T08:59:21.722925Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1709-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Lord of the Flies' was written and published shortly after WWII."@en ;
  dcterms:modified "2026-02-12T08:59:21.722929Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1709-3
  a curric:KeyLearningPoint ;
  rdfs:label "The novel is set against the backdrop of WWII."@en ;
  dcterms:modified "2026-02-12T08:59:21.722936Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1709-4
  a curric:KeyLearningPoint ;
  rdfs:label "The novel explores human beings' capacity for persecution and brutality."@en ;
  dcterms:modified "2026-02-12T08:59:21.722941Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1709-5
  a curric:KeyLearningPoint ;
  rdfs:label "Golding himself experienced the brutality and savagery of humans, whilst at war."@en ;
  dcterms:modified "2026-02-12T08:59:21.722946Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1722-1
  a curric:KeyLearningPoint ;
  rdfs:label "As elected leader, Ralph represents an early desire for law, order and civility."@en ;
  dcterms:modified "2026-02-12T08:59:21.722950Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1722-2
  a curric:KeyLearningPoint ;
  rdfs:label """Golding uses colour symbolism to characterise Ralph as possessing the qualities of an effective and charismatic leader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.722955Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1722-3
  a curric:KeyLearningPoint ;
  rdfs:label """Ralph's participation in the murder of Simon illustrates human beings' capacity for savagery and brutality."""@en ;
  dcterms:modified "2026-02-12T08:59:21.722959Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1722-4
  a curric:KeyLearningPoint ;
  rdfs:label """Ralph's naivety fades away as he begins to recognise the savagery that exists in supposedly-civilised people."""@en ;
  dcterms:modified "2026-02-12T08:59:21.722964Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1722-5
  a curric:KeyLearningPoint ;
  rdfs:label """Ralph's faith in democracy is arguably his greatest strength and his greatest weakness."""@en ;
  dcterms:modified "2026-02-12T08:59:21.722968Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1843-1
  a curric:KeyLearningPoint ;
  rdfs:label """The 5 part narrative structure divides a story into exposition, rising action, climax, falling action and resolution."""@en ;
  dcterms:modified "2026-02-12T08:59:21.722972Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1843-2
  a curric:KeyLearningPoint ;
  rdfs:label """Each section of the narrative does not have to have the same number of paragraphs."""@en ;
  dcterms:modified "2026-02-12T08:59:21.722977Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1843-3
  a curric:KeyLearningPoint ;
  rdfs:label "You can engage your reader by using interesting methods in each paragraph."@en ;
  dcterms:modified "2026-02-12T08:59:21.722981Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1843-4
  a curric:KeyLearningPoint ;
  rdfs:label """To structure your piece, you could link the concluding sentence of paragraphs to the next topic sentence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.722986Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1843-5
  a curric:KeyLearningPoint ;
  rdfs:label """To further structure your piece, your first and final paragraph could repeat selected ideas or images."""@en ;
  dcterms:modified "2026-02-12T08:59:21.722990Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1816-1
  a curric:KeyLearningPoint ;
  rdfs:label """Shakespeare argues that jealousy doesn't occur in isolation but is a product of the flaws of society."""@en ;
  dcterms:modified "2026-02-12T08:59:21.722995Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1816-2
  a curric:KeyLearningPoint ;
  rdfs:label "Male dominance and pride permeates most of the jealousy in the play."@en ;
  dcterms:modified "2026-02-12T08:59:21.722999Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1816-3
  a curric:KeyLearningPoint ;
  rdfs:label "You could argue that Othello’s downfall is not caused by jealousy alone."@en ;
  dcterms:modified "2026-02-12T08:59:21.723004Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1924-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Search for My Tongue' shows the importance of language in shaping our identity."@en ;
  dcterms:modified "2026-02-12T08:59:21.723008Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1924-2
  a curric:KeyLearningPoint ;
  rdfs:label """Initially, Bhatt fears she has lost her mother tongue, Gujarati, after immigrating to America."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723012Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1924-3
  a curric:KeyLearningPoint ;
  rdfs:label "Bhatt then finds her mother tongue again, writing the second stanza in Gujarati."@en ;
  dcterms:modified "2026-02-12T08:59:21.723021Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1924-4
  a curric:KeyLearningPoint ;
  rdfs:label """Bhatt ends the poem showing great pride in her ability to still speak her mother tongue."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723026Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1924-5
  a curric:KeyLearningPoint ;
  rdfs:label """Bhatt uses plant imagery in the poem to reflect the power of one's native language."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723030Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1939-1
  a curric:KeyLearningPoint ;
  rdfs:label "It is likely that Julia Stoner’s death has a sinister explanation to it"@en ;
  dcterms:modified "2026-02-12T08:59:21.723035Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1939-2
  a curric:KeyLearningPoint ;
  rdfs:label """Doctor Roylott is a suspect in the death of Julia Stoner as he has a clear motive"""@en ;
  dcterms:modified "2026-02-12T08:59:21.723039Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1939-3
  a curric:KeyLearningPoint ;
  rdfs:label "There are several pieces of evidence to consider in the case"@en ;
  dcterms:modified "2026-02-12T08:59:21.723044Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1939-4
  a curric:KeyLearningPoint ;
  rdfs:label """Holmes must weigh up the evidence to make a plausible explanation about what happened to Julia Stoner"""@en ;
  dcterms:modified "2026-02-12T08:59:21.723048Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1885-1
  a curric:KeyLearningPoint ;
  rdfs:label """Presenting the experiences of women, particularly Black women, was very important to Angelou."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723056Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1885-2
  a curric:KeyLearningPoint ;
  rdfs:label """Many of Angelou's poems explore sexist attitudes, whilst also observing women's resilience despite this discrimination."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723061Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1885-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Woman Work' sees a Black woman explain how she has to complete hard, manual labour for no reward."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723066Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1885-4
  a curric:KeyLearningPoint ;
  rdfs:label """When exploring a poem’s structure, a good place to start can be to compare its beginning to its end."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723070Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1885-5
  a curric:KeyLearningPoint ;
  rdfs:label """In this way, you can consider any shifts in tone from the beginning to the end of the poem."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723074Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1954-1
  a curric:KeyLearningPoint ;
  rdfs:label "Julia Stoner and Charles McCarthy are presented as very different victims."@en ;
  dcterms:modified "2026-02-12T08:59:21.723439Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1954-2
  a curric:KeyLearningPoint ;
  rdfs:label "Stoner is presented more sympathetically than McCarthy."@en ;
  dcterms:modified "2026-02-12T08:59:21.723443Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1954-3
  a curric:KeyLearningPoint ;
  rdfs:label "Contrasting connectives are important for comparative responses."@en ;
  dcterms:modified "2026-02-12T08:59:21.723450Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1954-4
  a curric:KeyLearningPoint ;
  rdfs:label "Comparisons should always be justified by quotes and analysis."@en ;
  dcterms:modified "2026-02-12T08:59:21.723455Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1954-5
  a curric:KeyLearningPoint ;
  rdfs:label "You should include a summary at the end of a comparative response."@en ;
  dcterms:modified "2026-02-12T08:59:21.723459Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-885-1
  a curric:KeyLearningPoint ;
  rdfs:label """Good topic sentence: At the [place in text], [author name] shows us [link back to intention] through the use of [X/Y]."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723464Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-885-2
  a curric:KeyLearningPoint ;
  rdfs:label """Every analytical paragraph should include at least 2 quotations to support your topic sentence idea."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723468Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-885-3
  a curric:KeyLearningPoint ;
  rdfs:label """Be selective when choosing quotations – select the best to support your topic sentence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723475Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27919-1
  a curric:KeyLearningPoint ;
  rdfs:label """Dialogue should be punctuated and laid out clearly and accurately to make it clear who is speaking."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723662Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27919-2
  a curric:KeyLearningPoint ;
  rdfs:label "The reporting clause is helpful when crafting character."@en ;
  dcterms:modified "2026-02-12T08:59:21.723668Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27919-3
  a curric:KeyLearningPoint ;
  rdfs:label """Strong verbs and adverbs are crucial for creating engaging dialogue that conveys characters' emotions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723673Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27919-4
  a curric:KeyLearningPoint ;
  rdfs:label "It’s important to include description when writing dialogue."@en ;
  dcterms:modified "2026-02-12T08:59:21.723678Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27919-5
  a curric:KeyLearningPoint ;
  rdfs:label """The tone conveyed when crafting dialogue tells the reader a lot about the characters involved."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723682Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1861-1
  a curric:KeyLearningPoint ;
  rdfs:label """Oberon and Puck have different reactions to the disorder amongst the Athenian nobles."""@en ;
  dcterms:modified "2026-02-12T08:59:21.724554Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1861-2
  a curric:KeyLearningPoint ;
  rdfs:label "Oberon tries to restore order immediately."@en ;
  dcterms:modified "2026-02-12T08:59:21.724579Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1861-3
  a curric:KeyLearningPoint ;
  rdfs:label "Oberon blames Puck for the chaos."@en ;
  dcterms:modified "2026-02-12T08:59:21.724584Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1861-4
  a curric:KeyLearningPoint ;
  rdfs:label "Puck enjoys the disorder, calling it “sport”."@en ;
  dcterms:modified "2026-02-12T08:59:21.724589Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1861-5
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, Shakespeare presents Puck as a remorseless character who has contempt for the humans in the forest."""@en ;
  dcterms:modified "2026-02-12T08:59:21.724593Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1848-1
  a curric:KeyLearningPoint ;
  rdfs:label "Athens is a patriarchal society."@en ;
  dcterms:modified "2026-02-12T08:59:21.724598Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1848-2
  a curric:KeyLearningPoint ;
  rdfs:label "Egeus has the right to kill his daughter."@en ;
  dcterms:modified "2026-02-12T08:59:21.724602Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1848-3
  a curric:KeyLearningPoint ;
  rdfs:label "Act 1 and Act 2 both begin with a conflict."@en ;
  dcterms:modified "2026-02-12T08:59:21.724609Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1848-4
  a curric:KeyLearningPoint ;
  rdfs:label "It could be argued that Titania is presented as Oberon's equal."@en ;
  dcterms:modified "2026-02-12T08:59:21.724614Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1848-5
  a curric:KeyLearningPoint ;
  rdfs:label """Oberon has to use a magical love potion on Titania in order to get what he wants."""@en ;
  dcterms:modified "2026-02-12T08:59:21.724621Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1500-1
  a curric:KeyLearningPoint ;
  rdfs:label """War literature can be impactful because it has the power to tell individual stories."""@en ;
  dcterms:modified "2026-02-12T08:59:21.724626Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1500-2
  a curric:KeyLearningPoint ;
  rdfs:label """War literature can be impactful because it tries to explain the experiences of war to those who have not experienced it."""@en ;
  dcterms:modified "2026-02-12T08:59:21.724630Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1500-3
  a curric:KeyLearningPoint ;
  rdfs:label """War literature can be used to expose the reality of war and serve as a warning to future generations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.724634Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1500-4
  a curric:KeyLearningPoint ;
  rdfs:label "Arguably, war literature helps humans empathise with the pain of others."@en ;
  dcterms:modified "2026-02-12T08:59:21.724639Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1999-1
  a curric:KeyLearningPoint ;
  rdfs:label "Descriptions should include minimal action."@en ;
  dcterms:modified "2026-02-12T08:59:21.724643Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1999-2
  a curric:KeyLearningPoint ;
  rdfs:label """An effective way to include character is with one small character action, for example, looking through a window."""@en ;
  dcterms:modified "2026-02-12T08:59:21.724648Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1999-3
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to decide your tone before you start writing, so that it remains consistent."""@en ;
  dcterms:modified "2026-02-12T08:59:21.724652Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1999-4
  a curric:KeyLearningPoint ;
  rdfs:label """When planning a single paragraph, you should choose three-four details to focus on."""@en ;
  dcterms:modified "2026-02-12T08:59:21.724657Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1999-5
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to plan interesting vocabulary that matches your tone before you start writing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.724661Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1715-1
  a curric:KeyLearningPoint ;
  rdfs:label """Military airplanes fight above the island and a dead parachutist drifts down onto the island."""@en ;
  dcterms:modified "2026-02-12T08:59:21.724665Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1715-2
  a curric:KeyLearningPoint ;
  rdfs:label "The twins, Sam and Eric, wake and believe that the parachutist is the beast."@en ;
  dcterms:modified "2026-02-12T08:59:21.724670Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1715-3
  a curric:KeyLearningPoint ;
  rdfs:label "The boys set out to hunt for the beast, with Jack in charge of the expedition."@en ;
  dcterms:modified "2026-02-12T08:59:21.724674Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1715-4
  a curric:KeyLearningPoint ;
  rdfs:label "Simon does not believe in the existence of the beast."@en ;
  dcterms:modified "2026-02-12T08:59:21.724678Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1715-5
  a curric:KeyLearningPoint ;
  rdfs:label """The use of dramatic irony creates a distance between reader and characters so we feel sorry for them."""@en ;
  dcterms:modified "2026-02-12T08:59:21.724683Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1800-1
  a curric:KeyLearningPoint ;
  rdfs:label "Shakespeare often uses different locations to represent mindsets."@en ;
  dcterms:modified "2026-02-12T08:59:21.725378Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1800-2
  a curric:KeyLearningPoint ;
  rdfs:label """In 'Othello', Venice represents civilisation whilst Cyprus symbolises the wilderness."""@en ;
  dcterms:modified "2026-02-12T08:59:21.725382Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1800-3
  a curric:KeyLearningPoint ;
  rdfs:label """The storm is a recurring symbol in Shakespeare's plays, reflecting a disruption of order."""@en ;
  dcterms:modified "2026-02-12T08:59:21.725386Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1800-4
  a curric:KeyLearningPoint ;
  rdfs:label """The description of the storm dividing Othello and Cassio foreshadows Othello’s demise."""@en ;
  dcterms:modified "2026-02-12T08:59:21.725391Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1952-1
  a curric:KeyLearningPoint ;
  rdfs:label "Holmes and Watson have set out to solve the Boscombe Valley mystery."@en ;
  dcterms:modified "2026-02-12T08:59:21.725395Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1952-2
  a curric:KeyLearningPoint ;
  rdfs:label "It is believed Charles McCarthy was murdered."@en ;
  dcterms:modified "2026-02-12T08:59:21.725400Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1952-3
  a curric:KeyLearningPoint ;
  rdfs:label "McCarthy was seen arguing with his son prior to his death."@en ;
  dcterms:modified "2026-02-12T08:59:21.725404Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1952-4
  a curric:KeyLearningPoint ;
  rdfs:label "McCarthy’s son’s gun was found near McCarthy’s dead body."@en ;
  dcterms:modified "2026-02-12T08:59:21.725409Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1952-5
  a curric:KeyLearningPoint ;
  rdfs:label "McCarthy’s son is the main suspect in McCarthy’s death."@en ;
  dcterms:modified "2026-02-12T08:59:21.725413Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1599-1
  a curric:KeyLearningPoint ;
  rdfs:label """Rhetorical questions, anecdotes and direct address are a great way to ‘hook’ your audience at the start of a speech."""@en ;
  dcterms:modified "2026-02-12T08:59:21.726227Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1599-2
  a curric:KeyLearningPoint ;
  rdfs:label """The content of a speech needs to be sufficiently developed for the argument to be convincing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.726231Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1599-3
  a curric:KeyLearningPoint ;
  rdfs:label """Language devices should be creative, original and matched to the purpose and audience of a speech."""@en ;
  dcterms:modified "2026-02-12T08:59:21.726235Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1862-1
  a curric:KeyLearningPoint ;
  rdfs:label """In Act 3, Scene 1, we see Puck’s ability to create disorder amongst the Rude Mechanicals."""@en ;
  dcterms:modified "2026-02-12T08:59:21.726242Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1862-2
  a curric:KeyLearningPoint ;
  rdfs:label """In Act 3, Scene 2, we see Puck use the same abilities to restore order amongst the Athenian nobles."""@en ;
  dcterms:modified "2026-02-12T08:59:21.726247Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1862-3
  a curric:KeyLearningPoint ;
  rdfs:label "Puck applies the antidote to Lysander, but not Demetrius."@en ;
  dcterms:modified "2026-02-12T08:59:21.726251Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1862-4
  a curric:KeyLearningPoint ;
  rdfs:label "Oberon asks for, and gets, the little boy he wants from Titania."@en ;
  dcterms:modified "2026-02-12T08:59:21.726255Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1862-5
  a curric:KeyLearningPoint ;
  rdfs:label """The resolution to the play is happy, but audiences might question the treatment of Titania and Demetrius."""@en ;
  dcterms:modified "2026-02-12T08:59:21.726260Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2000-1
  a curric:KeyLearningPoint ;
  rdfs:label """An effective description should include a variety of sentence types, including simple, compound and complex"""@en ;
  dcterms:modified "2026-02-12T08:59:21.726264Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2000-2
  a curric:KeyLearningPoint ;
  rdfs:label """An effective description should include a variety of sentence forms, such as declarative, interrogative and exclamatory"""@en ;
  dcterms:modified "2026-02-12T08:59:21.726269Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2000-3
  a curric:KeyLearningPoint ;
  rdfs:label """Checking and editing your work includes checking all of your spellings and that your basic punctuation is accurate"""@en ;
  dcterms:modified "2026-02-12T08:59:21.726273Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2000-4
  a curric:KeyLearningPoint ;
  rdfs:label """Enhancing your work includes adding sophisticated punctuation and changing your sentence types"""@en ;
  dcterms:modified "2026-02-12T08:59:21.726278Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2000-5
  a curric:KeyLearningPoint ;
  rdfs:label """At least ten minutes should be spent after finishing writing, to firstly edit then enhance your work"""@en ;
  dcterms:modified "2026-02-12T08:59:21.726282Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1834-1
  a curric:KeyLearningPoint ;
  rdfs:label """'The Canterbury Tales' is a poem written in Middle English by Geoffrey Chaucer in the late 14th century."""@en ;
  dcterms:modified "2026-02-12T08:59:21.726287Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1834-2
  a curric:KeyLearningPoint ;
  rdfs:label """Chaucer creates a group of characters who are going on pilgrimage, and they tell each other stories on the way."""@en ;
  dcterms:modified "2026-02-12T08:59:21.726291Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1834-3
  a curric:KeyLearningPoint ;
  rdfs:label """In the first section of the poem, Chaucer creates compelling descriptions of each pilgrim."""@en ;
  dcterms:modified "2026-02-12T08:59:21.726295Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1834-4
  a curric:KeyLearningPoint ;
  rdfs:label """Creating a compelling character could include describing their role in society, as well as how they look, speak and act."""@en ;
  dcterms:modified "2026-02-12T08:59:21.726302Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1503-1
  a curric:KeyLearningPoint ;
  rdfs:label "The gas attack, and its aftermath, is the central focus of Beck’s short story."@en ;
  dcterms:modified "2026-02-12T08:59:21.726574Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1503-2
  a curric:KeyLearningPoint ;
  rdfs:label "The effects of the gas attack are described in graphic detail."@en ;
  dcterms:modified "2026-02-12T08:59:21.726580Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1503-3
  a curric:KeyLearningPoint ;
  rdfs:label """Perceptive analysis can involve making thoughtful connections between different moments in a text."""@en ;
  dcterms:modified "2026-02-12T08:59:21.726585Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1802-1
  a curric:KeyLearningPoint ;
  rdfs:label """Using two slightly different adjectives in a topic sentence can add depth and debate to a paragraph."""@en ;
  dcterms:modified "2026-02-12T08:59:21.726590Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1802-2
  a curric:KeyLearningPoint ;
  rdfs:label """Comment on patterns of language, such as diabolical or bestial imagery is useful when analysing Iago."""@en ;
  dcterms:modified "2026-02-12T08:59:21.726596Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1802-3
  a curric:KeyLearningPoint ;
  rdfs:label "Iago can be seen as satanic and Machiavellian."@en ;
  dcterms:modified "2026-02-12T08:59:21.726601Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1802-4
  a curric:KeyLearningPoint ;
  rdfs:label """Concluding sentences can draw ideas together and can help you comment on Iago's role in the overall tragedy."""@en ;
  dcterms:modified "2026-02-12T08:59:21.726605Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1883-1
  a curric:KeyLearningPoint ;
  rdfs:label """Figurative language sees writers use non-literal words and phrases to develop complex ideas about something, or someone."""@en ;
  dcterms:modified "2026-02-12T08:59:21.726977Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1883-2
  a curric:KeyLearningPoint ;
  rdfs:label """Maya Angelou uses figurative language in ‘Equality’ to develop complex ideas about the speaker and society."""@en ;
  dcterms:modified "2026-02-12T08:59:21.726984Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1883-3
  a curric:KeyLearningPoint ;
  rdfs:label "Angelou uses figurative language in many of her poems."@en ;
  dcterms:modified "2026-02-12T08:59:21.726989Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1883-4
  a curric:KeyLearningPoint ;
  rdfs:label "When comparing poems, using words like 'more' or 'less' can be helpful."@en ;
  dcterms:modified "2026-02-12T08:59:21.726995Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-882-1
  a curric:KeyLearningPoint ;
  rdfs:label "Using two adjectives in front of a noun creates a detailed description."@en ;
  dcterms:modified "2026-02-12T08:59:21.727000Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-882-2
  a curric:KeyLearningPoint ;
  rdfs:label """Prepositions indicate relationships between words in a sentence and may help us better understand and visualise a scene."""@en ;
  dcterms:modified "2026-02-12T08:59:21.727004Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-882-3
  a curric:KeyLearningPoint ;
  rdfs:label """Embedded clauses add extra information and detail to a scene that help us better understand and visualise it."""@en ;
  dcterms:modified "2026-02-12T08:59:21.727009Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-882-4
  a curric:KeyLearningPoint ;
  rdfs:label """Using three adjectives at the end of a sentence creates a multi-layered description."""@en ;
  dcterms:modified "2026-02-12T08:59:21.727013Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1809-1
  a curric:KeyLearningPoint ;
  rdfs:label "Introductions could follow the three-part structure."@en ;
  dcterms:modified "2026-02-12T08:59:21.727068Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1809-2
  a curric:KeyLearningPoint ;
  rdfs:label """The thesis statement should address the writer's purpose or message, in relation to the question focus."""@en ;
  dcterms:modified "2026-02-12T08:59:21.727073Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1809-3
  a curric:KeyLearningPoint ;
  rdfs:label """Topic sentences should contain evaluative adjectives and phrases to show an interpretation - not devices."""@en ;
  dcterms:modified "2026-02-12T08:59:21.727077Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1809-4
  a curric:KeyLearningPoint ;
  rdfs:label "Topic sentences should develop in a sequence to maintain focus on the argument."@en ;
  dcterms:modified "2026-02-12T08:59:21.727081Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1869-1
  a curric:KeyLearningPoint ;
  rdfs:label "A thesis is an idea that you develop and maintain throughout an essay."@en ;
  dcterms:modified "2026-02-12T08:59:21.727086Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1869-2
  a curric:KeyLearningPoint ;
  rdfs:label "A thesis should consider the writer and their intentions."@en ;
  dcterms:modified "2026-02-12T08:59:21.727090Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1869-3
  a curric:KeyLearningPoint ;
  rdfs:label "Topic sentences should develop and maintain your thesis."@en ;
  dcterms:modified "2026-02-12T08:59:21.727094Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1541-1
  a curric:KeyLearningPoint ;
  rdfs:label "A motif is a recurring image or ideas."@en ;
  dcterms:modified "2026-02-12T08:59:21.727164Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1541-2
  a curric:KeyLearningPoint ;
  rdfs:label "Writers use motifs to build up imaginative layers of meaning."@en ;
  dcterms:modified "2026-02-12T08:59:21.727169Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1541-3
  a curric:KeyLearningPoint ;
  rdfs:label "Shakespeare uses a motif of light to show Romeo’s impression of Juliet."@en ;
  dcterms:modified "2026-02-12T08:59:21.727174Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1541-4
  a curric:KeyLearningPoint ;
  rdfs:label "Motifs need to be dynamic, using a range of techniques."@en ;
  dcterms:modified "2026-02-12T08:59:21.727178Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1541-5
  a curric:KeyLearningPoint ;
  rdfs:label "You can use metaphors, personification and comparison when creating a motif."@en ;
  dcterms:modified "2026-02-12T08:59:21.727184Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27922-1
  a curric:KeyLearningPoint ;
  rdfs:label "Single paragraph outlines are a useful tool for planning writing."@en ;
  dcterms:modified "2026-02-12T08:59:21.727191Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27922-2
  a curric:KeyLearningPoint ;
  rdfs:label "When you plan writing, you should plan the vocabulary that you will use."@en ;
  dcterms:modified "2026-02-12T08:59:21.727196Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27922-3
  a curric:KeyLearningPoint ;
  rdfs:label "Using figurative and sensory language creates vivid description."@en ;
  dcterms:modified "2026-02-12T08:59:21.727202Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27922-4
  a curric:KeyLearningPoint ;
  rdfs:label """A success criteria can act as an excellent guide to what you could include in your writing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.727207Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1993-1
  a curric:KeyLearningPoint ;
  rdfs:label "Similes are a useful technique for creating atmosphere"@en ;
  dcterms:modified "2026-02-12T08:59:21.727212Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1993-2
  a curric:KeyLearningPoint ;
  rdfs:label """Excellent similes will uses carefully selected adjectives and noun phrases so comparisons are suitable"""@en ;
  dcterms:modified "2026-02-12T08:59:21.727216Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1993-3
  a curric:KeyLearningPoint ;
  rdfs:label "Subordinate clauses can be used to add vivid detail to your similes"@en ;
  dcterms:modified "2026-02-12T08:59:21.727220Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1993-4
  a curric:KeyLearningPoint ;
  rdfs:label """When analysing a writer’s use of similes, zoom in on individual word choices and explain how they create atmosphere"""@en ;
  dcterms:modified "2026-02-12T08:59:21.727225Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1994-1
  a curric:KeyLearningPoint ;
  rdfs:label "Declarative sentences convey facts, explanations or information"@en ;
  dcterms:modified "2026-02-12T08:59:21.727230Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1994-2
  a curric:KeyLearningPoint ;
  rdfs:label "Exclamatory sentences express strong feelings in the form of an exclamation"@en ;
  dcterms:modified "2026-02-12T08:59:21.727234Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1994-3
  a curric:KeyLearningPoint ;
  rdfs:label "An interrogative sentence is a sentence that asks a question"@en ;
  dcterms:modified "2026-02-12T08:59:21.727238Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1994-4
  a curric:KeyLearningPoint ;
  rdfs:label """All three sentence forms should be used to create an interesting and varied description"""@en ;
  dcterms:modified "2026-02-12T08:59:21.727243Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1994-5
  a curric:KeyLearningPoint ;
  rdfs:label """Exclamatory sentences are more likely to be simple; declarative sentences are more likely to be compound or complex"""@en ;
  dcterms:modified "2026-02-12T08:59:21.727247Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1529-1
  a curric:KeyLearningPoint ;
  rdfs:label "The language shows the hollowness of victory."@en ;
  dcterms:modified "2026-02-12T08:59:21.727252Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1529-2
  a curric:KeyLearningPoint ;
  rdfs:label "The use of similes shows the value of the soldiers."@en ;
  dcterms:modified "2026-02-12T08:59:21.727256Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1529-3
  a curric:KeyLearningPoint ;
  rdfs:label "Structure emphasises the inevitability of the soldiers' deaths."@en ;
  dcterms:modified "2026-02-12T08:59:21.727260Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1573-1
  a curric:KeyLearningPoint ;
  rdfs:label """Figurative language is words or phrases that are meaningful, but not literally true."""@en ;
  dcterms:modified "2026-02-12T08:59:21.727265Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1573-2
  a curric:KeyLearningPoint ;
  rdfs:label "Figurative language can be used to create vivid imagery."@en ;
  dcterms:modified "2026-02-12T08:59:21.727269Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1573-3
  a curric:KeyLearningPoint ;
  rdfs:label """When choosing an object for comparison, you need to consider the atmosphere you are trying to create."""@en ;
  dcterms:modified "2026-02-12T08:59:21.727274Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1573-4
  a curric:KeyLearningPoint ;
  rdfs:label """For Gothic descriptions, try to compare your setting to an object of fear or disgust so that you can unsettle the reader"""@en ;
  dcterms:modified "2026-02-12T08:59:21.727279Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1573-5
  a curric:KeyLearningPoint ;
  rdfs:label """Always choose vocabulary that contributes to the atmosphere you are trying to create."""@en ;
  dcterms:modified "2026-02-12T08:59:21.727285Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1847-1
  a curric:KeyLearningPoint ;
  rdfs:label """The First Folio divides Shakespeare’s plays into tragedies, histories and comedies."""@en ;
  dcterms:modified "2026-02-12T08:59:21.728327Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1847-2
  a curric:KeyLearningPoint ;
  rdfs:label """An additional genre - tragicomedies - has been used to describe plays which combine both tragic and comic elements."""@en ;
  dcterms:modified "2026-02-12T08:59:21.728331Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1847-3
  a curric:KeyLearningPoint ;
  rdfs:label "Shakespearean comedies usually focus on love, and end in marriage."@en ;
  dcterms:modified "2026-02-12T08:59:21.728338Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1847-4
  a curric:KeyLearningPoint ;
  rdfs:label """The plots of comedies are often intricate and include a number of surprises and plot twists."""@en ;
  dcterms:modified "2026-02-12T08:59:21.728343Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1847-5
  a curric:KeyLearningPoint ;
  rdfs:label "Shakespearean comedies often include slapstick humour."@en ;
  dcterms:modified "2026-02-12T08:59:21.728347Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1719-1
  a curric:KeyLearningPoint ;
  rdfs:label """Ralph, Piggy, Sam and Eric want to deny the role that they played in Simon's murder."""@en ;
  dcterms:modified "2026-02-12T08:59:21.728351Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1719-2
  a curric:KeyLearningPoint ;
  rdfs:label """Jack blames the beast for Simon's death, absolving himself of any responsibility."""@en ;
  dcterms:modified "2026-02-12T08:59:21.728356Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1719-3
  a curric:KeyLearningPoint ;
  rdfs:label "Jack's tribe attack Ralph's as they sleep, stealing Piggy's glasses."@en ;
  dcterms:modified "2026-02-12T08:59:21.728360Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1719-4
  a curric:KeyLearningPoint ;
  rdfs:label """Jack rules his camp through fear and appealing to the violent animalistic side of the boys’ characters."""@en ;
  dcterms:modified "2026-02-12T08:59:21.728365Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1719-5
  a curric:KeyLearningPoint ;
  rdfs:label "At the end of Chapter 10, Jack feels he is the true chief."@en ;
  dcterms:modified "2026-02-12T08:59:21.728369Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1799-1
  a curric:KeyLearningPoint ;
  rdfs:label "Evaluative adjectives should be used in topic sentences, not devices."@en ;
  dcterms:modified "2026-02-12T08:59:21.728375Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1799-2
  a curric:KeyLearningPoint ;
  rdfs:label """A participle phrase can be added to a topic sentence to comment on the writer's purpose or links to context."""@en ;
  dcterms:modified "2026-02-12T08:59:21.728380Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1799-3
  a curric:KeyLearningPoint ;
  rdfs:label "You could outline the moment in the plot, before quoting."@en ;
  dcterms:modified "2026-02-12T08:59:21.728384Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1799-4
  a curric:KeyLearningPoint ;
  rdfs:label "Use multiple linking quotations, exploring language connotations and devices."@en ;
  dcterms:modified "2026-02-12T08:59:21.728389Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1888-1
  a curric:KeyLearningPoint ;
  rdfs:label "We can explore Angelou's poems as a collection, as well as individually."@en ;
  dcterms:modified "2026-02-12T08:59:21.728393Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1888-2
  a curric:KeyLearningPoint ;
  rdfs:label "Exploring Angelou's poems as a collection allows us to understand her as a poet."@en ;
  dcterms:modified "2026-02-12T08:59:21.728397Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1888-3
  a curric:KeyLearningPoint ;
  rdfs:label """We might make comments on similarities between speakers, ideas and methods across poems."""@en ;
  dcterms:modified "2026-02-12T08:59:21.728402Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1888-4
  a curric:KeyLearningPoint ;
  rdfs:label """We can use these comments to consider Angelou's poetic voice as a whole, and suggest the dominant tone across her work."""@en ;
  dcterms:modified "2026-02-12T08:59:21.728406Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1979-1
  a curric:KeyLearningPoint ;
  rdfs:label "A newspaper article should be written in the third person."@en ;
  dcterms:modified "2026-02-12T08:59:21.728411Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1979-2
  a curric:KeyLearningPoint ;
  rdfs:label "A newspaper article should have a formal tone without using slang."@en ;
  dcterms:modified "2026-02-12T08:59:21.728415Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1979-3
  a curric:KeyLearningPoint ;
  rdfs:label "You can use language devices in a newspaper article to intrigue the reader."@en ;
  dcterms:modified "2026-02-12T08:59:21.728421Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1979-4
  a curric:KeyLearningPoint ;
  rdfs:label """You need to punctuate quotes correctly using speech marks in a newspaper article."""@en ;
  dcterms:modified "2026-02-12T08:59:21.728430Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1979-5
  a curric:KeyLearningPoint ;
  rdfs:label """You can use a noun appositive in an article to give more information about a noun."""@en ;
  dcterms:modified "2026-02-12T08:59:21.728435Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1801-1
  a curric:KeyLearningPoint ;
  rdfs:label "Iago’s third soliloquy reveals his exploitative machinations."@en ;
  dcterms:modified "2026-02-12T08:59:21.728962Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1801-2
  a curric:KeyLearningPoint ;
  rdfs:label "References to God and Hell develop the diabolical presentation of Iago."@en ;
  dcterms:modified "2026-02-12T08:59:21.728966Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1801-3
  a curric:KeyLearningPoint ;
  rdfs:label """Iago describes poisoning Othello's ear; he knows the effect his manipulation will have."""@en ;
  dcterms:modified "2026-02-12T08:59:21.728971Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1801-4
  a curric:KeyLearningPoint ;
  rdfs:label """Iago takes pleasure in corrupting goodness: he talks of tarnishing Desdemona’s virtue and calls Cassio an "honest fool"."""@en ;
  dcterms:modified "2026-02-12T08:59:21.728975Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1801-5
  a curric:KeyLearningPoint ;
  rdfs:label """Iago uses imagery to show the control he has over the characters and tries to manipulate the audience too."""@en ;
  dcterms:modified "2026-02-12T08:59:21.728980Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1583-1
  a curric:KeyLearningPoint ;
  rdfs:label "The form of a piece is the kind of writing it is."@en ;
  dcterms:modified "2026-02-12T08:59:21.729464Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1583-2
  a curric:KeyLearningPoint ;
  rdfs:label "The form of a piece informs the tone you use."@en ;
  dcterms:modified "2026-02-12T08:59:21.729468Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1583-3
  a curric:KeyLearningPoint ;
  rdfs:label "Opinion writing requires a strong sense of voice and a persuasive tone."@en ;
  dcterms:modified "2026-02-12T08:59:21.729492Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1583-4
  a curric:KeyLearningPoint ;
  rdfs:label "Puns can be used in opinion writing to create wit."@en ;
  dcterms:modified "2026-02-12T08:59:21.729497Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1583-5
  a curric:KeyLearningPoint ;
  rdfs:label "Wit engages the reader, thereby making your piece more persuasive."@en ;
  dcterms:modified "2026-02-12T08:59:21.729501Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1557-1
  a curric:KeyLearningPoint ;
  rdfs:label """The Enlightenment period represents a philosophical shift in thought, whereby reason and rationale were celebrated."""@en ;
  dcterms:modified "2026-02-12T08:59:21.729505Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1557-2
  a curric:KeyLearningPoint ;
  rdfs:label """There was an emphasis on learning the ‘truth’ about things; people thought this would bring them knowledge and freedom."""@en ;
  dcterms:modified "2026-02-12T08:59:21.729510Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1557-3
  a curric:KeyLearningPoint ;
  rdfs:label """The Industrial Revolution occurred in Britain in the 18th century, and then again in the 19th century."""@en ;
  dcterms:modified "2026-02-12T08:59:21.729514Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1557-4
  a curric:KeyLearningPoint ;
  rdfs:label "Galvanisation is the process of using electricity to try to create life."@en ;
  dcterms:modified "2026-02-12T08:59:21.729518Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1557-5
  a curric:KeyLearningPoint ;
  rdfs:label """Scientific advancements were contested by religious people, who dismissed them as heresy."""@en ;
  dcterms:modified "2026-02-12T08:59:21.729523Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1517-1
  a curric:KeyLearningPoint ;
  rdfs:label """The opening of comparative paragraphs could start with a topic sentence which states the paragraph’s main idea."""@en ;
  dcterms:modified "2026-02-12T08:59:21.729576Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1517-2
  a curric:KeyLearningPoint ;
  rdfs:label """The next sentences of a comparative paragraph could focus on the differences between the two texts you wish to compare."""@en ;
  dcterms:modified "2026-02-12T08:59:21.729580Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1517-3
  a curric:KeyLearningPoint ;
  rdfs:label "Including multiple quotations from both texts is key to a comparative paragraph."@en ;
  dcterms:modified "2026-02-12T08:59:21.729585Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1517-4
  a curric:KeyLearningPoint ;
  rdfs:label "Comparing the methods writers have used can help to develop the comparison."@en ;
  dcterms:modified "2026-02-12T08:59:21.729589Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1517-5
  a curric:KeyLearningPoint ;
  rdfs:label "The final sentence of a comparative paragraph should link to the topic sentence."@en ;
  dcterms:modified "2026-02-12T08:59:21.729593Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1859-1
  a curric:KeyLearningPoint ;
  rdfs:label "Arguably, Puck is first presented as an irreverent character."@en ;
  dcterms:modified "2026-02-12T08:59:21.729597Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1859-2
  a curric:KeyLearningPoint ;
  rdfs:label """Shakespeare develops Puck’s character by contrasting his initial presentation to his interactions with Oberon."""@en ;
  dcterms:modified "2026-02-12T08:59:21.729601Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1859-3
  a curric:KeyLearningPoint ;
  rdfs:label "Puck’s language when he speaks to Oberon suggests he respects the hierarchy."@en ;
  dcterms:modified "2026-02-12T08:59:21.729606Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1859-4
  a curric:KeyLearningPoint ;
  rdfs:label """Puck’s language when he first meets the Rude Mechanicals suggests he has contempt for them as low status characters."""@en ;
  dcterms:modified "2026-02-12T08:59:21.729610Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1561-1
  a curric:KeyLearningPoint ;
  rdfs:label "Frankenstein is disgusted and disappointed with his creation."@en ;
  dcterms:modified "2026-02-12T08:59:21.729616Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1561-2
  a curric:KeyLearningPoint ;
  rdfs:label "Frankenstein’s hatred for his creation is based purely on the way he looks."@en ;
  dcterms:modified "2026-02-12T08:59:21.729621Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1561-3
  a curric:KeyLearningPoint ;
  rdfs:label """Frankenstein repeatedly runs away from the Creature, thereby cruelly rejecting him."""@en ;
  dcterms:modified "2026-02-12T08:59:21.729625Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1561-4
  a curric:KeyLearningPoint ;
  rdfs:label "Arguably, Frankenstein’s treatment of the Creature is unethical and immoral."@en ;
  dcterms:modified "2026-02-12T08:59:21.729629Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1561-5
  a curric:KeyLearningPoint ;
  rdfs:label """Frankenstein’s callous treatment of the Creature is a key motivator in the Creature’s subsequent violence in the novel."""@en ;
  dcterms:modified "2026-02-12T08:59:21.729634Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1568-1
  a curric:KeyLearningPoint ;
  rdfs:label "Jane is characterised as a polite, calm and helpful character."@en ;
  dcterms:modified "2026-02-12T08:59:21.729638Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1568-2
  a curric:KeyLearningPoint ;
  rdfs:label "Brontë creates a Gothic setting using classic Gothic conventions."@en ;
  dcterms:modified "2026-02-12T08:59:21.729642Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1568-3
  a curric:KeyLearningPoint ;
  rdfs:label "Brontë’s setting is isolated, lifeless and has a supernatural feel to it."@en ;
  dcterms:modified "2026-02-12T08:59:21.729646Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1568-4
  a curric:KeyLearningPoint ;
  rdfs:label "Brontë uses contrasting colours to make her settings Gothic."@en ;
  dcterms:modified "2026-02-12T08:59:21.729653Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1568-5
  a curric:KeyLearningPoint ;
  rdfs:label "Brontë uses the setting to reflect Jane’s isolation and innocence."@en ;
  dcterms:modified "2026-02-12T08:59:21.729657Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1519-1
  a curric:KeyLearningPoint ;
  rdfs:label "Letters were a vital form of communication during World War One."@en ;
  dcterms:modified "2026-02-12T08:59:21.729661Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1519-2
  a curric:KeyLearningPoint ;
  rdfs:label """Receiving and sending letters brought small moments of joy to those on the front, and those at home."""@en ;
  dcterms:modified "2026-02-12T08:59:21.729667Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1519-3
  a curric:KeyLearningPoint ;
  rdfs:label """Owen is best remembered for his poetry about World War One, but he also sent many letters home."""@en ;
  dcterms:modified "2026-02-12T08:59:21.729674Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1519-4
  a curric:KeyLearningPoint ;
  rdfs:label """Owen’s letters are different in structure, audience and tone from his poems, but still convey the horrors of war."""@en ;
  dcterms:modified "2026-02-12T08:59:21.729678Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1519-5
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, Owen’s letter is structured into three sections: scene-setting, recounting an event, conveying his attitude."""@en ;
  dcterms:modified "2026-02-12T08:59:21.729683Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1826-1
  a curric:KeyLearningPoint ;
  rdfs:label """Symbolism is when writers use something tangible to represent an intangible idea."""@en ;
  dcterms:modified "2026-02-12T08:59:21.729687Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1826-2
  a curric:KeyLearningPoint ;
  rdfs:label """Tennyson’s use of symbols is one way he creates a sombre atmosphere, particularly in Part 4 of ‘The Lady of Shalott’."""@en ;
  dcterms:modified "2026-02-12T08:59:21.729691Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1826-3
  a curric:KeyLearningPoint ;
  rdfs:label """Key symbols in ‘The Lady of Shalott’ include a willow tree to symbolise grief, and a pearl to symbolise perfection."""@en ;
  dcterms:modified "2026-02-12T08:59:21.729695Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1826-4
  a curric:KeyLearningPoint ;
  rdfs:label """Tennyson also relies on pathetic fallacy to create a sombre and dramatic atmosphere in Part 4 of the poem."""@en ;
  dcterms:modified "2026-02-12T08:59:21.729700Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1826-5
  a curric:KeyLearningPoint ;
  rdfs:label """You can employ pathetic fallacy and symbolism in your own writing to create a distinctive atmosphere."""@en ;
  dcterms:modified "2026-02-12T08:59:21.729704Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1893-1
  a curric:KeyLearningPoint ;
  rdfs:label """Poets pay close attention to how their poems sound, as well as what the words express."""@en ;
  dcterms:modified "2026-02-12T08:59:21.729708Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1893-2
  a curric:KeyLearningPoint ;
  rdfs:label """You might like a poem for its harmonious sound before you understand its meanings."""@en ;
  dcterms:modified "2026-02-12T08:59:21.729713Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1893-3
  a curric:KeyLearningPoint ;
  rdfs:label """Angelou created harmonious sounds in her poems, often relying on rhythm, rhyme, repetition and refrain."""@en ;
  dcterms:modified "2026-02-12T08:59:21.729717Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1893-4
  a curric:KeyLearningPoint ;
  rdfs:label """When writing your own poems, reading your work aloud lets you to hear what sounds harmonious, and edit dissonant sounds."""@en ;
  dcterms:modified "2026-02-12T08:59:21.729721Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1971-1
  a curric:KeyLearningPoint ;
  rdfs:label "Summaries are important revision tools for understanding the plot."@en ;
  dcterms:modified "2026-02-12T08:59:21.729725Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1971-2
  a curric:KeyLearningPoint ;
  rdfs:label """A summary should be concise, chronological and only include the most important moments."""@en ;
  dcterms:modified "2026-02-12T08:59:21.729730Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1971-3
  a curric:KeyLearningPoint ;
  rdfs:label "Using time connectives allows you to write a clear, chronological summary."@en ;
  dcterms:modified "2026-02-12T08:59:21.729736Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1971-4
  a curric:KeyLearningPoint ;
  rdfs:label """Using comparative connectives allows you to compare the significance of key moments."""@en ;
  dcterms:modified "2026-02-12T08:59:21.729740Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1510-1
  a curric:KeyLearningPoint ;
  rdfs:label "Comparing one text to another can often help you evaluate it more clearly."@en ;
  dcterms:modified "2026-02-12T08:59:21.729745Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1510-2
  a curric:KeyLearningPoint ;
  rdfs:label """You can compare what each writer chose to write about, and how they chose to write about it."""@en ;
  dcterms:modified "2026-02-12T08:59:21.729749Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1510-3
  a curric:KeyLearningPoint ;
  rdfs:label """The opening line of comparative paragraphs could start with a topic sentence which states the paragraph's main idea."""@en ;
  dcterms:modified "2026-02-12T08:59:21.729753Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1510-4
  a curric:KeyLearningPoint ;
  rdfs:label """The next sentences of a comparative paragraph could focus on the differences between the two texts you wish to compare."""@en ;
  dcterms:modified "2026-02-12T08:59:21.729757Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1713-1
  a curric:KeyLearningPoint ;
  rdfs:label """In Chapter 4, the boys’ behaviour changes as they become less and less respectful of their old values."""@en ;
  dcterms:modified "2026-02-12T08:59:21.729764Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1713-2
  a curric:KeyLearningPoint ;
  rdfs:label "The island’s climate seems hostile towards them."@en ;
  dcterms:modified "2026-02-12T08:59:21.729768Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1713-3
  a curric:KeyLearningPoint ;
  rdfs:label """A ship was seen on the horizon but the hunters/the choir have let the signal fire go out."""@en ;
  dcterms:modified "2026-02-12T08:59:21.729772Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1713-4
  a curric:KeyLearningPoint ;
  rdfs:label "Jack and his hunters kill a pig and the boys feast on the meat."@en ;
  dcterms:modified "2026-02-12T08:59:21.729777Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1713-5
  a curric:KeyLearningPoint ;
  rdfs:label """Ralph is angry that they missed the opportunity of being rescued and says they need to have a meeting."""@en ;
  dcterms:modified "2026-02-12T08:59:21.729781Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1543-1
  a curric:KeyLearningPoint ;
  rdfs:label """Fairy tales have specific conventions including noble heroes/heroines, magical transformations and happy endings."""@en ;
  dcterms:modified "2026-02-12T08:59:21.729905Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1543-2
  a curric:KeyLearningPoint ;
  rdfs:label """Charles Kingsley was a Victorian clergyman who took a stand against the use of children as chimney sweeps."""@en ;
  dcterms:modified "2026-02-12T08:59:21.729910Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1543-3
  a curric:KeyLearningPoint ;
  rdfs:label """Kingsley’s novel ‘The Water Babies’ adapted the fairy tale genre to protest the use of children as chimney sweeps."""@en ;
  dcterms:modified "2026-02-12T08:59:21.729914Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1543-4
  a curric:KeyLearningPoint ;
  rdfs:label "His novel was influential in raising awareness of the cruelty of child labour."@en ;
  dcterms:modified "2026-02-12T08:59:21.729918Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1543-5
  a curric:KeyLearningPoint ;
  rdfs:label "Freytag’s narrative structure can be adapted by any writer."@en ;
  dcterms:modified "2026-02-12T08:59:21.729926Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1956-1
  a curric:KeyLearningPoint ;
  rdfs:label """Both 'The Speckled Band' and 'The Boscombe Valley Mystery' share detective conventions"""@en ;
  dcterms:modified "2026-02-12T08:59:21.729931Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1956-2
  a curric:KeyLearningPoint ;
  rdfs:label """'The Speckled Band' and 'The Boscombe Valley Mystery' mostly differ on their presentation of key characters"""@en ;
  dcterms:modified "2026-02-12T08:59:21.729937Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1956-3
  a curric:KeyLearningPoint ;
  rdfs:label """A thesis statement appears in the introduction and is a summary of your viewpoint on a topic"""@en ;
  dcterms:modified "2026-02-12T08:59:21.729942Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1842-1
  a curric:KeyLearningPoint ;
  rdfs:label """The 5 part narrative structure divides a story into: exposition, rising action, climax, falling action, resolution."""@en ;
  dcterms:modified "2026-02-12T08:59:21.729946Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1842-2
  a curric:KeyLearningPoint ;
  rdfs:label """Each section of the narrative does not have to have the same number of paragraphs."""@en ;
  dcterms:modified "2026-02-12T08:59:21.729950Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1842-3
  a curric:KeyLearningPoint ;
  rdfs:label "Single paragraph outlines are a way of planning a narrative paragraph."@en ;
  dcterms:modified "2026-02-12T08:59:21.729954Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1842-4
  a curric:KeyLearningPoint ;
  rdfs:label """Single paragraph outlines have topic and concluding sentences written in full, and supporting detail in note form."""@en ;
  dcterms:modified "2026-02-12T08:59:21.729959Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1842-5
  a curric:KeyLearningPoint ;
  rdfs:label """To further structure your piece, you could link the concluding sentence of paragraphs to the next topic sentence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.729963Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27921-1
  a curric:KeyLearningPoint ;
  rdfs:label "We use paragraphs to organise our ideas clearly."@en ;
  dcterms:modified "2026-02-12T08:59:21.729967Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27921-2
  a curric:KeyLearningPoint ;
  rdfs:label "Paragraphs are needed when you introduce a new topic, time, place or person."@en ;
  dcterms:modified "2026-02-12T08:59:21.729972Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27921-3
  a curric:KeyLearningPoint ;
  rdfs:label "Paragraphs should be cohesive in between shifts."@en ;
  dcterms:modified "2026-02-12T08:59:21.729976Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27921-4
  a curric:KeyLearningPoint ;
  rdfs:label """Slowly revealing information about a character across multiple paragraphs creates suspense."""@en ;
  dcterms:modified "2026-02-12T08:59:21.729980Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1988-1
  a curric:KeyLearningPoint ;
  rdfs:label """A dystopia is a fictional, futuristic society in which there is great suffering and injustice"""@en ;
  dcterms:modified "2026-02-12T08:59:21.729984Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1988-2
  a curric:KeyLearningPoint ;
  rdfs:label "The setting is the time and place in which a story takes place"@en ;
  dcterms:modified "2026-02-12T08:59:21.729991Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1988-3
  a curric:KeyLearningPoint ;
  rdfs:label """The opposite of a dystopia is a utopia, which is an imagined place where everything is fair and perfect"""@en ;
  dcterms:modified "2026-02-12T08:59:21.729995Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1988-4
  a curric:KeyLearningPoint ;
  rdfs:label "Dystopian settings are often used to make a point about our current society"@en ;
  dcterms:modified "2026-02-12T08:59:21.730000Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1581-1
  a curric:KeyLearningPoint ;
  rdfs:label """Symbolism is where writers use objects, characters, or elements in their work, to represent deeper ideas and themes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.730004Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1581-2
  a curric:KeyLearningPoint ;
  rdfs:label """Poe uses the old man’s eye to symbolise intrusion, truth and moral or spiritual judgement in the story."""@en ;
  dcterms:modified "2026-02-12T08:59:21.730010Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1581-3
  a curric:KeyLearningPoint ;
  rdfs:label """Poe uses the heart beat to symbolise the narrator’s guilt, paranoia and time running out."""@en ;
  dcterms:modified "2026-02-12T08:59:21.730015Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1581-4
  a curric:KeyLearningPoint ;
  rdfs:label """Symbols allow the writer to communicate hidden or deeper meanings within the text."""@en ;
  dcterms:modified "2026-02-12T08:59:21.730019Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1581-5
  a curric:KeyLearningPoint ;
  rdfs:label """When writing about a writer’s use of symbolism, it is always important to discuss why it has been used."""@en ;
  dcterms:modified "2026-02-12T08:59:21.730023Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1597-1
  a curric:KeyLearningPoint ;
  rdfs:label "Blending is when words are 'chopped up' and put together."@en ;
  dcterms:modified "2026-02-12T08:59:21.731395Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1597-2
  a curric:KeyLearningPoint ;
  rdfs:label "Compounds are when two words are merged (sometimes using a hyphen)."@en ;
  dcterms:modified "2026-02-12T08:59:21.731399Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1597-3
  a curric:KeyLearningPoint ;
  rdfs:label "Initialism is like an acronym, except all the letters are pronounced."@en ;
  dcterms:modified "2026-02-12T08:59:21.731403Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1597-4
  a curric:KeyLearningPoint ;
  rdfs:label "Affixation means fastening parts of words to other words."@en ;
  dcterms:modified "2026-02-12T08:59:21.731408Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1849-1
  a curric:KeyLearningPoint ;
  rdfs:label "‘A Midsummer Night’s Dream’ was first performed to an Elizabethan audience."@en ;
  dcterms:modified "2026-02-12T08:59:21.731414Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1849-2
  a curric:KeyLearningPoint ;
  rdfs:label "Elizabethans believed women should obey their fathers and husbands."@en ;
  dcterms:modified "2026-02-12T08:59:21.731418Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1849-3
  a curric:KeyLearningPoint ;
  rdfs:label "Elizabethans believed the supernatural was evil."@en ;
  dcterms:modified "2026-02-12T08:59:21.731422Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1849-4
  a curric:KeyLearningPoint ;
  rdfs:label """Shakespeare included ideas about the patriarchy and the supernatural in his plays as a way to connect to his audiences."""@en ;
  dcterms:modified "2026-02-12T08:59:21.731426Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1849-5
  a curric:KeyLearningPoint ;
  rdfs:label """When writing about ‘A Midsummer Night’s Dream’, you should include context to help develop your ideas."""@en ;
  dcterms:modified "2026-02-12T08:59:21.731431Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1578-1
  a curric:KeyLearningPoint ;
  rdfs:label "’The Tell-Tale Heart’ is the story about the murder of an old man."@en ;
  dcterms:modified "2026-02-12T08:59:21.731437Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1578-2
  a curric:KeyLearningPoint ;
  rdfs:label "The narrator did not murder for money but for fear of the man's blue eyes."@en ;
  dcterms:modified "2026-02-12T08:59:21.731441Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1578-3
  a curric:KeyLearningPoint ;
  rdfs:label """The narrator kills the man as he worries a neighbour may hear the loud beating of his heart."""@en ;
  dcterms:modified "2026-02-12T08:59:21.731463Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1578-4
  a curric:KeyLearningPoint ;
  rdfs:label "The narrator dismembers the body and hides it under the floorboards."@en ;
  dcterms:modified "2026-02-12T08:59:21.731468Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1578-5
  a curric:KeyLearningPoint ;
  rdfs:label """The narrator continues to hear the beating heart of the dead man, which leads him to confess."""@en ;
  dcterms:modified "2026-02-12T08:59:21.731472Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28474-1
  a curric:KeyLearningPoint ;
  rdfs:label """Slam poetry can be considered different to more conventional, written forms of poetry."""@en ;
  dcterms:modified "2026-02-12T08:59:21.731476Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28474-2
  a curric:KeyLearningPoint ;
  rdfs:label """Slam poetry is created to be performed out loud and responds to audience feedback."""@en ;
  dcterms:modified "2026-02-12T08:59:21.731480Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28474-3
  a curric:KeyLearningPoint ;
  rdfs:label """Slam poetry uses poetic devices such as onomatopoeia, alliteration and repetition to engage the audience."""@en ;
  dcterms:modified "2026-02-12T08:59:21.731486Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28474-4
  a curric:KeyLearningPoint ;
  rdfs:label "Harry Baker is an example of a slam poet."@en ;
  dcterms:modified "2026-02-12T08:59:21.731491Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28474-5
  a curric:KeyLearningPoint ;
  rdfs:label "The poem 'Where The Wild Things Are' conforms to the conventions of slam poetry."@en ;
  dcterms:modified "2026-02-12T08:59:21.731497Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1730-1
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, through the novel, Golding alludes to the 'Garden of Eden' story in the Bible."""@en ;
  dcterms:modified "2026-02-12T08:59:21.731501Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1730-2
  a curric:KeyLearningPoint ;
  rdfs:label """The Garden of Eden parable recounts the story of original sin - the idea that man is born innately sinful."""@en ;
  dcterms:modified "2026-02-12T08:59:21.731505Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1730-3
  a curric:KeyLearningPoint ;
  rdfs:label """Golding draws parallels between the boys' transgressions on the island and Adam and Eve's transgression in Genesis."""@en ;
  dcterms:modified "2026-02-12T08:59:21.731509Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1730-4
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, the "beast" inside man tempts man into sinning, thereby corrupting his virtuosity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.731513Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1730-5
  a curric:KeyLearningPoint ;
  rdfs:label """Golding alludes to Milton’s 'Paradise Lost' by using a symbolic title that represents the concept of innate evil."""@en ;
  dcterms:modified "2026-02-12T08:59:21.731517Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1728-1
  a curric:KeyLearningPoint ;
  rdfs:label "Arguably, the conch is a symbol of democracy and civilisation on the island."@en ;
  dcterms:modified "2026-02-12T08:59:21.731552Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1728-2
  a curric:KeyLearningPoint ;
  rdfs:label """Jack despises the conch because it is representative of Ralph's leadership and because it is a threat to his campaign."""@en ;
  dcterms:modified "2026-02-12T08:59:21.731566Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1728-3
  a curric:KeyLearningPoint ;
  rdfs:label """The destruction of the conch arguably represents the downfall of civilisation and democracy and descent into savagery."""@en ;
  dcterms:modified "2026-02-12T08:59:21.731572Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1728-4
  a curric:KeyLearningPoint ;
  rdfs:label """Jack's painted face could mark the emergence of the real (savage) Jack, who has surrendered to his dark impulses."""@en ;
  dcterms:modified "2026-02-12T08:59:21.731581Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1728-5
  a curric:KeyLearningPoint ;
  rdfs:label """The boys are appalled by Jack’s mask because it makes him unrecognisable as human in both appearance and demeanour."""@en ;
  dcterms:modified "2026-02-12T08:59:21.731586Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1839-1
  a curric:KeyLearningPoint ;
  rdfs:label "'One Thousand and One Nights' is a collection of Middle Eastern folktales."@en ;
  dcterms:modified "2026-02-12T08:59:21.731591Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1839-2
  a curric:KeyLearningPoint ;
  rdfs:label """'One Thousand and One Nights' uses a frame story: a main story around shorter ones, all told by one person, Shahrazad."""@en ;
  dcterms:modified "2026-02-12T08:59:21.731595Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1839-3
  a curric:KeyLearningPoint ;
  rdfs:label """Shahrazad tells these stories to her husband, Shahrayar, ending each installment on a cliffhanger."""@en ;
  dcterms:modified "2026-02-12T08:59:21.731599Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1839-4
  a curric:KeyLearningPoint ;
  rdfs:label """In this way, Shahrayar, desperate to know the rest of the story, puts off killing her (his usual custom with his wives)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.731603Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1839-5
  a curric:KeyLearningPoint ;
  rdfs:label "'The Fisherman and the Jinni' is one of the stories Shahrazad tells her husband."@en ;
  dcterms:modified "2026-02-12T08:59:21.731607Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1841-1
  a curric:KeyLearningPoint ;
  rdfs:label "The structure of a narrative means how the plot is organised - its sequence."@en ;
  dcterms:modified "2026-02-12T08:59:21.731611Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1841-2
  a curric:KeyLearningPoint ;
  rdfs:label "Readers need to feel that the structure of a story has been planned."@en ;
  dcterms:modified "2026-02-12T08:59:21.731615Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1841-3
  a curric:KeyLearningPoint ;
  rdfs:label "One way to plan a narrative is to rely on the five part narrative structure."@en ;
  dcterms:modified "2026-02-12T08:59:21.731621Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1841-4
  a curric:KeyLearningPoint ;
  rdfs:label """The five part narrative structure divides a story into exposition, rising action, climax, falling action, resolution."""@en ;
  dcterms:modified "2026-02-12T08:59:21.731626Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1596-1
  a curric:KeyLearningPoint ;
  rdfs:label "Weakening is when a word is overused and loses the strength of its meaning"@en ;
  dcterms:modified "2026-02-12T08:59:21.732202Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1596-2
  a curric:KeyLearningPoint ;
  rdfs:label "Intensification is when a word acquires a stronger meaning over time"@en ;
  dcterms:modified "2026-02-12T08:59:21.732206Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1596-3
  a curric:KeyLearningPoint ;
  rdfs:label """Amelioration is when a word acquires a certain, more pleasurable meaning than it once had"""@en ;
  dcterms:modified "2026-02-12T08:59:21.732210Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1596-4
  a curric:KeyLearningPoint ;
  rdfs:label """Pejoration is when a word acquires negative connotations that it did not have before"""@en ;
  dcterms:modified "2026-02-12T08:59:21.732216Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1872-1
  a curric:KeyLearningPoint ;
  rdfs:label """Conclusions can follow a three part structure moving from the specific to the general."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732221Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1872-2
  a curric:KeyLearningPoint ;
  rdfs:label """The first sentence of a conclusion could be a specific response to the thesis you have argued throughout your essay."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732225Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1872-3
  a curric:KeyLearningPoint ;
  rdfs:label """The second sentence of a conclusion could be an evaluative comment about the writer's intentions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732229Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1872-4
  a curric:KeyLearningPoint ;
  rdfs:label """The final sentence of your conclusion could consider why the text remains popular and relevant."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732233Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1872-5
  a curric:KeyLearningPoint ;
  rdfs:label "You don't need to include quotations in a conclusion."@en ;
  dcterms:modified "2026-02-12T08:59:21.732237Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1852-1
  a curric:KeyLearningPoint ;
  rdfs:label "Oberon’s servant has two names: Puck and Robin Goodfellow."@en ;
  dcterms:modified "2026-02-12T08:59:21.732241Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1852-2
  a curric:KeyLearningPoint ;
  rdfs:label "In Elizabethan folklore, ‘puck’ was a general term for a fairy."@en ;
  dcterms:modified "2026-02-12T08:59:21.732246Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1852-3
  a curric:KeyLearningPoint ;
  rdfs:label """Elizabethan folklore also connected the word ‘puck’ with malevolence and the devil."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732252Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1852-4
  a curric:KeyLearningPoint ;
  rdfs:label """Robin Goodfellow is a name from Elizabethan folklore, a character connected with practical jokes and helpfulness."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732256Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1852-5
  a curric:KeyLearningPoint ;
  rdfs:label "When Puck is first introduced, we are told about many of his practical jokes."@en ;
  dcterms:modified "2026-02-12T08:59:21.732260Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28476-1
  a curric:KeyLearningPoint ;
  rdfs:label "Planning is an important part of the writing process."@en ;
  dcterms:modified "2026-02-12T08:59:21.732264Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28476-2
  a curric:KeyLearningPoint ;
  rdfs:label """When planning a slam poem you can consider your theme and key ideas to help get you started."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732268Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28476-3
  a curric:KeyLearningPoint ;
  rdfs:label "‘Lifted lines’ can be used to create interest and help to develop content."@en ;
  dcterms:modified "2026-02-12T08:59:21.732272Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28476-4
  a curric:KeyLearningPoint ;
  rdfs:label "Both end and internal rhymes can be used effectively in slam poetry."@en ;
  dcterms:modified "2026-02-12T08:59:21.732276Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1721-1
  a curric:KeyLearningPoint ;
  rdfs:label "Ralph hides in the thicket of the forest as Jack's tribe hunt him down."@en ;
  dcterms:modified "2026-02-12T08:59:21.732280Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1721-2
  a curric:KeyLearningPoint ;
  rdfs:label "In an attempt to smoke Ralph out of the forest, Jack sets the jungle on fire."@en ;
  dcterms:modified "2026-02-12T08:59:21.732284Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1721-3
  a curric:KeyLearningPoint ;
  rdfs:label "A  British Naval vessel sees the jungle ablaze and rescues the boys."@en ;
  dcterms:modified "2026-02-12T08:59:21.732288Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1721-4
  a curric:KeyLearningPoint ;
  rdfs:label "The officer is surprised and disappointed  by the savage behaviour of the boys."@en ;
  dcterms:modified "2026-02-12T08:59:21.732292Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1721-5
  a curric:KeyLearningPoint ;
  rdfs:label """After reading a novel, a good question to ask ourselves is whether the ending is satisfying."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732296Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1931-1
  a curric:KeyLearningPoint ;
  rdfs:label """You can gather ideas for your own poem about home by studying the stylistic choices of other poets."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732300Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1931-2
  a curric:KeyLearningPoint ;
  rdfs:label """Figurative language uses words beyond their literal meaning to create images in the reader's mind."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732304Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1931-3
  a curric:KeyLearningPoint ;
  rdfs:label "Imagery is visually descriptive language to create images in the reader's mind."@en ;
  dcterms:modified "2026-02-12T08:59:21.732308Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1931-4
  a curric:KeyLearningPoint ;
  rdfs:label """Both figurative language and imagery are useful in creating a vivid image of home in your reader's mind."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732315Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1931-5
  a curric:KeyLearningPoint ;
  rdfs:label "You should plan out sentences when constructing a plan for your writing."@en ;
  dcterms:modified "2026-02-12T08:59:21.732319Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-881-1
  a curric:KeyLearningPoint ;
  rdfs:label """Bilan arguably foreshadows something negative happening to Asha and Jeevan in Zandapur."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732323Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-881-2
  a curric:KeyLearningPoint ;
  rdfs:label """Textural description can be used to influence the reader’s perception of a place or object."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732329Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-881-3
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, Bilan uses textures to imply that Zandapur is unsafe and not a worthwhile place."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732334Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-881-4
  a curric:KeyLearningPoint ;
  rdfs:label "We might infer from Bilan’s use of smells that Zandapur is an unpleasant place."@en ;
  dcterms:modified "2026-02-12T08:59:21.732338Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-864-1
  a curric:KeyLearningPoint ;
  rdfs:label """Planning before you write will support you to demonstrate skill in key areas and ensure your piece is cohesive."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732342Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-864-2
  a curric:KeyLearningPoint ;
  rdfs:label """Supporting details describe the focus of each paragraph in more detail – using sensory detail (at least 3 senses)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732346Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-864-3
  a curric:KeyLearningPoint ;
  rdfs:label """Similes and metaphors are effective in descriptive writing because they help the reader to picture the scene."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732350Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-864-4
  a curric:KeyLearningPoint ;
  rdfs:label "Choose verbs or adjectives that work together to create an overall atmosphere."@en ;
  dcterms:modified "2026-02-12T08:59:21.732356Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1537-1
  a curric:KeyLearningPoint ;
  rdfs:label """When writers take a stand, they often include elements such as personal anecdote, experts and politics."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732363Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1537-2
  a curric:KeyLearningPoint ;
  rdfs:label """Using Aristotle’s triad of logos, ethos and pathos can help strengthen a point of view."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732367Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1537-3
  a curric:KeyLearningPoint ;
  rdfs:label "When we evaluate texts, we need to measure them against specific criteria."@en ;
  dcterms:modified "2026-02-12T08:59:21.732371Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1537-4
  a curric:KeyLearningPoint ;
  rdfs:label """Evaluation means looking at the validity of the content and the quality of the writing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732375Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1968-1
  a curric:KeyLearningPoint ;
  rdfs:label """Martha's dream tells her that she can only save Mormor from torment if she goes to the tree."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732379Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1968-2
  a curric:KeyLearningPoint ;
  rdfs:label "Martha kisses Stig but he pulls away and she feels humiliated."@en ;
  dcterms:modified "2026-02-12T08:59:21.732383Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1968-3
  a curric:KeyLearningPoint ;
  rdfs:label "The draugr appears and kills Stig and Gandalf."@en ;
  dcterms:modified "2026-02-12T08:59:21.732387Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1968-4
  a curric:KeyLearningPoint ;
  rdfs:label "Martha calls on her ancestors to help her against the draugr."@en ;
  dcterms:modified "2026-02-12T08:59:21.732391Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1968-5
  a curric:KeyLearningPoint ;
  rdfs:label "Martha visits Hel."@en ;
  dcterms:modified "2026-02-12T08:59:21.732395Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1863-1
  a curric:KeyLearningPoint ;
  rdfs:label """Some people argue Puck is the most important character in the play because of his significance to the plot."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732796Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1863-2
  a curric:KeyLearningPoint ;
  rdfs:label "Selecting powerful quotations is a key skill in English."@en ;
  dcterms:modified "2026-02-12T08:59:21.732800Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1863-3
  a curric:KeyLearningPoint ;
  rdfs:label "Powerful quotations link to your topic sentence."@en ;
  dcterms:modified "2026-02-12T08:59:21.732804Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1863-4
  a curric:KeyLearningPoint ;
  rdfs:label "Powerful quotations are rich in methods."@en ;
  dcterms:modified "2026-02-12T08:59:21.732812Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1863-5
  a curric:KeyLearningPoint ;
  rdfs:label "You should select more than one quotation to prove each topic sentence."@en ;
  dcterms:modified "2026-02-12T08:59:21.732816Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6226-1
  a curric:KeyLearningPoint ;
  rdfs:label """Rhetorical questions need to be ‘targeted’ - personalised to the situation or moment, and used with an aim in mind."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732820Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6226-2
  a curric:KeyLearningPoint ;
  rdfs:label """Using emotive language in rhetorical questions can be a very effective way of making them more targeted and purposeful."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732824Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6226-3
  a curric:KeyLearningPoint ;
  rdfs:label """Direct address can be used to motivate and empower the reader to make changes or speak up."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732828Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6226-4
  a curric:KeyLearningPoint ;
  rdfs:label """Repeating ‘you’ too many times can be quite accusatory, which can actually make your reader resistant to your message."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732832Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6226-5
  a curric:KeyLearningPoint ;
  rdfs:label """Try being more subtle with direct address- speak to an imagined reader by name or address readers collectively."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732836Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1560-1
  a curric:KeyLearningPoint ;
  rdfs:label "On a dreary night in November, Frankenstein brings his creation to life."@en ;
  dcterms:modified "2026-02-12T08:59:21.732840Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1560-2
  a curric:KeyLearningPoint ;
  rdfs:label """He despises his creation because it is hideous and ugly; he shuns the Creature and runs away from it."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732844Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1560-3
  a curric:KeyLearningPoint ;
  rdfs:label "Shelley uses pathetic fallacy and setting to create an ominous atmosphere."@en ;
  dcterms:modified "2026-02-12T08:59:21.732847Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1560-4
  a curric:KeyLearningPoint ;
  rdfs:label """Shelley cleverly builds tension in the lead up to the reveal of Frankenstein’s monster."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732851Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1516-1
  a curric:KeyLearningPoint ;
  rdfs:label """Katherine Mansfield’s 'The Fly' is written using a third person omniscient narrator."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732855Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1516-2
  a curric:KeyLearningPoint ;
  rdfs:label "A third person narrator uses 'she', 'he' and 'they' rather than 'I'."@en ;
  dcterms:modified "2026-02-12T08:59:21.732859Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1516-3
  a curric:KeyLearningPoint ;
  rdfs:label "A third person narrator might focus more on one or more character’s experiences."@en ;
  dcterms:modified "2026-02-12T08:59:21.732863Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1516-4
  a curric:KeyLearningPoint ;
  rdfs:label """Using third person means that the reader often has to interpret why a character does something rather being told why."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732867Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1516-5
  a curric:KeyLearningPoint ;
  rdfs:label """We learn little about the character of Macey, but there are suggestions of his devotion to the boss."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732870Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1806-1
  a curric:KeyLearningPoint ;
  rdfs:label """In Act 1, Desdemona is brave and adventurous, proclaiming her love for Othello and following him to the battleground."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732874Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1806-2
  a curric:KeyLearningPoint ;
  rdfs:label "Othello greets her as \"my fair warrior\" in Act 2, highlighting her strength."@en ;
  dcterms:modified "2026-02-12T08:59:21.732878Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1806-3
  a curric:KeyLearningPoint ;
  rdfs:label "Many argue that Desdemona is a submissive character by the end of the play."@en ;
  dcterms:modified "2026-02-12T08:59:21.732884Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1806-4
  a curric:KeyLearningPoint ;
  rdfs:label """Desdemona's name in Greek means 'ill-fated' or 'unfortunate', suggesting that she is a tragic victim."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732888Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1943-1
  a curric:KeyLearningPoint ;
  rdfs:label "The main body of an article should include details of the event"@en ;
  dcterms:modified "2026-02-12T08:59:21.732892Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1943-2
  a curric:KeyLearningPoint ;
  rdfs:label "Interview quotes can add gravitas to your article"@en ;
  dcterms:modified "2026-02-12T08:59:21.732896Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1943-3
  a curric:KeyLearningPoint ;
  rdfs:label "The interview quotes can be from various parties"@en ;
  dcterms:modified "2026-02-12T08:59:21.732900Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1943-4
  a curric:KeyLearningPoint ;
  rdfs:label "The tone of your quote can vary depending on who the provided the quote"@en ;
  dcterms:modified "2026-02-12T08:59:21.732904Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1536-1
  a curric:KeyLearningPoint ;
  rdfs:label """Aristotle was an influential ancient Greek philosopher who lived between 384 BCE to 322 BCE."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732908Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1536-2
  a curric:KeyLearningPoint ;
  rdfs:label "Aristotle wrote about politics, rhetoric and logic."@en ;
  dcterms:modified "2026-02-12T08:59:21.732914Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1536-3
  a curric:KeyLearningPoint ;
  rdfs:label "Aristotle’s triad consists of logos, ethos and pathos."@en ;
  dcterms:modified "2026-02-12T08:59:21.732918Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1536-4
  a curric:KeyLearningPoint ;
  rdfs:label """Logos is the appeal to reason; ethos is the appeal to authority and credibility and pathos is the appeal to emotion."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732922Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1536-5
  a curric:KeyLearningPoint ;
  rdfs:label "Aristotle’s triad is very important when planning persuasive writing."@en ;
  dcterms:modified "2026-02-12T08:59:21.732926Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1854-1
  a curric:KeyLearningPoint ;
  rdfs:label """In Elizabethan folklore, the word ‘puck’ meant a fairy, often one that was malicious and associated with the devil."""@en ;
  dcterms:modified "2026-02-12T08:59:21.733239Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1854-2
  a curric:KeyLearningPoint ;
  rdfs:label """In Elizabethan folklore, Robin Goodfellow was associated with a mischievous fairy who also helped with housework."""@en ;
  dcterms:modified "2026-02-12T08:59:21.733263Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1854-3
  a curric:KeyLearningPoint ;
  rdfs:label "Shakespeare emphasises Puck’s ability to transform himself physically."@en ;
  dcterms:modified "2026-02-12T08:59:21.733268Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1854-4
  a curric:KeyLearningPoint ;
  rdfs:label """Shakespeare emphasises Puck’s ability to transform his attitude and dialogue depending on who he is talking to."""@en ;
  dcterms:modified "2026-02-12T08:59:21.733274Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1854-5
  a curric:KeyLearningPoint ;
  rdfs:label """Audiences may have different reactions to the character of Puck at different points in the play."""@en ;
  dcterms:modified "2026-02-12T08:59:21.733278Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1758-1
  a curric:KeyLearningPoint ;
  rdfs:label """A writer can use key conventions to craft a malevolent character in their writing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.733282Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1758-2
  a curric:KeyLearningPoint ;
  rdfs:label """These conventions include: physical description, dialogue, and other characters' reactions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.733286Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1758-3
  a curric:KeyLearningPoint ;
  rdfs:label """The contrast between dialogue and action can be used to imply a character is malevolent subtly."""@en ;
  dcterms:modified "2026-02-12T08:59:21.733290Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1758-4
  a curric:KeyLearningPoint ;
  rdfs:label "Bram Stoker's Count Dracula is a classic malevolent character."@en ;
  dcterms:modified "2026-02-12T08:59:21.733295Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1831-1
  a curric:KeyLearningPoint ;
  rdfs:label """'Skin of the Sea' centres around a protagonist called Simidele who is a Mami Wata, in this instance a mermaid."""@en ;
  dcterms:modified "2026-02-12T08:59:21.733316Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1831-2
  a curric:KeyLearningPoint ;
  rdfs:label """As a Mami Wata, Simidele must collect souls of enslaved people who die as they are transported across the Atlantic."""@en ;
  dcterms:modified "2026-02-12T08:59:21.733320Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1831-3
  a curric:KeyLearningPoint ;
  rdfs:label """Natasha Bowen makes use of flashback in the opening chapter to hint at Simidele's life before she became a Mami Wata."""@en ;
  dcterms:modified "2026-02-12T08:59:21.733324Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1831-4
  a curric:KeyLearningPoint ;
  rdfs:label """When annotating a text, you can use a range of symbols and notes to help develop an understanding of the text’s ideas."""@en ;
  dcterms:modified "2026-02-12T08:59:21.733328Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1836-1
  a curric:KeyLearningPoint ;
  rdfs:label """Briseis is a character from Greek mythology; she is given to Achilles (a renowned warrior) as a prize of war."""@en ;
  dcterms:modified "2026-02-12T08:59:21.733332Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1836-2
  a curric:KeyLearningPoint ;
  rdfs:label """Pat Barker wrote ‘The Silence of the Girls’ from the first person perspective of Briseis."""@en ;
  dcterms:modified "2026-02-12T08:59:21.733336Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1836-3
  a curric:KeyLearningPoint ;
  rdfs:label """The novel begins with Briseis in her home city of Lyrnessus which is under attack from the Greeks."""@en ;
  dcterms:modified "2026-02-12T08:59:21.733340Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1836-4
  a curric:KeyLearningPoint ;
  rdfs:label """Barker creates tension and suspense through descriptions of Achilles, the battle and hints about Briseis's future."""@en ;
  dcterms:modified "2026-02-12T08:59:21.733347Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1836-5
  a curric:KeyLearningPoint ;
  rdfs:label """When annotating a text, you can use a range of symbols and notes to help develop an understanding of the text’s ideas."""@en ;
  dcterms:modified "2026-02-12T08:59:21.733351Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1938-1
  a curric:KeyLearningPoint ;
  rdfs:label "Julia Stoner has died in a suspicious manner"@en ;
  dcterms:modified "2026-02-12T08:59:21.733355Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1938-2
  a curric:KeyLearningPoint ;
  rdfs:label "There does not seem to be an obvious way in which Julia Stoner died"@en ;
  dcterms:modified "2026-02-12T08:59:21.733359Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1938-3
  a curric:KeyLearningPoint ;
  rdfs:label """There are a range of peculiar events and clues which Holmes must piece together to solve the case"""@en ;
  dcterms:modified "2026-02-12T08:59:21.733363Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1938-4
  a curric:KeyLearningPoint ;
  rdfs:label "Based on recent events, Helen may now face the same danger as her sister"@en ;
  dcterms:modified "2026-02-12T08:59:21.733369Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29488-1
  a curric:KeyLearningPoint ;
  rdfs:label """Armitage was commissioned to write ‘All Right?’ for a campaign that aimed to encourage people to watch out for others."""@en ;
  dcterms:modified "2026-02-12T08:59:21.733373Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29488-2
  a curric:KeyLearningPoint ;
  rdfs:label """Armitage suggests that having an accompanying film meant that he didn’t have to create a whole backdrop for the poem."""@en ;
  dcterms:modified "2026-02-12T08:59:21.733377Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29488-3
  a curric:KeyLearningPoint ;
  rdfs:label "Armitage says that ‘Give’ is a poem about not being loved."@en ;
  dcterms:modified "2026-02-12T08:59:21.733381Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29488-4
  a curric:KeyLearningPoint ;
  rdfs:label """One idea for how to create a poem is to take a narrative and manipulate it into a poem."""@en ;
  dcterms:modified "2026-02-12T08:59:21.733385Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-879-1
  a curric:KeyLearningPoint ;
  rdfs:label """Use your first read through of an unseen extract to establish ideas about plot and characters."""@en ;
  dcterms:modified "2026-02-12T08:59:21.733389Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-879-2
  a curric:KeyLearningPoint ;
  rdfs:label """Use your second read through to examine words or phrases in more detail to consider the writer’s intention."""@en ;
  dcterms:modified "2026-02-12T08:59:21.733393Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-879-3
  a curric:KeyLearningPoint ;
  rdfs:label """Light imagery is where the writer uses descriptions of light in order to influence the atmosphere."""@en ;
  dcterms:modified "2026-02-12T08:59:21.733396Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-879-4
  a curric:KeyLearningPoint ;
  rdfs:label """Colour imagery is where the writer makes specific vocabulary choices to influence the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.733400Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-879-5
  a curric:KeyLearningPoint ;
  rdfs:label """Topic sentences introduce the main idea of a paragraph and clearly tell the reader what your idea is."""@en ;
  dcterms:modified "2026-02-12T08:59:21.733404Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1855-1
  a curric:KeyLearningPoint ;
  rdfs:label "Shakespeare was writing for an Elizabethan audience."@en ;
  dcterms:modified "2026-02-12T08:59:21.734226Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1855-2
  a curric:KeyLearningPoint ;
  rdfs:label """The ideas, characters and plot points in the play are designed to engage with Elizabethan society, attitudes and values."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734232Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1855-3
  a curric:KeyLearningPoint ;
  rdfs:label "Information about Elizabethan society, attitudes and values is called context."@en ;
  dcterms:modified "2026-02-12T08:59:21.734236Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1855-4
  a curric:KeyLearningPoint ;
  rdfs:label "When writing about the play, you should include context to develop your ideas."@en ;
  dcterms:modified "2026-02-12T08:59:21.734240Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1559-1
  a curric:KeyLearningPoint ;
  rdfs:label """Victor Frankenstein is portrayed as a highly hubristic and arrogant character who plays God."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734248Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1559-2
  a curric:KeyLearningPoint ;
  rdfs:label """Victor relentlessly pursues knowledge to its limits, to the detriment of his own sanity, and the lives of others."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734252Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1559-3
  a curric:KeyLearningPoint ;
  rdfs:label "Shelley uses hyperbolic language to characterise Frankenstein as hubristic."@en ;
  dcterms:modified "2026-02-12T08:59:21.734256Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1559-4
  a curric:KeyLearningPoint ;
  rdfs:label """Frankenstein regrets his hubris and ambition, acknowledging that it has destroyed him physically and mentally."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734260Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1559-5
  a curric:KeyLearningPoint ;
  rdfs:label """Shelley warns us of the corruptive nature of ambition, especially when pursued by those without respect for boundaries."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734264Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1716-1
  a curric:KeyLearningPoint ;
  rdfs:label "The boys stage a mock pig hunt using Robert as the pig; Robert is badly hurt."@en ;
  dcterms:modified "2026-02-12T08:59:21.734270Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1716-2
  a curric:KeyLearningPoint ;
  rdfs:label "For the first time, Ralph joins in the violence and savagery."@en ;
  dcterms:modified "2026-02-12T08:59:21.734274Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1716-3
  a curric:KeyLearningPoint ;
  rdfs:label "Ralph, Jack and Roger go to look for the beast."@en ;
  dcterms:modified "2026-02-12T08:59:21.734278Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1716-4
  a curric:KeyLearningPoint ;
  rdfs:label "Golding uses the flashback of Ralph's memories to depict a happier time."@en ;
  dcterms:modified "2026-02-12T08:59:21.734282Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1716-5
  a curric:KeyLearningPoint ;
  rdfs:label "The flashback also hints at the ever present existence of war."@en ;
  dcterms:modified "2026-02-12T08:59:21.734286Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1951-1
  a curric:KeyLearningPoint ;
  rdfs:label "Dr. Roylott is presented as aggressive in 'The Speckled Band'."@en ;
  dcterms:modified "2026-02-12T08:59:21.734290Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1951-2
  a curric:KeyLearningPoint ;
  rdfs:label """We can use the connotations of words to help us analyse a character’s presentation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734294Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1951-3
  a curric:KeyLearningPoint ;
  rdfs:label """We should always use tentative language when suggesting why an author has presented a character in a certain way."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734298Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1933-1
  a curric:KeyLearningPoint ;
  rdfs:label """A poem about home should clearly express your story, including your attitude towards the place you live."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734520Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1933-2
  a curric:KeyLearningPoint ;
  rdfs:label """Zooming and metaphorical language can be used, so a reader can imagine your home."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734524Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1933-3
  a curric:KeyLearningPoint ;
  rdfs:label """Deciding upon the structure of the poem and how you could express your content is important to consider."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734528Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1933-4
  a curric:KeyLearningPoint ;
  rdfs:label "Juxtaposition can be used in poems to express a contrast between two places."@en ;
  dcterms:modified "2026-02-12T08:59:21.734534Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1933-5
  a curric:KeyLearningPoint ;
  rdfs:label """Punctuation can be used to add pace or rhythm to a poem and reflect different feelings."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734538Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29485-1
  a curric:KeyLearningPoint ;
  rdfs:label """Armitage suggests that ‘I am very bothered’ was based on real events that happened during his school years."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734542Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29485-2
  a curric:KeyLearningPoint ;
  rdfs:label """Armitage says that ‘I am very bothered’ is about how we hurt people who don’t love us in the way that we want them to."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734546Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29485-3
  a curric:KeyLearningPoint ;
  rdfs:label """Armitage’s ‘My father thought it’ is based on Armitage piercing his ear and his father’s reaction to the piercing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734550Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29485-4
  a curric:KeyLearningPoint ;
  rdfs:label """Armitage suggests that the poem could be seen as a late reply to his father’s reaction."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734554Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2003-1
  a curric:KeyLearningPoint ;
  rdfs:label """Effective revision means that you can remember key information, without using your notes"""@en ;
  dcterms:modified "2026-02-12T08:59:21.735714Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2003-2
  a curric:KeyLearningPoint ;
  rdfs:label """Recalling examples of each of the sentence types will help you remember to include all of them when writing"""@en ;
  dcterms:modified "2026-02-12T08:59:21.735718Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2003-3
  a curric:KeyLearningPoint ;
  rdfs:label "Practising writing precise sentences will help you recall punctuation rules."@en ;
  dcterms:modified "2026-02-12T08:59:21.735722Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2003-4
  a curric:KeyLearningPoint ;
  rdfs:label """An effective description should use the different sentence types, for specific effects"""@en ;
  dcterms:modified "2026-02-12T08:59:21.735726Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1718-1
  a curric:KeyLearningPoint ;
  rdfs:label """Simon wakes up after fainting, sees the parachutist and realises the boys have mistaken the dead body for the beast."""@en ;
  dcterms:modified "2026-02-12T08:59:21.735902Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1718-2
  a curric:KeyLearningPoint ;
  rdfs:label "Simon goes to Jack's feast to tell the boys that the beast is not real."@en ;
  dcterms:modified "2026-02-12T08:59:21.735906Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1718-3
  a curric:KeyLearningPoint ;
  rdfs:label """Jack's feast becomes a frenzy as the boys perform a hunting dance - even Ralph and Piggy join in."""@en ;
  dcterms:modified "2026-02-12T08:59:21.735911Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1718-4
  a curric:KeyLearningPoint ;
  rdfs:label """The boys mistake Simon for the beast and savagely kill him with their hands and teeth."""@en ;
  dcterms:modified "2026-02-12T08:59:21.735916Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1718-5
  a curric:KeyLearningPoint ;
  rdfs:label """Golding uses pathetic fallacy to describe how the tension builds, explodes and reduces in this chapter."""@en ;
  dcterms:modified "2026-02-12T08:59:21.735919Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-873-1
  a curric:KeyLearningPoint ;
  rdfs:label "Baum describes the everyday setting of Kansas as dull and predictable."@en ;
  dcterms:modified "2026-02-12T08:59:21.735923Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-873-2
  a curric:KeyLearningPoint ;
  rdfs:label "Baum describes the unknown setting of Oz as wondrous and beautiful."@en ;
  dcterms:modified "2026-02-12T08:59:21.735927Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-873-3
  a curric:KeyLearningPoint ;
  rdfs:label """The contrasting use of colour in the descriptions depicts Kansas as a lifeless place and Oz as one of vitality."""@en ;
  dcterms:modified "2026-02-12T08:59:21.735931Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1598-1
  a curric:KeyLearningPoint ;
  rdfs:label "A successful speech will maintain a clear, single viewpoint throughout."@en ;
  dcterms:modified "2026-02-12T08:59:21.736641Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1598-2
  a curric:KeyLearningPoint ;
  rdfs:label """Ideas must be logically sequenced and linked, so that the audience can follow the argument."""@en ;
  dcterms:modified "2026-02-12T08:59:21.736645Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1598-3
  a curric:KeyLearningPoint ;
  rdfs:label "Vocabulary and language devices must be chosen for effect."@en ;
  dcterms:modified "2026-02-12T08:59:21.736649Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1598-4
  a curric:KeyLearningPoint ;
  rdfs:label """Use structural features at paragraph and sentence level, to manage pace and emphasis."""@en ;
  dcterms:modified "2026-02-12T08:59:21.736652Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1866-1
  a curric:KeyLearningPoint ;
  rdfs:label """A theme is an important idea in a text that is explored in a number of different ways."""@en ;
  dcterms:modified "2026-02-12T08:59:21.736658Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1866-2
  a curric:KeyLearningPoint ;
  rdfs:label """As students of English, the first step is to work out what are a text’s most important themes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.736662Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1866-3
  a curric:KeyLearningPoint ;
  rdfs:label "The next step is to consider when these themes are explored in the text."@en ;
  dcterms:modified "2026-02-12T08:59:21.736666Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1866-4
  a curric:KeyLearningPoint ;
  rdfs:label """Finally, you could consider what a writer might be trying to say about this particular theme."""@en ;
  dcterms:modified "2026-02-12T08:59:21.736670Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1512-1
  a curric:KeyLearningPoint ;
  rdfs:label "Mansfield (1888-1923) was a New Zealand writer and critic."@en ;
  dcterms:modified "2026-02-12T08:59:21.736674Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1512-2
  a curric:KeyLearningPoint ;
  rdfs:label """Mansfield was part of the modernist movement: she rejected traditional ideas about what literature should look like."""@en ;
  dcterms:modified "2026-02-12T08:59:21.736678Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1512-3
  a curric:KeyLearningPoint ;
  rdfs:label "‘The Fly’ presents two men, both of whom lost their sons in World War One."@en ;
  dcterms:modified "2026-02-12T08:59:21.736682Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1512-4
  a curric:KeyLearningPoint ;
  rdfs:label """‘The Fly’ (1922) was perhaps inspired by her own experiences of loss in World War One: her brother was killed in 1915."""@en ;
  dcterms:modified "2026-02-12T08:59:21.736686Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1714-1
  a curric:KeyLearningPoint ;
  rdfs:label "Chapter 5 shows the boys becoming increasingly angry and divided."@en ;
  dcterms:modified "2026-02-12T08:59:21.736690Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1714-2
  a curric:KeyLearningPoint ;
  rdfs:label "Ralph attempts to assert his authority, but Jack openly defies him."@en ;
  dcterms:modified "2026-02-12T08:59:21.736694Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1714-3
  a curric:KeyLearningPoint ;
  rdfs:label "The boys' many fears are openly expressed."@en ;
  dcterms:modified "2026-02-12T08:59:21.736698Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1714-4
  a curric:KeyLearningPoint ;
  rdfs:label "Irrational fears are held by the majority of the boys."@en ;
  dcterms:modified "2026-02-12T08:59:21.736702Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1714-5
  a curric:KeyLearningPoint ;
  rdfs:label "Jack uses the boys' fears to take them away, therefore asserting his authority."@en ;
  dcterms:modified "2026-02-12T08:59:21.736706Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6223-1
  a curric:KeyLearningPoint ;
  rdfs:label """When making an inference, start by choosing a key word or technique to zoom in on."""@en ;
  dcterms:modified "2026-02-12T08:59:21.736710Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6223-2
  a curric:KeyLearningPoint ;
  rdfs:label "Inferences should be developed with additional ideas that could link to context."@en ;
  dcterms:modified "2026-02-12T08:59:21.736715Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6223-3
  a curric:KeyLearningPoint ;
  rdfs:label """Similes and metaphors that link to snakes are often used, for the association with evil."""@en ;
  dcterms:modified "2026-02-12T08:59:21.736720Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6223-4
  a curric:KeyLearningPoint ;
  rdfs:label "Fog often symbolises mystery and danger."@en ;
  dcterms:modified "2026-02-12T08:59:21.736723Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1980-1
  a curric:KeyLearningPoint ;
  rdfs:label "Writers use a symbol to represent something that is not literally there."@en ;
  dcterms:modified "2026-02-12T08:59:21.737264Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1980-2
  a curric:KeyLearningPoint ;
  rdfs:label """Symbols in 'The Twisted Tree' include ravens, a blinded eye, the Norns and the fog."""@en ;
  dcterms:modified "2026-02-12T08:59:21.737270Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1980-3
  a curric:KeyLearningPoint ;
  rdfs:label "Each symbol represents a key theme or idea."@en ;
  dcterms:modified "2026-02-12T08:59:21.737275Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1980-4
  a curric:KeyLearningPoint ;
  rdfs:label """To create an effective analysis of a symbol, you need to explain where it appears in the novel and what it represents."""@en ;
  dcterms:modified "2026-02-12T08:59:21.737279Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1850-1
  a curric:KeyLearningPoint ;
  rdfs:label "Act 2 of ‘A Midsummer Night’s Dream’ begins, like Act 1, with a conflict."@en ;
  dcterms:modified "2026-02-12T08:59:21.737322Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1850-2
  a curric:KeyLearningPoint ;
  rdfs:label """Shakespeare uses dramatic methods to draw attention to the differences between the two conflicts."""@en ;
  dcterms:modified "2026-02-12T08:59:21.737327Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1850-3
  a curric:KeyLearningPoint ;
  rdfs:label """Dramatic methods are the tools a playwright uses to create their work e.g. characterisation, setting, stage directions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.737331Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1850-4
  a curric:KeyLearningPoint ;
  rdfs:label """You should explore dramatic methods when annotating, discussing or writing about a text."""@en ;
  dcterms:modified "2026-02-12T08:59:21.737335Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1567-1
  a curric:KeyLearningPoint ;
  rdfs:label """When reading an unseen extract, use the information you are given to make predictions about the text."""@en ;
  dcterms:modified "2026-02-12T08:59:21.737339Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1567-2
  a curric:KeyLearningPoint ;
  rdfs:label """When thinking about how something is presented, it can helpful to imagine yourself describing it to someone else."""@en ;
  dcterms:modified "2026-02-12T08:59:21.737345Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1567-3
  a curric:KeyLearningPoint ;
  rdfs:label """The red-room from ‘Jane Eyre’ is presented as a grand, mysterious and isolated room."""@en ;
  dcterms:modified "2026-02-12T08:59:21.737351Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1567-4
  a curric:KeyLearningPoint ;
  rdfs:label """‘Jane Eyre’ is a novel about a young, isolated girl who grows up, facing challenges along the way."""@en ;
  dcterms:modified "2026-02-12T08:59:21.737355Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1567-5
  a curric:KeyLearningPoint ;
  rdfs:label """Jane meets a wealthy man (Mr. Rochester) and falls in love with him but mystery and darkness seem to follow the couple."""@en ;
  dcterms:modified "2026-02-12T08:59:21.737359Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1837-1
  a curric:KeyLearningPoint ;
  rdfs:label """The opening of a comparative paragraph could start with a topic sentence which states the paragraph's main idea."""@en ;
  dcterms:modified "2026-02-12T08:59:21.737363Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1837-2
  a curric:KeyLearningPoint ;
  rdfs:label "Next, the comparative paragraph could focus on analysing the first text."@en ;
  dcterms:modified "2026-02-12T08:59:21.737367Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1837-3
  a curric:KeyLearningPoint ;
  rdfs:label """Then, a comparative paragraph could focus on the second text, comparing it to the first."""@en ;
  dcterms:modified "2026-02-12T08:59:21.737371Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1837-4
  a curric:KeyLearningPoint ;
  rdfs:label "Comparing the methods writers have used can help to develop the comparison."@en ;
  dcterms:modified "2026-02-12T08:59:21.737378Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1837-5
  a curric:KeyLearningPoint ;
  rdfs:label "The final sentence of a comparative paragraph could link to the topic sentence."@en ;
  dcterms:modified "2026-02-12T08:59:21.737382Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1815-1
  a curric:KeyLearningPoint ;
  rdfs:label """Critically evaluative thesis statements can be developed using 'whilst', 'not only' and 'crucially'."""@en ;
  dcterms:modified "2026-02-12T08:59:21.737386Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1815-2
  a curric:KeyLearningPoint ;
  rdfs:label """Thesis statements should address the writer's purpose or message, in relation to the question focus."""@en ;
  dcterms:modified "2026-02-12T08:59:21.737390Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1815-3
  a curric:KeyLearningPoint ;
  rdfs:label """Topic sentences should contain evaluative adjectives and phrases to communicate an interpretation - not devices."""@en ;
  dcterms:modified "2026-02-12T08:59:21.737394Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1815-4
  a curric:KeyLearningPoint ;
  rdfs:label "Topic sentences should develop in a sequence, to maintain focus on the argument."@en ;
  dcterms:modified "2026-02-12T08:59:21.737399Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1535-1
  a curric:KeyLearningPoint ;
  rdfs:label """Throughout history, writers have used their skills to take a stand to address social issues."""@en ;
  dcterms:modified "2026-02-12T08:59:21.737605Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1535-2
  a curric:KeyLearningPoint ;
  rdfs:label """Writers also use their skills to express their views with conviction and passion."""@en ;
  dcterms:modified "2026-02-12T08:59:21.737611Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1535-3
  a curric:KeyLearningPoint ;
  rdfs:label """Sometimes a writer taking a stand can have real world benefits by stimulating awareness of an issue."""@en ;
  dcterms:modified "2026-02-12T08:59:21.737617Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1535-4
  a curric:KeyLearningPoint ;
  rdfs:label """Different text types have different strengths when it comes to expressing convictions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.737621Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1535-5
  a curric:KeyLearningPoint ;
  rdfs:label """Writers make specific language choices to express their views strongly and effectively."""@en ;
  dcterms:modified "2026-02-12T08:59:21.737625Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1501-1
  a curric:KeyLearningPoint ;
  rdfs:label """Wartime propaganda was used to encourage recruitment and persuade the population that war was necessary."""@en ;
  dcterms:modified "2026-02-12T08:59:21.737815Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1501-2
  a curric:KeyLearningPoint ;
  rdfs:label """Wartime propaganda promoted the idea that fighting would bring glory upon soldiers."""@en ;
  dcterms:modified "2026-02-12T08:59:21.737819Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1501-3
  a curric:KeyLearningPoint ;
  rdfs:label "Much of World War One was fought in trenches."@en ;
  dcterms:modified "2026-02-12T08:59:21.737823Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1501-4
  a curric:KeyLearningPoint ;
  rdfs:label """Conditions in trenches were appalling: the mud, rats, shelling, gore and inactivity traumatised many soldiers."""@en ;
  dcterms:modified "2026-02-12T08:59:21.737830Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1501-5
  a curric:KeyLearningPoint ;
  rdfs:label "Much war literature attempts to evoke conditions in the trenches."@en ;
  dcterms:modified "2026-02-12T08:59:21.737835Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1868-1
  a curric:KeyLearningPoint ;
  rdfs:label "Topic sentences state a paragraph’s main idea."@en ;
  dcterms:modified "2026-02-12T08:59:21.738946Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1868-2
  a curric:KeyLearningPoint ;
  rdfs:label "Evaluative topic sentences offer a judgement about a character."@en ;
  dcterms:modified "2026-02-12T08:59:21.738950Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1868-3
  a curric:KeyLearningPoint ;
  rdfs:label """You could compare one character to another, or the complexity of a character, to create an evaluative topic sentence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.738953Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1868-4
  a curric:KeyLearningPoint ;
  rdfs:label "Conjunctions can help create an evaluative topic sentence."@en ;
  dcterms:modified "2026-02-12T08:59:21.738957Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1868-5
  a curric:KeyLearningPoint ;
  rdfs:label """You must support your evaluative topic sentence with appropriate evidence from the text."""@en ;
  dcterms:modified "2026-02-12T08:59:21.738961Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1797-1
  a curric:KeyLearningPoint ;
  rdfs:label """Niccolo Machiavelli's 'The Prince’ proposes that in order to get and maintain power you have to be prepared to be evil."""@en ;
  dcterms:modified "2026-02-12T08:59:21.738965Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1797-2
  a curric:KeyLearningPoint ;
  rdfs:label "A Machiavellian villain is scheming and operates in secrecy."@en ;
  dcterms:modified "2026-02-12T08:59:21.738969Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1797-3
  a curric:KeyLearningPoint ;
  rdfs:label """A Machiavellian villain is a 'puppet master’, manipulating and using others as tools."""@en ;
  dcterms:modified "2026-02-12T08:59:21.738973Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1797-4
  a curric:KeyLearningPoint ;
  rdfs:label "Iago reveals his commitment to knavery, through his soliloquies."@en ;
  dcterms:modified "2026-02-12T08:59:21.738977Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-862-1
  a curric:KeyLearningPoint ;
  rdfs:label """A dash can be used to indicate a pause, added emphasis, an interruption, or an abrupt change of thought."""@en ;
  dcterms:modified "2026-02-12T08:59:21.738985Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-862-2
  a curric:KeyLearningPoint ;
  rdfs:label "Dashes can be used to replace brackets or colons."@en ;
  dcterms:modified "2026-02-12T08:59:21.738989Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-862-3
  a curric:KeyLearningPoint ;
  rdfs:label "Commas are used to separate words, clauses or ideas within a sentence."@en ;
  dcterms:modified "2026-02-12T08:59:21.738993Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-862-4
  a curric:KeyLearningPoint ;
  rdfs:label """Colons can be used to connect main clauses, add emphasis to a word or phrase, or introduce an explanation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.738997Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-862-5
  a curric:KeyLearningPoint ;
  rdfs:label "Colons can also be used to introduce lists."@en ;
  dcterms:modified "2026-02-12T08:59:21.739001Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1544-1
  a curric:KeyLearningPoint ;
  rdfs:label "A poem can be turned into song and used to take a stand."@en ;
  dcterms:modified "2026-02-12T08:59:21.739005Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1544-2
  a curric:KeyLearningPoint ;
  rdfs:label "‘Where Have All The Flowers Gone’ is a famous anti-war song."@en ;
  dcterms:modified "2026-02-12T08:59:21.739009Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1544-3
  a curric:KeyLearningPoint ;
  rdfs:label "The song uses a cyclical structure to show the inevitability of war."@en ;
  dcterms:modified "2026-02-12T08:59:21.739013Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1544-4
  a curric:KeyLearningPoint ;
  rdfs:label """The imagery of flowers in the poem reflects the beauty and innocence that is destroyed by war."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739016Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1544-5
  a curric:KeyLearningPoint ;
  rdfs:label """Repetition of “where” and “learn” reinforces the sense of loss and history’s inability to teach us about violence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739021Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1533-1
  a curric:KeyLearningPoint ;
  rdfs:label """Both Naidu and Brooke personify their respective countries but they have different effects on the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739351Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1533-2
  a curric:KeyLearningPoint ;
  rdfs:label """Both Naidu and McCrae utilise natural imagery, but they have different effects on the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739355Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1533-3
  a curric:KeyLearningPoint ;
  rdfs:label """Thinking about poets as being in conversation with one another is a useful way of thinking about a comparative essay."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739359Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1526-1
  a curric:KeyLearningPoint ;
  rdfs:label "Brooke's poem is arguably patriotic - the soldier loves his homeland"@en ;
  dcterms:modified "2026-02-12T08:59:21.739365Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1526-2
  a curric:KeyLearningPoint ;
  rdfs:label """The poem is also quite idealistic - the soldier believes that England is paradise"""@en ;
  dcterms:modified "2026-02-12T08:59:21.739369Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1526-3
  a curric:KeyLearningPoint ;
  rdfs:label """The soldier arguably believes that dying for his country will cleanse his soul of evil"""@en ;
  dcterms:modified "2026-02-12T08:59:21.739373Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1526-4
  a curric:KeyLearningPoint ;
  rdfs:label """The poem was popular at the time of writing, before the realities of war where known"""@en ;
  dcterms:modified "2026-02-12T08:59:21.739377Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1526-5
  a curric:KeyLearningPoint ;
  rdfs:label "Modern readers may find the poem very naive"@en ;
  dcterms:modified "2026-02-12T08:59:21.739381Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28475-1
  a curric:KeyLearningPoint ;
  rdfs:label """Sound is an important feature of slam poetry, it adds to the dynamic and energetic performances."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739385Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28475-2
  a curric:KeyLearningPoint ;
  rdfs:label "Harry Baker uses a refrain to emphasise key ideas and engage the audience."@en ;
  dcterms:modified "2026-02-12T08:59:21.739389Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28475-3
  a curric:KeyLearningPoint ;
  rdfs:label "In his refrain, Baker uses repetition, direct address and exclamatives."@en ;
  dcterms:modified "2026-02-12T08:59:21.739393Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28475-4
  a curric:KeyLearningPoint ;
  rdfs:label """Baker demonstrates that onomatopeia can be effective in slam poems, but needs to be used carefully."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739397Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2002-1
  a curric:KeyLearningPoint ;
  rdfs:label """Sentence level accuracy includes spelling, punctuation, sentence structures, syntax and fluency"""@en ;
  dcterms:modified "2026-02-12T08:59:21.739401Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2002-2
  a curric:KeyLearningPoint ;
  rdfs:label """Re-writing a section of your descriptive writing is important as it shows a good understanding of the feedback"""@en ;
  dcterms:modified "2026-02-12T08:59:21.739404Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2002-3
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to understand where a mistake is, so that it can be avoided in the next piece of descriptive writing"""@en ;
  dcterms:modified "2026-02-12T08:59:21.739408Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28390-1
  a curric:KeyLearningPoint ;
  rdfs:label """A specific success criteria enables you to evaluate how effective a discussion is."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739412Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28390-2
  a curric:KeyLearningPoint ;
  rdfs:label """When giving feedback, it is important to be specific and refer to the success criteria."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739416Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28390-3
  a curric:KeyLearningPoint ;
  rdfs:label """Taking a few moments to mind map the discussion question or topic can help you to make relevant and developed comments."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739420Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1534-1
  a curric:KeyLearningPoint ;
  rdfs:label """A comparative thesis statement introduces the two poems and your overall ideas in relation to the question."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739755Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1534-2
  a curric:KeyLearningPoint ;
  rdfs:label """A comparative topic sentence states the focus of the paragraph and links it back to the thesis statement."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739759Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1534-3
  a curric:KeyLearningPoint ;
  rdfs:label """Comparative conjunctions should be used to compare language, form and structure of poems"""@en ;
  dcterms:modified "2026-02-12T08:59:21.739763Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27920-1
  a curric:KeyLearningPoint ;
  rdfs:label """Descriptions of a setting can help reflect a character's personality, mood or emotions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739767Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27920-2
  a curric:KeyLearningPoint ;
  rdfs:label "Using sensory imagery to describe a setting creates a vivid description."@en ;
  dcterms:modified "2026-02-12T08:59:21.739771Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27920-3
  a curric:KeyLearningPoint ;
  rdfs:label "Tone can be built through the description of a setting."@en ;
  dcterms:modified "2026-02-12T08:59:21.739776Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27920-4
  a curric:KeyLearningPoint ;
  rdfs:label """You can combine the sensory description of a setting and an emotional state of a character to create tone."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739781Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1540-1
  a curric:KeyLearningPoint ;
  rdfs:label """A motif is a repeated idea within a piece of writing, that has symbolic significance."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739785Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1540-2
  a curric:KeyLearningPoint ;
  rdfs:label """Motifs give the opportunity to weave thematic ideas and give another layer of meaning."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739789Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1540-3
  a curric:KeyLearningPoint ;
  rdfs:label "Clinton uses the motif of speech and silence."@en ;
  dcterms:modified "2026-02-12T08:59:21.739793Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1540-4
  a curric:KeyLearningPoint ;
  rdfs:label """The motif suggests women have been silenced and they have not been afforded the freedom and rights of men."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739797Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1984-1
  a curric:KeyLearningPoint ;
  rdfs:label """Our writing should be structured in a clear and logical way with our reader in mind."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739801Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1984-2
  a curric:KeyLearningPoint ;
  rdfs:label "Effective writing will include an introduction, main body and conclusion."@en ;
  dcterms:modified "2026-02-12T08:59:21.739805Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1984-3
  a curric:KeyLearningPoint ;
  rdfs:label """Conclusions can follow a three part structure moving from the specific to the general."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739809Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1984-4
  a curric:KeyLearningPoint ;
  rdfs:label """Our writing should consider the choices a writer makes, and evaluate their intention."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739813Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1566-1
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to understand a text's context, as this enhances our understanding of why it was written."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739819Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1566-2
  a curric:KeyLearningPoint ;
  rdfs:label """To keep focus on the writer’s intentions in your response, ask yourself ‘why’ at each stage in the writing process."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739824Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1566-3
  a curric:KeyLearningPoint ;
  rdfs:label """Victor Frankenstein is characterised as irresponsible to reflect Shelley’s concerns about unethical science."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739829Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1566-4
  a curric:KeyLearningPoint ;
  rdfs:label "A convincing analytical response should follow one line of argument."@en ;
  dcterms:modified "2026-02-12T08:59:21.739834Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1566-5
  a curric:KeyLearningPoint ;
  rdfs:label "Focusing on an author's intention results in stronger analytical writing."@en ;
  dcterms:modified "2026-02-12T08:59:21.739838Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1584-1
  a curric:KeyLearningPoint ;
  rdfs:label "Functional writing that makes use of description is often stronger."@en ;
  dcterms:modified "2026-02-12T08:59:21.739842Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1584-2
  a curric:KeyLearningPoint ;
  rdfs:label """Anecdotes are brilliant for connecting to the reader through creating a shared experience."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739846Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1584-3
  a curric:KeyLearningPoint ;
  rdfs:label """Before writing an anecdote, consider what you want your reader to feel - choose your language accordingly."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739849Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1584-4
  a curric:KeyLearningPoint ;
  rdfs:label """A successful anecdote makes use of language to create vivid imagery for the reader, so they can share the experience."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739855Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1584-5
  a curric:KeyLearningPoint ;
  rdfs:label "Figurative language can be very persuasive when used effectively."@en ;
  dcterms:modified "2026-02-12T08:59:21.739859Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1562-1
  a curric:KeyLearningPoint ;
  rdfs:label """Liminality describes the physical process of crossing across boundaries and borders."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739863Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1562-2
  a curric:KeyLearningPoint ;
  rdfs:label """The Creature is a liminal creature because it is characterised as a living corpse."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739867Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1562-3
  a curric:KeyLearningPoint ;
  rdfs:label """Victor has committed a moral transgression against nature, God and science in creating the Creature."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739871Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1562-4
  a curric:KeyLearningPoint ;
  rdfs:label """Shelley uses the Gothic genre to explore the darker side of humanity and consuming ambition."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739877Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1562-5
  a curric:KeyLearningPoint ;
  rdfs:label """Shelley arguably presents us with the idea that real monsters are not born, but shaped by society or those around them."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739881Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1574-1
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to create tension in Gothic writing because it keeps your reader in a state of anticipation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739885Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1574-2
  a curric:KeyLearningPoint ;
  rdfs:label """Keeping the reader in a state of anticipation makes reading the text a thrilling experience for the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739889Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1574-3
  a curric:KeyLearningPoint ;
  rdfs:label """You can build tension by delaying revealing key information, switching focus or ending with a cliff-hanger."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739892Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1574-4
  a curric:KeyLearningPoint ;
  rdfs:label "Fronted adverbials tell us the way in which something is done."@en ;
  dcterms:modified "2026-02-12T08:59:21.739896Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1574-5
  a curric:KeyLearningPoint ;
  rdfs:label "Fronted adverbials can be used to build tension."@en ;
  dcterms:modified "2026-02-12T08:59:21.739900Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1521-1
  a curric:KeyLearningPoint ;
  rdfs:label "Rhythm is the beat, flow, or pattern of a piece of music or writing."@en ;
  dcterms:modified "2026-02-12T08:59:21.740073Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1521-2
  a curric:KeyLearningPoint ;
  rdfs:label "Writers create rhythm by using a variety of sentence types and punctuation."@en ;
  dcterms:modified "2026-02-12T08:59:21.740077Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1521-3
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials are words or phrases at the beginning of a sentence which describe the action that follows."""@en ;
  dcterms:modified "2026-02-12T08:59:21.740083Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1521-4
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials can help organise writing by explaining how, when or why something happens."""@en ;
  dcterms:modified "2026-02-12T08:59:21.740087Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1521-5
  a curric:KeyLearningPoint ;
  rdfs:label "Fronted adverbials can help create tension."@en ;
  dcterms:modified "2026-02-12T08:59:21.740091Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1853-1
  a curric:KeyLearningPoint ;
  rdfs:label "In Oberon’s and Puck’s first dialogue, Oberon speaks 27 lines and Puck speaks 3."@en ;
  dcterms:modified "2026-02-12T08:59:21.740223Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1853-2
  a curric:KeyLearningPoint ;
  rdfs:label """Oberon commands that Puck get him the magical potion so he can use it on Titania."""@en ;
  dcterms:modified "2026-02-12T08:59:21.740227Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1853-3
  a curric:KeyLearningPoint ;
  rdfs:label "Puck obeys Oberon without question."@en ;
  dcterms:modified "2026-02-12T08:59:21.740230Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1853-4
  a curric:KeyLearningPoint ;
  rdfs:label """When writing about ‘A Midsummer Night’s Dream’, you could link quotations together to develop your ideas."""@en ;
  dcterms:modified "2026-02-12T08:59:21.740236Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1996-1
  a curric:KeyLearningPoint ;
  rdfs:label "A colon is used to introduce a list or to introduce a list or explanation"@en ;
  dcterms:modified "2026-02-12T08:59:21.740240Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1996-2
  a curric:KeyLearningPoint ;
  rdfs:label "A semi-colon is used to separate two main clauses that are linked"@en ;
  dcterms:modified "2026-02-12T08:59:21.740245Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1996-3
  a curric:KeyLearningPoint ;
  rdfs:label "A dash can add extra information about a noun"@en ;
  dcterms:modified "2026-02-12T08:59:21.740248Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1729-1
  a curric:KeyLearningPoint ;
  rdfs:label "Golding aims to provide an incisive insight into human behaviour."@en ;
  dcterms:modified "2026-02-12T08:59:21.740253Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1729-2
  a curric:KeyLearningPoint ;
  rdfs:label """Golding was horrified by the brutality he witnessed during the war, perpetrated by seemingly-ordinary people."""@en ;
  dcterms:modified "2026-02-12T08:59:21.740256Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1729-3
  a curric:KeyLearningPoint ;
  rdfs:label """Golding used children for his exploration of human behaviour, arguably because they are considered innocent."""@en ;
  dcterms:modified "2026-02-12T08:59:21.740260Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1729-4
  a curric:KeyLearningPoint ;
  rdfs:label """Golding suggests that all humans have an innate savageness within, which is suppressed by societal expectations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.740264Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1729-5
  a curric:KeyLearningPoint ;
  rdfs:label """Once these societal expectations are removed, arguably, this savageness is given space to emerge."""@en ;
  dcterms:modified "2026-02-12T08:59:21.740268Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1507-1
  a curric:KeyLearningPoint ;
  rdfs:label "Many writers use vivid description to convey the horrors of the front line."@en ;
  dcterms:modified "2026-02-12T08:59:21.740272Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1507-2
  a curric:KeyLearningPoint ;
  rdfs:label """Beck shows the depth of Alfred’s trauma when the noise and sight of washing transports him back to the front line."""@en ;
  dcterms:modified "2026-02-12T08:59:21.740278Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1507-3
  a curric:KeyLearningPoint ;
  rdfs:label """A vivid description is the result of careful planning and close attention to methods."""@en ;
  dcterms:modified "2026-02-12T08:59:21.740282Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-870-1
  a curric:KeyLearningPoint ;
  rdfs:label "Free writing is designed to help you unleash your creativity."@en ;
  dcterms:modified "2026-02-12T08:59:21.740415Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-870-2
  a curric:KeyLearningPoint ;
  rdfs:label """Revising is where you look at or consider again a piece of writing in order to correct or improve it."""@en ;
  dcterms:modified "2026-02-12T08:59:21.740419Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-870-3
  a curric:KeyLearningPoint ;
  rdfs:label """In order to evoke an emotional response from the reader, you need to carefully consider the words you use."""@en ;
  dcterms:modified "2026-02-12T08:59:21.740423Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-870-4
  a curric:KeyLearningPoint ;
  rdfs:label """Accurate spelling, punctuation and grammar is essential to help your reader understand your writing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.740427Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1860-1
  a curric:KeyLearningPoint ;
  rdfs:label "Oberon is pleased that Titania has fallen in love with Bottom."@en ;
  dcterms:modified "2026-02-12T08:59:21.740537Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1860-2
  a curric:KeyLearningPoint ;
  rdfs:label "Oberon is angry that Puck put the magical potion on the wrong Athenian man."@en ;
  dcterms:modified "2026-02-12T08:59:21.740542Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1860-3
  a curric:KeyLearningPoint ;
  rdfs:label "The relationship between Titania and Bottom is an example of disorder."@en ;
  dcterms:modified "2026-02-12T08:59:21.740548Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1860-4
  a curric:KeyLearningPoint ;
  rdfs:label """For Elizabethans, Titania and Bottom’s relationship would be seen as especially funny because it disrupts the hierarchy."""@en ;
  dcterms:modified "2026-02-12T08:59:21.740552Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1860-5
  a curric:KeyLearningPoint ;
  rdfs:label """Elizabethans believed that everyone had their place in a hierarchical system called The Great Chain of Being."""@en ;
  dcterms:modified "2026-02-12T08:59:21.740556Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1858-1
  a curric:KeyLearningPoint ;
  rdfs:label "In Act 2, Scene 2, Puck tries to fulfil Oberon’s orders but he makes a mistake."@en ;
  dcterms:modified "2026-02-12T08:59:21.740560Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1858-2
  a curric:KeyLearningPoint ;
  rdfs:label """Puck’s mistake creates much confusion and chaos, a key aspect of Shakespearean comedy."""@en ;
  dcterms:modified "2026-02-12T08:59:21.740564Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1858-3
  a curric:KeyLearningPoint ;
  rdfs:label """However, Shakespeare makes it clear that Puck’s mistake is genuine, despite his reputation as a practical joker."""@en ;
  dcterms:modified "2026-02-12T08:59:21.740568Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1858-4
  a curric:KeyLearningPoint ;
  rdfs:label """When writing about ‘A Midsummer Night’s Dream’, link different moments of the play together to deepen your analysis."""@en ;
  dcterms:modified "2026-02-12T08:59:21.740572Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1807-1
  a curric:KeyLearningPoint ;
  rdfs:label """Othello begins the scene in delusion and ends with clarity, demonstrating the impact of Iago's deceit."""@en ;
  dcterms:modified "2026-02-12T08:59:21.741079Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1807-2
  a curric:KeyLearningPoint ;
  rdfs:label """Othello says he "loved" Desdemona "too well", which suggests that he doesn't understand the implications of his actions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.741082Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1807-3
  a curric:KeyLearningPoint ;
  rdfs:label """The negative beliefs about Othello perhaps become a self-fulfilling prophecy by the end of the play"""@en ;
  dcterms:modified "2026-02-12T08:59:21.741086Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1717-1
  a curric:KeyLearningPoint ;
  rdfs:label "Jack creates a breakaway group and some of the boys sneak away to join him."@en ;
  dcterms:modified "2026-02-12T08:59:21.741369Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1717-2
  a curric:KeyLearningPoint ;
  rdfs:label """Jack and what he now calls his "tribe" kill a pig and leave her head as a present for the beast."""@en ;
  dcterms:modified "2026-02-12T08:59:21.741373Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1717-3
  a curric:KeyLearningPoint ;
  rdfs:label "Simon goes into the jungle alone and speaks with the head of the pig."@en ;
  dcterms:modified "2026-02-12T08:59:21.741377Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1717-4
  a curric:KeyLearningPoint ;
  rdfs:label "The head of the pig appears to him as the beast."@en ;
  dcterms:modified "2026-02-12T08:59:21.741381Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1717-5
  a curric:KeyLearningPoint ;
  rdfs:label """The beast tells him that he exists in all people and is the reason that everything is wrong."""@en ;
  dcterms:modified "2026-02-12T08:59:21.741385Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1793-1
  a curric:KeyLearningPoint ;
  rdfs:label """Iago is angry that he has been passed over for promotion, so pretends to love Othello whist plotting his downfall"""@en ;
  dcterms:modified "2026-02-12T08:59:21.741537Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1793-2
  a curric:KeyLearningPoint ;
  rdfs:label """Iago tells Desdemona's father about her secret marriage to Othello which causes trouble but she defends her love for him"""@en ;
  dcterms:modified "2026-02-12T08:59:21.741541Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1793-3
  a curric:KeyLearningPoint ;
  rdfs:label """Iago preys on Othello’s insecurity by planting Desdemona’s handkerchief – false proof of her betrayal - in Cassio’s room"""@en ;
  dcterms:modified "2026-02-12T08:59:21.741545Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1793-4
  a curric:KeyLearningPoint ;
  rdfs:label """Iago manipulates Othello to the point where he murders his wife, as punishment for her supposed unfaithfulness"""@en ;
  dcterms:modified "2026-02-12T08:59:21.741549Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1793-5
  a curric:KeyLearningPoint ;
  rdfs:label "Race and gender are key contextual ideas to consider in the play"@en ;
  dcterms:modified "2026-02-12T08:59:21.741553Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1936-1
  a curric:KeyLearningPoint ;
  rdfs:label """Using clues to predict is a key skill in helping us understand more about a character"""@en ;
  dcterms:modified "2026-02-12T08:59:21.741557Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1936-2
  a curric:KeyLearningPoint ;
  rdfs:label """Predicting could mean using images or quotes as clues to help us make inferences about a character"""@en ;
  dcterms:modified "2026-02-12T08:59:21.741561Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1936-3
  a curric:KeyLearningPoint ;
  rdfs:label """You should use tentative language, evidence, conjunctions and alternative ideas when writing about your predictions"""@en ;
  dcterms:modified "2026-02-12T08:59:21.741565Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1936-4
  a curric:KeyLearningPoint ;
  rdfs:label "Your prediction will be stronger if you provide two pieces of evidence"@en ;
  dcterms:modified "2026-02-12T08:59:21.741569Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1887-1
  a curric:KeyLearningPoint ;
  rdfs:label """'On Aging' was first published in Maya Angelou's 1978 collection of poems, 'And Still I Rise'."""@en ;
  dcterms:modified "2026-02-12T08:59:21.741575Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1887-2
  a curric:KeyLearningPoint ;
  rdfs:label """In 'On Aging', the speaker admits that she has many of the stereotypical signs of aging in a self-deprecating way."""@en ;
  dcterms:modified "2026-02-12T08:59:21.741579Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1887-3
  a curric:KeyLearningPoint ;
  rdfs:label "Although the speaker admits to getting older, she rejects sympathy and help."@en ;
  dcterms:modified "2026-02-12T08:59:21.741583Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1887-4
  a curric:KeyLearningPoint ;
  rdfs:label """Angelou's use of commands and her sentence structures help create a defiant voice."""@en ;
  dcterms:modified "2026-02-12T08:59:21.741586Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1887-5
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, the poem has a wider message about not judging others by their age or appearance."""@en ;
  dcterms:modified "2026-02-12T08:59:21.741590Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-877-1
  a curric:KeyLearningPoint ;
  rdfs:label "Magical-realist texts have a real world setting in which magic happens."@en ;
  dcterms:modified "2026-02-12T08:59:21.741594Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-877-2
  a curric:KeyLearningPoint ;
  rdfs:label """Use the first read of an unseen extract to establish key information about plot, character and setting."""@en ;
  dcterms:modified "2026-02-12T08:59:21.741598Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-877-3
  a curric:KeyLearningPoint ;
  rdfs:label """Next, read more closely to consider the meaning of specific words and phrases and their effects."""@en ;
  dcterms:modified "2026-02-12T08:59:21.741602Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-877-4
  a curric:KeyLearningPoint ;
  rdfs:label "Imperative language means giving commands."@en ;
  dcterms:modified "2026-02-12T08:59:21.741606Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6222-1
  a curric:KeyLearningPoint ;
  rdfs:label """To plan an effective description, you should establish a clear setting using precise imagery."""@en ;
  dcterms:modified "2026-02-12T08:59:21.741610Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6222-2
  a curric:KeyLearningPoint ;
  rdfs:label """When describing show off your ability to use figurative language, varied sentences and punctuation for effect."""@en ;
  dcterms:modified "2026-02-12T08:59:21.741614Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6222-3
  a curric:KeyLearningPoint ;
  rdfs:label """Make sure that your description is well-structured and has a clear sense of direction – a beginning, middle and end."""@en ;
  dcterms:modified "2026-02-12T08:59:21.741618Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1978-1
  a curric:KeyLearningPoint ;
  rdfs:label "Newspaper articles include a headline, subheading, opening, main body and tail."@en ;
  dcterms:modified "2026-02-12T08:59:21.741869Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1978-2
  a curric:KeyLearningPoint ;
  rdfs:label """A clear and interesting introduction should be used to introduce the article's focus."""@en ;
  dcterms:modified "2026-02-12T08:59:21.741872Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1978-3
  a curric:KeyLearningPoint ;
  rdfs:label "Each paragraph should have a clear and distinct focus."@en ;
  dcterms:modified "2026-02-12T08:59:21.741876Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1978-4
  a curric:KeyLearningPoint ;
  rdfs:label """The draugr's death at the end of 'The Twisted Tree' lends itself well to be written about in a newspaper article."""@en ;
  dcterms:modified "2026-02-12T08:59:21.741880Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1978-5
  a curric:KeyLearningPoint ;
  rdfs:label """Planning the content and vocabulary for each paragraph before writing helps to create fluency."""@en ;
  dcterms:modified "2026-02-12T08:59:21.741884Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1572-1
  a curric:KeyLearningPoint ;
  rdfs:label "A semantic field is a set of words that are related in meaning."@en ;
  dcterms:modified "2026-02-12T08:59:21.742038Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1572-2
  a curric:KeyLearningPoint ;
  rdfs:label "Semantic fields can challenge us to use more ambitious vocabulary."@en ;
  dcterms:modified "2026-02-12T08:59:21.742042Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1572-3
  a curric:KeyLearningPoint ;
  rdfs:label "Semantic fields can help us to be less repetitive when selecting our vocabulary."@en ;
  dcterms:modified "2026-02-12T08:59:21.742048Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1572-4
  a curric:KeyLearningPoint ;
  rdfs:label """It can be useful to plan your use of vocabulary (within the semantic field) before you begin writing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742056Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1531-1
  a curric:KeyLearningPoint ;
  rdfs:label """The natural imagery of the poppy and the lark suggests that it's natural to die for your country"""@en ;
  dcterms:modified "2026-02-12T08:59:21.742061Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1531-2
  a curric:KeyLearningPoint ;
  rdfs:label "The euphonic sounds create a soothing tone to the poem"@en ;
  dcterms:modified "2026-02-12T08:59:21.742065Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1531-3
  a curric:KeyLearningPoint ;
  rdfs:label "McCrae uses the imagery of sunlight to represent life and death"@en ;
  dcterms:modified "2026-02-12T08:59:21.742068Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1531-4
  a curric:KeyLearningPoint ;
  rdfs:label """The last lines act as a warning to the reader, saying the dead will never sleep if we do not continue their fight"""@en ;
  dcterms:modified "2026-02-12T08:59:21.742072Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1506-1
  a curric:KeyLearningPoint ;
  rdfs:label "Writers use symbols and motifs to present key themes."@en ;
  dcterms:modified "2026-02-12T08:59:21.742076Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1506-2
  a curric:KeyLearningPoint ;
  rdfs:label "Beck uses the symbol of the canary to explore the theme of sacrifice."@en ;
  dcterms:modified "2026-02-12T08:59:21.742080Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1506-3
  a curric:KeyLearningPoint ;
  rdfs:label "Beck uses the motif of the washing line to explore the theme of trauma."@en ;
  dcterms:modified "2026-02-12T08:59:21.742084Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1884-1
  a curric:KeyLearningPoint ;
  rdfs:label """Angelou was inspired to write 'Caged Bird' after reading a poem called 'Sympathy' by Paul Laurence Dunbar (1872-1906)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742088Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1884-2
  a curric:KeyLearningPoint ;
  rdfs:label """Inspired by Dunbar, Angelou relies on the extended metaphor of a bird in a cage to present discrimination and injustice."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742094Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1884-3
  a curric:KeyLearningPoint ;
  rdfs:label "Like Angelou, you can be inspired by texts you have read."@en ;
  dcterms:modified "2026-02-12T08:59:21.742098Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1884-4
  a curric:KeyLearningPoint ;
  rdfs:label "A single paragraph outline is a way of planning a paragraph."@en ;
  dcterms:modified "2026-02-12T08:59:21.742102Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1884-5
  a curric:KeyLearningPoint ;
  rdfs:label """First and final sentences of a single paragraph outline are written in full; supporting detail is written in note form."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742106Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1582-1
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to consider the first version of your work a first draft and not the finished essay."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742277Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1582-2
  a curric:KeyLearningPoint ;
  rdfs:label """Redrafting your critical writing is just as important as redrafting your creative writing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742283Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1582-3
  a curric:KeyLearningPoint ;
  rdfs:label "A clear and concise essay focuses on the writer’s use of methods."@en ;
  dcterms:modified "2026-02-12T08:59:21.742287Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1582-4
  a curric:KeyLearningPoint ;
  rdfs:label """Successful essays offer a comprehensive explanation and exploration of the effects the writer’s methods."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742291Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1582-5
  a curric:KeyLearningPoint ;
  rdfs:label "Short, embedded quotations make your essay more concise and coherent."@en ;
  dcterms:modified "2026-02-12T08:59:21.742295Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1525-1
  a curric:KeyLearningPoint ;
  rdfs:label """Naidu personifies India as a mother to humanise the soldiers and emphaise that they are someone's son."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742298Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1525-2
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, Naidu uses the poem as a request for Britain to remember the sacrifice of the soldiers."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742302Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1525-3
  a curric:KeyLearningPoint ;
  rdfs:label """The poem is a tribute to the memory of more than one million soldiers from undivided India who had served in WW1."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742306Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1840-1
  a curric:KeyLearningPoint ;
  rdfs:label """You can make connections between the frame story of 'One Thousand and One Nights' and the folktales themselves."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742310Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1840-2
  a curric:KeyLearningPoint ;
  rdfs:label """The frame story and 'The Fisherman and the Jinni' both explore ideas about power."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742314Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1840-3
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, the frame story and 'The Fisherman and the Jinni' show the power of stories over status or physical power."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742320Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1840-4
  a curric:KeyLearningPoint ;
  rdfs:label "Single paragraph outlines are a way of planning an analytical paragraph."@en ;
  dcterms:modified "2026-02-12T08:59:21.742324Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1840-5
  a curric:KeyLearningPoint ;
  rdfs:label """Analytical paragraphs should include a comment on the methods a writer has used to create their work."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742328Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1817-1
  a curric:KeyLearningPoint ;
  rdfs:label "Topic sentences should develop in a sequence, to maintain focus on the argument."@en ;
  dcterms:modified "2026-02-12T08:59:21.742332Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1817-2
  a curric:KeyLearningPoint ;
  rdfs:label """Connotations of words and images should be linked to other examples that either compound or contrast their effect."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742336Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1817-3
  a curric:KeyLearningPoint ;
  rdfs:label """You can use context to evaluate different interpretations and support the overarching argument."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742340Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-868-1
  a curric:KeyLearningPoint ;
  rdfs:label """Use the first read of an unseen extract to establish key information about plot, character and setting."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742344Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-868-2
  a curric:KeyLearningPoint ;
  rdfs:label """After a first read, read a text more closely, considering the meaning of specific words/phrases and their effects."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742347Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-868-3
  a curric:KeyLearningPoint ;
  rdfs:label "Writers deliberately use a range of language techniques to create meaning."@en ;
  dcterms:modified "2026-02-12T08:59:21.742351Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-868-4
  a curric:KeyLearningPoint ;
  rdfs:label "Every idea we have must be clearly supported by evidence from the text."@en ;
  dcterms:modified "2026-02-12T08:59:21.742359Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-869-1
  a curric:KeyLearningPoint ;
  rdfs:label """The atmosphere in literature is the way an author uses setting, objects, or thoughts of characters to create mood."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742842Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-869-2
  a curric:KeyLearningPoint ;
  rdfs:label "The atmosphere can be influenced by sensory and figurative language."@en ;
  dcterms:modified "2026-02-12T08:59:21.742846Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-869-3
  a curric:KeyLearningPoint ;
  rdfs:label "Sensory language is language where some or all of the five senses are evoked."@en ;
  dcterms:modified "2026-02-12T08:59:21.742850Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-869-4
  a curric:KeyLearningPoint ;
  rdfs:label "Figurative language is non-literal wording that adds creativity to your writing."@en ;
  dcterms:modified "2026-02-12T08:59:21.742854Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1812-1
  a curric:KeyLearningPoint ;
  rdfs:label """Race cannot be considered a theme in the same way that jealousy and love are themes but it must be considered."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742858Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1812-2
  a curric:KeyLearningPoint ;
  rdfs:label """Othello's racial identity is undefined but being an outsider makes him vulnerable to Iago's machinations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742862Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1812-3
  a curric:KeyLearningPoint ;
  rdfs:label """Before Othello, Black characters in Elizabethan drama were often villains; the presentation of a noble Moor was new."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742866Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1812-4
  a curric:KeyLearningPoint ;
  rdfs:label """Imagery of black and white, light and dark is regular, suggesting colour is important in the play."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742870Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1833-1
  a curric:KeyLearningPoint ;
  rdfs:label "Achilles is a renowned warrior from Greek mythology."@en ;
  dcterms:modified "2026-02-12T08:59:21.742874Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1833-2
  a curric:KeyLearningPoint ;
  rdfs:label """Patroclus is another character from Greek mythology; he is the closest friend of Achilles."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742878Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1833-3
  a curric:KeyLearningPoint ;
  rdfs:label """Madeline Miller wrote ‘The Song of Achilles’ from the first person perspective of Patroclus."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742883Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1833-4
  a curric:KeyLearningPoint ;
  rdfs:label """To start, Miller focuses on the relationship between Patroclus and his father, and when Patroclus first sees Achilles."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742888Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1833-5
  a curric:KeyLearningPoint ;
  rdfs:label """When annotating a text, you can use a range of symbols and notes to help develop an understanding of the text’s ideas."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742892Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1711-1
  a curric:KeyLearningPoint ;
  rdfs:label """The boys agree to hold meetings and make plans, using the conch as a debating tool."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742896Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1711-2
  a curric:KeyLearningPoint ;
  rdfs:label "The boys realise that nobody knows where they are."@en ;
  dcterms:modified "2026-02-12T08:59:21.742900Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1711-3
  a curric:KeyLearningPoint ;
  rdfs:label "The \"littluns\" are scared of something they call the \"beastie\"."@en ;
  dcterms:modified "2026-02-12T08:59:21.742903Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1711-4
  a curric:KeyLearningPoint ;
  rdfs:label """The boys start a fire that is meant to attract the attention of ships but causes damage."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742907Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1711-5
  a curric:KeyLearningPoint ;
  rdfs:label """Piggy has the greatest knowledge and is the most sensible but the others ignore him and instead act impulsively."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742913Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1992-1
  a curric:KeyLearningPoint ;
  rdfs:label "Atmosphere is the tone or mood of a situation"@en ;
  dcterms:modified "2026-02-12T08:59:21.742919Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1992-2
  a curric:KeyLearningPoint ;
  rdfs:label "Dystopias could have unsettling, bleak and oppressive atmospheres"@en ;
  dcterms:modified "2026-02-12T08:59:21.742924Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1992-3
  a curric:KeyLearningPoint ;
  rdfs:label "Personification is a useful technique for creating a hostile atmosphere"@en ;
  dcterms:modified "2026-02-12T08:59:21.742927Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1992-4
  a curric:KeyLearningPoint ;
  rdfs:label "Make careful verb choices alongside personification"@en ;
  dcterms:modified "2026-02-12T08:59:21.742931Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1851-1
  a curric:KeyLearningPoint ;
  rdfs:label """Annotating a question about ‘A Midsummer Night’s Dream’ ensures you focus on the right topic."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742935Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1851-2
  a curric:KeyLearningPoint ;
  rdfs:label """Dramatic methods are the tools a playwright uses to create their work e.g. characterisation, setting, stage directions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742939Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1851-3
  a curric:KeyLearningPoint ;
  rdfs:label "When writing about the play, you should explore Shakespeare's dramatic methods."@en ;
  dcterms:modified "2026-02-12T08:59:21.742943Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1997-1
  a curric:KeyLearningPoint ;
  rdfs:label """Contrasting settings can be used to show injustice and inequality in a dystopian society"""@en ;
  dcterms:modified "2026-02-12T08:59:21.744007Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1997-2
  a curric:KeyLearningPoint ;
  rdfs:label """Hostile or dilapidated settings are often used to reflect difficulties or discrimination"""@en ;
  dcterms:modified "2026-02-12T08:59:21.744011Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1997-3
  a curric:KeyLearningPoint ;
  rdfs:label "Opulent or luxurious settings are often used to show power and greed"@en ;
  dcterms:modified "2026-02-12T08:59:21.744017Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1997-4
  a curric:KeyLearningPoint ;
  rdfs:label "Semantic fields can help create a setting that has a theme running through it"@en ;
  dcterms:modified "2026-02-12T08:59:21.744021Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1591-1
  a curric:KeyLearningPoint ;
  rdfs:label "'The Raven' and 'The Haunted Palace' are both examples of the Gothic genre."@en ;
  dcterms:modified "2026-02-12T08:59:21.744025Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1591-2
  a curric:KeyLearningPoint ;
  rdfs:label """'The Raven' and 'The Haunted Palace' both feature speakers who are grieving, one for a woman, the other for a house."""@en ;
  dcterms:modified "2026-02-12T08:59:21.744029Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1591-3
  a curric:KeyLearningPoint ;
  rdfs:label """Both 'The Raven' and 'The Haunted Palace' use figurative language such as symbolism to convey emotions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.744033Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1591-4
  a curric:KeyLearningPoint ;
  rdfs:label """Comparing the two poems involves looking at similarities and differences in meaning and linguistic techniques."""@en ;
  dcterms:modified "2026-02-12T08:59:21.744037Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1844-1
  a curric:KeyLearningPoint ;
  rdfs:label "Enjambment is when there is no punctuation at the end of a line of poetry."@en ;
  dcterms:modified "2026-02-12T08:59:21.744041Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1844-2
  a curric:KeyLearningPoint ;
  rdfs:label "You can analyse a poet's use of enjambment."@en ;
  dcterms:modified "2026-02-12T08:59:21.744045Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1844-3
  a curric:KeyLearningPoint ;
  rdfs:label """When analysing a poet's use of enjambment, you should select a clear example and refer to it through quotation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.744049Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1844-4
  a curric:KeyLearningPoint ;
  rdfs:label "You should connect the use of enjambment to specific ideas in the poem."@en ;
  dcterms:modified "2026-02-12T08:59:21.744053Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1930-1
  a curric:KeyLearningPoint ;
  rdfs:label """The poem 'Filter' reveals that home is a place that reflects our authentic selves."""@en ;
  dcterms:modified "2026-02-12T08:59:21.744057Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1930-2
  a curric:KeyLearningPoint ;
  rdfs:label "Subramaniam seems to take pride in her identity as reflected in her home."@en ;
  dcterms:modified "2026-02-12T08:59:21.744060Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1930-3
  a curric:KeyLearningPoint ;
  rdfs:label "Home can reveal our heritage, hobbies and personality."@en ;
  dcterms:modified "2026-02-12T08:59:21.744064Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1930-4
  a curric:KeyLearningPoint ;
  rdfs:label """We can help the reader understand what our home is like by inviting them inside via poetic descriptions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.744068Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1935-1
  a curric:KeyLearningPoint ;
  rdfs:label """Connecting with the audience when reading our poems can make our story more powerful."""@en ;
  dcterms:modified "2026-02-12T08:59:21.744072Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1935-2
  a curric:KeyLearningPoint ;
  rdfs:label """We can use our body language, posture and eye contact to convey certain emotions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.744078Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1935-3
  a curric:KeyLearningPoint ;
  rdfs:label """We can vary the pitch and pace of our voice to convey different emotions and influence the tone of our poem."""@en ;
  dcterms:modified "2026-02-12T08:59:21.744082Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1935-4
  a curric:KeyLearningPoint ;
  rdfs:label """You can trick yourself into feeling more confident about a performance through deep breathing and smiling."""@en ;
  dcterms:modified "2026-02-12T08:59:21.744086Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-867-1
  a curric:KeyLearningPoint ;
  rdfs:label """An analytical question asks you to use evidence from the text to present your ideas."""@en ;
  dcterms:modified "2026-02-12T08:59:21.744090Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-867-2
  a curric:KeyLearningPoint ;
  rdfs:label "A topic sentence should concisely explain the main idea of the paragraph."@en ;
  dcterms:modified "2026-02-12T08:59:21.744094Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-867-3
  a curric:KeyLearningPoint ;
  rdfs:label "Quotations should match the point made by the topic sentence."@en ;
  dcterms:modified "2026-02-12T08:59:21.744098Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-867-4
  a curric:KeyLearningPoint ;
  rdfs:label "Quotations should be embedded in your sentences."@en ;
  dcterms:modified "2026-02-12T08:59:21.744102Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28387-1
  a curric:KeyLearningPoint ;
  rdfs:label """A productive discussion means thinking, listening and speaking clearly to develop it in a meaningful way."""@en ;
  dcterms:modified "2026-02-12T08:59:21.744106Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28387-2
  a curric:KeyLearningPoint ;
  rdfs:label """Listening is an important discussion skill - it helps to create a supportive and respectful environment."""@en ;
  dcterms:modified "2026-02-12T08:59:21.744110Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28387-3
  a curric:KeyLearningPoint ;
  rdfs:label """Active listening means you are completely engaged and focused on what is being delivered to you."""@en ;
  dcterms:modified "2026-02-12T08:59:21.744114Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28387-4
  a curric:KeyLearningPoint ;
  rdfs:label """Using positive body language can help demonstrate active listening and keep you focused on the content being delivered."""@en ;
  dcterms:modified "2026-02-12T08:59:21.744118Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1569-1
  a curric:KeyLearningPoint ;
  rdfs:label """A successful Gothic setting makes the reader feel uneasy and unsettled, but not necessarily frightened."""@en ;
  dcterms:modified "2026-02-12T08:59:21.744198Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1569-2
  a curric:KeyLearningPoint ;
  rdfs:label """A Gothic setting can be created through the use of semantic fields and pathetic fallacy."""@en ;
  dcterms:modified "2026-02-12T08:59:21.744202Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1569-3
  a curric:KeyLearningPoint ;
  rdfs:label "A semantic field is a group of words that all share similar meaning."@en ;
  dcterms:modified "2026-02-12T08:59:21.744206Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1569-4
  a curric:KeyLearningPoint ;
  rdfs:label """Pathetic fallacy is when the weather reflects the mood (often of the main character)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.744210Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1569-5
  a curric:KeyLearningPoint ;
  rdfs:label """Brontë uses these methods in ‘Jane Eyre’ to characterise Lowood as a miserable and oppressive institute."""@en ;
  dcterms:modified "2026-02-12T08:59:21.744214Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1864-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘A Midsummer Night’s Dream’ ends with an epilogue given by the character of Puck."""@en ;
  dcterms:modified "2026-02-12T08:59:21.744346Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1864-2
  a curric:KeyLearningPoint ;
  rdfs:label """Puck’s epilogue breaks the fourth wall and offers to make “amends” for any offence caused by the play."""@en ;
  dcterms:modified "2026-02-12T08:59:21.744350Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1864-3
  a curric:KeyLearningPoint ;
  rdfs:label """Perhaps this epilogue acknowledges some of the fears that Elizabethans had about the potential dangers of the theatre."""@en ;
  dcterms:modified "2026-02-12T08:59:21.744353Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1864-4
  a curric:KeyLearningPoint ;
  rdfs:label """Some Elizabethans believed the theatres were a place of dangerous ideas and atmospheres."""@en ;
  dcterms:modified "2026-02-12T08:59:21.744362Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1576-1
  a curric:KeyLearningPoint ;
  rdfs:label """In descriptions, you can focus on how the scene smells, feels, sounds and tastes, as well as just what it looks like."""@en ;
  dcterms:modified "2026-02-12T08:59:21.744366Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1576-2
  a curric:KeyLearningPoint ;
  rdfs:label "Multi-sensory descriptions make the scene more vivid for your reader."@en ;
  dcterms:modified "2026-02-12T08:59:21.744370Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1576-3
  a curric:KeyLearningPoint ;
  rdfs:label "You can use figurative language to create vivid imagery for the reader."@en ;
  dcterms:modified "2026-02-12T08:59:21.744374Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1576-4
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials can build tension by elongating the sentence and delaying the action."""@en ;
  dcterms:modified "2026-02-12T08:59:21.744378Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1576-5
  a curric:KeyLearningPoint ;
  rdfs:label "To build tension, try describing small details quite comprehensively."@en ;
  dcterms:modified "2026-02-12T08:59:21.744383Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1527-1
  a curric:KeyLearningPoint ;
  rdfs:label "The main themes of the poem are patriotism and nationhood"@en ;
  dcterms:modified "2026-02-12T08:59:21.744387Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1527-2
  a curric:KeyLearningPoint ;
  rdfs:label """Whilst the speaker fears death, he believes that it is right to die for his country"""@en ;
  dcterms:modified "2026-02-12T08:59:21.744392Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1527-3
  a curric:KeyLearningPoint ;
  rdfs:label "The form is a sonnet making it almost like a love letter to England"@en ;
  dcterms:modified "2026-02-12T08:59:21.744396Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1527-4
  a curric:KeyLearningPoint ;
  rdfs:label "England is personified, like a mother figure"@en ;
  dcterms:modified "2026-02-12T08:59:21.744399Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1527-5
  a curric:KeyLearningPoint ;
  rdfs:label "The structure of the poem emphasises the peace that the soldier feels."@en ;
  dcterms:modified "2026-02-12T08:59:21.744403Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1934-1
  a curric:KeyLearningPoint ;
  rdfs:label """A poem about home should clearly express your attitude towards the place you live."""@en ;
  dcterms:modified "2026-02-12T08:59:21.744407Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1934-2
  a curric:KeyLearningPoint ;
  rdfs:label "You can plan structural elements of your poem before you write."@en ;
  dcterms:modified "2026-02-12T08:59:21.744411Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1934-3
  a curric:KeyLearningPoint ;
  rdfs:label "Structure can be used to aid meaning in your poem."@en ;
  dcterms:modified "2026-02-12T08:59:21.744415Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1934-4
  a curric:KeyLearningPoint ;
  rdfs:label "Imagery and figurative language help the reader to visualise where you live."@en ;
  dcterms:modified "2026-02-12T08:59:21.744435Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1934-5
  a curric:KeyLearningPoint ;
  rdfs:label "Poems can be a great vehicle to express your personal story."@en ;
  dcterms:modified "2026-02-12T08:59:21.744440Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1547-1
  a curric:KeyLearningPoint ;
  rdfs:label """Presentations are much more engaging when the speaker does not simply read off a page or memorise word for word."""@en ;
  dcterms:modified "2026-02-12T08:59:21.744444Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1547-2
  a curric:KeyLearningPoint ;
  rdfs:label """Effective cue cards will give just the right amount of information to help to deliver and structure a presentation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.744447Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1547-3
  a curric:KeyLearningPoint ;
  rdfs:label """If you take questions, try and respond with new content rather than repeating parts of the presentation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.744451Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1547-4
  a curric:KeyLearningPoint ;
  rdfs:label "Asking open questions can invite developed responses."@en ;
  dcterms:modified "2026-02-12T08:59:21.744455Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1547-5
  a curric:KeyLearningPoint ;
  rdfs:label "If you are unsure how to answer a question, using tentative phrases can help."@en ;
  dcterms:modified "2026-02-12T08:59:21.744459Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1805-1
  a curric:KeyLearningPoint ;
  rdfs:label """The depths of Iago’s depravity, treachery and cowardice are revealed in his violence towards Cassio and Roderigo."""@en ;
  dcterms:modified "2026-02-12T08:59:21.744577Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1805-2
  a curric:KeyLearningPoint ;
  rdfs:label """Othello's violent speech contrasts poignantly with his declarations of love in Act 1."""@en ;
  dcterms:modified "2026-02-12T08:59:21.744581Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1805-3
  a curric:KeyLearningPoint ;
  rdfs:label """Night symbolises Iago and Othello’s descent into darkness and foreshadows the evil acts to come."""@en ;
  dcterms:modified "2026-02-12T08:59:21.744586Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1814-1
  a curric:KeyLearningPoint ;
  rdfs:label "Iago’s deceit is delivered by manipulation of perception."@en ;
  dcterms:modified "2026-02-12T08:59:21.744590Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1814-2
  a curric:KeyLearningPoint ;
  rdfs:label "Iago defines his role as deceiver in Act 1, Scene 1: ’I am not what I am’."@en ;
  dcterms:modified "2026-02-12T08:59:21.744594Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1814-3
  a curric:KeyLearningPoint ;
  rdfs:label """The language of the play refers to dreams, trances and visions to explore the unreliability of reality."""@en ;
  dcterms:modified "2026-02-12T08:59:21.744599Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1814-4
  a curric:KeyLearningPoint ;
  rdfs:label """Iago performs a role of a director, addressing audience and staging scenes, suggesting how reality can be manipulated."""@en ;
  dcterms:modified "2026-02-12T08:59:21.744603Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1946-1
  a curric:KeyLearningPoint ;
  rdfs:label "Newspaper articles include a headline, subheading, opening, main body and tail."@en ;
  dcterms:modified "2026-02-12T08:59:21.744693Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1946-2
  a curric:KeyLearningPoint ;
  rdfs:label """The crime case within 'The Speckled Band' lends itself well to being written about in a newspaper article."""@en ;
  dcterms:modified "2026-02-12T08:59:21.744701Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1946-3
  a curric:KeyLearningPoint ;
  rdfs:label "When writing a full newspaper article, you must plan each section."@en ;
  dcterms:modified "2026-02-12T08:59:21.744705Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1946-4
  a curric:KeyLearningPoint ;
  rdfs:label """You can use a multiple paragraph outline to plan each section of your newspaper article."""@en ;
  dcterms:modified "2026-02-12T08:59:21.744709Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1871-1
  a curric:KeyLearningPoint ;
  rdfs:label "Topic sentences state a paragraph’s main idea."@en ;
  dcterms:modified "2026-02-12T08:59:21.744831Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1871-2
  a curric:KeyLearningPoint ;
  rdfs:label "Topic sentences should develop and maintain your thesis."@en ;
  dcterms:modified "2026-02-12T08:59:21.744835Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1871-3
  a curric:KeyLearningPoint ;
  rdfs:label "Select main quotations and supporting quotations to include in an essay."@en ;
  dcterms:modified "2026-02-12T08:59:21.744839Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1871-4
  a curric:KeyLearningPoint ;
  rdfs:label """Main quotations should be analysed; supporting quotations don’t need to be analysed."""@en ;
  dcterms:modified "2026-02-12T08:59:21.744843Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1579-1
  a curric:KeyLearningPoint ;
  rdfs:label """The narrator in the story is extremely hubristic, unreliable and unpredictable because he is delusional."""@en ;
  dcterms:modified "2026-02-12T08:59:21.744890Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1579-2
  a curric:KeyLearningPoint ;
  rdfs:label "Poe uses the hubristic and delusional narrator to create suspense."@en ;
  dcterms:modified "2026-02-12T08:59:21.744894Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1579-3
  a curric:KeyLearningPoint ;
  rdfs:label """Poe uses irony to create suspense - the narrator insists that he is not ‘mad’ but his actions suggest otherwise."""@en ;
  dcterms:modified "2026-02-12T08:59:21.744898Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1579-4
  a curric:KeyLearningPoint ;
  rdfs:label """Poe shortens his sentences and uses more expressive punctuation to reflect the narrator’s escalating delusion."""@en ;
  dcterms:modified "2026-02-12T08:59:21.744902Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1579-5
  a curric:KeyLearningPoint ;
  rdfs:label """Poe uses sentence structure and punctuation to build tension in the lead up to the narrator's dramatic confession."""@en ;
  dcterms:modified "2026-02-12T08:59:21.744905Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1857-1
  a curric:KeyLearningPoint ;
  rdfs:label "The magical potion is used twice in Act 2, Scene 2."@en ;
  dcterms:modified "2026-02-12T08:59:21.745049Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1857-2
  a curric:KeyLearningPoint ;
  rdfs:label "Oberon has malicious intentions; Puck is trying to carry out Oberon’s orders."@en ;
  dcterms:modified "2026-02-12T08:59:21.745053Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1857-3
  a curric:KeyLearningPoint ;
  rdfs:label "Lysander falls in love with Helena, who believes Lysander is mocking her."@en ;
  dcterms:modified "2026-02-12T08:59:21.745057Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1857-4
  a curric:KeyLearningPoint ;
  rdfs:label "Titania falls in love with Bottom, and makes him stay with her in the forest."@en ;
  dcterms:modified "2026-02-12T08:59:21.745061Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1857-5
  a curric:KeyLearningPoint ;
  rdfs:label """When writing about ‘A Midsummer Night’s Dream’, connect different moments of the play together."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745065Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1585-1
  a curric:KeyLearningPoint ;
  rdfs:label """You can create an engaging opening by using humour, or creating a shared experience with your reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745069Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1585-2
  a curric:KeyLearningPoint ;
  rdfs:label "In an opinion piece, your message is your opinion."@en ;
  dcterms:modified "2026-02-12T08:59:21.745073Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1585-3
  a curric:KeyLearningPoint ;
  rdfs:label """In an opinion piece, it is important to get the reader onside, so that they are more likely to internalise your message."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745076Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1585-4
  a curric:KeyLearningPoint ;
  rdfs:label """The ending of your opinion piece should bring together the threads of your argument and reinforce your viewpoint."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745080Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1585-5
  a curric:KeyLearningPoint ;
  rdfs:label """You can create an impactful ending by using mirroring and/or leaving your reader with a moral conundrum to consider."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745084Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6225-1
  a curric:KeyLearningPoint ;
  rdfs:label """Voice is how you convey the identity of the writer - readers should have an understanding of who the writer is."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745088Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6225-2
  a curric:KeyLearningPoint ;
  rdfs:label """The writer's viewpoint should be introduced early in the article, but it can be implied."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745092Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6225-3
  a curric:KeyLearningPoint ;
  rdfs:label """Rhetorical devices and descriptions (including figurative language) can be used for effect to support your argument."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745097Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6225-4
  a curric:KeyLearningPoint ;
  rdfs:label "Topic sentence and paragraphs should be used to present arguments."@en ;
  dcterms:modified "2026-02-12T08:59:21.745103Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6225-5
  a curric:KeyLearningPoint ;
  rdfs:label """Paragraph outlines can be very useful in maintaining a cohesive structure for your argument."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745107Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1502-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘Propping Up The Line’ is a short story by Ian Beck written using a third person narrative voice."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745111Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1502-2
  a curric:KeyLearningPoint ;
  rdfs:label """Beck was inspired to write the story to “honour” his grandfather who was gassed in the trenches during World War One."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745115Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1502-3
  a curric:KeyLearningPoint ;
  rdfs:label "Gas attacks killed about three percent of people immediately."@en ;
  dcterms:modified "2026-02-12T08:59:21.745119Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1502-4
  a curric:KeyLearningPoint ;
  rdfs:label """There were long term physical and psychological effects for those who survived gas attacks."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745125Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1502-5
  a curric:KeyLearningPoint ;
  rdfs:label """Many people who write about World War One try to convey the horrors of gas attacks in their work."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745129Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27923-1
  a curric:KeyLearningPoint ;
  rdfs:label """Reviewing your plan before writing can help ensure your written work meets the success criteria."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745500Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27923-2
  a curric:KeyLearningPoint ;
  rdfs:label """Reviewing your writing after you have finished your first draft is an important step in the writing process."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745504Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27923-3
  a curric:KeyLearningPoint ;
  rdfs:label """Editing and improving your work is crucial for the continual development of your written work."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745508Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1927-1
  a curric:KeyLearningPoint ;
  rdfs:label """An anthem is an upbeat song that has importance for a particular group of people."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745512Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1927-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Anthem of the North' is a celebration of Northern England."@en ;
  dcterms:modified "2026-02-12T08:59:21.745516Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1927-3
  a curric:KeyLearningPoint ;
  rdfs:label "Lemn Sissay shows his pride in his region through 'Anthem of the North'."@en ;
  dcterms:modified "2026-02-12T08:59:21.745519Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1927-4
  a curric:KeyLearningPoint ;
  rdfs:label """Sissay may have been particularly grateful to the North because it supported him through his hardships."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745525Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1927-5
  a curric:KeyLearningPoint ;
  rdfs:label """Sissay crafts a powerful stanza through use of direct address and conscious rhyme scheme."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745529Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-865-1
  a curric:KeyLearningPoint ;
  rdfs:label "Drafting is where you write the first version of a piece of writing."@en ;
  dcterms:modified "2026-02-12T08:59:21.745533Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-865-2
  a curric:KeyLearningPoint ;
  rdfs:label """Revising is where you look at or consider again a piece of writing in order to correct or improve it."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745537Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-865-3
  a curric:KeyLearningPoint ;
  rdfs:label """Using a variety of sentence starters is important because it can influence the pace, emphasis or cohesion of a sentence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745541Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-865-4
  a curric:KeyLearningPoint ;
  rdfs:label "You can vary your sentence starters by using adjectives, verbs or adverbs."@en ;
  dcterms:modified "2026-02-12T08:59:21.745545Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-883-1
  a curric:KeyLearningPoint ;
  rdfs:label """Making predictions about a text is useful because it allows you to consider the impact of a writer’s choices."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745549Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-883-2
  a curric:KeyLearningPoint ;
  rdfs:label """You should use the first read through of an unseen text to establish information about plot and characters."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745555Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-883-3
  a curric:KeyLearningPoint ;
  rdfs:label """You should use the second read through of an unseen text to consider the writer’s choices."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745559Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-883-4
  a curric:KeyLearningPoint ;
  rdfs:label """When we read, we must make inferences about a text to help us understand what the author is really saying."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745563Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-858-1
  a curric:KeyLearningPoint ;
  rdfs:label "A complete sentence has a subject, a verb and expresses a complete idea."@en ;
  dcterms:modified "2026-02-12T08:59:21.745567Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-858-2
  a curric:KeyLearningPoint ;
  rdfs:label """A sentence fragment is an incomplete sentence, lacking a subject, verb – or both."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745571Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-858-3
  a curric:KeyLearningPoint ;
  rdfs:label """To correct sentence fragments, identify whether the subject or verb is missing and add it to the sentence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745575Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-858-4
  a curric:KeyLearningPoint ;
  rdfs:label "A complete sentence starts with a capital letter and ends with a full stop."@en ;
  dcterms:modified "2026-02-12T08:59:21.745579Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-858-5
  a curric:KeyLearningPoint ;
  rdfs:label """A subordinate clause is a group of words that is not a complete sentence but adds extra information."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745582Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1542-1
  a curric:KeyLearningPoint ;
  rdfs:label "The Industrial Revolution created great wealth and great poverty."@en ;
  dcterms:modified "2026-02-12T08:59:21.745586Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1542-2
  a curric:KeyLearningPoint ;
  rdfs:label "Young children were used to sweep the chimneys of houses in the growing cities."@en ;
  dcterms:modified "2026-02-12T08:59:21.745590Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1542-3
  a curric:KeyLearningPoint ;
  rdfs:label """Poet William Blake used his writing to took a stand against the exploitation of child workers."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745594Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1542-4
  a curric:KeyLearningPoint ;
  rdfs:label """His poem ‘The Chimney Sweeper’ uses the language of religion and the language of social issues to take a stand."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745598Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1732-1
  a curric:KeyLearningPoint ;
  rdfs:label """Consider the first version of your work a first draft and not the finished essay."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745734Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1732-2
  a curric:KeyLearningPoint ;
  rdfs:label """Redrafting your analytical writing is just as important as redrafting your creative writing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745738Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1732-3
  a curric:KeyLearningPoint ;
  rdfs:label "A clear and concise essay focuses on the writer’s use of methods."@en ;
  dcterms:modified "2026-02-12T08:59:21.745741Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1732-4
  a curric:KeyLearningPoint ;
  rdfs:label """A successful essay offers a comprehensive explanation and exploration of the effects the writer’s methods."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745745Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1732-5
  a curric:KeyLearningPoint ;
  rdfs:label """Asking yourself ‘why’ at each stage in the writing process helps you to maintain a focus on the writer’s intentions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745749Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1886-1
  a curric:KeyLearningPoint ;
  rdfs:label """In 1993, President Bill Clinton asked Angelou to write, and perform, a poem at his inauguration."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745841Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1886-2
  a curric:KeyLearningPoint ;
  rdfs:label """Perhaps President Clinton asked Angelou because of her importance as an American poet and civil rights activist."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745845Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1886-3
  a curric:KeyLearningPoint ;
  rdfs:label """Angelou wrote on 'On the Pulse of the Morning', a poem focusing on America's past, and its future."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745848Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1886-4
  a curric:KeyLearningPoint ;
  rdfs:label """'On the Pulse of the Morning' emphasises the idea that Americans should see each other as equals, and practice kindness."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745852Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1886-5
  a curric:KeyLearningPoint ;
  rdfs:label """Angelou followed a strict writing routine: rising early and working with minimal distractions for a full morning."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745856Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-887-1
  a curric:KeyLearningPoint ;
  rdfs:label """You can use language such as semantic fields to show the contrast between the familiar and the unknown."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745890Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-887-2
  a curric:KeyLearningPoint ;
  rdfs:label "You could use short, simple sentences to show the surprise at the unknown."@en ;
  dcterms:modified "2026-02-12T08:59:21.745894Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-887-3
  a curric:KeyLearningPoint ;
  rdfs:label """You could use compound sentences to show familiarity since you are aware of the relationship between objects."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745898Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1571-1
  a curric:KeyLearningPoint ;
  rdfs:label """It can be useful to take vocabulary from texts you have read to use in your own work."""@en ;
  dcterms:modified "2026-02-12T08:59:21.746011Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1571-2
  a curric:KeyLearningPoint ;
  rdfs:label """Selecting the right vocabulary when trying to create atmosphere is really important - every word counts."""@en ;
  dcterms:modified "2026-02-12T08:59:21.746015Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1571-3
  a curric:KeyLearningPoint ;
  rdfs:label """Use new vocabulary because it is the most specific word and not just because you think it sounds fancy."""@en ;
  dcterms:modified "2026-02-12T08:59:21.746019Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1571-4
  a curric:KeyLearningPoint ;
  rdfs:label """All of the words in a description must ‘fit’ with the atmosphere or impression you are trying to create."""@en ;
  dcterms:modified "2026-02-12T08:59:21.746023Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1514-1
  a curric:KeyLearningPoint ;
  rdfs:label "A topic sentence states the focus for a paragraph."@en ;
  dcterms:modified "2026-02-12T08:59:21.746029Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1514-2
  a curric:KeyLearningPoint ;
  rdfs:label """Including multiple quotations in a main body paragraph from across a text can help strengthen your analysis."""@en ;
  dcterms:modified "2026-02-12T08:59:21.746033Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1514-3
  a curric:KeyLearningPoint ;
  rdfs:label "Exploring the methods a writer has used can help to develop your analysis."@en ;
  dcterms:modified "2026-02-12T08:59:21.746037Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1514-4
  a curric:KeyLearningPoint ;
  rdfs:label "You don’t need to analyse every quotation in the same amount of depth."@en ;
  dcterms:modified "2026-02-12T08:59:21.746041Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1723-1
  a curric:KeyLearningPoint ;
  rdfs:label """Jack is the novel's antagonist because he opposes Ralph both personally and politically."""@en ;
  dcterms:modified "2026-02-12T08:59:21.746045Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1723-2
  a curric:KeyLearningPoint ;
  rdfs:label "Jack arguably represents dictatorial leadership and savagery."@en ;
  dcterms:modified "2026-02-12T08:59:21.746049Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1723-3
  a curric:KeyLearningPoint ;
  rdfs:label """Jack creates and maintains a culture of fear and intimidation, which gives him power and authority."""@en ;
  dcterms:modified "2026-02-12T08:59:21.746053Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1723-4
  a curric:KeyLearningPoint ;
  rdfs:label """Jack repeatedly undermines Ralph, Piggy and the rules of the conch, showing his lack of respect for democracy."""@en ;
  dcterms:modified "2026-02-12T08:59:21.746057Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1723-5
  a curric:KeyLearningPoint ;
  rdfs:label """Jack's devotion to barbarism and savagery illustrates the great cruelty and wickedness man is capable of."""@en ;
  dcterms:modified "2026-02-12T08:59:21.746061Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1845-1
  a curric:KeyLearningPoint ;
  rdfs:label "Reviewing and refining a piece of writing is an important skill in English."@en ;
  dcterms:modified "2026-02-12T08:59:21.746065Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1845-2
  a curric:KeyLearningPoint ;
  rdfs:label """There might be areas of your work that you want to rewrite, focusing on particular areas of weakness."""@en ;
  dcterms:modified "2026-02-12T08:59:21.746069Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1845-3
  a curric:KeyLearningPoint ;
  rdfs:label "Proofreading is the final stage of the writing process."@en ;
  dcterms:modified "2026-02-12T08:59:21.746073Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1845-4
  a curric:KeyLearningPoint ;
  rdfs:label """Proofreading means to read through a piece of written work and correct any errors."""@en ;
  dcterms:modified "2026-02-12T08:59:21.746079Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1845-5
  a curric:KeyLearningPoint ;
  rdfs:label """Strategies like reading aloud, reading backwards or reading with a particular focus can help you proofread successfully."""@en ;
  dcterms:modified "2026-02-12T08:59:21.746083Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1810-1
  a curric:KeyLearningPoint ;
  rdfs:label "Evidence within a paragraph should contain linked moments and quotations."@en ;
  dcterms:modified "2026-02-12T08:59:21.746086Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1810-2
  a curric:KeyLearningPoint ;
  rdfs:label """Moments should be contextualised and linked with connectives, to demonstrate understanding of plot sequencing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.746093Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1810-3
  a curric:KeyLearningPoint ;
  rdfs:label """Connotations of words and images should be linked to other examples that either compound or contrast their effect."""@en ;
  dcterms:modified "2026-02-12T08:59:21.746096Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1810-4
  a curric:KeyLearningPoint ;
  rdfs:label """More sophisticated terms e.g. ‘semantic field’, support commentary on the cumulative effect of language."""@en ;
  dcterms:modified "2026-02-12T08:59:21.746100Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1731-1
  a curric:KeyLearningPoint ;
  rdfs:label "Golding uses the novel to explore the true nature of human beings."@en ;
  dcterms:modified "2026-02-12T08:59:21.746862Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1731-2
  a curric:KeyLearningPoint ;
  rdfs:label """A cohesive argument unpacks one 'big idea' - each paragraph should work with the others to prove the 'big idea'."""@en ;
  dcterms:modified "2026-02-12T08:59:21.746866Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1731-3
  a curric:KeyLearningPoint ;
  rdfs:label """Single paragraph outlines contain a topic sentence, supporting detail and a summary sentence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.746870Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1731-4
  a curric:KeyLearningPoint ;
  rdfs:label """Supporting details should contain quotes, along with the writer's methods, key vocabulary and contextual information."""@en ;
  dcterms:modified "2026-02-12T08:59:21.746874Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1731-5
  a curric:KeyLearningPoint ;
  rdfs:label """A single paragraph outline should be planned for each section of your response and can take up to five minutes to plan."""@en ;
  dcterms:modified "2026-02-12T08:59:21.746878Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1957-1
  a curric:KeyLearningPoint ;
  rdfs:label "You should begin an essay with an introduction that summarises your main ideas"@en ;
  dcterms:modified "2026-02-12T08:59:21.746882Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1957-2
  a curric:KeyLearningPoint ;
  rdfs:label """An introduction should include three sections that move from general ideas to more specific ones"""@en ;
  dcterms:modified "2026-02-12T08:59:21.746888Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1957-3
  a curric:KeyLearningPoint ;
  rdfs:label """A comparative paragraph must include a topic sentence and comparative connectives"""@en ;
  dcterms:modified "2026-02-12T08:59:21.746892Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1957-4
  a curric:KeyLearningPoint ;
  rdfs:label """Quotations should be selected and analysed from both texts to help create a balanced comparison"""@en ;
  dcterms:modified "2026-02-12T08:59:21.746896Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1969-1
  a curric:KeyLearningPoint ;
  rdfs:label "Martha visits Hel in the underworld."@en ;
  dcterms:modified "2026-02-12T08:59:21.746900Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1969-2
  a curric:KeyLearningPoint ;
  rdfs:label """Hel gives Martha a magical cord that could allow her to return the dead to the underworld."""@en ;
  dcterms:modified "2026-02-12T08:59:21.746906Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1969-3
  a curric:KeyLearningPoint ;
  rdfs:label "Martha's mother arrives to help her."@en ;
  dcterms:modified "2026-02-12T08:59:21.746910Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1969-4
  a curric:KeyLearningPoint ;
  rdfs:label "Martha and her mother work together to kill the draugr."@en ;
  dcterms:modified "2026-02-12T08:59:21.746914Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1969-5
  a curric:KeyLearningPoint ;
  rdfs:label "This is the climax of the novel."@en ;
  dcterms:modified "2026-02-12T08:59:21.746918Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1724-1
  a curric:KeyLearningPoint ;
  rdfs:label "Arguably, Simon is characterised as a self-imposed an outsider."@en ;
  dcterms:modified "2026-02-12T08:59:21.747224Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1724-2
  a curric:KeyLearningPoint ;
  rdfs:label """Simon is thoughtful, insightful and spiritual, and has a deep appreciation and respect for all living things."""@en ;
  dcterms:modified "2026-02-12T08:59:21.747228Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1724-3
  a curric:KeyLearningPoint ;
  rdfs:label """Simon's ceremonious burial is arguably symbolic of his close relationship with nature."""@en ;
  dcterms:modified "2026-02-12T08:59:21.747232Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1724-4
  a curric:KeyLearningPoint ;
  rdfs:label "Simon is arguably used as a foil character to Jack - the two are opposites."@en ;
  dcterms:modified "2026-02-12T08:59:21.747241Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1724-5
  a curric:KeyLearningPoint ;
  rdfs:label """Simon's character reminds us that there is innate good in mankind as well as evil  - we don't have to choose savagery."""@en ;
  dcterms:modified "2026-02-12T08:59:21.747245Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1824-1
  a curric:KeyLearningPoint ;
  rdfs:label """The Lady of Shalott is a cursed woman who is confined to a tower on an island just outside Camelot."""@en ;
  dcterms:modified "2026-02-12T08:59:21.747249Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1824-2
  a curric:KeyLearningPoint ;
  rdfs:label """The Lady of Shalott isn't allowed to look out of the tower's window, but sees the outside through a mirror's reflection."""@en ;
  dcterms:modified "2026-02-12T08:59:21.747253Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1824-3
  a curric:KeyLearningPoint ;
  rdfs:label """The Lady of Shalott must weave these reflections into a cloth; if she stops weaving, something terrible will happen."""@en ;
  dcterms:modified "2026-02-12T08:59:21.747257Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1824-4
  a curric:KeyLearningPoint ;
  rdfs:label "One day she looks out of the window in order to see Sir Lancelot."@en ;
  dcterms:modified "2026-02-12T08:59:21.747261Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1824-5
  a curric:KeyLearningPoint ;
  rdfs:label "The curse comes upon her and she dies, found in a boat drifting toward Camelot."@en ;
  dcterms:modified "2026-02-12T08:59:21.747265Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1759-1
  a curric:KeyLearningPoint ;
  rdfs:label """Physical descriptions of characters shouldn't just be a list of what they look like or the clothes they are wearing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.747546Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1759-2
  a curric:KeyLearningPoint ;
  rdfs:label """Physical descriptions of characters should use carefully chosen vocabulary to allow the reader to infer information."""@en ;
  dcterms:modified "2026-02-12T08:59:21.747550Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1759-3
  a curric:KeyLearningPoint ;
  rdfs:label """Linking physical description to a character's personality can make descriptions more effective."""@en ;
  dcterms:modified "2026-02-12T08:59:21.747554Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1759-4
  a curric:KeyLearningPoint ;
  rdfs:label "‘Show not tell’ works on implied meanings."@en ;
  dcterms:modified "2026-02-12T08:59:21.747558Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1577-1
  a curric:KeyLearningPoint ;
  rdfs:label "Editing is the process of making technical corrections to a piece of writing."@en ;
  dcterms:modified "2026-02-12T08:59:21.747634Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1577-2
  a curric:KeyLearningPoint ;
  rdfs:label """Accurate spelling, punctuation and grammar is essential to help your reader understand your writing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.747638Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1577-3
  a curric:KeyLearningPoint ;
  rdfs:label """Revising is where you look at or consider again a piece of writing in order to correct or improve it."""@en ;
  dcterms:modified "2026-02-12T08:59:21.747641Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1577-4
  a curric:KeyLearningPoint ;
  rdfs:label """Using a variety of sentence starters is important because it can influence the pace, emphasis or cohesion of a sentence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.747645Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1577-5
  a curric:KeyLearningPoint ;
  rdfs:label "You can vary your sentence starters by using adjectives, verbs or adverbs."@en ;
  dcterms:modified "2026-02-12T08:59:21.747649Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29487-1
  a curric:KeyLearningPoint ;
  rdfs:label """Armitage wrote ‘Harmonium’ as a response to his memories of church and his relationship with his father."""@en ;
  dcterms:modified "2026-02-12T08:59:21.747653Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29487-2
  a curric:KeyLearningPoint ;
  rdfs:label """Armitage suggests that you should avoid being too sentimental when writing poetry about personal events."""@en ;
  dcterms:modified "2026-02-12T08:59:21.747657Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29487-3
  a curric:KeyLearningPoint ;
  rdfs:label """Instead, you need to think about how the function of a poem is to convey an emotion."""@en ;
  dcterms:modified "2026-02-12T08:59:21.747661Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29487-4
  a curric:KeyLearningPoint ;
  rdfs:label """For him, he wants the emotion to be recognisable to people who may not have had the same experiences."""@en ;
  dcterms:modified "2026-02-12T08:59:21.747665Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1595-1
  a curric:KeyLearningPoint ;
  rdfs:label """The Lord's Prayer, from the King James Bible 1611, contains many words that we still use today."""@en ;
  dcterms:modified "2026-02-12T08:59:21.748449Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1595-2
  a curric:KeyLearningPoint ;
  rdfs:label """Modern technologies have caused us to use abbreviations as part of spoken language."""@en ;
  dcterms:modified "2026-02-12T08:59:21.748453Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1595-3
  a curric:KeyLearningPoint ;
  rdfs:label """New words are created all the time, with generational divides between word usage."""@en ;
  dcterms:modified "2026-02-12T08:59:21.748457Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1515-1
  a curric:KeyLearningPoint ;
  rdfs:label "You could argue that Mansfield is critical of the older generation in ‘The Fly’."@en ;
  dcterms:modified "2026-02-12T08:59:21.748461Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1515-2
  a curric:KeyLearningPoint ;
  rdfs:label """At points, Mansfield seems to present the older generation as complacent, infantile and vacuous."""@en ;
  dcterms:modified "2026-02-12T08:59:21.748465Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1515-3
  a curric:KeyLearningPoint ;
  rdfs:label """These criticisms could stem from the idea that the older generation were not impacted by war as deeply as the younger."""@en ;
  dcterms:modified "2026-02-12T08:59:21.748469Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1515-4
  a curric:KeyLearningPoint ;
  rdfs:label "However, there is no one correct interpretation of ‘The Fly’."@en ;
  dcterms:modified "2026-02-12T08:59:21.748473Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1520-1
  a curric:KeyLearningPoint ;
  rdfs:label "The date, address and greeting are important features of letters."@en ;
  dcterms:modified "2026-02-12T08:59:21.748477Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1520-2
  a curric:KeyLearningPoint ;
  rdfs:label "A recount could balance precise facts with atmospheric details."@en ;
  dcterms:modified "2026-02-12T08:59:21.748481Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1520-3
  a curric:KeyLearningPoint ;
  rdfs:label """A letter concludes with a sign off which could signal your relationship with the person the letter is to."""@en ;
  dcterms:modified "2026-02-12T08:59:21.748485Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1928-1
  a curric:KeyLearningPoint ;
  rdfs:label """'This Poem is Taking Place on Stolen Land' is a poem about the colonisation of Native America."""@en ;
  dcterms:modified "2026-02-12T08:59:21.748489Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1928-2
  a curric:KeyLearningPoint ;
  rdfs:label """Clarke shows her condemnation of Native America's colonisation through the title and the description of the colonisers."""@en ;
  dcterms:modified "2026-02-12T08:59:21.748492Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1928-3
  a curric:KeyLearningPoint ;
  rdfs:label """Clarke laments the devastating effects that colonisation has had on Indigenous populations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.748499Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1928-4
  a curric:KeyLearningPoint ;
  rdfs:label """Clarke ends the poem by emphasising the strength and resilience of Indigenous populations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.748503Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-871-1
  a curric:KeyLearningPoint ;
  rdfs:label """Responding to an image can involve considering what first draws your attention and then zooming in."""@en ;
  dcterms:modified "2026-02-12T08:59:21.748509Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-871-2
  a curric:KeyLearningPoint ;
  rdfs:label "Effective descriptive writing allows the reader to visualise the scene."@en ;
  dcterms:modified "2026-02-12T08:59:21.748514Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-871-3
  a curric:KeyLearningPoint ;
  rdfs:label """Linguistic devices and sentence structures can help the reader to visualise the scene."""@en ;
  dcterms:modified "2026-02-12T08:59:21.748517Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1546-1
  a curric:KeyLearningPoint ;
  rdfs:label "A presentation can be used for a variety of purposes."@en ;
  dcterms:modified "2026-02-12T08:59:21.749214Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1546-2
  a curric:KeyLearningPoint ;
  rdfs:label """It can be useful to sum up your idea in a one sentence statement of the presentation's key message."""@en ;
  dcterms:modified "2026-02-12T08:59:21.749218Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1546-3
  a curric:KeyLearningPoint ;
  rdfs:label "You should be clear about the who, what, when and how of your presentation."@en ;
  dcterms:modified "2026-02-12T08:59:21.749224Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1546-4
  a curric:KeyLearningPoint ;
  rdfs:label """A plan is essential if you are going to write effective content for your presentation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.749229Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1976-1
  a curric:KeyLearningPoint ;
  rdfs:label "Odin is a Norse god who is associated with wisdom, poetry and death."@en ;
  dcterms:modified "2026-02-12T08:59:21.749233Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1976-2
  a curric:KeyLearningPoint ;
  rdfs:label "Odin sacrificed his eye in order to gain metaphorical sight and understanding."@en ;
  dcterms:modified "2026-02-12T08:59:21.749238Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1976-3
  a curric:KeyLearningPoint ;
  rdfs:label "A draugr is an undead creature from Scandinavian folklore."@en ;
  dcterms:modified "2026-02-12T08:59:21.749243Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1976-4
  a curric:KeyLearningPoint ;
  rdfs:label """A draugr is a re-animated corpse that stinks of decay and possesses superhuman strength."""@en ;
  dcterms:modified "2026-02-12T08:59:21.749247Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1976-5
  a curric:KeyLearningPoint ;
  rdfs:label """Burge uses some of the most terrifying elements of Norse mythology to create a frightening villain."""@en ;
  dcterms:modified "2026-02-12T08:59:21.749251Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1563-1
  a curric:KeyLearningPoint ;
  rdfs:label "In Chapter 10, we see Frankenstein confront the Creature aggressively."@en ;
  dcterms:modified "2026-02-12T08:59:21.749770Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1563-2
  a curric:KeyLearningPoint ;
  rdfs:label """Frankenstein regrets creating first Creature, and regrets his decision to begin creating the second one."""@en ;
  dcterms:modified "2026-02-12T08:59:21.749774Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1563-3
  a curric:KeyLearningPoint ;
  rdfs:label """Victor subsequently destroys the second creation, fearing the consequences of unleashing another ‘wretch’."""@en ;
  dcterms:modified "2026-02-12T08:59:21.749778Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1563-4
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, Victor has understood the consequences of his actions and has developed some moral awareness."""@en ;
  dcterms:modified "2026-02-12T08:59:21.749782Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1563-5
  a curric:KeyLearningPoint ;
  rdfs:label "Victor’s regret forces him to take responsibility."@en ;
  dcterms:modified "2026-02-12T08:59:21.749786Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1794-1
  a curric:KeyLearningPoint ;
  rdfs:label "Aristotle prescribed criteria for tragedy and comedy."@en ;
  dcterms:modified "2026-02-12T08:59:21.749790Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1794-2
  a curric:KeyLearningPoint ;
  rdfs:label "Aristotle prescribed unity of time, place and action."@en ;
  dcterms:modified "2026-02-12T08:59:21.749794Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1794-3
  a curric:KeyLearningPoint ;
  rdfs:label """The plot in a tragedy should evoke pity and fear in an audience and end with catharsis."""@en ;
  dcterms:modified "2026-02-12T08:59:21.749798Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1794-4
  a curric:KeyLearningPoint ;
  rdfs:label """A tragic hero - a man of noble standing with a fatal flaw and an error of judgement - must meet a demise."""@en ;
  dcterms:modified "2026-02-12T08:59:21.749802Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1950-1
  a curric:KeyLearningPoint ;
  rdfs:label "The night Julia Stoner dies, there is an awful storm."@en ;
  dcterms:modified "2026-02-12T08:59:21.749806Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1950-2
  a curric:KeyLearningPoint ;
  rdfs:label """Conan Doyle uses pathetic fallacy to create a sinister atmosphere, foreshadowing the threatening force behind her death."""@en ;
  dcterms:modified "2026-02-12T08:59:21.749810Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1950-3
  a curric:KeyLearningPoint ;
  rdfs:label "Conan Doyle also emphasises the fear of both the Stoner sisters."@en ;
  dcterms:modified "2026-02-12T08:59:21.749813Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1950-4
  a curric:KeyLearningPoint ;
  rdfs:label "Quote explosions can help you to gather ideas for analytical writing."@en ;
  dcterms:modified "2026-02-12T08:59:21.749818Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1950-5
  a curric:KeyLearningPoint ;
  rdfs:label """Analytical writing should include single word analysis and conjunctions to justify analysis."""@en ;
  dcterms:modified "2026-02-12T08:59:21.749822Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1953-1
  a curric:KeyLearningPoint ;
  rdfs:label "Sherlock Holmes reveals James McCarthy’s innocence."@en ;
  dcterms:modified "2026-02-12T08:59:21.749826Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1953-2
  a curric:KeyLearningPoint ;
  rdfs:label "John Turner is the perpetrator in the death of Charles McCarthy."@en ;
  dcterms:modified "2026-02-12T08:59:21.749830Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1953-3
  a curric:KeyLearningPoint ;
  rdfs:label """Charles McCarthy is revealed to have manipulated and threatened John Turner his whole life."""@en ;
  dcterms:modified "2026-02-12T08:59:21.749833Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1953-4
  a curric:KeyLearningPoint ;
  rdfs:label """John Turner kills Charles McCarthy because he did not want James McCarthy to marry his daughter."""@en ;
  dcterms:modified "2026-02-12T08:59:21.749837Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1538-1
  a curric:KeyLearningPoint ;
  rdfs:label "When you take a stand, you express your opinion forcefully."@en ;
  dcterms:modified "2026-02-12T08:59:21.749843Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1538-2
  a curric:KeyLearningPoint ;
  rdfs:label """You can support your opinion by using personal experience to make your writing more relatable."""@en ;
  dcterms:modified "2026-02-12T08:59:21.749847Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1538-3
  a curric:KeyLearningPoint ;
  rdfs:label "Expert views will make your writing seem more knowledgeable."@en ;
  dcterms:modified "2026-02-12T08:59:21.749851Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1538-4
  a curric:KeyLearningPoint ;
  rdfs:label "Referring to formal politics can add a sense of urgency to your writing,"@en ;
  dcterms:modified "2026-02-12T08:59:21.749855Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1532-1
  a curric:KeyLearningPoint ;
  rdfs:label "McCrae's use of language and structure creates a soothing, reassuring tone."@en ;
  dcterms:modified "2026-02-12T08:59:21.750286Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1532-2
  a curric:KeyLearningPoint ;
  rdfs:label "Quotations should be selected carefully to match the point of the sentence."@en ;
  dcterms:modified "2026-02-12T08:59:21.750290Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1532-3
  a curric:KeyLearningPoint ;
  rdfs:label "Tentative language should be used throughout."@en ;
  dcterms:modified "2026-02-12T08:59:21.750294Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1532-4
  a curric:KeyLearningPoint ;
  rdfs:label """Concluding sentences should summarise the paragraph and link back to the question."""@en ;
  dcterms:modified "2026-02-12T08:59:21.750299Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1528-1
  a curric:KeyLearningPoint ;
  rdfs:label "Thesis statements introduce the overarching argument."@en ;
  dcterms:modified "2026-02-12T08:59:21.750304Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1528-2
  a curric:KeyLearningPoint ;
  rdfs:label "Topic sentences introduce the focus of the paragraph."@en ;
  dcterms:modified "2026-02-12T08:59:21.750310Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1528-3
  a curric:KeyLearningPoint ;
  rdfs:label """Answers should consider writers' intentions and writers' use of language, form, and structure."""@en ;
  dcterms:modified "2026-02-12T08:59:21.750314Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1925-1
  a curric:KeyLearningPoint ;
  rdfs:label """Comparative and correlative conjunctions are useful when explaining similarities and differences."""@en ;
  dcterms:modified "2026-02-12T08:59:21.750318Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1925-2
  a curric:KeyLearningPoint ;
  rdfs:label """Comparative conjunctions can be used to compare ideas in a sentence and show difference."""@en ;
  dcterms:modified "2026-02-12T08:59:21.750322Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1925-3
  a curric:KeyLearningPoint ;
  rdfs:label """Correlative conjunctions are pairs of words that work together to connect ideas in a sentence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.750328Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1925-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Island Man' and 'Search for My Tongue' both explore immigration, pride and identity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.750332Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1947-1
  a curric:KeyLearningPoint ;
  rdfs:label """A newspaper article has five main sections with their own unique success criteria."""@en ;
  dcterms:modified "2026-02-12T08:59:21.750336Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1947-2
  a curric:KeyLearningPoint ;
  rdfs:label "You can use emotive language in a newspaper article to intrigue the reader."@en ;
  dcterms:modified "2026-02-12T08:59:21.750340Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1947-3
  a curric:KeyLearningPoint ;
  rdfs:label """You need to punctuate quotes correctly using speech marks in a newspaper article."""@en ;
  dcterms:modified "2026-02-12T08:59:21.750343Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1947-4
  a curric:KeyLearningPoint ;
  rdfs:label """You can use a noun appositive in an article to give more information about a person."""@en ;
