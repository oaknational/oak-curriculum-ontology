# ----------------------------------------------------------------------
# Keywords
# ----------------------------------------------------------------------

oakcurric:keyword-prejudice
  a curric:Keyword ;
  schema:name "prejudice"@en ;
  schema:description """preconceived opinions or attitudes towards a person or group, often based on
  stereotypes"""@en ;
  dcterms:modified "2026-06-07T15:30:02.347231Z"^^xsd:dateTime .

oakcurric:keyword-compelling
  a curric:Keyword ;
  schema:name "compelling"@en ;
  schema:description "persuasive, convincing"@en ;
  dcterms:modified "2026-06-07T15:30:02.347236Z"^^xsd:dateTime .

oakcurric:keyword-colloquial
  a curric:Keyword ;
  schema:name "colloquial"@en ;
  schema:description """language commonly used in everyday speech, often specific to a particular
  region or social group"""@en ;
  dcterms:modified "2026-06-07T15:30:02.347241Z"^^xsd:dateTime .

oakcurric:keyword-harmony
  a curric:Keyword ;
  schema:name "harmony"@en ;
  schema:description "how different notes and chords work together"@en ;
  dcterms:modified "2026-06-07T15:30:02.347358Z"^^xsd:dateTime .

oakcurric:keyword-subtle
  a curric:Keyword ;
  schema:name "subtle"@en ;
  schema:description "less obvious; nuanced; complex or understated"@en ;
  dcterms:modified "2026-06-07T15:30:02.347380Z"^^xsd:dateTime .

oakcurric:keyword-redraft
  a curric:Keyword ;
  schema:name "redraft"@en ;
  schema:description """rewriting parts of your work to include missing elements or upgrade the
  quality of your response"""@en ;
  dcterms:modified "2026-06-07T15:30:02.347404Z"^^xsd:dateTime .

oakcurric:keyword-dominant
  a curric:Keyword ;
  schema:name "dominant"@en ;
  schema:description "the fifth note in a scale, or the chord based on that note (chord V)"@en ;
  dcterms:modified "2026-06-07T15:30:02.347419Z"^^xsd:dateTime .

oakcurric:keyword-foreshadow
  a curric:Keyword ;
  schema:name "foreshadow"@en ;
  schema:description "a sign of something that will happen in the future"@en ;
  dcterms:modified "2026-06-07T15:30:02.347526Z"^^xsd:dateTime .

oakcurric:keyword-symbolism
  a curric:Keyword ;
  schema:name "symbolism"@en ;
  schema:description """figurative language where something is used to represent something other
  than its literal meaning"""@en ;
  dcterms:modified "2026-06-07T15:30:02.347530Z"^^xsd:dateTime .

oakcurric:keyword-tragedy
  a curric:Keyword ;
  schema:name "tragedy"@en ;
  schema:description "a play dealing with tragic events and often ends with a death"@en ;
  dcterms:modified "2026-06-07T15:30:02.347535Z"^^xsd:dateTime .

oakcurric:keyword-machiavellian
  a curric:Keyword ;
  schema:name "Machiavellian"@en ;
  schema:description """Machiavellian is an adjective. It describes someone who gets what they want
  in cunning, ruthless and immoral ways."""@en ;
  dcterms:modified "2026-06-07T15:30:02.347544Z"^^xsd:dateTime .

oakcurric:keyword-thesis
  a curric:Keyword ;
  schema:name "Thesis"@en ;
  schema:description """A thesis is an argument, a powerful idea that you state at the beginning of
  an essay and prove throughout your essay."""@en ;
  dcterms:modified "2026-06-07T15:30:02.347552Z"^^xsd:dateTime .

oakcurric:keyword-methods
  a curric:Keyword ;
  schema:name "Methods"@en ;
  schema:description """Methods are techniques a writer uses. These encompass everything: language,
  form, structure and characterisation."""@en ;
  dcterms:modified "2026-06-07T15:30:02.347566Z"^^xsd:dateTime .

oakcurric:keyword-context
  a curric:Keyword ;
  schema:name "Context"@en ;
  schema:description """Context concerns the circumstances in which a text was written; context
  helps us to understand the writer’s intentions further."""@en ;
  dcterms:modified "2026-06-07T15:30:02.347571Z"^^xsd:dateTime .

oakcurric:keyword-literal
  a curric:Keyword ;
  schema:name "literal"@en ;
  schema:description "factual, exact"@en ;
  dcterms:modified "2026-06-07T15:30:02.347601Z"^^xsd:dateTime .

oakcurric:keyword-figurative-language
  a curric:Keyword ;
  schema:name "figurative language"@en ;
  schema:description "non-literal words and phrases which develop a writer’s meaning"@en ;
  dcterms:modified "2026-06-07T15:30:02.347606Z"^^xsd:dateTime .

oakcurric:keyword-tenacious
  a curric:Keyword ;
  schema:name "tenacious"@en ;
  schema:description "to not give up easily"@en ;
  dcterms:modified "2026-06-07T15:30:02.347630Z"^^xsd:dateTime .

oakcurric:keyword-credible
  a curric:Keyword ;
  schema:name "credible"@en ;
  schema:description "convincing, trustworthy, reliable"@en ;
  dcterms:modified "2026-06-07T15:30:02.347637Z"^^xsd:dateTime .

oakcurric:keyword-anecdote
  a curric:Keyword ;
  schema:name "anecdote"@en ;
  schema:description "a short, often funny story, especially about something someone has done"@en ;
  dcterms:modified "2026-06-07T15:30:02.347651Z"^^xsd:dateTime .

oakcurric:keyword-call-to-action
  a curric:Keyword ;
  schema:name "call to action"@en ;
  schema:description "writing that asks or encourages people to take action about a problem"@en ;
  dcterms:modified "2026-06-07T15:30:02.347668Z"^^xsd:dateTime .

oakcurric:keyword-motif
  a curric:Keyword ;
  schema:name "motif"@en ;
  schema:description "a short melodic idea that recurs throughout a piece of music"@en ;
  dcterms:modified "2026-06-07T15:30:02.347684Z"^^xsd:dateTime .

oakcurric:keyword-present
  a curric:Keyword ;
  schema:name "present"@en ;
  schema:description "describes habitual events in the present, e.g. ‘I do’"@en ;
  dcterms:modified "2026-06-07T15:30:02.347769Z"^^xsd:dateTime .

oakcurric:keyword-ambiguous
  a curric:Keyword ;
  schema:name "ambiguous"@en ;
  schema:description "open to more than one interpretation; not having one obvious meaning"@en ;
  dcterms:modified "2026-06-07T15:30:02.347877Z"^^xsd:dateTime .

oakcurric:keyword-resolution
  a curric:Keyword ;
  schema:name "resolution"@en ;
  schema:description "the process of solving or ending a problem or disagreement"@en ;
  dcterms:modified "2026-06-07T15:30:02.347888Z"^^xsd:dateTime .

oakcurric:keyword-evaluate
  a curric:Keyword ;
  schema:name "evaluate"@en ;
  schema:description """to examine something closely and make a judgement about its
  effectiveness"""@en ;
  dcterms:modified "2026-06-07T15:30:02.347900Z"^^xsd:dateTime .

oakcurric:keyword-criteria
  a curric:Keyword ;
  schema:name "criteria"@en ;
  schema:description "the rules or guidelines used to judge or decide something"@en ;
  dcterms:modified "2026-06-07T15:30:02.347905Z"^^xsd:dateTime .

oakcurric:keyword-specific
  a curric:Keyword ;
  schema:name "specific"@en ;
  schema:description "clearly defined, precise or exact"@en ;
  dcterms:modified "2026-06-07T15:30:02.347910Z"^^xsd:dateTime .

oakcurric:keyword-relevant
  a curric:Keyword ;
  schema:name "relevant"@en ;
  schema:description "closely connected or directly related to what is being discussed"@en ;
  dcterms:modified "2026-06-07T15:30:02.347914Z"^^xsd:dateTime .

oakcurric:keyword-grammar
  a curric:Keyword ;
  schema:name "Grammar"@en ;
  schema:description """Grammar refers to the rules about how words change and combine to make
  accurate sentences."""@en ;
  dcterms:modified "2026-06-07T15:30:02.347919Z"^^xsd:dateTime .

oakcurric:keyword-tense
  a curric:Keyword ;
  schema:name "Tense"@en ;
  schema:description """A verb’s tense will tell you whether the action happened in the past,
  present or future."""@en ;
  dcterms:modified "2026-06-07T15:30:02.347923Z"^^xsd:dateTime .

oakcurric:keyword-foreboding
  a curric:Keyword ;
  schema:name "Foreboding"@en ;
  schema:description """A feeling of something bad about to happen can be described as a feeling of
  foreboding."""@en ;
