  schema:description "a theme, image, character or plot element that is used across many texts"@en ;
  dcterms:modified "2026-06-07T15:30:02.423454Z"^^xsd:dateTime .

oakcurric:keyword-presents
  a curric:Keyword ;
  schema:name "Presents"@en ;
  schema:description "Presents means to show something or make something known."@en ;
  dcterms:modified "2026-06-07T15:30:02.423621Z"^^xsd:dateTime .

oakcurric:keyword-implies
  a curric:Keyword ;
  schema:name "Implies"@en ;
  schema:description """To imply something is to communicate an idea or feeling without saying it
  directly."""@en ;
  dcterms:modified "2026-06-07T15:30:02.423627Z"^^xsd:dateTime .

oakcurric:keyword-insinuates
  a curric:Keyword ;
  schema:name "Insinuates"@en ;
  schema:description "To insinuate is to suggest something without directly saying it."@en ;
  dcterms:modified "2026-06-07T15:30:02.423632Z"^^xsd:dateTime .

oakcurric:keyword-portrays
  a curric:Keyword ;
  schema:name "Portrays"@en ;
  schema:description "To portray is to represent or describe something or someone."@en ;
  dcterms:modified "2026-06-07T15:30:02.423637Z"^^xsd:dateTime .

oakcurric:keyword-master
  a curric:Keyword ;
  schema:name "Master"@en ;
  schema:description "A master is someone who has control over others."@en ;
  dcterms:modified "2026-06-07T15:30:02.423643Z"^^xsd:dateTime .

oakcurric:keyword-wronged
  a curric:Keyword ;
  schema:name "Wronged"@en ;
  schema:description """If you have been wronged by someone then they have treated you in an unfair
  or unacceptable way."""@en ;
  dcterms:modified "2026-06-07T15:30:02.423648Z"^^xsd:dateTime .

oakcurric:keyword-imprisonment
  a curric:Keyword ;
  schema:name "Imprisonment"@en ;
  schema:description "If you are imprisoned then you are being held in captivity."@en ;
  dcterms:modified "2026-06-07T15:30:02.423653Z"^^xsd:dateTime .

oakcurric:keyword-rhetorical
  a curric:Keyword ;
  schema:name "rhetorical"@en ;
  schema:description """Rhetorical means speech or writing intended to be effective and influence
  people."""@en ;
  dcterms:modified "2026-06-07T15:30:02.423846Z"^^xsd:dateTime .

# ----------------------------------------------------------------------
# Misconceptions
# ----------------------------------------------------------------------

oakcurric:misconception-evaluating-simply-identifying-whether-something
  a curric:Misconception ;
  curric:statement "Evaluating is about simply identifying whether something is good or bad."@en ;
  curric:correction """The best evaluation will involve looking closely at something, thinking about
  its strengths and weaknesses, and explaining why it works well or not. It’s about making a
  thoughtful judgement based on evidence, not just a simple 'good' or 'bad' label."""@en ;
  dcterms:modified "2026-06-07T15:30:15.083975Z"^^xsd:dateTime .

oakcurric:misconception-first-draft-final-draft
  a curric:Misconception ;
  curric:statement "That the first draft is the final draft."@en ;
  curric:correction """The best writing is achieved through a cycle of initial creation, feedback
  and re-drafting."""@en ;
  dcterms:modified "2026-06-07T15:30:15.083980Z"^^xsd:dateTime .

oakcurric:misconception-adding-bang-crash-end-line
  a curric:Misconception ;
  curric:statement """Adding \"bang\" or \"crash\" to the end of a line or stanza is an effective
  way to use onomatopoeia."""@en ;
  curric:correction """Although onomatopoeia might seem like an easy device to use, it still needs
  careful consderation and crafting to be used effectively and creatively."""@en ;
  dcterms:modified "2026-06-07T15:30:15.084010Z"^^xsd:dateTime .

oakcurric:misconception-poet-experience-actual-fighting-write
  a curric:Misconception ;
  curric:statement "That a poet had to experience actual fighting to write war poetry."@en ;
  curric:correction """Though part of the Royal Navy Volunteer Reserve, Brooke saw no military
  action."""@en ;
  dcterms:modified "2026-06-07T15:30:15.084017Z"^^xsd:dateTime .

oakcurric:misconception-comparative-essays-focus-differences-poems
  a curric:Misconception ;
  curric:statement """That comparative essays should only focus on the differences between
  poems."""@en ;
  curric:correction """The most successful comparative essays focus on both the similarities and the
  differences between the poems."""@en ;
  dcterms:modified "2026-06-07T15:30:15.084022Z"^^xsd:dateTime .

oakcurric:misconception-writing-character-write-everything-know
  a curric:Misconception ;
  curric:statement """If you are writing about a character, you should just write down everything
  you know about them."""@en ;
  curric:correction """When writing about a character, you should consider how you interpret them
  and why. You should explain this main idea in your thesis."""@en ;
  dcterms:modified "2026-06-07T15:30:15.084504Z"^^xsd:dateTime .

oakcurric:misconception-essay-contain-random-ideas-theme
  a curric:Misconception ;
  curric:statement """An essay can contain random ideas about a theme/character as long as they link
  to the question."""@en ;
  curric:correction """Points in an essay should be planned tightly to expand upon and demonstrate
  the thesis statement."""@en ;
  dcterms:modified "2026-06-07T15:30:15.084512Z"^^xsd:dateTime .

oakcurric:misconception-personal-opinions-texts-valid-analysis
  a curric:Misconception ;
  curric:statement "Personal opinions about texts are not valid. Only analysis is valid."@en ;
  curric:correction """Being a student of English can often feel like this. But expressing your
  opinions about your feelings towards a text - those you read in and outside the classroom
  - is very important and just as much a part of the subject of English as analysis."""@en ;
  dcterms:modified "2026-06-07T15:30:15.084541Z"^^xsd:dateTime .

oakcurric:misconception-tension-scary-dangerous-situations
  a curric:Misconception ;
  curric:statement "Tension is only about scary or dangerous situations."@en ;
  curric:correction """While scary or dangerous situations can create tension, tension can also
  arise from emotional conflicts, difficult decisions, or unresolved mysteries. It's about
  keeping readers eager to know what will happen next."""@en ;
  dcterms:modified "2026-06-07T15:30:15.084546Z"^^xsd:dateTime .

oakcurric:misconception-rewriting-improving-responses-waste-time
  a curric:Misconception ;
  curric:statement "Rewriting and improving responses is a waste of time."@en ;
  curric:correction """How does the process of revising and rewriting develop vocabulary use? How
  does rewriting support the writing of future responses?"""@en ;
  dcterms:modified "2026-06-07T15:30:15.084627Z"^^xsd:dateTime .

oakcurric:misconception-students-avoid-short-one-word
  a curric:Misconception ;
  curric:statement """Students should avoid short or one-word sentences in favour of longer, complex
  sentences."""@en ;
  curric:correction """If used correctly, shorter sentences can be great for amending pace and
  giving emphasis to particular parts of a speech."""@en ;
  dcterms:modified "2026-06-07T15:30:15.086171Z"^^xsd:dateTime .

oakcurric:misconception-theme-idea-plot-point-text
  a curric:Misconception ;
  curric:statement "A theme is any idea or plot point in a text."@en ;
  curric:correction """Themes are the most important ideas in a text. There may be multiple. The
  most important themes are the ones that are returned to over and over again, and explored
  in a number of different ways."""@en ;
  dcterms:modified "2026-06-07T15:30:15.086242Z"^^xsd:dateTime .

oakcurric:misconception-mr-woodifield-intentionally-tries-upset
  a curric:Misconception ;
  curric:statement "Mr. Woodifield intentionally tries to upset the boss."@en ;
  curric:correction """Mr. Woodifield seems unaware that he has upset the boss, and his cruelty in
  mentioning his son's grave in Belgium is thoughtless rather than deliberately cruel."""@en ;
  dcterms:modified "2026-06-07T15:30:15.086254Z"^^xsd:dateTime .

oakcurric:misconception-students-think-ralph-doesnt-blow
  a curric:Misconception ;
  curric:statement """Students may think that Ralph doesn't blow the conch to summon the boys back
  because he is afraid of Jack."""@en ;
  curric:correction """Ralph is not afraid of Jack. He is afraid that if he blows the conch and the
  boys don't return, he will have lost his authority."""@en ;
  dcterms:modified "2026-06-07T15:30:15.086266Z"^^xsd:dateTime .

oakcurric:misconception-writers-use-stories-characters-already
  a curric:Misconception ;
  curric:statement """Writers will not use stories or characters that already exist. This is
  copying!"""@en ;
  curric:correction """Storytelling is an ancient form. Many writers and artists are inspired by
  stories that have existed for thousands of years. This is because of their universal
  characters and timeless themes."""@en ;
  dcterms:modified "2026-06-07T15:30:15.086277Z"^^xsd:dateTime .

oakcurric:misconception-long-back-my-answer-put
  a curric:Misconception ;
  curric:statement """As long as I can back up my answer, I can put forward any interpretation of
  the text."""@en ;
  curric:correction """Using tentative language can lead to a more exploratory approach, rather than
  presenting 'right' or 'wrong' interpretations."""@en ;
  dcterms:modified "2026-06-07T15:30:15.086297Z"^^xsd:dateTime .

oakcurric:misconception-once-essay-completed-its-worth
  a curric:Misconception ;
  curric:statement "Once an essay is completed it's not worth thinking about again."@en ;
  curric:correction """How does rewriting support the writing of future responses? Consider the
  strategies, tips and phrases explored. Revisiting our own essays can make feedback become
  really personalised and allow you to work and focus on your own targets."""@en ;
  dcterms:modified "2026-06-07T15:30:15.086544Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-draugr-simply-physical
  a curric:Misconception ;
  curric:statement """Pupils might think that the draugr is simply a physical monster with no deeper
  significance or symbolism."""@en ;
  curric:correction """While the draugr is indeed a fearsome physical entity, it also symbolises
  deeper themes such as death, decay and the persistence of fear. In Norse mythology,
  draugrs are more than just monsters; they embody the fears and anxieties of the living."""@en ;
  dcterms:modified "2026-06-07T15:30:15.086550Z"^^xsd:dateTime .

oakcurric:misconception-students-think-clear-distinction-poetry
  a curric:Misconception ;
  curric:statement """Students may think that there is a very clear distinction between poetry and
  music lyrics."""@en ;
  curric:correction """Encourage students to consider what the poetry and song lyrics have in
  common. For example the use of verses and refrains, as well as the use of figurative
  language, often crosses over."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087969Z"^^xsd:dateTime .

oakcurric:misconception-looking-punctuation-dry-impact-way
  a curric:Misconception ;
  curric:statement """That looking at punctuation is very dry and has no impact on the way you see a
  text or a character."""@en ;
  curric:correction """The way that writers use and play with punctuation can have a profound impact
  on the way we view a text or character's emotions."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087975Z"^^xsd:dateTime .

oakcurric:misconception-iago-simply-villain-unkind-evil
  a curric:Misconception ;
  curric:statement "Iago is simply a villain - unkind and evil."@en ;
  curric:correction """Iago's character as a villain can be looked at through different lenses. One
  is Machiavellian."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087986Z"^^xsd:dateTime .

oakcurric:misconception-compound-sentences-better-simple-sentences
  a curric:Misconception ;
  curric:statement "Compound sentences are better than simple sentences all of the time."@en ;
  curric:correction """Make it explicit to students that sometimes simple sentences can be more
  suitable in their writing; long does not equal better."""@en ;
  dcterms:modified "2026-06-07T15:30:15.088268Z"^^xsd:dateTime .

oakcurric:misconception-paragraphs-focus-one-character-time
  a curric:Misconception ;
  curric:statement "Paragraphs can only focus on one character at a time."@en ;
  curric:correction """Comparing characters can be a useful way to deepen your understanding and
  analysis."""@en ;
  dcterms:modified "2026-06-07T15:30:15.088298Z"^^xsd:dateTime .

oakcurric:misconception-testament-youth-fictional
  a curric:Misconception ;
  curric:statement "'Testament of Youth' is fictional."@en ;
  curric:correction """A memoir is an account of something based on a person's memories. They are
  examples of nonfiction."""@en ;
  dcterms:modified "2026-06-07T15:30:15.089917Z"^^xsd:dateTime .

oakcurric:misconception-director-tells-actors-stand-say
  a curric:Misconception ;
  curric:statement """The director just tells the actors where to stand and how to say their
  lines."""@en ;
  curric:correction """According to Norris, that’s only the simplest description. A director also
  creates an atmosphere of confidence, supports actors, makes key creative decisions, and
  ensures the whole production comes together smoothly."""@en ;
  dcterms:modified "2026-06-07T15:30:15.089939Z"^^xsd:dateTime .

oakcurric:misconception-including-theme-fate-means-characters
  a curric:Misconception ;
  curric:statement """Including the theme of fate means that characters have no choice or control
  over their actions and are simply puppets of destiny."""@en ;
  curric:correction """While fate in 'The Twisted Tree' suggests that certain events and abilities
  are predestined, characters still have the power to make choices that shape their journey."""@en ;
  dcterms:modified "2026-06-07T15:30:15.090714Z"^^xsd:dateTime .

oakcurric:misconception-quotation-main-body-paragraph-analysed
  a curric:Misconception ;
  curric:statement "Every quotation in a main body paragraph should be analysed."@en ;
  curric:correction """Some quotations should be analysed, but others you can simply embed into
  sentences."""@en ;
  dcterms:modified "2026-06-07T15:30:15.091054Z"^^xsd:dateTime .

oakcurric:misconception-students-think-irony-term-used
  a curric:Misconception ;
  curric:statement "Students might think that irony is a term only used in comedy."@en ;
  curric:correction """There is a dark comedy to this story, created through the use of irony,
  whereby the narrator insists that he is not 'mad' but then proceeds to murder and
  dismember an old man simply because he hates one of the old man's eyes."""@en ;
  dcterms:modified "2026-06-07T15:30:15.091071Z"^^xsd:dateTime .

oakcurric:misconception-select-quotes-linguistic-features-talk
  a curric:Misconception ;
  curric:statement """That you should always select quotes with the most linguistic features to talk
  about."""@en ;
  curric:correction "You should select the quote that best matches the point of the sentence."@en ;
  dcterms:modified "2026-06-07T15:30:15.091082Z"^^xsd:dateTime .

oakcurric:misconception-answer-include-interesting-details-text
  a curric:Misconception ;
  curric:statement "That an answer should include all of the interesting details about a text."@en ;
  curric:correction "An answer should only include details that are relevant to the question."@en ;
  dcterms:modified "2026-06-07T15:30:15.091087Z"^^xsd:dateTime .

oakcurric:misconception-students-first-understand-use-parallel
  a curric:Misconception ;
  curric:statement """Students may not at first understand that they must use a parallel sentence
  structure when using correlative conjunctions e.g. Both 'Island Man' uses imagery as well
  as 'Search for My Tongue'."""@en ;
  curric:correction """Model a few sentences with correlative conjunctions to show that parallel
  structures are needed. e.g. Both 'Island Man' and 'Search for My Tongue' use imagery."""@en ;
  dcterms:modified "2026-06-07T15:30:15.091139Z"^^xsd:dateTime .

oakcurric:misconception-newspaper-article-written-same-style
  a curric:Misconception ;
  curric:statement "A newspaper article can be written in the same style as a story retelling."@en ;
  curric:correction """Newspaper articles must have different elements to show they are an article -
  interview quotes and a concise way of writing things are key."""@en ;
  dcterms:modified "2026-06-07T15:30:15.091146Z"^^xsd:dateTime .

oakcurric:misconception-cant-plan-stanza-poem-its
  a curric:Misconception ;
  curric:statement "You can't plan a stanza of a poem. It's not like a paragraph or an essay."@en ;
  curric:correction """Stanzas are like paragraphs. They need structure and focus. Spending time
  planning their methods, vocabulary and ideas make writing the stanza easier."""@en ;
  dcterms:modified "2026-06-07T15:30:15.091151Z"^^xsd:dateTime .

oakcurric:misconception-cant-compare-one-scene-another
  a curric:Misconception ;
  curric:statement "You can't compare one scene to another. You must focus on one at a time."@en ;
  curric:correction """A play is not a sequence of unconnected scenes and characters. They all work
  together to present and explore particular ideas. You should compare characters and scenes
  in order to understand a play, its characters and ideas more deeply."""@en ;
  dcterms:modified "2026-06-07T15:30:15.092073Z"^^xsd:dateTime .

oakcurric:misconception-students-panic-unseen-activities-think
  a curric:Misconception ;
  curric:statement """Students panic about unseen activities and think that there is a 'right' or
  'wrong' answer."""@en ;
  curric:correction """The text is unseen - students are not supposed to be experts on it. They just
  need to read the text and give their opinions about it - any well-evidenced opinion is the
  'right' answer."""@en ;
  dcterms:modified "2026-06-07T15:30:15.092079Z"^^xsd:dateTime .

oakcurric:misconception-students-think-frankenstein-name-creature
  a curric:Misconception ;
  curric:statement "Students think that Frankenstein is the name of the creature."@en ;
  curric:correction """Frankenstein is the name of the scientist who created the hideous creature
  that students are often familiar with."""@en ;
  dcterms:modified "2026-06-07T15:30:15.092101Z"^^xsd:dateTime .

oakcurric:misconception-two-different-presentations-achilles-one
  a curric:Misconception ;
  curric:statement """We have two different presentations of Achilles. One of them must be right,
  and one must be wrong."""@en ;
  curric:correction """What Miller and Barker do with their novels is show how important perspective
  is. For Patroclus, Achilles is awe inspiring and innocent. For Briseis, he is quite the
  opposite. Their perspectives are based on their relationship with him."""@en ;
  dcterms:modified "2026-06-07T15:30:15.092115Z"^^xsd:dateTime .

oakcurric:misconception-long-planned-argument-your-essay
  a curric:Misconception ;
  curric:statement """As long as you have planned the argument of your essay, you are ready to write
  it."""@en ;
  curric:correction """Planning topic sentences to go with your argument is also important to ensure
  that your essay is focused on proving the argument."""@en ;
  dcterms:modified "2026-06-07T15:30:15.092123Z"^^xsd:dateTime .

oakcurric:misconception-queenie-bernards-relationship-marriage-convenience
  a curric:Misconception ;
  curric:statement "That Queenie and Bernard's relationship is only a marriage of convenience."@en ;
  curric:correction """How do Queenie and Bernard interact with each other? Can you find any clues
  where love or affection might be present?"""@en ;
  dcterms:modified "2026-06-07T15:30:15.092140Z"^^xsd:dateTime .

oakcurric:misconception-introductions-conclusions-arent-important
  a curric:Misconception ;
  curric:statement "Introductions and conclusions aren't important."@en ;
  curric:correction """An effective introduction means you can impress your reader from the outset
  and clearly layout your overarching argument for your essay."""@en ;
  dcterms:modified "2026-06-07T15:30:15.092146Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-symbols-novel-one
  a curric:Misconception ;
  curric:statement "Pupils might think symbols in the novel have only one clear meaning."@en ;
  curric:correction """Explain that symbols often have multiple meanings. For example, Martha's
  blindness can represent family secrets, vulnerability and hidden truths. Encourage looking
  for different interpretations."""@en ;
  dcterms:modified "2026-06-07T15:30:15.092163Z"^^xsd:dateTime .

oakcurric:misconception-used-rhetorical-devices-one-possible
  a curric:Misconception ;
  curric:statement "When used, rhetorical devices have only one possible effect or outcome."@en ;
  curric:correction """Writers can craft rhetorical devices to create different tones and match
  their purpose, audience and form. For example, direct address can be used to sound
  confrontational or it can create an intimate and personal tone."""@en ;
  dcterms:modified "2026-06-07T15:30:15.092182Z"^^xsd:dateTime .

oakcurric:misconception-pupils-fail-recognise-ralphs-role
  a curric:Misconception ;
  curric:statement "Pupils often fail to recognise Ralph's role in the ostracism of Piggy."@en ;
  curric:correction """Ralph is the first person to ostracise Piggy, by banning him from
  accompanying the boys on their expedition. He also calls Piggy by the name he begged Ralph
  not to use - Piggy. Once Jack senses Piggy's vulnerability within the group, he exploits
  it."""@en ;
  dcterms:modified "2026-06-07T15:30:15.092777Z"^^xsd:dateTime .

oakcurric:misconception-debate-argue-stance-truly-believe
  a curric:Misconception ;
  curric:statement "In a debate you can only argue a stance you truly believe in."@en ;
  curric:correction """Part of the skill of debating is being able to create, justify and
  convincingly present an argument that might not reflect your own personal viewpoint."""@en ;
  dcterms:modified "2026-06-07T15:30:15.092788Z"^^xsd:dateTime .

oakcurric:misconception-rhetorical-devices-used-randomly-throughout
  a curric:Misconception ;
  curric:statement """Rhetorical devices can be used randomly throughout work with little
  thought."""@en ;
  curric:correction """Show that rhetorical devices have to be used for precise effect otherwise
  there is no point in using them."""@en ;
  dcterms:modified "2026-06-07T15:30:15.092794Z"^^xsd:dateTime .

oakcurric:misconception-life-doesnt-frighten-me-saying
  a curric:Misconception ;
  curric:statement "'Life Doesn't Frighten Me' is saying that life isn't scary."@en ;
  curric:correction """The poem lists many scary and frightening things. It presents some of the
  world's dangers. The speaker, however, is not frightened of life despite these dangers."""@en ;
  dcterms:modified "2026-06-07T15:30:15.092802Z"^^xsd:dateTime .

oakcurric:misconception-describe-light-two-dimensional-way
  a curric:Misconception ;
  curric:statement "You can only describe light in a two-dimensional way."@en ;
  curric:correction """There are many ways to describe light to have an effect. You can talk about
  the dawn, the twilight or the way the light gleams or flickers in order to influence the
  reader's perception."""@en ;
  dcterms:modified "2026-06-07T15:30:15.092811Z"^^xsd:dateTime .

oakcurric:misconception-thesis-statement-needs-focus-one
  a curric:Misconception ;
  curric:statement "A thesis statement only needs to focus on one part of the book."@en ;
  curric:correction """A thesis statement should address the overarching argument of your essay,
  which means it needs to consider the entire text."""@en ;
  dcterms:modified "2026-06-07T15:30:15.092821Z"^^xsd:dateTime .

oakcurric:misconception-students-understand-depth-meaning-symbolism
  a curric:Misconception ;
  curric:statement """Students often do not understand the depth of meaning that symbolism can
  provide."""@en ;
  curric:correction """Symbols communicate hidden or deeper meanings to the reader, so that they can
  better understand the characters or themes of the text."""@en ;
  dcterms:modified "2026-06-07T15:30:15.093714Z"^^xsd:dateTime .

oakcurric:misconception-pupils-mistake-dystopia-utopia-words
  a curric:Misconception ;
  curric:statement "Pupils may mistake dystopia and utopia as the words are similar"@en ;
  curric:correction """Explicitly explain the difference between the two and explain that they are
  antonyms"""@en ;
  dcterms:modified "2026-06-07T15:30:15.093725Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-doesnt-matter-paragraphs
  a curric:Misconception ;
  curric:statement """Some pupils might think it doesn't always matter where paragraphs go as long
  as the text is broken up in places."""@en ;
  curric:correction """Effective paragraphing is important to the reader's experience of the text.
  It helps them to follow what they're reading more easily and well crafted paragraphs allow
  the writer to reveal information in a way that suits their writing best."""@en ;
  dcterms:modified "2026-06-07T15:30:15.093739Z"^^xsd:dateTime .

oakcurric:misconception-section-five-part-narrative-structure
  a curric:Misconception ;
  curric:statement """Each section of the five part narrative structure equals one paragraph in your
  writing."""@en ;
  curric:correction """The five part narrative structure is a helpful way to help plan plot and
  character. However, some sections might be longer than others. Some might require multiple
  paragraphs, others just one."""@en ;
  dcterms:modified "2026-06-07T15:30:15.093752Z"^^xsd:dateTime .

oakcurric:misconception-sherlock-holmes-mystery-stories-almost
  a curric:Misconception ;
  curric:statement "Sherlock Holmes mystery stories are almost identical."@en ;
  curric:correction """Whilst all Sherlock Holmes mystery stories are part of the detective fiction
  genre, the stories can differ a lot."""@en ;
  dcterms:modified "2026-06-07T15:30:15.093763Z"^^xsd:dateTime .

oakcurric:misconception-ending-happy-because-everything-works
  a curric:Misconception ;
  curric:statement """The ending is happy because everything works out perfectly and offers hope for
  the future."""@en ;
  curric:correction """Edmundson says the ending is hopeful, but not perfect. There’s pain, loss,
  and compromise (Queenie gives up her baby), but real progress comes from facing reality
  with care and honesty."""@en ;
  dcterms:modified "2026-06-07T15:30:15.093777Z"^^xsd:dateTime .

oakcurric:misconception-windrush-generation-entered-britain-illegally
  a curric:Misconception ;
  curric:statement "The Windrush generation entered Britain illegally."@en ;
  curric:correction "Those coming from the British Commonwealth were considered citizens."@en ;
  dcterms:modified "2026-06-07T15:30:15.093783Z"^^xsd:dateTime .

oakcurric:misconception-fairy-tales-written-solely-children
  a curric:Misconception ;
  curric:statement "Fairy tales are written solely for children."@en ;
  curric:correction """Fairy tales are primarily stories about transformation and therefore this
  form appeals to many writers, especially those who are interested in social issues."""@en ;
  dcterms:modified "2026-06-07T15:30:15.093841Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-island-presented-idyllic
  a curric:Misconception ;
  curric:statement "Pupils think that the island is presented as idyllic in the first chapter."@en ;
  curric:correction """Whilst there are aspects of the description that present the island as
  idyllic, Golding's descriptions are characterised by a sense of threat in more ominous
  undertones. He achieves this through his use of dark and light and through his use of
  verbs."""@en ;
  dcterms:modified "2026-06-07T15:30:15.094418Z"^^xsd:dateTime .

oakcurric:misconception-lots-students-realise-novel-actually
  a curric:Misconception ;
  curric:statement """Lots of students do not realise that this novel was actually inspired by an
  earlier, 19th century novel called 'Coral Island' by Ballantyne."""@en ;
  curric:correction """Golding uses the established genre and subverts its conventions to create a
  horrifying exploration of what evil truly is and where it comes from."""@en ;
  dcterms:modified "2026-06-07T15:30:15.094426Z"^^xsd:dateTime .

oakcurric:misconception-once-used-image-idea-piece
  a curric:Misconception ;
  curric:statement """Once you have used an image or idea in a piece of writing, you can't reuse it
  in the same piece."""@en ;
  curric:correction """Sometimes repeating an idea or image throughout a piece can help give it a
  sense of structure. You might change certain details, but you can repeat them."""@en ;
  dcterms:modified "2026-06-07T15:30:15.094432Z"^^xsd:dateTime .

oakcurric:misconception-select-one-quotation-text-comparative
  a curric:Misconception ;
  curric:statement "You should select one quotation from each text in a comparative paragraph."@en ;
  curric:correction """Like in a powerful analytical paragraph, selecting multiple quotations from
  each text will help strengthen your argument. Selecting these quotations in the planning
  stage is key."""@en ;
  dcterms:modified "2026-06-07T15:30:15.094438Z"^^xsd:dateTime .

oakcurric:misconception-students-constantly-changing-pitch-their
  a curric:Misconception ;
  curric:statement """That students should constantly be changing the pitch of their voice when
  speaking."""@en ;
  curric:correction """Pitch is an effective tool when delivering speeches. It should be used to
  make a speech more engaging and shouldn't be used arbitrarily."""@en ;
  dcterms:modified "2026-06-07T15:30:15.095143Z"^^xsd:dateTime .

oakcurric:misconception-war-poetry-designed-dissuade-people
  a curric:Misconception ;
  curric:statement "That all war poetry is designed to dissuade people from fighting."@en ;
  curric:correction "Pro-war poetry is designed to encourage people to volunteer to fight."@en ;
  dcterms:modified "2026-06-07T15:30:15.095148Z"^^xsd:dateTime .

oakcurric:misconception-pupils-get-nervous-perfom-find
  a curric:Misconception ;
  curric:statement """Pupils get too nervous to perfom and find public speaking really daunting so
  they can't do it."""@en ;
  curric:correction """Even the most confident speakers feel nervous! It is completely natural to
  feel nervous when public speaking. Practising and using specfic strategies will mean they
  will gradually begin to understand how to work with them."""@en ;
  dcterms:modified "2026-06-07T15:30:15.095159Z"^^xsd:dateTime .

oakcurric:misconception-angelous-poem-unstructured-stanzas-uneven
  a curric:Misconception ;
  curric:statement """Angelou's poem is unstructured - the stanzas are uneven and she talks about
  lots of different things."""@en ;
  curric:correction """Every piece of writing has a structure - even a shopping list. Structure is
  about the how a text is put together - at its most simple, beginning, middle and end. But
  we can also look for other structural features. In this case, stanzas and a refrain."""@en ;
  dcterms:modified "2026-06-07T15:30:15.095167Z"^^xsd:dateTime .

oakcurric:misconception-cant-prepare-discussions-its-really
  a curric:Misconception ;
  curric:statement """You can't prepare for discussions, so it's not really something you can
  practise."""@en ;
  curric:correction """Just like writing, you can learn phrases and strategies that can help you to
  respond and develop comments in a discussion, especially when offering evidence. These can
  help you feel more prepared in discussion scenarios."""@en ;
  dcterms:modified "2026-06-07T15:30:15.095173Z"^^xsd:dateTime .

oakcurric:misconception-introductions-same-thesis-statements
  a curric:Misconception ;
  curric:statement "Introductions are the same as thesis statements."@en ;
  curric:correction """An introduction includes a thesis statement. However, an introduction should
  include a more general statement about the text, as well as a more general statement about
  the given character or theme as well as the thesis."""@en ;
  dcterms:modified "2026-06-07T15:30:15.095908Z"^^xsd:dateTime .

oakcurric:misconception-ever-consider-one-shakespearean-play
  a curric:Misconception ;
  curric:statement """You should only ever consider one Shakespearean play at a time. Comparing
  plays and characters is irrelevant and confusing."""@en ;
  curric:correction """Comparing characters can be an excellent way to deepen your understanding of
  Shakespeare as a writer, and to understand the significance of how a particular character
  has been created."""@en ;
  dcterms:modified "2026-06-07T15:30:15.095916Z"^^xsd:dateTime .

oakcurric:misconception-conan-doyle-creates-scary-atmosphere
  a curric:Misconception ;
  curric:statement """Conan Doyle creates a scary atmosphere all the way through 'The Speckled
  Band'."""@en ;
  curric:correction """If you look carefully, Conan Doyle carefully alters the atmosphere in order
  to build tension in the reader."""@en ;
  dcterms:modified "2026-06-07T15:30:15.095924Z"^^xsd:dateTime .

oakcurric:misconception-fixed-setting-act-2-means
  a curric:Misconception ;
  curric:statement "The fixed setting in Act 2 means the play is less interesting or creative."@en ;
  curric:correction """The fixed setting in Act 2 shows how the characters feel trapped or confined
  by their situations, which makes the story more powerful and emotional."""@en ;
  dcterms:modified "2026-06-07T15:30:15.095930Z"^^xsd:dateTime .

oakcurric:misconception-gothic-literature-horror-scary-elements
  a curric:Misconception ;
  curric:statement "Gothic literature is only about horror and scary elements."@en ;
  curric:correction """While Gothic literature often includes elements of horror, such as
  supernatural occurrences and eerie settings, it also explores complex themes like human
  psychology, societal anxieties and the supernatural as a metaphor for deeper fears or
  desires."""@en ;
  dcterms:modified "2026-06-07T15:30:15.095938Z"^^xsd:dateTime .

oakcurric:misconception-magical-potion-removed-everyones-eyes
  a curric:Misconception ;
  curric:statement "The magical potion is removed from everyone's eyes at the end of the play."@en ;
  curric:correction """Demetrius still has the magical potion on his eyes. This is why he is in love
  with Helena."""@en ;
  dcterms:modified "2026-06-07T15:30:15.096374Z"^^xsd:dateTime .

oakcurric:misconception-living-britain-world-war-one
  a curric:Misconception ;
  curric:statement """Those living in Britain during World War One faced no threat or privation
  other than their loved ones being far away."""@en ;
  curric:correction """World War One was what is known as 'total war' meaning that those in Britain
  felt its impact in their day to day life."""@en ;
  dcterms:modified "2026-06-07T15:30:15.096379Z"^^xsd:dateTime .

oakcurric:misconception-skimming-scanning-means-arent-reading
  a curric:Misconception ;
  curric:statement "Skimming and scanning means you just aren't reading a text properly."@en ;
  curric:correction """Reading is a skill and, often it is good not to dive into its most difficult
  skill - analysis - immediately. Instead, giving yourself some time with the text, its
  title and overall ideas can allow for a deeper understanding in the long run."""@en ;
  dcterms:modified "2026-06-07T15:30:15.096394Z"^^xsd:dateTime .

oakcurric:misconception-students-use-sentence-fragments-their
  a curric:Misconception ;
  curric:statement "Students may use sentence fragments in their work"@en ;
  curric:correction """Showing exactly how sentence fragments obscure meaning and explaining why
  they should not be used"""@en ;
  dcterms:modified "2026-06-07T15:30:15.096399Z"^^xsd:dateTime .

oakcurric:misconception-persona-same-writer
  a curric:Misconception ;
  curric:statement "That the persona is the same as the writer."@en ;
  curric:correction """Emphasise the difference. Draw attention to the different personas in 'The
  Haunted Palace' and 'The Raven'. Same writer, different personas."""@en ;
  dcterms:modified "2026-06-07T15:30:15.096405Z"^^xsd:dateTime .

oakcurric:misconception-details-crime-reported-part-article
  a curric:Misconception ;
  curric:statement "Details of a crime can be reported in any part of an article."@en ;
  curric:correction """Explain to students that more and more information is revealed as an article
  develops."""@en ;
  dcterms:modified "2026-06-07T15:30:15.096413Z"^^xsd:dateTime .

oakcurric:misconception-people-born-britain-part-british
  a curric:Misconception ;
  curric:statement """That only people born in Britain were part of the British Army that fought in
  WWII."""@en ;
  curric:correction """The British Army contained a huge number of soldiers from different
  countries. For example, over two and a half million men from the Indian subcontinent
  volunteered for service, producing the largest volunteer army in history."""@en ;
  dcterms:modified "2026-06-07T15:30:15.096419Z"^^xsd:dateTime .

oakcurric:misconception-pathetic-fallacy-used-give-emotion
  a curric:Misconception ;
  curric:statement "That pathetic fallacy can only be used to give emotion to the weather."@en ;
  curric:correction """Pathetic fallacy is where human emotions are given to any non-human object or
  thing."""@en ;
  dcterms:modified "2026-06-07T15:30:15.096424Z"^^xsd:dateTime .

oakcurric:misconception-using-one-quotation-per-paragraph
  a curric:Misconception ;
  curric:statement "Using one quotation per paragraph is enough."@en ;
  curric:correction """Using multiple quotations per paragraph can be effective if you select
  quotations which link. Select quotations from across the text."""@en ;
  dcterms:modified "2026-06-07T15:30:15.097013Z"^^xsd:dateTime .

oakcurric:misconception-students-think-using-lots-pronoun
  a curric:Misconception ;
  curric:statement """Students think that using lots of the pronoun 'you' is an effective use of
  direct address. They tend to do this a lot in rhetorical questions."""@en ;
  curric:correction """Using 'you' too many times can create an accusatory tone that can actually
  make the reader defensive. Sometimes, it can be better to approach direct address more
  subtly, by speaking to an imagined reader or addressing the readers collectively."""@en ;
  dcterms:modified "2026-06-07T15:30:15.097019Z"^^xsd:dateTime .

oakcurric:misconception-students-think-creature-something-terrify
  a curric:Misconception ;
  curric:statement """Students often think that the Creature did something to terrify/hurt
  Victor."""@en ;
  curric:correction """Victor takes an instant dislike to the Creature because of its ugliness.
  Victor shuns the Creature immediately, purely because of its looks."""@en ;
  dcterms:modified "2026-06-07T15:30:15.097027Z"^^xsd:dateTime .

oakcurric:misconception-writing-third-person-cant-know
  a curric:Misconception ;
  curric:statement """If you are writing in third person, then you can't know the internal feelings
  of characters because you are not inside their head."""@en ;
  curric:correction """Writers that use a third person narrative voice can still explore and present
  the internal thoughts and feelings of one or more of their characters. You can develop
  their psychology without having to use the pronoun 'I'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.097035Z"^^xsd:dateTime .

oakcurric:misconception-students-think-complex-sentences-superior
  a curric:Misconception ;
  curric:statement "Students may think that complex sentences are superior to other sentences."@en ;
  curric:correction "Show the effect of all sentences working in harmony via a model."@en ;
  dcterms:modified "2026-06-07T15:30:15.097041Z"^^xsd:dateTime .

oakcurric:misconception-desdemona-conforms-jacobean-stereotypes-throughout
  a curric:Misconception ;
  curric:statement "Desdemona conforms to Jacobean stereotypes throughout the play."@en ;
  curric:correction """Desdemona's character changes throughout the play - it is only at the end
  that she seems to conform."""@en ;
  dcterms:modified "2026-06-07T15:30:15.097047Z"^^xsd:dateTime .

oakcurric:misconception-matter-interview-your-article
  a curric:Misconception ;
  curric:statement "It does not matter who you interview for your article."@en ;
  curric:correction """You should choose your interviewee carefully depending on the effect you want
  to have."""@en ;
  dcterms:modified "2026-06-07T15:30:15.097052Z"^^xsd:dateTime .

oakcurric:misconception-same-response-certain-words
  a curric:Misconception ;
  curric:statement "That we will all have the same response to certain words."@en ;
  curric:correction """Our response to words depends on our own individual experiences and memories
  and therefore we are likely to all get different connotations from words."""@en ;
  dcterms:modified "2026-06-07T15:30:15.097058Z"^^xsd:dateTime .

oakcurric:misconception-students-dont-value-their-own
  a curric:Misconception ;
  curric:statement """Students often don't value their own knowledge or experiences when aiming to
  persuade."""@en ;
  curric:correction "Encourage students to use examples that they are familiar with."@en ;
  dcterms:modified "2026-06-07T15:30:15.097063Z"^^xsd:dateTime .

oakcurric:misconception-historically-societal-expectations-focused-women
  a curric:Misconception ;
  curric:statement "That historically, societal expectations were focused on women."@en ;
  curric:correction """Both men and women were subject to societal expectations. However, men had
  much more freedom and power and it's important to acknowledge this difference."""@en ;
  dcterms:modified "2026-06-07T15:30:15.097069Z"^^xsd:dateTime .

oakcurric:misconception-police-force-today-one-society
  a curric:Misconception ;
  curric:statement "The police force we have today is the one society has always had."@en ;
  curric:correction """Explain that the police force was a new concept to Victorians and thus
  civilians had a lot of anxiety around crime."""@en ;
  dcterms:modified "2026-06-07T15:30:15.097313Z"^^xsd:dateTime .

oakcurric:misconception-students-think-george-poets-attitude
  a curric:Misconception ;
  curric:statement """Students may think George The Poet's attitude towards his city is wholly
  negative."""@en ;
  curric:correction """George The Poet critiques certain aspects of London, particularly inequality
  and the way in which people often do not acknowledge the poverty in London."""@en ;
  dcterms:modified "2026-06-07T15:30:15.097318Z"^^xsd:dateTime .

oakcurric:misconception-othellos-jealousy-thing-causes-him
  a curric:Misconception ;
  curric:statement """Othello's jealousy is the only thing that causes him to be considered a tragic
  hero."""@en ;
  curric:correction """Othello also has hubris, stubbornness and anagnorisis that can add to his
  status as tragic hero."""@en ;
  dcterms:modified "2026-06-07T15:30:15.097326Z"^^xsd:dateTime .

oakcurric:misconception-cant-talk-two-different-texts
  a curric:Misconception ;
  curric:statement "You can't talk about two different texts in the same paragraph."@en ;
  curric:correction """It can be tricky to talk about two texts in one paragraph, but it often makes
  for a stronger comparison. A good way to start is to consider one aspect of the texts you
  wish to compare, and then draw out the differences in your analysis."""@en ;
  dcterms:modified "2026-06-07T15:30:15.097840Z"^^xsd:dateTime .

oakcurric:misconception-performing-poetry-reading-aloud
  a curric:Misconception ;
  curric:statement "Performing poetry is just about reading it aloud."@en ;
  curric:correction """Watching people perform poetry is very popular. The most engaging performers
  carefully consider how they will say the poem, and how they will engage with their
  audiences."""@en ;
  dcterms:modified "2026-06-07T15:30:15.097846Z"^^xsd:dateTime .

oakcurric:misconception-students-think-tone-voice-same
  a curric:Misconception ;
  curric:statement "Students often think that tone and voice are the same thing."@en ;
  curric:correction """Voice is the identity of the writer and the beliefs they convey, whereas tone
  is the way in which these beliefs are conveyed."""@en ;
  dcterms:modified "2026-06-07T15:30:15.098753Z"^^xsd:dateTime .

oakcurric:misconception-students-think-scientific-advancements-celebrated
  a curric:Misconception ;
  curric:statement """Students often think that scientific advancements have always been
  celebrated."""@en ;
  curric:correction """In reality, scientists faced a lot of backlash for their ideas, mostly
  because many of them contradicted the teachings of the Bible."""@en ;
  dcterms:modified "2026-06-07T15:30:15.098759Z"^^xsd:dateTime .

oakcurric:misconception-students-think-goldings-reference-world
  a curric:Misconception ;
  curric:statement """Students might think that Golding's reference to a world order in \"ruins\"
  refers to the damaged sandcastles and their ruined life on the island."""@en ;
  curric:correction """Remind students of Golding's wartime experiences and the events of WWII.
  Golding is referring to the world the boys left behind as well as the world on the island."""@en ;
  dcterms:modified "2026-06-07T15:30:15.098779Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-same-punctuation-rules
  a curric:Misconception ;
  curric:statement """Pupils may think that the same punctuation rules apply in poetry and other
  types of writing (e.g. full stops are needed at the end of lines)."""@en ;
  curric:correction """Poems are not bound to formal punctuation rules. Having flexibility allows
  the poet to shape their poem based on emotion rather than grammar rules."""@en ;
  dcterms:modified "2026-06-07T15:30:15.098787Z"^^xsd:dateTime .

oakcurric:misconception-students-think-speeches-form-protest
  a curric:Misconception ;
  curric:statement "Students think of speeches as being a form of protest, but poems or songs."@en ;
  curric:correction "Emphasise the wide range of text types used in the lesson."@en ;
  dcterms:modified "2026-06-07T15:30:15.098847Z"^^xsd:dateTime .

oakcurric:misconception-cant-prepare-advance-discussion
  a curric:Misconception ;
  curric:statement "You can't prepare in advance for a discussion."@en ;
  curric:correction """Developing an effective strategy and learning some phrases, will enable you
  to take part in discussions successfully and confidently. These can help you feel more
  prepared in discussion scenarios."""@en ;
  dcterms:modified "2026-06-07T15:30:15.099516Z"^^xsd:dateTime .

oakcurric:misconception-use-definitive-authoritative-language-your
  a curric:Misconception ;
  curric:statement """That you should use definitive, authoritative language in your analytical
  writing to prove to the reader that you are right."""@en ;
  curric:correction """You should use tentative language because we can never be truly sure of the
  writer's intentions - you should use evidence and clear explanations to prove your idea to
  the reader."""@en ;
  dcterms:modified "2026-06-07T15:30:15.099522Z"^^xsd:dateTime .

oakcurric:misconception-tail-functions-summary-events
  a curric:Misconception ;
  curric:statement "The tail functions as a summary of the events."@en ;
  curric:correction """Although a conclusion in any other form of writing would contain a summary,
  an article summary usually goes at the beginning."""@en ;
  dcterms:modified "2026-06-07T15:30:15.099527Z"^^xsd:dateTime .

oakcurric:misconception-students-think-villains-one-dimensional
  a curric:Misconception ;
  curric:statement "Some students think that villains are one dimensional."@en ;
  curric:correction "Villains have their own struggles."@en ;
  dcterms:modified "2026-06-07T15:30:15.099536Z"^^xsd:dateTime .

oakcurric:misconception-commas-full-stops-interchangeable
  a curric:Misconception ;
  curric:statement "Commas and full stops are interchangeable."@en ;
  curric:correction """Full stops divide independent clauses and create a longer pause than a comma.
  Full stops divide ideas and create clear writing. Commas divide subordinate clauses and
  lists. They create a shorter pause."""@en ;
  dcterms:modified "2026-06-07T15:30:15.099541Z"^^xsd:dateTime .

oakcurric:misconception-students-used-starting-sensory-language
  a curric:Misconception ;
  curric:statement """Students may be used to starting any sensory language sentences with 'I can
  see, I can hear ...'"""@en ;
  curric:correction """Poetry allows us to innovate with traditional writing structures to help a
  rhythmic flow and sense of nostalgia; help students recognise the difference between 'I
  can see ...' and 'Seeing ...'"""@en ;
  dcterms:modified "2026-06-07T15:30:15.099547Z"^^xsd:dateTime .

oakcurric:misconception-audience-perceive-tragic-hero-complete
  a curric:Misconception ;
  curric:statement """The audience will perceive the tragic hero to be at complete fault for their
  downfall."""@en ;
  curric:correction """In Othello, due to the amount of time we spend getting to know Iago, we can
  see the huge role Iago plays in Othello's character change."""@en ;
  dcterms:modified "2026-06-07T15:30:15.099553Z"^^xsd:dateTime .

oakcurric:misconception-students-overuse-exclamation-marks-because
  a curric:Misconception ;
  curric:statement """Students may overuse exclamation marks because they think it adds
  sophistication"""@en ;
  curric:correction "Show pupils that exclamation marks are best used for dramatic effect"@en ;
  dcterms:modified "2026-06-07T15:30:15.099567Z"^^xsd:dateTime .

oakcurric:misconception-script-dialogue-characters-doesnt-need
  a curric:Misconception ;
  curric:statement """A script is just dialogue between characters and doesn't need any other
  elements"""@en ;
  curric:correction """While dialogue is a crucial part of a script, it's not the only component. A
  script also includes stage directions, which provide important instructions on how actors
  should move, behave, and speak."""@en ;
  dcterms:modified "2026-06-07T15:30:15.101382Z"^^xsd:dateTime .

oakcurric:misconception-pupils-believe-tension-story-created
  a curric:Misconception ;
  curric:statement """Pupils might believe that tension in a story is only created through dramatic
  events or actions."""@en ;
  curric:correction """Tension can also be built through subtle elements like descriptive language,
  sensory details and the anticipation of what might happen next."""@en ;
  dcterms:modified "2026-06-07T15:30:15.101388Z"^^xsd:dateTime .

oakcurric:misconception-stories-purely-intended-entertain-us
  a curric:Misconception ;
  curric:statement "That stories are purely intended to entertain us."@en ;
  curric:correction """While stories are entertaining, often there is also a message or a purpose
  behind the story that is designed to teach us something."""@en ;
  dcterms:modified "2026-06-07T15:30:15.101396Z"^^xsd:dateTime .

oakcurric:misconception-pattern-within-text-random-happened
  a curric:Misconception ;
  curric:statement "That a pattern within a text is random and just happened by chance."@en ;
  curric:correction """Patterns are a way for writers to emphasise certain information or convey
  importance onto a concept because our brains are wired to recognise and remember patterns."""@en ;
  dcterms:modified "2026-06-07T15:30:15.101408Z"^^xsd:dateTime .

oakcurric:misconception-edmundson-write-small-island
  a curric:Misconception ;
  curric:statement "Edmundson did not write 'Small Island'."@en ;
  curric:correction """Explore the conventions of a play. What would Edmundson have to have added to
  re-imagine the novel?"""@en ;
  dcterms:modified "2026-06-07T15:30:15.101413Z"^^xsd:dateTime .

oakcurric:misconception-context-needs-included-response-make
  a curric:Misconception ;
  curric:statement "Context just needs to be included in a response to make it effective."@en ;
  curric:correction """Context must not only be included but carefully considered, adapted and
  moulded to the point you are trying to make."""@en ;
  dcterms:modified "2026-06-07T15:30:15.101419Z"^^xsd:dateTime .

oakcurric:misconception-analyse-quotation-word-level
  a curric:Misconception ;
  curric:statement "You must analyse every quotation at word level."@en ;
  curric:correction """Sometimes exploring individual words can be helpful, but more often than not
  it makes for shallow analysis which is not helpful in answering the question. Look at
  'bigger' methods than single words."""@en ;
  dcterms:modified "2026-06-07T15:30:15.101424Z"^^xsd:dateTime .

oakcurric:misconception-process-amelioration-pejoration-mean-word
  a curric:Misconception ;
  curric:statement """That the process of amelioration and pejoration mean a word completely changes
  its meaning."""@en ;
  curric:correction """Pejoration and amelioration refer to a word becoming more negative/positive
  and this does not mean the word completely changes its meaning."""@en ;
  dcterms:modified "2026-06-07T15:30:15.101886Z"^^xsd:dateTime .

oakcurric:misconception-conclusions-include-quotations
  a curric:Misconception ;
  curric:statement "Conclusions should include quotations."@en ;
  curric:correction """Conclusions are about summing up your overall argument (your thesis) rather
  than continuing to develop it via analysis of new quotations."""@en ;
  dcterms:modified "2026-06-07T15:30:15.101900Z"^^xsd:dateTime .

oakcurric:misconception-one-interpretation-puck-either-malevolent
  a curric:Misconception ;
  curric:statement """There is one interpretation of Puck (either malevolent or mischievous) and you
  have to work out which one is correct."""@en ;
  curric:correction """A play, and its characters, can be interpreted in many different ways.
  Different performances will draw out particular interpretations."""@en ;
  dcterms:modified "2026-06-07T15:30:15.101912Z"^^xsd:dateTime .

oakcurric:misconception-slam-poetry-serious-personal-social
  a curric:Misconception ;
  curric:statement "Slam poetry always has to be serious and about personal or social issues."@en ;
  curric:correction """While slam poetry often tackles serious personal and social issues, it can
  also be playful, humorous or lighthearted. Slam poetry is about expressing yourself in an
  engaging and authentic way. You can write about anything that matters to you."""@en ;
  dcterms:modified "2026-06-07T15:30:15.101917Z"^^xsd:dateTime .

oakcurric:misconception-students-see-rescue-wholly-positive
  a curric:Misconception ;
  curric:statement "Students may see the rescue as wholly positive."@en ;
  curric:correction """Draw your pupils' attention to the lack of understanding of their ordeal.
  Also, to the fact rescue comes on a warship and the officer is carrying a revolver."""@en ;
  dcterms:modified "2026-06-07T15:30:15.101923Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-using-contrast-juxtaposition
  a curric:Misconception ;
  curric:statement """Pupils might think that using contrast and juxtaposition in character
  descriptions means simply listing opposing traits without showing how they interact or
  affect each other."""@en ;
  curric:correction """It's important to show how the contrasting traits of characters impact each
  other. For example, instead of just stating that one character is kind and the other is
  cruel, describe a scene where their actions and behaviors directly conflict."""@en ;
  dcterms:modified "2026-06-07T15:30:15.101929Z"^^xsd:dateTime .

oakcurric:misconception-show-sides-argument-debate-discussion
  a curric:Misconception ;
  curric:statement """You always have to show both sides of the argument in a debate or
  discussion."""@en ;
  curric:correction """In a debate, it is much more skilfull to present a single line of
  argument."""@en ;
  dcterms:modified "2026-06-07T15:30:15.101943Z"^^xsd:dateTime .

oakcurric:misconception-students-understand-subtle-difference-imagery
  a curric:Misconception ;
  curric:statement """Students may not understand the subtle difference between imagery and
  figurative language."""@en ;
  curric:correction """Whilst imagery can include figurative language and vice versa, imagery does
  not always have to be figurative."""@en ;
  dcterms:modified "2026-06-07T15:30:15.101961Z"^^xsd:dateTime .

oakcurric:misconception-textures-arent-important-detail-descriptive
  a curric:Misconception ;
  curric:statement "That textures aren't an important detail in descriptive writing."@en ;
  curric:correction """The textures that writers choose to use can help us to make inferences about
  the nature of the object or place."""@en ;
  dcterms:modified "2026-06-07T15:30:15.101978Z"^^xsd:dateTime .

oakcurric:misconception-set-formula-follow-comes-choosing
  a curric:Misconception ;
  curric:statement """That there is a set formula to follow when it comes to choosing what to focus
  on in an image."""@en ;
  curric:correction """When looking at an image for descriptive writing, you should think about what
  catches your eye and then focus on those elements."""@en ;
  dcterms:modified "2026-06-07T15:30:15.101983Z"^^xsd:dateTime .

oakcurric:misconception-students-think-evaluate-something-say
  a curric:Misconception ;
  curric:statement """Students often think that to evaluate something is to say whether or not you
  like it."""@en ;
  curric:correction """Keep reminding them of the criteria. Does a text measure up to a standard
  being set?"""@en ;
  dcterms:modified "2026-06-07T15:30:15.101989Z"^^xsd:dateTime .

oakcurric:misconception-characters-meant-read-themselves
  a curric:Misconception ;
  curric:statement "That characters are only meant to be read as themselves."@en ;
  curric:correction """Often in literature, the characters are the writer's way of commenting on
  something happening in the world."""@en ;
  dcterms:modified "2026-06-07T15:30:15.101998Z"^^xsd:dateTime .

oakcurric:misconception-norns-whimsical-conventionally-beautiful
  a curric:Misconception ;
  curric:statement "The Norns are whimsical and conventionally beautiful."@en ;
  curric:correction """Look at the descriptions of the Norns. Their beauty lies in their power and
  wisdom. They are \"gnarled\" and \"wrinkled\", which adds an air of authority to their
  presence. They are also described as \"fierce\"."""@en ;
  dcterms:modified "2026-06-07T15:30:15.102007Z"^^xsd:dateTime .

oakcurric:misconception-stage-directions-suggestions-dont-need
  a curric:Misconception ;
  curric:statement """Stage directions are just suggestions and don't need to be followed
  exactly."""@en ;
  curric:correction """Stage directions are essential parts of the script that provide important
  guidance on how the scene should be performed. They help create the atmosphere, convey
  emotions and ensure the story is told as the writer intended."""@en ;
  dcterms:modified "2026-06-07T15:30:15.102381Z"^^xsd:dateTime .

oakcurric:misconception-meeting-someone-unknown-strange-place
  a curric:Misconception ;
  curric:statement "That meeting someone unknown in a strange place will always be scary."@en ;
  curric:correction """Instead of feeling scared, you might also feel excited or intrigued and you
  can use language to have this effect on the reader."""@en ;
  dcterms:modified "2026-06-07T15:30:15.102388Z"^^xsd:dateTime .

oakcurric:misconception-students-think-methods-exclusively-similes
  a curric:Misconception ;
  curric:statement "Students often think of methods exclusively as 'similes/metaphors' etc."@en ;
  curric:correction """The writer's method is anything they do consciously. This could be choosing
  one, single word over another."""@en ;
  dcterms:modified "2026-06-07T15:30:15.103015Z"^^xsd:dateTime .

oakcurric:misconception-students-think-write-horror-story
  a curric:Misconception ;
  curric:statement """Students think that if they write a horror story that is full of blood and
  gore, that this makes it Gothic."""@en ;
  curric:correction """Gothic literature is about unsettling and mystifying the reader - not
  traumatising them with gory descriptions and extreme violence. There can be more fear in
  what is not revealed, than what is revealed."""@en ;
  dcterms:modified "2026-06-07T15:30:15.103024Z"^^xsd:dateTime .

oakcurric:misconception-include-aspect-characterisation-same-paragraph
  a curric:Misconception ;
  curric:statement """You have to include each aspect of characterisation in the same paragraph, and
  always in the same order."""@en ;
  curric:correction """Chaucer has a particular way of introducing and describing his characters.
  However, this is one way to do it, amongst many. You will see lots of different writers
  use the same methods of characterisation, but in different orders and structures."""@en ;
  dcterms:modified "2026-06-07T15:30:15.103043Z"^^xsd:dateTime .

oakcurric:misconception-motifs-symbols-same
  a curric:Misconception ;
  curric:statement "Motifs and symbols are the same."@en ;
  curric:correction """A motif is a recurring image whereas a symbol is one thing that represents
  something else."""@en ;
  dcterms:modified "2026-06-07T15:30:15.103051Z"^^xsd:dateTime .

oakcurric:misconception-rules-debating-another-way-argue
  a curric:Misconception ;
  curric:statement """There are no rules in debating. It is just another way to argue or have an
  argument and does not need preparation."""@en ;
  curric:correction """Formal debating is an important part of society and allows important issues
  to be discussed in a constructuve way. It takes consideration and preparation to be
  involved in an effective debate."""@en ;
  dcterms:modified "2026-06-07T15:30:15.103066Z"^^xsd:dateTime .

oakcurric:misconception-poem-follow-similar-rhythm-whole
  a curric:Misconception ;
  curric:statement "A poem has to follow a similar rhythm the whole way through."@en ;
  curric:correction "By creating two different rhythms, we can juxtapose two places."@en ;
  dcterms:modified "2026-06-07T15:30:15.103091Z"^^xsd:dateTime .

oakcurric:misconception-writing-purely-form-escapism
  a curric:Misconception ;
  curric:statement "Writing is purely a form of escapism."@en ;
  curric:correction "For some, writing can be a way of helping to process emotions and ideas."@en ;
  dcterms:modified "2026-06-07T15:30:15.103111Z"^^xsd:dateTime .

oakcurric:misconception-mind-mapping-way-plan-piece
  a curric:Misconception ;
  curric:statement "Mind mapping is the only way to plan a piece of writing."@en ;
  curric:correction """Mind mapping is a good place to start, but isn't always useful for
  considering structure. Using single paragraph outlines is an effective way to ensure a
  cohesive stricture and a clearly developed line of argument."""@en ;
  dcterms:modified "2026-06-07T15:30:15.103150Z"^^xsd:dateTime .

oakcurric:misconception-students-add-sophisticated-punctuation-tick
  a curric:Misconception ;
  curric:statement "Students add sophisticated punctuation as a tick box exercise."@en ;
  curric:correction """The inclusion of sophisticated punctuation should always be driven first and
  foremost by effect. What effect will this punctuation achieve?"""@en ;
  dcterms:modified "2026-06-07T15:30:15.103800Z"^^xsd:dateTime .

oakcurric:misconception-context-included-one-sentence-end
  a curric:Misconception ;
  curric:statement """Context should be included in one sentence at the end of each analytical
  paragraph."""@en ;
  curric:correction """You can include contextual ideas where relevant - this could be at the start,
  middle or multiple times in a paragraph. Contextual ideas will often help you develop your
  analysis of a particular quotation or character."""@en ;
  dcterms:modified "2026-06-07T15:30:15.105811Z"^^xsd:dateTime .

oakcurric:misconception-pupils-appreciate-extent-frankensteins-immorality
  a curric:Misconception ;
  curric:statement "Pupils do not appreciate the extent of Frankenstein's immorality."@en ;
  curric:correction """In pursuit of knowledge, Frankenstein broke natural and political laws. He
  robbed graves and tortured live animals to achieve his ambition."""@en ;
  dcterms:modified "2026-06-07T15:30:15.105827Z"^^xsd:dateTime .

oakcurric:misconception-pupils-puzzled-ralphs-seemingly-sudden
  a curric:Misconception ;
  curric:statement """Pupils may be puzzled by Ralph's seemingly sudden descent into the violence
  and savagery that seems to have captured the other boys."""@en ;
  curric:correction "Point out how Jack's more aggressive behaviour appeals to the boys."@en ;
  dcterms:modified "2026-06-07T15:30:15.105833Z"^^xsd:dateTime .

oakcurric:misconception-use-adjectives-simple-technique-isnt
  a curric:Misconception ;
  curric:statement """The use of adjectives is a simple technique, so there isn't much point
  analysing a writer's use of them, or planning for them in your own writing."""@en ;
  curric:correction """Adjectives are a wonderful way to express tone, nuanced meaning and
  atmosphere. As such, they can be rich for analysis, and have a powerful effect on your own
  descriptive writing."""@en ;
  dcterms:modified "2026-06-07T15:30:15.105838Z"^^xsd:dateTime .

oakcurric:misconception-iago-similar-many-other-shakespeare
  a curric:Misconception ;
  curric:statement "Iago is similar to many other Shakespeare villains."@en ;
  curric:correction "Iago stands out because of his diabolical nature."@en ;
  dcterms:modified "2026-06-07T15:30:15.105852Z"^^xsd:dateTime .

oakcurric:misconception-students-realise-importance-listening-discussions
  a curric:Misconception ;
  curric:statement """Students may not realise the importance of listening in discussions, as they
  may be thinking about what they have to say next."""@en ;
  curric:correction """Explain the importance of listening. Model a discussion with a pupil where
  you are not listening, ask them how it made them feel and ask the class how it affected
  the quality of the discussion."""@en ;
  dcterms:modified "2026-06-07T15:30:15.105858Z"^^xsd:dateTime .

oakcurric:misconception-connotation-definition-word
  a curric:Misconception ;
  curric:statement "Connotation is the definition of a word."@en ;
  curric:correction "Connotation is a feeling that a word gives ."@en ;
  dcterms:modified "2026-06-07T15:30:15.105866Z"^^xsd:dateTime .

oakcurric:misconception-planning-isnt-useful-step-writing
  a curric:Misconception ;
  curric:statement "Planning isn't a useful step in the writing process and it takes too long."@en ;
  curric:correction """How might planning help to organise our thoughts into a coherent response?
  How can planning improve the efficiency of the writing process?"""@en ;
  dcterms:modified "2026-06-07T15:30:15.105882Z"^^xsd:dateTime .

oakcurric:misconception-unknown-scary
  a curric:Misconception ;
  curric:statement "That the unknown is always scary."@en ;
  curric:correction """While we typically think of the unknown as something scary and overwhelming,
  it can also be something exciting and refreshing."""@en ;
  dcterms:modified "2026-06-07T15:30:15.106506Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-jacks-hunters-involved
  a curric:Misconception ;
  curric:statement """Pupils sometimes think that only Jack's hunters are involved in the killing of
  Simon."""@en ;
  curric:correction """Draw attention to the one sentence where Golding says that Ralph and Piggy
  want to be part of the group."""@en ;
  dcterms:modified "2026-06-07T15:30:15.106517Z"^^xsd:dateTime .

oakcurric:misconception-oberon-asks-puck-turn-bottoms
  a curric:Misconception ;
  curric:statement "Oberon asks Puck to turn Bottom's head into that of a donkey."@en ;
  curric:correction """Puck follows Oberon's orders, but in his own time, he gets up to his own
  mischief. He decides to transform Bottom and Oberon does not set out for Titania to fall
  in love with this particular character."""@en ;
  dcterms:modified "2026-06-07T15:30:15.106892Z"^^xsd:dateTime .

oakcurric:misconception-malevolent-characters-obviously-outwardly-evil
  a curric:Misconception ;
  curric:statement "Malevolent characters are always obviously and outwardly evil characters."@en ;
  curric:correction """Ask pupils whether they can think of any characters from literature where
  their malevolence is implied or not explicitly stated at first. These characters are often
  dangerously deceptive."""@en ;
  dcterms:modified "2026-06-07T15:30:15.106900Z"^^xsd:dateTime .

oakcurric:misconception-mami-wata-presented-mermaid-saves
  a curric:Misconception ;
  curric:statement """A Mami Wata is always presented as a mermaid who saves the souls of enslaved
  people."""@en ;
  curric:correction """Mami Wata is a water spirit and has a rich tradition in West, Central and
  Southern Africa. Bowen has used the deity in her novel and presented her as a mermaid with
  a specific task, but the goddess is presented in different ways in other art."""@en ;
  dcterms:modified "2026-06-07T15:30:15.106911Z"^^xsd:dateTime .

oakcurric:misconception-annotating-highlight-underline-circle-interesting
  a curric:Misconception ;
  curric:statement """When annotating, you should highlight, underline and circle interesting
  things. You don't need to write anything down as you will remember what you thought."""@en ;
  curric:correction """Symbols, highlights and underlinings are all useful, but only if accompanied
  by short written notes which remind you what it was you found interesting. Otherwise your
  symbols become meaningless."""@en ;
  dcterms:modified "2026-06-07T15:30:15.106934Z"^^xsd:dateTime .

oakcurric:misconception-julia-stoners-death-accidental
  a curric:Misconception ;
  curric:statement "Julia Stoner's death was accidental."@en ;
  curric:correction """Explain that the point of a mystery story is for the detective to use clues
  to solve it and usually find a perpetrator."""@en ;
  dcterms:modified "2026-06-07T15:30:15.106947Z"^^xsd:dateTime .

oakcurric:misconception-poem-completely-separate-narrative-story
  a curric:Misconception ;
  curric:statement "A poem is completely separate from a narrative story."@en ;
  curric:correction """Fundamentally, a poem is about the manipulation of language - so you can
  manipulate a narrative story into a poem."""@en ;
  dcterms:modified "2026-06-07T15:30:15.106967Z"^^xsd:dateTime .

oakcurric:misconception-jamaican-characters-cynical-view-britain
  a curric:Misconception ;
  curric:statement """The Jamaican characters all have a cynical view of Britain and the British
  empire."""@en ;
  curric:correction """The reality is more nuanced. Whilst characters like Elwood are openly
  critical, some characters (like Gilbert) are more positive, buying into wartime narratives
  of fighting for their 'mother country'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.106981Z"^^xsd:dateTime .

oakcurric:misconception-adaptations-copy-story-book-writer
  a curric:Misconception ;
  curric:statement """Adaptations just copy the story from the book. The writer doesn’t have to
  change much or make many decisions."""@en ;
  curric:correction """Adaptations need big changes to work on stage! Edmundson tested scenes in
  workshops, adjusted them in rehearsals, and watched audience reactions in previews to make
  sure the story was clear and powerful in performance."""@en ;
  dcterms:modified "2026-06-07T15:30:15.106986Z"^^xsd:dateTime .

oakcurric:misconception-same-answer-question-writer-presents
  a curric:Misconception ;
  curric:statement """That we will all have the same answer to a question about how a writer
  presents a particular character or theme."""@en ;
  curric:correction """The way we respond to how a writer presents a particular character or theme
  will be very individual since our responses depend on our own experiences or memories."""@en ;
  dcterms:modified "2026-06-07T15:30:15.107000Z"^^xsd:dateTime .

oakcurric:misconception-soldiers-front-line-direct-experiences
  a curric:Misconception ;
  curric:statement "Only soldiers on the front line had direct experiences of conflict."@en ;
  curric:correction """Who does war impact? Besides being a soldier, what other roles do people have
  in war?"""@en ;
  dcterms:modified "2026-06-07T15:30:15.107011Z"^^xsd:dateTime .

oakcurric:misconception-cant-link-quotations-across-text
  a curric:Misconception ;
  curric:statement "You can't link quotations from across a text in a short story."@en ;
  curric:correction """Being able to link quotations from any text together is a key skill in
  English. It helps make your analysis thoughtful and convincing."""@en ;
  dcterms:modified "2026-06-07T15:30:15.107861Z"^^xsd:dateTime .

oakcurric:misconception-one-interpretation-iago-relevant-since
  a curric:Misconception ;
  curric:statement "Only one interpretation of Iago is relevant since he is clearly a villain."@en ;
  curric:correction """Even villains can be looked at through multiple lenses. Doing this can
  elevate your response as you say what others may not consider."""@en ;
  dcterms:modified "2026-06-07T15:30:15.107867Z"^^xsd:dateTime .

oakcurric:misconception-poems-song-lyrics-same
  a curric:Misconception ;
  curric:statement "Poems and song lyrics are the same."@en ;
  curric:correction """While there are similarities, Armitage suggests that poems have to create
  musicality through language while song lyrics are a component of a larger whole."""@en ;
  dcterms:modified "2026-06-07T15:30:15.107872Z"^^xsd:dateTime .

oakcurric:misconception-segregation-happened-united-states
  a curric:Misconception ;
  curric:statement "That segregation only happened in the United States."@en ;
  curric:correction """This in the most part is true and Britain certainly didn't have any
  segregation laws. However, as we see in the play, some individuals and institutions still
  upheld these ideas of segregation."""@en ;
  dcterms:modified "2026-06-07T15:30:15.107878Z"^^xsd:dateTime .

oakcurric:misconception-long-used-like-created-effective
  a curric:Misconception ;
  curric:statement """As long as I have used \"like\" or \"as\", I have created an effective
  simile."""@en ;
  curric:correction """Consider this simile: 'Her voice was like a salad.' The comparison is unclear
  and doesn't enhance understanding."""@en ;
  dcterms:modified "2026-06-07T15:30:15.107886Z"^^xsd:dateTime .

oakcurric:misconception-long-using-language-devices-their
  a curric:Misconception ;
  curric:statement """That as long as they are using language devices in their speeches, this is
  enough."""@en ;
  curric:correction """There is great variety in quality in the execution of language devices. The
  best devices are creative, original and well-matched to purpose."""@en ;
  dcterms:modified "2026-06-07T15:30:15.108630Z"^^xsd:dateTime .

oakcurric:misconception-titania-lysander-demetrius-antidote-applied
  a curric:Misconception ;
  curric:statement "Titania, Lysander and Demetrius have the antidote applied to them."@en ;
  curric:correction """So that the play can end in happy marriages between all four Athenian nobles,
  only Lysander has the antidote applied to him. Demetrius is still under the influence of
  the magical potion."""@en ;
  dcterms:modified "2026-06-07T15:30:15.108650Z"^^xsd:dateTime .

oakcurric:misconception-need-check-your-work-writing
  a curric:Misconception ;
  curric:statement "You do not need to check your work after writing it."@en ;
  curric:correction """Show pupils the value of checking and editing their work - show the
  transformation from first draft to final draft."""@en ;
  dcterms:modified "2026-06-07T15:30:15.108661Z"^^xsd:dateTime .

oakcurric:misconception-middle-english-same-old-english
  a curric:Misconception ;
  curric:statement """Middle English is the same as Old English. Both are general terms, and mean
  the same thing."""@en ;
  curric:correction """Middle English was spoken from about 1100-1500. Old English was spoken before
  1100. Both are technical terms and have a specific meaning."""@en ;
  dcterms:modified "2026-06-07T15:30:15.108667Z"^^xsd:dateTime .

oakcurric:misconception-persuasive-writing-need-include-range
  a curric:Misconception ;
  curric:statement """In persuasive writing, I just need to include a range of rhetorical devices
  and sophisticated vocabulary."""@en ;
  curric:correction """Whilst it is important to use rhetorical devices and choose interesting
  language, you must also consider the structure of your writing. This ensures that your
  argument has a clear progression and your message doesn't get lost."""@en ;
  dcterms:modified "2026-06-07T15:30:15.108680Z"^^xsd:dateTime .

oakcurric:misconception-context-refers-historical-facts
  a curric:Misconception ;
  curric:statement "That context refers only to historical facts."@en ;
  curric:correction """Interesting context also includes different attitudes and values. How would
  different audiences respond to the text and why?"""@en ;
  dcterms:modified "2026-06-07T15:30:15.109029Z"^^xsd:dateTime .

oakcurric:misconception-small-island-england-presented-bad
  a curric:Misconception ;
  curric:statement """In 'Small Island' England is presented as a bad place and Jamaica as a good
  place."""@en ;
  curric:correction """Look at what is happening at the start of Scene 6, why is the situation
  volatile? What does the discussion between Gilbert and Elwood reveal about the realities
  in both Jamaica and England?"""@en ;
  dcterms:modified "2026-06-07T15:30:15.109216Z"^^xsd:dateTime .

oakcurric:misconception-use-your-own-opinions-perspectives
  a curric:Misconception ;
  curric:statement """That you should not use your own opinions or perspectives when exploring a
  text."""@en ;
  curric:correction """Being able to articulate your own opinions and perspectives is an important
  skill to have. They should be rooted in evidence from the text and should avoid
  speculation."""@en ;
  dcterms:modified "2026-06-07T15:30:15.109336Z"^^xsd:dateTime .

oakcurric:misconception-puck-disrespectful-character
  a curric:Misconception ;
  curric:statement "Puck is a disrespectful character."@en ;
  curric:correction """Puck's disrespect is targeted at particular characters. He is shown as
  respectful to Oberon, for example, and other high status characters."""@en ;
  dcterms:modified "2026-06-07T15:30:15.109639Z"^^xsd:dateTime .

oakcurric:misconception-pupils-forget-description-creature-written
  a curric:Misconception ;
  curric:statement """Pupils forget that the description of the Creature is written from
  Frankenstein's perspective."""@en ;
  curric:correction """Shelley describes the Creature so horribly through the eyes of Frankenstein
  to show his disgust with his creation."""@en ;
  dcterms:modified "2026-06-07T15:30:15.109644Z"^^xsd:dateTime .

oakcurric:misconception-students-recognise-gothic-setting-overtly
  a curric:Misconception ;
  curric:statement """Students might not recognise this as a Gothic setting, as it is not overtly
  frightening or eerie."""@en ;
  curric:correction """Brontë's use of contrasting colours, isolation and cold make this a Gothic
  setting. Gothic descriptions do not have to be terrifying at all times."""@en ;
  dcterms:modified "2026-06-07T15:30:15.109650Z"^^xsd:dateTime .

oakcurric:misconception-poems-carefully-crafted-use-methods
  a curric:Misconception ;
  curric:statement """Poems are carefully crafted and use methods, but nonfiction letters won't have
  a structure or include methods."""@en ;
  curric:correction """Almost all writing follows some sort of structure even, for example, a
  shopping list. Methods are tools writers use to convey their messages. Every single word,
  technically, is a method."""@en ;
  dcterms:modified "2026-06-07T15:30:15.109672Z"^^xsd:dateTime .

oakcurric:misconception-writers-use-object-symbolise-idea
  a curric:Misconception ;
  curric:statement "Writers can use any object to symbolise any idea."@en ;
  curric:correction """Writers can get their messages across via inventive and innovative methods.
  However, there are some key symbols in literature which have a generally accepted meaning.
  For example, a rose to symbolise love, or a pearl to symbolise perfection."""@en ;
  dcterms:modified "2026-06-07T15:30:15.109677Z"^^xsd:dateTime .

oakcurric:misconception-poem-good-rhythm-rhymes
  a curric:Misconception ;
  curric:statement "A poem with a good rhythm always rhymes."@en ;
  curric:correction """Rhythm is about the flow, beat and sound of a poem. Rhyme can sometimes
  develop rhythm, but it is not necessary."""@en ;
  dcterms:modified "2026-06-07T15:30:15.109685Z"^^xsd:dateTime .

oakcurric:misconception-play-comedy-wont-moments-sadness
  a curric:Misconception ;
  curric:statement "If a play is a comedy, it won't have any moments of sadness in it."@en ;
  curric:correction """When thinking about genre, we consider the overall tone, plot and features of
  a play. However, many comedies have moments of sadness, just as many tragedies have
  moments of humour."""@en ;
  dcterms:modified "2026-06-07T15:30:15.110572Z"^^xsd:dateTime .

oakcurric:misconception-students-think-boys-feel-same
  a curric:Misconception ;
  curric:statement "Students may think the boys all feel the same about the killing of Simon."@en ;
  curric:correction """Focus on words used: Some talk about \"murder,\" some call the killing an
  \"accident\" or pretend that they left \"early\"."""@en ;
  dcterms:modified "2026-06-07T15:30:15.110578Z"^^xsd:dateTime .

oakcurric:misconception-topic-sentences-worth-spending-much
  a curric:Misconception ;
  curric:statement """Topic sentences are not worth spending much time on, the discussion of
  techniques is more important."""@en ;
  curric:correction """To make a paragraph even more effective, a topic sentence can be elevated in
  many ways to make writing clear and specific with a firm voice."""@en ;
  dcterms:modified "2026-06-07T15:30:15.110599Z"^^xsd:dateTime .

oakcurric:misconception-shouldnt-talk-poems-group-make
  a curric:Misconception ;
  curric:statement """You shouldn't talk about poems as a group. This will make your comments too
  general."""@en ;
  curric:correction """You can make clear comments about a poet's work as a whole, as long as these
  comments are supported by specific examples from specific poems."""@en ;
  dcterms:modified "2026-06-07T15:30:15.110605Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-use-formal-tone
  a curric:Misconception ;
  curric:statement """Pupils might think that the use of a formal tone and third person point of
  view is only necessary for professional journalism and not applicable to other forms of
  writing."""@en ;
  curric:correction """Explain that while formal tone and third person are essential in professional
  journalism, they are also important in many other types of writing, including more
  localised articles like this."""@en ;
  dcterms:modified "2026-06-07T15:30:15.110619Z"^^xsd:dateTime .

oakcurric:misconception-cant-compare-different-text-types
  a curric:Misconception ;
  curric:statement """You can't compare different text types to each other. For example, an article
  to a memoir."""@en ;
  curric:correction """By comparing different forms, we can often come to understand why a writer
  chose a particular text type more deeply - what this particular text type allowed them to
  do or convey to the reader."""@en ;
  dcterms:modified "2026-06-07T15:30:15.110631Z"^^xsd:dateTime .

oakcurric:misconception-old-english-created-exclusively-anglo
  a curric:Misconception ;
  curric:statement "That Old English was created exclusively by the Anglo-Saxons."@en ;
  curric:correction """The Anglo-Saxons' Germanic languages contributed to Old English but languages
  already spoken in Britain – and Latin – also played a part."""@en ;
  dcterms:modified "2026-06-07T15:30:15.111298Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-role-rules-society
  a curric:Misconception ;
  curric:statement """When pupils think about the role of rules in society, they tend to focus on
  the role of more punitive rules and argue that rules are restrictive."""@en ;
  curric:correction """Try to get pupils to understand the necessity for rules and laws -
  particularly those that ban harming others. Get students to imagine what life would be
  like if harming others was not prohibited."""@en ;
  dcterms:modified "2026-06-07T15:30:15.111314Z"^^xsd:dateTime .

oakcurric:misconception-students-tendency-view-ralph-morally
  a curric:Misconception ;
  curric:statement """Students have a tendency to view Ralph as a morally-virtuous character who
  does no wrong."""@en ;
  curric:correction """Ralph does behave immorally and wickedly in the text - he is mean to Piggy
  about his asthma and he participates in the murder of Simon. What separates Ralph from the
  others is the remorse he shows for his actions and how he learns from them."""@en ;
  dcterms:modified "2026-06-07T15:30:15.111320Z"^^xsd:dateTime .

oakcurric:misconception-cant-repeat-ideas-creative-writing
  a curric:Misconception ;
  curric:statement """You can't repeat any ideas in creative writing. Once you have used them once,
  you must create new ideas in every successive paragraph."""@en ;
  curric:correction """Repetition of certain ideas or images can give your writing a sense of
  structure. This is particularly true in your final paragraph where repeating ideas from
  your first paragraph can alert your reader to the idea that you are about to finish."""@en ;
  dcterms:modified "2026-06-07T15:30:15.111326Z"^^xsd:dateTime .

oakcurric:misconception-othello-feels-jealousy-play
  a curric:Misconception ;
  curric:statement "Only Othello feels jealousy in the play."@en ;
  curric:correction """Many other characters feel jealousy and it is a driving force for lots of the
  action in the play."""@en ;
  dcterms:modified "2026-06-07T15:30:15.111331Z"^^xsd:dateTime .

oakcurric:misconception-students-misconceive-phrase-my-tongue
  a curric:Misconception ;
  curric:statement "Students may misconceive what the phrase \"my tongue\" means initially."@en ;
  curric:correction """Explain the figurative language involved in the phrase \"my tongue\" and the
  link to language."""@en ;
  dcterms:modified "2026-06-07T15:30:15.111337Z"^^xsd:dateTime .

oakcurric:misconception-piece-evidence-looked-isolation-thinking
  a curric:Misconception ;
  curric:statement """Each piece of evidence can be looked at in isolation when thinking about the
  crime."""@en ;
  curric:correction """Question your students' explanations to help them acknowledge where they have
  failed to consider certain pieces of evidence."""@en ;
  dcterms:modified "2026-06-07T15:30:15.111342Z"^^xsd:dateTime .

oakcurric:misconception-comparing-poems-beginning-end-doesnt
  a curric:Misconception ;
  curric:statement """Comparing a poem's beginning and end doesn't count as analysis. It's too
  simple to be interesting."""@en ;
  curric:correction """At its most basic (and often most powerful), a text's structure is its
  beginning, middle and end. Commenting on the journey - emotional or physical - that a
  writer has taken us on is a great way to start exploring structure."""@en ;
  dcterms:modified "2026-06-07T15:30:15.111362Z"^^xsd:dateTime .

oakcurric:misconception-important-part-dialogue-inside-speech
  a curric:Misconception ;
  curric:statement "The most important part of dialogue is what is inside the speech marks."@en ;
  curric:correction """What is said through dialogue is really important, but it's also crucial to
  consider how that dialogue is to be said. Careful selection of verbs and adverbs give the
  reader a crucial insight into how dialogue should be read."""@en ;
  dcterms:modified "2026-06-07T15:30:15.111878Z"^^xsd:dateTime .

oakcurric:misconception-long-am-quiet-am-listening
  a curric:Misconception ;
  curric:statement "As long as I am being quiet, I am listening."@en ;
  curric:correction """Although being quiet is an effective way to show you are listening, there are
  many other things to consider to ensure you are 'actively listening'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.111906Z"^^xsd:dateTime .

oakcurric:misconception-victim-profiles-similar
  a curric:Misconception ;
  curric:statement "All victim profiles are similar."@en ;
  curric:correction """Conan Doyle manipulates his presentation of victims depending on how he wants
  the reader to view them."""@en ;
  dcterms:modified "2026-06-07T15:30:15.112792Z"^^xsd:dateTime .

oakcurric:misconception-choose-quotation-techniques-your-evidence
  a curric:Misconception ;
  curric:statement """That you should choose the quotation with the most techniques as your
  evidence."""@en ;
  curric:correction """You need to select a quotation that matches the point of your topic sentence
  rather than simply being the one with the most techniques."""@en ;
  dcterms:modified "2026-06-07T15:30:15.112797Z"^^xsd:dateTime .

oakcurric:misconception-writing-persuasively-use-many-rhetorical
  a curric:Misconception ;
  curric:statement """When writing persuasively you should use as many rhetorical devices as
  possible."""@en ;
  curric:correction """Whilst using rhetorical devices is a great way to engage your audience, they
  need to be used sparingly and crafted carefully to ensure they don't lose their impact."""@en ;
  dcterms:modified "2026-06-07T15:30:15.112806Z"^^xsd:dateTime .

oakcurric:misconception-historical-texts-portray-stereotypical-representations
  a curric:Misconception ;
  curric:statement "Historical texts only portray stereotypical representations of women."@en ;
  curric:correction """Even though societal expectations and stereotypes exist, this does not mean
  that all people conform to these standards - even in the past!"""@en ;
  dcterms:modified "2026-06-07T15:30:15.113252Z"^^xsd:dateTime .

oakcurric:misconception-dont-time-write-effective-closing
  a curric:Misconception ;
  curric:statement """I don't have time to write an effective closing, I just need to get my work
  finished!"""@en ;
  curric:correction """The ending is arguably the most important part of the piece of writing. You
  need to leave your audience with a clear message that is memorable. Writing effective
  closings will get quicker the more you practice using specific strategies."""@en ;
  dcterms:modified "2026-06-07T15:30:15.113579Z"^^xsd:dateTime .

oakcurric:misconception-students-think-stories-fit-perfectly
  a curric:Misconception ;
  curric:statement """Students might think that all stories fit perfectly into a traditional
  narrative arc with only one climax."""@en ;
  curric:correction """While many stories follow a traditional narrative arc, some can have multiple
  climaxes or may not fit perfectly into the structure. The narrative arc is a helpful
  guide, but it's important to recognise that stories can vary and still be effective."""@en ;
  dcterms:modified "2026-06-07T15:30:15.114144Z"^^xsd:dateTime .

oakcurric:misconception-pupils-believe-conclusion-introduce-new
  a curric:Misconception ;
  curric:statement """Pupils may believe that the conclusion should introduce new ideas or
  quotes."""@en ;
  curric:correction """Explain that a conclusion should summarise the main points and restate the
  thesis in a new way, rather than introducing new evidence or arguments. Its purpose is to
  reinforce what has already been discussed, reinforcing the main arguments."""@en ;
  dcterms:modified "2026-06-07T15:30:15.114160Z"^^xsd:dateTime .

oakcurric:misconception-students-think-motif-symbol-used
  a curric:Misconception ;
  curric:statement """Students can think a motif is a symbol used once or think it is deployed in
  the same way as a semantic field."""@en ;
  curric:correction """Remind them of the etymology - there has to be movement and change of the
  motif. A semantic field does not have to be symbolic."""@en ;
  dcterms:modified "2026-06-07T15:30:15.114168Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-descriptions-setting-serve
  a curric:Misconception ;
  curric:statement """Pupils might think that descriptions of setting only serve as background and
  do not contribute to character development or tone of a piece of writing."""@en ;
  curric:correction """Settings are integral to storytelling as they can reflect and enhance a
  character's emotions, personality, and the overall tone of the scene. For example, a
  gloomy, rainy setting can mirror a character's sadness or create a foreboding atmosphere."""@en ;
  dcterms:modified "2026-06-07T15:30:15.114188Z"^^xsd:dateTime .

oakcurric:misconception-working-tone-audience-purpose-unnecessary
  a curric:Misconception ;
  curric:statement """Working out the tone, audience and purpose is an unnecessary step in planning.
  These things are always really obvious."""@en ;
  curric:correction """The foundations of convincing writing comes in the planning stage. This
  includes thinking carefully about tone, audience and purpose. Having a deep, rather than
  superficial, understanding of each will allow for a compelling piece of writing."""@en ;
  dcterms:modified "2026-06-07T15:30:15.114194Z"^^xsd:dateTime .

oakcurric:misconception-comparative-essay-deal-poem-separately
  a curric:Misconception ;
  curric:statement """A comparative essay should deal with each poem separately in the body of the
  essay."""@en ;
  curric:correction """While one method of comparison might be to deal with each poem separately,
  you might also consider comparing the poems throughout the essay and instead splitting up
  the essay thematically or by methods."""@en ;
  dcterms:modified "2026-06-07T15:30:15.114213Z"^^xsd:dateTime .

oakcurric:misconception-shakespearean-theatre-didnt-special-effects
  a curric:Misconception ;
  curric:statement "That Shakespearean theatre didn't have special effects."@en ;
  curric:correction """Although they didn't have access to modern technology, the theatre used many
  special effects to help make the production more realistic."""@en ;
  dcterms:modified "2026-06-07T15:30:15.114488Z"^^xsd:dateTime .

oakcurric:misconception-discussions-chats-arent-important
  a curric:Misconception ;
  curric:statement "That discussions are just 'chats' and aren't that important."@en ;
  curric:correction """Think about all of the times you may need to use your verbal skills e.g an
  interview or presentation. Being able to articulate yourself well verbally is an important
  skill to have."""@en ;
  dcterms:modified "2026-06-07T15:30:15.114499Z"^^xsd:dateTime .

oakcurric:misconception-significant-puck-performs-epilogue-characters
  a curric:Misconception ;
  curric:statement """It is not significant that Puck performs the epilogue. It could have been any
  of the characters."""@en ;
  curric:correction """There are many different ideas to explore in terms of why Puck performs this
  epilogue. It could speak to his centrality to the plot, his infamous reputation amongst
  the play's first Elizabethan audiences, and the way we should interpret key themes."""@en ;
  dcterms:modified "2026-06-07T15:30:15.115133Z"^^xsd:dateTime .

oakcurric:misconception-descriptive-writing-students-describe-their
  a curric:Misconception ;
  curric:statement """In descriptive writing, students often just describe what their protagonist
  can see. They often neglect the other senses."""@en ;
  curric:correction """To create the most vivid description possible, students should focus their
  description on the five sense, subtly moving between exploring how the scene feels,
  smells, looks, tastes and sounds."""@en ;
  dcterms:modified "2026-06-07T15:30:15.115139Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-gothic-settings-utterly
  a curric:Misconception ;
  curric:statement """Pupils think that Gothic settings have to be utterly terrifying to count as
  Gothic."""@en ;
  curric:correction """Gothic settings are not about frightening the reader as much as possible.
  They are about making the reader feel unsettled and creating an atmosphere of mystery and
  dark intrigue."""@en ;
  dcterms:modified "2026-06-07T15:30:15.115148Z"^^xsd:dateTime .

oakcurric:misconception-analysing-word-choice-exclusively-part
  a curric:Misconception ;
  curric:statement "That analysing word choice is exclusively part of language analysis."@en ;
  curric:correction """Analysing where certain words appear in a poem is an effective structural
  choice."""@en ;
  dcterms:modified "2026-06-07T15:30:15.115160Z"^^xsd:dateTime .

oakcurric:misconception-important-thing-poem-words
  a curric:Misconception ;
  curric:statement "The most important thing in a poem is the words."@en ;
  curric:correction """Structure is important, it can help tell your story. Not considering the
  structure of your poem is like an author not considering the beginning, middle and end of
  a novel."""@en ;
  dcterms:modified "2026-06-07T15:30:15.115168Z"^^xsd:dateTime .

oakcurric:misconception-memorising-presentation-script-makes-confident
  a curric:Misconception ;
  curric:statement """Memorising a presentation, or having a script, makes for a more confident
  delivery."""@en ;
  curric:correction """An effective presentation will have an element of spontaneity and naturalism
  about it. Relying on a script, or repeating a speech word for word, can lead to a robotic
  delivery and a less convincing presentation."""@en ;
  dcterms:modified "2026-06-07T15:30:15.115200Z"^^xsd:dateTime .

oakcurric:misconception-pankhurst-suffragettes-peaceful-protesters
  a curric:Misconception ;
  curric:statement "Pankhurst and the suffragettes were peaceful protesters."@en ;
  curric:correction """How does Pankhurst's speech convey some of the radical tactics or attitudes
  employed by the suffragettes? Pankhurst and her followers pushed boundaries and challenged
  societal norms to fight for women's rights."""@en ;
  dcterms:modified "2026-06-07T15:30:15.115224Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-inferences-guesses-without
  a curric:Misconception ;
  curric:statement "Pupils might think that inferences are just guesses without any evidence."@en ;
  curric:correction """Inferences are not guesses; they are conclusions drawn from evidence in the
  text. For example, Burge describes the fog as \"snaking\" around Martha. We infer that it
  is dangerous and sinister because the word \"snake\" often implies danger and malice."""@en ;
  dcterms:modified "2026-06-07T15:30:15.115632Z"^^xsd:dateTime .

oakcurric:misconception-working-class-social-class-likely
  a curric:Misconception ;
  curric:statement "The working class are the social class most likely to commit crime."@en ;
  curric:correction """What types of crime are more likely to be committed by the wealthy? Why might
  they be less likely to be punished?"""@en ;
  dcterms:modified "2026-06-07T15:30:15.115668Z"^^xsd:dateTime .

oakcurric:misconception-planning-necessary-writing
  a curric:Misconception ;
  curric:statement "Planning is not necessary before writing."@en ;
  curric:correction """Planning is important in helping us structure our work and keep a clear
  focus."""@en ;
  dcterms:modified "2026-06-07T15:30:15.115996Z"^^xsd:dateTime .

oakcurric:misconception-appearance-vs-reality-shown-othello
  a curric:Misconception ;
  curric:statement """Appearance vs. reality is only shown through Othello believing his wife is
  unfaithful."""@en ;
  curric:correction """There are many moments in the play in which appearance and reality are
  manipulated"""@en ;
  dcterms:modified "2026-06-07T15:30:15.116002Z"^^xsd:dateTime .

oakcurric:misconception-iago-evil-villain-completely-control
  a curric:Misconception ;
  curric:statement "Iago is an evil villain, completely in control the whole play."@en ;
  curric:correction "Iago begins to show his fallibility in 5.1."@en ;
  dcterms:modified "2026-06-07T15:30:15.116037Z"^^xsd:dateTime .

oakcurric:misconception-students-think-first-attempt-their
  a curric:Misconception ;
  curric:statement """Students often think that the first attempt at their response is the finished
  version."""@en ;
  curric:correction """Redrafting your work has many benefits and the second attempt is always
  superior. Taking time to reflect on your work and identify areas for improvements allows
  you to recognise any lack of clarity in your explanations."""@en ;
  dcterms:modified "2026-06-07T15:30:15.116043Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-dystopian-societies-involve
  a curric:Misconception ;
  curric:statement """Pupils may think that dystopian societies only involve dilapidated
  settings."""@en ;
  curric:correction """Explain that there are two sides in a dystopia: those with power and control
  who live in luxury and ordinary citizens in run down areas."""@en ;
  dcterms:modified "2026-06-07T15:30:15.117011Z"^^xsd:dateTime .

oakcurric:misconception-students-thinking-need-find-big
  a curric:Misconception ;
  curric:statement "Students thinking they need to  find big differences in the poems."@en ;
  curric:correction """It's often better to choose similarities and then explain and explore the
  subtle differences."""@en ;
  dcterms:modified "2026-06-07T15:30:15.117028Z"^^xsd:dateTime .

oakcurric:misconception-cant-include-quotations-exploring-enjambment
  a curric:Misconception ;
  curric:statement "You can't include quotations when exploring enjambment."@en ;
  curric:correction """If analysing enjambment, you must include a specific example. Just as you
  would include a quotation to explore a simile (for example) so must you include a
  quotation to explore enjambment."""@en ;
  dcterms:modified "2026-06-07T15:30:15.117042Z"^^xsd:dateTime .

oakcurric:misconception-students-immediately-think-relate-poem
  a curric:Misconception ;
  curric:statement """Students may not immediately think they can relate to the poem, if their own
  home does not have distinct elements of their culture or heritage."""@en ;
  curric:correction """Explain how everyone can relate to the idea of having a filter on. Whilst
  Subramaniam takes off her filter and reveals her heritage at home, your students might
  reveal their true personality or hobbies through home."""@en ;
  dcterms:modified "2026-06-07T15:30:15.117056Z"^^xsd:dateTime .

oakcurric:misconception-long-content-poem-good-performance
  a curric:Misconception ;
  curric:statement """As long as the content of a poem is good, the performance will automatically
  be good."""@en ;
  curric:correction """Performance requires practise in a unique set of skills which are worth
  practising as a good performance can enhance the poem content."""@en ;
  dcterms:modified "2026-06-07T15:30:15.117064Z"^^xsd:dateTime .

oakcurric:misconception-put-literary-analysis-part-your
  a curric:Misconception ;
  curric:statement """That you should put literary analysis in every part of your analytical
  writing."""@en ;
  curric:correction """You shouldn't put literary analysis in your topic sentence - it should just
  explain the main idea of the paragraph concisely."""@en ;
  dcterms:modified "2026-06-07T15:30:15.117082Z"^^xsd:dateTime .

oakcurric:misconception-letters-used-novels-drive-plot
  a curric:Misconception ;
  curric:statement "Letters are only used in novels to drive the plot forward."@en ;
  curric:correction """Letters can also give a reader an insight into a character's thoughts and
  feelings, as well as background information. They can also be used as an effective way to
  create dramatic irony."""@en ;
  dcterms:modified "2026-06-07T15:30:15.117654Z"^^xsd:dateTime .

oakcurric:misconception-oberon-knows-titania-fall-love
  a curric:Misconception ;
  curric:statement "Oberon knows Titania will fall in love with Bottom."@en ;
  curric:correction """Oberon hopes Titania will fall in love with something \"vile\" but he doesn't
  know about Bottom, or his transformation, until Puck tells him the joke he has played."""@en ;
  dcterms:modified "2026-06-07T15:30:15.118393Z"^^xsd:dateTime .

oakcurric:misconception-students-rush-ending-their-work
  a curric:Misconception ;
  curric:statement """Students often rush the ending of their work - particularly if they are
  writing in timed conditions."""@en ;
  curric:correction """The ending is arguably the most important part of the piece of writing.
  Students need to leave their reader with a clear message that is memorable. The ending
  ties together the threads of the argument and reinforces the writer's viewpoint."""@en ;
  dcterms:modified "2026-06-07T15:30:15.118398Z"^^xsd:dateTime .

oakcurric:misconception-students-think-write-their-own
  a curric:Misconception ;
  curric:statement """Students often think that they have to write from their own perspective - that
  the 'voice' in the article has to be their own."""@en ;
  curric:correction """Students can create a voice. For example, they could write the article from
  the perspective of a teacher or a parent. This is still voice."""@en ;
  dcterms:modified "2026-06-07T15:30:15.118411Z"^^xsd:dateTime .

oakcurric:misconception-pupils-dont-see-value-editing
  a curric:Misconception ;
  curric:statement """Pupils often don't see the value in editing work and think once the first
  draft is finished, the work on it is done."""@en ;
  curric:correction """Writing is a process that involves multiple stages. Revising and editing are
  crucial steps to refine your work, enhance clarity, and improve overall quality. Even
  professional writers revise their drafts several times before publishing."""@en ;
  dcterms:modified "2026-06-07T15:30:15.118417Z"^^xsd:dateTime .

oakcurric:misconception-term-complex-sentence-synonym-long
  a curric:Misconception ;
  curric:statement "The term complex sentence is a synonym for a long sentence."@en ;
  curric:correction """A complex sentence is a technical term. It refers to a sentence that has a
  main clause and a subordinate clause. Sentences can be long but if they don't have a
  subordinate clause, they are not a complex sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:15.118422Z"^^xsd:dateTime .

oakcurric:misconception-students-unfamiliar-term-region
  a curric:Misconception ;
  curric:statement "Students may be unfamiliar with the term 'region'."@en ;
  curric:correction "Help students recognise and learn about their own region."@en ;
  dcterms:modified "2026-06-07T15:30:15.118430Z"^^xsd:dateTime .

oakcurric:misconception-piece-writing-completely-finished-once
  a curric:Misconception ;
  curric:statement "That a piece of writing is completely finished once you have written it."@en ;
  curric:correction """The first time you complete a piece of writing is it in its draft form. You
  want to go back and continually revise it."""@en ;
  dcterms:modified "2026-06-07T15:30:15.118436Z"^^xsd:dateTime .

oakcurric:misconception-its-impossible-guess-happen-text
  a curric:Misconception ;
  curric:statement "That it's impossible to guess what will happen in a text."@en ;
  curric:correction """While we can't know for certain, we can pick up on clues that the writer
  gives us to make predictions about what will happen in a text."""@en ;
  dcterms:modified "2026-06-07T15:30:15.118447Z"^^xsd:dateTime .

oakcurric:misconception-subject-sentence-person-sentence
  a curric:Misconception ;
  curric:statement "That the subject of a sentence is always the person in the sentence."@en ;
  curric:correction """A subject is the person, place, or thing that is performing the action of the
  sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:15.118452Z"^^xsd:dateTime .

oakcurric:misconception-students-think-serious-topics-need
  a curric:Misconception ;
  curric:statement """Students often think that serious topics need serious text types such as
  articles or speeches."""@en ;
  curric:correction """Encourage students to consider why a writer might choose to use a poem to
  write about a serious topic and take a stand."""@en ;
  dcterms:modified "2026-06-07T15:30:15.118458Z"^^xsd:dateTime .

oakcurric:misconception-hortense-simply-ungrateful
  a curric:Misconception ;
  curric:statement "That Hortense is simply ungrateful."@en ;
  curric:correction """Think about the promises and expectations that were used to encourage
  migration. View Hortense's and Gilbert's interaction in light of this betrayal."""@en ;
  dcterms:modified "2026-06-07T15:30:15.118588Z"^^xsd:dateTime .

oakcurric:misconception-figurative-language-metaphors-synonyms
  a curric:Misconception ;
  curric:statement "Figurative language and metaphors are synonyms."@en ;
  curric:correction """All metaphors are examples of figurative language. But not all figurative
  language is a metaphor. For example, personification, hyperbole and simile are also
  examples of figurative language."""@en ;
  dcterms:modified "2026-06-07T15:30:15.118894Z"^^xsd:dateTime .

oakcurric:misconception-reader-automatically-able-follow-your
  a curric:Misconception ;
  curric:statement """That the reader will automatically be able to follow your train of
  thought."""@en ;
  curric:correction """We all have different connotations from words; you need to clearly explain
  how you have reached your idea in order for the reader to be able to understand your
  argument."""@en ;
  dcterms:modified "2026-06-07T15:30:15.118899Z"^^xsd:dateTime .

oakcurric:misconception-using-similes-itself-effective-descriptive
  a curric:Misconception ;
  curric:statement "That using similes is in itself effective descriptive writing."@en ;
  curric:correction """You should aim to have a simile that creates a specific emotion and avoids
  clichés."""@en ;
  dcterms:modified "2026-06-07T15:30:15.118910Z"^^xsd:dateTime .

oakcurric:misconception-long-am-comparing-key-points
  a curric:Misconception ;
  curric:statement "As long as I am comparing the key points of two sources that is enough."@en ;
  curric:correction """Using both comparative and correlative conjunctions will ensure there is
  nuance in your comparisons. They will aslo help keep your comparisons succinct."""@en ;
  dcterms:modified "2026-06-07T15:30:15.118938Z"^^xsd:dateTime .

oakcurric:misconception-students-think-need-plan-one
  a curric:Misconception ;
  curric:statement """Students might think that they only need to plan one single paragraph
  outline."""@en ;
  curric:correction """Students will need to plan one paragraph outline per section of their
  response."""@en ;
  dcterms:modified "2026-06-07T15:30:15.118994Z"^^xsd:dateTime .

oakcurric:misconception-cant-refer-other-writers-texts
  a curric:Misconception ;
  curric:statement "You can't refer to other writers or texts in your analysis."@en ;
  curric:correction """Often, you will be asked to write about a text, and that text should
  certainly be your focus. However, you can refer to other writers or texts if they help
  develop your analysis and understanding. This is called literary context."""@en ;
  dcterms:modified "2026-06-07T15:30:15.118999Z"^^xsd:dateTime .

oakcurric:misconception-flashback-way-include-information-characters
  a curric:Misconception ;
  curric:statement "Flashback is the only way to include information about a character's past."@en ;
  curric:correction """Flashback is a powerful method and one which lots of writers rely on.
  However, there are many other ways to include details about a character's past. For
  example, explanation from a character or dialogue between characters."""@en ;
  dcterms:modified "2026-06-07T15:30:15.119008Z"^^xsd:dateTime .

oakcurric:misconception-need-plan-debate
  a curric:Misconception ;
  curric:statement "I do not need to plan for a debate."@en ;
  curric:correction """To participate effectively in debate you will need to have clear arguments
  and rebuttals, that are backed up with evidence. Planning will ensure you can do this
  confidently."""@en ;
  dcterms:modified "2026-06-07T15:30:15.119019Z"^^xsd:dateTime .

oakcurric:misconception-immediately-start-trying-spot-language
  a curric:Misconception ;
  curric:statement """That you should immediately start trying to spot language devices when reading
  an unseen extract."""@en ;
  curric:correction """It's better to take the time to understand what is happening before starting
  to think about how the writer creates meaning."""@en ;
  dcterms:modified "2026-06-07T15:30:15.119035Z"^^xsd:dateTime .

oakcurric:misconception-oberon-puck-deliberately-try-create
  a curric:Misconception ;
  curric:statement """Oberon and Puck deliberately try and create disorder between Hermia, Lysander,
  Helena and Demetrius."""@en ;
  curric:correction """Oberon orders Puck to put the magical potion on Demetrius so that he falls in
  love with Helena. Puck makes a genuine mistake by putting it on Lysander."""@en ;
  dcterms:modified "2026-06-07T15:30:15.119584Z"^^xsd:dateTime .

oakcurric:misconception-williams-didnt-use-methods-his
  a curric:Misconception ;
  curric:statement """Williams didn't use any methods in his poem because he is just describing a
  painting."""@en ;
  curric:correction """Every word in a poem is carefully selected. Williams could have made any
  number of choices about what he depicted in terms of focus, structure, tone and language.
  We can explore these methods, and add layers of meaning to the painting."""@en ;
  dcterms:modified "2026-06-07T15:30:15.119592Z"^^xsd:dateTime .

oakcurric:misconception-othello-live-others-expectations-opinions
  a curric:Misconception ;
  curric:statement "Othello will live up to others' expectations and opinions of him."@en ;
  curric:correction """Othello is completely different to other's perceptions of him. Indeed, he
  must be worthy of sympathy if he is to be a tragic hero."""@en ;
  dcterms:modified "2026-06-07T15:30:15.119598Z"^^xsd:dateTime .

oakcurric:misconception-poems-meant-read-your-head
  a curric:Misconception ;
  curric:statement "Poems are meant to be read in your head."@en ;
  curric:correction """When poets write poems, they play close attention to their sounds and rhythm.
  As such, it's often important and desirable to hear poems aloud."""@en ;
  dcterms:modified "2026-06-07T15:30:15.119604Z"^^xsd:dateTime .

oakcurric:misconception-use-impressive-sounding-words-your
  a curric:Misconception ;
  curric:statement """You should always use the most impressive sounding words in your
  description."""@en ;
  curric:correction """While you should reach for ambitious words, you want to ensure that all the
  words you use are creating a consistent atmosphere."""@en ;
  dcterms:modified "2026-06-07T15:30:15.119611Z"^^xsd:dateTime .

oakcurric:misconception-symbols-literature-mean-same-everyone
  a curric:Misconception ;
  curric:statement "That symbols in literature mean the same to everyone."@en ;
  curric:correction """Our responses to symbolism depend on our experiences as well as exposure to
  certain concepts so we might all have very different responses."""@en ;
  dcterms:modified "2026-06-07T15:30:15.119626Z"^^xsd:dateTime .

oakcurric:misconception-word-blending-type-compound
  a curric:Misconception ;
  curric:statement "That 'word blending' is a type of compound."@en ;
  curric:correction """'Word blending' combines only part of other words whereas word compounds
  combines the entirety of two existing words to form a new one."""@en ;
  dcterms:modified "2026-06-07T15:30:15.120046Z"^^xsd:dateTime .

oakcurric:misconception-characters-midsummer-nights-dream-elizabethan
  a curric:Misconception ;
  curric:statement "The characters in 'A Midsummer Night's Dream' are Elizabethan."@en ;
  curric:correction """The play's first audiences were Elizabethan, and Shakespeare explores
  Elizabethan attitudes and ideas in the play. But the play is set in Athens many centuries
  before the Elizabethan period."""@en ;
  dcterms:modified "2026-06-07T15:30:15.120055Z"^^xsd:dateTime .

oakcurric:misconception-students-recognise-possibility-sound-old
  a curric:Misconception ;
  curric:statement """Students might not recognise that there is a possibility that the sound of the
  old man's heart beating, may be the sound of the narrator's own heart beating."""@en ;
  curric:correction """Some may interpret the sound of the old man's heart beating as the sound of
  the narrator's own heart beating, with anticipation and excitement at the prospect of the
  imminent murder."""@en ;
  dcterms:modified "2026-06-07T15:30:15.120061Z"^^xsd:dateTime .

oakcurric:misconception-slam-poetry-doesnt-rules-conventions
  a curric:Misconception ;
  curric:statement """Slam poetry doesn't have any rules or conventions, so anything goes. It's just
  speaking to an audience."""@en ;
  curric:correction """While slam poetry encourages creativity and self-expression, it does follow
  certain conventions, like using sound techniques, imagery and themes. These conventions
  help poets effectively communicate their messages and engage the audience."""@en ;
  dcterms:modified "2026-06-07T15:30:15.120067Z"^^xsd:dateTime .

oakcurric:misconception-students-try-draw-parallels-jack
  a curric:Misconception ;
  curric:statement """Students might try to draw parallels between Jack and the snake from the
  Garden of Eden."""@en ;
  curric:correction """Arguably, the temptation is not Jack himself, but the savagery and evil that
  resides within him. It is the \"beast\" within him that tempts him to evil."""@en ;
  dcterms:modified "2026-06-07T15:30:15.120073Z"^^xsd:dateTime .

oakcurric:misconception-students-think-symbols-text-physical
  a curric:Misconception ;
  curric:statement """Students think that symbols in a text have to be physical objects that
  represent ideas."""@en ;
  curric:correction """Symbolism is the use of images, words or nouns to represent abstract ideas or
  qualities - symbols do not have to be physical objects that can be picked up and held."""@en ;
  dcterms:modified "2026-06-07T15:30:15.120093Z"^^xsd:dateTime .

oakcurric:misconception-fisherman-jinni-framing-story-because
  a curric:Misconception ;
  curric:statement """'The Fisherman the and Jinni' is a framing story because there is a story
  within it."""@en ;
  curric:correction """The story of King Yunan and his sage is a story within a story. In 'One
  Thousand and One Nights', the frame story is only that of Shahrazad and Shahrayar. This
  frame story punctuates all the tales, with dialogue between husband and wife throughout."""@en ;
  dcterms:modified "2026-06-07T15:30:15.120099Z"^^xsd:dateTime .

oakcurric:misconception-five-part-narrative-structure-way
  a curric:Misconception ;
  curric:statement "The five part narrative structure is the only way to structure a story."@en ;
  curric:correction """There are lots of ways to create a story that is structured. This is one
  example. The most important thing to remember is that whatever your structure, it should
  be considered and carefully planned."""@en ;
  dcterms:modified "2026-06-07T15:30:15.120105Z"^^xsd:dateTime .

oakcurric:misconception-figurative-language-synonym-metaphor-simile
  a curric:Misconception ;
  curric:statement "Figurative language is a synonym for a metaphor or simile."@en ;
  curric:correction """Metaphor and simile are both specific examples of figurative language.
  Figurative language is a broader term. Allusion, personification and hyperbole are other
  common examples of figurative language."""@en ;
  dcterms:modified "2026-06-07T15:30:15.120116Z"^^xsd:dateTime .

oakcurric:misconception-prepositions-arent-important-focal-point
  a curric:Misconception ;
  curric:statement "That prepositions aren't an important focal point for descriptive writing."@en ;
  curric:correction """Not only do prepositions indicate the relationship between words, but they
  also influence our perception of people based on their body language and positioning in a
  scene."""@en ;
  dcterms:modified "2026-06-07T15:30:15.120122Z"^^xsd:dateTime .

oakcurric:misconception-content-alone-enough-effective-formal
  a curric:Misconception ;
  curric:statement "Content alone is enough for an effective formal presentation."@en ;
  curric:correction """Consider the most engaging speakers and how they use tone, gestures and eye
  contact. Delivering a presentation is so much more than just the words on a page."""@en ;
  dcterms:modified "2026-06-07T15:30:15.120860Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-rift-novel-ralph
  a curric:Misconception ;
  curric:statement """Pupils may think that the rift in the novel is only between Ralph and
  Jack."""@en ;
  curric:correction """Draw attention to how the boys are increasingly living separately: Piggy is
  on his own, the \"littluns\" are a group by themselves and Simon sneaks away to be alone."""@en ;
  dcterms:modified "2026-06-07T15:30:15.120889Z"^^xsd:dateTime .

oakcurric:misconception-shakespearean-tragic-heroes-nobility-command
  a curric:Misconception ;
  curric:statement """Shakespearean tragic heroes are often nobility who command respect from all
  before their fall."""@en ;
  curric:correction """Othello, the tragic hero, is not respected by Iago and Roderigo because of
  his race."""@en ;
  dcterms:modified "2026-06-07T15:30:15.120931Z"^^xsd:dateTime .

oakcurric:misconception-shakespeare-wrote-according-aristotles-notion
  a curric:Misconception ;
  curric:statement "Shakespeare wrote only according to Aristotle's notion of tragedy."@en ;
  curric:correction """Shakespeare had his own beliefs about tragedy and combined them with
  Aristotle's ideas."""@en ;
  dcterms:modified "2026-06-07T15:30:15.120973Z"^^xsd:dateTime .

oakcurric:misconception-outsider-negative-thing
  a curric:Misconception ;
  curric:statement "That being an outsider is always a negative thing."@en ;
  curric:correction """Sometimes people are considered outsiders because they don't fit society's
  expectations of normal and that's not necessarily negative."""@en ;
  dcterms:modified "2026-06-07T15:30:15.120980Z"^^xsd:dateTime .

oakcurric:misconception-quotations-need-analysed-depth
  a curric:Misconception ;
  curric:statement "All quotations need to be analysed in depth."@en ;
  curric:correction """Not all quotations need the same level of analysis. Main quotations are
  central to your argument and should be analysed to show how they support your thesis.
  Supporting quotations are used to reinforce the point made with the main quotations."""@en ;
  dcterms:modified "2026-06-07T15:30:15.120986Z"^^xsd:dateTime .

oakcurric:misconception-pupils-mistake-simile-metaphor-vice
  a curric:Misconception ;
  curric:statement "Pupils might mistake a simile for metaphor and vice versa."@en ;
  curric:correction """Go through simile and metaphor definitions and examples slowly and
  explicitly."""@en ;
  dcterms:modified "2026-06-07T15:30:15.123253Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-island-novel-like
  a curric:Misconception ;
  curric:statement "Pupils often think the island in the novel is like a tropical paradise."@en ;
  curric:correction "Draw their attention to the suggestion of danger in the language used."@en ;
  dcterms:modified "2026-06-07T15:30:15.123259Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-physical-description-character
  a curric:Misconception ;
  curric:statement """Pupils may think that a physical description of a character is enough to help
  the reader understand what the character's personality is like."""@en ;
  curric:correction """Though physical description is really useful, considering verb and adverb
  choices in particular allows the reader to really imagine a character. For example, how
  they walk, talk and behave around others are all telling of their character."""@en ;
  dcterms:modified "2026-06-07T15:30:15.123267Z"^^xsd:dateTime .

oakcurric:misconception-solitude-feel-lonely
  a curric:Misconception ;
  curric:statement "If you are in solitude, you feel lonely."@en ;
  curric:correction """Solitude can be a pleasant state, one that lots of people seek out. It is
  different from feeling lonely or isolated."""@en ;
  dcterms:modified "2026-06-07T15:30:15.123281Z"^^xsd:dateTime .

oakcurric:misconception-modern-reader-victorian-reader-perceive
  a curric:Misconception ;
  curric:statement """That a modern reader and Victorian reader perceive the text and characters in
  the same way."""@en ;
  curric:correction "Use Victorian context to explain the difference between our attitudes."@en ;
  dcterms:modified "2026-06-07T15:30:15.123290Z"^^xsd:dateTime .

oakcurric:misconception-cant-plan-poem-poems-inspired
  a curric:Misconception ;
  curric:statement "You can't plan a poem. Poems are inspired, and just flow from the heart."@en ;
  curric:correction """Poems, just like paragraphs, can be planned. You can consider ideas and
  methods. Indeed, because poems are often shorter than other texts, planning each idea and
  method is even more important - no word can be wasted."""@en ;
  dcterms:modified "2026-06-07T15:30:15.123308Z"^^xsd:dateTime .

oakcurric:misconception-resolution-story-leave-unanswered-questions
  a curric:Misconception ;
  curric:statement """The resolution of a story will leave no unanswered questions and all conflicts
  resolved."""@en ;
  curric:correction """Sometimes there can still be a few things left open or unresolved. This can
  make the story more interesting and leave readers thinking about what might happen next."""@en ;
  dcterms:modified "2026-06-07T15:30:15.123339Z"^^xsd:dateTime .

oakcurric:misconception-autobiographies-considered-literary-forms-literature
  a curric:Misconception ;
  curric:statement "Autobiographies are not considered literary or forms of literature."@en ;
  curric:correction """Just like other forms of writing, writers of autobiographies will use
  literary devices to convey emotions and document events in detail."""@en ;
  dcterms:modified "2026-06-07T15:30:15.123344Z"^^xsd:dateTime .

oakcurric:misconception-choice-sentence-type-isnt-important
  a curric:Misconception ;
  curric:statement """That the choice of sentence type isn't important as long as the grammar and
  punctuation is correct."""@en ;
  curric:correction """The choice of sentence type can impact the way that a reader responds to your
  writing."""@en ;
  dcterms:modified "2026-06-07T15:30:15.123534Z"^^xsd:dateTime .

oakcurric:misconception-students-think-atmosphere-created-purely
  a curric:Misconception ;
  curric:statement """Students think that atmosphere is created purely through the description of a
  physical setting."""@en ;
  curric:correction """Atmosphere can also be created through characters interacting with one
  another, as we see in Chapter 11 of 'Jane Eyre'."""@en ;
  dcterms:modified "2026-06-07T15:30:15.124008Z"^^xsd:dateTime .

oakcurric:misconception-long-similes-metaphors-follow-correct
  a curric:Misconception ;
  curric:statement """As long as similes or metaphors follow the correct rules they will be
  effective."""@en ;
  curric:correction """Many comparisons in similes and metaphors are clichéd and this often takes
  away from a description and makes it unimaginative. The challenge is to try be original in
  your thought!"""@en ;
  dcterms:modified "2026-06-07T15:30:15.124022Z"^^xsd:dateTime .

oakcurric:misconception-isnt-humour-plays-like-small
  a curric:Misconception ;
  curric:statement """There isn’t any humour in plays like 'Small Island' because the subject matter
  is too serious."""@en ;
  curric:correction """Humour is used in 'Small Island' to make the characters more relatable and to
  provide moments of relief during tense scenes. It helps the audience connect with the
  story while still exploring serious issues."""@en ;
  dcterms:modified "2026-06-07T15:30:15.124034Z"^^xsd:dateTime .

oakcurric:misconception-proofreading-waste-time
  a curric:Misconception ;
  curric:statement "That proofreading is a waste of time."@en ;
  curric:correction """Proofreading helps you to spot errors that might hinder the readers'
  understanding of your work."""@en ;
  dcterms:modified "2026-06-07T15:30:15.124041Z"^^xsd:dateTime .

oakcurric:misconception-students-dont-think-include-rhetorical
  a curric:Misconception ;
  curric:statement """Students often don't think to include rhetorical devices within their topic
  sentences."""@en ;
  curric:correction """Just because the topic sentences introduces the main idea for the paragraph,
  that does not mean the topic sentence can't be really creative and engaging. It's crucial
  that it is engaging to motivate the reader to learn more about the topic."""@en ;
  dcterms:modified "2026-06-07T15:30:15.124717Z"^^xsd:dateTime .

oakcurric:misconception-single-paragraph-outlines-take-long
  a curric:Misconception ;
  curric:statement """Single paragraph outlines take too long to plan. You should just start
  writing."""@en ;
  curric:correction """Single paragraph outlines give you time to think and prepare. Spending time
  on these means that you will be able to write your paragraph efficiently knowing that it
  has a clear focus with well-selected supporting detail."""@en ;
  dcterms:modified "2026-06-07T15:30:15.124722Z"^^xsd:dateTime .

oakcurric:misconception-argument-means-heated-angry-exchange
  a curric:Misconception ;
  curric:statement "That an argument only means a heated, angry exchange."@en ;
  curric:correction """An argument about a text means presenting your idea and your points to prove
  that your idea is correct."""@en ;
  dcterms:modified "2026-06-07T15:30:15.124755Z"^^xsd:dateTime .

oakcurric:misconception-creative-writing-present-tense
  a curric:Misconception ;
  curric:statement "That creative writing should be in present tense."@en ;
  curric:correction """Because diaries are records of events that have happened, they should be
  written in past tense."""@en ;
  dcterms:modified "2026-06-07T15:30:15.124776Z"^^xsd:dateTime .

oakcurric:misconception-bernard-completely-rejects-queenies-baby
  a curric:Misconception ;
  curric:statement "Bernard completely rejects Queenie's baby due to his racial prejudices."@en ;
  curric:correction """What does the baby symbolise? How does Edmundson use Benard's behaviour to
  hint at the potential for reparation and change."""@en ;
  dcterms:modified "2026-06-07T15:30:15.125024Z"^^xsd:dateTime .

oakcurric:misconception-small-island-finishes-perfect-resolution
  a curric:Misconception ;
  curric:statement "That 'Small Island' finishes with a perfect resolution."@en ;
  curric:correction """What issues are addressed in these scenes? Is Edmundson suggesting that these
  have all been solved? Why is the theme of hope so important?"""@en ;
  dcterms:modified "2026-06-07T15:30:15.125275Z"^^xsd:dateTime .

oakcurric:misconception-poem-lost-their-lives-sad
  a curric:Misconception ;
  curric:statement "A poem about those who have lost their lives will always be sad."@en ;
  curric:correction """While laments for the dead contain sadness, they also often contain elements
  of hope and joy for the lives lived and the futures ahead."""@en ;
  dcterms:modified "2026-06-07T15:30:15.125458Z"^^xsd:dateTime .

oakcurric:misconception-students-think-once-written-their
  a curric:Misconception ;
  curric:statement """Students often think that once they have written their first draft, the piece
  is finished."""@en ;
  curric:correction """Writing is a process that involves several drafts of the same piece. Each
  time, editing and rewriting the draft makes the piece of writing better."""@en ;
  dcterms:modified "2026-06-07T15:30:15.127389Z"^^xsd:dateTime .

oakcurric:misconception-use-adjective-describe-noun
  a curric:Misconception ;
  curric:statement "You should use an adjective to describe every noun."@en ;
  curric:correction """Adjectives can help add interest and atmosphere to your writing. But not
  every noun needs an adjective. This can become overwhelming for the reader."""@en ;
  dcterms:modified "2026-06-07T15:30:15.127413Z"^^xsd:dateTime .

oakcurric:misconception-poetry-personal-event-emotional-possible
  a curric:Misconception ;
  curric:statement "Poetry about a personal event should be as emotional as possible."@en ;
  curric:correction """Armitage suggests that poetry about personal events should convey emotion
  without being too obvious or too sentimental."""@en ;
  dcterms:modified "2026-06-07T15:30:15.127587Z"^^xsd:dateTime .

oakcurric:misconception-caged-bird-presented-completely-powerless
  a curric:Misconception ;
  curric:statement "The caged bird is presented as completely powerless."@en ;
  curric:correction """Although the bird in the cage is confined, he still has power, through his
  song which speaks to his unbroken spirit. We are meant to draw a parallel to the strength
  of the Black community."""@en ;
  dcterms:modified "2026-06-07T15:30:15.127595Z"^^xsd:dateTime .

oakcurric:misconception-caliban-prospero-negative-relationship
  a curric:Misconception ;
  curric:statement "That Caliban and Prospero always have a negative relationship."@en ;
  curric:correction """When Prospero first arrived, Caliban showed Prospero how to survive on the
  island so it began as a positive relationship."""@en ;
  dcterms:modified "2026-06-07T15:30:15.127619Z"^^xsd:dateTime .

oakcurric:misconception-edmundson-reveals-dreams-futile-hopeless
  a curric:Misconception ;
  curric:statement "That Edmundson reveals that dreams are futile and hopeless."@en ;
  curric:correction """Examine the purpose of the idealistic view of England, what does it allow
  Hortense and Gilbert to do? What reaction do these moments of humour and hope have on the
  audience?"""@en ;
  dcterms:modified "2026-06-07T15:30:15.128771Z"^^xsd:dateTime .

oakcurric:misconception-analysis-means-zooming-individual-words
  a curric:Misconception ;
  curric:statement """Analysis means zooming in to individual words and explaining what they
  mean."""@en ;
  curric:correction """Exploring quotations is more than just looking at individual words and
  offering paraphrase or synonym. Your exploration of the quotation should develop your
  ideas about the question, and look at dramatic methods (more than just individual words)."""@en ;
  dcterms:modified "2026-06-07T15:30:15.131528Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-using-verb-associated
  a curric:Misconception ;
  curric:statement """Pupils think that using any verb that is associated with people makes good
  quality personification."""@en ;
  curric:correction """Provide pupils with a choices of verbs, including incongruous ones, to allow
  them to identify high quality personification."""@en ;
  dcterms:modified "2026-06-07T15:30:15.131536Z"^^xsd:dateTime .

oakcurric:misconception-pupils-judge-piggy-critical-standards
  a curric:Misconception ;
  curric:statement """Pupils often judge Piggy by the critical standards employed by the
  other boys."""@en ;
  curric:correction """Pick out examples of how sensible and intelligent Piggy is and how his
  judgement is usually sound."""@en ;
  dcterms:modified "2026-06-07T15:30:15.131560Z"^^xsd:dateTime .

oakcurric:misconception-othello-acts-way-simply-due
  a curric:Misconception ;
  curric:statement "Othello acts in the way he does simply due to his hamartia: jealousy."@en ;
  curric:correction """We must interrogate why Othello is targeted by Iago, how his outsider status
  makes him more susceptible to manipulation and insecurity."""@en ;
  dcterms:modified "2026-06-07T15:30:15.131575Z"^^xsd:dateTime .

oakcurric:misconception-planning-something-needs-practiced
  a curric:Misconception ;
  curric:statement "That planning is not something that needs to be practiced."@en ;
  curric:correction """What are the benefits of practising planning over writing whole essay
  responses? Not only is planning a very important part of the writing process, but an
  efficient way to practise essay writing."""@en ;
  dcterms:modified "2026-06-07T15:30:15.131586Z"^^xsd:dateTime .

oakcurric:misconception-descriptive-writing-telling-reader-whats
  a curric:Misconception ;
  curric:statement """That descriptive writing is all about telling the reader what's in the
  image."""@en ;
  curric:correction """Descriptive writing is about showing the reader what's in the image through
  sensory and figurative language."""@en ;
  dcterms:modified "2026-06-07T15:30:15.131592Z"^^xsd:dateTime .

oakcurric:misconception-perspective-presented-text-writers
  a curric:Misconception ;
  curric:statement "The only perspective presented in a text is the writer's."@en ;
  curric:correction """Texts can also include viewpoints of characters, experts or sources the
  writer references. In this article we also hear the subject's perspective through the use
  of quotations."""@en ;
  dcterms:modified "2026-06-07T15:30:15.131598Z"^^xsd:dateTime .

oakcurric:misconception-memorising-speech-script-makes-confident
  a curric:Misconception ;
  curric:statement """That memorising the speech, or having a script, makes for a more confident
  delivery."""@en ;
  curric:correction """An effective speech will have an element of spontaneity and naturalism about
  it. Relying on a script, or repeating a speech word for word, can lead to a robotic
  delivery and a less convincing speech."""@en ;
  dcterms:modified "2026-06-07T15:30:15.132077Z"^^xsd:dateTime .

oakcurric:misconception-oberon-finds-disorder-athenian-nobles
  a curric:Misconception ;
  curric:statement "Oberon finds the disorder between the Athenian nobles funny."@en ;
  curric:correction """As soon as Oberon realises Puck's mistake, he swiftly tries to
  correct it."""@en ;
  dcterms:modified "2026-06-07T15:30:15.133582Z"^^xsd:dateTime .

oakcurric:misconception-isnt-important-pucks-mistake-genuine
  a curric:Misconception ;
  curric:statement "It isn't important that Puck's mistake is genuine."@en ;
  curric:correction """Without understanding what happens, and why, in Act 2, Scene 2, we won't have
  an accurate understanding of Shakespeare's characterisation of Puck which deepens and
  develops throughout the play."""@en ;
  dcterms:modified "2026-06-07T15:30:15.133591Z"^^xsd:dateTime .

oakcurric:misconception-word-choice-important-rhythm
  a curric:Misconception ;
  curric:statement "Word choice is more important than rhythm."@en ;
  curric:correction """Word choice and powerful literary methods (for example metaphor) are hard
  things to craft and deserve time and attention. But so too does your sentence
  construction. Consider if you heard one of your favourite songs but there was no rhythm to
  it."""@en ;
  dcterms:modified "2026-06-07T15:30:15.133597Z"^^xsd:dateTime .

oakcurric:misconception-use-single-paragraph-outlines-plan
  a curric:Misconception ;
  curric:statement "You can only use single paragraph outlines to plan analytical writing."@en ;
  curric:correction """We structure so much of our writing using paragraphs. All paragraphs, whether
  creative or analytical or something else, require a clear and carefully planned structure."""@en ;
  dcterms:modified "2026-06-07T15:30:15.133609Z"^^xsd:dateTime .

oakcurric:misconception-students-think-piggys-death-accident
  a curric:Misconception ;
  curric:statement """Students may think that Piggy's death is an accident, similar in kind to
  Simon's, an example of boys getting carried away."""@en ;
  curric:correction """Draw pupils' attention to the fact that Roger is compared to a hangman. A
  hangman kills intentionally."""@en ;
  dcterms:modified "2026-06-07T15:30:15.133614Z"^^xsd:dateTime .

oakcurric:misconception-third-person-omniscient-narrator-develop
  a curric:Misconception ;
  curric:statement """A third person omniscient narrator must develop each character in the same
  amount of detail."""@en ;
  curric:correction """Whilst a third person omniscient narrator can develop many characters, they
  don't need the same amount of space, detail and time in a written piece. You can still
  have a central character, and minor characters who are more or less important."""@en ;
  dcterms:modified "2026-06-07T15:30:15.133620Z"^^xsd:dateTime .

oakcurric:misconception-because-gilbert-jokes-confident-means
  a curric:Misconception ;
  curric:statement """Because Gilbert jokes and is confident, it means he isn’t really affected by
  racism or hardship."""@en ;
  curric:correction """Gilbert uses humour to hide pain. Arguably, his confidence masks his
  struggle, making his experience more powerful and real. Consider this when you watch the
  perfomance."""@en ;
  dcterms:modified "2026-06-07T15:30:15.133626Z"^^xsd:dateTime .

oakcurric:misconception-plan-piece-creative-writing
  a curric:Misconception ;
  curric:statement "That you always have to plan before a piece of creative writing."@en ;
  curric:correction """While a plan is very useful, and should be used in most cases, sometimes free
  writing can be a way of unleashing creativity that can then be revised."""@en ;
  dcterms:modified "2026-06-07T15:30:15.133632Z"^^xsd:dateTime .

oakcurric:misconception-oberons-commands-status-dominance-dialogue
  a curric:Misconception ;
  curric:statement """Oberon's commands, status and dominance in the dialogue mean he can only be
  interpreted as powerful."""@en ;
  curric:correction """There is much to suggest Oberon's power in this scene, but dialogue can be
  interpreted in many ways, and performance can affect how we perceive a character. There is
  no single reading of the play."""@en ;
  dcterms:modified "2026-06-07T15:30:15.137339Z"^^xsd:dateTime .

oakcurric:misconception-students-simply-method-spot-analytical
  a curric:Misconception ;
  curric:statement "Students often simply 'method spot' in analytical responses."@en ;
  curric:correction """The writer's intention should form part of students' analysis of the text, as
  they should be outlining why the writer has used the method."""@en ;
  dcterms:modified "2026-06-07T15:30:15.137359Z"^^xsd:dateTime .

oakcurric:misconception-students-use-descriptions-functional-writing
  a curric:Misconception ;
  curric:statement """Students often do not use descriptions in functional writing frequently
  enough."""@en ;
  curric:correction """Descriptive language massively enhances functional writing. Anecdotes are a
  brilliant example of how descriptive writing can be used to connect to the
  reader/audience."""@en ;
  dcterms:modified "2026-06-07T15:30:15.137367Z"^^xsd:dateTime .

oakcurric:misconception-students-tend-think-humans-good
  a curric:Misconception ;
  curric:statement "Students tend to think of humans as being good and monsters as being evil."@en ;
  curric:correction """In this novel, the line between good and evil is blurred. Shelley forces us
  to question who the real monster is in the novel."""@en ;
  dcterms:modified "2026-06-07T15:30:15.137374Z"^^xsd:dateTime .

oakcurric:misconception-pupils-reveal-things-early-descriptions
  a curric:Misconception ;
  curric:statement """Pupils often reveal things early-on in descriptions by saying things like 'it
  was a painting' and then proceeding to describe it."""@en ;
  curric:correction """It can be much more effective to describe your narrator's view before
  revealing what the view actually is. This way, the reader is kept in a state of
  anticipation, as they try to work out what the view is."""@en ;
  dcterms:modified "2026-06-07T15:30:15.137379Z"^^xsd:dateTime .

oakcurric:misconception-using-semicolons-colons-interchangeably
  a curric:Misconception ;
  curric:statement "Using semicolons and colons interchangeably"@en ;
  curric:correction """A semicolon always has to have an independent clause on either side
  of it."""@en ;
  dcterms:modified "2026-06-07T15:30:15.137385Z"^^xsd:dateTime .

oakcurric:misconception-students-think-golding-sits-nature
  a curric:Misconception ;
  curric:statement """Students think that Golding sits on the 'nature' side of the nature/nurture
  debate."""@en ;
  curric:correction """Golding does not provide us with a concrete answer- he suggests that we all
  have the capacity (or the impulses) to behave sinfully, but it takes the right
  circumstances for brutality to emerge."""@en ;
  dcterms:modified "2026-06-07T15:30:15.137391Z"^^xsd:dateTime .

oakcurric:misconception-modern-experience-going-theatre-same
  a curric:Misconception ;
  curric:statement """That the modern experience of going to the theatre is the same as in
  Shakespearean times."""@en ;
  curric:correction """The experience was very different - the modern theatre experience is quiet
  and respectful while the Shakespearean experience was riotous."""@en ;
  dcterms:modified "2026-06-07T15:30:15.140630Z"^^xsd:dateTime .

oakcurric:misconception-students-try-read-poem-rather
  a curric:Misconception ;
  curric:statement "Students might try to read the poem rather than recite."@en ;
  curric:correction "Encourage students to learn as much of the poem as possible."@en ;
  dcterms:modified "2026-06-07T15:30:15.141159Z"^^xsd:dateTime .

oakcurric:misconception-students-think-characters-methods-tend
  a curric:Misconception ;
  curric:statement """Students often think that characters are not methods. They tend to think of
  methods as just 'similes' or 'metaphors'."""@en ;
  curric:correction """Any choice that the writer makes consciously is a method. This includes their
  use of characterisation. Anything the character says or does is a method."""@en ;
  dcterms:modified "2026-06-07T15:30:15.141167Z"^^xsd:dateTime .

oakcurric:misconception-introduction-written-without-thoughtful-planning
  a curric:Misconception ;
  curric:statement "An introduction can be written without thoughtful planning"@en ;
  curric:correction """To make an introduction worthwhile, and for it to effectively introduce an
  essay, it requires thoughtful planning"""@en ;
  dcterms:modified "2026-06-07T15:30:15.141244Z"^^xsd:dateTime .

oakcurric:misconception-climax-comes-end-story
  a curric:Misconception ;
  curric:statement "The climax comes at the end of a story."@en ;
  curric:correction """The climax is actually the high point of tension and action in a story, not
  necessarily at the end. It usually occurs towards the end but is followed by the
  resolution where the remaining conflicts are settled."""@en ;
  dcterms:modified "2026-06-07T15:30:15.141322Z"^^xsd:dateTime .

oakcurric:misconception-students-appreciate-creatures-eloquence-fact
  a curric:Misconception ;
  curric:statement """Students do not appreciate the Creature's eloquence and the fact that he has
  educated himself."""@en ;
  curric:correction """The Creature is a persuasive and eloquent character who manages to convince
  Victor to begin making him a mate."""@en ;
  dcterms:modified "2026-06-07T15:30:15.144095Z"^^xsd:dateTime .

oakcurric:misconception-tragedy-simply-sad-play
  a curric:Misconception ;
  curric:statement "A tragedy is simply a sad play."@en ;
  curric:correction """Tragedies have specific conventions, such as a tragic hero and their
  hamartia, a tragic fall and elements of fate or the supernatural."""@en ;
  dcterms:modified "2026-06-07T15:30:15.144126Z"^^xsd:dateTime .

oakcurric:misconception-planning-seen-waste-time
  a curric:Misconception ;
  curric:statement "Planning can often be seen as a waste of time."@en ;
  curric:correction """You must take time to make notes and gather ideas so the analysis you write
  is strong."""@en ;
  dcterms:modified "2026-06-07T15:30:15.144135Z"^^xsd:dateTime .

oakcurric:misconception-students-confused-turners-fate-end
  a curric:Misconception ;
  curric:statement "Students may be confused about Turner's fate at the end of the story."@en ;
  curric:correction """Explain that no two Sherlock Holmes mysteries are the same. Two perpetrators
  can face different fates."""@en ;
  dcterms:modified "2026-06-07T15:30:15.144141Z"^^xsd:dateTime .

oakcurric:misconception-students-recognise-value-using-semantic
  a curric:Misconception ;
  curric:statement """Students do not recognise the value in using semantic fields - they think that
  semantic fields are just a method that they can spot in other writers' texts."""@en ;
  curric:correction """Using semantic fields can help us to include figurative language, such as
  extended metaphors. They are means of including other methods - they are not necessarily a
  stand-alone method."""@en ;
  dcterms:modified "2026-06-07T15:30:15.144662Z"^^xsd:dateTime .

oakcurric:misconception-natural-imagery-designed-help-paint
  a curric:Misconception ;
  curric:statement """That natural imagery is only designed to help paint a picture to the
  reader."""@en ;
  curric:correction """Natural imagery can also be used to suggest a concept is natural or make a
  comment about the relationship between humans and nature."""@en ;
  dcterms:modified "2026-06-07T15:30:15.144669Z"^^xsd:dateTime .

oakcurric:misconception-common-symbols-across-literature
  a curric:Misconception ;
  curric:statement "There are no common symbols across literature."@en ;
  curric:correction """There are many common symbols across literature which writers use knowing
  that many of their readers will know what they mean. For example, a crown to symbolise
  power. A rose to symbolise love. Birds to symbolise freedom."""@en ;
  dcterms:modified "2026-06-07T15:30:15.144674Z"^^xsd:dateTime .

oakcurric:misconception-ekphrastic-poems-poems-inspired-someone
  a curric:Misconception ;
  curric:statement "Ekphrastic poems are poems inspired by someone or something."@en ;
  curric:correction """Ekphrastic poems are poems inspired by a piece of art, and they describe that
  piece of art in the poem."""@en ;
  dcterms:modified "2026-06-07T15:30:15.144680Z"^^xsd:dateTime .

oakcurric:misconception-angelou-copied-dunbar-copying-allowed
  a curric:Misconception ;
  curric:statement "Angelou copied Dunbar. Copying is not allowed."@en ;
  curric:correction """Many writers learn from, and are inspired by, others. Angelou's poem is very
  different to Dunbar's - her personal style and voice come through - but the central
  metaphor 'speaks' from one poem to another, developing a relationship between them."""@en ;
  dcterms:modified "2026-06-07T15:30:15.144688Z"^^xsd:dateTime .

oakcurric:misconception-path-news-clips-old-videos
  a curric:Misconception ;
  curric:statement """The Pathé news clips are just old videos used as a backdrop and don’t add
  meaning to the play."""@en ;
  curric:correction """The Pathé clips set the historical context and show a biased view of the
  British Empire. They contrast with the characters’ real experiences, deepening our
  understanding of the story’s themes."""@en ;
  dcterms:modified "2026-06-07T15:30:15.144786Z"^^xsd:dateTime .

oakcurric:misconception-newspaper-articles-strictly-adhere-factual
  a curric:Misconception ;
  curric:statement """Newspaper articles must strictly adhere to factual reporting without any
  creative elements."""@en ;
  curric:correction """While newspaper articles are based on factual reporting, they often
  incorporate language devices like puns, alliteration and sensationalist language in
  headlines and sometimes throughout the article. These elements are used to engage readers."""@en ;
  dcterms:modified "2026-06-07T15:30:15.144815Z"^^xsd:dateTime .

oakcurric:misconception-respond-description-same-way
  a curric:Misconception ;
  curric:statement "That we will all respond to a description in the same way."@en ;
  curric:correction """The way we respond to a description and the language devices will always be
  unique because we all have different experiences."""@en ;
  dcterms:modified "2026-06-07T15:30:15.147232Z"^^xsd:dateTime .

oakcurric:misconception-women-act-1-consider-marriage
  a curric:Misconception ;
  curric:statement """That only the women in Act 1 consider marriage almost like a business
  transaction."""@en ;
  curric:correction """What does Gilbert gain from his marriage to Hortense? How does he describe
  his feelings towards Hortense and what does this tell the audience?"""@en ;
  dcterms:modified "2026-06-07T15:30:15.147238Z"^^xsd:dateTime .

oakcurric:misconception-reading-poem-aloud-same-reading
  a curric:Misconception ;
  curric:statement "Reading a poem aloud is the same as reading prose aloud."@en ;
  curric:correction """When reading a poem, you need to consider the line breaks in a way that you
  don't have to with prose."""@en ;
  dcterms:modified "2026-06-07T15:30:15.147255Z"^^xsd:dateTime .

oakcurric:misconception-context-separate-ideas-analysis
  a curric:Misconception ;
  curric:statement "Context is separate to ideas and analysis."@en ;
  curric:correction """Context is not an add on for an essay, it is something that can shape
  arguments."""@en ;
  dcterms:modified "2026-06-07T15:30:15.147261Z"^^xsd:dateTime .

oakcurric:misconception-folktales-connection-frame-story
  a curric:Misconception ;
  curric:statement "The folktales have no connection to the frame story."@en ;
  curric:correction """The folktales are being told by Shahrazad. The fact that she is trying to
  save her life by telling the stories is important. But more than this, you can also make
  connections between the ideas, plot and characters in the folktales to the frame story."""@en ;
  dcterms:modified "2026-06-07T15:30:15.147270Z"^^xsd:dateTime .

oakcurric:misconception-create-tone-via-1-3
  a curric:Misconception ;
  curric:statement "You can create tone via 1-3 words."@en ;
  curric:correction """Show that tone is established through consistent effort and crafting
  throughout the writing process - every word is picked precisely."""@en ;
  dcterms:modified "2026-06-07T15:30:15.147318Z"^^xsd:dateTime .

oakcurric:misconception-soldiers-england-fought-britain-ww1
  a curric:Misconception ;
  curric:statement "That only soldiers from England fought for Britain in WW1."@en ;
  curric:correction "Soldiers from all over the British Empire fought for Britain."@en ;
  dcterms:modified "2026-06-07T15:30:15.147324Z"^^xsd:dateTime .

oakcurric:misconception-students-think-first-version-their
  a curric:Misconception ;
  curric:statement "Students think that the first version of their work is the finished piece."@en ;
  curric:correction """Redrafting work improves its quality, depth and coherence. Students should be
  encouraged to appreciate, and embrace the value of redrafting their work."""@en ;
  dcterms:modified "2026-06-07T15:30:15.147330Z"^^xsd:dateTime .

oakcurric:misconception-objective-writing-world-events
  a curric:Misconception ;
  curric:statement "You should be objective when you are writing about world events."@en ;
  curric:correction """Armitage suggests that poetry is about the individual and that we have a
  responsibility to reflect our personal responses to what's happening in the world."""@en ;
  dcterms:modified "2026-06-07T15:30:15.147646Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-headline-alone-enough
  a curric:Misconception ;
  curric:statement """Pupils may think that a headline alone is enough to convey the entire story of
  an article."""@en ;
  curric:correction """Explain that while a headline grabs attention and hints at the article's
  content, it's the subheading and body text that provide the full details and context.
  Emphasise the importance of each element working together to inform the reader."""@en ;
  dcterms:modified "2026-06-07T15:30:15.147771Z"^^xsd:dateTime .

oakcurric:misconception-character-foil-another-because-characters
  a curric:Misconception ;
  curric:statement "Every character is a foil to another because all characters are different."@en ;
  curric:correction """Whilst characters, like humans, are unique, not every character serves as a
  foil. Strangely, character foils often have similarities in terms of who they are, and
  what has happened to them, but their reactions to these things are different."""@en ;
  dcterms:modified "2026-06-07T15:30:15.148108Z"^^xsd:dateTime .

oakcurric:misconception-students-find-idea-house-metaphor
  a curric:Misconception ;
  curric:statement """Students may find the idea of house as a metaphor for the self
  challenging."""@en ;
  curric:correction "Draw their attention to their own ideas around houses."@en ;
  dcterms:modified "2026-06-07T15:30:15.148114Z"^^xsd:dateTime .

oakcurric:misconception-othellos-downfall-solely-due-his
  a curric:Misconception ;
  curric:statement "Othello's downfall is solely due to his own faults."@en ;
  curric:correction """Shakespeare carefully crafts Iago as someone who plays a huge role in
  Othello's downfall - acting like the serpent in the Garden of Eden."""@en ;
  dcterms:modified "2026-06-07T15:30:15.148120Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-using-exclamatory-sentences
  a curric:Misconception ;
  curric:statement """Pupils may think that using exclamatory sentences is appropriate in a
  newspaper article about Mormor's death to express strong emotions."""@en ;
  curric:correction """Explain that while exclamatory sentences express sudden or strong emotions,
  they are not appropriate for a factual newspaper article. Instead, emphasise using emotive
  language and other devices that convey the community's feelings respectfully."""@en ;
  dcterms:modified "2026-06-07T15:30:15.148135Z"^^xsd:dateTime .

oakcurric:misconception-opinions-think-dont-need-informed
  a curric:Misconception ;
  curric:statement """Opinions are just what you think and don't need to be informed by
  anything."""@en ;
  curric:correction """Opinions should be informed by available information or evidence. For
  example: prior knowledge, contextual information and the writer's language choices, can
  all help to create informed opinions."""@en ;
  dcterms:modified "2026-06-07T15:30:15.148803Z"^^xsd:dateTime .

oakcurric:misconception-everyone-respond-image-same-way
  a curric:Misconception ;
  curric:statement "Everyone will respond to an image in the same way."@en ;
  curric:correction """How you respond to an image, and what you choose to zoom in on, will be
  different for each person since we're all unique with different memories and experiences."""@en ;
  dcterms:modified "2026-06-07T15:30:15.148809Z"^^xsd:dateTime .

oakcurric:misconception-many-students-think-planning-isnt
  a curric:Misconception ;
  curric:statement """Many students often think that planning isn't a useful step in the writing
  process and that it takes too long."""@en ;
  curric:correction """How might planning help to organise our thoughts into a coherent response?
  How can planning improve the efficiency of the writing process?"""@en ;
  dcterms:modified "2026-06-07T15:30:15.148817Z"^^xsd:dateTime .

oakcurric:misconception-students-immediately-understand-title-come
  a curric:Misconception ;
  curric:statement """Students may not immediately understand the title if they have never come
  across 'colonialism' before."""@en ;
  curric:correction "Take some time unpicking why Clarke equates colonisation to stealing."@en ;
  dcterms:modified "2026-06-07T15:30:15.148823Z"^^xsd:dateTime .

oakcurric:misconception-lady-shalott-chooses-take-her
  a curric:Misconception ;
  curric:statement "The Lady of Shalott chooses to take her own life on the way to Camelot."@en ;
  curric:correction """The Lady of Shalott realises that, because she got up from her loom, she is
  now cursed. Knowing she will die from this curse, she gets into the boat to sail to
  Camelot. She realises she will not make it there alive."""@en ;
  dcterms:modified "2026-06-07T15:30:15.148829Z"^^xsd:dateTime .

oakcurric:misconception-pupils-overlook-simons-significance-novel
  a curric:Misconception ;
  curric:statement "Pupils often overlook Simon's significance in this novel."@en ;
  curric:correction """Simon is a very important character because he shows us that, in a world of
  evil, we can still act in a compassionate and civilised manner. Through Simon, Golding
  reminds us that our behaviour is a choice."""@en ;
  dcterms:modified "2026-06-07T15:30:15.148834Z"^^xsd:dateTime .

oakcurric:misconception-students-misuse-varying-forms-word
  a curric:Misconception ;
  curric:statement "Students may misuse the varying forms of the word \"symbolism.\""@en ;
  curric:correction "Explicitly teach them how the various forms are used in sentences."@en ;
  dcterms:modified "2026-06-07T15:30:15.148846Z"^^xsd:dateTime .

oakcurric:misconception-people-dont-use-literary-methods
  a curric:Misconception ;
  curric:statement "People don't use literary methods in nonfiction writing."@en ;
  curric:correction """Whenever you write any thing - even a shopping list - you are employing
  methods. Every word is a choice, thus every choice can be evaluated. In nonfiction writing
  (even nonfiction writing by people who aren't writers) methods will be used for effect."""@en ;
  dcterms:modified "2026-06-07T15:30:15.148852Z"^^xsd:dateTime .

oakcurric:misconception-one-interpretation-text-your-job
  a curric:Misconception ;
  curric:statement """There is one interpretation of a text and it is your job as a student of
  English to find the correct interpretation."""@en ;
  curric:correction """Texts rarely have one interpretation, and part of your job as a student of
  English is to consider the range and then select which one you think is the strongest,
  whilst still allowing for the idea that some might disagree with you."""@en ;
  dcterms:modified "2026-06-07T15:30:15.148858Z"^^xsd:dateTime .

oakcurric:misconception-different-translations-lords-prayer-time
  a curric:Misconception ;
  curric:statement """That different translations of the Lord's Prayer over time have been purely
  literal."""@en ;
  curric:correction """When new translations are made, writers change both the language and the
  content to suit modern audiences."""@en ;
  dcterms:modified "2026-06-07T15:30:15.148866Z"^^xsd:dateTime .

oakcurric:misconception-students-think-shelley-opposed-scientific
  a curric:Misconception ;
  curric:statement "Students think that Shelley was opposed to scientific advancement."@en ;
  curric:correction """Shelley was not opposed to scientific advancement; she was opposed to
  unethical and limitless scientific practices."""@en ;
  dcterms:modified "2026-06-07T15:30:15.149229Z"^^xsd:dateTime .

oakcurric:misconception-students-immediately-piece-together-pieces
  a curric:Misconception ;
  curric:statement """Students may not immediately piece together all of the pieces of evidence
  throughout the case."""@en ;
  curric:correction """Break the conclusion down for students with a visual depiction or flow
  diagram if necessary, explain that some clues were red herrings."""@en ;
  dcterms:modified "2026-06-07T15:30:15.149235Z"^^xsd:dateTime .

oakcurric:misconception-figurative-language-like-metaphors-used
  a curric:Misconception ;
  curric:statement "Figurative language, like metaphors, is not used in presentations."@en ;
  curric:correction """Stress how much stronger presentations can be when it allows the audience to
  make associations with objects and items they are familiar with."""@en ;
  dcterms:modified "2026-06-07T15:30:15.149246Z"^^xsd:dateTime .

oakcurric:misconception-villains-easily-identifiable-introduced-outset
  a curric:Misconception ;
  curric:statement """Villains are easily identifiable and will be always be introduced from the
  outset of a text."""@en ;
  curric:correction """Consider the draugr's subtle and encroaching presence. Burge uses this slow
  reveal to create tension."""@en ;
  dcterms:modified "2026-06-07T15:30:15.149326Z"^^xsd:dateTime .

oakcurric:misconception-students-think-need-balanced-their
  a curric:Misconception ;
  curric:statement """Students often think they need to be balanced in their writing and discuss
  both sides of a debate."""@en ;
  curric:correction "Teach the difference between opinion writing and argument writing."@en ;
  dcterms:modified "2026-06-07T15:30:15.149332Z"^^xsd:dateTime .

oakcurric:misconception-students-think-making-inference-same
  a curric:Misconception ;
  curric:statement """Students might think that making an inference is the same as guessing randomly
  without any evidence."""@en ;
  curric:correction """Inferences are not random guesses. They are logical conclusions drawn from
  clues or evidence presented in the text or context."""@en ;
  dcterms:modified "2026-06-07T15:30:15.149404Z"^^xsd:dateTime .

oakcurric:misconception-analyse-one-quotation-per-paragraph
  a curric:Misconception ;
  curric:statement "You should only analyse one quotation per paragraph."@en ;
  curric:correction """Analysing multiple quotations, and exploring the connections between them,
  makes for the most powerful analysis."""@en ;
  dcterms:modified "2026-06-07T15:30:15.149771Z"^^xsd:dateTime .

oakcurric:misconception-gothic-applies-external-settings-like
  a curric:Misconception ;
  curric:statement "Gothic only applies to external settings like buildings and the weather."@en ;
  curric:correction "The Gothic is about psychological states as much as setting."@en ;
  dcterms:modified "2026-06-07T15:30:15.149776Z"^^xsd:dateTime .

oakcurric:misconception-creating-effective-piece-descriptive-writing
  a curric:Misconception ;
  curric:statement """Creating an effective piece of descriptive writing is all about using
  linguistic devices."""@en ;
  curric:correction """Varying your sentences can also be a very effective way of conveying emotion
  and detail to help the reader visualise the scene."""@en ;
  dcterms:modified "2026-06-07T15:30:15.149791Z"^^xsd:dateTime .

oakcurric:misconception-need-personally-affected-something-make
  a curric:Misconception ;
  curric:statement """That you need to be personally affected by something to make a speech about
  it."""@en ;
  curric:correction "Draw attention to Hillary Clinton as an advocate."@en ;
  dcterms:modified "2026-06-07T15:30:15.149857Z"^^xsd:dateTime .

oakcurric:misconception-life-simply-bad-good-now
  a curric:Misconception ;
  curric:statement "That life was simply bad 'then' and 'good' now."@en ;
  curric:correction """Exploring the similarities between the past and now, can help draw out the
  nuances of societal expectations and stereotypical representations."""@en ;
  dcterms:modified "2026-06-07T15:30:15.149877Z"^^xsd:dateTime .

oakcurric:misconception-writing-serious-issues-main-tone
  a curric:Misconception ;
  curric:statement """When writing about serious issues, the main tone of your writing should be
  angry and confrontational."""@en ;
  curric:correction """Think about what engages you. An audience is far more likely to be engaged if
  they feel like they have a rapport with the speaker."""@en ;
  dcterms:modified "2026-06-07T15:30:15.149883Z"^^xsd:dateTime .

oakcurric:misconception-planning-necessary-write-effective-response
  a curric:Misconception ;
  curric:statement "Planning is not necessary to write an effective response."@en ;
  curric:correction """Not only is planning an efficient way to consider different questions and
  arguments, it also leads to more cohesive, well sequenced responses."""@en ;
  dcterms:modified "2026-06-07T15:30:15.150078Z"^^xsd:dateTime .

oakcurric:misconception-othello-character-suffers-tragic-fate
  a curric:Misconception ;
  curric:statement "Othello is the only character that suffers a tragic fate"@en ;
  curric:correction "Desdemona, Emilia and Othello all suffer a tragic fate"@en ;
  dcterms:modified "2026-06-07T15:30:15.151357Z"^^xsd:dateTime .

oakcurric:misconception-poetic-language-exist-everyday-life
  a curric:Misconception ;
  curric:statement "Poetic language does not exist in everyday life."@en ;
  curric:correction """Poetic language is everywhere since we use metaphors and comparisons in
  everyday speech all the time."""@en ;
  dcterms:modified "2026-06-07T15:30:15.152266Z"^^xsd:dateTime .

oakcurric:misconception-students-think-balanced-deliver-persuasive
  a curric:Misconception ;
  curric:statement """Students often think they have to be balanced when they deliver persuasive
  presentations."""@en ;
  curric:correction """Be clear about taking a stand and picking a side. A presentation which is
  clear in its stance has much more impact."""@en ;
  dcterms:modified "2026-06-07T15:30:15.152314Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-draugr-depicted-norse
  a curric:Misconception ;
  curric:statement """Pupils may think all draugr are depicted in Norse mythology and in 'The
  Twisted Tree' in the same way."""@en ;
  curric:correction """While draugr in Norse mythology generally share traits their specific
  appearances can vary between stories. Rachel Burge's portrayal in 'The Twisted Tree'
  offers her unique interpretation, reflecting the novel's narrative and atmosphere."""@en ;
  dcterms:modified "2026-06-07T15:30:15.152328Z"^^xsd:dateTime .

oakcurric:misconception-easy-confuse-motifs-extended-metaphors
  a curric:Misconception ;
  curric:statement "It is easy to confuse motifs with extended metaphors."@en ;
  curric:correction """A motif uses recurring elements that can employ a range of techniques. An
  extended metaphor is a sustained comparison across a text."""@en ;
  dcterms:modified "2026-06-07T15:30:15.152653Z"^^xsd:dateTime .

oakcurric:misconception-gilbert-shouting-hortense-shows-doesnt
  a curric:Misconception ;
  curric:statement """Gilbert shouting at Hortense shows he doesn’t respect her or care about their
  relationship"""@en ;
  curric:correction """Gilbert’s anger reflects his frustration and the pressures he faces in a
  racist society. His harsh words mask his deep care and protectiveness, and the scene later
  shows their developing understanding and connection."""@en ;
  dcterms:modified "2026-06-07T15:30:15.152659Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-planning-isnt-helpful
  a curric:Misconception ;
  curric:statement "Some pupils think that planning isn't a helpful or worthwhile exercise."@en ;
  curric:correction """Planning allows us to carefully consider our ideas before writing and allows
  us to work out what ideas work best for the task we've been given. Planning often results
  in a final stronger piece of work so is very worthwhile!"""@en ;
  dcterms:modified "2026-06-07T15:30:15.152667Z"^^xsd:dateTime .

oakcurric:misconception-long-similes-compare-something-similar
  a curric:Misconception ;
  curric:statement "As long as a similes compare something similar it is effective."@en ;
  curric:correction """Similes are much more powerful when used alongside vivid description. Work
  through example in learning cycle 1 to help unravel this."""@en ;
  dcterms:modified "2026-06-07T15:30:15.152685Z"^^xsd:dateTime .

oakcurric:misconception-exclamatory-sentences-sentences-express-emotions
  a curric:Misconception ;
  curric:statement "Exclamatory sentences are the only sentences that express emotions"@en ;
  curric:correction """Interrogative sentences can also effectively show some emotions e.g.
  confusion, despair, by the character asking themselves questions"""@en ;
  dcterms:modified "2026-06-07T15:30:15.152693Z"^^xsd:dateTime .

oakcurric:misconception-cannot-analyse-words-structural-analysis
  a curric:Misconception ;
  curric:statement "That you cannot analyse words in structural analysis."@en ;
  curric:correction """Analysis of where certain words appear in a poem is a valuable structural
  analysis."""@en ;
  dcterms:modified "2026-06-07T15:30:15.152708Z"^^xsd:dateTime .

oakcurric:misconception-pupils-understand-think-carefully-their
  a curric:Misconception ;
  curric:statement """Pupils do not understand that they have to think carefully about their use of
  figurative language and plan it before they begin writing."""@en ;
  curric:correction """Students need to consider carefully what kind of atmosphere they are trying
  to create. When comparing their setting to something else, the 'something else' needs to
  fit with the atmosphere they are aiming to create."""@en ;
  dcterms:modified "2026-06-07T15:30:15.152714Z"^^xsd:dateTime .

oakcurric:misconception-students-make-mistake-using-new
  a curric:Misconception ;
  curric:statement """Students often make the mistake of using a new word they have just learned
  inaccurately, in an attempt to show off their knowledge."""@en ;
  curric:correction """The point of learning new vocabulary is to give students options and choices
  so that they can select the most specific and useful word in their writing. Sometimes, the
  most specific word choice isn't the new vocabulary."""@en ;
  dcterms:modified "2026-06-07T15:30:15.154073Z"^^xsd:dateTime .

oakcurric:misconception-analyse-quotation
  a curric:Misconception ;
  curric:statement "You must analyse every quotation."@en ;
  curric:correction """There are some quotations that you will want to analyse in depth, and
  consider their methods and the range of ways they might be interpreted. However, there
  will also be quotations that link to your topic sentence, but don't need to be analysed."""@en ;
  dcterms:modified "2026-06-07T15:30:15.154079Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-island-turned-jack
  a curric:Misconception ;
  curric:statement """Pupils often think that the island turned Jack into the cruel and bloodthirsty
  leader he is by the end of the novel."""@en ;
  curric:correction """From the very beginning, Jack was characterised as unpleasant and
  egomaniacal. He treats the choir terribly in the first chapter. Jack arguably always had
  the traits of a dictatorial leader. The island has exacerbated these traits, not created
  them."""@en ;
  dcterms:modified "2026-06-07T15:30:15.154084Z"^^xsd:dateTime .

oakcurric:misconception-proofreading-rewriting-same-thing
  a curric:Misconception ;
  curric:statement "Proofreading and rewriting are the same thing."@en ;
  curric:correction """Proofreading is the final stage of the writing process. It is about checking
  for small errors - often grammatical. Rewriting is a larger task which requires you to
  think about the effects you want to create."""@en ;
  dcterms:modified "2026-06-07T15:30:15.154098Z"^^xsd:dateTime .

oakcurric:misconception-essay-effective-long-contains-range
  a curric:Misconception ;
  curric:statement "An essay is effective as long as it contains a range of evidence."@en ;
  curric:correction """To maximise effectiveness of an essay, you should link pieces of evidence
  together."""@en ;
  dcterms:modified "2026-06-07T15:30:15.154110Z"^^xsd:dateTime .

oakcurric:misconception-poem-island-man-tells-story
  a curric:Misconception ;
  curric:statement """The poem 'Island Man' only tells the story of someone that misses the
  Caribbean."""@en ;
  curric:correction """The poem 'Island Man' can help to tell the story of any migrant who
  experiences nostalgia for their home country."""@en ;
  dcterms:modified "2026-06-07T15:30:15.154119Z"^^xsd:dateTime .

oakcurric:misconception-personal-opinions-english-dont-matter
  a curric:Misconception ;
  curric:statement "Personal opinions in English don't matter. Only analysis is valid."@en ;
  curric:correction """Being a student of English can often feel like this. But expressing your
  opinions about your feelings towards a text - those you read in and outside the classroom
  - is very important and just as much a part of the subject of English as analysis."""@en ;
  dcterms:modified "2026-06-07T15:30:15.154160Z"^^xsd:dateTime .

oakcurric:misconception-american-president-poem-read-their
  a curric:Misconception ;
  curric:statement "Every American president has a poem read at their inauguration."@en ;
  curric:correction """Presidents have choice over some elements of their inauguration. President
  Clinton was only the second president to have a poem read at his ceremony, and he
  specifically asked for Angelou to write and perform it."""@en ;
  dcterms:modified "2026-06-07T15:30:15.154166Z"^^xsd:dateTime .

oakcurric:misconception-creative-writing-effective-focuses-something
  a curric:Misconception ;
  curric:statement """Creative writing is more effective when it focuses on something
  extraordinary."""@en ;
  curric:correction """Describing something very well known to you can be more effective as you're
  able to spend the time focusing on the little details."""@en ;
  dcterms:modified "2026-06-07T15:30:15.154183Z"^^xsd:dateTime .

oakcurric:misconception-cant-anything-help-control-our
  a curric:Misconception ;
  curric:statement "That we can't do anything to help control our nerves."@en ;
  curric:correction """While we can't stop the feeling of nervousness entirely, we can trick our
  body into relaxing more by smiling and using deep breathing."""@en ;
  dcterms:modified "2026-06-07T15:30:15.154188Z"^^xsd:dateTime .

oakcurric:misconception-puck-tries-create-chaos-realising
  a curric:Misconception ;
  curric:statement "Puck tries to create more chaos after realising his mistake."@en ;
  curric:correction """Puck is consistently shown to follow Oberon's orders in relation to the
  Athenian nobles, and to try and do so correctly. However, he does find it very funny, even
  though he didn't deliberately create the situation."""@en ;
  dcterms:modified "2026-06-07T15:30:15.154382Z"^^xsd:dateTime .

oakcurric:misconception-titania-seems-power-hermia-none
  a curric:Misconception ;
  curric:statement "Titania seems to have some power, but Hermia has none."@en ;
  curric:correction """Hermia defies her father by saying that she will marry Lysander, and refusing
  to marry Demetrius. She is also willing to leave her father, and the place she was born
  rather than obey her father."""@en ;
  dcterms:modified "2026-06-07T15:30:15.154388Z"^^xsd:dateTime .

oakcurric:misconception-isnt-important-consider-ethics-writing
  a curric:Misconception ;
  curric:statement """It isn't important to consider the ethics of writing about war. It is a topic
  just like any other."""@en ;
  curric:correction """There are important questions to be asked when considering writing about any
  harrowing experience, particularly war."""@en ;
  dcterms:modified "2026-06-07T15:30:15.154394Z"^^xsd:dateTime .

oakcurric:misconception-action-key-part-description
  a curric:Misconception ;
  curric:statement "Action is a key part of a description."@en ;
  curric:correction """Explain to pupils that the purpose of a description is to focus on certain
  aspects of a scene in order to set the tone and genre."""@en ;
  dcterms:modified "2026-06-07T15:30:15.154402Z"^^xsd:dateTime .

oakcurric:misconception-students-understand-sam-eric-actually
  a curric:Misconception ;
  curric:statement """Students may not understand that Sam and Eric have not actually seen the
  parachutist."""@en ;
  curric:correction """Unpick the description given by Sam and Eric. Were we (the reader) actually
  shown the different aspects of the beast?"""@en ;
  dcterms:modified "2026-06-07T15:30:15.154408Z"^^xsd:dateTime .

oakcurric:misconception-react-same-way-towards-characters
  a curric:Misconception ;
  curric:statement """We would react the same way towards the characters and events as would the
  Jacobean audience."""@en ;
  curric:correction """Explain that societal beliefs were different in the 1600s so a Jacobean
  audience would likely react differently to the events and characters"""@en ;
  dcterms:modified "2026-06-07T15:30:15.154414Z"^^xsd:dateTime .

oakcurric:misconception-better-know-everything-character-text
  a curric:Misconception ;
  curric:statement "It is better to know everything about a character or text before reading."@en ;
  curric:correction """Making predictions can help us with our comprehension of complex texts and
  independent thinking."""@en ;
  dcterms:modified "2026-06-07T15:30:15.154420Z"^^xsd:dateTime .

oakcurric:misconception-speaker-aging-doesnt-think-aging
  a curric:Misconception ;
  curric:statement "The speaker in 'On Aging' doesn't think aging affects you."@en ;
  curric:correction """The speaker lists some of the things that happen to you physically when you
  get older - she faces the reality. However, what she does want to change are people's
  reactions and perceptions of what these changes mean."""@en ;
  dcterms:modified "2026-06-07T15:30:15.154425Z"^^xsd:dateTime .

oakcurric:misconception-magic-stories-happens-make-believe
  a curric:Misconception ;
  curric:statement "That magic in stories always happens in a make-believe, faraway world."@en ;
  curric:correction """Magical-realist stories are set in the real world but magic and fantastical
  events happen."""@en ;
  dcterms:modified "2026-06-07T15:30:15.154431Z"^^xsd:dateTime .

oakcurric:misconception-use-generic-sensory-language-create
  a curric:Misconception ;
  curric:statement """That you should use generic sensory language to create an effective
  description."""@en ;
  curric:correction """You need to use sensory language tailored to the atmosphere that you want to
  create in order for it to be effective."""@en ;
  dcterms:modified "2026-06-07T15:30:15.154437Z"^^xsd:dateTime .

oakcurric:misconception-front-cover-show-way-identify
  a curric:Misconception ;
  curric:statement "The front cover is just for 'show' and a way to identify a book."@en ;
  curric:correction """The images and font on a front cover can give you lots of clues about themes
  and genre."""@en ;
  dcterms:modified "2026-06-07T15:30:15.154442Z"^^xsd:dateTime .

oakcurric:misconception-flawed-character-someone-unlikeable-hard
  a curric:Misconception ;
  curric:statement """A flawed character is someone who is always unlikeable or hard to
  relate to."""@en ;
  curric:correction """In reality, flawed characters often have human weaknesses that make them more
  believable or even sympathetic, much like the character of Hortense."""@en ;
  dcterms:modified "2026-06-07T15:30:15.154552Z"^^xsd:dateTime .

oakcurric:misconception-try-speak-other-people-your
  a curric:Misconception ;
  curric:statement "You should try to speak for other people in your writing."@en ;
  curric:correction """We all have slightly different opinions and ideas, so you should try to
  communicate your ideas and emotions to other people through your writing."""@en ;
  dcterms:modified "2026-06-07T15:30:15.154560Z"^^xsd:dateTime .

oakcurric:misconception-mccarthys-son-definitely-guilty
  a curric:Misconception ;
  curric:statement "McCarthy's son is definitely guilty."@en ;
  curric:correction """It is suspected that McCarthy's son is responsible for the murder of
  McCarthy, however Holmes still has a lot of investigating to do."""@en ;
  dcterms:modified "2026-06-07T15:30:15.154566Z"^^xsd:dateTime .

oakcurric:misconception-storm-othello-device-means-turkish
  a curric:Misconception ;
  curric:statement """The storm in Othello is just a device that means the Turkish army is defeated
  and the war is over."""@en ;
  curric:correction """The storm in Othello is a device that is symbolic of chaos and disorder to
  come."""@en ;
  dcterms:modified "2026-06-07T15:30:15.154572Z"^^xsd:dateTime .

oakcurric:misconception-auden-saying-suffering-unimportant
  a curric:Misconception ;
  curric:statement "Auden is saying suffering is unimportant."@en ;
  curric:correction """Auden presents extreme suffering, but he is exploring how, inevitably, when
  something terrible is happening, something ordinary is happening at the same time too."""@en ;
  dcterms:modified "2026-06-07T15:30:15.154578Z"^^xsd:dateTime .

oakcurric:misconception-using-onomatopoeia-way-create-sense
  a curric:Misconception ;
  curric:statement """Using onomatopoeia is the only way to create a sense of sound in a piece of
  writing."""@en ;
  curric:correction """Onomatopoeia can be a helpful tool to rely on in some pieces of writing.
  However, alliteration, plosives and sibilance are often more sophisticated and more
  subtle. They also allow for a greater range of sounds to be generated."""@en ;
  dcterms:modified "2026-06-07T15:30:15.154583Z"^^xsd:dateTime .

oakcurric:misconception-students-confused-actually-happening-encounter
  a curric:Misconception ;
  curric:statement """Students may be confused about what is actually happening in the encounter
  between the beast and Simon."""@en ;
  curric:correction """Remind them that Simon has a tendency to lose consciousness. They need to be
  able to interpret this encounter on multiple levels."""@en ;
  dcterms:modified "2026-06-07T15:30:15.154916Z"^^xsd:dateTime .

oakcurric:misconception-greek-myths-morals
  a curric:Misconception ;
  curric:statement "All the Greek myths have morals."@en ;
  curric:correction """The Greek myths are not all moralistic. Indeed, the gods, mythological
  creatures and mortals often act in cruel, reactive, vengeful and immoral ways."""@en ;
  dcterms:modified "2026-06-07T15:30:15.154925Z"^^xsd:dateTime .

oakcurric:misconception-best-endings-neat-fully-resolved
  a curric:Misconception ;
  curric:statement """The best endings are always neat and fully resolved, tying up every
  storyline."""@en ;
  curric:correction """While neat endings can feel satisfying, 'Small Island' shows powerful endings
  often include uncertainty. Edmundson says the play balances hope and love with an unclear
  future, making it realistic and thought-provoking."""@en ;
  dcterms:modified "2026-06-07T15:30:15.154931Z"^^xsd:dateTime .

oakcurric:misconception-settings-provide-backdrop-story
  a curric:Misconception ;
  curric:statement "Settings are only there to provide a backdrop for the story."@en ;
  curric:correction """Setting plays a crucial role in shaping the mood and atmosphere of a novel.
  It can also help us gain a deeper understanding of the characters and themes."""@en ;
  dcterms:modified "2026-06-07T15:30:15.154945Z"^^xsd:dateTime .

oakcurric:misconception-biography-offers-authentic-impression-person
  a curric:Misconception ;
  curric:statement "A biography offers an authentic impression of that person."@en ;
  curric:correction """We all might have different perspectives on the same person, so different
  biographies are likely to portray the same person in different ways."""@en ;
  dcterms:modified "2026-06-07T15:30:15.155204Z"^^xsd:dateTime .

oakcurric:misconception-michael-hortnese-same-upbringing
  a curric:Misconception ;
  curric:statement "Michael and Hortnese have the same upbringing."@en ;
  curric:correction """As well as exploring the different ways their lives are described, think back
  to how Mr. Philip reacts to Hortense climbing the tree. Why does he find it so
  problematic? This reveals a stark difference between Michael and Hortense."""@en ;
  dcterms:modified "2026-06-07T15:30:15.157217Z"^^xsd:dateTime .

oakcurric:misconception-clear-confident-delivery-speeches-requires
  a curric:Misconception ;
  curric:statement """Clear and confident delivery of speeches requires a consistent pace of
  delivery throughout."""@en ;
  curric:correction """Model the delivery of a sentence which starts at pace, but slows down to draw
  attention to particular vocabulary choices."""@en ;
  dcterms:modified "2026-06-07T15:30:15.157225Z"^^xsd:dateTime .

oakcurric:misconception-pupils-start-speech-directly-addressing
  a curric:Misconception ;
  curric:statement """Pupils start a speech by directly addressing the audience and explaining the
  purpose of the speech."""@en ;
  curric:correction """Ask pupils if the best method of getting your own way is by stating what you
  want straight away."""@en ;
  dcterms:modified "2026-06-07T15:30:15.157351Z"^^xsd:dateTime .

oakcurric:misconception-form-direct-address-addressing-reader
  a curric:Misconception ;
  curric:statement """\"You\" is the only form of direct address when addressing a
  reader/audience."""@en ;
  curric:correction """When teaching the over reliance on direct address, rapidly fire questions to
  one pupil, addressing them as 'you'. Ask them how this feels."""@en ;
  dcterms:modified "2026-06-07T15:30:15.157944Z"^^xsd:dateTime .

oakcurric:misconception-shouldnt-judge-book-its-cover
  a curric:Misconception ;
  curric:statement "That you shouldn't judge a book by its cover."@en ;
  curric:correction """If we consider a literal book cover, it has been chosen to introduce the
  reader to the tone of the text."""@en ;
  dcterms:modified "2026-06-07T15:30:15.158300Z"^^xsd:dateTime .

oakcurric:misconception-english-language-developed-quickly
  a curric:Misconception ;
  curric:statement "That the English language developed quickly."@en ;
  curric:correction """The English that we speak today was shaped across many hundreds of years by
  lots of significant events in our history."""@en ;
  dcterms:modified "2026-06-07T15:30:15.158781Z"^^xsd:dateTime .

oakcurric:misconception-students-think-women-completely-powerless
  a curric:Misconception ;
  curric:statement """Students sometimes think that women were completely powerless in Shakespeare's
  time."""@en ;
  curric:correction """While there were legal restrictions and social pressures on women in
  Shakespeare's time, there were some women who had power and influence."""@en ;
  dcterms:modified "2026-06-07T15:30:15.158922Z"^^xsd:dateTime .

oakcurric:misconception-important-focus-creation-complex-methods
  a curric:Misconception ;
  curric:statement """It is important to focus on the creation of complex methods like metaphor or
  anaphora. Verbs don't matter."""@en ;
  curric:correction """Every sentence should contain a verb. As such, choosing them requires careful
  thought, and can dramatically impact the tone and pace of your writing."""@en ;
  dcterms:modified "2026-06-07T15:30:15.159142Z"^^xsd:dateTime .

oakcurric:misconception-topic-sentences-used-essay-writing
  a curric:Misconception ;
  curric:statement "Topic sentences are only used in essay writing."@en ;
  curric:correction """Remind pupils that topic sentences are signposts for readers, indicating to
  them the direction our writing will be travelling in."""@en ;
  dcterms:modified "2026-06-07T15:30:15.159147Z"^^xsd:dateTime .

oakcurric:misconception-content-alone-enough-effective-speech
  a curric:Misconception ;
  curric:statement "Content alone is enough for an effective speech."@en ;
  curric:correction """Consider the most engaging speakers and how they use tone, gestures and eye
  contact. Giving a speech is so much more than just the words on a page."""@en ;
  dcterms:modified "2026-06-07T15:30:15.159676Z"^^xsd:dateTime .

oakcurric:misconception-pupils-believe-writing-summary-means
  a curric:Misconception ;
  curric:statement """Pupils might believe that writing a summary means including all details from
  the story."""@en ;
  curric:correction """Explain that a summary should only include the most important events and main
  ideas in a concise manner. Remind them that the goal is to capture the essence of the
  story, not every detail."""@en ;
  dcterms:modified "2026-06-07T15:30:15.160121Z"^^xsd:dateTime .

oakcurric:misconception-analysis-play-consists-word-characters
  a curric:Misconception ;
  curric:statement "That an analysis of a play only consists of the word the characters say."@en ;
  curric:correction """The amount of lines a character has as well as stage directions are also
  important aspects of analysing a play."""@en ;
  dcterms:modified "2026-06-07T15:30:15.160418Z"^^xsd:dateTime .

oakcurric:misconception-ariel-female-character
  a curric:Misconception ;
  curric:statement "That Ariel is a female character."@en ;
  curric:correction "There is no gender assigned to Ariel."@en ;
  dcterms:modified "2026-06-07T15:30:15.160535Z"^^xsd:dateTime .

oakcurric:misconception-characters-literature-create-good-story
  a curric:Misconception ;
  curric:statement "Characters in literature are just there to create a good story."@en ;
  curric:correction """Characters in literature often represent things bigger than themselves such
  as colonialism or gender inequality."""@en ;
  dcterms:modified "2026-06-07T15:30:15.160712Z"^^xsd:dateTime .

oakcurric:misconception-know-certain-shakespeare-intended-his
  a curric:Misconception ;
  curric:statement """That we know for certain how Shakespeare intended his characters to be
  seen."""@en ;
  curric:correction """We don't know how Shakespeare intended the audience to perceive his
  characters - we can just look at the language and decide from that."""@en ;
  dcterms:modified "2026-06-07T15:30:15.160833Z"^^xsd:dateTime .

oakcurric:misconception-images-sentences-need-varied-writing
  a curric:Misconception ;
  curric:statement "That images and sentences always need to be varied in writing."@en ;
  curric:correction """Repeated images and sentences can be an effective way of crafting a
  convincing character voice."""@en ;
  dcterms:modified "2026-06-07T15:30:15.160929Z"^^xsd:dateTime .

oakcurric:misconception-theatre-performance-actors-interacting-other
  a curric:Misconception ;
  curric:statement """That a theatre performance is all about actors interacting with each other on
  the stage."""@en ;
  curric:correction """Often the most memorable moments from a performance are the actors'
  monologues where they express their character's inner thoughts."""@en ;
  dcterms:modified "2026-06-07T15:30:15.160977Z"^^xsd:dateTime .

oakcurric:misconception-identifying-language-devices-important-skill
  a curric:Misconception ;
  curric:statement """Identifying language devices is the most important skill when analysing
  author's language choices."""@en ;
  curric:correction """When looking at the question, ask pupils whether 'Guthrie uses a simile'
  would be an appropriate response to the question. If not, why not?"""@en ;
  dcterms:modified "2026-06-07T15:30:15.161167Z"^^xsd:dateTime .

oakcurric:misconception-relevant-information-comes-dialogue-plays
  a curric:Misconception ;
  curric:statement "All relevant information comes only from the dialogue in plays."@en ;
  curric:correction """What is the role of stage directions? Explore how they are crafted to further
  characterisation. What extra information do they give us?"""@en ;
  dcterms:modified "2026-06-07T15:30:15.161542Z"^^xsd:dateTime .

oakcurric:misconception-quote-entire-sentences-text-order
  a curric:Misconception ;
  curric:statement """That you should quote entire sentences of text in order to prove your
  point."""@en ;
  curric:correction """Often, individual words and short quotes are more effective in analytical
  writing."""@en ;
  dcterms:modified "2026-06-07T15:30:15.161548Z"^^xsd:dateTime .

oakcurric:misconception-annotating-means-highlighting-everything-think
  a curric:Misconception ;
  curric:statement "Annotating means highlighting everything you think is important in a text."@en ;
  curric:correction """Annotating is a skill that requires time and thought. Using symbols and short
  notes makes your annotations helpful and understandable, even if you come back to them at
  a much later date."""@en ;
  dcterms:modified "2026-06-07T15:30:15.161841Z"^^xsd:dateTime .

oakcurric:misconception-persuasive-speech-needs-angry-aggressive
  a curric:Misconception ;
  curric:statement "A persuasive speech needs to be angry and aggressive."@en ;
  curric:correction """What is Watson's tone? How does she motivate and persuade her audience
  without being confrontational? You don't want to alienate any audience members."""@en ;
  dcterms:modified "2026-06-07T15:30:15.162041Z"^^xsd:dateTime .

oakcurric:misconception-calling-someone-monster-means-find
  a curric:Misconception ;
  curric:statement "That calling someone a 'monster' means that you find them terrifying."@en ;
  curric:correction """While calling someone a 'monster' can mean you find them terrifying, it can
  also be a way of ridiculing someone and showing your dislike."""@en ;
  dcterms:modified "2026-06-07T15:30:15.162206Z"^^xsd:dateTime .

oakcurric:misconception-anyone-breathed-gas-died-immediately
  a curric:Misconception ;
  curric:statement "Anyone who breathed in gas died immediately."@en ;
  curric:correction """Gas attacks killed about three percent of people immediately, but there were
  long term physical and psychological effects for those who experienced gas attacks."""@en ;
  dcterms:modified "2026-06-07T15:30:15.162289Z"^^xsd:dateTime .

oakcurric:misconception-its-obvious-character-interpreted-audience
  a curric:Misconception ;
  curric:statement "That it's obvious how a character should be interpreted by the audience."@en ;
  curric:correction """The staging of a performance from body language to costuming can make a huge
  difference in how different audiences interpret a character."""@en ;
  dcterms:modified "2026-06-07T15:30:15.162296Z"^^xsd:dateTime .

oakcurric:misconception-pupils-overload-physical-description-their
  a curric:Misconception ;
  curric:statement """Pupils will sometimes overload the physical description of their character and
  list each individual detail, often using cliches."""@en ;
  curric:correction """Describing every part of a character’s appearance in detail can overwhelm the
  reader. It's better to provide purposeful descriptions that integrate physical appearance
  with personality to create an engaging and convincing character."""@en ;
  dcterms:modified "2026-06-07T15:30:15.162459Z"^^xsd:dateTime .

oakcurric:misconception-argument-needs-present-balanced-viewpoint
  a curric:Misconception ;
  curric:statement """That an argument needs to present a balanced viewpoint for both sides of the
  argument."""@en ;
  curric:correction """An argument needs to give your reasons behind your answer to the
  question."""@en ;
  dcterms:modified "2026-06-07T15:30:15.162465Z"^^xsd:dateTime .

oakcurric:misconception-pupils-confuse-compound-complex-sentences
  a curric:Misconception ;
  curric:statement """Pupils might confuse compound and complex sentences, thinking that any
  sentence with more than one clause is a complex sentence."""@en ;
  curric:correction """A compound sentence has two main clauses that can each stand alone as
  separate sentences, joined by a coordinating conjunction. In contrast, a complex sentence
  has one main clause and at least one subordinate clause that cannot stand alone."""@en ;
  dcterms:modified "2026-06-07T15:30:15.162556Z"^^xsd:dateTime .

oakcurric:misconception-hortense-motivated-heartbreak
  a curric:Misconception ;
  curric:statement "That Hortense is only motivated by heartbreak."@en ;
  curric:correction """How does Hortense view herself, even from a young age? She does at times view
  herself as superior. Furthermore, she has lived in the house for a long time and has
  perhaps internalised the moral and religious standards that Mr. Philip holds."""@en ;
  dcterms:modified "2026-06-07T15:30:15.162562Z"^^xsd:dateTime .

oakcurric:misconception-cant-use-words-phrases-methods
  a curric:Misconception ;
  curric:statement """You can't use words, phrases or methods from other people's writing in your
  own writing."""@en ;
  curric:correction """Plagiarism is when you use someone's work or ideas without their consent.
  This is not allowed. However, you can use texts that inspire and excite you to inform your
  own writing. This might be a piece of powerful vocabulary or a powerful method."""@en ;
  dcterms:modified "2026-06-07T15:30:15.163018Z"^^xsd:dateTime .

oakcurric:misconception-trench-warfare-fighting-characterised-intense
  a curric:Misconception ;
  curric:statement "Trench warfare was fighting characterised by intense and constant action."@en ;
  curric:correction """Trench warfare was characterised by intense periods of action, but also long
  periods of inaction which could be demoralising, boring and harrowing."""@en ;
  dcterms:modified "2026-06-07T15:30:15.163028Z"^^xsd:dateTime .

oakcurric:misconception-evidence-quotations-need-long-used
  a curric:Misconception ;
  curric:statement """Evidence, or quotations, need to be long when used in an analytical paragraph
  or response."""@en ;
  curric:correction """If you select the right words, single words can provide an opportunity for
  rich analysis. Layering your comments means you can say a lot about a little!"""@en ;
  dcterms:modified "2026-06-07T15:30:15.163242Z"^^xsd:dateTime .

oakcurric:misconception-planning-pointless-endeavour
  a curric:Misconception ;
  curric:statement "That planning is a pointless endeavour."@en ;
  curric:correction """Planning is a really important aspect of any writing task as it makes the
  process easier and allows you to organise your thoughts."""@en ;
  dcterms:modified "2026-06-07T15:30:15.163404Z"^^xsd:dateTime .

oakcurric:misconception-defining-feature-comedy-play-funny
  a curric:Misconception ;
  curric:statement "The defining feature of a comedy play is that they are funny."@en ;
  curric:correction """While Shakespeare's comedies do employ humour, the defining feature is that
  everything is resolved at the end of the play."""@en ;
  dcterms:modified "2026-06-07T15:30:15.163410Z"^^xsd:dateTime .

oakcurric:misconception-comparisons-either-clear-similarities-clear
  a curric:Misconception ;
  curric:statement "Comparisons are either clear similarities or clear differences."@en ;
  curric:correction """Use examples from slides to demonstrate how comparisons are often more
  complex than ideas being completely similar or completely different."""@en ;
  dcterms:modified "2026-06-07T15:30:15.163415Z"^^xsd:dateTime .

oakcurric:misconception-long-keep-my-headline-subheading
  a curric:Misconception ;
  curric:statement """As long as I keep my headline and subheading short, they will be
  effective."""@en ;
  curric:correction """Headlines and subheadings must be crafted to fit the purpose of the
  article."""@en ;
  dcterms:modified "2026-06-07T15:30:15.163925Z"^^xsd:dateTime .

oakcurric:misconception-people-didnt-believe-magic-shakespeares
  a curric:Misconception ;
  curric:statement "That people didn't believe in magic in Shakespeare's time."@en ;
  curric:correction """In Shakespeare's time, most people believed in magic and thought it could
  bring ill luck and misfortune."""@en ;
  dcterms:modified "2026-06-07T15:30:15.163930Z"^^xsd:dateTime .

oakcurric:misconception-hortense-main-protagonist
  a curric:Misconception ;
  curric:statement "Hortense is the main protagonist."@en ;
  curric:correction """Look at how many scenes other characters are in and the importance of their
  journeys. Why might Levy choose to have multiple protagonists? Think back to her original
  intentions."""@en ;
  dcterms:modified "2026-06-07T15:30:15.164019Z"^^xsd:dateTime .

oakcurric:misconception-students-think-women-shakespeares-time
  a curric:Misconception ;
  curric:statement """Students often think that women in Shakespeare's time always obeyed the male
  figures in their life."""@en ;
  curric:correction """There are many examples of women being disobedient and not following the
  rules of the male figures in their life."""@en ;
  dcterms:modified "2026-06-07T15:30:15.164045Z"^^xsd:dateTime .

oakcurric:misconception-writers-use-original-ideas-dont
  a curric:Misconception ;
  curric:statement """That all writers use only original ideas and if they don't they are bad
  writers."""@en ;
  curric:correction """Explore the idea of a literary trope and how writer's use these to elicit
  specific responses from readers. How do recognisable conventions work to appeal to us as
  readers?"""@en ;
  dcterms:modified "2026-06-07T15:30:15.164140Z"^^xsd:dateTime .

oakcurric:misconception-dont-need-use-quotes-your
  a curric:Misconception ;
  curric:statement "That you don't need to use quotes in your essay."@en ;
  curric:correction """Quotes act as textual evidence and are needed to write a successful
  analytical essay."""@en ;
  dcterms:modified "2026-06-07T15:30:15.164280Z"^^xsd:dateTime .

oakcurric:misconception-our-feelings-towards-characters-consistent
  a curric:Misconception ;
  curric:statement "That our feelings towards characters must be consistent."@en ;
  curric:correction """Our feelings towards characters can change depending on what is happening
  during the plot."""@en ;
  dcterms:modified "2026-06-07T15:30:15.164286Z"^^xsd:dateTime .

oakcurric:misconception-men-england-fought-britain
  a curric:Misconception ;
  curric:statement "That only men from England fought for Britain."@en ;
  curric:correction "Men from all over the British Empire fought for Britain."@en ;
  dcterms:modified "2026-06-07T15:30:15.164505Z"^^xsd:dateTime .

oakcurric:misconception-pathetic-fallacy-using-weather-express
  a curric:Misconception ;
  curric:statement "That pathetic fallacy is only about using the weather to express emotions."@en ;
  curric:correction """Pathetic fallacy is a type of personification where emotions are given to a
  setting, an object or the weather."""@en ;
  dcterms:modified "2026-06-07T15:30:15.164514Z"^^xsd:dateTime .
