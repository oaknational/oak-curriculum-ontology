# ----------------------------------------------------------------------
# Keywords
# ----------------------------------------------------------------------

oakcurric:keyword-expectations
  a curric:Keyword ;
  schema:name "expectations"@en ;
  schema:description "are what people believe should happen or the way things should be"@en ;
  dcterms:modified "2026-02-12T08:59:15.789312Z"^^xsd:dateTime .

oakcurric:keyword-dominant
  a curric:Keyword ;
  schema:name "dominant"@en ;
  schema:description "the most widely accepted or prevailing (idea or concept)"@en ;
  dcterms:modified "2026-02-12T08:59:15.789347Z"^^xsd:dateTime .

oakcurric:keyword-conform
  a curric:Keyword ;
  schema:name "conform"@en ;
  schema:description "to behave or think in a way that is socially acceptable"@en ;
  dcterms:modified "2026-02-12T08:59:15.789355Z"^^xsd:dateTime .

oakcurric:keyword-societal
  a curric:Keyword ;
  schema:name "societal"@en ;
  schema:description "anything related to society, including beliefs, customs  and behaviours"@en ;
  dcterms:modified "2026-02-12T08:59:15.789361Z"^^xsd:dateTime .

oakcurric:keyword-stereotype
  a curric:Keyword ;
  schema:name "stereotype"@en ;
  schema:description "a simplified belief, view or representation of a group of people"@en ;
  dcterms:modified "2026-02-12T08:59:15.789366Z"^^xsd:dateTime .

oakcurric:keyword-fleeting
  a curric:Keyword ;
  schema:name "fleeting"@en ;
  schema:description "passing quickly"@en ;
  dcterms:modified "2026-02-12T08:59:15.789372Z"^^xsd:dateTime .

oakcurric:keyword-foreboding
  a curric:Keyword ;
  schema:name "foreboding"@en ;
  schema:description "a feeling that something bad is going to happen"@en ;
  dcterms:modified "2026-02-12T08:59:15.789377Z"^^xsd:dateTime .

oakcurric:keyword-ancestry
  a curric:Keyword ;
  schema:name "ancestry"@en ;
  schema:description "a person’s family history or lineage"@en ;
  dcterms:modified "2026-02-12T08:59:15.789381Z"^^xsd:dateTime .

oakcurric:keyword-omen
  a curric:Keyword ;
  schema:name "omen"@en ;
  schema:description "a sign or event that is believed to predict or indicate a future occurrence"@en ;
  dcterms:modified "2026-02-12T08:59:15.789386Z"^^xsd:dateTime .

oakcurric:keyword-theme
  a curric:Keyword ;
  schema:name "theme"@en ;
  schema:description """an important idea or thread in a text that is explored in a number of different ways"""@en ;
  dcterms:modified "2026-02-12T08:59:15.789391Z"^^xsd:dateTime .

oakcurric:keyword-alliteration
  a curric:Keyword ;
  schema:name "alliteration"@en ;
  schema:description "when two or more words start with the same consonant"@en ;
  dcterms:modified "2026-02-12T08:59:15.789414Z"^^xsd:dateTime .

oakcurric:keyword-plosives
  a curric:Keyword ;
  schema:name "plosives"@en ;
  schema:description """use of letters 'p', 't', 'k', 'b', 'd' and 'g' to make a harsh sound; unlike alliteration, these letters don’t have to be found at the start of a word."""@en ;
  dcterms:modified "2026-02-12T08:59:15.789419Z"^^xsd:dateTime .

oakcurric:keyword-onomatopoeia
  a curric:Keyword ;
  schema:name "onomatopoeia"@en ;
  schema:description "words which sound like the noise they describe e.g. crash"@en ;
  dcterms:modified "2026-02-12T08:59:15.789423Z"^^xsd:dateTime .

oakcurric:keyword-sibilance
  a curric:Keyword ;
  schema:name "sibilance"@en ;
  schema:description "repetition of the letter 's' in successive words"@en ;
  dcterms:modified "2026-02-12T08:59:15.789435Z"^^xsd:dateTime .

oakcurric:keyword-campaign
  a curric:Keyword ;
  schema:name "campaign"@en ;
  schema:description "a series of military operations, usually with the aim of defeating an enemy"@en ;
  dcterms:modified "2026-02-12T08:59:15.789466Z"^^xsd:dateTime .

oakcurric:keyword-putrid
  a curric:Keyword ;
  schema:name "putrid"@en ;
  schema:description "a foul smell from rotting matter"@en ;
  dcterms:modified "2026-02-12T08:59:15.789475Z"^^xsd:dateTime .

oakcurric:keyword-devouring
  a curric:Keyword ;
  schema:name "devouring"@en ;
  schema:description "eating food or prey hungrily and quickly"@en ;
  dcterms:modified "2026-02-12T08:59:15.789481Z"^^xsd:dateTime .

oakcurric:keyword-emanating
  a curric:Keyword ;
  schema:name "emanating"@en ;
  schema:description "emitting or spreading from something"@en ;
  dcterms:modified "2026-02-12T08:59:15.789486Z"^^xsd:dateTime .

oakcurric:keyword-superstition
  a curric:Keyword ;
  schema:name "superstition"@en ;
  schema:description "a widely held but irrational belief in a supernatural influence or practice"@en ;
  dcterms:modified "2026-02-12T08:59:15.789491Z"^^xsd:dateTime .

oakcurric:keyword-sacred
  a curric:Keyword ;
  schema:name "sacred"@en ;
  schema:description "connected with god or regarded with great respect"@en ;
  dcterms:modified "2026-02-12T08:59:15.789496Z"^^xsd:dateTime .

oakcurric:keyword-patriotic
  a curric:Keyword ;
  schema:name "Patriotic"@en ;
  schema:description "Being patriotic means showing love and support for your country."@en ;
  dcterms:modified "2026-02-12T08:59:15.789519Z"^^xsd:dateTime .

oakcurric:keyword-empire
  a curric:Keyword ;
  schema:name "Empire"@en ;
  schema:description """An Empire is a group of countries ruled by a single person, government or country, e.g. The Roman Empire."""@en ;
  dcterms:modified "2026-02-12T08:59:15.789526Z"^^xsd:dateTime .

oakcurric:keyword-propaganda
  a curric:Keyword ;
  schema:name "Propaganda"@en ;
  schema:description """Propaganda is information, especially of a biased or misleading nature, used to promote a political cause or point of view."""@en ;
  dcterms:modified "2026-02-12T08:59:15.789531Z"^^xsd:dateTime .

oakcurric:keyword-censorship
  a curric:Keyword ;
  schema:name "Censorship"@en ;
  schema:description """The act of preventing something from being seen or made available to the public for political reasons is known as censorship."""@en ;
  dcterms:modified "2026-02-12T08:59:15.789536Z"^^xsd:dateTime .

oakcurric:keyword-provocative
  a curric:Keyword ;
  schema:name "Provocative"@en ;
  schema:description """Something provocative is deliberately designed to cause anger or another strong emotion."""@en ;
  dcterms:modified "2026-02-12T08:59:15.789540Z"^^xsd:dateTime .

oakcurric:keyword-gist
  a curric:Keyword ;
  schema:name "gist"@en ;
  schema:description "the main idea or essence of something, often brief and in a simplified form"@en ;
  dcterms:modified "2026-02-12T08:59:15.789545Z"^^xsd:dateTime .

oakcurric:keyword-militant
  a curric:Keyword ;
  schema:name "militant"@en ;
  schema:description "to be forceful, determined and extreme, sometimes using aggressive methods"@en ;
  dcterms:modified "2026-02-12T08:59:15.789549Z"^^xsd:dateTime .

oakcurric:keyword-slogan
  a curric:Keyword ;
  schema:name "slogan"@en ;
  schema:description """a slogan is a memorable phrase used by a person, group, or company to convey a message or idea"""@en ;
  dcterms:modified "2026-02-12T08:59:15.789554Z"^^xsd:dateTime .

oakcurric:keyword-archaic
  a curric:Keyword ;
  schema:name "archaic"@en ;
  schema:description "something that is outdated, old-fashioned, or no longer in common use"@en ;
  dcterms:modified "2026-02-12T08:59:15.789558Z"^^xsd:dateTime .

oakcurric:keyword-autonomy
  a curric:Keyword ;
  schema:name "autonomy"@en ;
  schema:description """having the freedom and independence to make your own decisions without being controlled by others"""@en ;
  dcterms:modified "2026-02-12T08:59:15.789563Z"^^xsd:dateTime .

oakcurric:keyword-rhythm
  a curric:Keyword ;
  schema:name "rhythm"@en ;
  schema:description "the beat, flow, or pattern of a piece of music or writing."@en ;
  dcterms:modified "2026-02-12T08:59:15.789567Z"^^xsd:dateTime .

oakcurric:keyword-oscillate
  a curric:Keyword ;
  schema:name "oscillate"@en ;
  schema:description "to move repeatedly from side to side."@en ;
