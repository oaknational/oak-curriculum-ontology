  dcterms:modified "2026-02-12T08:59:21.695180Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4753-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The letter d has an ascender"@en ;
  dcterms:modified "2026-02-12T08:59:21.695188Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4753-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The letters c, a and d are all formed by curling round in an anti-clockwise direction"""@en ;
  dcterms:modified "2026-02-12T08:59:21.695193Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4761-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "All the letters have a lead in and a lead out."@en ;
  dcterms:modified "2026-02-12T08:59:21.695199Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4761-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Cursive letter joins refer to how the letters connect together."@en ;
  dcterms:modified "2026-02-12T08:59:21.695204Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4761-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The pencil does not lift when forming the join."@en ;
  dcterms:modified "2026-02-12T08:59:21.695209Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4761-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The letter r lead out has a dip down to aid joining."@en ;
  dcterms:modified "2026-02-12T08:59:21.695213Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4761-5
  a oakcurric:KeyLearningPoint ;
