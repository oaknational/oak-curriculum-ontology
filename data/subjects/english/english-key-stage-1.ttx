  dcterms:modified "2026-02-12T08:59:21.687345Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4774-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The pencil only lifts to add the dot to the i and the cross to the t once you have finished the letter string."""@en ;
  dcterms:modified "2026-02-12T08:59:21.687350Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4738-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The capital letters M, N, W and V all have the same starting point and go down and back up."""@en ;
  dcterms:modified "2026-02-12T08:59:21.687964Z"^^xsd:dateTime .

