  dcterms:modified "2026-02-12T08:59:21.695218Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4771-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The letters are formed by following the right starting point and direction."@en ;
  dcterms:modified "2026-02-12T08:59:21.695222Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4771-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Cursive letter joins refer to how the letters connect together."@en ;
  dcterms:modified "2026-02-12T08:59:21.695227Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4771-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The pencil does not lift when forming the join."@en ;
  dcterms:modified "2026-02-12T08:59:21.695231Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4771-4
