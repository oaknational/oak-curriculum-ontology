  a oakcurric:KeyLearningPoint ;
  rdfs:label "The pencil does not lift when forming the join."@en ;
  dcterms:modified "2026-02-12T08:59:21.687293Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4769-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The third join starts at the x-height line and dips below the x-height line and back up to join the next letter."""@en ;
  dcterms:modified "2026-02-12T08:59:21.687298Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4769-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """When using the third join you leave enough space to ensure the letters are not touching without leaving a big gap."""@en ;
  dcterms:modified "2026-02-12T08:59:21.687302Z"^^xsd:dateTime .

