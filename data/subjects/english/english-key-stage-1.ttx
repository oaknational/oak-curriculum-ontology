oak:keylearningpoint-lesson-7212-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """'Heartbroken' is an adjective which means feeling very upset and sad about something."""@en ;
  dcterms:modified "2026-02-12T08:59:21.688504Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7212-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "'Sulky' is an adjective which means being quiet and grumpy and moping about."@en ;
  dcterms:modified "2026-02-12T08:59:21.688509Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-7212-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "'Disappointed' and 'miserable' are other adjectives associated with sadness."@en ;
  dcterms:modified "2026-02-12T08:59:21.688513Z"^^xsd:dateTime .

