oak:keylearningpoint-lesson-8483-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """A theme is a big idea or lesson that the author wants you to explore and understand through reading the story."""@en ;
  dcterms:modified "2026-02-12T08:59:21.685058Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-8483-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Readers can interpret themes and their importance within a story in different ways."""@en ;
  dcterms:modified "2026-02-12T08:59:21.685065Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-8483-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """‘The Planet in a Pickle Jar’ explores the theme of protection relating to environment, family and belongings."""@en ;
  dcterms:modified "2026-02-12T08:59:21.685069Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-8483-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The importance of protecting the world’s natural wonders and the environment is a key lesson communicated in the story."""@en ;
  dcterms:modified "2026-02-12T08:59:21.685074Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-8483-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """There are many natural elements in our world that need protecting and a variety of ways to help with this."""@en ;
  dcterms:modified "2026-02-12T08:59:21.685078Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-8892-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Plop is a young barn owl who is initially scared of the dark but gradually learns to appreciate the night time."""@en ;
  dcterms:modified "2026-02-12T08:59:21.685083Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-8892-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Plop meets lots of characters who all help him in overcoming his fear of the dark."""@en ;
  dcterms:modified "2026-02-12T08:59:21.685087Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-8892-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """A personal response is what you think and how you feel about the story, including whether you liked it or not."""@en ;
  dcterms:modified "2026-02-12T08:59:21.685092Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-8892-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The theme in a story is the big idea or lesson that the author wants you to explore and understand through reading."""@en ;
  dcterms:modified "2026-02-12T08:59:21.685096Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-8892-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Key themes in ‘The Owl who was Afraid of the Dark’ are curiosity and courage."@en ;
  dcterms:modified "2026-02-12T08:59:21.685101Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-27622-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "People can agree or disagree with an opinion."@en ;
  dcterms:modified "2026-02-12T08:59:21.685105Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-27622-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Using the word 'because' allows us to explain our opinions."@en ;
  dcterms:modified "2026-02-12T08:59:21.685110Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-27622-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Successful listening includes looking at the person speaking and paying close attention."""@en ;
  dcterms:modified "2026-02-12T08:59:21.685114Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-27622-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Speaking in full sentences and in a loud, clear voice helps the listener understand what is being said."""@en ;
  dcterms:modified "2026-02-12T08:59:21.685119Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-6198-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """An introduction of a non-chronological report should entice the reader to read the main report."""@en ;
  dcterms:modified "2026-02-12T08:59:21.685123Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-6198-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "An introduction should make the report itself seem interesting and informative."@en ;
  dcterms:modified "2026-02-12T08:59:21.685128Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-6198-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """A question is a type of simple sentence that asks the reader for an answer and ends with a question mark."""@en ;
  dcterms:modified "2026-02-12T08:59:21.685135Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-6198-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "A question mark is a punctuation mark used at the end of a question."@en ;
  dcterms:modified "2026-02-12T08:59:21.685170Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-6198-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """A command is a type of simple sentence that tells someone to do something and can end with an exclamation mark"""@en ;
  dcterms:modified "2026-02-12T08:59:21.685175Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-6199-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Planning is an important part of preparing to write."@en ;
  dcterms:modified "2026-02-12T08:59:21.685182Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-6199-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """A plan helps a writer to organise their ideas, thoughts and the information they want to include in their writing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.685187Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-6199-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Notes can be used in a plan to help organise key information and are not written in full sentences."""@en ;
  dcterms:modified "2026-02-12T08:59:21.685191Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-6199-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Bats are nocturnal animals, which means they sleep during the day and are awake at night."""@en ;
  dcterms:modified "2026-02-12T08:59:21.685196Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-6199-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Bats have very poor eyesight but use echolocation to help them navigate their way around."""@en ;
  dcterms:modified "2026-02-12T08:59:21.685200Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-6182-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Florence Nightingale was a nurse during the Crimean War."@en ;
  dcterms:modified "2026-02-12T08:59:21.685204Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-6182-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Florence Nightingale helped to train nurses and make hospitals cleaner."@en ;
  dcterms:modified "2026-02-12T08:59:21.685209Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-6182-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Mary Seacole was born in Jamaica and was a doctress."@en ;
  dcterms:modified "2026-02-12T08:59:21.685216Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-6182-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Mary Seacole went to the Crimean War and set up a hospital called the ‘British Hotel’ to look after wounded soldiers."""@en ;
  dcterms:modified "2026-02-12T08:59:21.685221Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-37-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "x-height letters can be called small letters"@en ;
  dcterms:modified "2026-02-12T08:59:21.685775Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-37-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "x-height letters sit between the baseline and the x-height line"@en ;
  dcterms:modified "2026-02-12T08:59:21.685780Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-37-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The letters are formed by following the right starting point and direction"@en ;
  dcterms:modified "2026-02-12T08:59:21.685785Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-37-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "X-height letters are all the same height"@en ;
  dcterms:modified "2026-02-12T08:59:21.685789Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-37-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The small letters are: a, c, o, e, i, m, n, r, s, u, v, w, x and z"@en ;
  dcterms:modified "2026-02-12T08:59:21.685796Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4777-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The letters are formed by following the right starting point and direction."@en ;
  dcterms:modified "2026-02-12T08:59:21.686228Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4777-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The third join starts at the x-height line and dips below the x-height line and back up to join the next letter."""@en ;
  dcterms:modified "2026-02-12T08:59:21.686235Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4777-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The letter strings are all x-height letters."@en ;
  dcterms:modified "2026-02-12T08:59:21.686240Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4777-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """When using the third join you leave enough space to ensure the letters are not touching without leaving a big gap."""@en ;
  dcterms:modified "2026-02-12T08:59:21.686245Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4777-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """You don't lift your pencil until the letter string is complete. The dot for the i is added at the end."""@en ;
  dcterms:modified "2026-02-12T08:59:21.686249Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-6206-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The subheading ‘Childhood and inspiration’ tells the reader what the section will be about."""@en ;
  dcterms:modified "2026-02-12T08:59:21.686543Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-6206-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The plan should include when and where the author was born, important or interesting facts and inspiration."""@en ;
  dcterms:modified "2026-02-12T08:59:21.686547Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-6206-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Notes are used when making a plan and capture key vocabulary and important information."""@en ;
  dcterms:modified "2026-02-12T08:59:21.686554Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-6206-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Notes are not written in full sentences and do not require capital letters or full stops."""@en ;
  dcterms:modified "2026-02-12T08:59:21.686559Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-6206-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Notes for an information text should include precise, accurate and descriptive vocabulary."""@en ;
  dcterms:modified "2026-02-12T08:59:21.686563Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4793-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "High frequency words are words that appear most frequently in written texts."@en ;
  dcterms:modified "2026-02-12T08:59:21.687262Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4793-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Letters in the high frequency words will be joined using a range of joins depending on the letters in the word."""@en ;
  dcterms:modified "2026-02-12T08:59:21.687266Z"^^xsd:dateTime .

