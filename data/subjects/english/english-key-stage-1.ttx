  dcterms:modified "2026-02-12T08:59:21.670271Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4792-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The first letter of the word always has a lead in and the last letter has a lead out."""@en ;
  dcterms:modified "2026-02-12T08:59:21.670276Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4792-4
  a oakcurric:KeyLearningPoint ;
