  a oakcurric:KeyLearningPoint ;
  rdfs:label "All of the letters have a starting point on the x-height line."@en ;
  dcterms:modified "2026-02-12T08:59:21.687337Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4774-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The second join goes from the baseline to the ascender line when joining to a tall letter."""@en ;
  dcterms:modified "2026-02-12T08:59:21.687341Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4774-4
