  a oakcurric:KeyLearningPoint ;
  rdfs:label """The pre-cursive letters c, a and d all have a curved up stroke on the baseline as the lead out"""@en ;
  dcterms:modified "2026-02-12T08:59:21.695174Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4753-3
