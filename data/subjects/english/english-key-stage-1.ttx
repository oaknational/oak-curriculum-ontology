  a oakcurric:KeyLearningPoint ;
  rdfs:label """The pre-cursive letter q has a diagonal line from the descender line to the baseline as the lead out"""@en ;
  dcterms:modified "2026-02-12T08:59:21.671061Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4783-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Cursive handwriting involves joining letters together without lifting your pencil."""@en ;
  dcterms:modified "2026-02-12T08:59:21.671065Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4783-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The first join connects from the baseline to the x-height line."@en ;
