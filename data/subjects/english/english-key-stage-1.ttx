# ----------------------------------------------------------------------
# Key Learning Points
# ----------------------------------------------------------------------

oak:keylearningpoint-lesson-907-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The tense of a simple sentence changes the time frame of the action."@en ;
  dcterms:modified "2026-02-12T08:59:21.481369Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-907-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Fronted adverbials of time tell the reader the time frame of the action."@en ;
  dcterms:modified "2026-02-12T08:59:21.481375Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-907-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "A simple sentence is about one idea."@en ;
  dcterms:modified "2026-02-12T08:59:21.481379Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-907-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "A simple sentence makes complete sense."@en ;
  dcterms:modified "2026-02-12T08:59:21.481382Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-6838-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Information about a character and setting can be found in the text and in illustrations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481816Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-6838-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """A front cover shares the title, 'Wild', the author, Emily Hughes and illustrations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481822Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-6838-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Knowing some key information about the book, such as the setting being a forest, helps to make a prediction."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481828Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-6838-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "A setting means where a story takes place."@en ;
  dcterms:modified "2026-02-12T08:59:21.481832Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-6838-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The plot is what the story is about."@en ;
  dcterms:modified "2026-02-12T08:59:21.481836Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-5325-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "A recount is a type of writing which retells something that has already happened"@en ;
  dcterms:modified "2026-02-12T08:59:21.483069Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-5325-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Recounts are mostly told in chronological or time order"@en ;
  dcterms:modified "2026-02-12T08:59:21.483073Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-5325-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Recounts are mostly written in the first person using 'I', 'me' and 'my'"@en ;
  dcterms:modified "2026-02-12T08:59:21.483077Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-5325-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Personal recounts can include facts and opinions"@en ;
  dcterms:modified "2026-02-12T08:59:21.483081Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-5325-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Recounts are told in the past tense"@en ;
  dcterms:modified "2026-02-12T08:59:21.483085Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-5408-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """A front cover often shows the title, an illustration, the author's name and the illustrator's name"""@en ;
  dcterms:modified "2026-02-12T08:59:21.483448Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-5408-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The title and illustrations can generate a prediction about what a book might be about"""@en ;
  dcterms:modified "2026-02-12T08:59:21.483452Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-5408-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "One person's prediction might be different to another person's"@en ;
  dcterms:modified "2026-02-12T08:59:21.483456Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-5408-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Looking closely at some illustrations can help to make more detailed predictions"@en ;
  dcterms:modified "2026-02-12T08:59:21.483461Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-5408-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Looking at illustrations and discussing a book before reading builds excitement about reading it"""@en ;
  dcterms:modified "2026-02-12T08:59:21.483464Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-6839-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Information about a character and setting can be found in the text and in illustrations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484434Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-6839-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Some adjectives describe feelings and emotions."@en ;
  dcterms:modified "2026-02-12T08:59:21.484438Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-6839-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "A character's feelings and emotion can change throughout the story."@en ;
  dcterms:modified "2026-02-12T08:59:21.484442Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-6839-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Linking our own experiences to what we are reading helps us to understand the character's feelings and actions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484446Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-6839-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The feeling of belonging means being accepted, feeling included and safe."@en ;
  dcterms:modified "2026-02-12T08:59:21.484453Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-6841-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """This story will be told from the girl's perspective, using the words "I", "me" and "my"."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485064Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-6841-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Thinking from someone else's perspective includes imagining how they might feel."@en ;
  dcterms:modified "2026-02-12T08:59:21.485068Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-6841-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Thinking from someone else's perspective includes imagining why they do certain things."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485072Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-6841-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Thinking from someone else's perspective includes imagining what they like or dislike."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485076Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-6841-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Facial expressions and movements help us understand what is happening in a story even when words have not been used."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485080Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-936-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """‘ew’ is a representation of the 'oo' phoneme that often comes at the end of a word."""@en ;
  dcterms:modified "2026-02-12T08:59:21.609216Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-936-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The ‘oo’ phoneme can be pronounced in two different ways: 'oo' and 'yoo'."@en ;
  dcterms:modified "2026-02-12T08:59:21.609224Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-936-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "How to spell the high frequency word: now."@en ;
  dcterms:modified "2026-02-12T08:59:21.609231Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-936-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "'New' and 'knew' are homophones."@en ;
  dcterms:modified "2026-02-12T08:59:21.609238Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-5409-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Fiction books are made up by the author and non-fiction books provide information based on facts."""@en ;
  dcterms:modified "2026-02-12T08:59:21.610295Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-5409-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Fiction books have fictional characters and places and non-fiction books provide information about real subjects."""@en ;
  dcterms:modified "2026-02-12T08:59:21.610302Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-5409-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Fiction books often have illustrations and non-fiction books often have photographs or diagrams of real things."""@en ;
  dcterms:modified "2026-02-12T08:59:21.610310Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-5409-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Fiction books usually follow a story structure and non-fiction books are usually organised by topic or subject."""@en ;
  dcterms:modified "2026-02-12T08:59:21.610317Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-5409-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Fiction books often have a moral and non-fiction books are designed to provide information and teach new things."""@en ;
  dcterms:modified "2026-02-12T08:59:21.610330Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-36-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The letters v, w, x and z are all x-height letters."@en ;
  dcterms:modified "2026-02-12T08:59:21.611120Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-36-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The letters v and w are formed by \"going diagonally down and back up\"."@en ;
  dcterms:modified "2026-02-12T08:59:21.611127Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-36-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The letter x is formed by making two diagonal straight lines crossing in the centre."""@en ;
  dcterms:modified "2026-02-12T08:59:21.611135Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-36-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The letter z is formed by a zigzag pattern with a straight, then diagonal and then a straight line."""@en ;
  dcterms:modified "2026-02-12T08:59:21.611142Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-6196-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Hedgehogs have thousands of spikes on their backs which are called spines."@en ;
  dcterms:modified "2026-02-12T08:59:21.611149Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-6196-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Hedgehogs protect themselves by curling up into a ball with their spines facing out."""@en ;
  dcterms:modified "2026-02-12T08:59:21.611156Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-6196-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The name for an animal that tries to eat another animal is predator."@en ;
  dcterms:modified "2026-02-12T08:59:21.611168Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-6196-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The name for an animal that other animals try to eat is prey."@en ;
  dcterms:modified "2026-02-12T08:59:21.611175Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-6196-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Habitat is the name for the place that an animal lives."@en ;
  dcterms:modified "2026-02-12T08:59:21.611183Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-5411-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The plot is what happens in a story"@en ;
  dcterms:modified "2026-02-12T08:59:21.611506Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-5411-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Fiction stories can sometimes teach us about real life experiences, such as how to care for a pet"""@en ;
  dcterms:modified "2026-02-12T08:59:21.611514Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-5411-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Illustrations, as well as the text, can help us to engage and respond to a story"@en ;
  dcterms:modified "2026-02-12T08:59:21.611521Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-5411-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Illustrations and the text can help us to describe the characters in stories"@en ;
  dcterms:modified "2026-02-12T08:59:21.611528Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-5411-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "People can have different personal responses to what they have read"@en ;
  dcterms:modified "2026-02-12T08:59:21.611536Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-898-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Adverbs describe verbs."@en ;
  dcterms:modified "2026-02-12T08:59:21.611543Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-898-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Adverbs tell the reader how a verb is or was done."@en ;
  dcterms:modified "2026-02-12T08:59:21.611550Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-898-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Adverbs often end in -ly."@en ;
  dcterms:modified "2026-02-12T08:59:21.611558Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-898-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "An adverb is often paired with the verb it is describing."@en ;
  dcterms:modified "2026-02-12T08:59:21.611565Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-901-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Adjectives are words that describe nouns."@en ;
  dcterms:modified "2026-02-12T08:59:21.612245Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-901-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Adjectives can describe singular or plural common nouns."@en ;
  dcterms:modified "2026-02-12T08:59:21.612252Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-901-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Adjectives can describe proper nouns."@en ;
  dcterms:modified "2026-02-12T08:59:21.612259Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-901-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "An adjective often comes before the noun it is describing."@en ;
  dcterms:modified "2026-02-12T08:59:21.612266Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-901-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Adjectives help the reader picture the noun."@en ;
  dcterms:modified "2026-02-12T08:59:21.612273Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-8900-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Predictions about the plot can be made using the front cover, title, illustrations and what we know"""@en ;
  dcterms:modified "2026-02-12T08:59:21.612619Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-8900-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """A front cover shares the title, "Ada Twist, Scientist", the author, Andrea Beaty and illustrations"""@en ;
  dcterms:modified "2026-02-12T08:59:21.612629Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-8900-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Sometimes, authors write a range of books with similarities"@en ;
  dcterms:modified "2026-02-12T08:59:21.612637Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-8900-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Looking at other books by the same author can help us to make links"@en ;
  dcterms:modified "2026-02-12T08:59:21.612644Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-8900-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Front covers and our own interests help us to decide which books we'd most like to read"""@en ;
  dcterms:modified "2026-02-12T08:59:21.612650Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-6281-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Perspective is the way someone thinks, feels or sees something."@en ;
  dcterms:modified "2026-02-12T08:59:21.613314Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-6281-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Florence Nightingale went to the Crimean War to help the wounded soldiers. She was shocked by what she saw."""@en ;
  dcterms:modified "2026-02-12T08:59:21.613320Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-6281-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Notes are used when making a plan and they are short and only capture key vocabulary and important information."""@en ;
  dcterms:modified "2026-02-12T08:59:21.613331Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-6281-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Notes are not written in full sentences and do not require capital letters, full stops or commas."""@en ;
  dcterms:modified "2026-02-12T08:59:21.613338Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-6822-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Predictions can be made based on illustrations, what has already been read and the front cover"""@en ;
  dcterms:modified "2026-02-12T08:59:21.613401Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-6822-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "One person's prediction may be different to another person's"@en ;
  dcterms:modified "2026-02-12T08:59:21.613408Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-6822-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Traditional tales often start by introducing the characters, such as the three goats and setting the scene"""@en ;
  dcterms:modified "2026-02-12T08:59:21.613415Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-6822-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The Three Billy Goats Gruff teaches the reader to be kind to others"@en ;
  dcterms:modified "2026-02-12T08:59:21.613422Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-6822-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Traditional tales mostly end happily, such as being able to cross the bridge"@en ;
  dcterms:modified "2026-02-12T08:59:21.613428Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-928-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """igh' is a representation of the 'igh' phoneme that is often found in the middle of a word and 'loves a t'."""@en ;
  dcterms:modified "2026-02-12T08:59:21.613566Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-928-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """‘i-e’ is a representation of the ‘igh’ phoneme that is often found ‘last but one'."""@en ;
  dcterms:modified "2026-02-12T08:59:21.613573Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-928-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "i-e' is a split digraph."@en ;
  dcterms:modified "2026-02-12T08:59:21.613580Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-928-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "How to spell the common exception words: so and do."@en ;
  dcterms:modified "2026-02-12T08:59:21.613591Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28627-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "James Carter is a poet and he loves words."@en ;
  dcterms:modified "2026-02-12T08:59:21.614889Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28627-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "‘A Ticket to Kalamazoo!’ is a fun poem about going on an imaginary adventure."@en ;
  dcterms:modified "2026-02-12T08:59:21.614896Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28627-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """‘A Ticket to Kalamazoo!’ uses rhyme and repetition, which make it fun to say and easy to remember."""@en ;
  dcterms:modified "2026-02-12T08:59:21.614902Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28627-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "When performing a poem, we should speak loudly and slowly."@en ;
  dcterms:modified "2026-02-12T08:59:21.614909Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-5443-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "A poet is someone who writes poems."@en ;
  dcterms:modified "2026-02-12T08:59:21.614985Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-5443-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Poems try to use words in a special way to create a feeling or to tell a story."@en ;
  dcterms:modified "2026-02-12T08:59:21.615039Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-5443-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "James Carter is a poet who uses rhyming words in his poems."@en ;
  dcterms:modified "2026-02-12T08:59:21.615048Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-5443-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Repetition in poems can make the poem fun to say and easy to remember."@en ;
  dcterms:modified "2026-02-12T08:59:21.615054Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-5443-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """James Carter uses onomatopoeia which helps us to imagine what sounds can be heard in a story or a poem."""@en ;
  dcterms:modified "2026-02-12T08:59:21.615061Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4768-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The letters all have a lead in and a lead out."@en ;
  dcterms:modified "2026-02-12T08:59:21.615234Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4768-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The pencil does not lift when forming the join."@en ;
  dcterms:modified "2026-02-12T08:59:21.615241Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4768-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The third join starts at the x-height line and dips below the x-height line and back up to join the next letter."""@en ;
  dcterms:modified "2026-02-12T08:59:21.615248Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4768-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """When connecting the letter e, with the third join, the dip down starts the formation of the letter e."""@en ;
  dcterms:modified "2026-02-12T08:59:21.615260Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-5433-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Traditional tales are mostly told in the past tense"@en ;
  dcterms:modified "2026-02-12T08:59:21.615946Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-5433-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The beginning of a story introduces the main characters, setting and plot"@en ;
  dcterms:modified "2026-02-12T08:59:21.615952Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-5433-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Two ideas can be joined using a joining word, 'and'"@en ;
  dcterms:modified "2026-02-12T08:59:21.615958Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-5433-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Two adjective sentences need a comma in between the two adjectives, such as 'noisy, hungry cow'"""@en ;
  dcterms:modified "2026-02-12T08:59:21.615965Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-5433-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Exclamation marks can be used to show anger, such as when mother throws the beans out of the window"""@en ;
  dcterms:modified "2026-02-12T08:59:21.615971Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-5445-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "A chorus is a part of a poem that repeats again and again."@en ;
  dcterms:modified "2026-02-12T08:59:21.616282Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-5445-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Onomatopoeia is when a word sounds like what it is describing."@en ;
  dcterms:modified "2026-02-12T08:59:21.616289Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-5445-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Poems can make the listener think about their own experiences."@en ;
  dcterms:modified "2026-02-12T08:59:21.616295Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-5445-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Repetition adds to the rhythm of the poem helping to make it fun to read and easy to remember."""@en ;
  dcterms:modified "2026-02-12T08:59:21.616302Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-5445-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Splish! Splash! Splosh! uses lots of descriptive words to talk about different sensory experiences about water."""@en ;
  dcterms:modified "2026-02-12T08:59:21.616308Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28628-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The poem ‘Elephant Beat’ tells a story about the adventure of riding an elephant."""@en ;
  dcterms:modified "2026-02-12T08:59:21.616759Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28628-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "It has a structured rhythm, which gives it a marching feel."@en ;
  dcterms:modified "2026-02-12T08:59:21.616767Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28628-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """‘Night Soup’ is a poem about creating an imaginary, magical ‘soup’ made from elements of the night."""@en ;
  dcterms:modified "2026-02-12T08:59:21.616774Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28628-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "When performing a poem, we can vary our volume to create different effects."@en ;
  dcterms:modified "2026-02-12T08:59:21.616781Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-28628-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Using expression and gestures can make our performances fun and interesting for the audience to watch."""@en ;
  dcterms:modified "2026-02-12T08:59:21.616787Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-5446-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "James Carter tries to create pictures in the listener's head."@en ;
  dcterms:modified "2026-02-12T08:59:21.616794Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-5446-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Descriptions using onomatopoeia, verbs and nouns help to imagine how the bear sounds, looks and moves."""@en ;
  dcterms:modified "2026-02-12T08:59:21.616801Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-5446-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "These words can be spoken with expression and intonation."@en ;
  dcterms:modified "2026-02-12T08:59:21.616807Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-5446-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Poems feel different to read depending on their rhythm."@en ;
  dcterms:modified "2026-02-12T08:59:21.616814Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-5446-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The way we read a poem can make it entertaining for people listening."@en ;
  dcterms:modified "2026-02-12T08:59:21.616820Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-8210-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """James Carter is a British poet who is mostly known for his entertaining poetry written for children."""@en ;
  dcterms:modified "2026-02-12T08:59:21.617212Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-8210-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "'What Did You Do at School Today?’ is a humorous poem."@en ;
  dcterms:modified "2026-02-12T08:59:21.617219Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-8210-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The poem is written as a conversation between a child and their mother about what the child did at school."""@en ;
  dcterms:modified "2026-02-12T08:59:21.617225Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-8210-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The poet uses a particular layout and structure in the poem to show the reader that it is a conversation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.617232Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-8210-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """'Wide Open' is humorous poem by Rachel Rooney; 'Ten Dancing Dinosaurs' is a humorous poem by John Foster."""@en ;
  dcterms:modified "2026-02-12T08:59:21.617241Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-5444-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Using the first person helps us think from someone or something else’s perspective."""@en ;
  dcterms:modified "2026-02-12T08:59:21.617316Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-5444-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Using \"I\" allows us to imagine we are someone or something else."@en ;
  dcterms:modified "2026-02-12T08:59:21.617323Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-5444-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Using exciting nouns and verbs help us to use our imagination to know what something looks or sounds like."""@en ;
  dcterms:modified "2026-02-12T08:59:21.617329Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-5444-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "James Carter is a poet who uses words that rhyme and onomatopoeia in his poems."@en ;
  dcterms:modified "2026-02-12T08:59:21.617336Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-5444-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Onomatopoeia is when a word sounds like what it is describing."@en ;
  dcterms:modified "2026-02-12T08:59:21.617342Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-5447-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Poems can be learnt by heart by listening to them again and again."@en ;
  dcterms:modified "2026-02-12T08:59:21.617736Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-5447-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Making comparisons means finding similarities and differences in a poem, such as the use of rhyme and onomatopoeia."""@en ;
  dcterms:modified "2026-02-12T08:59:21.617745Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-5447-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Personal responses are a way of sharing your own thoughts, feelings, and opinions about the text."""@en ;
  dcterms:modified "2026-02-12T08:59:21.617751Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-5447-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Actions and sound effects help to add to a poem's meaning."@en ;
  dcterms:modified "2026-02-12T08:59:21.617757Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-5447-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Expression and volume help to hold an audience's attention."@en ;
  dcterms:modified "2026-02-12T08:59:21.617763Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-904-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Verbs are doing words."@en ;
  dcterms:modified "2026-02-12T08:59:21.618328Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-904-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Verbs agree with the noun they are paired with."@en ;
  dcterms:modified "2026-02-12T08:59:21.618334Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-904-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "A complete sentence must contain a verb."@en ;
  dcterms:modified "2026-02-12T08:59:21.618344Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-904-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "A doing verb can be the only verb in a complete sentence."@en ;
  dcterms:modified "2026-02-12T08:59:21.618350Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-927-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """'e' is a representation of the 'ee' phoneme that is often found in short high frequency words."""@en ;
  dcterms:modified "2026-02-12T08:59:21.618454Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-927-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """'y' is a representation of the 'ee' phoneme that is often found at the end of a word."""@en ;
  dcterms:modified "2026-02-12T08:59:21.618464Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-927-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """'ey' is a representation of the 'ee' phoneme that is often found at the end of a word."""@en ;
  dcterms:modified "2026-02-12T08:59:21.618470Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-927-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """'ie' is a representation of the 'ee' phoneme that is often found in the middle of a word."""@en ;
  dcterms:modified "2026-02-12T08:59:21.618477Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-927-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "How to spell the common exception words: class, grass and pass."@en ;
  dcterms:modified "2026-02-12T08:59:21.618483Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-8480-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """‘The Wolf, The Duck and The Mouse’ is a children’s story told through narrative writing and illustrations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.618489Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-8480-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Using what we know to make a prediction can help to build our understanding of a text."""@en ;
  dcterms:modified "2026-02-12T08:59:21.618495Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-8480-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """There can be multiple main characters in a story, e.g. the wolf, the duck and the mouse are all main characters."""@en ;
  dcterms:modified "2026-02-12T08:59:21.618507Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-8480-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The main setting of the story is inside the stomach of the wolf."@en ;
  dcterms:modified "2026-02-12T08:59:21.618514Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-8480-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The plot follows the story of how the duck and the mouse decide to make a home inside the wolf’s stomach."""@en ;
  dcterms:modified "2026-02-12T08:59:21.618520Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-8888-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Fiction is a story which is made up or imagined."@en ;
  dcterms:modified "2026-02-12T08:59:21.619540Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-8888-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The opening of a story introduces the characters and the setting."@en ;
  dcterms:modified "2026-02-12T08:59:21.619549Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-8888-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Plop is a baby barn owl who is afraid of the dark."@en ;
  dcterms:modified "2026-02-12T08:59:21.619555Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-8888-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Plop's mother wants Plop to learn not to be afraid of the dark."@en ;
  dcterms:modified "2026-02-12T08:59:21.619561Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-8925-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "An adjective describes a noun"@en ;
  dcterms:modified "2026-02-12T08:59:21.620627Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-8925-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "A character can feel different emotions at different points of a story"@en ;
  dcterms:modified "2026-02-12T08:59:21.620636Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-8925-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Including a range of adjectives to describe the same feeling stops repetition and makes writing more interesting"""@en ;
  dcterms:modified "2026-02-12T08:59:21.620642Z"^^xsd:dateTime .

