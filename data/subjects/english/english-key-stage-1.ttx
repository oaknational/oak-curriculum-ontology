  a oakcurric:KeyLearningPoint ;
  rdfs:label "You don’t lift your pencil until the letter string is complete."@en ;
  dcterms:modified "2026-02-12T08:59:21.670285Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4754-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The pre-cursive letters o, g and q all have a lead in which starts at the baseline"""@en ;
