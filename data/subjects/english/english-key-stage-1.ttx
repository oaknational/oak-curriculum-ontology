  dcterms:modified "2026-02-12T08:59:21.671074Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4783-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The third join connects from the x-height line to the x-height line."@en ;
