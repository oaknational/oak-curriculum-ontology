  dcterms:modified "2026-02-12T08:59:21.674639Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4776-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The letters are formed by following the right starting point and direction."@en ;
  dcterms:modified "2026-02-12T08:59:21.674643Z"^^xsd:dateTime .

