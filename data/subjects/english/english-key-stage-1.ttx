  dcterms:modified "2026-02-12T08:59:21.674628Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-920-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """‘a-e’ is a representation of the ‘ay’ phoneme that is often found ‘last but one'."""@en ;
