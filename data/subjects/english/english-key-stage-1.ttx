oak:keylearningpoint-lesson-4799-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "There is appropriate spacing between the letters."@en ;
  dcterms:modified "2026-02-12T08:59:21.687987Z"^^xsd:dateTime .

