  dcterms:modified "2026-02-12T08:59:21.668084Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4782-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Break letters are letters in the alphabet that do not join to the next letter in the letter string."""@en ;
  dcterms:modified "2026-02-12T08:59:21.668088Z"^^xsd:dateTime .

