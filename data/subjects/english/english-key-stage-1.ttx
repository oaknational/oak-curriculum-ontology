  a oakcurric:KeyLearningPoint ;
  rdfs:label """The first letter of the word always has a lead in and the last letter has a lead out."""@en ;
  dcterms:modified "2026-02-12T08:59:21.687275Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4793-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "There is appropriate spacing between the letters."@en ;
  dcterms:modified "2026-02-12T08:59:21.687280Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4793-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "You don’t lift your pencil until the letter string is complete."@en ;
  dcterms:modified "2026-02-12T08:59:21.687284Z"^^xsd:dateTime .

