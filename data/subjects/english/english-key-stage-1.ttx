oak:keylearningpoint-lesson-4772-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The first join goes from the baseline to the x-height line."@en ;
  dcterms:modified "2026-02-12T08:59:21.687323Z"^^xsd:dateTime .

