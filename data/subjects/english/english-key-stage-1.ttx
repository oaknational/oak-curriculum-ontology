  dcterms:modified "2026-02-12T08:59:21.693625Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4790-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Letters in the common exception words will be joined using a range of joins depending on the letters in the word."""@en ;
  dcterms:modified "2026-02-12T08:59:21.693629Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4790-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The first letter always has a lead in and the last letter always has a lead out."@en ;
  dcterms:modified "2026-02-12T08:59:21.693634Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4790-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "There is appropriate spacing between the letters."@en ;
  dcterms:modified "2026-02-12T08:59:21.693638Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4790-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """You don't lift your pencil to add the 'cross' for the letter t until the letter string is complete."""@en ;
  dcterms:modified "2026-02-12T08:59:21.693642Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-6851-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "'Leaf' is a fiction text where all of the characters are animals with voices."@en ;
  dcterms:modified "2026-02-12T08:59:21.694254Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-6851-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Making predictions means deciding what you think will happen in a story using illustration and the text as evidence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.694259Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-6851-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Fiction books can be based on a real life issue or event, e.g. climate change."@en ;
  dcterms:modified "2026-02-12T08:59:21.694263Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-6851-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Developing deeper understanding of 'Leaf' can allow us to learn important lessons from the story."""@en ;
  dcterms:modified "2026-02-12T08:59:21.694268Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-6851-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label """One person's prediction or the lesson they interpret may be different to another person's."""@en ;
  dcterms:modified "2026-02-12T08:59:21.694272Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-27604-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Instructions are sentences that tell us how to do something."@en ;
  dcterms:modified "2026-02-12T08:59:21.694277Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-27604-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Successful speaking includes speaking loudly and clearly enough for everyone to hear."""@en ;
  dcterms:modified "2026-02-12T08:59:21.694281Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-27604-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Successful listening includes looking at the person speaking and paying close attention."""@en ;
  dcterms:modified "2026-02-12T08:59:21.694285Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-27776-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The capital letters J, U, X, Y and Z start on the ascender line."@en ;
  dcterms:modified "2026-02-12T08:59:21.695009Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-27776-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The capital letters J, U, X, Y and Z all have either one or two vertical or diagonal lines going down to the baseline."""@en ;
  dcterms:modified "2026-02-12T08:59:21.695014Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-27776-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The letters J, X and Y all need the pencil to be lifted to form the horizontal or diagonal lines."""@en ;
  dcterms:modified "2026-02-12T08:59:21.695018Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-27776-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "You do not lift your pencil when forming the letters U and Z."@en ;
  dcterms:modified "2026-02-12T08:59:21.695025Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-27776-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The letter Z has a zigzag pattern."@en ;
  dcterms:modified "2026-02-12T08:59:21.695030Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4785-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label """Capital letters are used at the beginning of a sentence, for proper nouns and for the pronoun I."""@en ;
  dcterms:modified "2026-02-12T08:59:21.695124Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4785-2
  a oakcurric:KeyLearningPoint ;
  rdfs:label "Capital letters sit between the baseline and the ascender line."@en ;
  dcterms:modified "2026-02-12T08:59:21.695129Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4785-3
  a oakcurric:KeyLearningPoint ;
  rdfs:label """The letters C, G, O and Q all start on the ascender line and curl round in an anti-clockwise direction."""@en ;
  dcterms:modified "2026-02-12T08:59:21.695133Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4785-4
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The letters C, O, M, N, W and V are all made using one continuous movement."@en ;
  dcterms:modified "2026-02-12T08:59:21.695138Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4785-5
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The letters M, N, W and V are all made using vertical lines or diagonal lines."@en ;
  dcterms:modified "2026-02-12T08:59:21.695142Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4753-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The pre-cursive letters c, a and d all start on the baseline with a lead in"@en ;
  dcterms:modified "2026-02-12T08:59:21.695169Z"^^xsd:dateTime .

