  a oakcurric:KeyLearningPoint ;
  rdfs:label "The cross for the letter t gets added once the letter string is complete."@en ;
  dcterms:modified "2026-02-12T08:59:21.687327Z"^^xsd:dateTime .

oak:keylearningpoint-lesson-4774-1
  a oakcurric:KeyLearningPoint ;
  rdfs:label "The letters are formed by following the right starting point and direction."@en ;
  dcterms:modified "2026-02-12T08:59:21.687332Z"^^xsd:dateTime .

