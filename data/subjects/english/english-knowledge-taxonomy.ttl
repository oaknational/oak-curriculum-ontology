# ======================================================================
# National Curriculum for England - English Knowledge Taxonomy 
# ======================================================================

# ----------------------------------------------------------------------
# Ontology Declaration
# ----------------------------------------------------------------------

<https://w3id.org/uk/oak/curriculum/nationalcurriculum/english-knowledge-taxonomy>
  rdf:type owl:Ontology ;

  rdfs:label "National Curriculum for England - English Knowledge Taxonomy"@en ;
  dc:title "National Curriculum for England - English Knowledge Taxonomy"@en ;
  rdfs:comment """English knowledge taxonomy for the National Curriculum in England, 
  organizing content through strands, sub-strands, content descriptors, and sub-content 
  descriptors."""@en ;

  owl:versionInfo "0.1.0" ;
  owl:versionIRI <https://w3id.org/uk/oak/curriculum/nationalcurriculum/english-knowledge-taxonomy/0.1.0> ;
  
  dcterms:description """English knowledge taxonomy for the National Curriculum in England, 
  organizing content through strands, sub-strands, content descriptors, and sub-content 
  descriptors."""@en ;
  dcterms:created "2025-11-24T12:33:32Z"^^xsd:dateTime ;
  dcterms:modified "2025-12-03T12:33:32Z"^^xsd:dateTime ;
  dcterms:issued "2025-12-03T12:33:32Z"^^xsd:dateTime ;
  
  # OGL 3.0 License
  dcterms:license <http://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/> ;
  dcterms:rights "Crown Copyright"@en ;

  vann:preferredNamespacePrefix "natcurric" ;
  vann:preferredNamespaceUri "https://w3id.org/uk/oak/curriculum/nationalcurriculum/" ;

  owl:imports <https://w3id.org/uk/oak/curriculum/ontology> ;
  owl:imports <https://w3id.org/uk/oak/curriculum/core/> ;
  owl:imports <https://w3id.org/uk/oak/curriculum/nationalcurriculum/english-programme-structure> .

# ----------------------------------------------------------------------
# Knowledge Taxonomy
# ----------------------------------------------------------------------

natcurric:knowledge-taxonomy
  a skos:ConceptScheme ;
  skos:prefLabel "National Curriculum for England Knowledge Taxonomy"@en ;
  skos:hasTopConcept natcurric:discipline-english ;
  dcterms:modified "2025-12-18T12:33:32Z"^^xsd:dateTime .
  
# ----------------------------------------------------------------------
# Disciplines
# ----------------------------------------------------------------------

natcurric:discipline-english
  a skos:Concept, curric:Discipline ;
  skos:prefLabel "English"@en ;
  skos:definition "Description of discipline..."@en ;
  skos:topConceptOf natcurric:knowledge-taxonomy ;
  skos:narrower
    natcurric:strand-reading ,
    natcurric:strand-writing ,
    natcurric:strand-grammar-and-vocabulary ,
    natcurric:strand-spoken-english ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2025-12-18T12:33:32Z"^^xsd:dateTime .

# ----------------------------------------------------------------------
# Strands
# ----------------------------------------------------------------------

natcurric:strand-reading
  a skos:Concept, curric:Strand ;
  skos:prefLabel "Reading"@en ;
  skos:definition "Description of strand..."@en ;
  curric:displayOrder "1"^^xsd:positiveInteger ;
  skos:broader natcurric:discipline-english ;
  skos:narrower natcurric:substrand-word-reading ,
                natcurric:substrand-comprehension ,
                natcurric:substrand-appreciation-and-love-of-reading ,
                natcurric:substrand-increasingly-challenging-texts ,
                natcurric:substrand-read-critically ,
                natcurric:substrand-english-literary-heritage ,
                natcurric:substrand-critically-evaluate-texts ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2025-12-18T12:33:32Z"^^xsd:dateTime .

natcurric:strand-writing
  a skos:Concept, curric:Strand ;
  skos:prefLabel "Writing"@en ;
  skos:definition "Description of strand..."@en ;
  curric:displayOrder "2"^^xsd:positiveInteger ;
  skos:broader natcurric:discipline-english ;
  skos:narrower natcurric:substrand-transcription ,
                natcurric:substrand-handwriting ,
                natcurric:substrand-composition ,
                natcurric:substrand-write-accurately-fluently-effectively ,
                natcurric:substrand-plan-draft-edit-and-proofread ,
                natcurric:substrand-revise-edit-and-proof-read ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2025-12-18T12:33:32Z"^^xsd:dateTime .

natcurric:strand-grammar-and-vocabulary
  a skos:Concept, curric:Strand ;
  skos:prefLabel "Grammar and Vocabulary"@en ;
  skos:definition "Description of strand..."@en ;
  curric:displayOrder "3"^^xsd:positiveInteger ;
  skos:broader natcurric:discipline-english ;
  skos:narrower natcurric:substrand-vocabulary-grammar-punctuation ,
                natcurric:substrand-consolidate-knowledge-grammar-vocabulary ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2025-12-18T12:33:32Z"^^xsd:dateTime .

natcurric:strand-spoken-english
  a skos:Concept, curric:Strand ;
  skos:prefLabel "Spoken English"@en ;
  skos:definition "Description of strand..."@en ;
  curric:displayOrder "4"^^xsd:positiveInteger ;
  skos:broader natcurric:discipline-english ;
  skos:narrower natcurric:substrand-speak-confidently-effectively ,
                natcurric:substrand-speak-confidently-audibly-effectively ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2025-12-18T12:33:32Z"^^xsd:dateTime .

