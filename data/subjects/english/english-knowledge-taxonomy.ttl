# ======================================================================
# National Curriculum for England - English Knowledge Taxonomy
# ======================================================================

# ----------------------------------------------------------------------
# Ontology Declaration
# ----------------------------------------------------------------------

<https://w3id.org/uk/oak/curriculum/nationalcurriculum/english-knowledge-taxonomy>
  rdf:type owl:Ontology ;

  rdfs:label "National Curriculum for England - English Knowledge Taxonomy"@en ;
  dc:title "National Curriculum for England - English Knowledge Taxonomy"@en ;
  rdfs:comment """English knowledge taxonomy defining the hierarchical organisation of content from
  strands through to sub-content descriptors."""@en ;

  owl:versionInfo "0.1.1" ;
  owl:versionIRI <https://w3id.org/uk/oak/curriculum/nationalcurriculum/english-knowledge-taxonomy/0.1.1> ;

  dcterms:description """This file defines the English knowledge taxonomy for the National
  Curriculum in England, organising content through strands, sub-strands, content
  descriptors, and sub-content descriptors."""@en ;
  dc:creator "Department for Education" ;
  dcterms:created "2026-05-12T23:01:09Z"^^xsd:dateTime ;
  dcterms:modified "2026-05-12T23:01:09Z"^^xsd:dateTime ;
  dcterms:issued "2026-05-12T23:01:09Z"^^xsd:dateTime ;

  # OGL 3.0 License
  dcterms:license <http://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/> ;
  dcterms:rights "Crown Copyright"@en ;

  rdfs:seeAlso <https://w3id.org/uk/oak/curriculum/ontology> ;

  vann:preferredNamespacePrefix "natcurric" ;
  vann:preferredNamespaceUri "https://w3id.org/uk/oak/curriculum/nationalcurriculum/" ;

  owl:imports <https://w3id.org/uk/oak/curriculum/ontology> ;
  owl:imports <https://w3id.org/uk/oak/curriculum/nationalcurriculum/english-programme-structure> .

# ----------------------------------------------------------------------
# Knowledge Taxonomy
# ----------------------------------------------------------------------

natcurric:knowledge-taxonomy
  a skos:ConceptScheme ;
  skos:prefLabel "National Curriculum for England Knowledge Taxonomy"@en ;
  skos:hasTopConcept natcurric:discipline-english ;
  dcterms:modified "2026-05-12T23:01:09Z"^^xsd:dateTime .

# ----------------------------------------------------------------------
# Disciplines
# ----------------------------------------------------------------------

natcurric:discipline-english
  a skos:Concept, curric:Discipline ;
  skos:prefLabel "English"@en ;
  skos:topConceptOf natcurric:knowledge-taxonomy ;
  skos:narrower
    natcurric:strand-reading ,
    natcurric:strand-writing ,
    natcurric:strand-grammar-and-vocabulary ,
    natcurric:strand-spoken-english ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-05-12T23:01:09Z"^^xsd:dateTime .

# ----------------------------------------------------------------------
# Strands
# ----------------------------------------------------------------------

natcurric:strand-reading
  a skos:Concept, curric:Strand ;
  skos:prefLabel "Reading"@en ;
  skos:definition "Description of strand..."@en ;
  skos:broader natcurric:discipline-english ;
  skos:narrower
    natcurric:substrand-word-reading ,
    natcurric:substrand-comprehension ,
    natcurric:substrand-appreciation-and-love-of-reading ,
