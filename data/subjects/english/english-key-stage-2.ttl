    oakcurric:priorknowledge-764-5 ,
    oakcurric:priorknowledge-764-6 ,
    oakcurric:priorknowledge-764-7 ;
  curric:id "764"^^xsd:positiveInteger;
  dcterms:modified "2026-06-07T15:29:26.173829Z"^^xsd:dateTime ;
  curric:isUnitOf
    natcurric:scheme-english-key-stage-2 ;
  curric:includesThread
    oakcurric:thread-modern-literature-strand-1-identity-belonging-and-community ,
    oakcurric:thread-fiction-reading-spine .

oakcurric:unit-578
  a curric:Unit ;
  rdfs:label "'Curiosity: The Story of a Mars Rover': reading"@en ;
  curric:slug "curiosity-reading" ;
  rdfs:comment """In this unit, pupils read and explore the narrative non-fiction text, 'Curiosity:
  The Story of a Mars Rover'. They explore the context of Mars and the rover mission and
  answer a range of comprehension questions. Finally, pupils identify and engage with the
  key themes in the text."""@en ;
  curric:whyThisWhyNow """This unit uses and builds on the prior unit, 'Escape from Pompeii:
  reading', where pupils explored a historical fiction picturebook narrative. In this unit,
  pupils will read, discuss and explore a non-fiction picturebook narrative based on space
  exploration. Pupils will learn about Mars and the Curiosity rover mission by reading around
  the text and use this knowledge to engage effectively in the narrative. This unit prepares
  pupils for future unit, 'Shackleton's Journey: reading', where they will read, discuss and
  explore another non-fiction picturebook narrative based on real-life events.""" ;
  curric:hasPriorKnowledgeRequirement
    oakcurric:priorknowledge-578-1 ,
    oakcurric:priorknowledge-578-2 ,
    oakcurric:priorknowledge-578-3 ;
  curric:id "578"^^xsd:positiveInteger;
  dcterms:modified "2026-06-07T15:29:26.188978Z"^^xsd:dateTime ;
  curric:isUnitOf
    natcurric:scheme-english-key-stage-2 ;
  curric:includesThread
    oakcurric:thread-reading-and-writing-texts-that-inform .

oakcurric:unit-552
  a curric:Unit ;
  rdfs:label "'Mulan': reading"@en ;
  curric:slug "mulan-reading" ;
  rdfs:comment """In this unit, pupils read and explore the legend of 'Mulan'. They discuss folklore
  as a genre and build comprehension around the text. Finally, pupils will explore the key
  themes and the moral of the text."""@en ;
  curric:whyThisWhyNow """This unit uses and builds on pupils' understanding of traditional tales
  from other cultures, which was explored in the prior unit, 'The Children of Lir', where
  pupils read a traditional tale from Ireland. Pupils will practise their skills in retrieval
  and inference in order to develop their comprehension of the story. Pupils will develop a
  character profile for 'Mulan' and explore the key themes in the text. This unit prepares
  pupils for the future unit, 'Moon Dragons', where children will encounter a female
  protagonist who also has to defy authority and challenge female stereotypes.""" ;
  curric:hasPriorKnowledgeRequirement
    oakcurric:priorknowledge-552-1 ,
    oakcurric:priorknowledge-552-2 ,
    oakcurric:priorknowledge-552-3 ,
    oakcurric:priorknowledge-552-4 ,
