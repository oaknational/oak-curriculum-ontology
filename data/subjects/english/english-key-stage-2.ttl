  a curric:KeyLearningPoint ;
  rdfs:label """Editing is most successful when it is chunked by punctuation, sentence structure, vocabulary and cohesive devices."""@en ;
  dcterms:modified "2026-02-12T08:59:21.697537Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6354-5
  a curric:KeyLearningPoint ;
  rdfs:label "A growth mindset helps us benefit most from editing."@en ;
  dcterms:modified "2026-02-12T08:59:21.697544Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1102-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Gust' is a noun which means a blast of air or strong breeze."@en ;
  dcterms:modified "2026-02-12T08:59:21.697549Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1102-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Flurry' is a noun which means a short, swirling gust."@en ;
  dcterms:modified "2026-02-12T08:59:21.697554Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1102-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Blustery' is an adjective which means windy or blowing noisily."@en ;
  dcterms:modified "2026-02-12T08:59:21.697560Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1322-1
  a curric:KeyLearningPoint ;
  rdfs:label "Editing is the process of making changes to improve writing."@en ;
  dcterms:modified "2026-02-12T08:59:21.697876Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1322-2
  a curric:KeyLearningPoint ;
  rdfs:label """When editing punctuation, missing or incorrect punctuation, like capital letters, full stops and commas, is checked."""@en ;
  dcterms:modified "2026-02-12T08:59:21.697881Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1322-3
  a curric:KeyLearningPoint ;
  rdfs:label """When editing sentence structure, the flow of sentences and the variety of sentence types used are checked."""@en ;
  dcterms:modified "2026-02-12T08:59:21.697885Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1322-4
  a curric:KeyLearningPoint ;
  rdfs:label """When editing language, word and phrase choices are checked to ensure they meet the tone required."""@en ;
  dcterms:modified "2026-02-12T08:59:21.697890Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8030-1
  a curric:KeyLearningPoint ;
  rdfs:label """Reading Non-Fiction can develop knowledge of the world around you and the people that inhabit it"""@en ;
  dcterms:modified "2026-02-12T08:59:21.697922Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8030-2
  a curric:KeyLearningPoint ;
  rdfs:label """Reading about other people's lives and cultures can develop curiosity about the wider world"""@en ;
  dcterms:modified "2026-02-12T08:59:21.697926Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8030-3
  a curric:KeyLearningPoint ;
  rdfs:label "Non-Fiction reading can be presented in a variety of forms"@en ;
  dcterms:modified "2026-02-12T08:59:21.697930Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8030-4
  a curric:KeyLearningPoint ;
  rdfs:label """You can read texts that are based on true stories to learn about history and important events"""@en ;
  dcterms:modified "2026-02-12T08:59:21.697935Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8028-1
  a curric:KeyLearningPoint ;
  rdfs:label "Reading allows you to explore your emotions and understand yourself better"@en ;
  dcterms:modified "2026-02-12T08:59:21.697940Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8028-2
  a curric:KeyLearningPoint ;
  rdfs:label """Understanding a character's motivations can lead us to connecting with them on an emotional level"""@en ;
  dcterms:modified "2026-02-12T08:59:21.697944Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8028-3
  a curric:KeyLearningPoint ;
  rdfs:label "Favourite characters can be heroes or anti-heroes"@en ;
  dcterms:modified "2026-02-12T08:59:21.697949Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5758-1
  a curric:KeyLearningPoint ;
  rdfs:label "Presenting involves speaking in front of others and listening to others."@en ;
  dcterms:modified "2026-02-12T08:59:21.697953Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5758-2
  a curric:KeyLearningPoint ;
  rdfs:label """Presenting involves speaking with clear diction and suitable volume, making eye contact and using strong body language."""@en ;
  dcterms:modified "2026-02-12T08:59:21.697958Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5758-3
  a curric:KeyLearningPoint ;
  rdfs:label "Practising pronouncing tricky words helps develop clear diction when presenting."@en ;
  dcterms:modified "2026-02-12T08:59:21.697963Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5758-4
  a curric:KeyLearningPoint ;
  rdfs:label "Rehearsing helps the presenter to speak more confidently and fluently."@en ;
  dcterms:modified "2026-02-12T08:59:21.697967Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5758-5
  a curric:KeyLearningPoint ;
  rdfs:label "Pauses at the end of sentences can help the audience follow what is being said."@en ;
  dcterms:modified "2026-02-12T08:59:21.697972Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6105-1
  a curric:KeyLearningPoint ;
  rdfs:label """A conclusion is the final paragraph of a text and it gives general information about the subject."""@en ;
  dcterms:modified "2026-02-12T08:59:21.697977Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6105-2
  a curric:KeyLearningPoint ;
  rdfs:label """A conclusion still has a subheading and an introductory sentence and it uses a range of cohesive devices."""@en ;
  dcterms:modified "2026-02-12T08:59:21.697981Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6105-3
  a curric:KeyLearningPoint ;
  rdfs:label """Before we write, we should orally rehearse sentences to ensure our sentences make sense and flow well."""@en ;
  dcterms:modified "2026-02-12T08:59:21.697986Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6105-4
  a curric:KeyLearningPoint ;
  rdfs:label """When we have finished our first draft of our writing, we edit it to improve and refine it."""@en ;
  dcterms:modified "2026-02-12T08:59:21.697990Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6105-5
  a curric:KeyLearningPoint ;
  rdfs:label """Editing includes looking at sentence structures, vocabulary, cohesive devices, spelling and punctuation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.697997Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6348-1
  a curric:KeyLearningPoint ;
  rdfs:label """The introduction to a persuasive letter will primarily focus on summarising the purpose of the letter."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698002Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6348-2
  a curric:KeyLearningPoint ;
  rdfs:label "The introductory sentence will explain the purpose for the letter."@en ;
  dcterms:modified "2026-02-12T08:59:21.698008Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6348-3
  a curric:KeyLearningPoint ;
  rdfs:label "A short summary of the matter will follow, using a range of cohesive devices."@en ;
  dcterms:modified "2026-02-12T08:59:21.698013Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6348-4
  a curric:KeyLearningPoint ;
  rdfs:label """Flattery is used as a persuasive technique in the final sentence to suggest to the reader that we need their help."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698018Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8476-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the resolution is to resolve the problem encountered in the story and allow readers to reflect."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698022Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8476-2
  a curric:KeyLearningPoint ;
  rdfs:label """In the resolution, Hogarth leads the Iron Man to a metal scrapyard and he no longer needs the farmers' machinery."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698027Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8476-3
  a curric:KeyLearningPoint ;
  rdfs:label """In a resolution, exaggeration is often used to convey the positive emotions felt by characters."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698032Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8476-4
  a curric:KeyLearningPoint ;
  rdfs:label """Using a range of synonyms for simple verbs, adjectives and nouns supports exaggeration."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698036Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8476-5
  a curric:KeyLearningPoint ;
  rdfs:label "‘Show and tell’ language conveys the Iron Man’s emotions."@en ;
  dcterms:modified "2026-02-12T08:59:21.698040Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3452-1
  a curric:KeyLearningPoint ;
  rdfs:label """The simple, progressive and perfect tense can denote present, past or future action."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698045Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3452-2
  a curric:KeyLearningPoint ;
  rdfs:label """The progressive tense is a tense that makes use of an auxiliary verb from the infinitive 'to be' with the main verb."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698049Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3452-3
  a curric:KeyLearningPoint ;
  rdfs:label "The progressive tense denotes ongoing action."@en ;
  dcterms:modified "2026-02-12T08:59:21.698054Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3452-4
  a curric:KeyLearningPoint ;
  rdfs:label """The perfect tense is a tense that makes use of an auxiliary verb from the infinitive 'to have' with the main verb."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698058Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3452-5
  a curric:KeyLearningPoint ;
  rdfs:label "The perfect tense often refers to action that has finished."@en ;
  dcterms:modified "2026-02-12T08:59:21.698063Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5467-1
  a curric:KeyLearningPoint ;
  rdfs:label """'Anansi and the Antelope Baby' tells the story of how Anansi and Antelope help and protect one another."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698162Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5467-2
  a curric:KeyLearningPoint ;
  rdfs:label """Anansi demonstrates admirable character traits such as kindness, loyalty and integrity towards Antelope."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698167Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5467-3
  a curric:KeyLearningPoint ;
  rdfs:label "We use a range of strategies to build comprehension of a text."@en ;
  dcterms:modified "2026-02-12T08:59:21.698174Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5467-4
  a curric:KeyLearningPoint ;
  rdfs:label "Skimming and scanning can help us to retrieve key information."@en ;
  dcterms:modified "2026-02-12T08:59:21.698179Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5467-5
  a curric:KeyLearningPoint ;
  rdfs:label "We can use inference to draw conclusions about the text by searching for clues."@en ;
  dcterms:modified "2026-02-12T08:59:21.698183Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7914-1
  a curric:KeyLearningPoint ;
  rdfs:label """Being heroic is not reflected by a character's gender, age or other protected characteristic."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698188Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7914-2
  a curric:KeyLearningPoint ;
  rdfs:label "During a text, characters and their relationships change and evolve."@en ;
  dcterms:modified "2026-02-12T08:59:21.698199Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7914-3
  a curric:KeyLearningPoint ;
  rdfs:label """Making connections & recommendations can enhance the reading experience & widen a reader’s understanding of literature."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698207Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6103-1
  a curric:KeyLearningPoint ;
  rdfs:label """Information in a section becomes more specific and detailed as the section goes on."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698215Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6103-2
  a curric:KeyLearningPoint ;
  rdfs:label "Facts written in a section should be researched and organised prior to writing."@en ;
  dcterms:modified "2026-02-12T08:59:21.698224Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6103-3
  a curric:KeyLearningPoint ;
  rdfs:label "A range of cohesive devices helps us to link facts within and between sentences."@en ;
  dcterms:modified "2026-02-12T08:59:21.698229Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6103-4
  a curric:KeyLearningPoint ;
  rdfs:label """Before we write, we should orally rehearse sentences to ensure our sentences make sense and flow well."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698234Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6103-5
  a curric:KeyLearningPoint ;
  rdfs:label """Parenthesis, varied sentence types and a range of fronted adverbials are all cohesive devices that can be used."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698238Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8468-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘The Iron Man’ is a science fiction novel about a robotic giant named the Iron Man."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698243Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8468-2
  a curric:KeyLearningPoint ;
  rdfs:label """A narrative can be structured into four key sections: the opening, the build-up, the climax and the resolution."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698248Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8468-3
  a curric:KeyLearningPoint ;
  rdfs:label "Each part of a narrative has a specific purpose."@en ;
  dcterms:modified "2026-02-12T08:59:21.698252Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8468-4
  a curric:KeyLearningPoint ;
  rdfs:label """Sometimes with longer novels, stories might go through a few cycles of this structure."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698257Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8468-5
  a curric:KeyLearningPoint ;
  rdfs:label """You can use your voice, language choices and expression to retell a story effectively."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698261Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8475-1
  a curric:KeyLearningPoint ;
  rdfs:label """The climax takes the suspense to its highest point as the Iron Man resurfaces and humanity grapples with how to respond."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698266Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8475-2
  a curric:KeyLearningPoint ;
  rdfs:label """Precise and ambitious vocabulary, including ‘show and tell’, help take the suspense to its highest point in the climax."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698271Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8475-3
  a curric:KeyLearningPoint ;
  rdfs:label """Using a range of sentence types, including adverbial complex sentences, supports text flow."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698279Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8475-4
  a curric:KeyLearningPoint ;
  rdfs:label """Direct speech shows that a person is speaking out loud and the reporting clause tells us who said it and how."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698284Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8475-5
  a curric:KeyLearningPoint ;
  rdfs:label """Inverted commas are used to demarcate speech and a piece of punctuation separates speech from the reporting clause."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698288Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6747-1
  a curric:KeyLearningPoint ;
  rdfs:label """In this lesson, we are writing a third person flashback and a first person perspective."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698487Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6747-2
  a curric:KeyLearningPoint ;
  rdfs:label """Switching perspectives like this allows us to focus on different elements of the narrative at different points."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698492Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6747-3
  a curric:KeyLearningPoint ;
  rdfs:label "Our flashback is likely to be more formal than the first person section."@en ;
  dcterms:modified "2026-02-12T08:59:21.698496Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6747-4
  a curric:KeyLearningPoint ;
  rdfs:label "Both sections should include a range of sentence structures and punctuation."@en ;
  dcterms:modified "2026-02-12T08:59:21.698501Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6747-5
  a curric:KeyLearningPoint ;
  rdfs:label "Orally rehearsing our writing allows us to write more confidently."@en ;
  dcterms:modified "2026-02-12T08:59:21.698505Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6154-1
  a curric:KeyLearningPoint ;
  rdfs:label """A journalistic report contains factual statements mixed with different individuals' perspectives."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698510Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6154-2
  a curric:KeyLearningPoint ;
  rdfs:label """It has a formal tone and it is written in the third person, using both past and present tense."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698514Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6154-3
  a curric:KeyLearningPoint ;
  rdfs:label """When we give individuals' perspectives, we can use direct speech or reported speech."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698519Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6154-4
  a curric:KeyLearningPoint ;
  rdfs:label """Direct speech uses inverted commas to say the exact words a person said; reported speech does not."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698526Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6154-5
  a curric:KeyLearningPoint ;
  rdfs:label """A journalistic report contains a range of cohesive devices used to connect ideas together."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698530Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5624-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘Into the Forest’ is a narrative fiction text written and illustrated by the author Anthony Browne."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698535Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5624-2
  a curric:KeyLearningPoint ;
  rdfs:label """The story is about a little boy who goes on a journey through a forest to visit his grandma and find his dad."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698539Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5624-3
  a curric:KeyLearningPoint ;
  rdfs:label """On the journey through the forest, the boy encounters characters from familiar fairy tales."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698544Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5624-4
  a curric:KeyLearningPoint ;
  rdfs:label """The plot of a story is retold in chronological order using expression to convey greater meaning."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698548Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5624-5
  a curric:KeyLearningPoint ;
  rdfs:label """Summarising the key events in a story helps us to build our understanding of the text and the meaning behind it."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698553Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5497-1
  a curric:KeyLearningPoint ;
  rdfs:label "An apostrophe is an important punctuation mark with more than one purpose."@en ;
  dcterms:modified "2026-02-12T08:59:21.698557Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5497-2
  a curric:KeyLearningPoint ;
  rdfs:label """Speech sentences can be punctuated a variety of ways: speech first, speech second and speech interrupted."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698562Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5497-3
  a curric:KeyLearningPoint ;
  rdfs:label """When we avoid using apostrophes for contraction and use serious language, we can create a formal tone."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698566Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7654-1
  a curric:KeyLearningPoint ;
  rdfs:label "Notes from our plan are used to form full sentences."@en ;
  dcterms:modified "2026-02-12T08:59:21.698573Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7654-2
  a curric:KeyLearningPoint ;
  rdfs:label """A range of sentence types (simple, compound and complex) improves text flow for the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698578Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7654-3
  a curric:KeyLearningPoint ;
  rdfs:label """A relative complex sentence is formed of a main clause that can be interrupted by a relative clause."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698582Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7654-4
  a curric:KeyLearningPoint ;
  rdfs:label """Direct speech is punctuated using inverted commas. Dialogue moves the action forward."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698587Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7654-5
  a curric:KeyLearningPoint ;
  rdfs:label "Paragraphs are used to indicate the start of a new idea or key moment."@en ;
  dcterms:modified "2026-02-12T08:59:21.698591Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6744-1
  a curric:KeyLearningPoint ;
  rdfs:label "Writing is most successful when it is planned."@en ;
  dcterms:modified "2026-02-12T08:59:21.698643Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6744-2
  a curric:KeyLearningPoint ;
  rdfs:label """Writing can include a shift in perspective from first to third person and a change from present to past tense."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698648Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6744-3
  a curric:KeyLearningPoint ;
  rdfs:label "The first person allows the reader to hear Addie's direct thoughts and emotions."@en ;
  dcterms:modified "2026-02-12T08:59:21.698653Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6744-4
  a curric:KeyLearningPoint ;
  rdfs:label """We can also plan to include flashbacks that show past events in the third person."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698659Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6744-5
  a curric:KeyLearningPoint ;
  rdfs:label "These flashbacks might be 'triggered' by a certain action in the present."@en ;
  dcterms:modified "2026-02-12T08:59:21.698664Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7917-1
  a curric:KeyLearningPoint ;
  rdfs:label """Looking at interactions between characters can tell readers about their relationships."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698668Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7917-2
  a curric:KeyLearningPoint ;
  rdfs:label """Addie and her older sister, Keedie, are both autistic; they have both had different experiences of growing up autistic."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698681Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7917-3
  a curric:KeyLearningPoint ;
  rdfs:label "Authors give us lots of clues about relationships between characters."@en ;
  dcterms:modified "2026-02-12T08:59:21.698686Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7917-4
  a curric:KeyLearningPoint ;
  rdfs:label """We can adopt the perspectives of different characters to understand plot points more fully."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698690Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5489-1
  a curric:KeyLearningPoint ;
  rdfs:label "A theme is a big idea, topic or message that recurs within a story."@en ;
  dcterms:modified "2026-02-12T08:59:21.698695Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5489-2
  a curric:KeyLearningPoint ;
  rdfs:label """Themes can leave us with ideas and questions that we reflect on after reading the text."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698699Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5489-3
  a curric:KeyLearningPoint ;
  rdfs:label """The theme of remembrance is conveyed through Tranio and Livia’s return to the mountain in the resolution."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698704Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5489-4
  a curric:KeyLearningPoint ;
  rdfs:label "Fluent readers can process text swiftly and efficiently."@en ;
  dcterms:modified "2026-02-12T08:59:21.698708Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7897-1
  a curric:KeyLearningPoint ;
  rdfs:label "Inferring meaning can help us to build our understanding of the story."@en ;
  dcterms:modified "2026-02-12T08:59:21.698713Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7897-2
  a curric:KeyLearningPoint ;
  rdfs:label """A turning point in a narrative is a pivotal moment that significantly alters the course of the story."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698717Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7897-3
  a curric:KeyLearningPoint ;
  rdfs:label "Turning points can evoke a range of emotions in the character."@en ;
  dcterms:modified "2026-02-12T08:59:21.698722Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7897-4
  a curric:KeyLearningPoint ;
  rdfs:label "We can track a character’s emotions on an emotions graph."@en ;
  dcterms:modified "2026-02-12T08:59:21.698726Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7897-5
  a curric:KeyLearningPoint ;
  rdfs:label """The author creates a turning point in the story by having a cliffhanger where Oliver is potentially fatally wounded."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698731Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5491-1
  a curric:KeyLearningPoint ;
  rdfs:label "A simple sentence has one main clause."@en ;
  dcterms:modified "2026-02-12T08:59:21.698735Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5491-2
  a curric:KeyLearningPoint ;
  rdfs:label """There are four types of simple sentence: statement, question, command and exclamation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698739Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5491-3
  a curric:KeyLearningPoint ;
  rdfs:label """A compound sentence has at least two main clauses joined with a co-ordinating conjunction."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698744Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5491-4
  a curric:KeyLearningPoint ;
  rdfs:label """Accurate sentences start with capital letters and end with full stops, question marks or exclamation marks."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698751Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5491-5
  a curric:KeyLearningPoint ;
  rdfs:label """A comma is placed before the co-ordinating conjunctions 'but' and 'or' in a compound sentence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698755Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5493-1
  a curric:KeyLearningPoint ;
  rdfs:label "The verb carries the tense of a clause."@en ;
  dcterms:modified "2026-02-12T08:59:21.698760Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5493-2
  a curric:KeyLearningPoint ;
  rdfs:label """The simple tense does not make use of an auxiliary verb in addition to the main verb except in the future tense."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698764Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5493-3
  a curric:KeyLearningPoint ;
  rdfs:label """The progressive tense denotes ongoing action and uses auxiliary verbs based on 'to be'."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698771Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5493-4
  a curric:KeyLearningPoint ;
  rdfs:label """Standard English is often used in writing and uses different verb forms to non-Standard English."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698776Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8471-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the build-up is to build up suspense and excitement before the climax."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698782Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8471-2
  a curric:KeyLearningPoint ;
  rdfs:label "The build-up of 'The Iron Man' describes humanity’s response to the Iron Man."@en ;
  dcterms:modified "2026-02-12T08:59:21.698787Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8471-3
  a curric:KeyLearningPoint ;
  rdfs:label """When we plan, we log precise and ambitious vocabulary to help paint vivid pictures for our reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698792Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8471-4
  a curric:KeyLearningPoint ;
  rdfs:label "A plan includes notes, a sequence of events and ambitious vocabulary."@en ;
  dcterms:modified "2026-02-12T08:59:21.698796Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8471-5
  a curric:KeyLearningPoint ;
  rdfs:label """‘Show-and-tell’ language shows a character’s feelings by describing their actions, body language and facial expressions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698801Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7830-1
  a curric:KeyLearningPoint ;
  rdfs:label "The plot of a story is all the events that happen in it."@en ;
  dcterms:modified "2026-02-12T08:59:21.698846Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7830-2
  a curric:KeyLearningPoint ;
  rdfs:label "A narrative will have a beginning, build-up, climax and ending."@en ;
  dcterms:modified "2026-02-12T08:59:21.698851Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7830-3
  a curric:KeyLearningPoint ;
  rdfs:label """Turning points in a text mark the change in direction of the plot, which affect the story."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698855Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7830-4
  a curric:KeyLearningPoint ;
  rdfs:label "Babe forms a relationship with the sheep."@en ;
  dcterms:modified "2026-02-12T08:59:21.698860Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7830-5
  a curric:KeyLearningPoint ;
  rdfs:label "Babe sucessfully herds the sheep and impresses Farmer Hogget and Fly."@en ;
  dcterms:modified "2026-02-12T08:59:21.698864Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6763-1
  a curric:KeyLearningPoint ;
  rdfs:label "Writing is most successful when structure, content and vocabulary is planned."@en ;
  dcterms:modified "2026-02-12T08:59:21.698990Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6763-2
  a curric:KeyLearningPoint ;
  rdfs:label "Information in this section should be specific and detailed."@en ;
  dcterms:modified "2026-02-12T08:59:21.698994Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6763-3
  a curric:KeyLearningPoint ;
  rdfs:label "Cohesion, making use of research and a formal tone are appropriate in an essay."@en ;
  dcterms:modified "2026-02-12T08:59:21.698999Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6763-4
  a curric:KeyLearningPoint ;
  rdfs:label """An essay can use a bank of research, evidence, statistics and quotes to inform the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699003Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7906-1
  a curric:KeyLearningPoint ;
  rdfs:label """When drawing comparisons to other texts, readers can look for connections in themes, events or characters."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699008Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7906-2
  a curric:KeyLearningPoint ;
  rdfs:label """‘Blackberry Blue’ shares lots of similarities with fairy and folk tales, especially ‘Cinderella’."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699014Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7906-3
  a curric:KeyLearningPoint ;
  rdfs:label "A theme is a big idea, topic or message that recurs within a story."@en ;
  dcterms:modified "2026-02-12T08:59:21.699019Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7906-4
  a curric:KeyLearningPoint ;
  rdfs:label """Some themes are more complex, they can impart important morals or lessons, regardless of when the text was written."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699023Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6112-1
  a curric:KeyLearningPoint ;
  rdfs:label "Information can be gathered from a range of different sources."@en ;
  dcterms:modified "2026-02-12T08:59:21.699028Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6112-2
  a curric:KeyLearningPoint ;
  rdfs:label "Credibility of each source must be determined."@en ;
  dcterms:modified "2026-02-12T08:59:21.699032Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6112-3
  a curric:KeyLearningPoint ;
  rdfs:label "Origin of a source must be cited."@en ;
  dcterms:modified "2026-02-12T08:59:21.699037Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6112-4
  a curric:KeyLearningPoint ;
  rdfs:label """Established facts and relevant evidence can be used to strengthen the writer's position on a subject."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699041Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6112-5
  a curric:KeyLearningPoint ;
  rdfs:label "Relevant statistics can enhance the evidence cited."@en ;
  dcterms:modified "2026-02-12T08:59:21.699046Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9042-1
  a curric:KeyLearningPoint ;
  rdfs:label """Different genres of writing make use of different plot and character conventions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699050Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9042-2
  a curric:KeyLearningPoint ;
  rdfs:label """In detective fiction, common character conventions include 'the brilliant detective' and 'the faithful sidekick'."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699055Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9042-3
  a curric:KeyLearningPoint ;
  rdfs:label """In detective fiction, common plot conventions include 'the red herring' and 'the big reveal'."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699059Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9042-4
  a curric:KeyLearningPoint ;
  rdfs:label """These conventions are not rules: authors constantly subvert and play with them to entertain the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699063Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9042-5
  a curric:KeyLearningPoint ;
  rdfs:label """In detective fiction, the reader is trying to solve the mystery too so the author plans the plot carefully."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699068Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7651-1
  a curric:KeyLearningPoint ;
  rdfs:label """Direct speech is punctuated using inverted commas. Dialogue moves the action forward."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699072Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7651-2
  a curric:KeyLearningPoint ;
  rdfs:label "Notes from a plan are used to form full sentences."@en ;
  dcterms:modified "2026-02-12T08:59:21.699077Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7651-3
  a curric:KeyLearningPoint ;
  rdfs:label """A range of sentence types (simple, compound and complex) improves text flow for the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699083Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7651-4
  a curric:KeyLearningPoint ;
  rdfs:label """A relative complex sentence is formed of a main clause that is interrupted by a relative clause."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699088Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7651-5
  a curric:KeyLearningPoint ;
  rdfs:label "Singular possession is shown by use of an apostrophe."@en ;
  dcterms:modified "2026-02-12T08:59:21.699092Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8876-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘The Iron Man’ is a contemporary science fiction novel written by the author Ted Hughes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699099Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8876-2
  a curric:KeyLearningPoint ;
  rdfs:label """Science fiction is a genre of fiction that involves imaginative & futuristic concepts linked to science and technology."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699104Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8876-3
  a curric:KeyLearningPoint ;
  rdfs:label """The opening chapter introduces a mysterious robot named the Iron Man as the protagonist."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699108Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8876-4
  a curric:KeyLearningPoint ;
  rdfs:label """Ted Hughes creates a mysterious atmosphere in the opening chapter, which leaves the reader with many questions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699113Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8876-5
  a curric:KeyLearningPoint ;
  rdfs:label """A variety of linguistic techniques are used to create vivid imagery and convey a mysterious atmosphere."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699117Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3400-1
  a curric:KeyLearningPoint ;
  rdfs:label "An introduction's purpose is to give general facts to the reader."@en ;
  dcterms:modified "2026-02-12T08:59:21.699222Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3400-2
  a curric:KeyLearningPoint ;
  rdfs:label """The introduction gives general facts about the time period and origins of the Anglo-Saxons."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699226Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3400-3
  a curric:KeyLearningPoint ;
  rdfs:label """The introduction tells the reader what they will learn in the rest of the report."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699231Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5663-1
  a curric:KeyLearningPoint ;
  rdfs:label "In Chapter 4, Grendel comes to Heorot and kills Leofric."@en ;
  dcterms:modified "2026-02-12T08:59:21.699236Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5663-2
  a curric:KeyLearningPoint ;
  rdfs:label """Beowulf attacks and he snaps off Grendel's arm, which makes the Geats think that Grendel must then die."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699240Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5663-3
  a curric:KeyLearningPoint ;
  rdfs:label """Beowulf and the Geats are rewarded by King Hrothgar for ridding the Danes of Grendel."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699245Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5663-4
  a curric:KeyLearningPoint ;
  rdfs:label """Authors describe and develop characters' traits through their actions, dialogue and interactions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699249Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5663-5
  a curric:KeyLearningPoint ;
  rdfs:label """This process of character development is called characterisation and we can find evidence of it in texts."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699254Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5753-1
  a curric:KeyLearningPoint ;
  rdfs:label "A subheading signals to the reader what the section is about."@en ;
  dcterms:modified "2026-02-12T08:59:21.699280Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5753-2
  a curric:KeyLearningPoint ;
  rdfs:label """A section about one feature of the report's subject contains specific facts and information to keep the reader engaged."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699284Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5753-3
  a curric:KeyLearningPoint ;
  rdfs:label """Using the full range of sentence types (simple, compound and complex) improves text flow for the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699288Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5753-4
  a curric:KeyLearningPoint ;
  rdfs:label """Sentences should be said aloud before writing to ensure they make sense and read back once written to check for errors."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699295Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5753-5
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials of cause and formal fronted adverbials are used at the start of sentences for cohesion."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699300Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6519-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of an essay can be to present a coherent argument in response to a question."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699350Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6519-2
  a curric:KeyLearningPoint ;
  rdfs:label """To meet its purpose effectively, the tone of an essay must be formal and informative."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699354Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6519-3
  a curric:KeyLearningPoint ;
  rdfs:label """Using correct linguistic features of an essay enables writers to meet the text's purpose."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699361Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6522-1
  a curric:KeyLearningPoint ;
  rdfs:label "Writing is most successful when structure, content and vocabulary is planned."@en ;
  dcterms:modified "2026-02-12T08:59:21.699366Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6522-2
  a curric:KeyLearningPoint ;
  rdfs:label "Information in this section should be specific and detailed."@en ;
  dcterms:modified "2026-02-12T08:59:21.699371Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6522-3
  a curric:KeyLearningPoint ;
  rdfs:label "Cohesion, making use of research and a formal tone are appropriate in an essay."@en ;
  dcterms:modified "2026-02-12T08:59:21.699375Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6522-4
  a curric:KeyLearningPoint ;
  rdfs:label """An essay can use a bank of research, evidence, statistics and quotes to inform the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699380Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7652-1
  a curric:KeyLearningPoint ;
  rdfs:label """When we plan, we log precise and ambitious vocabulary to help paint vivid pictures for our reader with words."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699385Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7652-2
  a curric:KeyLearningPoint ;
  rdfs:label """Dialogue is the written conversation between two characters or more within a narrative and it moves the story forward."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699391Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7652-3
  a curric:KeyLearningPoint ;
  rdfs:label "A plan is written in note-form, out of full sentences."@en ;
  dcterms:modified "2026-02-12T08:59:21.699398Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7652-4
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the climax is to describe the main action and to take the tension and excitement to its highest point."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699403Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7652-5
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the resolution is to resolve a story, tying up its 'loose ends', allowing readers a chance to reflect."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699407Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7649-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the opening is to engage the reader and introduce the setting and characters."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699412Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7649-2
  a curric:KeyLearningPoint ;
  rdfs:label """Using a range of sentence types (simple, compound and complex) improves text flow for the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699416Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7649-3
  a curric:KeyLearningPoint ;
  rdfs:label """Direct speech is punctuated using inverted commas. Dialogue moves the action forward."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699421Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7649-4
  a curric:KeyLearningPoint ;
  rdfs:label """An adverbial clause is joined with a main clause to form an adverbial complex sentence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699425Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7649-5
  a curric:KeyLearningPoint ;
  rdfs:label "Notes from the plan are used to form full sentences."@en ;
  dcterms:modified "2026-02-12T08:59:21.699430Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7658-1
  a curric:KeyLearningPoint ;
  rdfs:label """When exploring a character’s point of view, we experience life as if through their eyes; this is called perspective."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699435Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7658-2
  a curric:KeyLearningPoint ;
  rdfs:label "Paikea feels a deep spiritual and ancestral connection to her Maori heritage."@en ;
  dcterms:modified "2026-02-12T08:59:21.699439Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7658-3
  a curric:KeyLearningPoint ;
  rdfs:label """Despite Koro's disapproval, Paikea is determined to prove herself worthy of carrying on the leadership of her tribe."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699444Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7658-4
  a curric:KeyLearningPoint ;
  rdfs:label "Koro is deeply entrenched in the traditional beliefs and customs of the tribe."@en ;
  dcterms:modified "2026-02-12T08:59:21.699453Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7658-5
  a curric:KeyLearningPoint ;
  rdfs:label """Koro sees her desire to lead as a challenge and he dismisses her abilities based on her gender."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699457Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4803-1
  a curric:KeyLearningPoint ;
  rdfs:label "The letters all have a lead in and a lead out."@en ;
  dcterms:modified "2026-02-12T08:59:21.699582Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4803-2
  a curric:KeyLearningPoint ;
  rdfs:label "The fourth join goes from the x-height line up towards the ascender line."@en ;
  dcterms:modified "2026-02-12T08:59:21.699587Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4803-3
  a curric:KeyLearningPoint ;
  rdfs:label """When joining to the letter t, the join reaches to between the x-height line and the ascender line."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699592Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4803-4
  a curric:KeyLearningPoint ;
  rdfs:label "The pencil does not lift when forming the join."@en ;
  dcterms:modified "2026-02-12T08:59:21.699599Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4803-5
  a curric:KeyLearningPoint ;
  rdfs:label """When forming the letter f, it has two loops: at the top of the lead in and at the bottom ready for the lead out."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699606Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4802-1
  a curric:KeyLearningPoint ;
  rdfs:label "The letters all have a lead in and a lead out."@en ;
  dcterms:modified "2026-02-12T08:59:21.699639Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4802-2
  a curric:KeyLearningPoint ;
  rdfs:label """The third join starts at the x-height line and dips below the x-height line and back up to join the next letter."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699645Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4802-3
  a curric:KeyLearningPoint ;
  rdfs:label "When joining from a \"w\" or an \"o\", remember the small 'dip down' to aid joining."@en ;
  dcterms:modified "2026-02-12T08:59:21.699649Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4802-4
  a curric:KeyLearningPoint ;
  rdfs:label "The pencil does not lift when forming the join."@en ;
  dcterms:modified "2026-02-12T08:59:21.699656Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4802-5
  a curric:KeyLearningPoint ;
  rdfs:label """When using the third join you leave enough space to ensure the letters are not touching without leaving a big gap."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699661Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5757-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of a conclusion is to summarise the information of the text for the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699665Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5757-2
  a curric:KeyLearningPoint ;
  rdfs:label """A summary sentence is one sentence that summarises key information from the text."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699672Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5757-3
  a curric:KeyLearningPoint ;
  rdfs:label "A conclusion can begin with a formal fronted adverbial."@en ;
  dcterms:modified "2026-02-12T08:59:21.699677Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5757-4
  a curric:KeyLearningPoint ;
  rdfs:label """The conclusion is an opportunity for the reader to reflect upon their own actions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699682Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5757-5
  a curric:KeyLearningPoint ;
  rdfs:label """A conclusion can finish with the writer advising the reader to do further research about the topic."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699686Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6190-1
  a curric:KeyLearningPoint ;
  rdfs:label "Because an essay is a non-fiction piece of writing, it must be based on facts."@en ;
  dcterms:modified "2026-02-12T08:59:21.699691Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6190-2
  a curric:KeyLearningPoint ;
  rdfs:label "Facts are obtained through research, using reliable sources."@en ;
  dcterms:modified "2026-02-12T08:59:21.699695Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6190-3
  a curric:KeyLearningPoint ;
  rdfs:label "Research can be collated using bullet points under different headings."@en ;
  dcterms:modified "2026-02-12T08:59:21.699700Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6190-4
  a curric:KeyLearningPoint ;
  rdfs:label """We can break an essay question down into smaller questions in order to structure our essay."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699704Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6190-5
  a curric:KeyLearningPoint ;
  rdfs:label """These smaller questions create the flow of a logical argument that leads towards a conclusion."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699708Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8641-1
  a curric:KeyLearningPoint ;
  rdfs:label """In this section of the build-up, Arrietty explores the outside world and enjoys freedom and nature."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699713Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8641-2
  a curric:KeyLearningPoint ;
  rdfs:label "The atmosphere shifts when Arrietty spots the eye of a human “bean”."@en ;
  dcterms:modified "2026-02-12T08:59:21.699718Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8641-3
  a curric:KeyLearningPoint ;
  rdfs:label """Arrietty forms a friendship with the human “bean” this eye belongs to whose name is “Boy”."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699723Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8641-4
  a curric:KeyLearningPoint ;
  rdfs:label """The atmosphere and Arrietty’s emotions change over the course of her experiences."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699727Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8641-5
  a curric:KeyLearningPoint ;
  rdfs:label """We can make inferences about a character’s emotions by analysing their actions, words and expressions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699732Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8472-1
  a curric:KeyLearningPoint ;
  rdfs:label """In part one of the build-up, Hogarth encounters the Iron Man and tells his father, who goes out in search of the giant."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699739Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8472-2
  a curric:KeyLearningPoint ;
  rdfs:label """The use of precise and ambitious vocabulary, including ‘show and tell’ language supports the building of suspense."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699746Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8472-3
  a curric:KeyLearningPoint ;
  rdfs:label """Using a range of sentence types, including adverbial complex sentences, supports text flow."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699751Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8472-4
  a curric:KeyLearningPoint ;
  rdfs:label "An adverbial clause begins with a subordinating conjunction."@en ;
  dcterms:modified "2026-02-12T08:59:21.699755Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8472-5
  a curric:KeyLearningPoint ;
  rdfs:label """An adverbial clause is joined with a main clause to form an adverbial complex sentence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699760Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2742-1
  a curric:KeyLearningPoint ;
  rdfs:label "The verb carries the tense of a sentence."@en ;
  dcterms:modified "2026-02-12T08:59:21.699764Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2742-2
  a curric:KeyLearningPoint ;
  rdfs:label "A modal verb is a type of auxiliary verb."@en ;
  dcterms:modified "2026-02-12T08:59:21.699769Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2742-3
  a curric:KeyLearningPoint ;
  rdfs:label "A modal verb is most often paired with the main verb of a clause."@en ;
  dcterms:modified "2026-02-12T08:59:21.699773Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2742-4
  a curric:KeyLearningPoint ;
  rdfs:label "A modal verb is not paired with the main verb if it appears in a question."@en ;
  dcterms:modified "2026-02-12T08:59:21.699778Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2742-5
  a curric:KeyLearningPoint ;
  rdfs:label """A modal verb expresses the degree of possibility, intent, ability or necessity of the clause."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699783Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6104-1
  a curric:KeyLearningPoint ;
  rdfs:label """Information in a section becomes more specific and detailed as the section goes on."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699939Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6104-2
  a curric:KeyLearningPoint ;
  rdfs:label "Facts written in a section should be researched and organised prior to writing."@en ;
  dcterms:modified "2026-02-12T08:59:21.699946Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6104-3
  a curric:KeyLearningPoint ;
  rdfs:label "A range of cohesive devices helps us to link facts within and between sentences."@en ;
  dcterms:modified "2026-02-12T08:59:21.699951Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6104-4
  a curric:KeyLearningPoint ;
  rdfs:label """Before we write, we should orally rehearse sentences to ensure our sentences make sense and flow well."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699955Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6104-5
  a curric:KeyLearningPoint ;
  rdfs:label """Parenthesis, varied sentence types and a range of fronted adverbials are all cohesive devices that can be used."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699960Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6114-1
  a curric:KeyLearningPoint ;
  rdfs:label """A non-chronological report is written to inform the reader about a subject or event out of time order."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699964Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6114-2
  a curric:KeyLearningPoint ;
  rdfs:label """The introduction of a non-chronological report summarises the general information about the subject."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699969Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6114-3
  a curric:KeyLearningPoint ;
  rdfs:label "Within the introduction, text that flows well and cohesively is important."@en ;
  dcterms:modified "2026-02-12T08:59:21.699973Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6114-4
  a curric:KeyLearningPoint ;
  rdfs:label "Text cohesion can be achieved by using a range of cohesive devices."@en ;
  dcterms:modified "2026-02-12T08:59:21.699978Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6114-5
  a curric:KeyLearningPoint ;
  rdfs:label """We can use compound sentences, complex sentences, fronted adverbials and parenthesis as cohesive devices."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699982Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5456-1
  a curric:KeyLearningPoint ;
  rdfs:label "The protagonist is a main character or central figure in a story or narrative."@en ;
  dcterms:modified "2026-02-12T08:59:21.699987Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5456-2
  a curric:KeyLearningPoint ;
  rdfs:label "Alina is the protagonist in 'The Moon Dragons'."@en ;
  dcterms:modified "2026-02-12T08:59:21.699991Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5456-3
  a curric:KeyLearningPoint ;
  rdfs:label """Character traits are the special qualities that make a character in a story unique and interesting."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699996Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5456-4
  a curric:KeyLearningPoint ;
  rdfs:label """We can identify Alina's character traits by exploring her experiences and interactions and making inferences."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700000Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5456-5
  a curric:KeyLearningPoint ;
  rdfs:label """Alina displays a range of character traits such as resilience, bravery, and morality."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700007Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1060-1
  a curric:KeyLearningPoint ;
  rdfs:label """A non-chronological report is a non-fiction text that provides information about a particular subject."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700012Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1060-2
  a curric:KeyLearningPoint ;
  rdfs:label """Vocabulary within an explanation text is subject-specific and factual, creating a formal tone."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700016Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1060-3
  a curric:KeyLearningPoint ;
  rdfs:label """Viewpoint fronted adverbials are a type of sentece starter and they show the writer's point of view."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700021Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1060-4
  a curric:KeyLearningPoint ;
  rdfs:label "Formal 'but' fronted adverbials contrast a point made in the previous sentence."@en ;
  dcterms:modified "2026-02-12T08:59:21.700025Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1060-5
  a curric:KeyLearningPoint ;
  rdfs:label "Formal 'and' fronted adverbials build on a point made in the previous sentence."@en ;
  dcterms:modified "2026-02-12T08:59:21.700030Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7662-1
  a curric:KeyLearningPoint ;
  rdfs:label "Ambitious vocabulary can be logged on a plan for future use."@en ;
  dcterms:modified "2026-02-12T08:59:21.700034Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7662-2
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials of time, place and manner indicate when, where and how action takes place."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700041Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7662-3
  a curric:KeyLearningPoint ;
  rdfs:label """Dialogue, using direct speech, moves the plot forward and develops characters in a story."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700046Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7662-4
  a curric:KeyLearningPoint ;
  rdfs:label """Show-not-tell language shows a character’s feelings by describing their actions, body language and facial expressions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700053Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7662-5
  a curric:KeyLearningPoint ;
  rdfs:label """Notes should not be written in full sentences and bullet points can be used to make notes clear."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700058Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7924-1
  a curric:KeyLearningPoint ;
  rdfs:label """In the final stages of the book, we see Joseph saved by Adonis before Adonis is shot dead."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700063Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7924-2
  a curric:KeyLearningPoint ;
  rdfs:label """We also see Joseph and Mrs F united in their grief with Joseph finally learning to trust her."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700068Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7924-3
  a curric:KeyLearningPoint ;
  rdfs:label """We can connect books we read to abstract concepts; we can connect this book to our understanding of 'compassion'."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700072Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7924-4
  a curric:KeyLearningPoint ;
  rdfs:label """We can also identify themes that run through the book - for example, the idea that people are capable of change."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700077Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1324-1
  a curric:KeyLearningPoint ;
  rdfs:label """Two or more words that are spelt the same but have different meanings are called homonyms."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700808Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1324-2
  a curric:KeyLearningPoint ;
  rdfs:label """Some homonyms are spelt the same, but have contrasting sounds and different meanings (e.g. tear, wind, wound or read)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700813Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1324-3
  a curric:KeyLearningPoint ;
  rdfs:label "The meaning and word class of homonyms can be determined by their context."@en ;
  dcterms:modified "2026-02-12T08:59:21.700818Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1324-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: community and leisure."@en ;
  dcterms:modified "2026-02-12T08:59:21.700825Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5772-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the main body is to describe events, thoughts and feelings in detail."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700830Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5772-2
  a curric:KeyLearningPoint ;
  rdfs:label "Sentences can be opened in a variety of ways to enhance text cohesion."@en ;
  dcterms:modified "2026-02-12T08:59:21.700835Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5772-3
  a curric:KeyLearningPoint ;
  rdfs:label """Adverbial complex sentences consist of a main clause and an adverbial subordinate clause."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700839Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5772-4
  a curric:KeyLearningPoint ;
  rdfs:label "Informal tone can be achieved through use of contractions and exclamations."@en ;
  dcterms:modified "2026-02-12T08:59:21.700844Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27780-1
  a curric:KeyLearningPoint ;
  rdfs:label """Michelle Obama is an American lawyer and author who served as the First Lady of the United States from 2009 to 2017."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700848Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27780-2
  a curric:KeyLearningPoint ;
  rdfs:label """Successful public speaking includes speaking loudly and clearly and engaging the audience."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700853Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27780-3
  a curric:KeyLearningPoint ;
  rdfs:label "A speech is written for a specific audience in order to achieve its purpose."@en ;
  dcterms:modified "2026-02-12T08:59:21.700857Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27780-4
  a curric:KeyLearningPoint ;
  rdfs:label """A speaker can engage an audience through a variety of techniques, including rhetorical questions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700862Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8025-1
  a curric:KeyLearningPoint ;
  rdfs:label """Free verse poems do not require the poet to follow poetic rules, but tend to follow the rhythm of natural speech."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700972Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8025-2
  a curric:KeyLearningPoint ;
  rdfs:label """Free verse poems may include a range of poetic techniques such as: alliteration, kennings and rhyme."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700976Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8025-3
  a curric:KeyLearningPoint ;
  rdfs:label "Verse refers to a single line or a group of lines within a poem."@en ;
  dcterms:modified "2026-02-12T08:59:21.700980Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8025-4
  a curric:KeyLearningPoint ;
  rdfs:label """Rhyme in poetry is the similarity of sounds between the ending syllables of words."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700985Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8025-5
  a curric:KeyLearningPoint ;
  rdfs:label """Poems can evoke a positive or negative emotion and a poet must carefully consider what atmosphere they wish to create."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700989Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28412-1
  a curric:KeyLearningPoint ;
  rdfs:label "To improvise means to make something up on the spot and in the moment."@en ;
  dcterms:modified "2026-02-12T08:59:21.701012Z"^^xsd:dateTime .

