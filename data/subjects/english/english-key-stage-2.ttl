    oakcurric:priorknowledge-640-10 ;
  curric:id "640"^^xsd:positiveInteger;
  dcterms:modified "2026-06-07T15:29:24.289747Z"^^xsd:dateTime ;
  curric:isUnitOf
    natcurric:scheme-english-key-stage-2 ;
  curric:includesThread
    oakcurric:thread-reading-and-writing-texts-that-inform .

oakcurric:unit-131
  a curric:Unit ;
  rdfs:label "Noun suffixes, letter strings and homophones"@en ;
  curric:slug "noun-suffixes-letter-strings-and-homophones" ;
  rdfs:comment """In this unit, pupils learn spelling and grammar conventions associated with more
  noun suffixes like -ant, -ance, -ancy, -ent, -ence and -ency, reviewing how the addition
  of a suffix can affect the grammar of a word, for example its word class. Pupils
  investigate letter strings and homophones."""@en ;
  curric:whyThisWhyNow """This unit uses and builds on pupils' knowledge of spelling and grammar
  conventions associated with noun suffixes learnt in the Year 5 unit, 'Year 5: Verb, adjective
  and noun suffixes'. Here, pupils learn more noun suffixes, like -ant, -ance, -ancy, -ent,
  -ence and -ency, reviewing how the addition of a suffix can affect the grammar of a word, in
  these examples by changing its word class. Pupils also investigate letter strings and
  homophones. This unit prepares pupils for further word class work in the Year 5 unit 'Year 5:
  Etymology and prefixes'.""" ;
  curric:hasPriorKnowledgeRequirement
    oakcurric:priorknowledge-131-1 ,
    oakcurric:priorknowledge-131-2 ,
