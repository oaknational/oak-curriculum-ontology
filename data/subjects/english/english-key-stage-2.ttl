    oakcurric:priorknowledge-704-10 ;
  curric:id "704"^^xsd:positiveInteger;
  dcterms:modified "2026-06-07T15:29:25.145841Z"^^xsd:dateTime ;
  curric:isUnitOf
    natcurric:scheme-english-key-stage-2 ;
