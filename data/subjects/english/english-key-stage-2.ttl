# ----------------------------------------------------------------------
# Keywords
# ----------------------------------------------------------------------

oakcurric:keyword-stereotype
  a curric:Keyword ;
  schema:name "stereotype"@en ;
  schema:description "a simplified belief, view or representation of a group of people"@en ;
  dcterms:modified "2026-02-12T08:59:15.789366Z"^^xsd:dateTime .

oakcurric:keyword-theme
  a curric:Keyword ;
  schema:name "theme"@en ;
  schema:description """an important idea or thread in a text that is explored in a number of different ways"""@en ;
  dcterms:modified "2026-02-12T08:59:15.789391Z"^^xsd:dateTime .

oakcurric:keyword-welfare-state
  a curric:Keyword ;
  schema:name "welfare state"@en ;
  schema:description """a system in which the government accepts responsibility for protecting people's quality of life"""@en ;
  dcterms:modified "2026-02-12T08:59:15.789396Z"^^xsd:dateTime .

oakcurric:keyword-alliteration
  a curric:Keyword ;
  schema:name "alliteration"@en ;
  schema:description "when two or more words start with the same consonant"@en ;
  dcterms:modified "2026-02-12T08:59:15.789414Z"^^xsd:dateTime .

oakcurric:keyword-onomatopoeia
  a curric:Keyword ;
  schema:name "onomatopoeia"@en ;
  schema:description "words which sound like the noise they describe e.g. crash"@en ;
  dcterms:modified "2026-02-12T08:59:15.789423Z"^^xsd:dateTime .

oakcurric:keyword-commonwealth
  a curric:Keyword ;
  schema:name "Commonwealth"@en ;
  schema:description """an international organisation consisting of states which once belonged to the British Empire"""@en ;
  dcterms:modified "2026-02-12T08:59:15.789500Z"^^xsd:dateTime .

oakcurric:keyword-slogan
  a curric:Keyword ;
  schema:name "slogan"@en ;
  schema:description """a slogan is a memorable phrase used by a person, group, or company to convey a message or idea"""@en ;
  dcterms:modified "2026-02-12T08:59:15.789554Z"^^xsd:dateTime .

oakcurric:keyword-rhythm
  a curric:Keyword ;
  schema:name "rhythm"@en ;
  schema:description "the beat, flow, or pattern of a piece of music or writing."@en ;
  dcterms:modified "2026-02-12T08:59:15.789567Z"^^xsd:dateTime .

oakcurric:keyword-subordinate-clause
  a curric:Keyword ;
  schema:name "subordinate clause"@en ;
  schema:description "a clause of a sentence which doesn’t make sense by itself."@en ;
  dcterms:modified "2026-02-12T08:59:15.789581Z"^^xsd:dateTime .

oakcurric:keyword-complex-sentence
  a curric:Keyword ;
  schema:name "complex sentence"@en ;
  schema:description """a sentence made up of a main clause (a sentence which makes sense by itself) and a subordinate clause."""@en ;
  dcterms:modified "2026-02-12T08:59:15.789585Z"^^xsd:dateTime .

oakcurric:keyword-simple-sentence
  a curric:Keyword ;
  schema:name "simple sentence"@en ;
  schema:description "a sentence about one idea that makes complete sense"@en ;
  dcterms:modified "2026-02-12T08:59:15.789590Z"^^xsd:dateTime .

oakcurric:keyword-past-tense
  a curric:Keyword ;
  schema:name "past tense"@en ;
  schema:description "tells the reader the action happened before now"@en ;
  dcterms:modified "2026-02-12T08:59:15.789594Z"^^xsd:dateTime .

oakcurric:keyword-fronted-adverbial-of-time
  a curric:Keyword ;
  schema:name "fronted adverbial of time"@en ;
  schema:description "a sentence starter that tells the reader when something happens"@en ;
  dcterms:modified "2026-02-12T08:59:15.789599Z"^^xsd:dateTime .

oakcurric:keyword-comma
  a curric:Keyword ;
  schema:name "comma"@en ;
  schema:description "a punctuation mark used after a fronted adverbial of time"@en ;
  dcterms:modified "2026-02-12T08:59:15.789603Z"^^xsd:dateTime .

oakcurric:keyword-migration
  a curric:Keyword ;
  schema:name "migration"@en ;
  schema:description """the movement of people from one place to another, either within a country or between countries, often for economic, social, political or environmental reasons"""@en ;
  dcterms:modified "2026-02-12T08:59:15.789717Z"^^xsd:dateTime .

oakcurric:keyword-form
  a curric:Keyword ;
  schema:name "form"@en ;
  schema:description "in writing, this refers to the structure, format or genre of a text"@en ;
  dcterms:modified "2026-02-12T08:59:15.789782Z"^^xsd:dateTime .

oakcurric:keyword-first-person
  a curric:Keyword ;
  schema:name "first person"@en ;
  schema:description """a point of view in writing where the narrator refers to themselves using pronouns like 'I' or 'we'"""@en ;
  dcterms:modified "2026-02-12T08:59:15.789797Z"^^xsd:dateTime .

oakcurric:keyword-direct-address
  a curric:Keyword ;
  schema:name "Direct address"@en ;
  schema:description "where a speaker talks directly to the audience"@en ;
  dcterms:modified "2026-02-12T08:59:15.789828Z"^^xsd:dateTime .

oakcurric:keyword-flashback
  a curric:Keyword ;
  schema:name "Flashback"@en ;
  schema:description "a scene that is set earlier than the main story"@en ;
  dcterms:modified "2026-02-12T08:59:15.789832Z"^^xsd:dateTime .

oakcurric:keyword-dialogue
  a curric:Keyword ;
  schema:name "Dialogue"@en ;
  schema:description "conversation and spoken interactions written for a play, book or film"@en ;
  dcterms:modified "2026-02-12T08:59:15.789846Z"^^xsd:dateTime .

oakcurric:keyword-dialect
  a curric:Keyword ;
  schema:name "Dialect"@en ;
  schema:description """a variation of a language spoken in a particular part of the country or by a particular group"""@en ;
  dcterms:modified "2026-02-12T08:59:15.789850Z"^^xsd:dateTime .

oakcurric:keyword-advocate
  a curric:Keyword ;
  schema:name "advocate"@en ;
  schema:description "to support or argue in favor of something or someone"@en ;
  dcterms:modified "2026-02-12T08:59:15.789986Z"^^xsd:dateTime .

oakcurric:keyword-refugee
  a curric:Keyword ;
  schema:name "refugee"@en ;
  schema:description """a refugee is a person who has been forced to leave their country in order to escape war, persecution or natural disaster"""@en ;
  dcterms:modified "2026-02-12T08:59:15.790020Z"^^xsd:dateTime .

oakcurric:keyword-prediction
  a curric:Keyword ;
  schema:name "prediction"@en ;
  schema:description "making a guess using what we already know"@en ;
  dcterms:modified "2026-02-12T08:59:15.790024Z"^^xsd:dateTime .

oakcurric:keyword-character
  a curric:Keyword ;
  schema:name "character"@en ;
  schema:description "a person or an animal in a story"@en ;
  dcterms:modified "2026-02-12T08:59:15.790032Z"^^xsd:dateTime .

oakcurric:keyword-setting
  a curric:Keyword ;
  schema:name "setting"@en ;
  schema:description "where the story takes place"@en ;
  dcterms:modified "2026-02-12T08:59:15.790036Z"^^xsd:dateTime .

oakcurric:keyword-plot
  a curric:Keyword ;
  schema:name "plot"@en ;
  schema:description "what happens in the story"@en ;
  dcterms:modified "2026-02-12T08:59:15.790041Z"^^xsd:dateTime .

oakcurric:keyword-third-person
  a curric:Keyword ;
  schema:name "third person"@en ;
