oakcurric:priorknowledge-227-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "A main clause is a group of words that contains a verb and makes complete sense."@en ;
  dcterms:modified "2026-06-07T15:29:23.728617Z"^^xsd:dateTime .

oakcurric:priorknowledge-227-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """A simple sentence is formed of one main clause and there are four types of simple
  sentence: statement, question, command and exclamation."""@en ;
  dcterms:modified "2026-06-07T15:29:23.728633Z"^^xsd:dateTime .

oakcurric:priorknowledge-227-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """A compound sentence is formed of two main clauses that are joined by a co-ordinating
  conjunction."""@en ;
  dcterms:modified "2026-06-07T15:29:23.728640Z"^^xsd:dateTime .

oakcurric:priorknowledge-227-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """A subordinate clause is a group of words that contains a verb that does not make
  complete sense."""@en ;
  dcterms:modified "2026-06-07T15:29:23.728645Z"^^xsd:dateTime .

oakcurric:priorknowledge-227-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """An adverbial complex sentence is formed of at least one main clause and an adverbial
  subordinate clause."""@en ;
  dcterms:modified "2026-06-07T15:29:23.728687Z"^^xsd:dateTime .

oakcurric:priorknowledge-227-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """An adverbial clause starts with a subordinating conjunction and each subordinating
  conjunction has a different meaning."""@en ;
  dcterms:modified "2026-06-07T15:29:23.728711Z"^^xsd:dateTime .

oakcurric:priorknowledge-227-7
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """A relative complex sentence is formed of at least one main clause and a relative
  subordinate clause."""@en ;
  dcterms:modified "2026-06-07T15:29:23.728719Z"^^xsd:dateTime .

oakcurric:priorknowledge-227-8
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "A relative clause starts with a relative pronoun."@en ;
  dcterms:modified "2026-06-07T15:29:23.728728Z"^^xsd:dateTime .

oakcurric:priorknowledge-227-9
  a curric:PriorKnowledgeRequirement ;
