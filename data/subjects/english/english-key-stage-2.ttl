    oakcurric:priorknowledge-702-8 ,
    oakcurric:priorknowledge-702-9 ,
    oakcurric:priorknowledge-702-10 ;
  curric:id "702"^^xsd:positiveInteger;
  dcterms:modified "2026-06-07T15:29:23.346413Z"^^xsd:dateTime ;
  curric:isUnitOf
    natcurric:scheme-english-key-stage-2 ;
  curric:includesThread
    oakcurric:thread-developing-fiction-writing .

oakcurric:unit-700
  a curric:Unit ;
  rdfs:label "Charles Darwin: biographical writing"@en ;
  curric:slug "charles-darwin-biographical-writing" ;
  rdfs:comment """In this unit, pupils research Charles Darwin's life and evolution theory in order
  to write a biography. The biography is written chronologically, from his early life to
  university, his trip to the Galapagos and his theory of evolution. Finally, pupils present
  information about evolution to a group."""@en ;
  curric:whyThisWhyNow """This unit uses and builds on conventions around biographical writing from
  the Year 5 unit, 'Harriet Tubman: biographical writing'. Pupils research the life and theory
  of Charles Darwin ahead of planning a biography. New learning includes pupils using a text
  map in the planning process - a device to organise ideas cohesively in a plan. Pupils use
  this text map to write with the full range of taught sentence structures across four
  paragraphs, using a formal tone throughout. This unit prepares pupils to write formally in
  the Year 6 unit, 'Climate emergency: journalistic report'.""" ;
  curric:hasPriorKnowledgeRequirement
    oakcurric:priorknowledge-700-1 ,
    oakcurric:priorknowledge-700-2 ,
