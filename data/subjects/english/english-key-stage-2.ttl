    oakcurric:priorknowledge-93-6 ;
  curric:id "93"^^xsd:positiveInteger;
  dcterms:modified "2026-06-07T15:29:24.602626Z"^^xsd:dateTime ;
  curric:isUnitOf
    natcurric:scheme-english-key-stage-2 ;
  curric:includesThread
    oakcurric:thread-developing-vocabulary-knowledge .

oakcurric:unit-302
  a curric:Unit ;
  rdfs:label "Ancient Greeks or Anglo-Saxons: non-chronological report"@en ;
  curric:slug "ancient-greeks-or-anglo-saxons-non-chronological-report" ;
  rdfs:comment """In this unit, pupils research the Ancient Greeks' religion and warfare to write a
  non-chronological report about them. Pupils focus on writing with cohesion, using a range
  of fronted adverbials, subject-specific vocabulary and Year 4 level sentence structures.
  Finally, pupils present their reports."""@en ;
  curric:whyThisWhyNow """This unit uses and builds pupils' knowledge of non-chronological report
  writing from the Year 4 unit 'Anglerfish: non-chronological report'. Pupils again write using
  the structure of introduction, themed sections and conclusion; they also write using a range
  of formal and viewpoint fronted adverbials and subject-specific vocabulary to ensure their
  writing flows cohesively. This unit prepares pupils for more non-chronological report writing
  with increased sophistication of vocabulary choices in the Year 5 unit, 'The Aye-Aye or Wild
  cats: non-chronological report'.""" ;
  curric:hasPriorKnowledgeRequirement
    oakcurric:priorknowledge-302-1 ,
    oakcurric:priorknowledge-302-2 ,
    oakcurric:priorknowledge-302-3 ,
    oakcurric:priorknowledge-302-4 ,
