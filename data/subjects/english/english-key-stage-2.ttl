  a curric:KeyLearningPoint ;
  rdfs:label "The purpose of the build-up is to build up suspense and excitement."@en ;
  dcterms:modified "2026-02-12T08:59:21.718486Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6147-2
  a curric:KeyLearningPoint ;
  rdfs:label "Precise and ambitious vocabulary is logged on a plan for future use."@en ;
  dcterms:modified "2026-02-12T08:59:21.718490Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6147-3
  a curric:KeyLearningPoint ;
  rdfs:label """Notes should not be written in full sentences and bullet points can be used to make notes clear."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718497Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6147-4
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials of time, place and manner indicate when, where and how action takes place."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718501Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6147-5
  a curric:KeyLearningPoint ;
  rdfs:label """Show-not-tell language shows a character’s feelings by describing their actions, body language and facial expressions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718506Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1343-1
  a curric:KeyLearningPoint ;
  rdfs:label "The 'ou' spelling can make the sounds 'or', 'u', 'ow' and 'oo'."@en ;
  dcterms:modified "2026-02-12T08:59:21.718758Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1343-2
  a curric:KeyLearningPoint ;
  rdfs:label "The 'ear' spelling can make the sounds 'ear', 'air', 'ar' and 'er'."@en ;
  dcterms:modified "2026-02-12T08:59:21.718762Z"^^xsd:dateTime .

