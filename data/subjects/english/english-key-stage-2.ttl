oakcurric:keylearningpoint-lesson-8022-4
  a curric:KeyLearningPoint ;
  rdfs:label "Poems can provoke emotions and engage our senses."@en ;
  dcterms:modified "2026-02-12T08:59:21.688567Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7645-1
  a curric:KeyLearningPoint ;
  rdfs:label """A slogan is an important feature of persuasive advertising and needs to be memorable and catchy."""@en ;
  dcterms:modified "2026-02-12T08:59:21.689060Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7645-2
  a curric:KeyLearningPoint ;
  rdfs:label """The layout of a persuasive advert is crucial for ensuring it is visually appealing to the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.689065Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7645-3
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to use neat and creative presentation when publishing a persuasive advert."""@en ;
  dcterms:modified "2026-02-12T08:59:21.689069Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7645-4
  a curric:KeyLearningPoint ;
  rdfs:label """A published persuasive advert should be visually and linguistically appealing to the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.689074Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8075-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘In the Heart of a Book’ is a 20 line poem written by Liz Brownlee; the poem is split into 10 two-line verses."""@en ;
  dcterms:modified "2026-02-12T08:59:21.689078Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8075-2
  a curric:KeyLearningPoint ;
  rdfs:label "The poem includes repetition through the use of anaphora."@en ;
  dcterms:modified "2026-02-12T08:59:21.689083Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8075-3
  a curric:KeyLearningPoint ;
  rdfs:label """Anaphora can draw attention to what books can provide readers with emotionally, while maintaining the poem’s pace."""@en ;
  dcterms:modified "2026-02-12T08:59:21.689087Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8075-4
  a curric:KeyLearningPoint ;
  rdfs:label """Understanding a poem, its language, imagery & the impression it creates will help us to create an impactful performance."""@en ;
  dcterms:modified "2026-02-12T08:59:21.689092Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8050-1
  a curric:KeyLearningPoint ;
  rdfs:label """A tanka is a traditional Japanese form of poetry that originated more than 1,300 years ago."""@en ;
  dcterms:modified "2026-02-12T08:59:21.689118Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8050-2
  a curric:KeyLearningPoint ;
  rdfs:label "Tankas often explore themes of nature, emotions and the passage of time."@en ;
  dcterms:modified "2026-02-12T08:59:21.689122Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8050-3
  a curric:KeyLearningPoint ;
