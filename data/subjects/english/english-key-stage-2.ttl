oakcurric:priorknowledge-309-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The purpose of an explanation text to explain the process of how or why something
  happens."""@en ;
  dcterms:modified "2026-06-07T15:29:24.875822Z"^^xsd:dateTime .

oakcurric:priorknowledge-309-2
  a curric:PriorKnowledgeRequirement ;
