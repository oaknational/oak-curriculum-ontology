oakcurric:priorknowledge-672-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "The Second World War lasted from 1939 to 1945."@en ;
  dcterms:modified "2026-06-07T15:29:23.372583Z"^^xsd:dateTime .

oakcurric:priorknowledge-672-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Some of the major powers involved in the Second World War were Germany, Japan, the
  United States of America and the Soviet Union."""@en ;
  dcterms:modified "2026-06-07T15:29:23.372594Z"^^xsd:dateTime .

oakcurric:priorknowledge-672-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Nazi Germany was defeated by the end of the Second World War."@en ;
  dcterms:modified "2026-06-07T15:29:23.372600Z"^^xsd:dateTime .

oakcurric:priorknowledge-672-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """There was a major human cost of the war with millions of lives lost, including those
  of civilians and soldiers."""@en ;
  dcterms:modified "2026-06-07T15:29:23.372605Z"^^xsd:dateTime .

oakcurric:priorknowledge-672-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Economies, societies and cultures of different countries around the world were
  affected by the Second World War."""@en ;
  dcterms:modified "2026-06-07T15:29:23.372610Z"^^xsd:dateTime .

oakcurric:priorknowledge-672-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "The Second World War has shaped significant parts of the modern world."@en ;
  dcterms:modified "2026-06-07T15:29:23.372615Z"^^xsd:dateTime .

oakcurric:priorknowledge-672-7
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The United Nations was formed on 24 October 1945 after the Second World War had
  ended."""@en ;
  dcterms:modified "2026-06-07T15:29:23.372620Z"^^xsd:dateTime .

oakcurric:priorknowledge-672-8
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Important lessons are learned after wars."@en ;
  dcterms:modified "2026-06-07T15:29:23.372624Z"^^xsd:dateTime .

oakcurric:priorknowledge-672-9
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Migration is the movement of individuals or groups of people from one place to
  another often across long distances."""@en ;
  dcterms:modified "2026-06-07T15:29:23.372629Z"^^xsd:dateTime .

oakcurric:priorknowledge-672-10
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Immigration is the act of entering and settling in a country that is not a person's
  country of origin for the purpose of living and working permanently."""@en ;
  dcterms:modified "2026-06-07T15:29:23.372633Z"^^xsd:dateTime .

oakcurric:priorknowledge-553-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Ability to apply phonics knowledge to support decoding in multisyllabic words."@en ;
  dcterms:modified "2026-06-07T15:29:23.387586Z"^^xsd:dateTime .

oakcurric:priorknowledge-553-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Ability to read common exception words by sight."@en ;
  dcterms:modified "2026-06-07T15:29:23.387597Z"^^xsd:dateTime .

oakcurric:priorknowledge-553-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Know how to retrieve information from a text."@en ;
  dcterms:modified "2026-06-07T15:29:23.387603Z"^^xsd:dateTime .

oakcurric:priorknowledge-553-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Know how to infer meaning from a text."@en ;
  dcterms:modified "2026-06-07T15:29:23.387607Z"^^xsd:dateTime .

oakcurric:priorknowledge-90-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The Stone Age is a prehistoric era before written records. It comes in between the
  Ice Age and the Bronze Age."""@en ;
  dcterms:modified "2026-06-07T15:29:23.389910Z"^^xsd:dateTime .

oakcurric:priorknowledge-90-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The Stone Age is split into three periods: Palaeolithic, Mesolithic and
  Neolithic."""@en ;
  dcterms:modified "2026-06-07T15:29:23.389923Z"^^xsd:dateTime .

oakcurric:priorknowledge-90-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The purpose of a non-chronological report is to inform its reader about a particular
  subject."""@en ;
  dcterms:modified "2026-06-07T15:29:23.389928Z"^^xsd:dateTime .

oakcurric:priorknowledge-90-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Non-chronological reports are a type of factual, non-fiction writing."@en ;
  dcterms:modified "2026-06-07T15:29:23.389933Z"^^xsd:dateTime .

oakcurric:priorknowledge-90-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Non-chronological reports are organised into paragraphs of related content each with
  its own subheading."""@en ;
  dcterms:modified "2026-06-07T15:29:23.389947Z"^^xsd:dateTime .

oakcurric:priorknowledge-90-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Non-chronological reports can contain visual information, most commonly diagrams or
  photographs accompanied by a caption."""@en ;
  dcterms:modified "2026-06-07T15:29:23.389952Z"^^xsd:dateTime .

oakcurric:priorknowledge-90-7
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Nouns can be referred to in a range of ways in order to avoid repetition."@en ;
  dcterms:modified "2026-06-07T15:29:23.389957Z"^^xsd:dateTime .

oakcurric:priorknowledge-90-8
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Text flow can be achieved by writing simple, compound and adverbial complex
  sentences."""@en ;
  dcterms:modified "2026-06-07T15:29:23.389961Z"^^xsd:dateTime .

oakcurric:priorknowledge-90-9
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Grammatical and linguistic features of non-chronological reports include apostrophes
  for singular possession, subject-specific vocabulary and causal conjunctions."""@en ;
  dcterms:modified "2026-06-07T15:29:23.389966Z"^^xsd:dateTime .

oakcurric:priorknowledge-90-10
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Formal fronted adverbials are sentence starters followed by a comma."@en ;
  dcterms:modified "2026-06-07T15:29:23.389970Z"^^xsd:dateTime .

oakcurric:priorknowledge-229-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Sentences can be formed in the present, past or future tense."@en ;
  dcterms:modified "2026-06-07T15:29:23.391869Z"^^xsd:dateTime .

oakcurric:priorknowledge-229-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Tense helps us understand the time frame of the sentence."@en ;
  dcterms:modified "2026-06-07T15:29:23.391881Z"^^xsd:dateTime .

oakcurric:priorknowledge-229-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "There are different tenses and ways of forming verbs in English."@en ;
  dcterms:modified "2026-06-07T15:29:23.391887Z"^^xsd:dateTime .

oakcurric:priorknowledge-229-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "A verb is a doing or a being word."@en ;
  dcterms:modified "2026-06-07T15:29:23.391897Z"^^xsd:dateTime .

oakcurric:priorknowledge-229-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "The verb carries the tense of a sentence."@en ;
  dcterms:modified "2026-06-07T15:29:23.391903Z"^^xsd:dateTime .

oakcurric:priorknowledge-229-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """There are three tense forms (simple, progressive and perfect), all of which can be
  in the past, present or future tense."""@en ;
  dcterms:modified "2026-06-07T15:29:23.391908Z"^^xsd:dateTime .

oakcurric:priorknowledge-229-7
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Simple, progressive and perfect forms have different grammatical rules."@en ;
  dcterms:modified "2026-06-07T15:29:23.391912Z"^^xsd:dateTime .

oakcurric:priorknowledge-229-8
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Simple, progressive and perfect forms tell the reader different contexts of the
