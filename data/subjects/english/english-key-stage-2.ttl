  a curric:KeyLearningPoint ;
  rdfs:label "'The Man on the Moon’ can be summarised into five key parts."@en ;
  dcterms:modified "2026-02-12T08:59:21.613386Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5693-4
  a curric:KeyLearningPoint ;
  rdfs:label "Sequencing places the story's events in chronological order."@en ;
  dcterms:modified "2026-02-12T08:59:21.613394Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6691-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of a build-up is to move the main character’s journey forward and build tension."""@en ;
