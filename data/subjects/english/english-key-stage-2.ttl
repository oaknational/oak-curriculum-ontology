  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: vehicle and apparent."@en ;
  dcterms:modified "2026-02-12T08:59:21.743267Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4821-1
  a curric:KeyLearningPoint ;
  rdfs:label "Common exception words do not follow regular spelling or phonics rules."@en ;
  dcterms:modified "2026-02-12T08:59:21.743344Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4821-2
  a curric:KeyLearningPoint ;
  rdfs:label "The words start with a lead in on the line and finish with a lead out."@en ;
  dcterms:modified "2026-02-12T08:59:21.743348Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4821-3
  a curric:KeyLearningPoint ;
  rdfs:label """Letters in the common exception words will be joined using a range of joins depending on the letters in the word."""@en ;
  dcterms:modified "2026-02-12T08:59:21.743352Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4821-4
  a curric:KeyLearningPoint ;
  rdfs:label "There is appropriate spacing between the letters."@en ;
  dcterms:modified "2026-02-12T08:59:21.743356Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4821-5
  a curric:KeyLearningPoint ;
  rdfs:label "You don't lift your pencil to form the joins."@en ;
  dcterms:modified "2026-02-12T08:59:21.743360Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1398-1
  a curric:KeyLearningPoint ;
  rdfs:label """A prefix is a letter or group of letters at the start of a word which changes its meaning."""@en ;
  dcterms:modified "2026-02-12T08:59:21.743397Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1398-2
  a curric:KeyLearningPoint ;
  rdfs:label "The prefixes co-, com- and con- mean ‘together’ or ‘with’."@en ;
  dcterms:modified "2026-02-12T08:59:21.743401Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1398-3
  a curric:KeyLearningPoint ;
  rdfs:label "The prefix pre- means ‘before’ and pro- means ‘ahead’."@en ;
  dcterms:modified "2026-02-12T08:59:21.743405Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1398-4
  a curric:KeyLearningPoint ;
  rdfs:label """A hyphen can join a prefix to a base word to avoid ambiguity in meaning or spelling."""@en ;
  dcterms:modified "2026-02-12T08:59:21.743409Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1398-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: complete, programme and develop."@en ;
  dcterms:modified "2026-02-12T08:59:21.743415Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6555-1
  a curric:KeyLearningPoint ;
  rdfs:label "The main body paragraphs should be factual, specific and detailed."@en ;
  dcterms:modified "2026-02-12T08:59:21.743419Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6555-2
  a curric:KeyLearningPoint ;
  rdfs:label """Flattery, presumption and veiled threat are appropriate persuasive devices to use in the main body."""@en ;
  dcterms:modified "2026-02-12T08:59:21.743424Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6555-3
  a curric:KeyLearningPoint ;
  rdfs:label """Points backed up by evidence, statistics, quotes or anecdotes are effective in persuading the recipient."""@en ;
  dcterms:modified "2026-02-12T08:59:21.743427Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6555-4
  a curric:KeyLearningPoint ;
  rdfs:label "Plans and success criteria should be referred to during the writing process."@en ;
  dcterms:modified "2026-02-12T08:59:21.743431Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5773-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the main body is to describe events, thoughts and feelings in detail."""@en ;
  dcterms:modified "2026-02-12T08:59:21.743435Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5773-2
  a curric:KeyLearningPoint ;
  rdfs:label "Using a variety of sentence types and structures enhances text cohesion."@en ;
  dcterms:modified "2026-02-12T08:59:21.743441Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5773-3
  a curric:KeyLearningPoint ;
  rdfs:label "Informal tone can be achieved through use of contractions and exclamations."@en ;
  dcterms:modified "2026-02-12T08:59:21.743445Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5773-4
  a curric:KeyLearningPoint ;
  rdfs:label "Adverbials of time can be used to sequence events."@en ;
  dcterms:modified "2026-02-12T08:59:21.743451Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3448-1
  a curric:KeyLearningPoint ;
  rdfs:label "Determiners are a word class."@en ;
  dcterms:modified "2026-02-12T08:59:21.743455Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3448-2
  a curric:KeyLearningPoint ;
  rdfs:label "A determiner introduces a noun in a clause or phrase."@en ;
  dcterms:modified "2026-02-12T08:59:21.743459Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3448-3
  a curric:KeyLearningPoint ;
  rdfs:label "Determiners can be articles, possessive pronouns, quantifiers or demonstratives."@en ;
  dcterms:modified "2026-02-12T08:59:21.743463Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3448-4
  a curric:KeyLearningPoint ;
  rdfs:label """Different determiners have different purposes, chosen by the writer for a reason."""@en ;
  dcterms:modified "2026-02-12T08:59:21.743467Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3448-5
  a curric:KeyLearningPoint ;
  rdfs:label """A determiner may be followed by an adjective or pair of adjectives then the noun."""@en ;
  dcterms:modified "2026-02-12T08:59:21.743472Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1444-1
  a curric:KeyLearningPoint ;
  rdfs:label """-er and "-est" are suffixes that can be used to change the meaning of a root word."""@en ;
  dcterms:modified "2026-02-12T08:59:21.743477Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1444-2
  a curric:KeyLearningPoint ;
  rdfs:label "For root words ending in 'y', you can remove the 'y' and add -ier or -iest."@en ;
  dcterms:modified "2026-02-12T08:59:21.743481Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1444-3
  a curric:KeyLearningPoint ;
  rdfs:label """For root words with a short vowel sound, you can double the consonant and add the suffix -er or -est."""@en ;
  dcterms:modified "2026-02-12T08:59:21.743485Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1444-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words popular and unpopular."@en ;
  dcterms:modified "2026-02-12T08:59:21.743489Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6554-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the main body paragraph is to specifically detail key persuasive arguments."""@en ;
  dcterms:modified "2026-02-12T08:59:21.743814Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6554-2
  a curric:KeyLearningPoint ;
  rdfs:label "Information in the main body should be specific not vague."@en ;
  dcterms:modified "2026-02-12T08:59:21.743818Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6554-3
  a curric:KeyLearningPoint ;
  rdfs:label "Using a range of sentence types enhances text cohesion."@en ;
  dcterms:modified "2026-02-12T08:59:21.743822Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6554-4
  a curric:KeyLearningPoint ;
  rdfs:label """Points that are backed up by evidence, statistics or anecdotes are effective for persuading the recipient of a letter."""@en ;
  dcterms:modified "2026-02-12T08:59:21.743826Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6592-1
  a curric:KeyLearningPoint ;
  rdfs:label """In the sections, writers share detailed, specific information about an aspect of the person's life with the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.743830Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6592-2
  a curric:KeyLearningPoint ;
  rdfs:label """Section paragraphs include a topic sentence, specific information and a linking sentence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.743834Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6592-3
  a curric:KeyLearningPoint ;
  rdfs:label "When planning, we should record ideas in concise, bullet-pointed notes."@en ;
  dcterms:modified "2026-02-12T08:59:21.743838Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6592-4
  a curric:KeyLearningPoint ;
  rdfs:label "When writing, we should use a plan and success criteria to guide us."@en ;
  dcterms:modified "2026-02-12T08:59:21.743841Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6592-5
  a curric:KeyLearningPoint ;
  rdfs:label """Text cohesion is achieved through use of subject-specific vocabulary, fronted adverbials and relative complex sentences."""@en ;
  dcterms:modified "2026-02-12T08:59:21.743845Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5766-1
  a curric:KeyLearningPoint ;
  rdfs:label "A diary entry is a type of recount written in the first person."@en ;
  dcterms:modified "2026-02-12T08:59:21.743851Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5766-2
  a curric:KeyLearningPoint ;
  rdfs:label "A diary entry is informal in its tone."@en ;
  dcterms:modified "2026-02-12T08:59:21.743856Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5766-3
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of a diary entry is to recount events and record thoughts and feelings."""@en ;
  dcterms:modified "2026-02-12T08:59:21.743859Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5766-4
  a curric:KeyLearningPoint ;
  rdfs:label "A diary entry can be sequenced in chronological order."@en ;
  dcterms:modified "2026-02-12T08:59:21.743863Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5766-5
  a curric:KeyLearningPoint ;
  rdfs:label "A diary entry may switch between past, present and future tenses."@en ;
  dcterms:modified "2026-02-12T08:59:21.743867Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5765-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the opening is to engage the reader and introduce characters and plot."""@en ;
  dcterms:modified "2026-02-12T08:59:21.743871Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5765-2
  a curric:KeyLearningPoint ;
  rdfs:label "Using a range of linguistic features helps achieve the text's purpose."@en ;
  dcterms:modified "2026-02-12T08:59:21.743875Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5765-3
  a curric:KeyLearningPoint ;
  rdfs:label """We have learned about three types of complex sentence: adverbial, relative and non-finite."""@en ;
  dcterms:modified "2026-02-12T08:59:21.743879Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5765-4
  a curric:KeyLearningPoint ;
  rdfs:label """Using a range of sentence types in narrative writing enhances text cohesion and keeps the reader engaged."""@en ;
  dcterms:modified "2026-02-12T08:59:21.743884Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5765-5
  a curric:KeyLearningPoint ;
  rdfs:label """Powerful, precise vocabulary choices engage the reader and help create atmosphere."""@en ;
  dcterms:modified "2026-02-12T08:59:21.743890Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4706-1
  a curric:KeyLearningPoint ;
  rdfs:label "A debate usually has a winning team."@en ;
  dcterms:modified "2026-02-12T08:59:21.743895Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4706-2
  a curric:KeyLearningPoint ;
  rdfs:label """The winning team in a debate can be decided by an audience vote, or a judge, or a panel of judges."""@en ;
  dcterms:modified "2026-02-12T08:59:21.743899Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4706-3
  a curric:KeyLearningPoint ;
  rdfs:label """The judges award a score out of ten in four different areas: content, style, delivery and points of information."""@en ;
  dcterms:modified "2026-02-12T08:59:21.743902Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1437-1
  a curric:KeyLearningPoint ;
  rdfs:label "-y is a suffix that can be used to change some nouns into adjectives."@en ;
  dcterms:modified "2026-02-12T08:59:21.743906Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1437-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Big letters' is a useful practice strategy."@en ;
  dcterms:modified "2026-02-12T08:59:21.743910Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1437-3
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum word: heart."@en ;
  dcterms:modified "2026-02-12T08:59:21.743914Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1437-4
  a curric:KeyLearningPoint ;
  rdfs:label "For root words ending in 'e', you remove the 'e' and just add -y."@en ;
  dcterms:modified "2026-02-12T08:59:21.743918Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1437-5
  a curric:KeyLearningPoint ;
  rdfs:label "For root words with a short vowel sound, you double the consonant and add -y."@en ;
  dcterms:modified "2026-02-12T08:59:21.743922Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1442-1
  a curric:KeyLearningPoint ;
  rdfs:label "-er and -est are suffixes that can be used to change the meaning of a root word."@en ;
  dcterms:modified "2026-02-12T08:59:21.743929Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1442-2
  a curric:KeyLearningPoint ;
  rdfs:label "For some root words you can add the suffix -er."@en ;
  dcterms:modified "2026-02-12T08:59:21.743933Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1442-3
  a curric:KeyLearningPoint ;
  rdfs:label "For some root words you can add the suffix -est."@en ;
  dcterms:modified "2026-02-12T08:59:21.743937Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1442-4
  a curric:KeyLearningPoint ;
  rdfs:label "For root words ending in 'e' you remove the 'e' and add the suffix -er or -est."@en ;
  dcterms:modified "2026-02-12T08:59:21.743941Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1442-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum word: minute."@en ;
  dcterms:modified "2026-02-12T08:59:21.743945Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28411-1
  a curric:KeyLearningPoint ;
  rdfs:label """Play scripts are written with certain conventions that help make a script organised, clear and easy to follow."""@en ;
  dcterms:modified "2026-02-12T08:59:21.743949Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28411-2
  a curric:KeyLearningPoint ;
  rdfs:label "Performance techniques are tools that actors use to connect with the audience."@en ;
  dcterms:modified "2026-02-12T08:59:21.743953Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28411-3
  a curric:KeyLearningPoint ;
  rdfs:label "These techniques can be learnt, practised and developed."@en ;
  dcterms:modified "2026-02-12T08:59:21.743957Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28411-4
  a curric:KeyLearningPoint ;
  rdfs:label """Deciding where to stand and how to move is an important part of the rehearsal process for the director and actors."""@en ;
  dcterms:modified "2026-02-12T08:59:21.743961Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28411-5
  a curric:KeyLearningPoint ;
  rdfs:label """Plays can have large or small casts - the number of actors who play the different characters in a play."""@en ;
  dcterms:modified "2026-02-12T08:59:21.743964Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2697-1
  a curric:KeyLearningPoint ;
  rdfs:label "A sentence composed of one main clause is a simple sentence."@en ;
  dcterms:modified "2026-02-12T08:59:21.743968Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2697-2
  a curric:KeyLearningPoint ;
  rdfs:label """There are four types of simple sentence: statement, question, command and exclamation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.743972Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2697-3
  a curric:KeyLearningPoint ;
  rdfs:label """A sentence composed of at least two main clauses joined by a co-ordinating conjunction is a compound sentence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.743976Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2697-4
  a curric:KeyLearningPoint ;
  rdfs:label """A sentence composed of at least one main clause and an adverbial subordinate clause is an adverbial complex sentence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.743980Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1364-1
  a curric:KeyLearningPoint ;
  rdfs:label "Adding -s or -es to a noun creates a plural."@en ;
  dcterms:modified "2026-02-12T08:59:21.743986Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1364-2
  a curric:KeyLearningPoint ;
  rdfs:label "If the word ends in a vowel (a, e, i, u) or consonant, just add -s."@en ;
  dcterms:modified "2026-02-12T08:59:21.743990Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1364-3
  a curric:KeyLearningPoint ;
  rdfs:label "If the word ends in 'y' preceded by a vowel, just add -s."@en ;
  dcterms:modified "2026-02-12T08:59:21.743994Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1364-4
  a curric:KeyLearningPoint ;
  rdfs:label "If the word ends in 'y' preceded by a consonant, remove the 'y' and add -ies."@en ;
  dcterms:modified "2026-02-12T08:59:21.743998Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1364-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: group, earth and yacht."@en ;
  dcterms:modified "2026-02-12T08:59:21.744003Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2707-1
  a curric:KeyLearningPoint ;
  rdfs:label "Direct speech is the term used for a character speaking out loud in a text."@en ;
  dcterms:modified "2026-02-12T08:59:21.744255Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2707-2
  a curric:KeyLearningPoint ;
  rdfs:label "A speech first sentence begins with a character's spoken words."@en ;
  dcterms:modified "2026-02-12T08:59:21.744260Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2707-3
  a curric:KeyLearningPoint ;
  rdfs:label """Inverted commas are the punctuation marks that signal direct speech to the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.744264Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2707-4
  a curric:KeyLearningPoint ;
  rdfs:label "The speech sentence spoken by a character must start with a capital letter."@en ;
  dcterms:modified "2026-02-12T08:59:21.744268Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2707-5
  a curric:KeyLearningPoint ;
  rdfs:label "The reporting clause comes after the speech to show who said the speech and how."@en ;
  dcterms:modified "2026-02-12T08:59:21.744271Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6717-1
  a curric:KeyLearningPoint ;
  rdfs:label "A biography is a non-fiction text written about someone's life."@en ;
  dcterms:modified "2026-02-12T08:59:21.744275Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6717-2
  a curric:KeyLearningPoint ;
  rdfs:label """Linguistic features of a biography include third person, formal fronted adverbials, formal tone and relative clauses."""@en ;
  dcterms:modified "2026-02-12T08:59:21.744279Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6717-3
  a curric:KeyLearningPoint ;
  rdfs:label """Structural features of a biography include a title, paragraphs and information grouped by theme."""@en ;
  dcterms:modified "2026-02-12T08:59:21.744285Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6717-4
  a curric:KeyLearningPoint ;
  rdfs:label """A biography is usually written in chronological order and will contain lots of past tense verbs."""@en ;
  dcterms:modified "2026-02-12T08:59:21.744289Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6717-5
  a curric:KeyLearningPoint ;
  rdfs:label "Additional factual information can be added to a clause as parenthesis."@en ;
  dcterms:modified "2026-02-12T08:59:21.744293Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6549-1
  a curric:KeyLearningPoint ;
  rdfs:label """The introduction must clearly communicate why the author is writing to the recipient."""@en ;
  dcterms:modified "2026-02-12T08:59:21.744297Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6549-2
  a curric:KeyLearningPoint ;
  rdfs:label "This persuasive letter is formal in tone."@en ;
  dcterms:modified "2026-02-12T08:59:21.744301Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6549-3
  a curric:KeyLearningPoint ;
  rdfs:label "An introductory sentence indicates what the paragraph will be about."@en ;
  dcterms:modified "2026-02-12T08:59:21.744307Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6549-4
  a curric:KeyLearningPoint ;
  rdfs:label "Information in the introduction should be kept general."@en ;
  dcterms:modified "2026-02-12T08:59:21.744311Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1400-1
  a curric:KeyLearningPoint ;
  rdfs:label """A suffix is a letter or group of letters added to the end of a word to change its meaning and sometimes wordclass."""@en ;
  dcterms:modified "2026-02-12T08:59:21.744315Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1400-2
  a curric:KeyLearningPoint ;
  rdfs:label "The suffixes -tion, -ity and -ness create nouns."@en ;
  dcterms:modified "2026-02-12T08:59:21.744318Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1400-3
  a curric:KeyLearningPoint ;
  rdfs:label """An abstract noun is a type of noun that names an idea or quality that cannot be seen."""@en ;
  dcterms:modified "2026-02-12T08:59:21.744322Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1400-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: describe, often and notice."@en ;
  dcterms:modified "2026-02-12T08:59:21.744326Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4711-1
  a curric:KeyLearningPoint ;
  rdfs:label "The purpose of your speech is the reason why you are speaking."@en ;
  dcterms:modified "2026-02-12T08:59:21.744330Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4711-2
  a curric:KeyLearningPoint ;
  rdfs:label "Speeches often try to persuade an audience to agree with its main themes."@en ;
  dcterms:modified "2026-02-12T08:59:21.744334Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4711-3
  a curric:KeyLearningPoint ;
  rdfs:label "Speeches can inform an audience about something they may not already know about."@en ;
  dcterms:modified "2026-02-12T08:59:21.744338Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4711-4
  a curric:KeyLearningPoint ;
  rdfs:label "Speeches can provoke an emotional response."@en ;
  dcterms:modified "2026-02-12T08:59:21.744341Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27894-1
  a curric:KeyLearningPoint ;
  rdfs:label "A debate often involves speakers disagreeing with each other."@en ;
  dcterms:modified "2026-02-12T08:59:21.744950Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27894-2
  a curric:KeyLearningPoint ;
  rdfs:label "The motion is the name for the belief or proposal that is being debated."@en ;
  dcterms:modified "2026-02-12T08:59:21.744955Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27894-3
  a curric:KeyLearningPoint ;
  rdfs:label "The PEPS structure stands for: point, explanation, proof, summary."@en ;
  dcterms:modified "2026-02-12T08:59:21.744959Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27894-4
  a curric:KeyLearningPoint ;
  rdfs:label "In a debate, a speaker will make a point and then explain it."@en ;
  dcterms:modified "2026-02-12T08:59:21.744962Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27894-5
  a curric:KeyLearningPoint ;
  rdfs:label "Adding proof gives credibility to an argument."@en ;
  dcterms:modified "2026-02-12T08:59:21.744966Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2734-1
  a curric:KeyLearningPoint ;
  rdfs:label "The non-finite clause is a type of subordinate clause."@en ;
  dcterms:modified "2026-02-12T08:59:21.745284Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2734-2
  a curric:KeyLearningPoint ;
  rdfs:label "A non-finite clause must join to a main clause to make sense."@en ;
  dcterms:modified "2026-02-12T08:59:21.745288Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2734-3
  a curric:KeyLearningPoint ;
  rdfs:label """The non-finite clause denotes ongoing action that relates to the subject of the main clause."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745292Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2734-4
  a curric:KeyLearningPoint ;
  rdfs:label """The action of the non-finite clause occurs simultaneously to the action of the main clause."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745296Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2734-5
  a curric:KeyLearningPoint ;
  rdfs:label """A non-finite clause joined with a main clause forms the non-finite complex sentence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745300Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27778-1
  a curric:KeyLearningPoint ;
  rdfs:label """A speech is the communication of someone’s thoughts, through words, to an audience."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745303Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27778-2
  a curric:KeyLearningPoint ;
  rdfs:label "The purpose of a speech is always to impact the audience in some way."@en ;
  dcterms:modified "2026-02-12T08:59:21.745307Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27778-3
  a curric:KeyLearningPoint ;
  rdfs:label """A common purpose of a speech is to persuade the audience to agree with the speaker about something."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745311Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27778-4
  a curric:KeyLearningPoint ;
  rdfs:label "Points are used to justify the speaker’s opinion in a speech."@en ;
  dcterms:modified "2026-02-12T08:59:21.745315Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7842-1
  a curric:KeyLearningPoint ;
  rdfs:label """The information learnt depends on which sections of the text the reader has focused on."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745319Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7842-2
  a curric:KeyLearningPoint ;
  rdfs:label """Summarising a topic and discussing it with others deepens understanding and helps knowledge to stick."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745325Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7842-3
  a curric:KeyLearningPoint ;
  rdfs:label "Rivers are home to many living things and they are a crucial part of human life."@en ;
  dcterms:modified "2026-02-12T08:59:21.745329Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7842-4
  a curric:KeyLearningPoint ;
  rdfs:label "Human activities can cause harm to rivers."@en ;
  dcterms:modified "2026-02-12T08:59:21.745334Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7842-5
  a curric:KeyLearningPoint ;
  rdfs:label """There are ways that humans can protect rivers for the benefit of all living things."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745337Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2701-1
  a curric:KeyLearningPoint ;
  rdfs:label """The relative clause is a type of subordinate clause, which must join to a main clause to make complete sense."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745341Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2701-2
  a curric:KeyLearningPoint ;
  rdfs:label """The relative clause adds extra, relevant information about a noun or noun phrase within a main clause."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745345Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2701-3
  a curric:KeyLearningPoint ;
  rdfs:label "A relative clause often interrupts the main clause."@en ;
  dcterms:modified "2026-02-12T08:59:21.745349Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2701-4
  a curric:KeyLearningPoint ;
  rdfs:label "A relative clause joined with a main clause forms the relative complex sentence."@en ;
  dcterms:modified "2026-02-12T08:59:21.745355Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2696-1
  a curric:KeyLearningPoint ;
  rdfs:label "Any clause is a group of words that contains a verb."@en ;
  dcterms:modified "2026-02-12T08:59:21.745359Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2696-2
  a curric:KeyLearningPoint ;
  rdfs:label "A main clause is a group of words that contains a verb and makes complete sense."@en ;
  dcterms:modified "2026-02-12T08:59:21.745365Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2696-3
  a curric:KeyLearningPoint ;
  rdfs:label """A subordinate clause is a group of words that contains a verb that does not make complete sense."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745369Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2696-4
  a curric:KeyLearningPoint ;
  rdfs:label "A subordinate clause must be joined to a main clause to make a complex sentence."@en ;
  dcterms:modified "2026-02-12T08:59:21.745373Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2696-5
  a curric:KeyLearningPoint ;
  rdfs:label """One type of subordinate clause is an adverbial clause, which starts with a subordinating conjunction."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745377Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1041-1
  a curric:KeyLearningPoint ;
  rdfs:label """A word that joins a second idea to a main clause in an adverbial complex sentence is called a subordinating conjunction."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745381Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1041-2
  a curric:KeyLearningPoint ;
  rdfs:label "A subordinating conjunction is the word that starts an adverbial clause."@en ;
  dcterms:modified "2026-02-12T08:59:21.745385Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1041-3
  a curric:KeyLearningPoint ;
  rdfs:label """A subordinate clause is a group of words that contains a verb and does not make complete sense."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745390Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1041-4
  a curric:KeyLearningPoint ;
  rdfs:label "An adverbial clause is a type of subordinate clause."@en ;
  dcterms:modified "2026-02-12T08:59:21.745395Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1041-5
  a curric:KeyLearningPoint ;
  rdfs:label "A main clause joined with any subordinate clause forms a complex sentence."@en ;
  dcterms:modified "2026-02-12T08:59:21.745399Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1049-1
  a curric:KeyLearningPoint ;
  rdfs:label """The simple tense is a tense that does not make use of an auxiliary verb with the main verb in the present and past."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745405Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1049-2
  a curric:KeyLearningPoint ;
  rdfs:label """The progressive tense is a tense that makes use of an auxiliary verb from the infinitive 'to be' with the main verb."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745409Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1049-3
  a curric:KeyLearningPoint ;
  rdfs:label """The perfect tense is a tense that makes use of an auxiliary verb from the infinitive 'to have' with the main verb."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745413Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1049-4
  a curric:KeyLearningPoint ;
  rdfs:label """The auxiliary verb is followed by the past tense form of the main verb in the perfect tense."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745417Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1049-5
  a curric:KeyLearningPoint ;
  rdfs:label "The past tense form of the verb frequently expresses completed action."@en ;
  dcterms:modified "2026-02-12T08:59:21.745421Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2704-1
  a curric:KeyLearningPoint ;
  rdfs:label "The verb carries the tense of a sentence."@en ;
  dcterms:modified "2026-02-12T08:59:21.745425Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2704-2
  a curric:KeyLearningPoint ;
  rdfs:label "The progressive tense can denote present, past or future action."@en ;
  dcterms:modified "2026-02-12T08:59:21.745429Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2704-3
  a curric:KeyLearningPoint ;
  rdfs:label """The progressive tense is a tense that makes use of an auxiliary verb based on 'to be' with a main verb."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745432Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2704-4
  a curric:KeyLearningPoint ;
  rdfs:label "The progressive tense denotes ongoing action."@en ;
  dcterms:modified "2026-02-12T08:59:21.745436Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2704-5
  a curric:KeyLearningPoint ;
  rdfs:label "The main verb in the progressive tense always ends with the -ing suffix."@en ;
  dcterms:modified "2026-02-12T08:59:21.745440Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4892-1
  a curric:KeyLearningPoint ;
  rdfs:label """The introduction provides general information and outlines the structure of the full report."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745444Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4892-2
  a curric:KeyLearningPoint ;
  rdfs:label "Parenthesis (additional information) can be conveyed using brackets."@en ;
  dcterms:modified "2026-02-12T08:59:21.745448Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4892-3
  a curric:KeyLearningPoint ;
  rdfs:label "Linking sentences at the end of paragraphs help create text cohesion."@en ;
  dcterms:modified "2026-02-12T08:59:21.745451Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4892-4
  a curric:KeyLearningPoint ;
  rdfs:label "Using passive verbs changes the way information is presented in a sentence."@en ;
  dcterms:modified "2026-02-12T08:59:21.745455Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1302-1
  a curric:KeyLearningPoint ;
  rdfs:label """Adding the suffix -ed turns the verb into the past tense and the -ed can sound like /id/, /d/ or /t/."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745460Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1302-2
  a curric:KeyLearningPoint ;
  rdfs:label """When a verb has two syllables and the final syllable is stressed, double the consonant and add -ed."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745466Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1302-3
  a curric:KeyLearningPoint ;
  rdfs:label "When a verb ends in 'e', remove the 'e' and add the suffix -ed."@en ;
  dcterms:modified "2026-02-12T08:59:21.745470Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1302-4
  a curric:KeyLearningPoint ;
  rdfs:label "When a verb ends in 'y', swap it for an 'i' and add the suffix -ed."@en ;
  dcterms:modified "2026-02-12T08:59:21.745474Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1302-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the common exception words: heard, appear and circle."@en ;
  dcterms:modified "2026-02-12T08:59:21.745480Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7853-1
  a curric:KeyLearningPoint ;
  rdfs:label """Words or phrases can be understood and explained by looking at the context they are situated in."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745484Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7853-2
  a curric:KeyLearningPoint ;
  rdfs:label "Re-reading a text helps develop our understanding and fluency."@en ;
  dcterms:modified "2026-02-12T08:59:21.745489Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7853-3
  a curric:KeyLearningPoint ;
  rdfs:label "Walter Tull was the first Black British professional outfield football player."@en ;
  dcterms:modified "2026-02-12T08:59:21.745492Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7853-4
  a curric:KeyLearningPoint ;
  rdfs:label """Walter Tull experienced discrimination and prejudice based on the colour of his skin."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745496Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1359-1
  a curric:KeyLearningPoint ;
  rdfs:label """Some sounds can be represented by a number of different spellings e.g. the /ee/ sound."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745661Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1359-2
  a curric:KeyLearningPoint ;
  rdfs:label """The same spellings can represent more than one sound e.g. 'ie', 'ei', 'ough' and 'ou'."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745665Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1359-3
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: shoulder and committee."@en ;
  dcterms:modified "2026-02-12T08:59:21.745669Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4852-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of an editing lesson is to improve writing and make necessary corrections."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745673Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4852-2
  a curric:KeyLearningPoint ;
  rdfs:label """Vocabulary, grammar and punctuation can be changed to make writing outcomes more effective in meeting text purpose."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745678Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4852-3
  a curric:KeyLearningPoint ;
  rdfs:label "When editing, we are selective about which parts of our writing to improve."@en ;
  dcterms:modified "2026-02-12T08:59:21.745682Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4852-4
  a curric:KeyLearningPoint ;
  rdfs:label "Editing does not involve re-writing the entire piece."@en ;
  dcterms:modified "2026-02-12T08:59:21.745686Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1435-1
  a curric:KeyLearningPoint ;
  rdfs:label "-es is a suffix that can turn a singular noun into a plural."@en ;
  dcterms:modified "2026-02-12T08:59:21.745690Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1435-2
  a curric:KeyLearningPoint ;
  rdfs:label "Using the strategy 'pyramid letters' is a useful practice strategy."@en ;
  dcterms:modified "2026-02-12T08:59:21.745694Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1435-3
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum word: describe."@en ;
  dcterms:modified "2026-02-12T08:59:21.745698Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1365-1
  a curric:KeyLearningPoint ;
  rdfs:label "If the root word ends in a ‘sh’, ‘ch’, ‘ss’ or ‘x’, then add the suffix -es."@en ;
  dcterms:modified "2026-02-12T08:59:21.745704Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1365-2
  a curric:KeyLearningPoint ;
  rdfs:label "If the root word ends in an ‘o’, it can use -s or -es."@en ;
  dcterms:modified "2026-02-12T08:59:21.745708Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1365-3
  a curric:KeyLearningPoint ;
  rdfs:label """If the root word ends in a ‘f’ or ‘fe’, then the ‘f’ is replaced by ‘v’ before adding the suffix -es."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745714Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1365-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: twelfth, often and appear."@en ;
  dcterms:modified "2026-02-12T08:59:21.745718Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7854-1
  a curric:KeyLearningPoint ;
  rdfs:label "Skimming and scanning helps to retrieve and record information from a text."@en ;
  dcterms:modified "2026-02-12T08:59:21.745722Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7854-2
  a curric:KeyLearningPoint ;
  rdfs:label "Reading between the lines to search for clues can help to infer meaning."@en ;
  dcterms:modified "2026-02-12T08:59:21.745726Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7854-3
  a curric:KeyLearningPoint ;
  rdfs:label "Evidence from the text helps us to justify our inferences."@en ;
  dcterms:modified "2026-02-12T08:59:21.745730Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27904-1
  a curric:KeyLearningPoint ;
  rdfs:label "Effective presentations are planned in advance."@en ;
  dcterms:modified "2026-02-12T08:59:21.745929Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27904-2
  a curric:KeyLearningPoint ;
  rdfs:label """Part of planning a presentation is organising what you are going to say and in what order."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745933Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27904-3
  a curric:KeyLearningPoint ;
  rdfs:label """Vocabulary chosen must be suitable for the presentation's audience and its purpose."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745937Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27904-4
  a curric:KeyLearningPoint ;
  rdfs:label "Engaging with an audience involves grabbing their attention and maintaining it."@en ;
  dcterms:modified "2026-02-12T08:59:21.745941Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27904-5
  a curric:KeyLearningPoint ;
  rdfs:label "Presentation skills can be learnt, developed and practised."@en ;
  dcterms:modified "2026-02-12T08:59:21.745947Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6143-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the opening is to engage the reader and introduce the setting and characters."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745951Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6143-2
  a curric:KeyLearningPoint ;
  rdfs:label "Precise and ambitious vocabulary is logged on a plan for future use."@en ;
  dcterms:modified "2026-02-12T08:59:21.745956Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6143-3
  a curric:KeyLearningPoint ;
  rdfs:label """Notes should not be written in full sentences and bullet points can be used to make notes clear."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745960Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6143-4
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials of time, place and manner indicate when, where and how action takes place."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745964Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6143-5
  a curric:KeyLearningPoint ;
  rdfs:label """Ambitious and precise adverbs, adjectives and verbs are used to create a vivid picture for the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745968Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4856-1
  a curric:KeyLearningPoint ;
  rdfs:label "The closing is the final paragraph of a journalistic report."@en ;
  dcterms:modified "2026-02-12T08:59:21.745972Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4856-2
  a curric:KeyLearningPoint ;
  rdfs:label "The closing summarises what is currently happening and what will happen next."@en ;
  dcterms:modified "2026-02-12T08:59:21.745976Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4856-3
  a curric:KeyLearningPoint ;
  rdfs:label """Reference to present and future events requires us to write correctly in present and future tense."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745980Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4856-4
  a curric:KeyLearningPoint ;
  rdfs:label "Using a range of cohesive devices enhances text flow and helps achieve purpose."@en ;
  dcterms:modified "2026-02-12T08:59:21.745984Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4856-5
  a curric:KeyLearningPoint ;
  rdfs:label """Modal verbs are types of auxiliary verbs that show the likelihood of something happening."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745987Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4850-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the recount section is to engage the reader and give them specific information about what happened."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745991Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4850-2
  a curric:KeyLearningPoint ;
  rdfs:label "An introductory sentence explains what the paragraph is about."@en ;
  dcterms:modified "2026-02-12T08:59:21.745995Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4850-3
  a curric:KeyLearningPoint ;
  rdfs:label """Relative complex sentences and passive voice enable the writer to convey information in varied ways."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745999Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4850-4
  a curric:KeyLearningPoint ;
  rdfs:label "Relative clauses begin with the relative pronouns ‘who’ or ‘which’."@en ;
  dcterms:modified "2026-02-12T08:59:21.746003Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4850-5
  a curric:KeyLearningPoint ;
  rdfs:label "Plans should include clear, concise notes."@en ;
  dcterms:modified "2026-02-12T08:59:21.746007Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4880-1
  a curric:KeyLearningPoint ;
  rdfs:label """Mummification is a process to preserve a dead body to make it ready for the afterlife."""@en ;
  dcterms:modified "2026-02-12T08:59:21.746714Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4880-2
  a curric:KeyLearningPoint ;
  rdfs:label """Mummification is a complex and long process that needs to be completed in a certain order."""@en ;
  dcterms:modified "2026-02-12T08:59:21.746718Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4880-3
  a curric:KeyLearningPoint ;
  rdfs:label "Embalmers were the people whose job it was to mummify corpses in Ancient Egypt."@en ;
  dcterms:modified "2026-02-12T08:59:21.746723Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4880-4
  a curric:KeyLearningPoint ;
  rdfs:label """The corpse was thoroughly cleaned, dried out and wrapped in linen in preparation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.746728Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4880-5
  a curric:KeyLearningPoint ;
  rdfs:label """The corpse was placed in a sarcophagus where it could be kept safe in the afterlife."""@en ;
  dcterms:modified "2026-02-12T08:59:21.746732Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1385-1
  a curric:KeyLearningPoint ;
  rdfs:label """There are many ways to spell the ‘ee’ sound, including ‘ee’, ‘ea’, ‘e-e’, ‘e’, ‘y’, ‘ey’, ‘ie’ and ‘ei’."""@en ;
  dcterms:modified "2026-02-12T08:59:21.746736Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1385-2
  a curric:KeyLearningPoint ;
  rdfs:label """The rule ‘i before e except after c’ can help choose between ‘ie’ and ‘ei’ when spelling ‘ee’."""@en ;
  dcterms:modified "2026-02-12T08:59:21.746740Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1385-3
  a curric:KeyLearningPoint ;
  rdfs:label "There are exceptions, including ‘protein’, ‘caffeine’, ‘either’ and ‘seize’."@en ;
  dcterms:modified "2026-02-12T08:59:21.746745Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1385-4
  a curric:KeyLearningPoint ;
  rdfs:label "It is important to practise to help us learn new spellings."@en ;
  dcterms:modified "2026-02-12T08:59:21.746749Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1385-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: rhyme, rhythm and remember."@en ;
  dcterms:modified "2026-02-12T08:59:21.746753Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1376-1
  a curric:KeyLearningPoint ;
  rdfs:label "Words that end with suffixes -ant and -ent can sound like ‘unt’ when we speak."@en ;
  dcterms:modified "2026-02-12T08:59:21.746757Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1376-2
  a curric:KeyLearningPoint ;
  rdfs:label "The -ant spelling may be found after a ‘hard c’ or ‘hard ‘g’."@en ;
  dcterms:modified "2026-02-12T08:59:21.746785Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1376-3
  a curric:KeyLearningPoint ;
  rdfs:label """Words ending in -ant sometimes have related words where the vowel sound is clearer, like with participant -participation"""@en ;
  dcterms:modified "2026-02-12T08:59:21.746789Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1376-4
  a curric:KeyLearningPoint ;
  rdfs:label """We just need to learn how to spell many words ending in -ant as there may not be a rule or pattern to help us."""@en ;
  dcterms:modified "2026-02-12T08:59:21.746793Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1376-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: relevant, knowledge and familiar."@en ;
  dcterms:modified "2026-02-12T08:59:21.746799Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1378-1
  a curric:KeyLearningPoint ;
  rdfs:label "Words that end with suffixes -ant and -ent can sound like ‘unt’ when we speak."@en ;
  dcterms:modified "2026-02-12T08:59:21.746803Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1378-2
  a curric:KeyLearningPoint ;
  rdfs:label "The -ent spelling may be found after a ‘soft c’, ‘soft ‘g’ or ‘qu’."@en ;
  dcterms:modified "2026-02-12T08:59:21.746807Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1378-3
  a curric:KeyLearningPoint ;
  rdfs:label """Words ending in -ent sometimes have related words where the ‘e’ vowel sound is clearer, like resident - residential."""@en ;
  dcterms:modified "2026-02-12T08:59:21.746813Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1378-4
  a curric:KeyLearningPoint ;
  rdfs:label "The letters ‘ent’ can also be found in the noun suffix -ment."@en ;
  dcterms:modified "2026-02-12T08:59:21.746817Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1378-5
  a curric:KeyLearningPoint ;
  rdfs:label """How to spell the curriculum words: different, excellent, experiment and equipment."""@en ;
  dcterms:modified "2026-02-12T08:59:21.746821Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6005-1
  a curric:KeyLearningPoint ;
  rdfs:label """Persuasion is the action or process of trying to change someone’s mind or behaviour."""@en ;
  dcterms:modified "2026-02-12T08:59:21.746825Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6005-2
  a curric:KeyLearningPoint ;
  rdfs:label "Persuading someone to agree with you all starts with a persuasive point."@en ;
  dcterms:modified "2026-02-12T08:59:21.746829Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6005-3
  a curric:KeyLearningPoint ;
  rdfs:label "A persuasive point is an idea or reason to support your opinion."@en ;
  dcterms:modified "2026-02-12T08:59:21.746835Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6005-4
  a curric:KeyLearningPoint ;
  rdfs:label """Points will usually contain the word ‘because’ which is used to give a reason for an opinion."""@en ;
  dcterms:modified "2026-02-12T08:59:21.746839Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5812-1
  a curric:KeyLearningPoint ;
  rdfs:label "The duel scene in Act III Scene 1 has a tense, pacy atmosphere."@en ;
  dcterms:modified "2026-02-12T08:59:21.746843Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5812-2
  a curric:KeyLearningPoint ;
  rdfs:label """When we write, we can choose vocabulary that will build this specific atmosphere."""@en ;
  dcterms:modified "2026-02-12T08:59:21.746847Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5812-3
  a curric:KeyLearningPoint ;
  rdfs:label """We will need to know vocabulary specific to duelling in order to describe it in a tense, pacy manner."""@en ;
  dcterms:modified "2026-02-12T08:59:21.746851Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5812-4
  a curric:KeyLearningPoint ;
  rdfs:label """We can also select specific vocabulary to show the characters' emotions during the duel."""@en ;
  dcterms:modified "2026-02-12T08:59:21.746855Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5812-5
  a curric:KeyLearningPoint ;
  rdfs:label "Using drama to explore vocabulary can help pupils to understand it more deeply."@en ;
  dcterms:modified "2026-02-12T08:59:21.746859Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5771-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of an editing lesson is to improve your writing and make necessary corrections."""@en ;
  dcterms:modified "2026-02-12T08:59:21.747481Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5771-2
  a curric:KeyLearningPoint ;
  rdfs:label """Vocabulary, grammar and punctuation can  be changed to make writing more effective."""@en ;
  dcterms:modified "2026-02-12T08:59:21.747487Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5771-3
  a curric:KeyLearningPoint ;
  rdfs:label "Editing is a vital element of the writing process."@en ;
  dcterms:modified "2026-02-12T08:59:21.747493Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5762-1
  a curric:KeyLearningPoint ;
  rdfs:label "The setting description describes where the narrative takes place."@en ;
  dcterms:modified "2026-02-12T08:59:21.747497Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5762-2
  a curric:KeyLearningPoint ;
  rdfs:label "Adverbial detail can be used to enhance text cohesion."@en ;
  dcterms:modified "2026-02-12T08:59:21.747501Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5762-3
  a curric:KeyLearningPoint ;
  rdfs:label """Using a range of sentence types can improve text flow, which can keep the reader engaged."""@en ;
  dcterms:modified "2026-02-12T08:59:21.747505Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5762-4
  a curric:KeyLearningPoint ;
  rdfs:label "Apostrophes can be used to indicate plural and singular possession."@en ;
  dcterms:modified "2026-02-12T08:59:21.747509Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8023-1
  a curric:KeyLearningPoint ;
  rdfs:label """There are many different forms of poetry including haikus, kenning poems and free verse."""@en ;
  dcterms:modified "2026-02-12T08:59:21.747512Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8023-2
  a curric:KeyLearningPoint ;
  rdfs:label "Free verse poems do not require the poet to follow poetic rules."@en ;
  dcterms:modified "2026-02-12T08:59:21.747516Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8023-3
  a curric:KeyLearningPoint ;
  rdfs:label "Repetition is when a single word, or group of words, is repeated for effect."@en ;
  dcterms:modified "2026-02-12T08:59:21.747520Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8023-4
  a curric:KeyLearningPoint ;
  rdfs:label "Poems can evoke a positive or negative feeling."@en ;
  dcterms:modified "2026-02-12T08:59:21.747524Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7840-1
  a curric:KeyLearningPoint ;
  rdfs:label """Non-fiction texts do not have to be read in order from the first to the last page."""@en ;
  dcterms:modified "2026-02-12T08:59:21.747528Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7840-2
  a curric:KeyLearningPoint ;
  rdfs:label """Using the features of a non-fiction text helps the reader to navigate the text effectively."""@en ;
  dcterms:modified "2026-02-12T08:59:21.747532Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7840-3
  a curric:KeyLearningPoint ;
  rdfs:label """Skimming and scanning for keywords helps the reader find and retrieve important information."""@en ;
  dcterms:modified "2026-02-12T08:59:21.747536Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7840-4
  a curric:KeyLearningPoint ;
  rdfs:label """Note-taking is an effective way to summarise the most important information and embed new knowledge."""@en ;
  dcterms:modified "2026-02-12T08:59:21.747542Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5811-1
  a curric:KeyLearningPoint ;
  rdfs:label """The conflict between the Montagues and Capulets comes to a head in Act III Scene 1."""@en ;
  dcterms:modified "2026-02-12T08:59:21.747562Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5811-2
  a curric:KeyLearningPoint ;
  rdfs:label """In this scene, Tybalt kills Mercutio and Romeo kills Tybalt in revenge, leading to his banishment from Verona."""@en ;
  dcterms:modified "2026-02-12T08:59:21.747566Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5811-3
  a curric:KeyLearningPoint ;
  rdfs:label """We can infer the meaning of Early Modern English when we know the meaning of certain key archaic terms."""@en ;
  dcterms:modified "2026-02-12T08:59:21.747569Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5811-4
  a curric:KeyLearningPoint ;
  rdfs:label """Lines in the original script also give us clues for how characters feel and think."""@en ;
  dcterms:modified "2026-02-12T08:59:21.747573Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5811-5
  a curric:KeyLearningPoint ;
  rdfs:label """When acting, we can show these emotions through our movements, tone of voice and body language."""@en ;
  dcterms:modified "2026-02-12T08:59:21.747577Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4876-1
  a curric:KeyLearningPoint ;
  rdfs:label "Information in the adaptations section is specific for the reader."@en ;
  dcterms:modified "2026-02-12T08:59:21.747581Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4876-2
  a curric:KeyLearningPoint ;
  rdfs:label """Text cohesion refers to how a piece of writing flows, engages the reader and achieves its purpose."""@en ;
  dcterms:modified "2026-02-12T08:59:21.747585Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4876-3
  a curric:KeyLearningPoint ;
  rdfs:label "Brackets can be used for parenthesis."@en ;
  dcterms:modified "2026-02-12T08:59:21.747589Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4876-4
  a curric:KeyLearningPoint ;
  rdfs:label "Planning is an essential part of the writing process."@en ;
  dcterms:modified "2026-02-12T08:59:21.747595Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4876-5
  a curric:KeyLearningPoint ;
  rdfs:label """Plans should include notes, bullet points and initial ideas that can be developed further when writing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.747599Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6369-1
  a curric:KeyLearningPoint ;
  rdfs:label "Apostrophes can be used to indicate plural and singular possession."@en ;
  dcterms:modified "2026-02-12T08:59:21.747605Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6369-2
  a curric:KeyLearningPoint ;
  rdfs:label "Figurative language can be used to create atmosphere and imagery for the reader."@en ;
  dcterms:modified "2026-02-12T08:59:21.747609Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6369-3
  a curric:KeyLearningPoint ;
  rdfs:label """Using a range of types of figurative language, as well as other linguistic devices, engages the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.747613Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6369-4
  a curric:KeyLearningPoint ;
  rdfs:label """Using a range of different sentence types enhances text cohesion and reader engagement."""@en ;
  dcterms:modified "2026-02-12T08:59:21.747619Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6369-5
  a curric:KeyLearningPoint ;
  rdfs:label "Planning, drafting, editing and rewriting are all parts of the writing process."@en ;
  dcterms:modified "2026-02-12T08:59:21.747630Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27627-1
  a curric:KeyLearningPoint ;
  rdfs:label """A debate can be led by a chairperson who introduces the speakers and keeps order."""@en ;
  dcterms:modified "2026-02-12T08:59:21.747769Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27627-2
  a curric:KeyLearningPoint ;
  rdfs:label """A debate is timed by a timekeeper so that each speaker has the same amount of time to speak."""@en ;
  dcterms:modified "2026-02-12T08:59:21.747773Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27627-3
  a curric:KeyLearningPoint ;
  rdfs:label """A point of information is a brief attempted interruption of someone’s speech and is similar to rebuttal."""@en ;
  dcterms:modified "2026-02-12T08:59:21.747778Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27892-1
  a curric:KeyLearningPoint ;
  rdfs:label "The motion is the name for the belief or proposal that is being debated."@en ;
  dcterms:modified "2026-02-12T08:59:21.747782Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27892-2
  a curric:KeyLearningPoint ;
  rdfs:label "An effective motion should be one that people can either agree or disagree with."@en ;
  dcterms:modified "2026-02-12T08:59:21.747786Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27892-3
  a curric:KeyLearningPoint ;
  rdfs:label "An effective motion should be relatable and important."@en ;
  dcterms:modified "2026-02-12T08:59:21.747790Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5815-1
  a curric:KeyLearningPoint ;
  rdfs:label "We have planned the structure, content and vocabulary for our narrative."@en ;
  dcterms:modified "2026-02-12T08:59:21.747794Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5815-2
  a curric:KeyLearningPoint ;
  rdfs:label """When we write, we use cohesive devices to connect these plan notes together into coherent sentences."""@en ;
  dcterms:modified "2026-02-12T08:59:21.747798Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5815-3
  a curric:KeyLearningPoint ;
  rdfs:label """We should aim to include all the narrative elements of action, description, dialogue and emotions in our writing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.747802Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5815-4
  a curric:KeyLearningPoint ;
  rdfs:label "Oral rehearsal prior to writing helps us to write more easily."@en ;
  dcterms:modified "2026-02-12T08:59:21.747806Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5815-5
  a curric:KeyLearningPoint ;
  rdfs:label "We can use adverbs to add detail to describe how verbs have been done."@en ;
  dcterms:modified "2026-02-12T08:59:21.747810Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2698-1
  a curric:KeyLearningPoint ;
  rdfs:label """A comma is written before "but" or "or" co-ordinating conjunctions in a compound sentence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.747814Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2698-2
  a curric:KeyLearningPoint ;
  rdfs:label """If the adverbial clause is first in an adverbial complex sentence, it is followed by a comma before the main clause."""@en ;
  dcterms:modified "2026-02-12T08:59:21.747818Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2698-3
  a curric:KeyLearningPoint ;
  rdfs:label """If the main clause is first in an adverbial complex sentence, it is not followed by a comma before the adverbial clause."""@en ;
  dcterms:modified "2026-02-12T08:59:21.747822Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2698-4
  a curric:KeyLearningPoint ;
  rdfs:label """Commas are often used to demarcate clauses in compound and complex sentence structures."""@en ;
  dcterms:modified "2026-02-12T08:59:21.747850Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2698-5
  a curric:KeyLearningPoint ;
  rdfs:label """Commas may be found in a simple sentence for other purposes than clause demarcation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.747855Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6000-1
  a curric:KeyLearningPoint ;
  rdfs:label """Persuasive letters have distinctive linguistic features in order to achieve their purpose."""@en ;
  dcterms:modified "2026-02-12T08:59:21.747859Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6000-2
  a curric:KeyLearningPoint ;
  rdfs:label """An adverbial complex sentence is a main clause and an adverbial clause that starts with a subordinating conjunction."""@en ;
  dcterms:modified "2026-02-12T08:59:21.747863Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6000-3
  a curric:KeyLearningPoint ;
  rdfs:label "The subordinating conjunction ‘because’ introduces a reason."@en ;
  dcterms:modified "2026-02-12T08:59:21.747867Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6000-4
  a curric:KeyLearningPoint ;
  rdfs:label "Oral rehearsal of full sentences helps to ensure they are structured accurately."@en ;
  dcterms:modified "2026-02-12T08:59:21.747871Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6000-5
  a curric:KeyLearningPoint ;
  rdfs:label """First person perspective is the point of view where the writer is the 'I' character."""@en ;
  dcterms:modified "2026-02-12T08:59:21.747877Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1366-1
  a curric:KeyLearningPoint ;
  rdfs:label "The suffixes -en and -ate often turns adjectives and nouns into verbs."@en ;
  dcterms:modified "2026-02-12T08:59:21.747881Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1366-2
  a curric:KeyLearningPoint ;
  rdfs:label "When the root word ends in a consonant, we often just add the suffix."@en ;
  dcterms:modified "2026-02-12T08:59:21.747886Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1366-3
  a curric:KeyLearningPoint ;
  rdfs:label """When the root word ends in a vowel, we remove the final vowel and add the suffix."""@en ;
  dcterms:modified "2026-02-12T08:59:21.747890Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1366-4
  a curric:KeyLearningPoint ;
  rdfs:label """When the root word has a short vowel, we double the consonant and add the suffix."""@en ;
  dcterms:modified "2026-02-12T08:59:21.747894Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1366-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: separate, desperate and communicate."@en ;
  dcterms:modified "2026-02-12T08:59:21.747898Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1430-1
  a curric:KeyLearningPoint ;
  rdfs:label "For some words you can add \"-s\" to turn into a plural."@en ;
  dcterms:modified "2026-02-12T08:59:21.747903Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1430-2
  a curric:KeyLearningPoint ;
  rdfs:label "For words ending in \"y\", you change the \"y\" to an \"i\" and add \"-es\"."@en ;
  dcterms:modified "2026-02-12T08:59:21.747908Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1430-3
  a curric:KeyLearningPoint ;
  rdfs:label "For words ending in \"y\" that have a vowel before the \"y\", you can just add \"s\"."@en ;
  dcterms:modified "2026-02-12T08:59:21.747912Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1430-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: early and probably."@en ;
  dcterms:modified "2026-02-12T08:59:21.747939Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7351-1
  a curric:KeyLearningPoint ;
  rdfs:label """The first paragraph of the build-up gradually conveys an eerie atmosphere, building suspense for the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.748180Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7351-2
  a curric:KeyLearningPoint ;
  rdfs:label """Precise vocabulary is used to describe sensory details and ‘show and tell’ conveys Scrooge’s emotions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.748184Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7351-3
  a curric:KeyLearningPoint ;
  rdfs:label "A range of sentence types supports text flow and the building of suspense."@en ;
  dcterms:modified "2026-02-12T08:59:21.748188Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7351-4
  a curric:KeyLearningPoint ;
  rdfs:label """Including a character’s internal thoughts communicates to the reader what a character is thinking and feeling."""@en ;
  dcterms:modified "2026-02-12T08:59:21.748192Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6556-1
  a curric:KeyLearningPoint ;
  rdfs:label "The conclusion is the final paragraph of a persuasive letter."@en ;
  dcterms:modified "2026-02-12T08:59:21.748196Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6556-2
  a curric:KeyLearningPoint ;
  rdfs:label "Information in the conclusion should be general."@en ;
  dcterms:modified "2026-02-12T08:59:21.748200Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6556-3
  a curric:KeyLearningPoint ;
  rdfs:label """Writers can use a range of cohesive devices to enhance text flow and keep the reader engaged."""@en ;
  dcterms:modified "2026-02-12T08:59:21.748204Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6556-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Yours faithfully' is an appropriate sign-off for a formal letter if the recipient is not known to the writer."""@en ;
  dcterms:modified "2026-02-12T08:59:21.748208Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6556-5
  a curric:KeyLearningPoint ;
  rdfs:label "Effective planning leads to successful writing outcomes."@en ;
  dcterms:modified "2026-02-12T08:59:21.748242Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1326-1
  a curric:KeyLearningPoint ;
  rdfs:label """Two or more words that almost sound the same but have different meanings and spellings are called near-homophones."""@en ;
  dcterms:modified "2026-02-12T08:59:21.748248Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1326-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Accept' and 'except' are near-homophones."@en ;
  dcterms:modified "2026-02-12T08:59:21.748253Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1326-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Wary' and 'weary' are near-homophones."@en ;
  dcterms:modified "2026-02-12T08:59:21.748271Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1326-4
  a curric:KeyLearningPoint ;
  rdfs:label "'Advice' and 'advise' and 'device' and 'devise' are near-homophones."@en ;
  dcterms:modified "2026-02-12T08:59:21.748302Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1326-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: recognise and category."@en ;
  dcterms:modified "2026-02-12T08:59:21.748348Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5760-1
  a curric:KeyLearningPoint ;
  rdfs:label "The closing is the final paragraph of a piece of writing."@en ;
  dcterms:modified "2026-02-12T08:59:21.748371Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5760-2
  a curric:KeyLearningPoint ;
  rdfs:label "Writers need to shift between past, present and future tense in the closing."@en ;
  dcterms:modified "2026-02-12T08:59:21.748375Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5760-3
  a curric:KeyLearningPoint ;
  rdfs:label """Using a range of linguistic features and sentence structures helps achieve text purpose and enhances cohesion."""@en ;
  dcterms:modified "2026-02-12T08:59:21.748379Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5760-4
  a curric:KeyLearningPoint ;
  rdfs:label "Using success criteria and a plan support the writer when writing."@en ;
  dcterms:modified "2026-02-12T08:59:21.748383Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3450-1
  a curric:KeyLearningPoint ;
  rdfs:label """Parenthesis can be achieved with a range of punctuation: brackets, dashes and commas."""@en ;
  dcterms:modified "2026-02-12T08:59:21.748387Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3450-2
  a curric:KeyLearningPoint ;
  rdfs:label """Any type of parenthesis is additional information that can be removed without compromising grammatical accuracy."""@en ;
  dcterms:modified "2026-02-12T08:59:21.748391Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3450-3
  a curric:KeyLearningPoint ;
  rdfs:label "Brackets are useful in non-fiction writing to add extra, factual information."@en ;
  dcterms:modified "2026-02-12T08:59:21.748395Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3450-4
  a curric:KeyLearningPoint ;
  rdfs:label "Dashes are useful in fiction writing for dramatic effect."@en ;
  dcterms:modified "2026-02-12T08:59:21.748399Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3450-5
  a curric:KeyLearningPoint ;
  rdfs:label "Commas are useful to drop information in to a clause."@en ;
  dcterms:modified "2026-02-12T08:59:21.748403Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28409-1
  a curric:KeyLearningPoint ;
  rdfs:label """A play is a written text that is intended to be read aloud and acted out by actors in a live performance."""@en ;
  dcterms:modified "2026-02-12T08:59:21.748407Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28409-2
  a curric:KeyLearningPoint ;
  rdfs:label "A play script is written by a playwright."@en ;
  dcterms:modified "2026-02-12T08:59:21.748411Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28409-3
  a curric:KeyLearningPoint ;
  rdfs:label "Plays are most often performed in theatres."@en ;
  dcterms:modified "2026-02-12T08:59:21.748415Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28409-4
  a curric:KeyLearningPoint ;
  rdfs:label """Actors read play scripts to bring them to life; directors tell actors how to speak, move and look when saying lines."""@en ;
  dcterms:modified "2026-02-12T08:59:21.748419Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28409-5
  a curric:KeyLearningPoint ;
  rdfs:label """There are certain conventions that are always written in play scripts that help the actors and the director."""@en ;
  dcterms:modified "2026-02-12T08:59:21.748422Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3447-1
  a curric:KeyLearningPoint ;
  rdfs:label "Any clause is a group of words that contains a verb."@en ;
  dcterms:modified "2026-02-12T08:59:21.748426Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3447-2
  a curric:KeyLearningPoint ;
  rdfs:label """Given that any clause contains a verb, it must contain an agent that does or is the verb."""@en ;
  dcterms:modified "2026-02-12T08:59:21.748433Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3447-3
  a curric:KeyLearningPoint ;
  rdfs:label "The noun, noun phrase or pronoun that does the verb is the subject."@en ;
  dcterms:modified "2026-02-12T08:59:21.748437Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3447-4
  a curric:KeyLearningPoint ;
  rdfs:label "Some sentences have the verb acting on another noun, noun phrase or pronoun."@en ;
  dcterms:modified "2026-02-12T08:59:21.748442Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3447-5
  a curric:KeyLearningPoint ;
  rdfs:label "The noun, noun phrase or pronoun that receives the action is the object."@en ;
  dcterms:modified "2026-02-12T08:59:21.748445Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28410-1
  a curric:KeyLearningPoint ;
  rdfs:label "A play is a written text that is acted out by actors in a live performance."@en ;
  dcterms:modified "2026-02-12T08:59:21.748727Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28410-2
  a curric:KeyLearningPoint ;
  rdfs:label """Actors, directors and a stage crew work together to prepare and rehearse a play ready for performance."""@en ;
  dcterms:modified "2026-02-12T08:59:21.748731Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28410-3
  a curric:KeyLearningPoint ;
  rdfs:label """Play script conventions help the actors and the director bring the dialogue and action to life."""@en ;
  dcterms:modified "2026-02-12T08:59:21.748737Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28410-4
  a curric:KeyLearningPoint ;
  rdfs:label """Performance techniques that help actors connect with the audience can be learnt, practised and developed."""@en ;
  dcterms:modified "2026-02-12T08:59:21.748741Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3449-1
  a curric:KeyLearningPoint ;
  rdfs:label """A fronted adverbial is a sentence starter followed by a comma that expresses time, place, manner, cause or contrast."""@en ;
  dcterms:modified "2026-02-12T08:59:21.748804Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3449-2
  a curric:KeyLearningPoint ;
  rdfs:label "A fronted adverbial can be a single word, phrase or clause."@en ;
  dcterms:modified "2026-02-12T08:59:21.748808Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3449-3
  a curric:KeyLearningPoint ;
  rdfs:label "A clause is a group of words that contains a verb."@en ;
  dcterms:modified "2026-02-12T08:59:21.748814Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3449-4
  a curric:KeyLearningPoint ;
  rdfs:label "A phrase is a group of words with no verb."@en ;
  dcterms:modified "2026-02-12T08:59:21.748818Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3449-5
  a curric:KeyLearningPoint ;
  rdfs:label "Varied fronted adverbials are useful to achieve text cohesion."@en ;
  dcterms:modified "2026-02-12T08:59:21.748822Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1382-1
  a curric:KeyLearningPoint ;
  rdfs:label """Two or more words that sound the same but have different meanings and spellings are called homophones."""@en ;
  dcterms:modified "2026-02-12T08:59:21.748826Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1382-2
  a curric:KeyLearningPoint ;
  rdfs:label """We can use the context of a sentence to figure out the spelling of the homophone."""@en ;
  dcterms:modified "2026-02-12T08:59:21.748830Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1382-3
  a curric:KeyLearningPoint ;
  rdfs:label "There are no spelling rules for homophones so we must learn them by sight."@en ;
  dcterms:modified "2026-02-12T08:59:21.748834Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1382-4
  a curric:KeyLearningPoint ;
  rdfs:label "We can look for naughty letters to help us to remember tricky spellings."@en ;
  dcterms:modified "2026-02-12T08:59:21.748838Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1382-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: century, breath and breathe."@en ;
  dcterms:modified "2026-02-12T08:59:21.748842Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8041-1
  a curric:KeyLearningPoint ;
  rdfs:label """Poetry comes in many different forms and can be written by a variety of different people."""@en ;
  dcterms:modified "2026-02-12T08:59:21.748846Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8041-2
  a curric:KeyLearningPoint ;
  rdfs:label """Grace Nichols, the author and poet, was born in Guyana in the Caribbean and moved to live in the UK in 1977."""@en ;
  dcterms:modified "2026-02-12T08:59:21.748849Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8041-3
  a curric:KeyLearningPoint ;
  rdfs:label "‘Cosmic Disco’ is linked to the science of the stars and the universe."@en ;
  dcterms:modified "2026-02-12T08:59:21.748853Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8041-4
  a curric:KeyLearningPoint ;
  rdfs:label "Poetry can communicate a sense of awe and wonder in the natural world."@en ;
  dcterms:modified "2026-02-12T08:59:21.748857Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1448-1
  a curric:KeyLearningPoint ;
  rdfs:label """A prefix is a letter or group of letters at the start of a word which creates another word."""@en ;
  dcterms:modified "2026-02-12T08:59:21.748861Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1448-2
  a curric:KeyLearningPoint ;
  rdfs:label """un-, non-, dis- and mis- can be added to the beginning of a word without changing the spelling of the root word."""@en ;
  dcterms:modified "2026-02-12T08:59:21.748865Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1448-3
  a curric:KeyLearningPoint ;
  rdfs:label "The prefixes un-, non- and dis- usually mean not."@en ;
  dcterms:modified "2026-02-12T08:59:21.748869Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1448-4
  a curric:KeyLearningPoint ;
  rdfs:label "The prefix mis- usually means wrongly."@en ;
  dcterms:modified "2026-02-12T08:59:21.748873Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1448-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum word: question."@en ;
  dcterms:modified "2026-02-12T08:59:21.748879Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7356-1
  a curric:KeyLearningPoint ;
  rdfs:label "Retrieval involves identifying and extracting key information from the text."@en ;
  dcterms:modified "2026-02-12T08:59:21.749000Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7356-2
  a curric:KeyLearningPoint ;
  rdfs:label """Searching for keywords or specific types of words can support readers in answering retrieval questions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.749004Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7356-3
  a curric:KeyLearningPoint ;
  rdfs:label """When a reader infers, they use clues from the text and their own understanding to ‘read between the lines’."""@en ;
  dcterms:modified "2026-02-12T08:59:21.749008Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7356-4
  a curric:KeyLearningPoint ;
  rdfs:label "Inferring helps readers establish an impression of a character."@en ;
  dcterms:modified "2026-02-12T08:59:21.749014Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7354-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the climax is to describe the main action and take the suspense to its highest point."""@en ;
  dcterms:modified "2026-02-12T08:59:21.749046Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7354-2
  a curric:KeyLearningPoint ;
  rdfs:label """The climax of ‘A Christmas Carol’ describes Scrooge’s encounter with the Ghost of Christmas Yet to Come (Future)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.749050Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7354-3
  a curric:KeyLearningPoint ;
  rdfs:label """Scrooge feels great regret and sorrow upon seeing the future visions and realises he must change his ways."""@en ;
  dcterms:modified "2026-02-12T08:59:21.749055Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7354-4
  a curric:KeyLearningPoint ;
  rdfs:label """Precise and descriptive vocabulary, including 'show and tell' is used to convey an ominous atmosphere."""@en ;
  dcterms:modified "2026-02-12T08:59:21.749059Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7354-5
  a curric:KeyLearningPoint ;
  rdfs:label """Direct speech and Scrooge’s inner thoughts are used to convey Scrooge’s fraught emotions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.749062Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1332-1
  a curric:KeyLearningPoint ;
  rdfs:label "Adding -s or -es to a noun creates a plural."@en ;
  dcterms:modified "2026-02-12T08:59:21.749069Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1332-2
  a curric:KeyLearningPoint ;
  rdfs:label "If the word ends in a vowel (a, e, i, u) or consonant, just add -s."@en ;
  dcterms:modified "2026-02-12T08:59:21.749075Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1332-3
  a curric:KeyLearningPoint ;
  rdfs:label "If the word ends in 'y' preceded by a vowel, just add -s."@en ;
  dcterms:modified "2026-02-12T08:59:21.749079Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1332-4
  a curric:KeyLearningPoint ;
  rdfs:label "If the word ends in 'y' preceded by a consonant, remove the 'y' and add -ies."@en ;
  dcterms:modified "2026-02-12T08:59:21.749083Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1332-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: harass and recommend."@en ;
  dcterms:modified "2026-02-12T08:59:21.749087Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6363-1
  a curric:KeyLearningPoint ;
  rdfs:label """The closing paragraph of a journalistic report provides the reader with information about what is currently happening."""@en ;
  dcterms:modified "2026-02-12T08:59:21.749090Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6363-2
  a curric:KeyLearningPoint ;
  rdfs:label """A shift to present tense is a key linguistic feature of the closing of a journalistic report."""@en ;
  dcterms:modified "2026-02-12T08:59:21.749094Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6363-3
  a curric:KeyLearningPoint ;
  rdfs:label """Adverbial complex sentences can be used to tell the reader about two things happening at the same time."""@en ;
  dcterms:modified "2026-02-12T08:59:21.749098Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6363-4
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials of time support in communicating the tense shift to the reader and closing the report."""@en ;
  dcterms:modified "2026-02-12T08:59:21.749102Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6360-1
  a curric:KeyLearningPoint ;
  rdfs:label """The recount section of a journalistic report provides specific details about a news event in chronological order."""@en ;
  dcterms:modified "2026-02-12T08:59:21.749106Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6360-2
  a curric:KeyLearningPoint ;
  rdfs:label "The use of notes from a plan support in the writing process."@en ;
  dcterms:modified "2026-02-12T08:59:21.749109Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6360-3
  a curric:KeyLearningPoint ;
  rdfs:label """Formal journalistic language and subject-specific vocabulary is crucial for creating an objective and serious tone."""@en ;
  dcterms:modified "2026-02-12T08:59:21.749113Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6360-4
  a curric:KeyLearningPoint ;
  rdfs:label """The use of fronted adverbials of time supports in communicating the timeline of events to the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.749117Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6360-5
  a curric:KeyLearningPoint ;
  rdfs:label """The use of adverbial and relative complex sentences supports in providing greater detail and facts for the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.749121Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1459-1
  a curric:KeyLearningPoint ;
  rdfs:label """The pronunciation of a word helps to identify if it is spelt with -sure or -ture."""@en ;
  dcterms:modified "2026-02-12T08:59:21.749125Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1459-2
  a curric:KeyLearningPoint ;
  rdfs:label """The -ture ending to a word can be confused with a root word ending in '(t)ch+er', such as 'teacher' or 'richer'."""@en ;
  dcterms:modified "2026-02-12T08:59:21.749129Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1459-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Colour blocking' is a useful practice strategy."@en ;
  dcterms:modified "2026-02-12T08:59:21.749132Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1459-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum word: grammar."@en ;
  dcterms:modified "2026-02-12T08:59:21.749136Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6008-1
  a curric:KeyLearningPoint ;
  rdfs:label """A written argument tries to convince the reader of something using strong reasoning to support."""@en ;
  dcterms:modified "2026-02-12T08:59:21.749140Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6008-2
  a curric:KeyLearningPoint ;
  rdfs:label "The PEPS structure stands for: point, explanation, proof, summary."@en ;
  dcterms:modified "2026-02-12T08:59:21.749146Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6008-3
  a curric:KeyLearningPoint ;
  rdfs:label "When we write a plan, we use notes."@en ;
  dcterms:modified "2026-02-12T08:59:21.749150Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4877-1
  a curric:KeyLearningPoint ;
  rdfs:label "Information in the adaptations section is specific for the reader."@en ;
  dcterms:modified "2026-02-12T08:59:21.749155Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4877-2
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials, subject-specific vocabulary, relative complex sentences and parenthesis enhance text cohesion."""@en ;
  dcterms:modified "2026-02-12T08:59:21.749158Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4877-3
  a curric:KeyLearningPoint ;
  rdfs:label """Parenthesis is additional information added to the sentence that can be demarcated using a pair of brackets."""@en ;
  dcterms:modified "2026-02-12T08:59:21.749162Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4877-4
  a curric:KeyLearningPoint ;
  rdfs:label "Plans should be used when writing to generate initial ideas and build upon them."@en ;
  dcterms:modified "2026-02-12T08:59:21.749167Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4877-5
  a curric:KeyLearningPoint ;
  rdfs:label "Success criteria help us understand what to include in our writing."@en ;
  dcterms:modified "2026-02-12T08:59:21.749171Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1367-1
  a curric:KeyLearningPoint ;
  rdfs:label "The suffixes -ise and -ify often turn adjectives and nouns into verbs."@en ;
  dcterms:modified "2026-02-12T08:59:21.749174Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1367-2
  a curric:KeyLearningPoint ;
  rdfs:label "When the root word ends in a consonant, we often just add the suffix."@en ;
  dcterms:modified "2026-02-12T08:59:21.749178Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1367-3
  a curric:KeyLearningPoint ;
  rdfs:label "When the root word ends in a ‘y’, we remove the ‘y’ and add the suffix."@en ;
  dcterms:modified "2026-02-12T08:59:21.749184Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1367-4
  a curric:KeyLearningPoint ;
  rdfs:label """When the root word ends in a vowel, we remove the final vowel and add the suffix."""@en ;
  dcterms:modified "2026-02-12T08:59:21.749188Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1367-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: exercise, criticise and consider."@en ;
  dcterms:modified "2026-02-12T08:59:21.749192Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1312-1
  a curric:KeyLearningPoint ;
  rdfs:label "The suffix -ous often turns nouns into adjectives and often means 'full of'."@en ;
  dcterms:modified "2026-02-12T08:59:21.749199Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1312-2
  a curric:KeyLearningPoint ;
  rdfs:label "There are four key rules when adding the suffix -ous to a root word."@en ;
  dcterms:modified "2026-02-12T08:59:21.749203Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1312-3
  a curric:KeyLearningPoint ;
  rdfs:label """When you hear the ‘ee’ sound before -ous, the most likely spelling is an ‘i’, but it is sometimes an ‘e’."""@en ;
  dcterms:modified "2026-02-12T08:59:21.749206Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1312-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: learn, group and earth."@en ;
  dcterms:modified "2026-02-12T08:59:21.749210Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6590-1
  a curric:KeyLearningPoint ;
  rdfs:label """When preparing to write a biography, it is important to thoroughly research the person we are writing about."""@en ;
  dcterms:modified "2026-02-12T08:59:21.749638Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6590-2
  a curric:KeyLearningPoint ;
  rdfs:label """Biographies usually share information about the person's life in chronological order."""@en ;
  dcterms:modified "2026-02-12T08:59:21.749644Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6590-3
  a curric:KeyLearningPoint ;
  rdfs:label """Recording information in chronological order helps the reader understand how different events are related & sequenced."""@en ;
  dcterms:modified "2026-02-12T08:59:21.749647Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1336-1
  a curric:KeyLearningPoint ;
  rdfs:label "The /shun/ sound spelt -tion is the most common spelling."@en ;
  dcterms:modified "2026-02-12T08:59:21.749651Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1336-2
  a curric:KeyLearningPoint ;
  rdfs:label "The /shun/ sound spelt -tion is used when the root word ends with 't' or 'te'."@en ;
  dcterms:modified "2026-02-12T08:59:21.749656Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1336-3
  a curric:KeyLearningPoint ;
  rdfs:label "The /shun/ sound spelt -cian is used for jobs, e.g. politician, mathematician."@en ;
  dcterms:modified "2026-02-12T08:59:21.749660Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1336-4
  a curric:KeyLearningPoint ;
  rdfs:label """The /shun/ sound spelt -cian is used when the root words ends in 'c' or 'cs' e.g. politics-politician."""@en ;
  dcterms:modified "2026-02-12T08:59:21.749664Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1336-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: competition and bargain."@en ;
  dcterms:modified "2026-02-12T08:59:21.749668Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4886-1
  a curric:KeyLearningPoint ;
  rdfs:label "A subheading signals to the reader what the section is about."@en ;
  dcterms:modified "2026-02-12T08:59:21.749672Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4886-2
  a curric:KeyLearningPoint ;
  rdfs:label "The steps in the mummification process are written in chronological order."@en ;
  dcterms:modified "2026-02-12T08:59:21.749678Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4886-3
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials of cause and formal fronted adverbials are used at the start of sentences for cohesion."""@en ;
  dcterms:modified "2026-02-12T08:59:21.749682Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4886-4
  a curric:KeyLearningPoint ;
  rdfs:label """Using the full range of sentence types (simple, compound and complex) improves text flow for the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.749686Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4886-5
  a curric:KeyLearningPoint ;
  rdfs:label """Explanation texts include subject-specific vocabulary that is related to the subject of the text."""@en ;
  dcterms:modified "2026-02-12T08:59:21.749692Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27608-1
  a curric:KeyLearningPoint ;
  rdfs:label """Telling a story in a charismatic way helps to engage the audience and hold their interest in a narrative throughout."""@en ;
  dcterms:modified "2026-02-12T08:59:21.749697Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27608-2
  a curric:KeyLearningPoint ;
  rdfs:label "Using expression will help make your story interesting to listen to."@en ;
  dcterms:modified "2026-02-12T08:59:21.749701Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27608-3
  a curric:KeyLearningPoint ;
  rdfs:label """Facial expressions can convey a character’s feelings in response to events in the story."""@en ;
  dcterms:modified "2026-02-12T08:59:21.749705Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27608-4
  a curric:KeyLearningPoint ;
  rdfs:label """Using body language and gestures to engage an audience will help to keep their attention."""@en ;
  dcterms:modified "2026-02-12T08:59:21.749709Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27608-5
  a curric:KeyLearningPoint ;
  rdfs:label """Using a varied tone and different voices for characters will engage the audience and make the story easier to follow."""@en ;
  dcterms:modified "2026-02-12T08:59:21.749712Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1305-1
  a curric:KeyLearningPoint ;
  rdfs:label "Adding the suffix -ing turns the verb into the progressive tense."@en ;
  dcterms:modified "2026-02-12T08:59:21.749716Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1305-2
  a curric:KeyLearningPoint ;
  rdfs:label """When the vowel sound is short with only one consonant after it,  double the consonant and add the suffix -ing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.749720Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1305-3
  a curric:KeyLearningPoint ;
  rdfs:label """When the vowel sound is short with more than one consonant after the vowel sound, just add the suffix -ing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.749724Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1305-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: though, although and through."@en ;
  dcterms:modified "2026-02-12T08:59:21.749728Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7852-1
  a curric:KeyLearningPoint ;
  rdfs:label """A similarity is a feature or aspect that has some resemblance to something else, without being identical."""@en ;
  dcterms:modified "2026-02-12T08:59:21.749732Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7852-2
  a curric:KeyLearningPoint ;
  rdfs:label """A difference is a feature or aspect that has a distinct or discernible feature that sets it apart from something else."""@en ;
  dcterms:modified "2026-02-12T08:59:21.749738Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7852-3
  a curric:KeyLearningPoint ;
  rdfs:label """Comparing two contexts, provides readers with an in-depth understanding of Walter's life."""@en ;
  dcterms:modified "2026-02-12T08:59:21.749742Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1425-1
  a curric:KeyLearningPoint ;
  rdfs:label """A suffix is a letter or group of letters at the end of a word which creates another word."""@en ;
  dcterms:modified "2026-02-12T08:59:21.749748Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1425-2
  a curric:KeyLearningPoint ;
  rdfs:label "-ed is a suffix that can be used to create the past tense."@en ;
  dcterms:modified "2026-02-12T08:59:21.749752Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1425-3
  a curric:KeyLearningPoint ;
  rdfs:label "If the verb has a short vowel, double the consonant and add -ed."@en ;
  dcterms:modified "2026-02-12T08:59:21.749756Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1425-4
  a curric:KeyLearningPoint ;
  rdfs:label """Change 'y' to 'i' and add –ed (common rule – unless vowel before ‘y’, e.g. enjoy-enjoyed)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.749760Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1425-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum word: busy."@en ;
  dcterms:modified "2026-02-12T08:59:21.749764Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7358-1
  a curric:KeyLearningPoint ;
  rdfs:label """After visits from the three ghosts, Scrooge reflects on his transformation and feels grateful for this second chance."""@en ;
  dcterms:modified "2026-02-12T08:59:21.750202Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7358-2
  a curric:KeyLearningPoint ;
  rdfs:label """He embraces the spirit of Christmas and treats all those around him with kindness and generosity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.750206Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7358-3
  a curric:KeyLearningPoint ;
  rdfs:label "He accepts Fred’s offer to dinner and promises Bob money and support."@en ;
  dcterms:modified "2026-02-12T08:59:21.750210Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7358-4
  a curric:KeyLearningPoint ;
  rdfs:label "Scrooge’s transformation has a big impact on Bob and his family."@en ;
  dcterms:modified "2026-02-12T08:59:21.750213Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1438-1
  a curric:KeyLearningPoint ;
  rdfs:label """-ly is a suffix that can be used to create adverbs.  For most words just add -ly."""@en ;
  dcterms:modified "2026-02-12T08:59:21.750218Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1438-2
  a curric:KeyLearningPoint ;
  rdfs:label "For words ending in 'ic' add -ally."@en ;
  dcterms:modified "2026-02-12T08:59:21.750222Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1438-3
  a curric:KeyLearningPoint ;
  rdfs:label "For two syllablle root words ending in 'y', remove the 'y', add -ily."@en ;
  dcterms:modified "2026-02-12T08:59:21.750225Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1438-4
  a curric:KeyLearningPoint ;
  rdfs:label "For root words ending in 'le', remove the 'le', add -ly."@en ;
  dcterms:modified "2026-02-12T08:59:21.750229Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1438-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum word: build."@en ;
  dcterms:modified "2026-02-12T08:59:21.750233Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2711-1
  a curric:KeyLearningPoint ;
  rdfs:label "A fronted adverbial is a sentence starter that is followed by a comma."@en ;
  dcterms:modified "2026-02-12T08:59:21.750237Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2711-2
  a curric:KeyLearningPoint ;
  rdfs:label "A fronted adverbial can be a single word."@en ;
  dcterms:modified "2026-02-12T08:59:21.750241Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2711-3
  a curric:KeyLearningPoint ;
  rdfs:label "A fronted adverbial can be a phrase."@en ;
  dcterms:modified "2026-02-12T08:59:21.750245Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2711-4
  a curric:KeyLearningPoint ;
  rdfs:label "A phrase is a group of words with no verb."@en ;
  dcterms:modified "2026-02-12T08:59:21.750251Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2711-5
  a curric:KeyLearningPoint ;
  rdfs:label "A fronted adverbial can express detail about time, place or manner."@en ;
  dcterms:modified "2026-02-12T08:59:21.750255Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1417-1
  a curric:KeyLearningPoint ;
  rdfs:label """Words that contain the /g/ sound spelt 'gue' often come from the French language."""@en ;
  dcterms:modified "2026-02-12T08:59:21.750259Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1417-2
  a curric:KeyLearningPoint ;
  rdfs:label """Words that contain the /k/ sound spelt 'que' often come from the French language."""@en ;
  dcterms:modified "2026-02-12T08:59:21.750263Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1417-3
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: increase, extreme and surprise."@en ;
  dcterms:modified "2026-02-12T08:59:21.750267Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4853-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of a recount paragraph is to give the reader specific information about an aspect of the topic."""@en ;
  dcterms:modified "2026-02-12T08:59:21.750271Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4853-2
  a curric:KeyLearningPoint ;
  rdfs:label """Non-finite complex sentences are formed of a main clause and a non-finite subordinate clause."""@en ;
  dcterms:modified "2026-02-12T08:59:21.750274Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4853-3
  a curric:KeyLearningPoint ;
  rdfs:label "Varying sentence types and structure enhance text cohesion."@en ;
  dcterms:modified "2026-02-12T08:59:21.750278Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4853-4
  a curric:KeyLearningPoint ;
  rdfs:label "When we plan, bullet points are used that are written in note form."@en ;
  dcterms:modified "2026-02-12T08:59:21.750282Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1395-1
  a curric:KeyLearningPoint ;
  rdfs:label """A prefix is a letter or group of letters at the start of a word which changes its meaning."""@en ;
  dcterms:modified "2026-02-12T08:59:21.750451Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1395-2
  a curric:KeyLearningPoint ;
  rdfs:label "Adding a prefix does not alter the spelling of the root word."@en ;
  dcterms:modified "2026-02-12T08:59:21.750454Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1395-3
  a curric:KeyLearningPoint ;
  rdfs:label """There are many prefixes that can mean ‘not’, including un-, dis-, in-, il-, im- and ir-."""@en ;
  dcterms:modified "2026-02-12T08:59:21.750458Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1395-4
  a curric:KeyLearningPoint ;
  rdfs:label """The prefix in- can also mean ‘in’ or ‘into’ and the prefix mis- usually means 'wrongly'."""@en ;
  dcterms:modified "2026-02-12T08:59:21.750462Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1395-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: immediate, immediately and disappear."@en ;
  dcterms:modified "2026-02-12T08:59:21.750466Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2733-1
  a curric:KeyLearningPoint ;
  rdfs:label """Any subordinate clause is a group of words that contains a verb and does not make complete sense."""@en ;
  dcterms:modified "2026-02-12T08:59:21.750470Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2733-2
  a curric:KeyLearningPoint ;
  rdfs:label "Any subordinate clause must join to a main clause to make sense."@en ;
  dcterms:modified "2026-02-12T08:59:21.750474Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2733-3
  a curric:KeyLearningPoint ;
  rdfs:label "A non-finite clause is a type of subordinate clause."@en ;
  dcterms:modified "2026-02-12T08:59:21.750480Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2733-4
  a curric:KeyLearningPoint ;
  rdfs:label """A non-finite clause can start with a verb in the progressive tense that denotes ongoing action."""@en ;
  dcterms:modified "2026-02-12T08:59:21.750484Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2733-5
  a curric:KeyLearningPoint ;
  rdfs:label """The previously-learnt types of subordinate clause are the adverbial clause and the relative clause."""@en ;
  dcterms:modified "2026-02-12T08:59:21.750488Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2737-1
  a curric:KeyLearningPoint ;
  rdfs:label "Determiners are a word class."@en ;
  dcterms:modified "2026-02-12T08:59:21.750492Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2737-2
  a curric:KeyLearningPoint ;
  rdfs:label "A determiner introduces a noun in a clause."@en ;
  dcterms:modified "2026-02-12T08:59:21.750496Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2737-3
  a curric:KeyLearningPoint ;
  rdfs:label "Determiners can be articles or possessive pronouns."@en ;
  dcterms:modified "2026-02-12T08:59:21.750500Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2737-4
  a curric:KeyLearningPoint ;
  rdfs:label "Determiners can be quantifiers."@en ;
  dcterms:modified "2026-02-12T08:59:21.750504Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2737-5
  a curric:KeyLearningPoint ;
  rdfs:label "Determiners can be demonstratives."@en ;
  dcterms:modified "2026-02-12T08:59:21.750507Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3451-1
  a curric:KeyLearningPoint ;
  rdfs:label "Words can be related to each other by common features, patterns or meaning."@en ;
  dcterms:modified "2026-02-12T08:59:21.750511Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3451-2
  a curric:KeyLearningPoint ;
  rdfs:label """Synonyms and antonyms can be used by writers to vary vocabulary choice and create text cohesion."""@en ;
  dcterms:modified "2026-02-12T08:59:21.750515Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3451-3
  a curric:KeyLearningPoint ;
  rdfs:label "All words have etymology."@en ;
  dcterms:modified "2026-02-12T08:59:21.750519Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3451-4
  a curric:KeyLearningPoint ;
  rdfs:label "Adverbs can describe verbs or adjectives."@en ;
  dcterms:modified "2026-02-12T08:59:21.750523Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3451-5
  a curric:KeyLearningPoint ;
  rdfs:label "Prepositions and adverbs have more than one purpose."@en ;
  dcterms:modified "2026-02-12T08:59:21.750527Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7841-1
  a curric:KeyLearningPoint ;
  rdfs:label """Navigating the features of a non-fiction text can help you read and retrieve information on a specific topic."""@en ;
  dcterms:modified "2026-02-12T08:59:21.750531Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7841-2
  a curric:KeyLearningPoint ;
  rdfs:label """Skimming and scanning for keywords can help you accurately retrieve information from the text quickly."""@en ;
  dcterms:modified "2026-02-12T08:59:21.750535Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7841-3
  a curric:KeyLearningPoint ;
  rdfs:label """Searching for capital letters helps to find proper nouns quicker, e.g. 'Ganges River'."""@en ;
  dcterms:modified "2026-02-12T08:59:21.750539Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7841-4
  a curric:KeyLearningPoint ;
  rdfs:label "Rivers are an important part of life for people around the world."@en ;
  dcterms:modified "2026-02-12T08:59:21.750543Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7841-5
  a curric:KeyLearningPoint ;
  rdfs:label """Rivers are used by humans for a variety of purposes and some have a special meaning to religious groups."""@en ;
  dcterms:modified "2026-02-12T08:59:21.750547Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1052-1
  a curric:KeyLearningPoint ;
  rdfs:label "An apostrophe is an important piece of punctuation with more than one purpose."@en ;
  dcterms:modified "2026-02-12T08:59:21.750553Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1052-2
  a curric:KeyLearningPoint ;
  rdfs:label "An apostrophe can contract two words together."@en ;
  dcterms:modified "2026-02-12T08:59:21.750557Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1052-3
  a curric:KeyLearningPoint ;
  rdfs:label "An apostrophe can show if a noun belongs to another singular noun."@en ;
  dcterms:modified "2026-02-12T08:59:21.750561Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1052-4
  a curric:KeyLearningPoint ;
  rdfs:label """Apostrophes for contraction and singular possession are useful in writing for different reasons."""@en ;
  dcterms:modified "2026-02-12T08:59:21.750567Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1052-5
  a curric:KeyLearningPoint ;
  rdfs:label "Apostrophes are most deeply understood when word class is understood."@en ;
  dcterms:modified "2026-02-12T08:59:21.750573Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1419-1
  a curric:KeyLearningPoint ;
  rdfs:label """When there are two of the same consonants beside each other, we call this a double consonant."""@en ;
  dcterms:modified "2026-02-12T08:59:21.750578Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1419-2
  a curric:KeyLearningPoint ;
  rdfs:label "Double consonants are often found after short vowel sounds."@en ;
  dcterms:modified "2026-02-12T08:59:21.750584Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1419-3
  a curric:KeyLearningPoint ;
  rdfs:label "Contrasting words are pairs or sets of words that have very similar spellings."@en ;
  dcterms:modified "2026-02-12T08:59:21.750588Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1419-4
  a curric:KeyLearningPoint ;
  rdfs:label """Contrasting words are often different because one has a double consonant, which impacts the pronunciation of the word."""@en ;
  dcterms:modified "2026-02-12T08:59:21.750592Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1419-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: remember, medicine and address."@en ;
  dcterms:modified "2026-02-12T08:59:21.750595Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6149-1
  a curric:KeyLearningPoint ;
  rdfs:label "The purpose of the build-up is to build up suspense and excitement."@en ;
  dcterms:modified "2026-02-12T08:59:21.750599Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6149-2
  a curric:KeyLearningPoint ;
  rdfs:label "Precise and ambitious vocabulary is logged on a plan for future use."@en ;
  dcterms:modified "2026-02-12T08:59:21.750603Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6149-3
  a curric:KeyLearningPoint ;
  rdfs:label """Notes should not be written in full sentences and bullet points can be used to make notes clear."""@en ;
  dcterms:modified "2026-02-12T08:59:21.750607Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6149-4
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials of time, place and manner indicate when, where and how action takes place."""@en ;
  dcterms:modified "2026-02-12T08:59:21.750611Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6149-5
  a curric:KeyLearningPoint ;
  rdfs:label """'Show-not-tell' language shows a character’s feelings by describing their actions, body language and facial expressions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.750615Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4855-1
  a curric:KeyLearningPoint ;
  rdfs:label """The quotes paragraph is used to share information from people who were at the scene or know more about the event."""@en ;
  dcterms:modified "2026-02-12T08:59:21.750619Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4855-2
  a curric:KeyLearningPoint ;
  rdfs:label "Quotes add credibility to a journalistic report."@en ;
  dcterms:modified "2026-02-12T08:59:21.750623Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4855-3
  a curric:KeyLearningPoint ;
  rdfs:label "Quotes can be written in the form of direct speech or reported speech."@en ;
  dcterms:modified "2026-02-12T08:59:21.750627Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4855-4
  a curric:KeyLearningPoint ;
  rdfs:label "Extra information can be given about the speaker in the reporting clause."@en ;
  dcterms:modified "2026-02-12T08:59:21.750632Z"^^xsd:dateTime .

