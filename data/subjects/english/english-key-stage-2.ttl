  a curric:KeyLearningPoint ;
  rdfs:label """An adverbial complex sentence is a sentence formed of a main clause and an adverbial subordinate clause."""@en ;
  dcterms:modified "2026-02-12T08:59:21.613245Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5693-1
  a curric:KeyLearningPoint ;
  rdfs:label """Narrative writing can be structured into an opening, a build-up, a climax and a resolution."""@en ;
