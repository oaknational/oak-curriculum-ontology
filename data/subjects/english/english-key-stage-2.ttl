    oakcurric:priorknowledge-302-7 ;
  curric:id "302"^^xsd:positiveInteger;
  dcterms:modified "2026-06-07T15:29:24.608534Z"^^xsd:dateTime ;
  curric:isUnitOf
    natcurric:scheme-english-key-stage-2 ;
  curric:includesThread
    oakcurric:thread-reading-and-writing-texts-that-inform .

oakcurric:unit-137
  a curric:Unit ;
  rdfs:label "More suffixes and silent letters"@en ;
  curric:slug "more-suffixes-and-silent-letters" ;
  rdfs:comment """In this unit, pupils learn spelling and grammar conventions used with the suffixes
  -ly, -ful and -less, as well as the spelling of words with silent letters. Pupils will
  learn how the addition of a suffix can affect the grammar of a word, for example its word
  class or tense."""@en ;
  curric:whyThisWhyNow """This unit uses and builds on pupils' knowledge of spelling rules
  associated with -ed and -ing suffixes learnt in the Year 3 unit 'Writing -ed and -ing
  suffixes'. Here, pupils learn new spelling and grammar conventions used with the suffixes
  -ly, -ful and -less, as well as the spelling of words with silent letters, applying new
  spellings in a sentence context. They review how the addition of a suffix can affect the
  grammar of a word, for example by changing its word class or tense. This unit prepares pupils
  for further suffix work in the Year 4 unit 'Year 4: Verb and adjective suffixes'.""" ;
  curric:hasPriorKnowledgeRequirement
    oakcurric:priorknowledge-137-1 ,
    oakcurric:priorknowledge-137-2 ,
    oakcurric:priorknowledge-137-3 ,
