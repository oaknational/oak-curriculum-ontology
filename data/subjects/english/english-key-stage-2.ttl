oakcurric:keylearningpoint-lesson-8031-3
  a curric:KeyLearningPoint ;
  rdfs:label "A poet is the name for someone who writes poems."@en ;
  dcterms:modified "2026-02-12T08:59:21.620695Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8031-4
  a curric:KeyLearningPoint ;
  rdfs:label "John Lyons has published eight poetry collections."@en ;
  dcterms:modified "2026-02-12T08:59:21.620700Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8032-1
  a curric:KeyLearningPoint ;
  rdfs:label """Reading and rereading poems leads to a richer response and a greater understanding of language within the poem."""@en ;
  dcterms:modified "2026-02-12T08:59:21.620784Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8032-2
  a curric:KeyLearningPoint ;
  rdfs:label """The structure of a poem plays a crucial role in conveying the poet's message and evoking emotions in the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.620789Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8032-3
  a curric:KeyLearningPoint ;
  rdfs:label """Language is how a poet expresses emotions, ideas and experiences using imagery, simile and other literary devices."""@en ;
  dcterms:modified "2026-02-12T08:59:21.620795Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8032-4
  a curric:KeyLearningPoint ;
  rdfs:label "A theme is a big idea, topic or message that recurs in a poem."@en ;
  dcterms:modified "2026-02-12T08:59:21.620801Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8032-5
  a curric:KeyLearningPoint ;
  rdfs:label """Engaging in conversations about poems allows us to make connections with our own lives and the world around us."""@en ;
  dcterms:modified "2026-02-12T08:59:21.620807Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8108-1
  a curric:KeyLearningPoint ;
  rdfs:label """Oral presentation is an important part of selling a product and persuading an audience."""@en ;
  dcterms:modified "2026-02-12T08:59:21.620813Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8108-2
  a curric:KeyLearningPoint ;
  rdfs:label """Projection, pace and diction are important for ensuring the audience can hear and understand you."""@en ;
  dcterms:modified "2026-02-12T08:59:21.620818Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8108-3
  a curric:KeyLearningPoint ;
  rdfs:label """Eye contact, body languge and intonation are important for connecting to the audience and engaging them."""@en ;
  dcterms:modified "2026-02-12T08:59:21.620824Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8108-4
  a curric:KeyLearningPoint ;
  rdfs:label """Reading over our writing and rehearsing supports successful delivery of a presentation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.620830Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8034-1
  a curric:KeyLearningPoint ;
  rdfs:label "Poets use vivid description to create imagery."@en ;
  dcterms:modified "2026-02-12T08:59:21.620836Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8034-2
  a curric:KeyLearningPoint ;
  rdfs:label """Poets may choose to use figurative language such as personification to bring their poem to life."""@en ;
  dcterms:modified "2026-02-12T08:59:21.620842Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8034-3
  a curric:KeyLearningPoint ;
  rdfs:label """Reading and rereading a poem leads to a richer response and a greater understanding of language within the poem."""@en ;
  dcterms:modified "2026-02-12T08:59:21.620847Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8034-4
  a curric:KeyLearningPoint ;
  rdfs:label """Engaging in conversations about poems allows us to make connections with our own lives and the world around us."""@en ;
  dcterms:modified "2026-02-12T08:59:21.620853Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8034-5
  a curric:KeyLearningPoint ;
  rdfs:label "A theme is a big idea, topic or message that recurs in a poem."@en ;
  dcterms:modified "2026-02-12T08:59:21.620875Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8463-1
  a curric:KeyLearningPoint ;
  rdfs:label "‘The BFG’ is a fiction text that was published in 1982."@en ;
  dcterms:modified "2026-02-12T08:59:21.620944Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8463-2
  a curric:KeyLearningPoint ;
  rdfs:label """‘The BFG’ was written by Roald Dahl (1916-1990) and he is a famous children’s author."""@en ;
  dcterms:modified "2026-02-12T08:59:21.620950Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8463-3
  a curric:KeyLearningPoint ;
  rdfs:label "The protagonists in ‘The BFG’ are Sophie, a young orphan, and the BFG."@en ;
  dcterms:modified "2026-02-12T08:59:21.620955Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8463-4
  a curric:KeyLearningPoint ;
  rdfs:label "The main settings of ‘The BFG’ are the orphanage, Giant World and Dream World."@en ;
  dcterms:modified "2026-02-12T08:59:21.620961Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8463-5
  a curric:KeyLearningPoint ;
  rdfs:label """Summarising the key events in a story helps us to build our understanding of the text and the meaning behind it."""@en ;
  dcterms:modified "2026-02-12T08:59:21.620971Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7892-1
  a curric:KeyLearningPoint ;
  rdfs:label """'The Listeners' by Walter de la Mare is a thirty-six line poem which is separated into 5 sentences."""@en ;
  dcterms:modified "2026-02-12T08:59:21.621021Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7892-2
  a curric:KeyLearningPoint ;
  rdfs:label "The poem follows a consistent pattern of rhyme in the scheme of ABCB."@en ;
  dcterms:modified "2026-02-12T08:59:21.621027Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7892-3
  a curric:KeyLearningPoint ;
  rdfs:label """Walter de la Mare chose to create rhyming pairs that are separated by un-rhyming lines."""@en ;
  dcterms:modified "2026-02-12T08:59:21.621033Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7892-4
  a curric:KeyLearningPoint ;
  rdfs:label "Walter de la Mare uses poetic devices to have an effect on the reader."@en ;
  dcterms:modified "2026-02-12T08:59:21.621039Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8048-1
  a curric:KeyLearningPoint ;
  rdfs:label "A pantoum is a form of poetry that originated in Malaysia."@en ;
  dcterms:modified "2026-02-12T08:59:21.621062Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8048-2
  a curric:KeyLearningPoint ;
  rdfs:label "Pantoums are characterised by their repeating lines and overlapping structure."@en ;
  dcterms:modified "2026-02-12T08:59:21.621068Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8048-3
  a curric:KeyLearningPoint ;
  rdfs:label """When editing pantoums, we can consider line length, use of rhyme and language choices."""@en ;
  dcterms:modified "2026-02-12T08:59:21.621074Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8048-4
  a curric:KeyLearningPoint ;
  rdfs:label """Editing word choices and phrases can help to improve the imagery and impression created by our poems."""@en ;
  dcterms:modified "2026-02-12T08:59:21.621081Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8048-5
  a curric:KeyLearningPoint ;
  rdfs:label "Reading your poem aloud will help you to revise and refine it."@en ;
  dcterms:modified "2026-02-12T08:59:21.621087Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6749-1
  a curric:KeyLearningPoint ;
  rdfs:label """'When the Sky Falls' is a complex novel with several plot lines - such as Joseph's struggle with reading."""@en ;
  dcterms:modified "2026-02-12T08:59:21.621131Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6749-2
  a curric:KeyLearningPoint ;
  rdfs:label "Different plot lines are resolved at different points in the story."@en ;
  dcterms:modified "2026-02-12T08:59:21.621140Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6749-3
  a curric:KeyLearningPoint ;
  rdfs:label "We can argue that the air raid at the zoo is the climax of the story."@en ;
  dcterms:modified "2026-02-12T08:59:21.621146Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6749-4
  a curric:KeyLearningPoint ;
  rdfs:label """The resolution of the story is not a 'happy ending' - the 'problem' of guarding Adonis is resolved by his death."""@en ;
  dcterms:modified "2026-02-12T08:59:21.621152Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6749-5
  a curric:KeyLearningPoint ;
  rdfs:label "The historical context of the climax - the Blitz - is key to the narrative."@en ;
  dcterms:modified "2026-02-12T08:59:21.621158Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8010-1
  a curric:KeyLearningPoint ;
  rdfs:label """Joseph Coelho’s poems are easy to read and engaging, with playful rhythms and subjects that young readers can relate to."""@en ;
  dcterms:modified "2026-02-12T08:59:21.621197Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8010-2
  a curric:KeyLearningPoint ;
  rdfs:label "Joseph Coelho often writes poems about his personal experiences."@en ;
  dcterms:modified "2026-02-12T08:59:21.621203Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8010-3
  a curric:KeyLearningPoint ;
  rdfs:label """The poem ‘Miss Flotsam’ is inspired by the teachers Coelho had when growing up and those he has met as an adult."""@en ;
  dcterms:modified "2026-02-12T08:59:21.621208Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8010-4
  a curric:KeyLearningPoint ;
  rdfs:label """The poem depicts ‘Miss Flotsam’ as a kind, understanding and caring teacher, who has an inclusive approach to teaching."""@en ;
  dcterms:modified "2026-02-12T08:59:21.621217Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8010-5
  a curric:KeyLearningPoint ;
  rdfs:label """Alliteration can be used to emphasise key themes and draw the reader’s attention to important parts of a poem."""@en ;
  dcterms:modified "2026-02-12T08:59:21.621226Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7640-1
  a curric:KeyLearningPoint ;
  rdfs:label """Using a range of adjectives and nouns is important when describing a product in a persuasive advert."""@en ;
  dcterms:modified "2026-02-12T08:59:21.621307Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7640-2
  a curric:KeyLearningPoint ;
  rdfs:label """Using a range of synonyms for the product avoids repetition and supports text flow."""@en ;
  dcterms:modified "2026-02-12T08:59:21.621313Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7640-3
  a curric:KeyLearningPoint ;
  rdfs:label """Exaggerated and precise adjectives are more appealing and persuasive to the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.621319Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7640-4
  a curric:KeyLearningPoint ;
  rdfs:label "Adjectives and nouns can be paired purposefully to form alliteration."@en ;
  dcterms:modified "2026-02-12T08:59:21.621325Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8011-1
  a curric:KeyLearningPoint ;
  rdfs:label """Joseph Coelho’s poems are easy to read and engaging, with playful rhythms and subjects that young readers can relate to."""@en ;
  dcterms:modified "2026-02-12T08:59:21.621499Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8011-2
  a curric:KeyLearningPoint ;
  rdfs:label "Joseph Coelho often writes poems with imaginative themes."@en ;
  dcterms:modified "2026-02-12T08:59:21.621504Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8011-3
  a curric:KeyLearningPoint ;
  rdfs:label """The poem ‘Things that Lurk in the Library’ is about the magic and wonder of libraries, books and reading."""@en ;
  dcterms:modified "2026-02-12T08:59:21.621510Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8011-4
  a curric:KeyLearningPoint ;
  rdfs:label """The poet uses personification to create vivid imagery and a sense of the mystery and magic of libraries."""@en ;
  dcterms:modified "2026-02-12T08:59:21.621516Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8046-1
  a curric:KeyLearningPoint ;
  rdfs:label """A cinquain is a five-line poem that follows a specific structure involving syllables."""@en ;
  dcterms:modified "2026-02-12T08:59:21.621575Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8046-2
  a curric:KeyLearningPoint ;
  rdfs:label """Cinquains often focus on creating vivid imagery through descriptive language and sensory details."""@en ;
  dcterms:modified "2026-02-12T08:59:21.621581Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8046-3
  a curric:KeyLearningPoint ;
  rdfs:label "An ode is a poem that celebrates a person, object or idea."@en ;
  dcterms:modified "2026-02-12T08:59:21.621586Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8046-4
  a curric:KeyLearningPoint ;
  rdfs:label "Poems can be written in many different forms and structures."@en ;
  dcterms:modified "2026-02-12T08:59:21.621595Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8046-5
  a curric:KeyLearningPoint ;
  rdfs:label """A poet may choose the form of poetry depending on the impression that they want to create."""@en ;
  dcterms:modified "2026-02-12T08:59:21.621601Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7890-1
  a curric:KeyLearningPoint ;
  rdfs:label "Identifying the word class can support readers when interpreting new vocabluary"@en ;
  dcterms:modified "2026-02-12T08:59:21.621651Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7890-2
  a curric:KeyLearningPoint ;
  rdfs:label """Readers can use the context of the sentence to help with understanding the meaning"""@en ;
  dcterms:modified "2026-02-12T08:59:21.621656Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7890-3
  a curric:KeyLearningPoint ;
  rdfs:label "Skipping a new word can help infer its meaning"@en ;
  dcterms:modified "2026-02-12T08:59:21.621662Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7890-4
  a curric:KeyLearningPoint ;
  rdfs:label """Replacing an unknown word with a known word can support readers when interpreting new vocabluary"""@en ;
  dcterms:modified "2026-02-12T08:59:21.621667Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7893-1
  a curric:KeyLearningPoint ;
  rdfs:label "Asking questions about a poem can help identify key themes within it"@en ;
  dcterms:modified "2026-02-12T08:59:21.621722Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7893-2
  a curric:KeyLearningPoint ;
  rdfs:label """There are several key themes in "The Listeners" including, the unknown, the supernatural, isolation and solitude"""@en ;
  dcterms:modified "2026-02-12T08:59:21.621728Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7893-3
  a curric:KeyLearningPoint ;
  rdfs:label """The Listeners portrays the strangeness of the world, and humankind's inability to fully understand it"""@en ;
  dcterms:modified "2026-02-12T08:59:21.621734Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1075-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Livid' is an adjective which means extremely angry or furious."@en ;
  dcterms:modified "2026-02-12T08:59:21.621762Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1075-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Spiteful' is an adjective which means hateful or mean."@en ;
  dcterms:modified "2026-02-12T08:59:21.621768Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1075-3
  a curric:KeyLearningPoint ;
  rdfs:label """A 'grudge' is an adjective which means hatred; when you stay angry with someone and refuse to forgive them."""@en ;
  dcterms:modified "2026-02-12T08:59:21.621777Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1075-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Furious', 'irritated' and 'raging' are other rich vocabulary associated with anger."""@en ;
  dcterms:modified "2026-02-12T08:59:21.621782Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6734-1
  a curric:KeyLearningPoint ;
  rdfs:label """The Scottish witch trials occurred during the 16th, 17th and early 18th centuries in Scotland."""@en ;
  dcterms:modified "2026-02-12T08:59:21.621791Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6734-2
  a curric:KeyLearningPoint ;
  rdfs:label "Individuals who were prosecuted as witches were often executed."@en ;
  dcterms:modified "2026-02-12T08:59:21.621797Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6734-3
  a curric:KeyLearningPoint ;
  rdfs:label "Witches were recognised by the church as being capable of causing real harm."@en ;
  dcterms:modified "2026-02-12T08:59:21.621803Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6734-4
  a curric:KeyLearningPoint ;
  rdfs:label "Witches were seen as linked to the devil and were therefore also heretical."@en ;
  dcterms:modified "2026-02-12T08:59:21.621812Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6734-5
  a curric:KeyLearningPoint ;
  rdfs:label """Life at this time was very much dominated by the church and the desire to stamp out any connections to the devil."""@en ;
  dcterms:modified "2026-02-12T08:59:21.621818Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7889-1
  a curric:KeyLearningPoint ;
  rdfs:label "The Listeners was written by Walter de la Mare in 1912"@en ;
  dcterms:modified "2026-02-12T08:59:21.621951Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7889-2
  a curric:KeyLearningPoint ;
  rdfs:label "Walter de la Mare was born in April 1873 in England"@en ;
  dcterms:modified "2026-02-12T08:59:21.621957Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7889-3
  a curric:KeyLearningPoint ;
  rdfs:label """The Listeners describes the actions of a Traveller who knocks on the door of a seemingly deserted home at night"""@en ;
  dcterms:modified "2026-02-12T08:59:21.621963Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7889-4
  a curric:KeyLearningPoint ;
  rdfs:label """Walter de la Mare's poetry tends to explore themes of imagination, childhood, and the mysterious or supernatural"""@en ;
  dcterms:modified "2026-02-12T08:59:21.621968Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28402-1
  a curric:KeyLearningPoint ;
  rdfs:label """Character relationships refer to the connections and interactions between individuals within a narrative."""@en ;
  dcterms:modified "2026-02-12T08:59:21.622067Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28402-2
  a curric:KeyLearningPoint ;
  rdfs:label """We can see that Nate has both positive and negative relationships and that his relationships are not static."""@en ;
  dcterms:modified "2026-02-12T08:59:21.622073Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28402-3
  a curric:KeyLearningPoint ;
  rdfs:label "Different moments in the plot can evoke a range of emotions in a character."@en ;
  dcterms:modified "2026-02-12T08:59:21.622078Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28402-4
  a curric:KeyLearningPoint ;
  rdfs:label "We can track a character’s emotions on an emotions graph."@en ;
  dcterms:modified "2026-02-12T08:59:21.622084Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8044-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘When the Wind Blows’ describes the impact of the wind on the environment; 'Heatwave' describes a very hot day."""@en ;
  dcterms:modified "2026-02-12T08:59:21.622254Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8044-2
  a curric:KeyLearningPoint ;
  rdfs:label "The poems are split into verses with different numbers of lines in each."@en ;
  dcterms:modified "2026-02-12T08:59:21.622259Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8044-3
  a curric:KeyLearningPoint ;
  rdfs:label """Poems can create a positive or negative impression of something through the language choices made."""@en ;
  dcterms:modified "2026-02-12T08:59:21.622268Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8044-4
  a curric:KeyLearningPoint ;
  rdfs:label """Considering and understanding the poet's language helps us form an impression of their poems."""@en ;
  dcterms:modified "2026-02-12T08:59:21.622274Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8044-5
  a curric:KeyLearningPoint ;
  rdfs:label "We can be inspired by a poem and create a mirrored version of it."@en ;
  dcterms:modified "2026-02-12T08:59:21.622280Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28384-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘Compliments of Shakespeare’ is a poem found in the poetry collection ‘Dear Ugly Sisters’ by Laura Mucha."""@en ;
  dcterms:modified "2026-02-12T08:59:21.622474Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28384-2
  a curric:KeyLearningPoint ;
  rdfs:label """Mucha has taken some of Shakespeare’s insults and turned them into a witty poem written in modern day language."""@en ;
  dcterms:modified "2026-02-12T08:59:21.622479Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28384-3
  a curric:KeyLearningPoint ;
  rdfs:label """Understanding a poem, its language and the atmosphere it creates will help us to create an impactful performance."""@en ;
  dcterms:modified "2026-02-12T08:59:21.622488Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28384-4
  a curric:KeyLearningPoint ;
  rdfs:label """We can vary our tone, pace and volume to create different effects when performing a poem."""@en ;
  dcterms:modified "2026-02-12T08:59:21.622494Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28384-5
  a curric:KeyLearningPoint ;
  rdfs:label """Our facial expressions and body language can help to convey meaning as we perform."""@en ;
  dcterms:modified "2026-02-12T08:59:21.622500Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7891-1
  a curric:KeyLearningPoint ;
  rdfs:label "Walter de la Mare uses a range of poetic devices to create atmosphere in \"The Listeners\""@en ;
