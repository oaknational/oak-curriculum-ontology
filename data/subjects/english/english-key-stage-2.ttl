  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Ability to decode text fluently at an age-appropriate level."@en ;
  dcterms:modified "2026-06-07T15:29:25.032455Z"^^xsd:dateTime .

oakcurric:priorknowledge-468-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "The ability to hold a pencil or pen in a comfortable tripod grip."@en ;
  dcterms:modified "2026-06-07T15:29:25.040883Z"^^xsd:dateTime .

oakcurric:priorknowledge-468-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "The ability to use joined-up handwriting, including the four letter joins."@en ;
  dcterms:modified "2026-06-07T15:29:25.040898Z"^^xsd:dateTime .

oakcurric:priorknowledge-468-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "The formation of capital letters."@en ;
  dcterms:modified "2026-06-07T15:29:25.040905Z"^^xsd:dateTime .

oakcurric:priorknowledge-468-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Knowledge of which letters to join and leave un-joined."@en ;
  dcterms:modified "2026-06-07T15:29:25.040910Z"^^xsd:dateTime .

oakcurric:priorknowledge-590-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "William Shakespeare was a renowned English playwright, poet and actor."@en ;
  dcterms:modified "2026-06-07T15:29:25.064117Z"^^xsd:dateTime .

oakcurric:priorknowledge-590-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """A play is a work of drama, usually consisting mostly of dialogue between characters
  and intended for theatrical performance."""@en ;
  dcterms:modified "2026-06-07T15:29:25.064130Z"^^xsd:dateTime .

oakcurric:priorknowledge-590-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "'Fiction' is prose that describes imaginary events and people."@en ;
  dcterms:modified "2026-06-07T15:29:25.064137Z"^^xsd:dateTime .

oakcurric:priorknowledge-590-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "'Genre' means the style or category of the play."@en ;
  dcterms:modified "2026-06-07T15:29:25.064142Z"^^xsd:dateTime .

oakcurric:priorknowledge-590-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "In a play, actors perform as the characters on stage."@en ;
  dcterms:modified "2026-06-07T15:29:25.064148Z"^^xsd:dateTime .

oakcurric:priorknowledge-590-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "A playwright is a person who writes plays."@en ;
  dcterms:modified "2026-06-07T15:29:25.064153Z"^^xsd:dateTime .

oakcurric:priorknowledge-87-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "A simple sentence is about one idea and makes complete sense."@en ;
  dcterms:modified "2026-06-07T15:29:25.066495Z"^^xsd:dateTime .

oakcurric:priorknowledge-87-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Any simple sentence contains one verb and at least one noun."@en ;
  dcterms:modified "2026-06-07T15:29:25.066507Z"^^xsd:dateTime .

oakcurric:priorknowledge-87-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Two simple sentences can be joined with a co-ordinating conjunction to form a
  compound sentence."""@en ;
  dcterms:modified "2026-06-07T15:29:25.066514Z"^^xsd:dateTime .

oakcurric:priorknowledge-87-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "The two ideas in a compound sentence hold equal grammatical weight."@en ;
  dcterms:modified "2026-06-07T15:29:25.066535Z"^^xsd:dateTime .

oakcurric:priorknowledge-87-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """A simple sentence can be stretched with subordination to form an adverbial complex
  sentence."""@en ;
  dcterms:modified "2026-06-07T15:29:25.066540Z"^^xsd:dateTime .

oakcurric:priorknowledge-87-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The second idea in an adverbial complex sentence is of lower importance to the first
  idea."""@en ;
  dcterms:modified "2026-06-07T15:29:25.066545Z"^^xsd:dateTime .

oakcurric:priorknowledge-87-7
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Co-ordination and subordination help our writing flow."@en ;
  dcterms:modified "2026-06-07T15:29:25.066550Z"^^xsd:dateTime .

oakcurric:priorknowledge-87-8
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """A simple, compound or adverbial complex sentence can be written in the past or
  present tense."""@en ;
  dcterms:modified "2026-06-07T15:29:25.066554Z"^^xsd:dateTime .

oakcurric:priorknowledge-87-9
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Tense is maintained in a simple, compound or adverbial complex sentence."@en ;
  dcterms:modified "2026-06-07T15:29:25.066559Z"^^xsd:dateTime .

oakcurric:priorknowledge-87-10
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Grammatically accurate sentences start with capital letters and most often end with
  full stops."""@en ;
  dcterms:modified "2026-06-07T15:29:25.066564Z"^^xsd:dateTime .

oakcurric:priorknowledge-704-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "An essay is a formal piece of writing that deals with a single subject."@en ;
  dcterms:modified "2026-06-07T15:29:25.145758Z"^^xsd:dateTime .

oakcurric:priorknowledge-704-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The purpose of an essay can be to present a coherent argument in response to a
  stimulus or question."""@en ;
  dcterms:modified "2026-06-07T15:29:25.145770Z"^^xsd:dateTime .

oakcurric:priorknowledge-704-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "An essay can attempt to persuade the reader of a certain viewpoint."@en ;
  dcterms:modified "2026-06-07T15:29:25.145776Z"^^xsd:dateTime .

oakcurric:priorknowledge-704-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Persuasion of a certain viewpoint is more likely to occur if the writer's
  credibility is maintained."""@en ;
  dcterms:modified "2026-06-07T15:29:25.145782Z"^^xsd:dateTime .

oakcurric:priorknowledge-704-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "An essay flows logically."@en ;
  dcterms:modified "2026-06-07T15:29:25.145787Z"^^xsd:dateTime .

oakcurric:priorknowledge-704-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Established facts and relevant evidence can be used to strengthen the writer's
  position on a subject."""@en ;
  dcterms:modified "2026-06-07T15:29:25.145792Z"^^xsd:dateTime .

oakcurric:priorknowledge-704-7
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Clear, concise language helps to clarify points being made."@en ;
  dcterms:modified "2026-06-07T15:29:25.145797Z"^^xsd:dateTime .

oakcurric:priorknowledge-704-8
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "An introduction opens an essay and a conclusion closes an essay."@en ;
  dcterms:modified "2026-06-07T15:29:25.145802Z"^^xsd:dateTime .

oakcurric:priorknowledge-704-9
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Each paragraph has an introductory sentence and focuses on a single idea."@en ;
  dcterms:modified "2026-06-07T15:29:25.145807Z"^^xsd:dateTime .

oakcurric:priorknowledge-704-10
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Third person and passive verbs can be used to strengthen writer's control in an
  essay."""@en ;
  dcterms:modified "2026-06-07T15:29:25.145812Z"^^xsd:dateTime .

oakcurric:priorknowledge-701-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Beowulf is classified as an epic poem."@en ;
  dcterms:modified "2026-06-07T15:29:25.148315Z"^^xsd:dateTime .

oakcurric:priorknowledge-701-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Beowulf was originally written in Old English."@en ;
  dcterms:modified "2026-06-07T15:29:25.148329Z"^^xsd:dateTime .

oakcurric:priorknowledge-701-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Old English was the language spoken in Anglo Saxon England before the Norman
  Conquest."""@en ;
  dcterms:modified "2026-06-07T15:29:25.148336Z"^^xsd:dateTime .

oakcurric:priorknowledge-701-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The poem follows the character of Beowulf and his battles both in youth and
  in age."""@en ;
  dcterms:modified "2026-06-07T15:29:25.148341Z"^^xsd:dateTime .

oakcurric:priorknowledge-701-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "The text is believed to have been written between 700 - 750 CE."@en ;
  dcterms:modified "2026-06-07T15:29:25.148346Z"^^xsd:dateTime .

oakcurric:priorknowledge-701-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Beowulf is one of the most frequently translated texts of Old English
  literature."""@en ;
  dcterms:modified "2026-06-07T15:29:25.148357Z"^^xsd:dateTime .

oakcurric:priorknowledge-701-7
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Epic poems are narrative poems that are often very long."@en ;
  dcterms:modified "2026-06-07T15:29:25.148362Z"^^xsd:dateTime .

oakcurric:priorknowledge-701-8
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Epic poems often track adventures of heroic characters."@en ;
  dcterms:modified "2026-06-07T15:29:25.148367Z"^^xsd:dateTime .

oakcurric:priorknowledge-701-9
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Themes of courage, honour and struggle against adversity are often explored through
  epic poetry."""@en ;
  dcterms:modified "2026-06-07T15:29:25.148372Z"^^xsd:dateTime .

oakcurric:priorknowledge-701-10
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Epic poems can feature dialogue."@en ;
  dcterms:modified "2026-06-07T15:29:25.148377Z"^^xsd:dateTime .

oakcurric:priorknowledge-451-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Speeches are read aloud to an audience."@en ;
  dcterms:modified "2026-06-07T15:29:25.164721Z"^^xsd:dateTime .

oakcurric:priorknowledge-451-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Speeches are more formal than usual conversation."@en ;
  dcterms:modified "2026-06-07T15:29:25.164734Z"^^xsd:dateTime .

oakcurric:priorknowledge-451-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "There have been many famous speeches in world history."@en ;
  dcterms:modified "2026-06-07T15:29:25.164740Z"^^xsd:dateTime .

oakcurric:priorknowledge-451-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Speeches can be made by anyone, of any age."@en ;
  dcterms:modified "2026-06-07T15:29:25.164745Z"^^xsd:dateTime .

oakcurric:priorknowledge-224-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The purpose of an explanation text is to explain the process of how or why something
  happens to the reader."""@en ;
  dcterms:modified "2026-06-07T15:29:25.171544Z"^^xsd:dateTime .

oakcurric:priorknowledge-224-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Explanation texts are a type of factual, non-fiction writing."@en ;
  dcterms:modified "2026-06-07T15:29:25.171556Z"^^xsd:dateTime .

oakcurric:priorknowledge-224-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Explanation texts are organised into paragraphs in chronological order of when the
  steps of the process happen."""@en ;
  dcterms:modified "2026-06-07T15:29:25.171563Z"^^xsd:dateTime .

oakcurric:priorknowledge-224-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Explanation texts can contain visual information, most commonly diagrams or
  photographs accompanied by a caption."""@en ;
  dcterms:modified "2026-06-07T15:29:25.171568Z"^^xsd:dateTime .

oakcurric:priorknowledge-224-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Important features of explanation texts include apostrophes possession,
  subject-specific, factual vocabulary, numerical facts and sequencing and causal
  conjunctions."""@en ;
  dcterms:modified "2026-06-07T15:29:25.171574Z"^^xsd:dateTime .

oakcurric:priorknowledge-224-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Nouns and pronouns can be referred to in a range of ways to avoid repetition."@en ;
  dcterms:modified "2026-06-07T15:29:25.171579Z"^^xsd:dateTime .

oakcurric:priorknowledge-685-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Economies, societies and cultures of different countries around the world were
  affected by the Second World War."""@en ;
  dcterms:modified "2026-06-07T15:29:25.173743Z"^^xsd:dateTime .

oakcurric:priorknowledge-685-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Migration is the movement of individuals or groups of people from one place to
  another often across long distances."""@en ;
  dcterms:modified "2026-06-07T15:29:25.173755Z"^^xsd:dateTime .

oakcurric:priorknowledge-685-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Immigration is the act of entering and settling in a country that is not a person's
  country of origin for the purpose of living and working permanently."""@en ;
  dcterms:modified "2026-06-07T15:29:25.173762Z"^^xsd:dateTime .

oakcurric:priorknowledge-685-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Caribbean immigrants arrived in Britain on the Empire Windrush after the Second
  World War."""@en ;
  dcterms:modified "2026-06-07T15:29:25.173768Z"^^xsd:dateTime .

oakcurric:priorknowledge-685-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Britain had been affected greatly by the Second World War."@en ;
  dcterms:modified "2026-06-07T15:29:25.173773Z"^^xsd:dateTime .

oakcurric:priorknowledge-685-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Changes in law meant that all citizens of the Commonwealth had the right to settle
  and work in the UK."""@en ;
  dcterms:modified "2026-06-07T15:29:25.173778Z"^^xsd:dateTime .

oakcurric:priorknowledge-685-7
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "The British Empire once comprised 23% of the world's population."@en ;
  dcterms:modified "2026-06-07T15:29:25.173782Z"^^xsd:dateTime .

oakcurric:priorknowledge-685-8
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Caribbean immigrants brought cultural influences to Britain."@en ;
  dcterms:modified "2026-06-07T15:29:25.173787Z"^^xsd:dateTime .

oakcurric:priorknowledge-685-9
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Many British people did not welcome West Indian immigrants into their community."@en ;
  dcterms:modified "2026-06-07T15:29:25.173792Z"^^xsd:dateTime .

oakcurric:priorknowledge-685-10
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Many West Indian immigrants experienced racism, prejudice and discrimination after
  arriving in Britain."""@en ;
  dcterms:modified "2026-06-07T15:29:25.173796Z"^^xsd:dateTime .

oakcurric:priorknowledge-819-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The purpose of descriptive writing is to create vivid imagery in the
  reader's mind"""@en ;
  dcterms:modified "2026-06-07T15:29:25.176049Z"^^xsd:dateTime .

oakcurric:priorknowledge-819-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Adjectives describe nouns"@en ;
  dcterms:modified "2026-06-07T15:29:25.176062Z"^^xsd:dateTime .

oakcurric:priorknowledge-819-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Adverbs modify verbs"@en ;
  dcterms:modified "2026-06-07T15:29:25.176068Z"^^xsd:dateTime .

oakcurric:priorknowledge-819-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Past tense in various forms shows that something has already happened"@en ;
  dcterms:modified "2026-06-07T15:29:25.176073Z"^^xsd:dateTime .

oakcurric:priorknowledge-220-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "A main clause is a group of words that contains a verb and makes complete sense."@en ;
  dcterms:modified "2026-06-07T15:29:25.251255Z"^^xsd:dateTime .

oakcurric:priorknowledge-220-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """A simple sentence is formed of one main clause and there are four types of simple
  sentence: statement, question, command and exclamation."""@en ;
  dcterms:modified "2026-06-07T15:29:25.251267Z"^^xsd:dateTime .

oakcurric:priorknowledge-220-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """A compound sentence is formed of two main clauses that are joined by a co-ordinating
  conjunction."""@en ;
  dcterms:modified "2026-06-07T15:29:25.251273Z"^^xsd:dateTime .

oakcurric:priorknowledge-220-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """There are three co-ordinating conjunctions used to join main clauses: 'and', 'but'
  and 'or'."""@en ;
  dcterms:modified "2026-06-07T15:29:25.251278Z"^^xsd:dateTime .

oakcurric:priorknowledge-220-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The main clause on either side of the co-ordinating conjunction holds equal
  grammatical weight."""@en ;
  dcterms:modified "2026-06-07T15:29:25.251284Z"^^xsd:dateTime .

oakcurric:priorknowledge-220-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """A subordinate clause is a group of words that contains a verb that does not make
  complete sense."""@en ;
  dcterms:modified "2026-06-07T15:29:25.251288Z"^^xsd:dateTime .

oakcurric:priorknowledge-220-7
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """An adverbial complex sentence is formed of at least one main clause and an adverbial
  subordinate clause."""@en ;
  dcterms:modified "2026-06-07T15:29:25.251293Z"^^xsd:dateTime .

oakcurric:priorknowledge-220-8
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """An adverbial clause starts with a subordinating conjunction and each subordinating
  conjunction has a different meaning."""@en ;
  dcterms:modified "2026-06-07T15:29:25.251297Z"^^xsd:dateTime .

oakcurric:priorknowledge-220-9
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The main clause and adverbial clause can swap position in an adverbial complex
  sentence."""@en ;
  dcterms:modified "2026-06-07T15:29:25.251302Z"^^xsd:dateTime .

oakcurric:priorknowledge-220-10
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Commas are often used to demarcate clauses in compound and complex sentences."@en ;
  dcterms:modified "2026-06-07T15:29:25.251307Z"^^xsd:dateTime .

oakcurric:priorknowledge-88-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Sentences can be formed in the present, past or future tense."@en ;
  dcterms:modified "2026-06-07T15:29:25.255497Z"^^xsd:dateTime .

oakcurric:priorknowledge-88-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Tense helps us understand the time frame of the sentence."@en ;
  dcterms:modified "2026-06-07T15:29:25.255509Z"^^xsd:dateTime .

oakcurric:priorknowledge-88-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "There are different tenses and ways of forming verbs in English."@en ;
  dcterms:modified "2026-06-07T15:29:25.255531Z"^^xsd:dateTime .

oakcurric:priorknowledge-88-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "A verb is a doing or a being word."@en ;
  dcterms:modified "2026-06-07T15:29:25.255537Z"^^xsd:dateTime .

oakcurric:priorknowledge-88-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "The verb carries the tense of a sentence."@en ;
  dcterms:modified "2026-06-07T15:29:25.255542Z"^^xsd:dateTime .

oakcurric:priorknowledge-88-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "A main clause is a group of words that contains a verb and makes complete sense."@en ;
  dcterms:modified "2026-06-07T15:29:25.255547Z"^^xsd:dateTime .

oakcurric:priorknowledge-88-7
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Some tenses and ways of forming verbs are more frequent in reading than others."@en ;
  dcterms:modified "2026-06-07T15:29:25.255551Z"^^xsd:dateTime .

oakcurric:priorknowledge-88-8
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Some tenses and ways of forming verbs are more frequent in everyday speaking than
  others."""@en ;
  dcterms:modified "2026-06-07T15:29:25.255556Z"^^xsd:dateTime .

oakcurric:priorknowledge-88-9
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "A noun does the verb of a sentence, including if the verb is a being verb."@en ;
  dcterms:modified "2026-06-07T15:29:25.255560Z"^^xsd:dateTime .

oakcurric:priorknowledge-88-10
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Verbs exist in all languages."@en ;
  dcterms:modified "2026-06-07T15:29:25.255565Z"^^xsd:dateTime .

oakcurric:priorknowledge-653-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Non fiction writing is writing that is informative or factual rather than
  fictional."""@en ;
  dcterms:modified "2026-06-07T15:29:25.257637Z"^^xsd:dateTime .

oakcurric:priorknowledge-653-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """A paragraph is a section of a piece of writing that is indicated by a new line and
  an indentation"""@en ;
  dcterms:modified "2026-06-07T15:29:25.257648Z"^^xsd:dateTime .

oakcurric:priorknowledge-653-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "A main clause is a group of words that contains a verb and makes complete sense"@en ;
  dcterms:modified "2026-06-07T15:29:25.257653Z"^^xsd:dateTime .

oakcurric:priorknowledge-653-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """A subordinate clause is a group of words that contains a verb and does not make
  complete sense"""@en ;
  dcterms:modified "2026-06-07T15:29:25.257658Z"^^xsd:dateTime .

oakcurric:priorknowledge-653-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """A complex sentence is a sentence formed of at least one main clause and a
  subordinate clause"""@en ;
  dcterms:modified "2026-06-07T15:29:25.257663Z"^^xsd:dateTime .

oakcurric:priorknowledge-588-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "'Fiction' is prose that describes imaginary events and people."@en ;
  dcterms:modified "2026-06-07T15:29:25.261581Z"^^xsd:dateTime .

oakcurric:priorknowledge-588-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "'Genre' means the style or category of the text."@en ;
  dcterms:modified "2026-06-07T15:29:25.261592Z"^^xsd:dateTime .

oakcurric:priorknowledge-588-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """\"Fantasy\" is a genre which includes themes such as magic and fictional
  creatures."""@en ;
