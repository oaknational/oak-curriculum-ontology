oakcurric:keylearningpoint-lesson-5774-4
  a curric:KeyLearningPoint ;
  rdfs:label "The closing may include past, present and future tenses."@en ;
  dcterms:modified "2026-02-12T08:59:21.742993Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6591-1
  a curric:KeyLearningPoint ;
  rdfs:label """The introduction provides the reader with general information about who the biography is about."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742997Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6591-2
  a curric:KeyLearningPoint ;
  rdfs:label """The introduction explicitly outlines which aspects of the subject's life will be explored."""@en ;
  dcterms:modified "2026-02-12T08:59:21.743001Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6591-3
  a curric:KeyLearningPoint ;
  rdfs:label """In the introduction, information should be kept general and it should encourage the reader to read on."""@en ;
  dcterms:modified "2026-02-12T08:59:21.743005Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6591-4
  a curric:KeyLearningPoint ;
  rdfs:label """When writing, we should orally rehearse sentences and use our plans and success criteria to guide us."""@en ;
  dcterms:modified "2026-02-12T08:59:21.743009Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6594-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of an editing lesson is to improve writing and to make necessary corrections or additions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.743237Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6594-2
  a curric:KeyLearningPoint ;
  rdfs:label """Vocabulary, cohesion and punctuation can be changed to make writing more effective."""@en ;
  dcterms:modified "2026-02-12T08:59:21.743241Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6594-3
  a curric:KeyLearningPoint ;
  rdfs:label """When editing, we should be selective about which elements to change and which to keep the same."""@en ;
  dcterms:modified "2026-02-12T08:59:21.743245Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1334-1
  a curric:KeyLearningPoint ;
  rdfs:label """The spelling -le is the most common spelling out of the suffixes -le, -el, -al and -il."""@en ;
