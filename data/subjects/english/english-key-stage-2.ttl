  rdfs:label "Oak Curriculum Data - English Key Stage 2 Instance Data"@en ;
  dc:title "Oak Curriculum Data - English Key Stage 2 Instance Data"@en ;
  rdfs:comment """Instance data defining the Oak National Academy Curriculum
  programmes for English Key Stage 2."""@en ;

  owl:versionInfo "0.1.1" ;
  owl:versionIRI <https://w3id.org/uk/oak/curriculum/oakcurriculum/english-key-stage-2/0.1.1> ;

  dcterms:description """This file contains Programme, Unit, Unit Variant, and Lesson instances for
  English Key Stage 2, including exam board-specific unit variants and lesson sequences."""@en ;
