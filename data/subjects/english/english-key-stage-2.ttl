oakcurric:keylearningpoint-lesson-1427-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum word: through."@en ;
  dcterms:modified "2026-02-12T08:59:21.742959Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27899-1
  a curric:KeyLearningPoint ;
  rdfs:label "A speaker can use humour to build a relationship with an audience."@en ;
  dcterms:modified "2026-02-12T08:59:21.742963Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27899-2
  a curric:KeyLearningPoint ;
  rdfs:label """Telling anecdotes in a speech can help an audience to feel connected to a speaker."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742967Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27899-3
  a curric:KeyLearningPoint ;
  rdfs:label """Malala Yousafzai is an activist and actively campaigns for children's rights to education and women's rights worldwide."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742971Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27899-4
  a curric:KeyLearningPoint ;
  rdfs:label """She is also a humanitarian, advocate and public speaker, who was the youngest winner of the Nobel Peace Prize in 2014."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742974Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5774-1
  a curric:KeyLearningPoint ;
  rdfs:label "The closing includes a sign-off from the writer."@en ;
  dcterms:modified "2026-02-12T08:59:21.742978Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5774-2
  a curric:KeyLearningPoint ;
  rdfs:label "The closing includes a summary of key events, thoughts, feelings and questions."@en ;
  dcterms:modified "2026-02-12T08:59:21.742982Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5774-3
  a curric:KeyLearningPoint ;
  rdfs:label "The closing refers to past, present and future events."@en ;
