oakcurric:priorknowledge-925-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The book tells the story of two young girls, who lost their father in war. Their
  mother wants to move them to another country where they can be safe."""@en ;
  dcterms:modified "2026-06-07T15:29:25.989960Z"^^xsd:dateTime .

oakcurric:priorknowledge-925-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """They undertake a long journey across land and sea, and cross different borders. They
  face many obstacles on their journey."""@en ;
  dcterms:modified "2026-06-07T15:29:25.989964Z"^^xsd:dateTime .

oakcurric:priorknowledge-925-7
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The story ends with family being near somewhere safe. They are yet to find a safe
  home."""@en ;
  dcterms:modified "2026-06-07T15:29:25.989969Z"^^xsd:dateTime .

oakcurric:priorknowledge-925-8
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """A refugee is a person who has been forced to leave their country in order to escape
  war, persecution, or natural disaster."""@en ;
  dcterms:modified "2026-06-07T15:29:25.989973Z"^^xsd:dateTime .

