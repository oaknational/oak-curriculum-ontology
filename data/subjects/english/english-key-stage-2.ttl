oakcurric:keylearningpoint-lesson-7941-2
  a curric:KeyLearningPoint ;
  rdfs:label "Narrative fiction can cover a range of genres, content, settings and styles."@en ;
  dcterms:modified "2026-02-12T08:59:21.708532Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7941-3
  a curric:KeyLearningPoint ;
  rdfs:label """A graphic novel is a type of text combining words and images in long-form, sequential art panels."""@en ;
  dcterms:modified "2026-02-12T08:59:21.708536Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8772-1
  a curric:KeyLearningPoint ;
  rdfs:label """Familiarising yourself with a text's layout helps you to navigate and understand it."""@en ;
  dcterms:modified "2026-02-12T08:59:21.708795Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8772-2
  a curric:KeyLearningPoint ;
  rdfs:label """Skimming and scanning is a way to retrieve information accurately and quickly from a text."""@en ;
  dcterms:modified "2026-02-12T08:59:21.708799Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8772-3
  a curric:KeyLearningPoint ;
  rdfs:label "Searching for key words helps you to find information you are looking for."@en ;
  dcterms:modified "2026-02-12T08:59:21.708804Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8772-4
  a curric:KeyLearningPoint ;
  rdfs:label """Bioluminescence and biofluorescence are two different ways in which creatures produce their glow."""@en ;
  dcterms:modified "2026-02-12T08:59:21.708810Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8771-1
  a curric:KeyLearningPoint ;
  rdfs:label """'Curious Creatures Glowing in the Dark' is a non-fiction book which provides true information."""@en ;
  dcterms:modified "2026-02-12T08:59:21.708832Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8771-2
  a curric:KeyLearningPoint ;
  rdfs:label """Creatures, and other living organisms, can glow in the dark using bioluminescence or biofluorescence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.708836Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8771-3
  a curric:KeyLearningPoint ;
  rdfs:label "The book is designed to engage children as its audience."@en ;
  dcterms:modified "2026-02-12T08:59:21.708843Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8771-4
  a curric:KeyLearningPoint ;
  rdfs:label "The layout of a text is determined by its purpose and audience."@en ;
  dcterms:modified "2026-02-12T08:59:21.708848Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8771-5
  a curric:KeyLearningPoint ;
  rdfs:label "The book chunks information into sections and uses fact boxes and illustrations."@en ;
  dcterms:modified "2026-02-12T08:59:21.708853Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6589-1
  a curric:KeyLearningPoint ;
  rdfs:label "A biography is a non-fiction text written about someone's life."@en ;
  dcterms:modified "2026-02-12T08:59:21.709032Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6589-2
  a curric:KeyLearningPoint ;
  rdfs:label """Linguistic features of a biography include fronted adverbials, facts, relative complex sentences and parenthesis."""@en ;
  dcterms:modified "2026-02-12T08:59:21.709036Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6589-3
  a curric:KeyLearningPoint ;
  rdfs:label """Structural features include a title, subheadings and relevant information grouped by theme."""@en ;
  dcterms:modified "2026-02-12T08:59:21.709041Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6589-4
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of a biography is to inform the reader about a particular individual."""@en ;
  dcterms:modified "2026-02-12T08:59:21.709045Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6589-5
  a curric:KeyLearningPoint ;
  rdfs:label """In biographies, extra, factual information can be added to clauses using brackets or commas."""@en ;
  dcterms:modified "2026-02-12T08:59:21.709050Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4704-1
  a curric:KeyLearningPoint ;
  rdfs:label """An important part of preparing for a debate is generating points for your side of the argument."""@en ;
  dcterms:modified "2026-02-12T08:59:21.709054Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4704-2
  a curric:KeyLearningPoint ;
  rdfs:label """The points that your team generates should be ordered from strongest to weakest to ensure your best points are included."""@en ;
  dcterms:modified "2026-02-12T08:59:21.709059Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4704-3
  a curric:KeyLearningPoint ;
  rdfs:label "The points generated should be assigned to different members of your team."@en ;
  dcterms:modified "2026-02-12T08:59:21.709064Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4704-4
  a curric:KeyLearningPoint ;
  rdfs:label """A debate team should liaise with each other while writing their speeches to avoid repetition."""@en ;
  dcterms:modified "2026-02-12T08:59:21.709068Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4882-1
  a curric:KeyLearningPoint ;
  rdfs:label """Precise vocabulary is used to accurately describe the complex process of mummification."""@en ;
  dcterms:modified "2026-02-12T08:59:21.709075Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4882-2
  a curric:KeyLearningPoint ;
  rdfs:label """Adjective choices are formal and technical in an explanation text rather than descriptive."""@en ;
  dcterms:modified "2026-02-12T08:59:21.709080Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4882-3
  a curric:KeyLearningPoint ;
  rdfs:label "Verb choices are precise to describe actions accurately."@en ;
  dcterms:modified "2026-02-12T08:59:21.709084Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4882-4
  a curric:KeyLearningPoint ;
  rdfs:label """Synonyms can be used to refer to the nouns in different ways to avoid repetition."""@en ;
  dcterms:modified "2026-02-12T08:59:21.709089Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4882-5
  a curric:KeyLearningPoint ;
  rdfs:label "Adverbs are used to add extra detail to the verb."@en ;
  dcterms:modified "2026-02-12T08:59:21.709093Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3456-1
  a curric:KeyLearningPoint ;
  rdfs:label "An apostrophe is an important piece of punctuation with more than one purpose."@en ;
  dcterms:modified "2026-02-12T08:59:21.709098Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3456-2
  a curric:KeyLearningPoint ;
  rdfs:label "An apostrophe can contract two words together."@en ;
  dcterms:modified "2026-02-12T08:59:21.709103Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3456-3
  a curric:KeyLearningPoint ;
  rdfs:label """An apostrophe can show if a noun belongs to another singular noun or to another plural noun."""@en ;
  dcterms:modified "2026-02-12T08:59:21.709107Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3456-4
  a curric:KeyLearningPoint ;
  rdfs:label """Contractions are useful in writing to indicate a character's informal speech or a less formal register."""@en ;
  dcterms:modified "2026-02-12T08:59:21.709111Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3456-5
  a curric:KeyLearningPoint ;
  rdfs:label "Apostrophes for possession are useful to clarify belonging to the reader."@en ;
  dcterms:modified "2026-02-12T08:59:21.709116Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4712-1
  a curric:KeyLearningPoint ;
  rdfs:label "Spending time preparing your speech will help you to make it successful."@en ;
  dcterms:modified "2026-02-12T08:59:21.709123Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4712-2
  a curric:KeyLearningPoint ;
  rdfs:label "The PEPS structure can help you to structure a speech successfully."@en ;
  dcterms:modified "2026-02-12T08:59:21.709128Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1048-1
  a curric:KeyLearningPoint ;
  rdfs:label """Both the simple tense and progressive tense can denote present, past or future action."""@en ;
  dcterms:modified "2026-02-12T08:59:21.709135Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1048-2
  a curric:KeyLearningPoint ;
  rdfs:label "The verb carries the tense of a sentence."@en ;
  dcterms:modified "2026-02-12T08:59:21.709140Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1048-3
  a curric:KeyLearningPoint ;
  rdfs:label """The simple tense is a tense that does not use an auxiliary verb in addition to the main verb except in the future."""@en ;
  dcterms:modified "2026-02-12T08:59:21.709144Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1048-4
  a curric:KeyLearningPoint ;
  rdfs:label """The progressive tense always makes use of an auxiliary verb from the infinitive 'to be' paired with the main verb."""@en ;
  dcterms:modified "2026-02-12T08:59:21.709180Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1048-5
  a curric:KeyLearningPoint ;
  rdfs:label "The progressive tense denotes ongoing action."@en ;
  dcterms:modified "2026-02-12T08:59:21.709186Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9045-1
  a curric:KeyLearningPoint ;
  rdfs:label """We can analyse a scene in a graphic novel by exploring the visual, narrative and contextual elements."""@en ;
  dcterms:modified "2026-02-12T08:59:21.710053Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9045-2
  a curric:KeyLearningPoint ;
  rdfs:label "We can ask questions about scenes to develop our understanding of the text."@en ;
  dcterms:modified "2026-02-12T08:59:21.710058Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9045-3
  a curric:KeyLearningPoint ;
  rdfs:label "One of the most prominent themes in the text is identity."@en ;
  dcterms:modified "2026-02-12T08:59:21.710063Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9045-4
  a curric:KeyLearningPoint ;
  rdfs:label """Marlene’s journey is about understanding and embracing her identity, accepting her natural hair as a part of who she is."""@en ;
  dcterms:modified "2026-02-12T08:59:21.710067Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9045-5
  a curric:KeyLearningPoint ;
  rdfs:label """Take-away ideas within a graphic novel may link to themes that are explored and developed in it."""@en ;
  dcterms:modified "2026-02-12T08:59:21.710071Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8774-1
  a curric:KeyLearningPoint ;
  rdfs:label """The Anglerfish is a bioluminescent creature that uses its glow to lure prey, making it an expert predator."""@en ;
  dcterms:modified "2026-02-12T08:59:21.710144Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8774-2
  a curric:KeyLearningPoint ;
  rdfs:label """The Anglerfish lives in the deepest part of the ocean named the midnight zone, which is difficult for humans to visit."""@en ;
  dcterms:modified "2026-02-12T08:59:21.710148Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8774-3
  a curric:KeyLearningPoint ;
  rdfs:label """Navigating the layout of a non-fiction text can help you read and retrieve information on a specific topic."""@en ;
  dcterms:modified "2026-02-12T08:59:21.710153Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8774-4
  a curric:KeyLearningPoint ;
  rdfs:label """Skimming and scanning for keywords can help you accurately retrieve information from the text quickly."""@en ;
  dcterms:modified "2026-02-12T08:59:21.710157Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8774-5
  a curric:KeyLearningPoint ;
  rdfs:label """Summarising what has been read helps knowledge to stick and builds comprehension."""@en ;
  dcterms:modified "2026-02-12T08:59:21.710162Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7671-1
  a curric:KeyLearningPoint ;
  rdfs:label """Subject-specific vocabulary, including numerical facts, is used in a non-chronological report."""@en ;
  dcterms:modified "2026-02-12T08:59:21.710169Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7671-2
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials of cause are used at the start of a sentence to explain a reason."""@en ;
  dcterms:modified "2026-02-12T08:59:21.710174Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7671-3
  a curric:KeyLearningPoint ;
  rdfs:label """Sentences can start with a range of fronted adverbials like formal and viewpoint fronted adverbials."""@en ;
  dcterms:modified "2026-02-12T08:59:21.710178Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2708-1
  a curric:KeyLearningPoint ;
  rdfs:label "Direct speech is the term used for a character speaking out loud in a text."@en ;
  dcterms:modified "2026-02-12T08:59:21.710259Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2708-2
  a curric:KeyLearningPoint ;
  rdfs:label """A speech second sentence begins with the reporting clause followed by a character's spoken words."""@en ;
  dcterms:modified "2026-02-12T08:59:21.710263Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2708-3
  a curric:KeyLearningPoint ;
  rdfs:label """The reporting clause comes before the speech to show who said the speech and how."""@en ;
  dcterms:modified "2026-02-12T08:59:21.710270Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2708-4
  a curric:KeyLearningPoint ;
  rdfs:label "The speech sentence spoken by a character must start with a capital letter."@en ;
  dcterms:modified "2026-02-12T08:59:21.710275Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4887-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of a conclusion is to summarise the information of the text for the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.710279Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4887-2
  a curric:KeyLearningPoint ;
  rdfs:label "A summary sentence summarises the key information from the text."@en ;
  dcterms:modified "2026-02-12T08:59:21.710284Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4887-3
  a curric:KeyLearningPoint ;
  rdfs:label "A conclusion can begin with a formal fronted adverbial."@en ;
  dcterms:modified "2026-02-12T08:59:21.710290Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4887-4
  a curric:KeyLearningPoint ;
  rdfs:label "No new information about the subject is given to the reader in the conclusion."@en ;
  dcterms:modified "2026-02-12T08:59:21.710296Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4887-5
  a curric:KeyLearningPoint ;
  rdfs:label """A conclusion finishes with the writer suggesting to the reader how to find out more."""@en ;
  dcterms:modified "2026-02-12T08:59:21.710300Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1042-1
  a curric:KeyLearningPoint ;
  rdfs:label "The position of an adverbial clause can move in an adverbial complex sentence."@en ;
  dcterms:modified "2026-02-12T08:59:21.710305Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1042-2
  a curric:KeyLearningPoint ;
  rdfs:label "The adverbial clause can come first in the sentence followed by the main clause."@en ;
  dcterms:modified "2026-02-12T08:59:21.710310Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1042-3
  a curric:KeyLearningPoint ;
  rdfs:label """If the adverbial clause comes first in the sentence, it is followed by a comma to separate it from the main clause."""@en ;
  dcterms:modified "2026-02-12T08:59:21.710314Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1042-4
  a curric:KeyLearningPoint ;
  rdfs:label "The main clause can come first in the sentence followed by the adverbial clause."@en ;
  dcterms:modified "2026-02-12T08:59:21.710319Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1042-5
  a curric:KeyLearningPoint ;
  rdfs:label "If the main clause comes first in the sentence, no comma is used."@en ;
  dcterms:modified "2026-02-12T08:59:21.710323Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4875-1
  a curric:KeyLearningPoint ;
  rdfs:label "Editing is an essential part of the writing process."@en ;
  dcterms:modified "2026-02-12T08:59:21.710735Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4875-2
  a curric:KeyLearningPoint ;
  rdfs:label """Editing does not involve rewriting the entire piece but is about being selective about what to edit and improve."""@en ;
  dcterms:modified "2026-02-12T08:59:21.710740Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4875-3
  a curric:KeyLearningPoint ;
  rdfs:label """Punctuation, sentence structure, grammar, vocabulary precision and spelling can all be edited."""@en ;
  dcterms:modified "2026-02-12T08:59:21.710745Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4875-4
  a curric:KeyLearningPoint ;
  rdfs:label "The purpose of editing is to ensure the text meets its text purpose."@en ;
  dcterms:modified "2026-02-12T08:59:21.710752Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1355-1
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: pronunciation, explanation and dictionary."@en ;
  dcterms:modified "2026-02-12T08:59:21.711126Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1355-2
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: disastrous, mischievous and marvellous."@en ;
  dcterms:modified "2026-02-12T08:59:21.711131Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1355-3
  a curric:KeyLearningPoint ;
  rdfs:label """How to spell the curriculum words: frequently, immediately, especially and sincerely."""@en ;
  dcterms:modified "2026-02-12T08:59:21.711137Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1355-4
  a curric:KeyLearningPoint ;
  rdfs:label "Spelling strategies help us to notice how words are spelled."@en ;
  dcterms:modified "2026-02-12T08:59:21.711142Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1355-5
  a curric:KeyLearningPoint ;
  rdfs:label """The practice spelling strategy you choose often depends on the spelling you are practising and what makes it difficult."""@en ;
  dcterms:modified "2026-02-12T08:59:21.711147Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6359-1
  a curric:KeyLearningPoint ;
  rdfs:label """The recount section of a journalistic report provides specific details about the news event in chronological order."""@en ;
  dcterms:modified "2026-02-12T08:59:21.711154Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6359-2
  a curric:KeyLearningPoint ;
  rdfs:label "Use of subject-specific vocabulary supports planning for a journalistic report."@en ;
  dcterms:modified "2026-02-12T08:59:21.711159Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6359-3
  a curric:KeyLearningPoint ;
  rdfs:label """Details of the timeline, people involved and action taken are crucial for reporting on a crime."""@en ;
  dcterms:modified "2026-02-12T08:59:21.711163Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6359-4
  a curric:KeyLearningPoint ;
  rdfs:label """A plan is written in note format, using bullet points to write the key facts in a few words."""@en ;
  dcterms:modified "2026-02-12T08:59:21.711168Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4883-1
  a curric:KeyLearningPoint ;
  rdfs:label "An explanation text needs a title to signify what the text is about."@en ;
  dcterms:modified "2026-02-12T08:59:21.711173Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4883-2
  a curric:KeyLearningPoint ;
  rdfs:label "The purpose of the introduction is to give general information to the reader."@en ;
  dcterms:modified "2026-02-12T08:59:21.711177Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4883-3
  a curric:KeyLearningPoint ;
  rdfs:label "The introduction outlines what the reader will learn from the explanation text."@en ;
  dcterms:modified "2026-02-12T08:59:21.711182Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4883-4
  a curric:KeyLearningPoint ;
  rdfs:label """The facts in the introduction are general about mummification; they become more specific in later paragraphs."""@en ;
  dcterms:modified "2026-02-12T08:59:21.711186Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4883-5
  a curric:KeyLearningPoint ;
  rdfs:label "An introduction ends with a command to the reader to continue reading."@en ;
  dcterms:modified "2026-02-12T08:59:21.711191Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1409-1
  a curric:KeyLearningPoint ;
  rdfs:label "It is common to see a ‘c’ or a ‘t’ before the suffix -ial."@en ;
  dcterms:modified "2026-02-12T08:59:21.711216Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1409-2
  a curric:KeyLearningPoint ;
  rdfs:label "The /shul/ ending can be spelt -cial or -tial."@en ;
  dcterms:modified "2026-02-12T08:59:21.711222Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1409-3
  a curric:KeyLearningPoint ;
  rdfs:label "If the letter before the /shul/ ending is a consonant, -tial is usually used."@en ;
  dcterms:modified "2026-02-12T08:59:21.711227Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1409-4
  a curric:KeyLearningPoint ;
  rdfs:label "If the letter before the /shul/ ending is a vowel, -cial is usually used."@en ;
  dcterms:modified "2026-02-12T08:59:21.711231Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1409-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: separate, popular and opposite."@en ;
  dcterms:modified "2026-02-12T08:59:21.711236Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1450-1
  a curric:KeyLearningPoint ;
  rdfs:label """A prefix is a letter or group of letters at the start of a word which creates another word."""@en ;
  dcterms:modified "2026-02-12T08:59:21.711241Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1450-2
  a curric:KeyLearningPoint ;
  rdfs:label """The prefixes de-, re-, sub- and super- can be added  without changing the spelling of the root word."""@en ;
  dcterms:modified "2026-02-12T08:59:21.711245Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1450-3
  a curric:KeyLearningPoint ;
  rdfs:label "The prefixes de- can mean undo and re- can mean again."@en ;
  dcterms:modified "2026-02-12T08:59:21.711250Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1450-4
  a curric:KeyLearningPoint ;
  rdfs:label "The prefix sub- can mean under or nearly and super- can mean above or larger."@en ;
  dcterms:modified "2026-02-12T08:59:21.711257Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1450-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum word: guide."@en ;
  dcterms:modified "2026-02-12T08:59:21.711261Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6221-1
  a curric:KeyLearningPoint ;
  rdfs:label """In our essay, the conclusion reflects the essay title, bringing the information from previous paragraphs together."""@en ;
  dcterms:modified "2026-02-12T08:59:21.711266Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6221-2
  a curric:KeyLearningPoint ;
  rdfs:label """The conclusion explains how reducing deforestation will help reduce the impacts of climate change."""@en ;
  dcterms:modified "2026-02-12T08:59:21.711271Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6221-3
  a curric:KeyLearningPoint ;
  rdfs:label "We will include subject-specific vocabulary and a range of linguistic features."@en ;
  dcterms:modified "2026-02-12T08:59:21.711275Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6221-4
  a curric:KeyLearningPoint ;
  rdfs:label """Because the conclusion looks at possible future actions and outcomes, we will often use modal verbs."""@en ;
  dcterms:modified "2026-02-12T08:59:21.711279Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6221-5
  a curric:KeyLearningPoint ;
  rdfs:label "Modal verbs are auxiliary ('helping') verbs that are paired with a main verb."@en ;
  dcterms:modified "2026-02-12T08:59:21.711284Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9043-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘Frizzy’ is a fictional graphic novel text written by Claribel A. Ortega and illustrated by Rose Bousamra."""@en ;
  dcterms:modified "2026-02-12T08:59:21.711309Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9043-2
  a curric:KeyLearningPoint ;
  rdfs:label """The text follows Marlene, a young Dominican-American girl coming to terms with growing up."""@en ;
  dcterms:modified "2026-02-12T08:59:21.711314Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9043-3
  a curric:KeyLearningPoint ;
  rdfs:label """Graphic novels include features such as speech bubbles, thought bubbles & sound effects to explain what is happening."""@en ;
  dcterms:modified "2026-02-12T08:59:21.711319Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9043-4
  a curric:KeyLearningPoint ;
  rdfs:label """Readers sometimes have to infer what has happened, rather than being told by the author or illustrator."""@en ;
  dcterms:modified "2026-02-12T08:59:21.711326Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9043-5
  a curric:KeyLearningPoint ;
  rdfs:label """The text celebrates Spanish language and Dominican culture; this helps ground the story in Marlene’s cultural heritage."""@en ;
  dcterms:modified "2026-02-12T08:59:21.711330Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9044-1
  a curric:KeyLearningPoint ;
  rdfs:label """Characterisation is the way an author and illustrator develop the personalities and traits of the characters in a story."""@en ;
  dcterms:modified "2026-02-12T08:59:21.711438Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9044-2
  a curric:KeyLearningPoint ;
  rdfs:label """Readers can tell lots about characters through their appearance, dialogue, their actions and how they are depicted."""@en ;
  dcterms:modified "2026-02-12T08:59:21.711442Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9044-3
  a curric:KeyLearningPoint ;
  rdfs:label """Through eye contact & body language we can infer how a character might be feeling & what this might convey to a reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.711447Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9044-4
  a curric:KeyLearningPoint ;
  rdfs:label """Having explored the characters in greater detail, readers can make predictions about what might happen next."""@en ;
  dcterms:modified "2026-02-12T08:59:21.711451Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8773-1
  a curric:KeyLearningPoint ;
  rdfs:label """Using the layout features to navigate a non-fiction text helps us to understand it."""@en ;
  dcterms:modified "2026-02-12T08:59:21.711594Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8773-2
  a curric:KeyLearningPoint ;
  rdfs:label """Using strategies like skimming and scanning for key words helps us retrieve information quickly."""@en ;
  dcterms:modified "2026-02-12T08:59:21.711599Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8773-3
  a curric:KeyLearningPoint ;
  rdfs:label """Summarising what has been read helps knowledge to stick and builds comprehension."""@en ;
  dcterms:modified "2026-02-12T08:59:21.711603Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8773-4
  a curric:KeyLearningPoint ;
  rdfs:label """Creatures on our planet create light naturally through the processes of bioluminescence and biofluorescence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.711608Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8773-5
  a curric:KeyLearningPoint ;
  rdfs:label """Understanding the science behind glowing creatures can help us protect the planet and understand diseases."""@en ;
  dcterms:modified "2026-02-12T08:59:21.711612Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8057-1
  a curric:KeyLearningPoint ;
  rdfs:label "‘The Invaders’ and ‘Kingfisher’ are two poems based on a similar theme: birds."@en ;
  dcterms:modified "2026-02-12T08:59:21.711663Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8057-2
  a curric:KeyLearningPoint ;
  rdfs:label """Both poems are written in free verse, they do not adhere to a specific rhyme scheme or meter."""@en ;
  dcterms:modified "2026-02-12T08:59:21.711668Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8057-3
  a curric:KeyLearningPoint ;
  rdfs:label """‘The Invaders’ describes the competition between two rival species, the sparrows and starlings."""@en ;
  dcterms:modified "2026-02-12T08:59:21.711676Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8057-4
  a curric:KeyLearningPoint ;
  rdfs:label """‘Kingfisher’ describes the story of a kingfisher who successfully hunts for its food."""@en ;
  dcterms:modified "2026-02-12T08:59:21.711680Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8057-5
  a curric:KeyLearningPoint ;
  rdfs:label "Both poems use imagery to convey an atmosphere to the reader or listener."@en ;
  dcterms:modified "2026-02-12T08:59:21.711685Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27626-1
  a curric:KeyLearningPoint ;
  rdfs:label "Thorough preparation is important for a debate."@en ;
  dcterms:modified "2026-02-12T08:59:21.711988Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27626-2
  a curric:KeyLearningPoint ;
  rdfs:label "Preparing for a debate includes generating points for your side of the argument."@en ;
  dcterms:modified "2026-02-12T08:59:21.711993Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27626-3
  a curric:KeyLearningPoint ;
  rdfs:label """Points can be ordered from strongest to weakest to ensure the most effective points are included."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712000Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27626-4
  a curric:KeyLearningPoint ;
  rdfs:label "Liaising with your team while writing speeches helps to avoid repetition."@en ;
  dcterms:modified "2026-02-12T08:59:21.712005Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27626-5
  a curric:KeyLearningPoint ;
  rdfs:label "The PEPS structure stands for: point, explanation, proof, summary."@en ;
  dcterms:modified "2026-02-12T08:59:21.712010Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2730-1
  a curric:KeyLearningPoint ;
  rdfs:label "Any clause is a group of words that contains a verb."@en ;
  dcterms:modified "2026-02-12T08:59:21.712014Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2730-2
  a curric:KeyLearningPoint ;
  rdfs:label "A main clause is a group of words that contains a verb and makes complete sense."@en ;
  dcterms:modified "2026-02-12T08:59:21.712019Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2730-3
  a curric:KeyLearningPoint ;
  rdfs:label """A subordinate clause is a group of words that contains a verb that does not make complete sense."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712023Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2730-4
  a curric:KeyLearningPoint ;
  rdfs:label "There are different types of subordinate clause."@en ;
  dcterms:modified "2026-02-12T08:59:21.712028Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2730-5
  a curric:KeyLearningPoint ;
  rdfs:label "Any type of subordinate clause must be joined to a main clause to make sense."@en ;
  dcterms:modified "2026-02-12T08:59:21.712032Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27777-1
  a curric:KeyLearningPoint ;
  rdfs:label "Speaking loudly and clearly is important when talking in front of an audience."@en ;
  dcterms:modified "2026-02-12T08:59:21.712037Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27777-2
  a curric:KeyLearningPoint ;
  rdfs:label """The main purpose of public speaking is to inform the audience about something or impact their thoughts/actions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712044Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27777-3
  a curric:KeyLearningPoint ;
  rdfs:label """Strategies to reduce nerves during public speaking include practicing and calm breathing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712049Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27777-4
  a curric:KeyLearningPoint ;
  rdfs:label """A good orator will engage their audience and deliver their speech in a charismatic and persuasive manner."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712053Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4885-1
  a curric:KeyLearningPoint ;
  rdfs:label "The steps in the mummification process are written in chronological order."@en ;
  dcterms:modified "2026-02-12T08:59:21.712058Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4885-2
  a curric:KeyLearningPoint ;
  rdfs:label "Ordering fronted adverbials indicate the order of the steps in a process."@en ;
  dcterms:modified "2026-02-12T08:59:21.712063Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4885-3
  a curric:KeyLearningPoint ;
  rdfs:label """Using the full range of sentence types (simple, compound and complex) improves text flow for the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712068Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4885-4
  a curric:KeyLearningPoint ;
  rdfs:label """Explanation texts include subject-specific vocabulary that is related to the subject of the text."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712072Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4885-5
  a curric:KeyLearningPoint ;
  rdfs:label """Sentences should be said aloud before writing to ensure they make sense and read back once written to check for errors."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712077Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3462-1
  a curric:KeyLearningPoint ;
  rdfs:label "Direct speech is the term used for a character speaking out loud in a text."@en ;
  dcterms:modified "2026-02-12T08:59:21.712119Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3462-2
  a curric:KeyLearningPoint ;
  rdfs:label "Inverted commas are the punctuation that signal direct speech to the reader."@en ;
  dcterms:modified "2026-02-12T08:59:21.712126Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3462-3
  a curric:KeyLearningPoint ;
  rdfs:label "A speech first sentence begins with a character's spoken words."@en ;
  dcterms:modified "2026-02-12T08:59:21.712135Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3462-4
  a curric:KeyLearningPoint ;
  rdfs:label """A speech second sentence begins with the reporting clause followed by a character's spoken words."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712143Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3462-5
  a curric:KeyLearningPoint ;
  rdfs:label """A speech interrupted sentence begins with a character's spoken words and they are interrupted by the reporting clause."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712148Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7839-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of a non-fiction text is to inform, explain, or provide factual information."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712170Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7839-2
  a curric:KeyLearningPoint ;
  rdfs:label """The features of a non-fiction text are designed to help the reader navigate the text and find information easily."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712175Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7839-3
  a curric:KeyLearningPoint ;
  rdfs:label """Contents, glossary and index pages are key features of a non-fiction text like 'Rushing Rivers'"""@en ;
  dcterms:modified "2026-02-12T08:59:21.712179Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7839-4
  a curric:KeyLearningPoint ;
  rdfs:label "The layout of 'Rushing Rivers' is determined by its purpose and audience."@en ;
  dcterms:modified "2026-02-12T08:59:21.712184Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7839-5
  a curric:KeyLearningPoint ;
  rdfs:label "Headings, images and facts are key layout features of 'Rushing Rivers'."@en ;
  dcterms:modified "2026-02-12T08:59:21.712188Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28946-1
  a curric:KeyLearningPoint ;
  rdfs:label """Hearing from the author and illustrator can enhance the reading process by adding layers of meaning and context."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713117Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28946-2
  a curric:KeyLearningPoint ;
  rdfs:label "‘Arthur and the Golden Rope’ is written and illustrated by Joe Todd-Stanton."@en ;
  dcterms:modified "2026-02-12T08:59:21.713151Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28946-3
  a curric:KeyLearningPoint ;
  rdfs:label "Authors and illustrators may gain inspiration from many different sources."@en ;
  dcterms:modified "2026-02-12T08:59:21.713156Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28946-4
  a curric:KeyLearningPoint ;
  rdfs:label """Brownstone’s Mythical Collection follows the stories of the Brownstones & their adventures through ancient mythologies."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713161Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28946-5
  a curric:KeyLearningPoint ;
  rdfs:label """Joe describes himself as a child who explored a lot on his own and this inspired the character of Arthur."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713166Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1162-1
  a curric:KeyLearningPoint ;
  rdfs:label """Both the progressive tense and perfect tense can denote present, past or future action."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713722Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1162-2
  a curric:KeyLearningPoint ;
  rdfs:label "The verb carries the tense of a sentence."@en ;
  dcterms:modified "2026-02-12T08:59:21.713727Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1162-3
  a curric:KeyLearningPoint ;
  rdfs:label """The progressive tense is a tense that makes use of an auxiliary verb from the infinitive 'to be' with the main verb."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713731Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1162-4
  a curric:KeyLearningPoint ;
  rdfs:label """The perfect tense is a tense that makes use of an auxiliary verb from the infinitive 'to have' with the main verb."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713736Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1162-5
  a curric:KeyLearningPoint ;
  rdfs:label """The perfect tense often refers to action that has finished whilst the progressive tense denotes ongoing action."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713741Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7878-1
  a curric:KeyLearningPoint ;
  rdfs:label "Following their mother’s death, Sophia and her family are split up."@en ;
  dcterms:modified "2026-02-12T08:59:21.713835Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7878-2
  a curric:KeyLearningPoint ;
  rdfs:label """Sophia’s father has decided against regaining his kingdom, he has asked Queen Victoria for forgiveness."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713840Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7878-3
  a curric:KeyLearningPoint ;
  rdfs:label """Sophia's father remarries after the death of his wife. Sophia has mixed feelings about her step-family."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713845Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7878-4
  a curric:KeyLearningPoint ;
  rdfs:label """Sufiya Ahmed writes the Duleep Singhs with some shared character traits and some different traits."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713849Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7881-1
  a curric:KeyLearningPoint ;
  rdfs:label """On 2nd July 1928, all British women finally succeeded in achieving the right to vote."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713942Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7881-2
  a curric:KeyLearningPoint ;
  rdfs:label "Inequality is a significant theme of the text."@en ;
  dcterms:modified "2026-02-12T08:59:21.713946Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7881-3
  a curric:KeyLearningPoint ;
  rdfs:label """Inequality is shown not only in the suffragette movement but also the experiences of the Duleep Singh sisters."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713951Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7881-4
  a curric:KeyLearningPoint ;
  rdfs:label """Suffragettes employed various tactics, strategies and approaches to draw attention to their cause."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713956Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7881-5
  a curric:KeyLearningPoint ;
  rdfs:label """Princess Sophia Duleep Singh’s legacy includes her efforts in charity work, medicine and political reform."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713960Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7880-1
  a curric:KeyLearningPoint ;
  rdfs:label """Suffragettes were campaigning for the right for women to vote; this was something that was not permitted at the time."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713990Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7880-2
  a curric:KeyLearningPoint ;
  rdfs:label """Emmeline Pankhurst is the leader of the WSPU (the Women’s Social and Political Union)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713995Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7880-3
  a curric:KeyLearningPoint ;
  rdfs:label "Reading between the lines to search for clues can help to infer meaning."@en ;
  dcterms:modified "2026-02-12T08:59:21.714000Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7880-4
  a curric:KeyLearningPoint ;
  rdfs:label "Evidence from the text helps us to justify our inferences."@en ;
  dcterms:modified "2026-02-12T08:59:21.714005Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8066-1
  a curric:KeyLearningPoint ;
  rdfs:label """After we have taken time to understand a poem’s meaning, themes and structure, we can learn a poem off by heart."""@en ;
  dcterms:modified "2026-02-12T08:59:21.714130Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8066-2
  a curric:KeyLearningPoint ;
  rdfs:label """Learning poetry by heart offers a range of benefits to pupils both emotionally and academically."""@en ;
  dcterms:modified "2026-02-12T08:59:21.714135Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8066-3
  a curric:KeyLearningPoint ;
  rdfs:label "We can use a range of strategies to support us learning poetry by heart."@en ;
  dcterms:modified "2026-02-12T08:59:21.714139Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8066-4
  a curric:KeyLearningPoint ;
  rdfs:label """Once we have been able to practise the poem several times, we can perform the poem aloud in a recital."""@en ;
  dcterms:modified "2026-02-12T08:59:21.714144Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8021-1
  a curric:KeyLearningPoint ;
  rdfs:label "Kennings are phrases of two words that refer to a noun, often used in poetry."@en ;
  dcterms:modified "2026-02-12T08:59:21.714212Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8021-2
  a curric:KeyLearningPoint ;
  rdfs:label "Kennings can describe an object without ever saying what it actually is."@en ;
  dcterms:modified "2026-02-12T08:59:21.714216Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8021-3
  a curric:KeyLearningPoint ;
  rdfs:label "Kennings can provoke the reader's curiosity."@en ;
  dcterms:modified "2026-02-12T08:59:21.714221Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8021-4
  a curric:KeyLearningPoint ;
  rdfs:label "A kenning poem is like a riddle."@en ;
  dcterms:modified "2026-02-12T08:59:21.714226Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7879-1
  a curric:KeyLearningPoint ;
  rdfs:label """Abdul Karim is a member of Queen Victoria’s household. He is teaching the Queen Hindustani."""@en ;
  dcterms:modified "2026-02-12T08:59:21.714303Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7879-2
  a curric:KeyLearningPoint ;
  rdfs:label "Abdul Karim describes India in Chapter 6."@en ;
  dcterms:modified "2026-02-12T08:59:21.714308Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7879-3
  a curric:KeyLearningPoint ;
  rdfs:label """The Duleep Singh sisters visit India in Chapters 9-14; their experiences differ from their expectations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.714313Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7879-4
  a curric:KeyLearningPoint ;
  rdfs:label """Reading from a particular perspective may mean that events or thoughts might not be balanced."""@en ;
  dcterms:modified "2026-02-12T08:59:21.714346Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7879-5
  a curric:KeyLearningPoint ;
  rdfs:label """Readers can compare and contrast a character’s perspective if they discuss shared or similar experiences."""@en ;
  dcterms:modified "2026-02-12T08:59:21.714351Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1062-1
  a curric:KeyLearningPoint ;
  rdfs:label """Notes should not be written in full sentences and bullet points can be used to order notes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.714356Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1062-2
  a curric:KeyLearningPoint ;
  rdfs:label """Viewpoint fronted adverbials and formal fronted adverbials are used at the start of sentences for cohesion."""@en ;
  dcterms:modified "2026-02-12T08:59:21.714361Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1062-3
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the diet paragraph is to show how the diet of the Mesolithic period differed to that of the Neolithic."""@en ;
  dcterms:modified "2026-02-12T08:59:21.714370Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1062-4
  a curric:KeyLearningPoint ;
  rdfs:label """Mesolithic people were nomadic hunter-gatherers (they hunted animals and foraged for berries for food.)"""@en ;
  dcterms:modified "2026-02-12T08:59:21.714375Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1062-5
  a curric:KeyLearningPoint ;
  rdfs:label "Neolithic people began farming, growing crops and using domesticated animals."@en ;
  dcterms:modified "2026-02-12T08:59:21.714380Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7940-1
  a curric:KeyLearningPoint ;
  rdfs:label "Text recommendations are an important part of developing reading for pleasure"@en ;
  dcterms:modified "2026-02-12T08:59:21.714427Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7940-2
  a curric:KeyLearningPoint ;
  rdfs:label """Making a text recommendation includes a personal reason for why the text was relevant to you"""@en ;
  dcterms:modified "2026-02-12T08:59:21.714431Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7940-3
  a curric:KeyLearningPoint ;
  rdfs:label """Making a text recommendation includes a reason that someone else might enjoy the text"""@en ;
  dcterms:modified "2026-02-12T08:59:21.714440Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7940-4
  a curric:KeyLearningPoint ;
  rdfs:label "There are a variety of ways we can share our reading preferences with others"@en ;
  dcterms:modified "2026-02-12T08:59:21.714446Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8063-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘The Tyger’ is a fixed verse poem; each verse has a rhyme scheme of AABB & a clear syllable pattern when reading aloud."""@en ;
  dcterms:modified "2026-02-12T08:59:21.714535Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8063-2
  a curric:KeyLearningPoint ;
  rdfs:label """Understanding a poem, its language and the impression it creates will help us to create an impactful performance."""@en ;
  dcterms:modified "2026-02-12T08:59:21.714539Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8063-3
  a curric:KeyLearningPoint ;
  rdfs:label """We can improve our performances by considering the rhythm and flow of the poem, our use of voice and use of gestures."""@en ;
  dcterms:modified "2026-02-12T08:59:21.714544Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8063-4
  a curric:KeyLearningPoint ;
  rdfs:label "We can improve our performances of poetry through practice."@en ;
  dcterms:modified "2026-02-12T08:59:21.714548Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8062-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘The Tyger’ is a poem written by William Blake in 1794 as part of the collection titled ‘Songs of Experience’."""@en ;
  dcterms:modified "2026-02-12T08:59:21.714630Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8062-2
  a curric:KeyLearningPoint ;
  rdfs:label """Imagery may be interpreted differently depending on the reader or listener's experiences."""@en ;
  dcterms:modified "2026-02-12T08:59:21.714637Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8062-3
  a curric:KeyLearningPoint ;
  rdfs:label """The poem uses symbolism; the use of symbols that represent ideas beyond their literal meaning."""@en ;
  dcterms:modified "2026-02-12T08:59:21.714641Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8062-4
  a curric:KeyLearningPoint ;
  rdfs:label """The poem references two animals: the lamb and the tiger; these can symbolise a range of emotions and themes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.714646Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8062-5
  a curric:KeyLearningPoint ;
  rdfs:label """A take-away idea within a text may link to themes that are explored and developed in it."""@en ;
  dcterms:modified "2026-02-12T08:59:21.714653Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7939-1
  a curric:KeyLearningPoint ;
  rdfs:label "Series texts can develop motivation to read."@en ;
  dcterms:modified "2026-02-12T08:59:21.714776Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7939-2
  a curric:KeyLearningPoint ;
  rdfs:label "A character might be part of a series of texts"@en ;
  dcterms:modified "2026-02-12T08:59:21.714780Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7939-3
  a curric:KeyLearningPoint ;
  rdfs:label """A character trait is a special quality that make a character in a story unique and interesting"""@en ;
  dcterms:modified "2026-02-12T08:59:21.714785Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7939-4
  a curric:KeyLearningPoint ;
  rdfs:label "A character's emotional arc might adapt or change over a series of books"@en ;
  dcterms:modified "2026-02-12T08:59:21.714789Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8061-1
  a curric:KeyLearningPoint ;
  rdfs:label """William Blake was an English poet, painter and printmaker, who was born in  1757 and died in 1827."""@en ;
  dcterms:modified "2026-02-12T08:59:21.714851Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8061-2
  a curric:KeyLearningPoint ;
  rdfs:label """‘The Tyger’ consists of six verses, each with four lines; each verse has a rhyme scheme of AABB."""@en ;
  dcterms:modified "2026-02-12T08:59:21.714885Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8061-3
  a curric:KeyLearningPoint ;
  rdfs:label "The poem 'The Tyger' describes the creation of a powerful and fearsome tiger."@en ;
  dcterms:modified "2026-02-12T08:59:21.714904Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8061-4
  a curric:KeyLearningPoint ;
  rdfs:label """The speaker questions who or what could create such a fearsome and awe-inspiring creature."""@en ;
  dcterms:modified "2026-02-12T08:59:21.714911Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3444-1
  a curric:KeyLearningPoint ;
  rdfs:label "Any clause is a group of words that contains a verb."@en ;
  dcterms:modified "2026-02-12T08:59:21.716257Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3444-2
  a curric:KeyLearningPoint ;
  rdfs:label "A main clause is a group of words that contains a verb and makes complete sense."@en ;
  dcterms:modified "2026-02-12T08:59:21.716262Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3444-3
  a curric:KeyLearningPoint ;
  rdfs:label """A subordinate clause is a group of words that contains a verb and does not make complete sense."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716267Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3444-4
  a curric:KeyLearningPoint ;
  rdfs:label """There are three types of subordinate clause: the adverbial clause, the relative clause and the non-finite clause."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716273Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3444-5
  a curric:KeyLearningPoint ;
  rdfs:label "Any type of subordinate clause must be joined to a main clause to make sense."@en ;
  dcterms:modified "2026-02-12T08:59:21.716278Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8829-1
  a curric:KeyLearningPoint ;
  rdfs:label "'The Day the Crayons Quit' is a children's picture book."@en ;
  dcterms:modified "2026-02-12T08:59:21.716283Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8829-2
  a curric:KeyLearningPoint ;
  rdfs:label """The book is compiled of letters from the crayons to their owner, Duncan, explaining why they are going to quit."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716290Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8829-3
  a curric:KeyLearningPoint ;
  rdfs:label """The illustrations visually bring to life the personalities and emotions of each crayon character."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716295Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8829-4
  a curric:KeyLearningPoint ;
  rdfs:label """Letters are often written when the writer has a feeling or an opinion about something."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716300Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8829-5
  a curric:KeyLearningPoint ;
  rdfs:label """The crayon characters all have different reasons for writing their letter to Duncan."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716304Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4871-1
  a curric:KeyLearningPoint ;
  rdfs:label """The introduction provides general information and outlines the structure of the full report."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716309Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4871-2
  a curric:KeyLearningPoint ;
  rdfs:label "Parenthesis (additional information) can be conveyed using brackets."@en ;
  dcterms:modified "2026-02-12T08:59:21.716313Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4871-3
  a curric:KeyLearningPoint ;
  rdfs:label "Linking sentences at the end of our paragraphs create text cohesion."@en ;
  dcterms:modified "2026-02-12T08:59:21.716318Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4871-4
  a curric:KeyLearningPoint ;
  rdfs:label "Using a plan helps us have more successful writing outcomes"@en ;
  dcterms:modified "2026-02-12T08:59:21.716323Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5807-1
  a curric:KeyLearningPoint ;
  rdfs:label """Writing is most successful when it is planned; this can include planning the vocabulary we may wish to include."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716327Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5807-2
  a curric:KeyLearningPoint ;
  rdfs:label """Juliet's diary entries will cover meeting Romeo, discovering he is a Montague and agreeing to marry him."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716332Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5807-3
  a curric:KeyLearningPoint ;
  rdfs:label """We will want to give Juliet's first impressions of Romeo by showing how she perceives him."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716337Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5807-4
  a curric:KeyLearningPoint ;
  rdfs:label "We will want to show Juliet's emotions at different points in the narrative."@en ;
  dcterms:modified "2026-02-12T08:59:21.716342Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5807-5
  a curric:KeyLearningPoint ;
  rdfs:label "We can use both rich vocabulary and show-not-tell to describe emotions."@en ;
  dcterms:modified "2026-02-12T08:59:21.716346Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27607-1
  a curric:KeyLearningPoint ;
  rdfs:label """There is some vocabulary that is commonly used when retelling a story, particularly a fairy tale."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716390Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27607-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Goldilocks and the Three Bears' uses repetition of the number three as a key storytelling technique."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716395Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27607-3
  a curric:KeyLearningPoint ;
  rdfs:label "Fronted adverbials of time can be used to help sequence a story."@en ;
  dcterms:modified "2026-02-12T08:59:21.716400Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27607-4
  a curric:KeyLearningPoint ;
  rdfs:label """Using precise vocabulary helps to create vivid descriptions of characters, setting and action."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716404Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7359-1
  a curric:KeyLearningPoint ;
  rdfs:label "A theme is a big idea, topic or message that recurs within a story."@en ;
  dcterms:modified "2026-02-12T08:59:21.716969Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7359-2
  a curric:KeyLearningPoint ;
  rdfs:label "Themes often link together and overlap."@en ;
  dcterms:modified "2026-02-12T08:59:21.716974Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7359-3
  a curric:KeyLearningPoint ;
  rdfs:label "The theme of transformation is an important theme in ‘A Christmas Carol’."@en ;
  dcterms:modified "2026-02-12T08:59:21.716978Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7359-4
  a curric:KeyLearningPoint ;
  rdfs:label """Transformation is depicted through Scrooge's journey from a miserly individual to a compassionate and generous one."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716982Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7359-5
  a curric:KeyLearningPoint ;
  rdfs:label """Dickens uses Scrooge’s treatment of others and their treatment of him to convey this change."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716987Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6361-1
  a curric:KeyLearningPoint ;
  rdfs:label """Quotes from witnesses or experts give additional information about the event being reported on."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716991Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6361-2
  a curric:KeyLearningPoint ;
  rdfs:label """Quotes from witnesses are often more informal in language and tone from the rest of the report."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716996Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6361-3
  a curric:KeyLearningPoint ;
  rdfs:label """A reporting clause is used either before or after speech to tell the reader who the quote is from."""@en ;
  dcterms:modified "2026-02-12T08:59:21.717000Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6361-4
  a curric:KeyLearningPoint ;
  rdfs:label """Inverted commas are used to demarcate speech and a piece of punctuation separates speech from the reporting clause."""@en ;
  dcterms:modified "2026-02-12T08:59:21.717007Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6361-5
  a curric:KeyLearningPoint ;
  rdfs:label """A range of synonyms for 'said' and use of adverbs can offer detail about the emotions of the witness."""@en ;
  dcterms:modified "2026-02-12T08:59:21.717011Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4872-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the introduction is to engage the reader and give them general information about the report's subject."""@en ;
  dcterms:modified "2026-02-12T08:59:21.717016Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4872-2
  a curric:KeyLearningPoint ;
  rdfs:label "Tigers can be referred to in the singular or plural throughout a report."@en ;
  dcterms:modified "2026-02-12T08:59:21.717022Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4872-3
  a curric:KeyLearningPoint ;
  rdfs:label """Writers plan and say each sentence aloud before writing it down so that they write more coherent sentences."""@en ;
  dcterms:modified "2026-02-12T08:59:21.717027Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4872-4
  a curric:KeyLearningPoint ;
  rdfs:label """The writing process involves planning, drafting, checking, editing and publishing a piece of writing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.717031Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1035-1
  a curric:KeyLearningPoint ;
  rdfs:label "Editing is the process of making changes to improve our writing."@en ;
  dcterms:modified "2026-02-12T08:59:21.717036Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1035-2
  a curric:KeyLearningPoint ;
  rdfs:label """When editing punctuation, missing or incorrectly used capital letters, full stops and commas are all checked."""@en ;
  dcterms:modified "2026-02-12T08:59:21.717041Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1035-3
  a curric:KeyLearningPoint ;
  rdfs:label """When editing sentence structure, the way sentences are constructed is checked to improve and enhance text flow."""@en ;
  dcterms:modified "2026-02-12T08:59:21.717045Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1035-4
  a curric:KeyLearningPoint ;
  rdfs:label "When editing language, choices of words and phrases are carefully reviewed."@en ;
  dcterms:modified "2026-02-12T08:59:21.717049Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1032-1
  a curric:KeyLearningPoint ;
  rdfs:label "A subheading signals to the reader what the section is about."@en ;
  dcterms:modified "2026-02-12T08:59:21.717056Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1032-2
  a curric:KeyLearningPoint ;
  rdfs:label """A section about one feature of the report's subject contains specific facts and information to keep the reader engaged."""@en ;
  dcterms:modified "2026-02-12T08:59:21.717061Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1032-3
  a curric:KeyLearningPoint ;
  rdfs:label """Writers choose varied fronted adverbials and different sentence types to ensure the text flows for the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.717066Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1032-4
  a curric:KeyLearningPoint ;
  rdfs:label "A section can be composed of one paragraph."@en ;
  dcterms:modified "2026-02-12T08:59:21.717070Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1032-5
  a curric:KeyLearningPoint ;
  rdfs:label """Sentences should be said aloud before writing to ensure they make sense and read back once written to check for errors."""@en ;
  dcterms:modified "2026-02-12T08:59:21.717074Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4849-1
  a curric:KeyLearningPoint ;
  rdfs:label "The opening provides the reader with general information about the event."@en ;
  dcterms:modified "2026-02-12T08:59:21.717227Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4849-2
  a curric:KeyLearningPoint ;
  rdfs:label """The opening includes when, where and what took place and what is currently happening."""@en ;
  dcterms:modified "2026-02-12T08:59:21.717232Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4849-3
  a curric:KeyLearningPoint ;
  rdfs:label """Writers use a range of cohesive devices to maintain the reader's interest and achieve text purpose."""@en ;
  dcterms:modified "2026-02-12T08:59:21.717236Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4849-4
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the opening is to engage the reader and encourage them to read on."""@en ;
  dcterms:modified "2026-02-12T08:59:21.717240Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1399-1
  a curric:KeyLearningPoint ;
  rdfs:label """A prefix is a letter or group of letters at the start of a word which changes its meaning."""@en ;
  dcterms:modified "2026-02-12T08:59:21.717866Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1399-2
  a curric:KeyLearningPoint ;
  rdfs:label "The prefixes ad- and af- mean ‘towards’."@en ;
  dcterms:modified "2026-02-12T08:59:21.717871Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1399-3
  a curric:KeyLearningPoint ;
  rdfs:label "The prefix al- means ‘all’ and a- means ‘in the state of’."@en ;
  dcterms:modified "2026-02-12T08:59:21.717875Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1399-4
  a curric:KeyLearningPoint ;
  rdfs:label """A hyphen can join a prefix to a base word to avoid ambiguity in meaning or spelling."""@en ;
  dcterms:modified "2026-02-12T08:59:21.717880Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1399-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: experience, extreme and increase."@en ;
  dcterms:modified "2026-02-12T08:59:21.717886Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1339-1
  a curric:KeyLearningPoint ;
  rdfs:label "There are four spelling rules when adding -ous to a root word."@en ;
  dcterms:modified "2026-02-12T08:59:21.717891Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1339-2
  a curric:KeyLearningPoint ;
  rdfs:label "If the root word ends in 'ce', use the suffix -cious"@en ;
  dcterms:modified "2026-02-12T08:59:21.717896Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1339-3
  a curric:KeyLearningPoint ;
  rdfs:label "The suffix -cious generally turns a noun into an adjective."@en ;
  dcterms:modified "2026-02-12T08:59:21.717900Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1339-4
  a curric:KeyLearningPoint ;
  rdfs:label """Exceptions or harder root words to identify include these words: anxious, conscious, delicious, suspicious, precious."""@en ;
  dcterms:modified "2026-02-12T08:59:21.717904Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1339-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: prejudice, accommodate and accompany."@en ;
  dcterms:modified "2026-02-12T08:59:21.717909Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4881-1
  a curric:KeyLearningPoint ;
  rdfs:label """An explanation text is a non-fiction text that explains a particular process or subject in detail."""@en ;
  dcterms:modified "2026-02-12T08:59:21.717913Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4881-2
  a curric:KeyLearningPoint ;
  rdfs:label """An explanation text can start with an introduction and then explain a sequenced process in chronological order."""@en ;
  dcterms:modified "2026-02-12T08:59:21.717918Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4881-3
  a curric:KeyLearningPoint ;
  rdfs:label """Vocabulary within an explanation text is subject-specific and factual, creating a formal tone."""@en ;
  dcterms:modified "2026-02-12T08:59:21.717922Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4881-4
  a curric:KeyLearningPoint ;
  rdfs:label """Ordering fronted adverbials indicate the chronological order of steps in a process."""@en ;
  dcterms:modified "2026-02-12T08:59:21.717926Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4881-5
  a curric:KeyLearningPoint ;
  rdfs:label "Fronted adverbials of cause link an effect to a cause."@en ;
  dcterms:modified "2026-02-12T08:59:21.717931Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4884-1
  a curric:KeyLearningPoint ;
  rdfs:label """Notes should not be written in full sentences and bullet points can be used to order notes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.717935Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4884-2
  a curric:KeyLearningPoint ;
  rdfs:label "The main paragraphs in an explanation text follow a clear, chronological order."@en ;
  dcterms:modified "2026-02-12T08:59:21.717940Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4884-3
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials of cause and ordering fronted adverbials are used at the start of sentences for cohesion."""@en ;
  dcterms:modified "2026-02-12T08:59:21.717944Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4884-4
  a curric:KeyLearningPoint ;
  rdfs:label """A subheading signals part of a text and should stand out from the rest of the text."""@en ;
  dcterms:modified "2026-02-12T08:59:21.717976Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4884-5
  a curric:KeyLearningPoint ;
  rdfs:label "The plan should include subject-specific vocabulary."@en ;
  dcterms:modified "2026-02-12T08:59:21.717982Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3460-1
  a curric:KeyLearningPoint ;
  rdfs:label "A semi-colon is a piece of punctuation with more than one purpose."@en ;
  dcterms:modified "2026-02-12T08:59:21.717986Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3460-2
  a curric:KeyLearningPoint ;
  rdfs:label "A semi-colon can be used to join two closely-related main clauses."@en ;
  dcterms:modified "2026-02-12T08:59:21.717991Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3460-3
  a curric:KeyLearningPoint ;
  rdfs:label "A semi-colon can help to improve text cohesion."@en ;
  dcterms:modified "2026-02-12T08:59:21.717998Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3461-1
  a curric:KeyLearningPoint ;
  rdfs:label "A semi-colon is a piece of punctuation with more than one purpose."@en ;
  dcterms:modified "2026-02-12T08:59:21.718003Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3461-2
  a curric:KeyLearningPoint ;
  rdfs:label """A semi-colon can be used to separate items in a detailed list in which each item includes commas."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718007Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3461-3
  a curric:KeyLearningPoint ;
  rdfs:label "A semi-colon can help to avoid ambiguity in a detailed list."@en ;
  dcterms:modified "2026-02-12T08:59:21.718011Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1044-1
  a curric:KeyLearningPoint ;
  rdfs:label "A subordinating conjunction starts an adverbial clause."@en ;
  dcterms:modified "2026-02-12T08:59:21.718016Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1044-2
  a curric:KeyLearningPoint ;
  rdfs:label """There are many different subordinating conjunctions that have different meanings."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718020Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1044-3
  a curric:KeyLearningPoint ;
  rdfs:label "\"As\" is a subordinating conjunction."@en ;
  dcterms:modified "2026-02-12T08:59:21.718025Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1044-4
  a curric:KeyLearningPoint ;
  rdfs:label """Using "as" in an adverbial complex sentence tells the reader a simultaneous action or feeling is occurring."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718029Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1044-5
  a curric:KeyLearningPoint ;
  rdfs:label "A preposition can tell the reader where a noun is."@en ;
  dcterms:modified "2026-02-12T08:59:21.718033Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6145-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the opening is to engage the reader and introduce the setting and characters."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718038Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6145-2
  a curric:KeyLearningPoint ;
  rdfs:label "Precise and ambitious vocabulary is logged on a plan for future use."@en ;
  dcterms:modified "2026-02-12T08:59:21.718044Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6145-3
  a curric:KeyLearningPoint ;
  rdfs:label """Notes should not be written in full sentences and bullet points can be used to make notes clear."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718049Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6145-4
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials of time, place and manner indicate when, where and how action takes place."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718053Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6145-5
  a curric:KeyLearningPoint ;
  rdfs:label """'Show-not-tell' language shows a character’s feelings by describing their actions, body language and facial expressions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718062Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6148-1
  a curric:KeyLearningPoint ;
  rdfs:label "The purpose of the build-up is to build tension and suspense."@en ;
  dcterms:modified "2026-02-12T08:59:21.718067Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6148-2
  a curric:KeyLearningPoint ;
  rdfs:label "Saying sentences aloud before they are written helps to check for sense."@en ;
  dcterms:modified "2026-02-12T08:59:21.718071Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6148-3
  a curric:KeyLearningPoint ;
  rdfs:label """Using the full range of sentence types (simple, compound and complex) improves text flow for the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718076Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6148-4
  a curric:KeyLearningPoint ;
  rdfs:label """A rhetorical question engages the reader and makes them feel more curious about the narrative."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718080Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6148-5
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials of time, place and manner describe the action in the main clause in further detail."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718087Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27628-1
  a curric:KeyLearningPoint ;
  rdfs:label "Self-reflection is an important tool to use for improving."@en ;
  dcterms:modified "2026-02-12T08:59:21.718260Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27628-2
  a curric:KeyLearningPoint ;
  rdfs:label """The winning team in a debate can be decided by an audience vote, or a judge, or a panel of judges."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718265Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27628-3
  a curric:KeyLearningPoint ;
  rdfs:label """The judges award a score out of ten in four different areas: content, style, delivery and points of information."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718269Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1335-1
  a curric:KeyLearningPoint ;
  rdfs:label "The suffix -al is the second most common spelling for the 'l' sound."@en ;
  dcterms:modified "2026-02-12T08:59:21.718273Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1335-2
  a curric:KeyLearningPoint ;
  rdfs:label """If the root word makes sense by itself, it is often likely to have the suffix -al."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718278Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1335-3
  a curric:KeyLearningPoint ;
  rdfs:label """The suffix -al often turns nouns into adjectives and often follows the letters 'on' and 'ic'."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718283Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1335-4
  a curric:KeyLearningPoint ;
  rdfs:label "When the root word ends in ‘e’, remove the ‘e’ and add the suffix."@en ;
  dcterms:modified "2026-02-12T08:59:21.718287Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1335-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: correspond and persuade."@en ;
  dcterms:modified "2026-02-12T08:59:21.718291Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1330-1
  a curric:KeyLearningPoint ;
  rdfs:label "If the root word ends in 'y', remove the 'y' and add -ier."@en ;
  dcterms:modified "2026-02-12T08:59:21.718298Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1330-2
  a curric:KeyLearningPoint ;
  rdfs:label "If the root word ends in 'e', remove the 'e' and add -er."@en ;
  dcterms:modified "2026-02-12T08:59:21.718303Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1330-3
  a curric:KeyLearningPoint ;
  rdfs:label "If the root word contains a short vowel sound, double the consonant and add -er."@en ;
  dcterms:modified "2026-02-12T08:59:21.718308Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1330-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Good' is irregular as it does not follow the same pattern. Instead we have good, better and best."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718312Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1330-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: necessary and average."@en ;
  dcterms:modified "2026-02-12T08:59:21.718316Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1345-1
  a curric:KeyLearningPoint ;
  rdfs:label """The 'ee' sound spelt 'ei' generally comes after the letter 'c' (deceive) or at the beginning of a word (either)"""@en ;
  dcterms:modified "2026-02-12T08:59:21.718340Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1345-2
  a curric:KeyLearningPoint ;
  rdfs:label """Exceptions include: protein, caffeine, seize, weird, foreign as well as either and neither if pronounced as such."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718345Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1345-3
  a curric:KeyLearningPoint ;
  rdfs:label "The 'ei' spelling can also make a long 'ay' sound and break other learnt rules."@en ;
  dcterms:modified "2026-02-12T08:59:21.718352Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1345-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: neighbour and soldier."@en ;
  dcterms:modified "2026-02-12T08:59:21.718357Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6013-1
  a curric:KeyLearningPoint ;
  rdfs:label """Editing is the process of improving writing to ensure text flow and overall quality."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718381Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6013-2
  a curric:KeyLearningPoint ;
  rdfs:label """Editing involves making improvements to a piece of writing without completely rewriting it."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718386Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6013-3
  a curric:KeyLearningPoint ;
  rdfs:label "Editing is a vital part of the writing process."@en ;
  dcterms:modified "2026-02-12T08:59:21.718390Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1043-1
  a curric:KeyLearningPoint ;
  rdfs:label """The position of an adverbial subordinate clause can move in an adverbial complex sentence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718417Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1043-2
  a curric:KeyLearningPoint ;
  rdfs:label """If the adverbial clause comes first in the sentence, it is followed by a comma to demarcate from the main clause."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718421Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1043-3
  a curric:KeyLearningPoint ;
  rdfs:label "If the main clause comes first in the sentence, there is no comma used."@en ;
  dcterms:modified "2026-02-12T08:59:21.718428Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1043-4
  a curric:KeyLearningPoint ;
  rdfs:label "A comma is a punctuation mark that has more than one purpose."@en ;
  dcterms:modified "2026-02-12T08:59:21.718433Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1043-5
  a curric:KeyLearningPoint ;
  rdfs:label """Commas often help the reader see clause demarcation in a range of sentence types."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718437Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4709-1
  a curric:KeyLearningPoint ;
  rdfs:label "A speech should have a clear purpose."@en ;
  dcterms:modified "2026-02-12T08:59:21.718442Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4709-2
  a curric:KeyLearningPoint ;
  rdfs:label "A speech may use techniques such as rhetorical questions or repetition."@en ;
  dcterms:modified "2026-02-12T08:59:21.718446Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1423-1
  a curric:KeyLearningPoint ;
