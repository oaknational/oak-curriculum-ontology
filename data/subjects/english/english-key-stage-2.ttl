  curric:isUnitOf
    natcurric:scheme-english-key-stage-2 ;
  curric:includesThread
    oakcurric:thread-developing-spelling-accuracy .

oakcurric:unit-133
  a curric:Unit ;
  rdfs:label "Noun and adjective suffixes"@en ;
  curric:slug "noun-and-adjective-suffixes" ;
  rdfs:comment """In this unit, pupils learn spelling and grammar conventions associated with
  certain noun and adjective suffixes like -ity, -ness, -tion, -sion, -ssion, -cian, -cial
  and -tial. Pupils review how the addition of a suffix can affect the grammar of a word, in
  most cases by changing its word class."""@en ;
  curric:whyThisWhyNow """This unit uses and builds on pupils' knowledge of spelling and grammar
  conventions associated with verb and adjective suffixes like -ate, -en, -ify, -ise and -ous
  learnt in the Year 4 unit 'Year 4: Verb and adjective suffixes'. In this unit, pupils learn
  noun and adjective suffixes, like -ity, -ness, -tion, -sion, -ssion, -cian, -cial and -tial,
  reviewing how the addition of a suffix can affect the grammar of a word, for example by
  changing its word class. This unit prepares pupils for further suffix work in the Year 4 unit
  'Year 4: Suffixes, etymology and homophones'.""" ;
  curric:hasPriorKnowledgeRequirement
    oakcurric:priorknowledge-133-1 ,
    oakcurric:priorknowledge-133-2 ,
    oakcurric:priorknowledge-133-3 ,
