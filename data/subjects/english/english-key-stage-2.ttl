oakcurric:keylearningpoint-lesson-4823-3
  a curric:KeyLearningPoint ;
  rdfs:label """After forming a capital letter, you need to lift your pencil to start the next part of the word."""@en ;
  dcterms:modified "2026-02-12T08:59:21.659752Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4823-4
  a curric:KeyLearningPoint ;
  rdfs:label "The joins are all used correctly."@en ;
  dcterms:modified "2026-02-12T08:59:21.659759Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1128-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Diffident' is an adjective which means modest or shy."@en ;
  dcterms:modified "2026-02-12T08:59:21.659764Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1128-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Hesitant' is an adjective which means nervous or uncertain."@en ;
  dcterms:modified "2026-02-12T08:59:21.659769Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1128-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Reticent' is an adjective which means shy and reserved."@en ;
  dcterms:modified "2026-02-12T08:59:21.659773Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1099-1
  a curric:KeyLearningPoint ;
  rdfs:label """'Treacherous' is an adjective which means dangerous or unsafe; like terrifying rapids."""@en ;
  dcterms:modified "2026-02-12T08:59:21.659778Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1099-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Murky' is an adjective which means dark, muddy or cloudy; like water that’s so dirty you can barely see through it."""@en ;
  dcterms:modified "2026-02-12T08:59:21.659782Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1099-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Stagnant' is an adjective which means stale or lifeless; like a dirty pond where nothing is living or moving."""@en ;
  dcterms:modified "2026-02-12T08:59:21.659787Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1099-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Choppy', 'frothy' and 'shimmering' are other rich vocabulary associated with water."""@en ;
  dcterms:modified "2026-02-12T08:59:21.659791Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2725-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the build-up is to develop the characters’ emotions and build tension and suspense."""@en ;
  dcterms:modified "2026-02-12T08:59:21.660517Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2725-2
  a curric:KeyLearningPoint ;
  rdfs:label "Notes from a plan can be used to form full sentences."@en ;
  dcterms:modified "2026-02-12T08:59:21.660521Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2725-3
  a curric:KeyLearningPoint ;
  rdfs:label "A new paragraph signifies a new key moment."@en ;
  dcterms:modified "2026-02-12T08:59:21.660526Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2725-4
  a curric:KeyLearningPoint ;
  rdfs:label """A range of sentence types (simple, compound and complex) improves text flow for the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.660530Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2725-5
  a curric:KeyLearningPoint ;
  rdfs:label """A relative complex sentence is formed of a main clause that can be interrupted by a relative clause."""@en ;
  dcterms:modified "2026-02-12T08:59:21.660535Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1083-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Meagre' is an adjective which means limited, small or not enough."@en ;
  dcterms:modified "2026-02-12T08:59:21.660539Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1083-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Hearty' is an adjective which means filling or wholesome."@en ;
  dcterms:modified "2026-02-12T08:59:21.660544Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1083-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Wholesome', 'sumptuous', 'lavish' and 'humble' are other adjectives related to a meal."""@en ;
  dcterms:modified "2026-02-12T08:59:21.660549Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6370-1
  a curric:KeyLearningPoint ;
  rdfs:label """Alfred Noyes uses figurative language and poetic devices to create imagery and describe events in stanza three."""@en ;
  dcterms:modified "2026-02-12T08:59:21.660629Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6370-2
  a curric:KeyLearningPoint ;
  rdfs:label """As this poem was set in the 18th century, some of the language choices may be unfamiliar."""@en ;
  dcterms:modified "2026-02-12T08:59:21.660634Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6370-3
  a curric:KeyLearningPoint ;
  rdfs:label """Understanding the meaning of all vocabulary in the poem enables us to analyse and understand each stanza fully."""@en ;
  dcterms:modified "2026-02-12T08:59:21.660638Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1116-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Bleak' is an adjective which means gloomy or depressing."@en ;
  dcterms:modified "2026-02-12T08:59:21.660664Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1116-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Downpour' is a noun which means a heavy rainstorm."@en ;
  dcterms:modified "2026-02-12T08:59:21.660669Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1116-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Drab' is an adjective which means dull or grey."@en ;
  dcterms:modified "2026-02-12T08:59:21.660675Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6368-1
  a curric:KeyLearningPoint ;
  rdfs:label """Adverbials of time, place and manner explain to the reader when, where and how things happened."""@en ;
  dcterms:modified "2026-02-12T08:59:21.660745Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6368-2
  a curric:KeyLearningPoint ;
  rdfs:label "Figurative language can be used to create atmosphere and imagery for the reader."@en ;
  dcterms:modified "2026-02-12T08:59:21.660750Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6368-3
  a curric:KeyLearningPoint ;
  rdfs:label """A complex sentence consists of at least one main clause and any type of subordinate clause."""@en ;
  dcterms:modified "2026-02-12T08:59:21.660755Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6368-4
  a curric:KeyLearningPoint ;
  rdfs:label "Using a range of sentence types enhances the flow of a text."@en ;
  dcterms:modified "2026-02-12T08:59:21.660760Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6375-1
  a curric:KeyLearningPoint ;
  rdfs:label """The build-up keeps the reader engaged, builds the tension of the plot and develops characters for the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.660973Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6375-2
  a curric:KeyLearningPoint ;
  rdfs:label "Speech first and second sentences can be used to convey dialogue."@en ;
  dcterms:modified "2026-02-12T08:59:21.660978Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6375-3
  a curric:KeyLearningPoint ;
  rdfs:label """Additional information can be added to the reporting clause in the form of adverbial detail or subordination."""@en ;
  dcterms:modified "2026-02-12T08:59:21.660982Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6374-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the build-up is to keep the reader engaged, increase the tension of the plot and develop the characters."""@en ;
  dcterms:modified "2026-02-12T08:59:21.661045Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6374-2
  a curric:KeyLearningPoint ;
  rdfs:label "Dialogue is when two or more characters are speaking in a text."@en ;
  dcterms:modified "2026-02-12T08:59:21.661053Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6374-3
  a curric:KeyLearningPoint ;
  rdfs:label "Dialogue can be written in the form of speech first or speech second sentences."@en ;
  dcterms:modified "2026-02-12T08:59:21.661057Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6374-4
  a curric:KeyLearningPoint ;
  rdfs:label "Show-not-tell can be used to convey a character's thoughts or emotions."@en ;
  dcterms:modified "2026-02-12T08:59:21.661064Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5665-1
  a curric:KeyLearningPoint ;
  rdfs:label "Having defeated Grendel's mother, Beowulf returns to Heorot a hero."@en ;
  dcterms:modified "2026-02-12T08:59:21.661261Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5665-2
  a curric:KeyLearningPoint ;
  rdfs:label """Beowulf wants to return home to Geatland; King Hrothgar sadly lets him go, rewarding him once more."""@en ;
  dcterms:modified "2026-02-12T08:59:21.661265Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5665-3
  a curric:KeyLearningPoint ;
  rdfs:label """Heroes are common in mythology and epic poetry and they have certain typical attributes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.661272Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5665-4
  a curric:KeyLearningPoint ;
  rdfs:label """These attributes might include courage, determination, physical strength, compassion and leadership."""@en ;
  dcterms:modified "2026-02-12T08:59:21.661277Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5665-5
  a curric:KeyLearningPoint ;
  rdfs:label "Beowulf has demonstrated these attributes throughout his time in Denmark."@en ;
  dcterms:modified "2026-02-12T08:59:21.661282Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1115-1
  a curric:KeyLearningPoint ;
  rdfs:label "Overcast is an adjective which means cloudy or grey."@en ;
  dcterms:modified "2026-02-12T08:59:21.661350Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1115-2
  a curric:KeyLearningPoint ;
  rdfs:label "Swirling is an adjective which means spiralling or twirling."@en ;
  dcterms:modified "2026-02-12T08:59:21.661392Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1115-3
  a curric:KeyLearningPoint ;
  rdfs:label "Wispy is an adjective which means thin or fine."@en ;
  dcterms:modified "2026-02-12T08:59:21.661398Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7901-1
  a curric:KeyLearningPoint ;
  rdfs:label "The protagonist of the story is August ‘Auggie’ Pullman."@en ;
  dcterms:modified "2026-02-12T08:59:21.661848Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7901-2
  a curric:KeyLearningPoint ;
  rdfs:label """August was born with a facial deformity which marks him out to be ‘different’ and subjected to discrimination."""@en ;
  dcterms:modified "2026-02-12T08:59:21.661853Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7901-3
  a curric:KeyLearningPoint ;
  rdfs:label """August gradually wins over his peers and becomes an integral part of the school community."""@en ;
  dcterms:modified "2026-02-12T08:59:21.661857Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7901-4
  a curric:KeyLearningPoint ;
  rdfs:label """The book is structured to show each character's different perspective; these are referred to as 'parts'."""@en ;
  dcterms:modified "2026-02-12T08:59:21.661862Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7901-5
  a curric:KeyLearningPoint ;
  rdfs:label """A take-away idea within a text may link to themes that are explored and developed in it."""@en ;
  dcterms:modified "2026-02-12T08:59:21.661866Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6719-1
  a curric:KeyLearningPoint ;
  rdfs:label """Darwin proposed the theory of evolution by natural selection to explain animals' adaptations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.661890Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6719-2
  a curric:KeyLearningPoint ;
  rdfs:label """The theory is based on the idea that within a species, there are variations and competition."""@en ;
  dcterms:modified "2026-02-12T08:59:21.661894Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6719-3
  a curric:KeyLearningPoint ;
  rdfs:label """Within a habitat, some individuals will be better-adapted and others will be less-well-adapted."""@en ;
  dcterms:modified "2026-02-12T08:59:21.661899Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6719-4
  a curric:KeyLearningPoint ;
  rdfs:label """The better-adapted individuals are more likely to survive and reproduce, passing on these advantageous characteristics."""@en ;
  dcterms:modified "2026-02-12T08:59:21.661904Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6719-5
  a curric:KeyLearningPoint ;
  rdfs:label """Over a huge period of time, the advantageous characteristics become normal in the species (or can create a new species)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.661908Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5845-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of an editing lesson is to improve writing and make necessary corrections."""@en ;
  dcterms:modified "2026-02-12T08:59:21.662177Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5845-2
  a curric:KeyLearningPoint ;
  rdfs:label """Vocabulary, grammar and punctuation can be changed to make writing more effective."""@en ;
  dcterms:modified "2026-02-12T08:59:21.662181Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5845-3
  a curric:KeyLearningPoint ;
  rdfs:label "We edit to ensure that our use of tense is consistent and correct."@en ;
  dcterms:modified "2026-02-12T08:59:21.662186Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2723-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the opening is to engage the reader and introduce the setting and characters."""@en ;
  dcterms:modified "2026-02-12T08:59:21.662330Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2723-2
  a curric:KeyLearningPoint ;
  rdfs:label """Using a range of sentence types (simple, compound and complex) improves text flow for the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.662335Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2723-3
  a curric:KeyLearningPoint ;
  rdfs:label """Direct speech is punctuated using inverted commas; dialogue moves the action forward."""@en ;
  dcterms:modified "2026-02-12T08:59:21.662339Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2723-4
  a curric:KeyLearningPoint ;
  rdfs:label "Notes from the plan can be used to form full sentences."@en ;
  dcterms:modified "2026-02-12T08:59:21.662346Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2723-5
  a curric:KeyLearningPoint ;
  rdfs:label "A new paragraph is used to signal the start of a new idea or key moment."@en ;
  dcterms:modified "2026-02-12T08:59:21.662351Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8052-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘Cosmic Disco’ is a free verse poem without a strict line length or rhyming structure."""@en ;
  dcterms:modified "2026-02-12T08:59:21.662994Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8052-2
  a curric:KeyLearningPoint ;
  rdfs:label """Understanding a poem, its language and the impression it creates will help us to create an impactful performance."""@en ;
  dcterms:modified "2026-02-12T08:59:21.662999Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8052-3
  a curric:KeyLearningPoint ;
  rdfs:label "We can improve our performances of poetry through practice."@en ;
  dcterms:modified "2026-02-12T08:59:21.663003Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8052-4
  a curric:KeyLearningPoint ;
  rdfs:label """The rhythm and flow, our use of voice, gestures and movement & showing expression and emotion all help our performance."""@en ;
  dcterms:modified "2026-02-12T08:59:21.663008Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8137-1
  a curric:KeyLearningPoint ;
  rdfs:label """When rehearsing and planning to write a diary entry, we do so in the first person from the character's perspective."""@en ;
  dcterms:modified "2026-02-12T08:59:21.663565Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8137-2
  a curric:KeyLearningPoint ;
  rdfs:label "An effective plan for a diary entry contains important thoughts and feelings."@en ;
  dcterms:modified "2026-02-12T08:59:21.663572Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8137-3
  a curric:KeyLearningPoint ;
  rdfs:label """A plan is written in note format using bullet points to capture the most important information."""@en ;
  dcterms:modified "2026-02-12T08:59:21.663577Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8137-4
  a curric:KeyLearningPoint ;
  rdfs:label "This paragraph will explain what the girl misses about home."@en ;
  dcterms:modified "2026-02-12T08:59:21.663581Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8137-5
  a curric:KeyLearningPoint ;
  rdfs:label "This paragraph will also explain what the girl hopes for in the future."@en ;
  dcterms:modified "2026-02-12T08:59:21.663586Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6720-1
  a curric:KeyLearningPoint ;
  rdfs:label "Writing is most successful when it is planned."@en ;
  dcterms:modified "2026-02-12T08:59:21.664325Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6720-2
  a curric:KeyLearningPoint ;
  rdfs:label """Our biography of Charles Darwin will contain paragraphs organised by theme and in chronological order."""@en ;
  dcterms:modified "2026-02-12T08:59:21.664329Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6720-3
  a curric:KeyLearningPoint ;
  rdfs:label """We can plan in note form, using our text map to support us in recalling information about the subject of the biography."""@en ;
  dcterms:modified "2026-02-12T08:59:21.664334Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6720-4
  a curric:KeyLearningPoint ;
  rdfs:label "When we write, we use a range of cohesive devices to connect ideas together."@en ;
  dcterms:modified "2026-02-12T08:59:21.664338Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1082-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Crave' is a verb which means to long for or desire."@en ;
  dcterms:modified "2026-02-12T08:59:21.665615Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1082-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Insatiable' is an adjective which means greedy or impossible to satisfy."@en ;
  dcterms:modified "2026-02-12T08:59:21.665619Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1082-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Voracious', 'ravenous', 'parched', and 'famished' are other adjectives related to hunger and thirst."""@en ;
  dcterms:modified "2026-02-12T08:59:21.665626Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6696-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the climax is to describe the main action and take the suspense and excitement to its highest point."""@en ;
  dcterms:modified "2026-02-12T08:59:21.665982Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6696-2
  a curric:KeyLearningPoint ;
  rdfs:label """Precise and ambitious vocabulary create vivid images for the reader for each key moment of the climax."""@en ;
  dcterms:modified "2026-02-12T08:59:21.665987Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6696-3
  a curric:KeyLearningPoint ;
  rdfs:label "An effective plan has vocabulary organised concisely and neatly."@en ;
  dcterms:modified "2026-02-12T08:59:21.665991Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6696-4
  a curric:KeyLearningPoint ;
  rdfs:label """Careful verb and adverb selection can convey characters' feelings through ‘show and tell’."""@en ;
  dcterms:modified "2026-02-12T08:59:21.665996Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6696-5
  a curric:KeyLearningPoint ;
  rdfs:label "Synonyms for ‘said’ are used to convey character emotion in speech."@en ;
  dcterms:modified "2026-02-12T08:59:21.666000Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6721-1
  a curric:KeyLearningPoint ;
  rdfs:label """In a biography, we write using a formal tone in the third person; our writing is mostly, but not all, in the past tense."""@en ;
  dcterms:modified "2026-02-12T08:59:21.666054Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6721-2
  a curric:KeyLearningPoint ;
  rdfs:label "We use a range of cohesive devices to connect ideas together."@en ;
  dcterms:modified "2026-02-12T08:59:21.666058Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6721-3
  a curric:KeyLearningPoint ;
  rdfs:label "We orally rehearse our sentences before we write."@en ;
  dcterms:modified "2026-02-12T08:59:21.666063Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6721-4
  a curric:KeyLearningPoint ;
  rdfs:label """We use our notes from our plan to help us write (including the subject-specific vocabulary we planned to use)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.666068Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6721-5
  a curric:KeyLearningPoint ;
  rdfs:label """We give a title for the biography as a whole and subheadings for each paragraph. Each paragraph is indented."""@en ;
  dcterms:modified "2026-02-12T08:59:21.666072Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1097-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Impenetrable' is an adjective which means dense or inaccessible."@en ;
  dcterms:modified "2026-02-12T08:59:21.666077Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1097-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Barren' is an adjective which means empty or bare."@en ;
  dcterms:modified "2026-02-12T08:59:21.666081Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1097-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Teeming' is an adjective which means full or crowded."@en ;
  dcterms:modified "2026-02-12T08:59:21.666086Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1097-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Overgrown', 'withered' and 'tangled' are other rich vocabulary associated with the outdoors."""@en ;
  dcterms:modified "2026-02-12T08:59:21.666093Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8047-1
  a curric:KeyLearningPoint ;
  rdfs:label """A pantoum is a form of poetry, originating in Malaysia; they are characterised by their repeating lines."""@en ;
  dcterms:modified "2026-02-12T08:59:21.667021Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8047-2
  a curric:KeyLearningPoint ;
  rdfs:label """The second and fourth lines of one verse are included as the first and third lines of the next verse."""@en ;
  dcterms:modified "2026-02-12T08:59:21.667026Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8047-3
  a curric:KeyLearningPoint ;
  rdfs:label """Repeated lines in pantoums can gain new context and meaning as they are combined within different verses."""@en ;
  dcterms:modified "2026-02-12T08:59:21.667030Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8047-4
  a curric:KeyLearningPoint ;
  rdfs:label """The first and third lines of the first verse are mirrored in the final verse in the second and fourth lines."""@en ;
  dcterms:modified "2026-02-12T08:59:21.667035Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8047-5
  a curric:KeyLearningPoint ;
  rdfs:label "Pupils can make specific language choices to describe the intensity of the rain."@en ;
  dcterms:modified "2026-02-12T08:59:21.667040Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8045-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘First Snow’ describes a changed landscape as a narrator explores their surroundings."""@en ;
  dcterms:modified "2026-02-12T08:59:21.667095Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8045-2
  a curric:KeyLearningPoint ;
  rdfs:label "Rhetorical questions are included in each verse."@en ;
  dcterms:modified "2026-02-12T08:59:21.667100Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8045-3
  a curric:KeyLearningPoint ;
  rdfs:label "'First Snow' uses the rhyme scheme: ABBA."@en ;
  dcterms:modified "2026-02-12T08:59:21.667105Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8045-4
  a curric:KeyLearningPoint ;
  rdfs:label """John Mole uses imagery to create a picture or impression of the scene in the reader or listener’s mind."""@en ;
  dcterms:modified "2026-02-12T08:59:21.667109Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1074-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Deflated' is an adjective which means feeling hopeless or let down."@en ;
  dcterms:modified "2026-02-12T08:59:21.669955Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1074-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Envious' is an adjective which means jealous or resentful."@en ;
  dcterms:modified "2026-02-12T08:59:21.669960Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1074-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Disheartened', 'regretful', 'humiliated' and 'snubbed' are other rich vocabulary associated with feeling bad."""@en ;
  dcterms:modified "2026-02-12T08:59:21.669964Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5698-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of a build-up is to develop the characters and plot and often to introduce a problem."""@en ;
  dcterms:modified "2026-02-12T08:59:21.670008Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5698-2
  a curric:KeyLearningPoint ;
  rdfs:label "Saying sentences aloud before they are written helps to check for sense."@en ;
  dcterms:modified "2026-02-12T08:59:21.670013Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5698-3
  a curric:KeyLearningPoint ;
  rdfs:label """Using the full range of sentence types (simple, compound and complex) improves text flow for the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.670017Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5698-4
  a curric:KeyLearningPoint ;
  rdfs:label """A rhetorical question engages the reader and makes them feel more curious about the narrative."""@en ;
  dcterms:modified "2026-02-12T08:59:21.670053Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5698-5
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials of time, place and manner describe the action in the main clause in further detail."""@en ;
  dcterms:modified "2026-02-12T08:59:21.670061Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6764-1
  a curric:KeyLearningPoint ;
  rdfs:label "The conclusion is the final paragraph of a non-fiction text."@en ;
  dcterms:modified "2026-02-12T08:59:21.670198Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6764-2
  a curric:KeyLearningPoint ;
  rdfs:label "Information in the conclusion should be kept general."@en ;
  dcterms:modified "2026-02-12T08:59:21.670203Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6764-3
  a curric:KeyLearningPoint ;
  rdfs:label """Plans should be used to document key, concise ideas. They can be built upon when writing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.670207Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6764-4
  a curric:KeyLearningPoint ;
  rdfs:label "When writing, we should use our success criteria and plan to guide us."@en ;
  dcterms:modified "2026-02-12T08:59:21.670212Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6764-5
  a curric:KeyLearningPoint ;
  rdfs:label """Using a range of cohesive devices enhances text flow and helps achieve the text purpose."""@en ;
  dcterms:modified "2026-02-12T08:59:21.670216Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1125-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Shrivelled' is an adjective which means wrinkled or shrunken."@en ;
  dcterms:modified "2026-02-12T08:59:21.670289Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1125-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Squat' is an adjective which means short and stubby."@en ;
  dcterms:modified "2026-02-12T08:59:21.670294Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1125-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Willowy' is an adjective which means tall, slender and graceful."@en ;
  dcterms:modified "2026-02-12T08:59:21.670299Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5628-1
  a curric:KeyLearningPoint ;
  rdfs:label """This paragraph of the diary entry recounts the boy’s encounters with characters in the forest from his perspective."""@en ;
  dcterms:modified "2026-02-12T08:59:21.670630Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5628-2
  a curric:KeyLearningPoint ;
  rdfs:label """The boy encounters a boy with a cow first, then a girl with long, golden plaits and then a pair of abandoned children."""@en ;
  dcterms:modified "2026-02-12T08:59:21.670635Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5628-3
  a curric:KeyLearningPoint ;
  rdfs:label """Thoughts and feelings can be explicitly stated and conveyed through the use of ‘show and tell’."""@en ;
  dcterms:modified "2026-02-12T08:59:21.670639Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5628-4
  a curric:KeyLearningPoint ;
  rdfs:label "The boy’s emotions heighten over the course of the encounters."@en ;
  dcterms:modified "2026-02-12T08:59:21.670644Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5628-5
  a curric:KeyLearningPoint ;
  rdfs:label """Your plan should contain precise and ambitious vocabulary and thoughts and feelings for each encounter."""@en ;
  dcterms:modified "2026-02-12T08:59:21.670648Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4866-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of a conclusion is to summarise the information of the text for the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.670669Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4866-2
  a curric:KeyLearningPoint ;
  rdfs:label "A summary sentence summarises the key information from the text."@en ;
  dcterms:modified "2026-02-12T08:59:21.670674Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4866-3
  a curric:KeyLearningPoint ;
  rdfs:label "A conclusion can begin with a formal fronted adverbial."@en ;
  dcterms:modified "2026-02-12T08:59:21.670678Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4866-4
  a curric:KeyLearningPoint ;
  rdfs:label "No new information about the subject is given to the reader in the conclusion."@en ;
  dcterms:modified "2026-02-12T08:59:21.670683Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4866-5
  a curric:KeyLearningPoint ;
  rdfs:label """A conclusion finishes with the writer suggesting to the reader how to find out more."""@en ;
  dcterms:modified "2026-02-12T08:59:21.670687Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8053-1
  a curric:KeyLearningPoint ;
  rdfs:label """Reader identity is the process of reflecting on what you enjoy or do not enjoy reading."""@en ;
  dcterms:modified "2026-02-12T08:59:21.670984Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8053-2
  a curric:KeyLearningPoint ;
  rdfs:label "Reading can take many forms; it does not have to be restricted to a book."@en ;
  dcterms:modified "2026-02-12T08:59:21.670989Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8053-3
  a curric:KeyLearningPoint ;
  rdfs:label """Researching the author, illustrator or poet can provide us with an insight into how a text was created."""@en ;
  dcterms:modified "2026-02-12T08:59:21.670994Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4819-1
  a curric:KeyLearningPoint ;
  rdfs:label "The /shun/ suffix can be spelt -tion, -sion, -ssion or -cian."@en ;
  dcterms:modified "2026-02-12T08:59:21.671019Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4819-2
  a curric:KeyLearningPoint ;
  rdfs:label "The words start with a lead in on the line and finish with a lead out."@en ;
  dcterms:modified "2026-02-12T08:59:21.671024Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4819-3
  a curric:KeyLearningPoint ;
  rdfs:label "The cursive letter join used depends on which letter is joining to which letter."@en ;
  dcterms:modified "2026-02-12T08:59:21.671028Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4819-4
  a curric:KeyLearningPoint ;
  rdfs:label "You don't lift your pencil when forming the joins."@en ;
  dcterms:modified "2026-02-12T08:59:21.671033Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4819-5
  a curric:KeyLearningPoint ;
  rdfs:label """You only lift your pencil once the letter string is complete or there is a break letter within the letter string."""@en ;
  dcterms:modified "2026-02-12T08:59:21.671037Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1094-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Affluent' is an adjective which means rich or wealthy."@en ;
  dcterms:modified "2026-02-12T08:59:21.671088Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1094-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Diverse' is an adjective which means mixed or various."@en ;
  dcterms:modified "2026-02-12T08:59:21.671092Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1094-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Imposing' is an adjective which means grand or impressive."@en ;
  dcterms:modified "2026-02-12T08:59:21.671097Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1094-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Hectic', 'bustling' and 'polluted' are other rich vocabulary associated with the city."""@en ;
  dcterms:modified "2026-02-12T08:59:21.671101Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8056-1
  a curric:KeyLearningPoint ;
  rdfs:label """Reading a range of poetry, from diverse poets, can develop our appreciation of the poetic form"""@en ;
  dcterms:modified "2026-02-12T08:59:21.671464Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8056-2
  a curric:KeyLearningPoint ;
  rdfs:label """Poetry can take many forms, including: haiku, limerick, cinquain, sonnet, tanka, riddle, acrostic"""@en ;
  dcterms:modified "2026-02-12T08:59:21.671469Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8056-3
  a curric:KeyLearningPoint ;
  rdfs:label "A lyric can be written in poem form; lyrics can express the writer's emotions"@en ;
  dcterms:modified "2026-02-12T08:59:21.671473Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8056-4
  a curric:KeyLearningPoint ;
  rdfs:label """A verse novel is a narrative told through poetry, blending prose and poetic elements"""@en ;
  dcterms:modified "2026-02-12T08:59:21.671478Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1079-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Overpowering' is an adjective which means overwhelming or unbearable."@en ;
  dcterms:modified "2026-02-12T08:59:21.672006Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1079-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Pungent' is an adjective which means having a strong smell or sharp taste."@en ;
  dcterms:modified "2026-02-12T08:59:21.672011Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1079-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Putrid' is an adjective which means rotten and decayed."@en ;
  dcterms:modified "2026-02-12T08:59:21.672015Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1079-4
  a curric:KeyLearningPoint ;
  rdfs:label "'Faint', 'musty' and 'toxic' are other adjectives related to smell."@en ;
  dcterms:modified "2026-02-12T08:59:21.672020Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5696-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of a narrative opening is to introduce the characters and to describe the setting to the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.672027Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5696-2
  a curric:KeyLearningPoint ;
  rdfs:label "Saying sentences aloud before they are written helps to check for sense."@en ;
  dcterms:modified "2026-02-12T08:59:21.672032Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5696-3
  a curric:KeyLearningPoint ;
  rdfs:label """Using the full range of sentence types (simple, compound and complex) improves text flow for the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.672036Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5696-4
  a curric:KeyLearningPoint ;
  rdfs:label """A rhetorical question engages the reader and makes them feel more curious about the narrative."""@en ;
  dcterms:modified "2026-02-12T08:59:21.672041Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5696-5
  a curric:KeyLearningPoint ;
  rdfs:label """Show and tell language uses characters' movements, body language and facial expressions to describe feelings."""@en ;
  dcterms:modified "2026-02-12T08:59:21.672045Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8093-1
  a curric:KeyLearningPoint ;
  rdfs:label """We can analyse a scene in a graphic novel by exploring the visual, narrative and contextual elements."""@en ;
  dcterms:modified "2026-02-12T08:59:21.672052Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8093-2
  a curric:KeyLearningPoint ;
  rdfs:label """Visuals refer to how the panels are presented on the page, the illustration style and how characters are portrayed."""@en ;
  dcterms:modified "2026-02-12T08:59:21.672057Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8093-3
  a curric:KeyLearningPoint ;
  rdfs:label "Narrative is how dialogue and text develop the plot and action."@en ;
  dcterms:modified "2026-02-12T08:59:21.672062Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8093-4
  a curric:KeyLearningPoint ;
  rdfs:label """Context refers to what the characters learn in a scene, how they change, as well as how the scene fits within the plot."""@en ;
  dcterms:modified "2026-02-12T08:59:21.672066Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8093-5
  a curric:KeyLearningPoint ;
  rdfs:label "We can ask questions about scenes to develop our understanding of the text."@en ;
  dcterms:modified "2026-02-12T08:59:21.672071Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6193-1
  a curric:KeyLearningPoint ;
  rdfs:label "Our essay gives a logical argument that builds towards a conclusion."@en ;
  dcterms:modified "2026-02-12T08:59:21.672084Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6193-2
  a curric:KeyLearningPoint ;
  rdfs:label """Throughout the essay, we connect ideas using a range of linguistic features and we support ideas with evidence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.672089Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6193-3
  a curric:KeyLearningPoint ;
  rdfs:label "We use a formal tone in an essay because we want to sound authoritative."@en ;
  dcterms:modified "2026-02-12T08:59:21.672094Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6193-4
  a curric:KeyLearningPoint ;
  rdfs:label """Our conclusion should directly address the essay question, making the end-point of our logical argument clear."""@en ;
  dcterms:modified "2026-02-12T08:59:21.672098Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6193-5
  a curric:KeyLearningPoint ;
  rdfs:label """It is useful to orally rehearse our ideas before writing to reduce our cognitive load."""@en ;
  dcterms:modified "2026-02-12T08:59:21.672103Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6345-1
  a curric:KeyLearningPoint ;
  rdfs:label "Writing is most successful when structure, content and vocabulary is planned."@en ;
  dcterms:modified "2026-02-12T08:59:21.672107Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6345-2
  a curric:KeyLearningPoint ;
  rdfs:label "Oral rehearsal is an important step in the writing process."@en ;
  dcterms:modified "2026-02-12T08:59:21.672112Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6345-3
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials of place, prepositions and precise vocabulary paint the picture for a reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.672117Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6345-4
  a curric:KeyLearningPoint ;
  rdfs:label "Complex sentences can be used to show the connections between ideas."@en ;
  dcterms:modified "2026-02-12T08:59:21.672121Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6345-5
  a curric:KeyLearningPoint ;
  rdfs:label "We can connect linked sentences using a semi-colon."@en ;
  dcterms:modified "2026-02-12T08:59:21.672125Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1081-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Irresistible' is an adjective which means gorgeous and inviting."@en ;
  dcterms:modified "2026-02-12T08:59:21.672147Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1081-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Tantalising' is an adjective which means tasty or delicious."@en ;
  dcterms:modified "2026-02-12T08:59:21.672151Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1081-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Scrumptious', 'mouthwatering', 'succulent' and 'moist' are other adjectives related to the word delicious."""@en ;
  dcterms:modified "2026-02-12T08:59:21.672156Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6414-1
  a curric:KeyLearningPoint ;
  rdfs:label """Knowing the events we are going to retell really well before we write frees up our brain to focus on writing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.672262Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6414-2
  a curric:KeyLearningPoint ;
  rdfs:label """Using a text map to tell the events of a story is a great way of embedding these events in our memory."""@en ;
  dcterms:modified "2026-02-12T08:59:21.672267Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6414-3
  a curric:KeyLearningPoint ;
  rdfs:label """In a diary, we are writing about our experiences and feelings in the past and present."""@en ;
  dcterms:modified "2026-02-12T08:59:21.672272Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6414-4
  a curric:KeyLearningPoint ;
  rdfs:label """To write a diary in role as another person, we need to try and empathise with that person."""@en ;
  dcterms:modified "2026-02-12T08:59:21.672277Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6414-5
  a curric:KeyLearningPoint ;
  rdfs:label """Role-play and drama are good ways of trying to empathise with a person and consider their emotions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.672284Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1113-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Lashing' is an adjective which means thrashing or beating."@en ;
  dcterms:modified "2026-02-12T08:59:21.672328Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1113-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Tempestuous' is an adjective which means stormy, wild or violent."@en ;
  dcterms:modified "2026-02-12T08:59:21.672332Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1113-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Torrential' is an adjective which means falling heavily or forcefully."@en ;
  dcterms:modified "2026-02-12T08:59:21.672336Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1132-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Blundering' is an adjective which means goofy or clumsy."@en ;
  dcterms:modified "2026-02-12T08:59:21.673224Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1132-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Bumbling' is an adjective which means awkward, clumsy or useless."@en ;
  dcterms:modified "2026-02-12T08:59:21.673228Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1132-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Butterfingered' is an adjective which means clumsy or accident-prone."@en ;
  dcterms:modified "2026-02-12T08:59:21.673233Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8830-1
  a curric:KeyLearningPoint ;
  rdfs:label """The crayons in ‘The Day the Crayons Quit’ use letters to explain to Duncan why they are going to quit."""@en ;
  dcterms:modified "2026-02-12T08:59:21.673237Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8830-2
  a curric:KeyLearningPoint ;
  rdfs:label "They all share different emotions in their letters."@en ;
  dcterms:modified "2026-02-12T08:59:21.673244Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8830-3
  a curric:KeyLearningPoint ;
  rdfs:label """Simple sentences can be written in the simple present, progressive present and perfect present tense."""@en ;
  dcterms:modified "2026-02-12T08:59:21.673249Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8830-4
  a curric:KeyLearningPoint ;
  rdfs:label """A simple sentence is formed of a main clause; a main clause contains a verb and makes sense by itself."""@en ;
  dcterms:modified "2026-02-12T08:59:21.673254Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8830-5
  a curric:KeyLearningPoint ;
  rdfs:label """One type of simple sentence is the statement: it tells the reader a fact or an opinion."""@en ;
  dcterms:modified "2026-02-12T08:59:21.673258Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8019-1
  a curric:KeyLearningPoint ;
  rdfs:label """'Ozymandias' is a sonnet by Percy Bysshe Shelley that describes a ruined statue of a once-powerful king."""@en ;
  dcterms:modified "2026-02-12T08:59:21.673446Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8019-2
  a curric:KeyLearningPoint ;
  rdfs:label "This poem explores the themes of life and death and the passing of time."@en ;
  dcterms:modified "2026-02-12T08:59:21.673451Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8019-3
  a curric:KeyLearningPoint ;
  rdfs:label """A sonnet is a form of poetry with fourteen lines, which usually follows a rhyme scheme."""@en ;
  dcterms:modified "2026-02-12T08:59:21.673455Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8019-4
  a curric:KeyLearningPoint ;
  rdfs:label "Percy Bysshe Shelley is one of Britain’s most famous poets."@en ;
  dcterms:modified "2026-02-12T08:59:21.673459Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1064-1
  a curric:KeyLearningPoint ;
  rdfs:label """Notes should be written in note form and bullet points can be used to order notes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.673464Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1064-2
  a curric:KeyLearningPoint ;
  rdfs:label """Viewpoint fronted adverbials and formal fronted adverbials are used at the start of sentences for cohesion."""@en ;
  dcterms:modified "2026-02-12T08:59:21.673471Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1064-3
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the houses paragraph is to show how housing of the Mesolithic period differed to that of the Neolithic."""@en ;
  dcterms:modified "2026-02-12T08:59:21.673478Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1064-4
  a curric:KeyLearningPoint ;
  rdfs:label """Mesolithic people were nomadic: they carried their homes with them as they moved."""@en ;
  dcterms:modified "2026-02-12T08:59:21.673483Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1064-5
  a curric:KeyLearningPoint ;
  rdfs:label "Neolithic people began settling in small communties in houses built of stone."@en ;
  dcterms:modified "2026-02-12T08:59:21.673488Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1091-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Gruelling' is an adjective, which means difficult or draining."@en ;
  dcterms:modified "2026-02-12T08:59:21.673633Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1091-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Tedious' is an adjective, which means boring or dull."@en ;
  dcterms:modified "2026-02-12T08:59:21.673638Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1091-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Laborious', 'overwhelming', 'backbreaking' and 'exhausted' are other adjectives related to hard-work."""@en ;
  dcterms:modified "2026-02-12T08:59:21.673642Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1085-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Devour' is a verb which means to eat hungrily or gobble up."@en ;
  dcterms:modified "2026-02-12T08:59:21.674014Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1085-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Demolish' is a verb which means to destroy or eat up."@en ;
  dcterms:modified "2026-02-12T08:59:21.674022Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1085-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Savour', inhale', 'guzzle' and 'gorge' are other verbs related to eating."@en ;
  dcterms:modified "2026-02-12T08:59:21.674027Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1086-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Submerged' is an adjective, which means to be completely underwater."@en ;
  dcterms:modified "2026-02-12T08:59:21.674661Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1086-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Drenched' is an adjective, which means sopping wet or soaked."@en ;
  dcterms:modified "2026-02-12T08:59:21.674666Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1086-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Immerse', 'squirt', 'douse' and 'plunge' are other verbs related to the word wet."""@en ;
  dcterms:modified "2026-02-12T08:59:21.674671Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1123-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Fiery' is an adjective which means hot-tempered, passionate or burning."@en ;
  dcterms:modified "2026-02-12T08:59:21.674675Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1123-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Steely' is an adjective which means cold and determined."@en ;
  dcterms:modified "2026-02-12T08:59:21.674679Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1123-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Vacant' is an adjective which means empty or without emotion."@en ;
  dcterms:modified "2026-02-12T08:59:21.674684Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1126-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Assertive' is an adjective which means forceful or self-confident."@en ;
  dcterms:modified "2026-02-12T08:59:21.674688Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1126-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Audacious' is an adjective which means bold and daring."@en ;
  dcterms:modified "2026-02-12T08:59:21.674693Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1126-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Brazen' is an adjective which means bold and shameless."@en ;
  dcterms:modified "2026-02-12T08:59:21.674697Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1110-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Balmy' is an adjective which means mild or warm."@en ;
  dcterms:modified "2026-02-12T08:59:21.674746Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1110-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Dewy' is an adjective which means moist or damp."@en ;
  dcterms:modified "2026-02-12T08:59:21.674751Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1110-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Temperate' is an adjective which means mild or pleasant."@en ;
  dcterms:modified "2026-02-12T08:59:21.674755Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5627-1
  a curric:KeyLearningPoint ;
  rdfs:label "The recount in a diary entry is written mainly in the past tense."@en ;
  dcterms:modified "2026-02-12T08:59:21.674760Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5627-2
  a curric:KeyLearningPoint ;
  rdfs:label """The present perfect tense shows unfinished past actions or past actions that are still relevant now."""@en ;
  dcterms:modified "2026-02-12T08:59:21.674764Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5627-3
  a curric:KeyLearningPoint ;
  rdfs:label """The auxiliary verb ‘has’ or ‘have’ is joined to the main verb to change simple past tense into perfect present tense."""@en ;
  dcterms:modified "2026-02-12T08:59:21.674769Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5627-4
  a curric:KeyLearningPoint ;
  rdfs:label "Contractions are one element of informal language in a diary entry."@en ;
  dcterms:modified "2026-02-12T08:59:21.674776Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5627-5
  a curric:KeyLearningPoint ;
  rdfs:label """A range of sentence types, including adverbial complex sentences, should be used in a diary entry."""@en ;
  dcterms:modified "2026-02-12T08:59:21.674780Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4809-1
  a curric:KeyLearningPoint ;
  rdfs:label """A suffix is a letter or group of letters at the end of a word which creates another word."""@en ;
  dcterms:modified "2026-02-12T08:59:21.674851Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4809-2
  a curric:KeyLearningPoint ;
  rdfs:label "The words start with a lead in and finish with a lead out."@en ;
  dcterms:modified "2026-02-12T08:59:21.674856Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4809-3
  a curric:KeyLearningPoint ;
  rdfs:label """The pencil does not lift when forming the join, only after to add the cross to a t or a dot to an i or a j."""@en ;
  dcterms:modified "2026-02-12T08:59:21.674861Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4809-4
  a curric:KeyLearningPoint ;
  rdfs:label "There are four cursive joins."@en ;
  dcterms:modified "2026-02-12T08:59:21.674865Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4809-5
  a curric:KeyLearningPoint ;
  rdfs:label """The join used depends on which letter is joining to which letter within a letter string."""@en ;
  dcterms:modified "2026-02-12T08:59:21.674870Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6096-1
  a curric:KeyLearningPoint ;
  rdfs:label "A non-chronological report is written out of time order."@en ;
  dcterms:modified "2026-02-12T08:59:21.675190Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6096-2
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of a non-chronological report is to inform and engage the reader about a particular subject or event."""@en ;
  dcterms:modified "2026-02-12T08:59:21.675194Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6096-3
  a curric:KeyLearningPoint ;
  rdfs:label """The intended reader of a non-chronological report is likely interested in the subject of the report."""@en ;
  dcterms:modified "2026-02-12T08:59:21.675199Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6096-4
  a curric:KeyLearningPoint ;
  rdfs:label """Subheadings are used to signal where each section of information is to the reader of a non-chronological report."""@en ;
  dcterms:modified "2026-02-12T08:59:21.675204Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6096-5
  a curric:KeyLearningPoint ;
  rdfs:label "Paragraphs are used within a subheading to organise information by theme."@en ;
  dcterms:modified "2026-02-12T08:59:21.675208Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7912-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘London is the Place for Me’ was written by Aldwyn ‘Lord Kitchener’ Roberts in 1948."""@en ;
  dcterms:modified "2026-02-12T08:59:21.675236Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7912-2
  a curric:KeyLearningPoint ;
  rdfs:label """‘Sweet Jamaica’ was written four years after his arrival on the Empire Windrush, in 1952."""@en ;
  dcterms:modified "2026-02-12T08:59:21.675241Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7912-3
  a curric:KeyLearningPoint ;
  rdfs:label """We can compare and contrast songs with similar themes or messages, noticing the impact that they have on us as readers."""@en ;
  dcterms:modified "2026-02-12T08:59:21.675247Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7912-4
  a curric:KeyLearningPoint ;
  rdfs:label """Understanding the context of the songs can support readers to form deeper reflections."""@en ;
  dcterms:modified "2026-02-12T08:59:21.675252Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7912-5
  a curric:KeyLearningPoint ;
  rdfs:label """From reading, listening and discussing songs about migration, we can make connections to our own lives and experiences."""@en ;
  dcterms:modified "2026-02-12T08:59:21.675257Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6192-1
  a curric:KeyLearningPoint ;
  rdfs:label "Our essay gives a logical argument that builds towards a conclusion."@en ;
  dcterms:modified "2026-02-12T08:59:21.675340Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6192-2
  a curric:KeyLearningPoint ;
  rdfs:label """The introduction gives the context of the polar regions while the first main paragraph begins to build the argument."""@en ;
  dcterms:modified "2026-02-12T08:59:21.675345Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6192-3
  a curric:KeyLearningPoint ;
  rdfs:label """Throughout the essay, we connect ideas using a range of linguistic features and support ideas with evidence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.675350Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6192-4
  a curric:KeyLearningPoint ;
  rdfs:label """It is useful to orally rehearse our ideas before writing to reduce our cognitive load."""@en ;
  dcterms:modified "2026-02-12T08:59:21.675354Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6192-5
  a curric:KeyLearningPoint ;
  rdfs:label "We use a formal tone in an essay because we want to sound authoritative."@en ;
  dcterms:modified "2026-02-12T08:59:21.675359Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8639-1
  a curric:KeyLearningPoint ;
  rdfs:label """In this section of the build-up, suspense is built around Arrietty setting off on her first borrowing expedition."""@en ;
  dcterms:modified "2026-02-12T08:59:21.675465Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8639-2
  a curric:KeyLearningPoint ;
  rdfs:label """The use of precise and ambitious vocabulary, including ‘show and tell’ language supports the building of suspense."""@en ;
  dcterms:modified "2026-02-12T08:59:21.675469Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8639-3
  a curric:KeyLearningPoint ;
  rdfs:label """Using a range of sentence types, including adverbial complex sentences, supports text flow."""@en ;
  dcterms:modified "2026-02-12T08:59:21.675474Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8639-4
  a curric:KeyLearningPoint ;
  rdfs:label "An adverbial clause begins with a subordinating conjunction."@en ;
  dcterms:modified "2026-02-12T08:59:21.675478Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8639-5
  a curric:KeyLearningPoint ;
  rdfs:label """An adverbial clause is joined with a main clause to form an adverbial complex sentence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.675486Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8074-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘One of These Days’ and ‘Being Heard’ are two poems in a collection that share themes of resilience."""@en ;
  dcterms:modified "2026-02-12T08:59:21.676024Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8074-2
  a curric:KeyLearningPoint ;
  rdfs:label """Enjambment is when a sentence or phrase runs over onto the next line of poetry without punctuation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.676029Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8074-3
  a curric:KeyLearningPoint ;
  rdfs:label """Enjambment can be used to create a sense of flow, as well as to emphasise certain words or ideas."""@en ;
  dcterms:modified "2026-02-12T08:59:21.676036Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8074-4
  a curric:KeyLearningPoint ;
  rdfs:label "The same theme can be represented in poems in similar or different ways."@en ;
  dcterms:modified "2026-02-12T08:59:21.676041Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1069-1
  a curric:KeyLearningPoint ;
  rdfs:label """Visuals and captions make information easier to understand and remember for the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.676046Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1069-2
  a curric:KeyLearningPoint ;
  rdfs:label """The layout of a text helps to organise information logically, allowing the reader to navigate through a report easily."""@en ;
  dcterms:modified "2026-02-12T08:59:21.676053Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1069-3
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to use neat, joined handwriting when publishing a non-chronological report."""@en ;
  dcterms:modified "2026-02-12T08:59:21.676060Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1069-4
  a curric:KeyLearningPoint ;
  rdfs:label """A published non-chronological report should be visually and linguistically appealing to the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.676065Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4818-1
  a curric:KeyLearningPoint ;
  rdfs:label """Cursive handwriting involves joining letters together without lifting your pencil."""@en ;
  dcterms:modified "2026-02-12T08:59:21.676314Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4818-2
  a curric:KeyLearningPoint ;
  rdfs:label "There are four cursive letter joins."@en ;
  dcterms:modified "2026-02-12T08:59:21.676318Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4818-3
  a curric:KeyLearningPoint ;
  rdfs:label "Which join is used depends on which letter is joining to which letter."@en ;
  dcterms:modified "2026-02-12T08:59:21.676325Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4818-4
  a curric:KeyLearningPoint ;
  rdfs:label "The first letter has a lead in and the last letter has a lead out."@en ;
  dcterms:modified "2026-02-12T08:59:21.676331Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1117-1
  a curric:KeyLearningPoint ;
  rdfs:label "Dreary is an adjective which means boring or miserable."@en ;
  dcterms:modified "2026-02-12T08:59:21.676840Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1117-2
  a curric:KeyLearningPoint ;
  rdfs:label "Ominous is an adjective which means scary, threatening or menacing."@en ;
  dcterms:modified "2026-02-12T08:59:21.676844Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1117-3
  a curric:KeyLearningPoint ;
  rdfs:label "Splattered is an adjective which means splashed or sprinkled."@en ;
  dcterms:modified "2026-02-12T08:59:21.676849Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1124-1
  a curric:KeyLearningPoint ;
  rdfs:label "Dainty is an adjective which means small, delicate and pretty."@en ;
  dcterms:modified "2026-02-12T08:59:21.677565Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1124-2
  a curric:KeyLearningPoint ;
  rdfs:label "Diminutive is an adjective which means unusally small."@en ;
  dcterms:modified "2026-02-12T08:59:21.677569Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1124-3
  a curric:KeyLearningPoint ;
  rdfs:label "Miniscule is an adjective which means tiny or microsocpic."@en ;
  dcterms:modified "2026-02-12T08:59:21.677574Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7643-1
  a curric:KeyLearningPoint ;
  rdfs:label "It is crucial to communicate the unique selling point of a product."@en ;
  dcterms:modified "2026-02-12T08:59:21.678087Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7643-2
  a curric:KeyLearningPoint ;
  rdfs:label """The beginning of persuasive writing should focus on the most appealing aspects of the product, e.g. taste."""@en ;
  dcterms:modified "2026-02-12T08:59:21.678092Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7643-3
  a curric:KeyLearningPoint ;
  rdfs:label "A variety of linguistic techniques are used to create persuasive adverts."@en ;
  dcterms:modified "2026-02-12T08:59:21.678097Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7643-4
  a curric:KeyLearningPoint ;
  rdfs:label """Use of a relative complex sentence supports communicating extra detail about a noun to the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.678101Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5754-1
  a curric:KeyLearningPoint ;
  rdfs:label """Notes should not be written in full sentences and bullet points can be used to order notes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.678131Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5754-2
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the paragraph is to explain the importance of exercise and sleep in a healthy lifestyle."""@en ;
  dcterms:modified "2026-02-12T08:59:21.678136Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5754-3
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials of cause and formal fronted adverbials are used at the start of sentences for cohesion."""@en ;
  dcterms:modified "2026-02-12T08:59:21.678140Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5754-4
  a curric:KeyLearningPoint ;
  rdfs:label """A subheading signals part of a a text and should stand out from the rest of the text."""@en ;
  dcterms:modified "2026-02-12T08:59:21.678145Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5754-5
  a curric:KeyLearningPoint ;
  rdfs:label "The plan should include subject-specific vocabulary."@en ;
  dcterms:modified "2026-02-12T08:59:21.678149Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1121-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Flawless' is an adjective which means perfect or impeccable."@en ;
  dcterms:modified "2026-02-12T08:59:21.678903Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1121-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Mesmerising' is an adjective which means very attractive or bewitching."@en ;
  dcterms:modified "2026-02-12T08:59:21.678908Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1121-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Statuesque' is an adjective which means tall, beautiful and dignified."@en ;
  dcterms:modified "2026-02-12T08:59:21.678912Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1073-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Flabbergasted' is an adjective which means shocked or amazed."@en ;
  dcterms:modified "2026-02-12T08:59:21.678917Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1073-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Astonished' is an adjective which means surprised or amazed."@en ;
  dcterms:modified "2026-02-12T08:59:21.678921Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1073-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Speechless' is an adjective which means you are dumbstruck or lost for words."@en ;
  dcterms:modified "2026-02-12T08:59:21.678930Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1073-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Alarmed', 'startled' and 'stunned' are other rich vocabulary associated with surprise."""@en ;
  dcterms:modified "2026-02-12T08:59:21.678935Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1084-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Rancid' is an adjective which means foul or rotten."@en ;
  dcterms:modified "2026-02-12T08:59:21.678940Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1084-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Nauseating' is an adjective which means sickening or disgusting."@en ;
  dcterms:modified "2026-02-12T08:59:21.678945Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1084-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Inedible', 'repulsive', 'stale' and 'unpalatable' are other adjectives related to the word disgusting."""@en ;
  dcterms:modified "2026-02-12T08:59:21.678949Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1098-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Precipitous' is an adjective which means steep or dangerously high."@en ;
  dcterms:modified "2026-02-12T08:59:21.679790Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1098-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Towering' is an adjective which means extremely tall."@en ;
  dcterms:modified "2026-02-12T08:59:21.679794Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1098-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Rugged' is an adjective which means rough, uneven or craggy."@en ;
  dcterms:modified "2026-02-12T08:59:21.679799Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1098-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Steep', 'summit' and 'crevasse' are other rich vocabulary associated with mountains."""@en ;
  dcterms:modified "2026-02-12T08:59:21.679803Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8073-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘The Land of Blue’ is written by Laura Mucha and illustrated by Victoria Jane Wheeler."""@en ;
  dcterms:modified "2026-02-12T08:59:21.680402Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8073-2
  a curric:KeyLearningPoint ;
  rdfs:label """The poem uses symbolism - symbols that represent ideas beyond their literal meaning."""@en ;
  dcterms:modified "2026-02-12T08:59:21.680406Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8073-3
  a curric:KeyLearningPoint ;
  rdfs:label """The poem references colours; these can symbolise a range of feelings and emotions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.680411Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8073-4
  a curric:KeyLearningPoint ;
  rdfs:label "We can respond to a poem by writing a personal response to it."@en ;
  dcterms:modified "2026-02-12T08:59:21.680416Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8073-5
  a curric:KeyLearningPoint ;
  rdfs:label """Personal responses are reflections that we make about a poem after reading or listening to it."""@en ;
  dcterms:modified "2026-02-12T08:59:21.680420Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1119-1
  a curric:KeyLearningPoint ;
  rdfs:label "Gargantuan is an adjective which means huge or enormous."@en ;
  dcterms:modified "2026-02-12T08:59:21.681440Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1119-2
  a curric:KeyLearningPoint ;
  rdfs:label "Bulky is an adjective which means large, heavily built or stocky."@en ;
  dcterms:modified "2026-02-12T08:59:21.681445Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1119-3
  a curric:KeyLearningPoint ;
  rdfs:label "A dictionary can be useful to help us spell words."@en ;
  dcterms:modified "2026-02-12T08:59:21.681449Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1127-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Conceited' is an adjective which means vain or proud."@en ;
  dcterms:modified "2026-02-12T08:59:21.681454Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1127-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Presumptuous' is an adjective which means overconfident, arrogant or rude."@en ;
  dcterms:modified "2026-02-12T08:59:21.681458Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1127-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Unflappable' is an adjective which means cool, calm or collected."@en ;
  dcterms:modified "2026-02-12T08:59:21.681463Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5697-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the build-up is to develop the characters and introduce a problem to increase the tension."""@en ;
  dcterms:modified "2026-02-12T08:59:21.682376Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5697-2
  a curric:KeyLearningPoint ;
  rdfs:label "Precise and ambitious vocabulary is logged on a plan for future use."@en ;
  dcterms:modified "2026-02-12T08:59:21.682380Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5697-3
  a curric:KeyLearningPoint ;
  rdfs:label """Notes should not be written in full sentences and bullet points can be used to make notes clear."""@en ;
  dcterms:modified "2026-02-12T08:59:21.682385Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5697-4
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials of time, place and manner indicate when, where and how an action takes place."""@en ;
  dcterms:modified "2026-02-12T08:59:21.682389Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1096-1
  a curric:KeyLearningPoint ;
  rdfs:label """'Idyllic' is an adjective which means ideal or perfect; like a beautiful place where you can relax in the sun."""@en ;
  dcterms:modified "2026-02-12T08:59:21.682394Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1096-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Verdant' is an adjective which means green and leafy; like a lush valley where sheep graze on the grass ."""@en ;
  dcterms:modified "2026-02-12T08:59:21.682399Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1096-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Rolling' is an adjective which means rippling, wavy or tumbling; like gentle hills that rise & fall like endless waves."""@en ;
  dcterms:modified "2026-02-12T08:59:21.682403Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1096-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Lush', 'scenic' and 'secluded' are other rich vocabulary associated with the countryside."""@en ;
  dcterms:modified "2026-02-12T08:59:21.682408Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5466-1
  a curric:KeyLearningPoint ;
  rdfs:label "Anansi is a spider in African folktales and he is famous for being a trickster."@en ;
  dcterms:modified "2026-02-12T08:59:21.682796Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5466-2
  a curric:KeyLearningPoint ;
  rdfs:label """Summarising key events and ideas in a story helps to build our understanding of it."""@en ;
  dcterms:modified "2026-02-12T08:59:21.682800Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5466-3
  a curric:KeyLearningPoint ;
  rdfs:label "Anansi faces danger and Antelope saves him when no other animal will."@en ;
  dcterms:modified "2026-02-12T08:59:21.682804Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5466-4
  a curric:KeyLearningPoint ;
  rdfs:label """When Antelope and her baby are in danger from hunters, Anansi uses his trickery for good to protect Baby Antelope."""@en ;
  dcterms:modified "2026-02-12T08:59:21.682809Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5466-5
  a curric:KeyLearningPoint ;
  rdfs:label """Antelope and Anansi forged a friendship through showing acts of kindness and loyalty."""@en ;
  dcterms:modified "2026-02-12T08:59:21.682813Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3408-1
  a curric:KeyLearningPoint ;
  rdfs:label "Presenting involves speaking in front of others and listening to others."@en ;
  dcterms:modified "2026-02-12T08:59:21.682911Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3408-2
  a curric:KeyLearningPoint ;
  rdfs:label """Presenting involves speaking with clear diction and suitable volume, making eye contact and using strong body language."""@en ;
  dcterms:modified "2026-02-12T08:59:21.682915Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3408-3
  a curric:KeyLearningPoint ;
  rdfs:label "Practising pronouncing tricky words helps develop clear diction when presenting."@en ;
  dcterms:modified "2026-02-12T08:59:21.682920Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3408-4
  a curric:KeyLearningPoint ;
  rdfs:label "Rehearsing helps the presenter to speak more confidently and fluently."@en ;
  dcterms:modified "2026-02-12T08:59:21.682925Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3408-5
  a curric:KeyLearningPoint ;
  rdfs:label "Pauses at the end of sentences can help the audience follow what is being said."@en ;
  dcterms:modified "2026-02-12T08:59:21.682929Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8054-1
  a curric:KeyLearningPoint ;
  rdfs:label """Historical fiction is a genre in which a fictional plot takes place in the setting of particular real historical events."""@en ;
  dcterms:modified "2026-02-12T08:59:21.682992Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8054-2
  a curric:KeyLearningPoint ;
  rdfs:label """Reading about important figures in history can offer readers inspiration in their own lives."""@en ;
  dcterms:modified "2026-02-12T08:59:21.682997Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8054-3
  a curric:KeyLearningPoint ;
  rdfs:label """Understanding an inspirational figure's motivations can lead us to connecting with them on an emotional level."""@en ;
  dcterms:modified "2026-02-12T08:59:21.683004Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1072-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Tenacious' is an adjective which means determined or strong-willed."@en ;
  dcterms:modified "2026-02-12T08:59:21.683009Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1072-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Persevere' is a verb which means to keep going or carry on."@en ;
  dcterms:modified "2026-02-12T08:59:21.683016Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1072-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Ambitious', 'determined', 'committed' and 'dedicated' are other rich vocabulary associated with trying hard."""@en ;
  dcterms:modified "2026-02-12T08:59:21.683021Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8076-1
  a curric:KeyLearningPoint ;
  rdfs:label "Poems can be written in many different forms and structures."@en ;
  dcterms:modified "2026-02-12T08:59:21.683026Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8076-2
  a curric:KeyLearningPoint ;
  rdfs:label """Poems about personal experiences can be based on emotions and feelings we have towards something."""@en ;
  dcterms:modified "2026-02-12T08:59:21.683030Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8076-3
  a curric:KeyLearningPoint ;
  rdfs:label """To help generate ideas, we can complete a mind map of actions and events that are associated with our experience."""@en ;
  dcterms:modified "2026-02-12T08:59:21.683035Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8076-4
  a curric:KeyLearningPoint ;
  rdfs:label "Creating a repeated line (anaphora) can support us when writing a poem."@en ;
  dcterms:modified "2026-02-12T08:59:21.683042Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8076-5
  a curric:KeyLearningPoint ;
  rdfs:label """We can experiment with word order, punctuation and phrasing when developing our poem."""@en ;
  dcterms:modified "2026-02-12T08:59:21.683046Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4828-1
  a curric:KeyLearningPoint ;
  rdfs:label """Journalistic reports use formal language, are usually written in the third person and will usually include quotes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.683097Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4828-2
  a curric:KeyLearningPoint ;
  rdfs:label """The title of a journalistic report is called the headline. Most words in the headline will start with a capital letter."""@en ;
  dcterms:modified "2026-02-12T08:59:21.683102Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4828-3
  a curric:KeyLearningPoint ;
  rdfs:label """Capital letters are used after inverted commas in speech first and speech second sentences."""@en ;
  dcterms:modified "2026-02-12T08:59:21.683106Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4828-4
  a curric:KeyLearningPoint ;
  rdfs:label "Capital letters are formed separately, they do not join to other letters."@en ;
  dcterms:modified "2026-02-12T08:59:21.683111Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4828-5
  a curric:KeyLearningPoint ;
  rdfs:label """The letter formation, spacing and cursive joins need to be correct for the writing to be legible."""@en ;
  dcterms:modified "2026-02-12T08:59:21.683115Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1095-1
  a curric:KeyLearningPoint ;
  rdfs:label """'Picturesque' is an adjective which means attractive or scenic; like a village so pretty it could be on a postcard."""@en ;
  dcterms:modified "2026-02-12T08:59:21.683742Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1095-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Remote' is an adjective which means far away and alone; like an island where one person lives all by himself."""@en ;
  dcterms:modified "2026-02-12T08:59:21.683746Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1095-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Rural' is an adjective which means rustic or natural; like being in the countryside."""@en ;
  dcterms:modified "2026-02-12T08:59:21.683751Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1095-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Quaint', 'coastal' and 'bucolic' are other rich vocabulary associated with a village."""@en ;
  dcterms:modified "2026-02-12T08:59:21.683756Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1111-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Rustling' is an adjective which means crackling or swishing."@en ;
  dcterms:modified "2026-02-12T08:59:21.683760Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1111-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Serene' is an adjective which means peaceful or calm."@en ;
  dcterms:modified "2026-02-12T08:59:21.683768Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1111-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Tranquil' is an adjective which means peaceful or blissfully quiet."@en ;
  dcterms:modified "2026-02-12T08:59:21.683772Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6160-1
  a curric:KeyLearningPoint ;
  rdfs:label """Our journalistic report will end with a conclusion that updates the story and gives an 'official' position."""@en ;
  dcterms:modified "2026-02-12T08:59:21.684132Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6160-2
  a curric:KeyLearningPoint ;
  rdfs:label "The conclusion will also look to the future to explain what will happen next."@en ;
  dcterms:modified "2026-02-12T08:59:21.684137Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6160-3
  a curric:KeyLearningPoint ;
  rdfs:label """After we finish a first draft, we use editing time to rethink, rephrase and reconsider those first ideas."""@en ;
  dcterms:modified "2026-02-12T08:59:21.684141Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6160-4
  a curric:KeyLearningPoint ;
  rdfs:label "Editing can be done by oneself, with a peer or with a teacher."@en ;
  dcterms:modified "2026-02-12T08:59:21.684146Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6160-5
  a curric:KeyLearningPoint ;
  rdfs:label """Editing is most successful when it is chunked by punctuation, sentence structure, vocabulary and cohesive devices."""@en ;
  dcterms:modified "2026-02-12T08:59:21.684150Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1070-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Auspicious' is an adjective which means hopeful or encouraging."@en ;
  dcterms:modified "2026-02-12T08:59:21.684391Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1070-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Sanguine' is an adjective which means optimistic or cheery."@en ;
  dcterms:modified "2026-02-12T08:59:21.684395Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1070-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Idealistic', 'encouraging', 'promising' and 'optimistic' are other adjectives associated with hope."""@en ;
  dcterms:modified "2026-02-12T08:59:21.684400Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5473-1
  a curric:KeyLearningPoint ;
  rdfs:label """Characterisation is the way an author describes and develops the personalities and traits of the characters in a story."""@en ;
  dcterms:modified "2026-02-12T08:59:21.684808Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5473-2
  a curric:KeyLearningPoint ;
  rdfs:label """Authors use a range of methods for characterisation which the reader can analyse."""@en ;
  dcterms:modified "2026-02-12T08:59:21.684813Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5473-3
  a curric:KeyLearningPoint ;
  rdfs:label """In 'Hansel and Gretel', there is a clear conflict between good and evil characters."""@en ;
  dcterms:modified "2026-02-12T08:59:21.684817Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5473-4
  a curric:KeyLearningPoint ;
  rdfs:label """Anthony Browne uses illustrations to enhance his depiction of characters and convey hidden messages."""@en ;
  dcterms:modified "2026-02-12T08:59:21.684822Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1436-1
  a curric:KeyLearningPoint ;
  rdfs:label "-y is a suffix that can be used to change some nouns into adjectives."@en ;
  dcterms:modified "2026-02-12T08:59:21.684827Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1436-2
  a curric:KeyLearningPoint ;
  rdfs:label "For some root words you can just add the suffix \"-y\"."@en ;
  dcterms:modified "2026-02-12T08:59:21.684831Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1436-3
  a curric:KeyLearningPoint ;
  rdfs:label "For root words ending in 'e', you remove the 'e' and just add -y."@en ;
  dcterms:modified "2026-02-12T08:59:21.684835Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1436-4
  a curric:KeyLearningPoint ;
  rdfs:label "For root words with a short vowel sound, you double the consonant and add -y."@en ;
  dcterms:modified "2026-02-12T08:59:21.684840Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1436-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum word: arrive."@en ;
  dcterms:modified "2026-02-12T08:59:21.684845Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6551-1
  a curric:KeyLearningPoint ;
  rdfs:label "An introductory sentence indicates what the paragraph will be about."@en ;
  dcterms:modified "2026-02-12T08:59:21.684881Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6551-2
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the main body paragraph is to specifically detail key persuasive arguments."""@en ;
  dcterms:modified "2026-02-12T08:59:21.684890Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6551-3
  a curric:KeyLearningPoint ;
  rdfs:label """Points backed up by evidence, statistics, quotes or anecdotes are more effective."""@en ;
  dcterms:modified "2026-02-12T08:59:21.684894Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6551-4
  a curric:KeyLearningPoint ;
  rdfs:label "Writing clearly and cohesively is a vital element of persuasion."@en ;
  dcterms:modified "2026-02-12T08:59:21.684899Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2735-1
  a curric:KeyLearningPoint ;
  rdfs:label "A non-finite clause joined to a main clause forms a non-finite complex sentence."@en ;
  dcterms:modified "2026-02-12T08:59:21.684904Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2735-2
  a curric:KeyLearningPoint ;
  rdfs:label """The non-finite clause denotes ongoing action that relates to the subject of the main clause."""@en ;
  dcterms:modified "2026-02-12T08:59:21.684908Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2735-3
  a curric:KeyLearningPoint ;
  rdfs:label """The action of the non-finite clause occurs simultaneously to the action of the main clause."""@en ;
  dcterms:modified "2026-02-12T08:59:21.684913Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2735-4
  a curric:KeyLearningPoint ;
  rdfs:label """The non-finite clause can come first in the complex sentence followed by the main clause or vice versa."""@en ;
  dcterms:modified "2026-02-12T08:59:21.684917Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2735-5
  a curric:KeyLearningPoint ;
  rdfs:label """A comma is always used to demarcate the non-finite clause from the main clause despite its position in the sentence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.684921Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4863-1
  a curric:KeyLearningPoint ;
  rdfs:label """Notes should not be written in full sentences and bullet points can be used to order notes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.684949Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4863-2
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the paragraph is to explain how King Tut died and what happened when his tomb was discovered."""@en ;
  dcterms:modified "2026-02-12T08:59:21.684954Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4863-3
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials of cause and formal fronted adverbials are used at the start of sentences for cohesion."""@en ;
  dcterms:modified "2026-02-12T08:59:21.684958Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4863-4
  a curric:KeyLearningPoint ;
  rdfs:label """A subheading signals part of a a text and should stand out from the rest of the text."""@en ;
  dcterms:modified "2026-02-12T08:59:21.684963Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4863-5
  a curric:KeyLearningPoint ;
  rdfs:label "The plan should include subject-specific vocabulary."@en ;
  dcterms:modified "2026-02-12T08:59:21.684967Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7910-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘London is the Place for Me’ is a fixed verse song; it contains four verses each with five lines and a repeated refrain."""@en ;
  dcterms:modified "2026-02-12T08:59:21.685242Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7910-2
  a curric:KeyLearningPoint ;
  rdfs:label """The 1st and 2nd verses can be described as following the rhyme scheme of AABBA; the rhyme scheme varies in verses 3 - 5."""@en ;
  dcterms:modified "2026-02-12T08:59:21.685247Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7910-3
  a curric:KeyLearningPoint ;
  rdfs:label """‘London is the Place for Me’ can be described as being in strophic form: it uses the same melody repeated for each verse"""@en ;
  dcterms:modified "2026-02-12T08:59:21.685251Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7910-4
  a curric:KeyLearningPoint ;
  rdfs:label """Semantic mapping is a technique used to explore the rich meaning of a word or phrase."""@en ;
  dcterms:modified "2026-02-12T08:59:21.685256Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7910-5
  a curric:KeyLearningPoint ;
  rdfs:label """Impressions can be formed about a song once readers or listeners have a secure understanding of the language used."""@en ;
  dcterms:modified "2026-02-12T08:59:21.685260Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6755-1
  a curric:KeyLearningPoint ;
  rdfs:label "Writing is most successful when it is planned."@en ;
  dcterms:modified "2026-02-12T08:59:21.685288Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6755-2
  a curric:KeyLearningPoint ;
  rdfs:label """In a journalistic report, we can plan both the factual information and perspectives we include."""@en ;
  dcterms:modified "2026-02-12T08:59:21.685293Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6755-3
  a curric:KeyLearningPoint ;
  rdfs:label """A journalistic report starts with an introduction giving a summary of the factual information."""@en ;
  dcterms:modified "2026-02-12T08:59:21.685297Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6755-4
  a curric:KeyLearningPoint ;
  rdfs:label """The main paragraphs include perspectives using direct and reported speech, along with some additional facts."""@en ;
  dcterms:modified "2026-02-12T08:59:21.685302Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6755-5
  a curric:KeyLearningPoint ;
  rdfs:label "The conclusion gives the 'official' perspective and looks to the future."@en ;
  dcterms:modified "2026-02-12T08:59:21.685306Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6692-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of a build-up is to move the main character’s journey forward and build tension."""@en ;
  dcterms:modified "2026-02-12T08:59:21.685637Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6692-2
  a curric:KeyLearningPoint ;
  rdfs:label """Precise and ambitious vocabulary creates vivid images for the reader for each key moment of the build-up."""@en ;
  dcterms:modified "2026-02-12T08:59:21.685642Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6692-3
  a curric:KeyLearningPoint ;
  rdfs:label "An effective plan has vocabulary organised concisely and neatly."@en ;
  dcterms:modified "2026-02-12T08:59:21.685647Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6692-4
  a curric:KeyLearningPoint ;
  rdfs:label """Careful verb and adverb selection can convey characters' feelings through show and tell."""@en ;
  dcterms:modified "2026-02-12T08:59:21.685651Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6692-5
  a curric:KeyLearningPoint ;
  rdfs:label "The emotions of the character change through the key moments of the build-up."@en ;
  dcterms:modified "2026-02-12T08:59:21.685655Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1108-1
  a curric:KeyLearningPoint ;
  rdfs:label "Biting is an adjective which means bitter, cold or harsh."@en ;
  dcterms:modified "2026-02-12T08:59:21.685814Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1108-2
  a curric:KeyLearningPoint ;
  rdfs:label "Brisk is an adjective which means sharp or crisp."@en ;
  dcterms:modified "2026-02-12T08:59:21.685818Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1108-3
  a curric:KeyLearningPoint ;
  rdfs:label "Excruciating is an adjective which means extremely painful."@en ;
  dcterms:modified "2026-02-12T08:59:21.685823Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8051-1
  a curric:KeyLearningPoint ;
  rdfs:label """Poems can be published with illustrations to help the reader engage with the poetry further."""@en ;
  dcterms:modified "2026-02-12T08:59:21.685959Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8051-2
  a curric:KeyLearningPoint ;
  rdfs:label "Illustrations can be influenced by both the content and form of the poem."@en ;
  dcterms:modified "2026-02-12T08:59:21.685964Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8051-3
  a curric:KeyLearningPoint ;
  rdfs:label """A poem’s illustrations can be based on imagery, emotions, rhythm and flow, and the intended audience."""@en ;
  dcterms:modified "2026-02-12T08:59:21.685971Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8051-4
  a curric:KeyLearningPoint ;
  rdfs:label """The layout of words and illustrations in a poem can make it more visually appealing to the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.685976Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5700-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the climax is to describe the highest tension, pace and action and to start to solve the problem."""@en ;
  dcterms:modified "2026-02-12T08:59:21.686178Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5700-2
  a curric:KeyLearningPoint ;
  rdfs:label "Saying sentences aloud before they are written helps to check for sense."@en ;
  dcterms:modified "2026-02-12T08:59:21.686183Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5700-3
  a curric:KeyLearningPoint ;
  rdfs:label """Using the full range of sentence types (simple, compound and complex) improves text flow for the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.686187Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5700-4
  a curric:KeyLearningPoint ;
  rdfs:label """A rhetorical question engages the reader and makes them feel more curious about the narrative."""@en ;
  dcterms:modified "2026-02-12T08:59:21.686192Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5700-5
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials of time, place and manner describe the action in the main clause in further detail."""@en ;
  dcterms:modified "2026-02-12T08:59:21.686196Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3406-1
  a curric:KeyLearningPoint ;
  rdfs:label "Editing is the process of making changes to improve writing."@en ;
  dcterms:modified "2026-02-12T08:59:21.686715Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3406-2
  a curric:KeyLearningPoint ;
  rdfs:label """When editing punctuation, missing or incorrect punctuation, like capital letters, full stops and commas, is checked."""@en ;
  dcterms:modified "2026-02-12T08:59:21.686720Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3406-3
  a curric:KeyLearningPoint ;
  rdfs:label """When editing sentence structure, the flow of sentences and the variety of sentence types used are checked."""@en ;
  dcterms:modified "2026-02-12T08:59:21.686724Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3406-4
  a curric:KeyLearningPoint ;
  rdfs:label """When editing language, word and phrase choices are checked to ensure they meet the tone required."""@en ;
  dcterms:modified "2026-02-12T08:59:21.686731Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4867-1
  a curric:KeyLearningPoint ;
  rdfs:label "Presenting involves speaking in front of others and listening to others."@en ;
  dcterms:modified "2026-02-12T08:59:21.686736Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4867-2
  a curric:KeyLearningPoint ;
  rdfs:label """Presenting involves speaking with clear diction and suitable volume, making eye contact and using strong body language."""@en ;
  dcterms:modified "2026-02-12T08:59:21.686741Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4867-3
  a curric:KeyLearningPoint ;
  rdfs:label "Practising pronouncing tricky words helps develop clear diction when presenting."@en ;
  dcterms:modified "2026-02-12T08:59:21.686746Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4867-4
  a curric:KeyLearningPoint ;
  rdfs:label "Rehearsing helps the presenter to speak more confidently and fluently."@en ;
  dcterms:modified "2026-02-12T08:59:21.686750Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4867-5
  a curric:KeyLearningPoint ;
  rdfs:label "Pauses at the end of sentences can help the audience follow what is being said."@en ;
  dcterms:modified "2026-02-12T08:59:21.686755Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1104-1
  a curric:KeyLearningPoint ;
  rdfs:label "Clammy is an adjective which means soggy or moist."@en ;
  dcterms:modified "2026-02-12T08:59:21.686759Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1104-2
  a curric:KeyLearningPoint ;
  rdfs:label "Gleaming is an adjective which means shining or bright."@en ;
  dcterms:modified "2026-02-12T08:59:21.686764Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1104-3
  a curric:KeyLearningPoint ;
  rdfs:label "Oppressive is an adjective which means heavy, harsh or overpowering."@en ;
  dcterms:modified "2026-02-12T08:59:21.686768Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6750-1
  a curric:KeyLearningPoint ;
  rdfs:label "Writing is most successful when it is planned."@en ;
  dcterms:modified "2026-02-12T08:59:21.686773Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6750-2
  a curric:KeyLearningPoint ;
  rdfs:label "We need to generate ideas for what to write about based on a stimulus."@en ;
  dcterms:modified "2026-02-12T08:59:21.686777Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6750-3
  a curric:KeyLearningPoint ;
  rdfs:label """We can generate ideas about descriptive details as well as the main character's emotions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.686782Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6750-4
  a curric:KeyLearningPoint ;
  rdfs:label """In this part of the climax, Joseph is racing to the zoo to guard Adonis and he is struggling with the reality of this."""@en ;
  dcterms:modified "2026-02-12T08:59:21.686788Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6750-5
  a curric:KeyLearningPoint ;
  rdfs:label """The details we generate should build an appropriate mood - in this case, a mood of panic and fear."""@en ;
  dcterms:modified "2026-02-12T08:59:21.686793Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7849-1
  a curric:KeyLearningPoint ;
  rdfs:label """'Varjak Paw' is in the form of an illustrated chapter book, combining words and illustration."""@en ;
  dcterms:modified "2026-02-12T08:59:21.687067Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7849-2
  a curric:KeyLearningPoint ;
  rdfs:label "Varjak Paw is a Mesopotamian Blue Kitten and has never left home."@en ;
  dcterms:modified "2026-02-12T08:59:21.687072Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7849-3
  a curric:KeyLearningPoint ;
  rdfs:label """During the text, Varjak must leave his home and family and has to survive on his own."""@en ;
  dcterms:modified "2026-02-12T08:59:21.687076Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7849-4
  a curric:KeyLearningPoint ;
  rdfs:label """One of the most prominent themes is identity; identity is who you are and what makes you unique."""@en ;
  dcterms:modified "2026-02-12T08:59:21.687081Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6690-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of a build-up is to move the main character’s journey forward and build tension."""@en ;
  dcterms:modified "2026-02-12T08:59:21.687355Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6690-2
  a curric:KeyLearningPoint ;
  rdfs:label """Precise and ambitious vocabulary creates vivid images for the reader for each key moment of the build-up."""@en ;
  dcterms:modified "2026-02-12T08:59:21.687359Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6690-3
  a curric:KeyLearningPoint ;
  rdfs:label "An effective plan has vocabulary organised concisely and neatly."@en ;
  dcterms:modified "2026-02-12T08:59:21.687363Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6690-4
  a curric:KeyLearningPoint ;
  rdfs:label """Careful verb and adverb selection can convey characters' feelings through show and tell."""@en ;
  dcterms:modified "2026-02-12T08:59:21.687368Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6690-5
  a curric:KeyLearningPoint ;
  rdfs:label "The emotions of the character change through the key moments of the build-up."@en ;
  dcterms:modified "2026-02-12T08:59:21.687372Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5694-1
  a curric:KeyLearningPoint ;
  rdfs:label "Precise vocabulary is used to accurately describe setting and characters."@en ;
  dcterms:modified "2026-02-12T08:59:21.687526Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5694-2
  a curric:KeyLearningPoint ;
  rdfs:label "Some vocabulary choices are more precise and appropriate than others."@en ;
  dcterms:modified "2026-02-12T08:59:21.687531Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5694-3
  a curric:KeyLearningPoint ;
  rdfs:label """Imagining colours as we write that might evoke feelings for the reader helps us choose vocabulary."""@en ;
  dcterms:modified "2026-02-12T08:59:21.687536Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5694-4
  a curric:KeyLearningPoint ;
  rdfs:label "Nouns are referred to in different ways to avoid repetition."@en ;
  dcterms:modified "2026-02-12T08:59:21.687540Z"^^xsd:dateTime .

