  a curric:KeyLearningPoint ;
  rdfs:label """Precise and ambitious vocabulary shows and tells the reader what happened on her journey and how she was feeling."""@en ;
  dcterms:modified "2026-02-12T08:59:21.613846Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6693-3
  a curric:KeyLearningPoint ;
  rdfs:label """Using a range of sentence types (simple, compound and complex) improves text flow for the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.613853Z"^^xsd:dateTime .

