  a curric:PupilLessonOutcome ;
  rdfs:label """I can use a plan to write the introduction of a persuasive letter, using inspiration from a text."""@en ;
  dcterms:modified "2026-02-12T08:59:24.444428Z"^^xsd:dateTime .

