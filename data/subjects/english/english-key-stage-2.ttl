  dcterms:modified "2026-02-12T08:59:21.706617Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7902-4
  a curric:KeyLearningPoint ;
  rdfs:label """Connections are ways in which you connect personally with a text; these may differ based on reader's life experiences."""@en ;
  dcterms:modified "2026-02-12T08:59:21.706624Z"^^xsd:dateTime .

