  dcterms:modified "2026-06-07T15:29:23.350849Z"^^xsd:dateTime .

oakcurric:priorknowledge-700-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "There is a wide variety of living things on Earth."@en ;
  dcterms:modified "2026-06-07T15:29:23.350854Z"^^xsd:dateTime .

oakcurric:priorknowledge-700-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "All living things have different characteristics, behaviours and adaptations."@en ;
  dcterms:modified "2026-06-07T15:29:23.350859Z"^^xsd:dateTime .

oakcurric:priorknowledge-700-7
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Living things can adapt to their environment over time."@en ;
  dcterms:modified "2026-06-07T15:29:23.350863Z"^^xsd:dateTime .

oakcurric:priorknowledge-700-8
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Some changes over time can be gradual and others can be sudden."@en ;
  dcterms:modified "2026-06-07T15:29:23.350867Z"^^xsd:dateTime .

oakcurric:priorknowledge-700-9
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Traits that help living things survive and reproduce are optimal for their
  survival."""@en ;
  dcterms:modified "2026-06-07T15:29:23.350871Z"^^xsd:dateTime .

oakcurric:priorknowledge-700-10
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Humans have a responsibility to know about the planet in order to protect its
  complex environment."""@en ;
  dcterms:modified "2026-06-07T15:29:23.350876Z"^^xsd:dateTime .

oakcurric:priorknowledge-3649-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "A debate is a structured argument between two teams."@en ;
  dcterms:modified "2026-06-07T15:29:23.352755Z"^^xsd:dateTime .

oakcurric:priorknowledge-3649-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "The motion is the name for the belief or proposal that is being debated."@en ;
  dcterms:modified "2026-06-07T15:29:23.352766Z"^^xsd:dateTime .

oakcurric:priorknowledge-3649-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The team that agrees with the motion is called the proposition and the team that
  disagrees with the motion is called the opposition."""@en ;
  dcterms:modified "2026-06-07T15:29:23.352771Z"^^xsd:dateTime .

oakcurric:priorknowledge-3649-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "The PEPS structure stands for: point, explanation, proof, summary."@en ;
  dcterms:modified "2026-06-07T15:29:23.352776Z"^^xsd:dateTime .

oakcurric:priorknowledge-3649-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """In a debate, an argument should be clearly structured to make it more
  convincing."""@en ;
  dcterms:modified "2026-06-07T15:29:23.352781Z"^^xsd:dateTime .

oakcurric:priorknowledge-3649-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "In a debate, an opinion must be justified with reasoning."@en ;
  dcterms:modified "2026-06-07T15:29:23.352785Z"^^xsd:dateTime .

oakcurric:priorknowledge-3649-7
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """A rebuttal point is a counter-argument made against something specific that the
  opposing team has said."""@en ;
  dcterms:modified "2026-06-07T15:29:23.352789Z"^^xsd:dateTime .

oakcurric:priorknowledge-3649-8
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "A point of information is a brief attempted interruption of someone's speech."@en ;
  dcterms:modified "2026-06-07T15:29:23.352793Z"^^xsd:dateTime .

oakcurric:priorknowledge-3649-9
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The winning team in a debate can be decided by an audience vote, or a judge, or a
  panel of judges."""@en ;
  dcterms:modified "2026-06-07T15:29:23.352798Z"^^xsd:dateTime .

oakcurric:priorknowledge-896-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Knowledge of text types, including fiction, non-fiction and poetry."@en ;
  dcterms:modified "2026-06-07T15:29:23.354584Z"^^xsd:dateTime .

oakcurric:priorknowledge-896-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "We read to get information and we read for pleasure."@en ;
  dcterms:modified "2026-06-07T15:29:23.354595Z"^^xsd:dateTime .

oakcurric:priorknowledge-896-3
  a curric:PriorKnowledgeRequirement ;
