    natcurric:scheme-english-key-stage-2 ;
  curric:includesThread
    oakcurric:thread-traditional-tales ,
    oakcurric:thread-fiction-reading-spine .

oakcurric:unit-129
  a curric:Unit ;
  rdfs:label "Review and revision of all taught spelling"@en ;
  curric:slug "review-and-revision-of-all-taught-spelling" ;
  rdfs:comment """In this unit, pupils review and revise the full range of spelling content learnt
  across KS2, including spelling patterns linked to suffixes, sounds and etymology, in
  preparation for the end of KS2 testing."""@en ;
  curric:whyThisWhyNow """This unit uses and builds on pupils' knowledge of spelling patterns
  associated with letter strings, a range of suffixes, silent letters, French and Greek origin
  words, curriculum words and hyphenated words learnt in the Year 6 unit 'Year 6: Letter
  strings, etymology and curriculum words'. In this unit, pupils review and revise the full
  range of spelling content learnt across KS2. This unit prepares pupils for end of KS2 testing
  in preparation for KS3.""" ;
  curric:hasPriorKnowledgeRequirement
    oakcurric:priorknowledge-129-1 ,
    oakcurric:priorknowledge-129-2 ,
