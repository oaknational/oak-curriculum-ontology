oakcurric:keylearningpoint-lesson-3454-5
  a curric:KeyLearningPoint ;
  rdfs:label """A clause in the passive voice contains two verbs: an auxiliary verb from the infinitive 'to be' and the past participle."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643963Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5749-1
  a curric:KeyLearningPoint ;
  rdfs:label """A non-chronological report is a non-fiction text providing information about a particular subject."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643968Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5749-2
  a curric:KeyLearningPoint ;
  rdfs:label """A non-chronological report can be organised into an introduction, paragraphs organised by theme and a conclusion."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643973Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5749-3
  a curric:KeyLearningPoint ;
  rdfs:label """Vocabulary within a non-chronological report is subject-specific and factual; the language and tone is formal."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643977Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5749-4
  a curric:KeyLearningPoint ;
  rdfs:label """Conjunctions are an important linguistic feature within non-chronological reports in order to ensure cohesion."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643982Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5749-5
  a curric:KeyLearningPoint ;
  rdfs:label """A fronted adverbial of cause is a sentence starter that tells the reader the cause and effect of something."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643987Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1066-1
  a curric:KeyLearningPoint ;
  rdfs:label """Notes should not be written in full sentences and bullet points can be used to organise notes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643992Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1066-2
  a curric:KeyLearningPoint ;
  rdfs:label """Viewpoint fronted adverbials and formal fronted adverbials are used at the start of sentences for cohesion."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643996Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1066-3
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the artefacts paragraph is to show what tools were made of and how they were used in the Stone Age."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644001Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1066-4
  a curric:KeyLearningPoint ;
  rdfs:label "Flint was the stone used to make weapons and tools."@en ;
  dcterms:modified "2026-02-12T08:59:21.644008Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1066-5
  a curric:KeyLearningPoint ;
  rdfs:label """Pots were made of clay and dice, jewellery and combs were made from animal bones."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644014Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7659-1
  a curric:KeyLearningPoint ;
  rdfs:label "Direct speech is the term used for a person speaking out loud in a text."@en ;
  dcterms:modified "2026-02-12T08:59:21.644018Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7659-2
  a curric:KeyLearningPoint ;
  rdfs:label """Speech first is punctuated with inverted commas and a comma, question mark or exclamation mark."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644023Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7659-3
  a curric:KeyLearningPoint ;
  rdfs:label """Speech second is punctuated with inverted commas and a full stop, question mark or exclamation mark."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644028Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7659-4
  a curric:KeyLearningPoint ;
  rdfs:label """Inverted commas are used to demarcate the direct speech from the reporting clause."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644035Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7659-5
  a curric:KeyLearningPoint ;
  rdfs:label """A range of synonyms for ‘said’ and use of adverbs can offer detail about how a character spoke and felt."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644040Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5822-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the build-up is to develop the plot and characters, introduce a problem and build up tension."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644408Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5822-2
  a curric:KeyLearningPoint ;
  rdfs:label """Show-not-tell allows the reader to observe the emotions a character may be experiencing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644412Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5822-3
  a curric:KeyLearningPoint ;
  rdfs:label "A relative clause can be used to give additional information about a noun."@en ;
  dcterms:modified "2026-02-12T08:59:21.644417Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5822-4
  a curric:KeyLearningPoint ;
  rdfs:label "A relative clause always starts with a relative pronoun e.g. ‘who’ or ‘which’."@en ;
  dcterms:modified "2026-02-12T08:59:21.644422Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2720-1
  a curric:KeyLearningPoint ;
  rdfs:label """'Jabberwocky' was written in 1871 by Lewis Carroll and included in his book 'Alice Through the Looking Glass'."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644427Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2720-2
  a curric:KeyLearningPoint ;
  rdfs:label "Speaking in a clear and engaging tone is important when reading a poem aloud."@en ;
  dcterms:modified "2026-02-12T08:59:21.644434Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2720-3
  a curric:KeyLearningPoint ;
  rdfs:label "Nonsense words are completely made up words that do not have a meaning."@en ;
  dcterms:modified "2026-02-12T08:59:21.644439Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2720-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Jabberwocky' tells the story of a young man defeating a dangerous creature: the Jabberwock."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644444Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2720-5
  a curric:KeyLearningPoint ;
  rdfs:label """Summarising the verses helps the reader to be able order the key moments chronologically."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644449Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6415-1
  a curric:KeyLearningPoint ;
  rdfs:label """Writing is most successful when it is planned. We can plan to describe events and feelings for a diary entry."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644454Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6415-2
  a curric:KeyLearningPoint ;
  rdfs:label """A diary entry is most often written retrospectively with no other intended reader than the writer themselves."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644458Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6415-3
  a curric:KeyLearningPoint ;
  rdfs:label """A Windrush passenger's diary could contain entries from on the ship and after arriving in the UK."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644463Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6415-4
  a curric:KeyLearningPoint ;
  rdfs:label """First person is used to write a diary entry and entries can use both past and present tense."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644468Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6415-5
  a curric:KeyLearningPoint ;
  rdfs:label "We can plan to include a range of vocabulary to describe emotions."@en ;
  dcterms:modified "2026-02-12T08:59:21.644473Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6349-1
  a curric:KeyLearningPoint ;
  rdfs:label "Our persuasive letter must include a summary of the mystery."@en ;
  dcterms:modified "2026-02-12T08:59:21.644478Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6349-2
  a curric:KeyLearningPoint ;
  rdfs:label """We can base the details of this summary on a journalistic report about the mystery."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644482Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6349-3
  a curric:KeyLearningPoint ;
  rdfs:label """The letter must also give reasons that will persuade Holmes to investigate the crime."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644487Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6349-4
  a curric:KeyLearningPoint ;
  rdfs:label "We can generate these reasons by empathising with the main character."@en ;
  dcterms:modified "2026-02-12T08:59:21.644492Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6349-5
  a curric:KeyLearningPoint ;
  rdfs:label "We can record all these ideas in note form."@en ;
  dcterms:modified "2026-02-12T08:59:21.644497Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5755-1
  a curric:KeyLearningPoint ;
  rdfs:label "A subheading signals to the reader what the section is about."@en ;
  dcterms:modified "2026-02-12T08:59:21.644531Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5755-2
  a curric:KeyLearningPoint ;
  rdfs:label """A section about one feature of the report's subject contains specific facts and information to keep the reader engaged."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644536Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5755-3
  a curric:KeyLearningPoint ;
  rdfs:label """Using the full range of sentence types (simple, compound and complex) improves text flow for the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644540Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5755-4
  a curric:KeyLearningPoint ;
  rdfs:label """Sentences should be said aloud before writing to ensure they make sense and read back once written to check for errors."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644545Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5755-5
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials of cause and formal fronted adverbials are used at the start of sentences for cohesion."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644550Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6733-1
  a curric:KeyLearningPoint ;
  rdfs:label "Writing is most successful when structure, content and vocabulary are planned."@en ;
  dcterms:modified "2026-02-12T08:59:21.644557Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6733-2
  a curric:KeyLearningPoint ;
  rdfs:label "We are aiming to set a tense, pacy atmosphere in our climax and resolution."@en ;
  dcterms:modified "2026-02-12T08:59:21.644562Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6733-3
  a curric:KeyLearningPoint ;
  rdfs:label """Short sentences, rhetorical questions and 'quick' fronted adverbials of time can add pace to a piece of writing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644569Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6733-4
  a curric:KeyLearningPoint ;
  rdfs:label "We can use a colon to introduce a question to show a character's inner thoughts."@en ;
  dcterms:modified "2026-02-12T08:59:21.644574Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6733-5
  a curric:KeyLearningPoint ;
  rdfs:label """We can use a relative complex sentence as a cohesive device to add detail after a noun."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644579Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3403-1
  a curric:KeyLearningPoint ;
  rdfs:label """The plan includes keywords and subject-specific vocabulary related to the section."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644584Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3403-2
  a curric:KeyLearningPoint ;
  rdfs:label "Taking notes is a skill."@en ;
  dcterms:modified "2026-02-12T08:59:21.644589Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3403-3
  a curric:KeyLearningPoint ;
  rdfs:label """Notes should not be written in full sentences and bullet points can be used to order notes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644594Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3403-4
  a curric:KeyLearningPoint ;
  rdfs:label "Key vocabulary and linguistic devices should be logged in a plan."@en ;
  dcterms:modified "2026-02-12T08:59:21.644598Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3403-5
  a curric:KeyLearningPoint ;
  rdfs:label "The plan should be clearly structured in the order of the section."@en ;
  dcterms:modified "2026-02-12T08:59:21.644603Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5667-1
  a curric:KeyLearningPoint ;
  rdfs:label "After Beowulf's death, Wiglaf is furious at the warriors who deserted him."@en ;
  dcterms:modified "2026-02-12T08:59:21.644608Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5667-2
  a curric:KeyLearningPoint ;
  rdfs:label """Beowulf is given a hero's funeral; the Geats are concerned about their future without him."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644613Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5667-3
  a curric:KeyLearningPoint ;
  rdfs:label """The Geats show that, just as Beowulf wanted, they will remember him after his death."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644620Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5667-4
  a curric:KeyLearningPoint ;
  rdfs:label "We aim to read with fluency and expression; repeated reading supports fluency."@en ;
  dcterms:modified "2026-02-12T08:59:21.644625Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7916-1
  a curric:KeyLearningPoint ;
  rdfs:label "When we read, we make inferences based on evidence."@en ;
  dcterms:modified "2026-02-12T08:59:21.644632Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7916-2
  a curric:KeyLearningPoint ;
  rdfs:label """We can infer what characters' thoughts might be based on their actions and stated words."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644637Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7916-3
  a curric:KeyLearningPoint ;
  rdfs:label """We can also infer characters' motives - their reasons for acting - which might be different to their stated motives."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644642Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7916-4
  a curric:KeyLearningPoint ;
  rdfs:label """Our inferences will also make use of empathy - and we should remember we can never empathise perfectly with others."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644647Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6109-1
  a curric:KeyLearningPoint ;
  rdfs:label """Text cohesion refers to how a text flows together to maintain the interest of the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644652Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6109-2
  a curric:KeyLearningPoint ;
  rdfs:label """We can improve text cohesion using cohesive devices that connect information within and between sentences."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644656Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6109-3
  a curric:KeyLearningPoint ;
  rdfs:label """Compound and complex sentences can be used to join linked information in one sentence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644662Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6109-4
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials can be used to show links between information in adjacent sentences."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644666Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6109-5
  a curric:KeyLearningPoint ;
  rdfs:label """There are different types of complex sentence and fronted adverbials, which serve different purposes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644671Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8029-1
  a curric:KeyLearningPoint ;
  rdfs:label """Making a text recommendation includes a personal reason for why the text was relevant to you"""@en ;
  dcterms:modified "2026-02-12T08:59:21.644676Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8029-2
  a curric:KeyLearningPoint ;
  rdfs:label """Making a text recommendation includes a reason that someone else might enjoy the text"""@en ;
  dcterms:modified "2026-02-12T08:59:21.644681Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8029-3
  a curric:KeyLearningPoint ;
  rdfs:label "There are a variety of ways we can share our reading preferences with others"@en ;
  dcterms:modified "2026-02-12T08:59:21.644685Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8029-4
  a curric:KeyLearningPoint ;
  rdfs:label """Curating a space at home or at school to share your reading preferences can support others in reading for pleasure"""@en ;
  dcterms:modified "2026-02-12T08:59:21.644690Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4813-1
  a curric:KeyLearningPoint ;
  rdfs:label """Two or more words that sound the same but have different meanings and spellings are called homophones."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644722Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4813-2
  a curric:KeyLearningPoint ;
  rdfs:label "The words start with a lead in and finish with a lead out."@en ;
  dcterms:modified "2026-02-12T08:59:21.644726Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4813-3
  a curric:KeyLearningPoint ;
  rdfs:label "There are four cursive joins."@en ;
  dcterms:modified "2026-02-12T08:59:21.644734Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4813-4
  a curric:KeyLearningPoint ;
  rdfs:label """The join used depends on which letter is joining to which letter within a letter string."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644739Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4813-5
  a curric:KeyLearningPoint ;
  rdfs:label "You don't lift your pencil to form the joins."@en ;
  dcterms:modified "2026-02-12T08:59:21.644744Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8091-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘No Country’ is a fictional graphic novel text written by Joe Brady and illustrated by Patrice Aggs."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644772Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8091-2
  a curric:KeyLearningPoint ;
  rdfs:label """The text focuses on the lives of one family as they try to navigate the challenges of a civil war."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644777Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8091-3
  a curric:KeyLearningPoint ;
  rdfs:label """Graphic novels tell a complete story with illustrations in panels; gutters are the spaces between panels."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644781Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8091-4
  a curric:KeyLearningPoint ;
  rdfs:label """Graphic novels include many features (including callouts) to inform the reader of what is happening."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644786Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8091-5
  a curric:KeyLearningPoint ;
  rdfs:label """Readers sometimes have to infer what has happened, rather than being told by the author or illustrator."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644791Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7895-1
  a curric:KeyLearningPoint ;
  rdfs:label """Characterisation is the way text creators describe & develop the personalities and traits of the characters in a story."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644796Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7895-2
  a curric:KeyLearningPoint ;
  rdfs:label """Many of the characters in ‘Oliver Twist’ are complex - they present as kind and helpful when their motives are not."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644803Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7895-3
  a curric:KeyLearningPoint ;
  rdfs:label """Fagin compares Oliver & the Artful Dodger; they both share similar characteristics, but have different personalities."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644808Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6194-1
  a curric:KeyLearningPoint ;
  rdfs:label """We have completed an essay that makes a persuasive argument for protecting the polar regions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644862Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6194-2
  a curric:KeyLearningPoint ;
  rdfs:label "An essay has a formal tone."@en ;
  dcterms:modified "2026-02-12T08:59:21.644867Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6194-3
  a curric:KeyLearningPoint ;
  rdfs:label """We can use an essay as an inspiration for a speech, which will have a more emotive tone."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644872Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6194-4
  a curric:KeyLearningPoint ;
  rdfs:label """When we make a speech, we should plan our ideas and speak clearly and at a good volume with positive body language."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644877Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6194-5
  a curric:KeyLearningPoint ;
  rdfs:label """We should use our intonation and body language as well as our word choices to show our passion for the subject."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644881Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2746-1
  a curric:KeyLearningPoint ;
  rdfs:label "Parenthesis can be achieved with a range of punctuation."@en ;
  dcterms:modified "2026-02-12T08:59:21.644886Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2746-2
  a curric:KeyLearningPoint ;
  rdfs:label """Dashes are a punctuation mark used to add extra information in a clause often for dramatic effect."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644895Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2746-3
  a curric:KeyLearningPoint ;
  rdfs:label "Dashes are often written in a pair."@en ;
  dcterms:modified "2026-02-12T08:59:21.644900Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2746-4
  a curric:KeyLearningPoint ;
  rdfs:label "Dashes can be removed from a clause and it will still make sense."@en ;
  dcterms:modified "2026-02-12T08:59:21.644905Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2746-5
  a curric:KeyLearningPoint ;
  rdfs:label """Dashes can be used purposefully in fiction texts to cause a dramatic effect for the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644910Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6756-1
  a curric:KeyLearningPoint ;
  rdfs:label """A journalistic report has a formal tone and it combines factual statements with different perspectives on an event."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644914Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6756-2
  a curric:KeyLearningPoint ;
  rdfs:label "The introduction gives a summary and a description of the event."@en ;
  dcterms:modified "2026-02-12T08:59:21.644919Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6756-3
  a curric:KeyLearningPoint ;
  rdfs:label """The main paragraphs give different perspectives using both direct and reported speech."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644924Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6756-4
  a curric:KeyLearningPoint ;
  rdfs:label "Throughout, a range of cohesive devices can be used to connect ideas together."@en ;
  dcterms:modified "2026-02-12T08:59:21.644929Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5499-1
  a curric:KeyLearningPoint ;
  rdfs:label """A colon has two functions - it can introduce a list or an explanation. A dash can also introduce an explanation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.645249Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5499-2
  a curric:KeyLearningPoint ;
  rdfs:label """A semi-colon has two functions - to separate detailed items in a list or to join two closely-related main clauses."""@en ;
  dcterms:modified "2026-02-12T08:59:21.645254Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5499-3
  a curric:KeyLearningPoint ;
  rdfs:label "Using colons and semi-colons can improve text cohesion."@en ;
  dcterms:modified "2026-02-12T08:59:21.645261Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5499-4
  a curric:KeyLearningPoint ;
  rdfs:label "Bullet points are useful in certain non-fiction texts."@en ;
  dcterms:modified "2026-02-12T08:59:21.645266Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5499-5
  a curric:KeyLearningPoint ;
  rdfs:label "Hyphens are used to join two or more words or parts of words together."@en ;
  dcterms:modified "2026-02-12T08:59:21.645271Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3453-1
  a curric:KeyLearningPoint ;
  rdfs:label "A modal verb is a type of auxiliary verb."@en ;
  dcterms:modified "2026-02-12T08:59:21.645278Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3453-2
  a curric:KeyLearningPoint ;
  rdfs:label "A modal verb is most often paired with the main verb of a clause."@en ;
  dcterms:modified "2026-02-12T08:59:21.645283Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3453-3
  a curric:KeyLearningPoint ;
  rdfs:label "A modal verb is not paired with the main verb if it appears in a question."@en ;
  dcterms:modified "2026-02-12T08:59:21.645288Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3453-4
  a curric:KeyLearningPoint ;
  rdfs:label "Modal verbs are often used in speech sentences and persuasive writing."@en ;
  dcterms:modified "2026-02-12T08:59:21.645292Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3453-5
  a curric:KeyLearningPoint ;
  rdfs:label """A modal verb expresses the degree of possibility, intent, ability or necessity of the clause."""@en ;
  dcterms:modified "2026-02-12T08:59:21.645297Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7923-1
  a curric:KeyLearningPoint ;
  rdfs:label """In this section of the book, Joseph learns from Mrs F that his father has died in the war."""@en ;
  dcterms:modified "2026-02-12T08:59:21.645302Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7923-2
  a curric:KeyLearningPoint ;
  rdfs:label "Joseph goes through a range of emotions, including denial, anger and guilt."@en ;
  dcterms:modified "2026-02-12T08:59:21.645307Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7923-3
  a curric:KeyLearningPoint ;
  rdfs:label """The author uses descriptions of Joseph's actions, speech and thoughts to depict these emotions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.645312Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7923-4
  a curric:KeyLearningPoint ;
  rdfs:label "The author also makes specific language choices to enhance certain emotions."@en ;
  dcterms:modified "2026-02-12T08:59:21.645317Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7923-5
  a curric:KeyLearningPoint ;
  rdfs:label "We make inferences about emotions based on evidence within the text."@en ;
  dcterms:modified "2026-02-12T08:59:21.645321Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6735-1
  a curric:KeyLearningPoint ;
  rdfs:label """Addie is the protagonist in 'A Kind of Spark'; she is autistic, but this does not define her exclusively."""@en ;
  dcterms:modified "2026-02-12T08:59:21.645813Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6735-2
  a curric:KeyLearningPoint ;
  rdfs:label """Addie has a range of character traits including bravery, determination and single-mindedness."""@en ;
  dcterms:modified "2026-02-12T08:59:21.645818Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6735-3
  a curric:KeyLearningPoint ;
  rdfs:label "We can identify character traits by looking at evidence in the text."@en ;
  dcterms:modified "2026-02-12T08:59:21.645823Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6735-4
  a curric:KeyLearningPoint ;
  rdfs:label """We can identify a structure within a narrative including an opening, build-up, climax and resolution."""@en ;
  dcterms:modified "2026-02-12T08:59:21.645828Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6735-5
  a curric:KeyLearningPoint ;
  rdfs:label """We can track a character's emotions across a story to understand more about their personality."""@en ;
  dcterms:modified "2026-02-12T08:59:21.645832Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1321-1
  a curric:KeyLearningPoint ;
  rdfs:label "Editing is the process of making changes to improve writing."@en ;
  dcterms:modified "2026-02-12T08:59:21.645837Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1321-2
  a curric:KeyLearningPoint ;
  rdfs:label """When editing punctuation, missing or incorrect punctuation, like capital letters, full stops and commas, is checked."""@en ;
  dcterms:modified "2026-02-12T08:59:21.645844Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1321-3
  a curric:KeyLearningPoint ;
  rdfs:label """When editing sentence structure, the flow of sentences and the variety of sentence types used are checked."""@en ;
  dcterms:modified "2026-02-12T08:59:21.645851Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1321-4
  a curric:KeyLearningPoint ;
  rdfs:label """When editing language, word and phrase choices are checked to ensure they meet the tone required."""@en ;
  dcterms:modified "2026-02-12T08:59:21.645856Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4815-1
  a curric:KeyLearningPoint ;
  rdfs:label "Common exception words do not follow regular spelling or phonics rules."@en ;
  dcterms:modified "2026-02-12T08:59:21.645861Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4815-2
  a curric:KeyLearningPoint ;
  rdfs:label """Letters in the common exception words will be joined using a range of joins depending on the letters in the word."""@en ;
  dcterms:modified "2026-02-12T08:59:21.645866Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4815-3
  a curric:KeyLearningPoint ;
  rdfs:label "The first letter always has a lead in and the last letter always has a lead out."@en ;
  dcterms:modified "2026-02-12T08:59:21.645871Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4815-4
  a curric:KeyLearningPoint ;
  rdfs:label "There is appropriate spacing between the letters."@en ;
  dcterms:modified "2026-02-12T08:59:21.645876Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4815-5
  a curric:KeyLearningPoint ;
  rdfs:label "You don't lift your pencil when forming the joins."@en ;
  dcterms:modified "2026-02-12T08:59:21.645880Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4810-1
  a curric:KeyLearningPoint ;
  rdfs:label "-sure and -ture are common spellings for the endings of words."@en ;
  dcterms:modified "2026-02-12T08:59:21.645885Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4810-2
  a curric:KeyLearningPoint ;
  rdfs:label "The words start with a lead in and finish with a lead out."@en ;
  dcterms:modified "2026-02-12T08:59:21.645892Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4810-3
  a curric:KeyLearningPoint ;
  rdfs:label """The pencil does not lift when forming the join, only after to add the cross to a t or a dot to an i or a j."""@en ;
  dcterms:modified "2026-02-12T08:59:21.645900Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4810-4
  a curric:KeyLearningPoint ;
  rdfs:label "There are four cursive joins."@en ;
  dcterms:modified "2026-02-12T08:59:21.645905Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4810-5
  a curric:KeyLearningPoint ;
  rdfs:label """The join used depends on which letter is joining to which letter within a letter string."""@en ;
  dcterms:modified "2026-02-12T08:59:21.645910Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7896-1
  a curric:KeyLearningPoint ;
  rdfs:label """Oliver is beginning to settle into life with Mr. Brownlow in Pentonville, London."""@en ;
  dcterms:modified "2026-02-12T08:59:21.645915Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7896-2
  a curric:KeyLearningPoint ;
  rdfs:label """Readers can form an impression of a range of characters by focusing on how a character is described or depicted in text."""@en ;
  dcterms:modified "2026-02-12T08:59:21.645920Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7896-3
  a curric:KeyLearningPoint ;
  rdfs:label "A prediction is a statement about what you think will happen in the future."@en ;
  dcterms:modified "2026-02-12T08:59:21.645925Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7896-4
  a curric:KeyLearningPoint ;
  rdfs:label """Predictions can be justified using information from the text or readers’ prior knowledge about the characters &context."""@en ;
  dcterms:modified "2026-02-12T08:59:21.645929Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7896-5
  a curric:KeyLearningPoint ;
  rdfs:label """Searching for keywords or specific types of words can support readers in answering retrieval questions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.645934Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8637-1
  a curric:KeyLearningPoint ;
  rdfs:label """In the build-up, Pod is “seen” by a human “bean” and this causes concern for the Clock family’s safety."""@en ;
  dcterms:modified "2026-02-12T08:59:21.645941Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8637-2
  a curric:KeyLearningPoint ;
  rdfs:label """Arrietty expresses her discontent being trapped under the floorboards and her desire to experience the world above."""@en ;
  dcterms:modified "2026-02-12T08:59:21.645946Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8637-3
  a curric:KeyLearningPoint ;
  rdfs:label "Homily persuades a reluctant Pod to take Arrietty borrowing."@en ;
  dcterms:modified "2026-02-12T08:59:21.645951Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8637-4
  a curric:KeyLearningPoint ;
  rdfs:label """The Clock family have contrasting feelings about Arrietty going on a borrowing expedition."""@en ;
  dcterms:modified "2026-02-12T08:59:21.645956Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8637-5
  a curric:KeyLearningPoint ;
  rdfs:label "We can infer a character’s emotions from their actions, words and expressions."@en ;
  dcterms:modified "2026-02-12T08:59:21.645961Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8060-1
  a curric:KeyLearningPoint ;
  rdfs:label "‘The Song of the Whale’ was written by Kit Wright in 1982."@en ;
  dcterms:modified "2026-02-12T08:59:21.645983Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8060-2
  a curric:KeyLearningPoint ;
  rdfs:label """Whales face a multitude of threats from humans, which include hunting, pollution and captivity in zoos and water parks."""@en ;
  dcterms:modified "2026-02-12T08:59:21.645987Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8060-3
  a curric:KeyLearningPoint ;
  rdfs:label """‘The Panther’ was written by Rainer Maria Rilke between 1902 and 1903; it describes a captive panther behind bars."""@en ;
  dcterms:modified "2026-02-12T08:59:21.645992Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8060-4
  a curric:KeyLearningPoint ;
  rdfs:label "Themes of captivity and freedom can be found in both poems."@en ;
  dcterms:modified "2026-02-12T08:59:21.645997Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8060-5
  a curric:KeyLearningPoint ;
  rdfs:label """We can compare and contrast poems with similar themes or messages, noticing the impact that they have on us as readers."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646002Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7650-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the build-up is to develop the characters and build up the excitement."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646007Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7650-2
  a curric:KeyLearningPoint ;
  rdfs:label """When we plan, we log precise and ambitious vocabulary to help paint vivid pictures for our reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646011Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7650-3
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials of time, place and manner are included in a plan to add extra detail about the action."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646016Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7650-4
  a curric:KeyLearningPoint ;
  rdfs:label """Dialogue is the written conversation between two characters or more within a narrative and it moves the story forward."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646021Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7650-5
  a curric:KeyLearningPoint ;
  rdfs:label "A plan is written in note-form, out of full sentences."@en ;
  dcterms:modified "2026-02-12T08:59:21.646026Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8058-1
  a curric:KeyLearningPoint ;
  rdfs:label """The poem describes a bird that comes down a garden path and interacts with the natural world around it."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646033Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8058-2
  a curric:KeyLearningPoint ;
  rdfs:label """‘A Bird came down the Walk’ can be described as a fixed verse poem; it consists of five verses, containing four lines."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646038Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8058-3
  a curric:KeyLearningPoint ;
  rdfs:label "Dashes create a pause in the poem; these can also be called caesuras."@en ;
  dcterms:modified "2026-02-12T08:59:21.646043Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8058-4
  a curric:KeyLearningPoint ;
  rdfs:label """Dashes can be used to create emphasis, add dramatic effect or control the pacing of a poem."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646047Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8058-5
  a curric:KeyLearningPoint ;
  rdfs:label """Understanding a poem, its language, imagery & the impression it creates will help us to create an impactful performance."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646052Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6754-1
  a curric:KeyLearningPoint ;
  rdfs:label "Before we write, we need to generate a wide range of ideas."@en ;
  dcterms:modified "2026-02-12T08:59:21.646057Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6754-2
  a curric:KeyLearningPoint ;
  rdfs:label """Journalistic writing includes both factual information and a range of different perspectives."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646064Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6754-3
  a curric:KeyLearningPoint ;
  rdfs:label """In this case, we can gather 'factual' information from our reading of 'When the Sky Falls'."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646069Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6754-4
  a curric:KeyLearningPoint ;
  rdfs:label """We can gather different perspectives by engaging in role play based on our understanding of the book."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646074Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6754-5
  a curric:KeyLearningPoint ;
  rdfs:label "These ideas will feed into our planning and writing."@en ;
  dcterms:modified "2026-02-12T08:59:21.646078Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8012-1
  a curric:KeyLearningPoint ;
  rdfs:label """Performing poetry to an audience is an important part of the process of creating poetry."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646193Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8012-2
  a curric:KeyLearningPoint ;
  rdfs:label """When performing poetry, you can vary your volume, pace and use gestures to have an impact on the audience."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646198Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8012-3
  a curric:KeyLearningPoint ;
  rdfs:label """Deciding upon and creating a desired atmosphere is important when performing poetry."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646203Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8012-4
  a curric:KeyLearningPoint ;
  rdfs:label "We can improve our performances of poetry through practice."@en ;
  dcterms:modified "2026-02-12T08:59:21.646208Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7674-1
  a curric:KeyLearningPoint ;
  rdfs:label "A subheading signals to the reader what the section is about."@en ;
  dcterms:modified "2026-02-12T08:59:21.646680Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7674-2
  a curric:KeyLearningPoint ;
  rdfs:label """Careful selection of nouns and pronouns ensures cohesion within sentences and across sections of the report."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646685Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7674-3
  a curric:KeyLearningPoint ;
  rdfs:label """A section about one feature of the report's subject contains specific facts and information to keep the reader engaged."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646690Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7674-4
  a curric:KeyLearningPoint ;
  rdfs:label """Writers choose varied fronted adverbials and different sentence types to ensure the text flows for the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646694Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7674-5
  a curric:KeyLearningPoint ;
  rdfs:label """Sentences should be said aloud before writing to ensure they make sense and read back once written to check for errors."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646699Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1319-1
  a curric:KeyLearningPoint ;
  rdfs:label "A subheading signals to the reader what the section is about."@en ;
  dcterms:modified "2026-02-12T08:59:21.646704Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1319-2
  a curric:KeyLearningPoint ;
  rdfs:label """Careful selection of nouns and pronouns ensures cohesion within sentences and across sections of the report."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646713Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1319-3
  a curric:KeyLearningPoint ;
  rdfs:label """A section about one feature of the report's subject contains specific facts and information to keep the reader engaged."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646718Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1319-4
  a curric:KeyLearningPoint ;
  rdfs:label """Writers choose varied fronted adverbials and different sentence types to ensure the text flows for the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646723Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1319-5
  a curric:KeyLearningPoint ;
  rdfs:label """Sentences should be said aloud before writing to ensure they make sense and read back once written to check for errors."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646727Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6159-1
  a curric:KeyLearningPoint ;
  rdfs:label """A journalistic report has a formal tone and combines factual statements with different perspectives on an event."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646732Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6159-2
  a curric:KeyLearningPoint ;
  rdfs:label """The main paragraphs give different perspectives using both direct and reported speech."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646737Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6159-3
  a curric:KeyLearningPoint ;
  rdfs:label "Throughout, a range of cohesive devices can be used to connect ideas together."@en ;
  dcterms:modified "2026-02-12T08:59:21.646742Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3466-1
  a curric:KeyLearningPoint ;
  rdfs:label """Precise vocabulary is used to accurately describe the complex process of making honey."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646775Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3466-2
  a curric:KeyLearningPoint ;
  rdfs:label """Adjective choices are formal and technical in an explanation text rather than descriptive."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646780Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3466-3
  a curric:KeyLearningPoint ;
  rdfs:label "Verb choices are precise to describe the bees’ movements accurately."@en ;
  dcterms:modified "2026-02-12T08:59:21.646785Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3466-4
  a curric:KeyLearningPoint ;
  rdfs:label """Synonyms can be used to refer to the nouns in different ways to avoid repetition."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646789Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3466-5
  a curric:KeyLearningPoint ;
  rdfs:label "Adverbs are used to add extra detail to the verb."@en ;
  dcterms:modified "2026-02-12T08:59:21.646794Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8895-1
  a curric:KeyLearningPoint ;
  rdfs:label "Hiccup is not a typical hero character"@en ;
  dcterms:modified "2026-02-12T08:59:21.646799Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8895-2
  a curric:KeyLearningPoint ;
  rdfs:label "Stories may portray heroes in various ways"@en ;
  dcterms:modified "2026-02-12T08:59:21.646806Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8895-3
  a curric:KeyLearningPoint ;
  rdfs:label """There are some common character traits heroes have, such as courage and determination"""@en ;
  dcterms:modified "2026-02-12T08:59:21.646811Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8895-4
  a curric:KeyLearningPoint ;
  rdfs:label "Authors can appeal to the senses when describing settings"@en ;
  dcterms:modified "2026-02-12T08:59:21.646816Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8895-5
  a curric:KeyLearningPoint ;
  rdfs:label """Role on the wall is a reading activity that helps readers develop their understanding of a character"""@en ;
  dcterms:modified "2026-02-12T08:59:21.646821Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5629-1
  a curric:KeyLearningPoint ;
  rdfs:label """This paragraph recounts the boy’s encounters with characters in the forest and conveys how his emotions heighten."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646825Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5629-2
  a curric:KeyLearningPoint ;
  rdfs:label """Diary entries should include specific linguistic features (past tense, first person perspective and informal language)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646830Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5629-3
  a curric:KeyLearningPoint ;
  rdfs:label "Fronted adverbials of time help clearly sequence the encounters."@en ;
  dcterms:modified "2026-02-12T08:59:21.646835Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5629-4
  a curric:KeyLearningPoint ;
  rdfs:label """A relative complex sentence uses a relative pronoun (who or which) to provide greater detail about a noun."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646840Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5629-5
  a curric:KeyLearningPoint ;
  rdfs:label """A relative clause can follow the main clause in a relative complex sentence or be embedded within it."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646845Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7629-1
  a curric:KeyLearningPoint ;
  rdfs:label "Editing is the process of making changes to improve our writing."@en ;
  dcterms:modified "2026-02-12T08:59:21.646849Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7629-2
  a curric:KeyLearningPoint ;
  rdfs:label "Editing can be done by oneself, with a peer or with a teacher."@en ;
  dcterms:modified "2026-02-12T08:59:21.646854Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7629-3
  a curric:KeyLearningPoint ;
  rdfs:label """When editing punctuation, missing or incorrectly used capital letters, full stops, inverted commas & commas are checked."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646859Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7629-4
  a curric:KeyLearningPoint ;
  rdfs:label """When editing sentence structure, the way sentences are constructed is checked to improve and enhance text flow."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646864Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7629-5
  a curric:KeyLearningPoint ;
  rdfs:label "When editing language, choices of words and phrases are carefully reviewed."@en ;
  dcterms:modified "2026-02-12T08:59:21.646868Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1067-1
  a curric:KeyLearningPoint ;
  rdfs:label "A subheading signals to the reader what the section is about."@en ;
  dcterms:modified "2026-02-12T08:59:21.646895Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1067-2
  a curric:KeyLearningPoint ;
  rdfs:label """A section about one feature of the report's subject contains specific facts and information to keep the reader engaged."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646900Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1067-3
  a curric:KeyLearningPoint ;
  rdfs:label """Writers choose varied fronted adverbials and different sentence types to ensure the text flows for the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646905Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1067-4
  a curric:KeyLearningPoint ;
  rdfs:label "A section can be composed of one paragraph."@en ;
  dcterms:modified "2026-02-12T08:59:21.646912Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1067-5
  a curric:KeyLearningPoint ;
  rdfs:label """Sentences should be said aloud before writing to ensure they make sense and read back once written to check for errors."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646917Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7660-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the opening is to engage the reader and introduce the setting and characters."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646922Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7660-2
  a curric:KeyLearningPoint ;
  rdfs:label """The opening of the story introduces Paikea and her grandfather and their family context."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646926Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7660-3
  a curric:KeyLearningPoint ;
  rdfs:label """Precise adjectives, verbs and adverbs are used to create a vivid picture for the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646931Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7660-4
  a curric:KeyLearningPoint ;
  rdfs:label "Precise and ambitious vocabulary is logged on a plan for future use."@en ;
  dcterms:modified "2026-02-12T08:59:21.646936Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7660-5
  a curric:KeyLearningPoint ;
  rdfs:label """Notes should not be written in full sentences and bullet points can be used to make notes clear."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646941Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6158-1
  a curric:KeyLearningPoint ;
  rdfs:label """A journalistic report has a formal tone and it combines factual statements with different perspectives on an event."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647533Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6158-2
  a curric:KeyLearningPoint ;
  rdfs:label """The introduction gives a summary of the event and the arguments and gives a description of the event."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647540Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6158-3
  a curric:KeyLearningPoint ;
  rdfs:label """The main paragraphs give different perspectives using both direct and reported speech."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647545Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6158-4
  a curric:KeyLearningPoint ;
  rdfs:label "Throughout, a range of cohesive devices can be used to connect ideas together."@en ;
  dcterms:modified "2026-02-12T08:59:21.647550Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5470-1
  a curric:KeyLearningPoint ;
  rdfs:label "A fairytale is a children's story about magical and imaginary beings and lands."@en ;
  dcterms:modified "2026-02-12T08:59:21.647555Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5470-2
  a curric:KeyLearningPoint ;
  rdfs:label """Fairytales belong to the genre of folklore where oral stories are shared and passed down over time."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647562Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5470-3
  a curric:KeyLearningPoint ;
  rdfs:label """Hansel and Gretel originated in Germany and was first recorded by the Brothers Grimm."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647567Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5470-4
  a curric:KeyLearningPoint ;
  rdfs:label """Fairytales have specific features e.g. they involve magical elements and often include good vs evil."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647572Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5470-5
  a curric:KeyLearningPoint ;
  rdfs:label """Anthony Browne wrote his own adaptation of 'Hansel and Gretel' and uses his illustrations to convey hidden messages."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647576Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6108-1
  a curric:KeyLearningPoint ;
  rdfs:label "A non-chronological report is written out of time order."@en ;
  dcterms:modified "2026-02-12T08:59:21.647581Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6108-2
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of a non-chronological report is to inform and engage the reader about a particular subject or event."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647586Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6108-3
  a curric:KeyLearningPoint ;
  rdfs:label """The intended reader of a non-chronological report is likely interested in the subject of the report."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647591Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6108-4
  a curric:KeyLearningPoint ;
  rdfs:label """Subheadings are used to signal where each section of information is to the reader of a non-chronological report."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647596Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6108-5
  a curric:KeyLearningPoint ;
  rdfs:label "Paragraphs are used within a subheading to organise information by theme."@en ;
  dcterms:modified "2026-02-12T08:59:21.647600Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2745-1
  a curric:KeyLearningPoint ;
  rdfs:label "Parenthesis can be achieved with a range of punctuation."@en ;
  dcterms:modified "2026-02-12T08:59:21.647605Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2745-2
  a curric:KeyLearningPoint ;
  rdfs:label """Brackets are a punctuation mark used to add extra, factual information in a clause."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647610Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2745-3
  a curric:KeyLearningPoint ;
  rdfs:label "Brackets can be removed from a clause and it will still make sense."@en ;
  dcterms:modified "2026-02-12T08:59:21.647614Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2745-4
  a curric:KeyLearningPoint ;
  rdfs:label """Brackets can be used purposefully in non-fiction texts to increase the amount of facts given to the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647619Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7918-1
  a curric:KeyLearningPoint ;
  rdfs:label """When we give our opinion about a text, we often need to justify our view with evidence or explanations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647945Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7918-2
  a curric:KeyLearningPoint ;
  rdfs:label "Specific language choices are made by the author to convey meaning."@en ;
  dcterms:modified "2026-02-12T08:59:21.647950Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7918-3
  a curric:KeyLearningPoint ;
  rdfs:label """We can compare characters within and between texts, including the same character at different points in a text."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647955Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7918-4
  a curric:KeyLearningPoint ;
  rdfs:label "Making these comparisons helps us to understand characters better."@en ;
  dcterms:modified "2026-02-12T08:59:21.647960Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1314-1
  a curric:KeyLearningPoint ;
  rdfs:label """Subject-specific, factual vocabulary, including numeral facts, is used in a non-chronological report."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647965Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1314-2
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials of cause are used at the start of a sentence that gives an effect to the cause in the previous one."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647969Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1314-3
  a curric:KeyLearningPoint ;
  rdfs:label """Sentences can start with a range of fronted adverbials like formal and viewpoint fronted adverbials."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647974Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1314-4
  a curric:KeyLearningPoint ;
  rdfs:label """Non-chronological reports are non-fiction texts that inform the reader about a specific subject."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647979Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7874-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘Greenling’ can be considered a fable, its moral might link to the conservation & preservation of the environment."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647986Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7874-2
  a curric:KeyLearningPoint ;
  rdfs:label "A theme is a big idea, topic or message that recurs within a story."@en ;
  dcterms:modified "2026-02-12T08:59:21.647991Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7874-3
  a curric:KeyLearningPoint ;
  rdfs:label """Some of the themes of 'Greenling' are sustainability, acceptance and the power of nature."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647996Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7874-4
  a curric:KeyLearningPoint ;
  rdfs:label """Revisiting a text can allow readers to discuss questions that focus on themes that are not explicitly stated in the text"""@en ;
  dcterms:modified "2026-02-12T08:59:21.648001Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6115-1
  a curric:KeyLearningPoint ;
  rdfs:label """Information in a section becomes more specific and detailed as the section goes on."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648006Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6115-2
  a curric:KeyLearningPoint ;
  rdfs:label "Facts written in a section should be researched and organised prior to writing."@en ;
  dcterms:modified "2026-02-12T08:59:21.648010Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6115-3
  a curric:KeyLearningPoint ;
  rdfs:label "A range of cohesive devices helps us to link facts within and between sentences."@en ;
  dcterms:modified "2026-02-12T08:59:21.648015Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6115-4
  a curric:KeyLearningPoint ;
  rdfs:label """Before we write, we should orally rehearse sentences to ensure our sentences make sense and flow well."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648020Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6115-5
  a curric:KeyLearningPoint ;
  rdfs:label """Parenthesis, varied sentence types and a range of fronted adverbials are all cohesive devices that can be used."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648025Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6188-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of an essay can be to present a coherent argument in response to a stimulus or question."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648032Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6188-2
  a curric:KeyLearningPoint ;
  rdfs:label "Understanding the question is critical to a successful essay answer."@en ;
  dcterms:modified "2026-02-12T08:59:21.648037Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6188-3
  a curric:KeyLearningPoint ;
  rdfs:label "An essay can attempt to persuade the reader of a certain viewpoint."@en ;
  dcterms:modified "2026-02-12T08:59:21.648042Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6188-4
  a curric:KeyLearningPoint ;
  rdfs:label "An essay follows a logical argument going step by step towards a conclusion."@en ;
  dcterms:modified "2026-02-12T08:59:21.648049Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6188-5
  a curric:KeyLearningPoint ;
  rdfs:label """A range of linguistic features contribute to the formal tone of an essay and make it persuasive."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648054Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8470-1
  a curric:KeyLearningPoint ;
  rdfs:label """The opening of ‘The Iron Man’ introduces the protagonist and conveys a mysterious atmosphere within the setting."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648059Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8470-2
  a curric:KeyLearningPoint ;
  rdfs:label """The use of precise and ambitious vocabulary engages the reader and conveys the mysterious atmosphere."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648064Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8470-3
  a curric:KeyLearningPoint ;
  rdfs:label "Using a range of sentence types supports text flow."@en ;
  dcterms:modified "2026-02-12T08:59:21.648069Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8470-4
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials of time, place and manner add greater detail to a sentence and help convey the desired atmosphere."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648074Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2724-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the build-up is to develop the characters and build up the excitement."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648081Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2724-2
  a curric:KeyLearningPoint ;
  rdfs:label """When we plan, we log precise and ambitious vocabulary to help paint vivid pictures for our reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648086Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2724-3
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials of time, place and manner are included in a plan to add extra detail about the action."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648093Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2724-4
  a curric:KeyLearningPoint ;
  rdfs:label "A plan is most often written in note-form, out of full sentences."@en ;
  dcterms:modified "2026-02-12T08:59:21.648098Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1106-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Blistering' is an adjective which means harsh or scorching."@en ;
  dcterms:modified "2026-02-12T08:59:21.648103Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1106-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Perspire' is a verb which means to drip with sweat."@en ;
  dcterms:modified "2026-02-12T08:59:21.648107Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1106-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Radiant' is an adjective which means bright, brilliant or glowing."@en ;
  dcterms:modified "2026-02-12T08:59:21.648112Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7670-1
  a curric:KeyLearningPoint ;
  rdfs:label """A piece of published writing is the final, best version and should be visually appealing to the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648117Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7670-2
  a curric:KeyLearningPoint ;
  rdfs:label "Neat, joined handwriting is important when publishing a piece of writing."@en ;
  dcterms:modified "2026-02-12T08:59:21.648121Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7670-3
  a curric:KeyLearningPoint ;
  rdfs:label """Illustrations can bring the world of the story to life and make it more vivid in the reader's mind."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648128Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7670-4
  a curric:KeyLearningPoint ;
  rdfs:label "Reading aloud involves speaking to an audience at a suitable volume and pace."@en ;
  dcterms:modified "2026-02-12T08:59:21.648134Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7670-5
  a curric:KeyLearningPoint ;
  rdfs:label """Reading with expression means reading with feeling and emotion to bring the words to life for the audience."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648138Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4804-1
  a curric:KeyLearningPoint ;
  rdfs:label "The letters all have a lead in and a lead out."@en ;
  dcterms:modified "2026-02-12T08:59:21.648384Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4804-2
  a curric:KeyLearningPoint ;
  rdfs:label """The third join starts at the x-height line and dips below the x-height line and back up to join the next letter."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648388Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4804-3
  a curric:KeyLearningPoint ;
  rdfs:label """When connecting the letter e, with the third join, the dip down starts the formation of the letter e."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648393Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4804-4
  a curric:KeyLearningPoint ;
  rdfs:label "The pencil does not lift when forming the join."@en ;
  dcterms:modified "2026-02-12T08:59:21.648402Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4804-5
  a curric:KeyLearningPoint ;
  rdfs:label """When using the third join you leave enough space to ensure the letters are not touching without leaving a big gap."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648407Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3470-1
  a curric:KeyLearningPoint ;
  rdfs:label "Activity inside the hive is an important part of the honey-making process."@en ;
  dcterms:modified "2026-02-12T08:59:21.648412Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3470-2
  a curric:KeyLearningPoint ;
  rdfs:label "The main sections in an explanation text follow a clear, sequenced order."@en ;
  dcterms:modified "2026-02-12T08:59:21.648417Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3470-3
  a curric:KeyLearningPoint ;
  rdfs:label """Notes should not be written in full sentences and bullet points can be used to make notes clear."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648421Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3470-4
  a curric:KeyLearningPoint ;
  rdfs:label """Facts become increasingly specific throughout one section of an explanation text."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648426Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5630-1
  a curric:KeyLearningPoint ;
  rdfs:label """This paragraph recounts the final part of the boy’s journey and his discovery that his dad is at his grandma’s."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648431Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5630-2
  a curric:KeyLearningPoint ;
  rdfs:label """The boys emotions heighten and he experiences intense fear leading up to him being reunited with his grandma and dad."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648435Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5630-3
  a curric:KeyLearningPoint ;
  rdfs:label """Thoughts and feelings can be explicitly stated and conveyed through the use of ‘show and tell’."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648440Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5630-4
  a curric:KeyLearningPoint ;
  rdfs:label "There is a shift from past to present tense during the final paragraph."@en ;
  dcterms:modified "2026-02-12T08:59:21.648445Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5630-5
  a curric:KeyLearningPoint ;
  rdfs:label """Present tense writing at the end of a diary entry conveys current reflections and feelings."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648449Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6351-1
  a curric:KeyLearningPoint ;
  rdfs:label "Writing is most successful when it is planned."@en ;
  dcterms:modified "2026-02-12T08:59:21.648454Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6351-2
  a curric:KeyLearningPoint ;
  rdfs:label """The paragraph should give a reason (followed by evidence to support that reason) why the recipient should help."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648459Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6351-3
  a curric:KeyLearningPoint ;
  rdfs:label "We should include a range of persuasive techniques in the paragraph."@en ;
  dcterms:modified "2026-02-12T08:59:21.648464Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6351-4
  a curric:KeyLearningPoint ;
  rdfs:label "Within the paragraph, ideas are connected using cohesive devices."@en ;
  dcterms:modified "2026-02-12T08:59:21.648468Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6351-5
  a curric:KeyLearningPoint ;
  rdfs:label """A colon can be used after a main clause to introduce an explanation which is also a main clause."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648473Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8064-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘Pike’ was written by Ted Hughes in 1960; the poem consists of eleven verses, each with four lines."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648500Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8064-2
  a curric:KeyLearningPoint ;
  rdfs:label """Hughes often used animals, landscapes and elemental forces as symbols in his work."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648505Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8064-3
  a curric:KeyLearningPoint ;
  rdfs:label """Hughes uses vivid imagery in the poem to create a rich and sensory description of the pike and its environment."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648510Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8064-4
  a curric:KeyLearningPoint ;
  rdfs:label """Researching about the subject of a poem can greatly enhance readers' understanding."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648515Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8064-5
  a curric:KeyLearningPoint ;
  rdfs:label "The goal of research is to enrich and engage readers in a poem."@en ;
  dcterms:modified "2026-02-12T08:59:21.648522Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8636-1
  a curric:KeyLearningPoint ;
  rdfs:label """The setting of ‘The Borrowers’ is the Clock family home, which is underneath the floorboards of an old, English house."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648541Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8636-2
  a curric:KeyLearningPoint ;
  rdfs:label """A preposition of place is a word or words that can tell the reader where a noun is."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648546Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8636-3
  a curric:KeyLearningPoint ;
  rdfs:label """Prepositions and precise vocabulary are crucial for describing an intricate setting."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648550Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8636-4
  a curric:KeyLearningPoint ;
  rdfs:label """Relative complex sentences are useful for adding details about nouns within a setting."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648555Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7850-1
  a curric:KeyLearningPoint ;
  rdfs:label """Character traits can be explored through the text’s illustrations or words used by the characters."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648586Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7850-2
  a curric:KeyLearningPoint ;
  rdfs:label "Different readers may interpret a text in different ways."@en ;
  dcterms:modified "2026-02-12T08:59:21.648591Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7850-3
  a curric:KeyLearningPoint ;
  rdfs:label """Discussing books by building on others and our own views can help us to deepen our understanding of a text."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648596Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7850-4
  a curric:KeyLearningPoint ;
  rdfs:label """Making links to other characters and stories helps to deepen our awareness of texts."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648601Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6752-1
  a curric:KeyLearningPoint ;
  rdfs:label "Writing is most successful when structure, content and vocabulary are planned."@en ;
  dcterms:modified "2026-02-12T08:59:21.648605Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6752-2
  a curric:KeyLearningPoint ;
  rdfs:label "Our climax should have a tense, fast-paced mood."@en ;
  dcterms:modified "2026-02-12T08:59:21.648610Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6752-3
  a curric:KeyLearningPoint ;
  rdfs:label """We combine descriptive details and emotive details to paint a clear picture for the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648615Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6752-4
  a curric:KeyLearningPoint ;
  rdfs:label """We can use a range of linguistic techniques and cohesive devices for increasing the pace."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648620Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6752-5
  a curric:KeyLearningPoint ;
  rdfs:label "We use precise vocabulary to add to the impression of speed."@en ;
  dcterms:modified "2026-02-12T08:59:21.648625Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28399-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘The Final Year’ is an illustrated verse novel that follows Nate as he approaches his final year of primary school."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648847Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28399-2
  a curric:KeyLearningPoint ;
  rdfs:label """The poems within ‘The Final Year’ are written in a dialect, reflecting the region of Manchester where it is set."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648851Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28399-3
  a curric:KeyLearningPoint ;
  rdfs:label """We can gain an initial understanding of the character of Nate by how he is described and how he is illustrated."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648859Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28399-4
  a curric:KeyLearningPoint ;
  rdfs:label """It’s important to not make quick judgements of characters based on a single poem."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648863Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28399-5
  a curric:KeyLearningPoint ;
  rdfs:label """Part 1 gives readers an initial impression of Nate, who he is and what his family and surroundings are like."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648868Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6743-1
  a curric:KeyLearningPoint ;
  rdfs:label "Writing is most successful when it is planned."@en ;
  dcterms:modified "2026-02-12T08:59:21.648873Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6743-2
  a curric:KeyLearningPoint ;
  rdfs:label "Vocabulary can be generated to precisely match the emotions of a character."@en ;
  dcterms:modified "2026-02-12T08:59:21.648878Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6743-3
  a curric:KeyLearningPoint ;
  rdfs:label "Thinking hard about vocabulary makes writing outcomes more powerful."@en ;
  dcterms:modified "2026-02-12T08:59:21.648882Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6743-4
  a curric:KeyLearningPoint ;
  rdfs:label """Vocabulary choices can be made to highlight the emotions of a character to the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648890Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6743-5
  a curric:KeyLearningPoint ;
  rdfs:label """Precision in describing a character's emotions means getting inside the character's head."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648894Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6739-1
  a curric:KeyLearningPoint ;
  rdfs:label """We are writing about an event from the build-up, using a third person perspective."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648899Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6739-2
  a curric:KeyLearningPoint ;
  rdfs:label """We are then using internal monologue to reflect on the same event from Addie's perspective."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648904Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6739-3
  a curric:KeyLearningPoint ;
  rdfs:label "Using a plan and orally rehearsing our writing helps us to do our best writing."@en ;
  dcterms:modified "2026-02-12T08:59:21.648909Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6739-4
  a curric:KeyLearningPoint ;
  rdfs:label """We should aim to use a complete range of sentence types and language features in our writing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648914Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4825-1
  a curric:KeyLearningPoint ;
  rdfs:label "Pen and pencil are the most common tools used to write or draw with."@en ;
  dcterms:modified "2026-02-12T08:59:21.648918Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4825-2
  a curric:KeyLearningPoint ;
  rdfs:label """Making a choice between pen and pencil depends on the task and the desired outcome."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648923Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4825-3
  a curric:KeyLearningPoint ;
  rdfs:label """Using a pencil allows for mistakes to be corrected easily with an eraser, which is ideal for sketching and drafting."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648928Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4825-4
  a curric:KeyLearningPoint ;
  rdfs:label """Using a pen is ideal for final drafts as pen is permanent and looks neat and professional."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648933Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4825-5
  a curric:KeyLearningPoint ;
  rdfs:label "Over time you will develop a personal preference for using pen or pencil."@en ;
  dcterms:modified "2026-02-12T08:59:21.648937Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4801-1
  a curric:KeyLearningPoint ;
  rdfs:label "The letters all have a lead in and a lead out."@en ;
  dcterms:modified "2026-02-12T08:59:21.648942Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4801-2
  a curric:KeyLearningPoint ;
  rdfs:label """The second join goes from the baseline to above the x-height line towards the ascender line."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648949Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4801-3
  a curric:KeyLearningPoint ;
  rdfs:label """The pencil only lifts to add the dot to the i and the cross to the t once the letter string is complete."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648956Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4801-4
  a curric:KeyLearningPoint ;
  rdfs:label """When forming the letter f it has two loops; one at the top of the lead in and one at the bottom ready for the lead out."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648961Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4801-5
  a curric:KeyLearningPoint ;
  rdfs:label """When joining to the letter t, the join goes up to between the x-height line and the ascender line."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648968Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8878-1
  a curric:KeyLearningPoint ;
  rdfs:label """In Chapter 3 of ‘The Iron Man’, Hogarth persuades the farmers to respond differently to the Iron Man."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649011Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8878-2
  a curric:KeyLearningPoint ;
  rdfs:label "Hogarth identifies the Iron Man’s needs and comes up with a solution."@en ;
  dcterms:modified "2026-02-12T08:59:21.649016Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8878-3
  a curric:KeyLearningPoint ;
  rdfs:label """Characterisation is the way an author describes and develops the personalities and traits of characters in the story."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649021Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8878-4
  a curric:KeyLearningPoint ;
  rdfs:label """We can identify Hogarth’s character traits by exploring his experiences and interactions and making inferences."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649025Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8878-5
  a curric:KeyLearningPoint ;
  rdfs:label """Hogarth displays a range of character traits such as being compassionate and resourceful."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649030Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6761-1
  a curric:KeyLearningPoint ;
  rdfs:label "Writing is most successful when it is planned."@en ;
  dcterms:modified "2026-02-12T08:59:21.649209Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6761-2
  a curric:KeyLearningPoint ;
  rdfs:label "Understanding the essay title is critical to a successful essay answer."@en ;
  dcterms:modified "2026-02-12T08:59:21.649214Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6761-3
  a curric:KeyLearningPoint ;
  rdfs:label """An essay can use a bank of research, evidence and statistics to inform the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649219Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6761-4
  a curric:KeyLearningPoint ;
  rdfs:label "A structure that supports the line of argument must be logical."@en ;
  dcterms:modified "2026-02-12T08:59:21.649224Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6725-1
  a curric:KeyLearningPoint ;
  rdfs:label """We are going to be writing a narrative retelling of most of the story of 'Beowulf and the dragon'."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649228Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6725-2
  a curric:KeyLearningPoint ;
  rdfs:label "We will be covering the build-up, climax and resolution of this mini-story."@en ;
  dcterms:modified "2026-02-12T08:59:21.649233Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6725-3
  a curric:KeyLearningPoint ;
  rdfs:label """To be ready to write, we need to know the events really well. To do this, we can create a text map."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649240Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6725-4
  a curric:KeyLearningPoint ;
  rdfs:label "We can use the text map to rehearse saying the events we will cover."@en ;
  dcterms:modified "2026-02-12T08:59:21.649245Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6725-5
  a curric:KeyLearningPoint ;
  rdfs:label """We can also use it for storytelling - saying the events out loud as if telling a story."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649250Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3464-1
  a curric:KeyLearningPoint ;
  rdfs:label """An explanation text is a non-fiction text that explains a particular process or subject in detail."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649257Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3464-2
  a curric:KeyLearningPoint ;
  rdfs:label """An explanation text can start with an introduction and then explains a sequenced process in chronological order."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649262Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3464-3
  a curric:KeyLearningPoint ;
  rdfs:label """Vocabulary within an explanation text is subject-specific and factual, creating a formal tone."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649267Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3464-4
  a curric:KeyLearningPoint ;
  rdfs:label """Formal fronted adverbials, ordering fronted adverbials and fronted adverbials of cause are used to enhance text flow."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649272Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3464-5
  a curric:KeyLearningPoint ;
  rdfs:label "Explanation texts are written in the present tense."@en ;
  dcterms:modified "2026-02-12T08:59:21.649276Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3465-1
  a curric:KeyLearningPoint ;
  rdfs:label "Honey making is a complex, natural process which takes a very long time."@en ;
  dcterms:modified "2026-02-12T08:59:21.649281Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3465-2
  a curric:KeyLearningPoint ;
  rdfs:label "Bees visit thousands of colourful flowers to collect nectar with their tongue."@en ;
  dcterms:modified "2026-02-12T08:59:21.649286Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3465-3
  a curric:KeyLearningPoint ;
  rdfs:label """The nectar travels to the honey stomach where the enzymes break it down into smaller molecules."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649291Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3465-4
  a curric:KeyLearningPoint ;
  rdfs:label """The bees transfer the nectar into the honeycomb cells and flap their wings to evaporate the water from the nectar."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649296Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3465-5
  a curric:KeyLearningPoint ;
  rdfs:label "Bees seal the cells with a wax lid. The honey cannot leak or expire."@en ;
  dcterms:modified "2026-02-12T08:59:21.649300Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2716-1
  a curric:KeyLearningPoint ;
  rdfs:label """An introduction's purpose is to give general facts about the topic and to tell the reader what they will learn."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649331Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2716-2
  a curric:KeyLearningPoint ;
  rdfs:label """Digestion is the process of breaking down food into particles small enough to be absorbed into the bloodstream."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649336Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2716-3
  a curric:KeyLearningPoint ;
  rdfs:label """The scientific definition of digestion, and the use of scientific vocabulary, are essential for introducing the subject."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649341Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2716-4
  a curric:KeyLearningPoint ;
  rdfs:label """The relative pronoun "which" can be used to embed a relative clause within a main clause to add detail."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649348Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2716-5
  a curric:KeyLearningPoint ;
  rdfs:label """A relative complex sentence is formed of a main clause and a relative subordinate clause."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649353Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6523-1
  a curric:KeyLearningPoint ;
  rdfs:label "The conclusion is the final paragraph of a non-fiction text."@en ;
  dcterms:modified "2026-02-12T08:59:21.649358Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6523-2
  a curric:KeyLearningPoint ;
  rdfs:label "Information in the conclusion should be kept general."@en ;
  dcterms:modified "2026-02-12T08:59:21.649363Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6523-3
  a curric:KeyLearningPoint ;
  rdfs:label """Plans should be used to document key, concise ideas. They can be built upon when writing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649367Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6523-4
  a curric:KeyLearningPoint ;
  rdfs:label "When writing, we should use our success criteria and plan to guide us."@en ;
  dcterms:modified "2026-02-12T08:59:21.649372Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6523-5
  a curric:KeyLearningPoint ;
  rdfs:label """Using a range of cohesive devices enhances text flow and helps achieve the text purpose."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649376Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7636-1
  a curric:KeyLearningPoint ;
  rdfs:label """Sentences should be said aloud before writing to ensure they make sense and read back once written to check for errors."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649398Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7636-2
  a curric:KeyLearningPoint ;
  rdfs:label """Ambitious vocabulary and figurative language create a vivid picture in the reader's mind."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649405Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7636-3
  a curric:KeyLearningPoint ;
  rdfs:label """Writers choose varied fronted adverbials and different sentence types to ensure the text flows for the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649410Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7636-4
  a curric:KeyLearningPoint ;
  rdfs:label """Careful selection of nouns and pronouns ensures cohesion within sentences and across sections of a written piece."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649415Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7636-5
  a curric:KeyLearningPoint ;
  rdfs:label """Past simple, progressive and perfect verb forms can be used to improve text cohesion."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649419Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7661-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of a narrative opening is to introduce the characters and to describe the setting to the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649427Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7661-2
  a curric:KeyLearningPoint ;
  rdfs:label """Using a range of sentence types (simple, compound and complex) improves text flow for the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649431Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7661-3
  a curric:KeyLearningPoint ;
  rdfs:label """A fronted adverbial of time, place or manner adds extra detail to the main clause that follows it."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649436Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7661-4
  a curric:KeyLearningPoint ;
  rdfs:label "This narrative version of ‘Whale Rider’ is written in the past tense."@en ;
  dcterms:modified "2026-02-12T08:59:21.649443Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7661-5
  a curric:KeyLearningPoint ;
  rdfs:label """Oral rehearsal before writing helps to structure grammatically correct sentences and check for sense."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649448Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8067-1
  a curric:KeyLearningPoint ;
  rdfs:label "‘You Are’ and ‘Mum Says She Loves Me’ are both poems written by Valerie Bloom."@en ;
  dcterms:modified "2026-02-12T08:59:21.649452Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8067-2
  a curric:KeyLearningPoint ;
  rdfs:label """Metaphors are used in the poem ‘You Are’; they are a way of comparing something by saying that it is something else."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649457Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8067-3
  a curric:KeyLearningPoint ;
  rdfs:label """‘Mum Says She Loves Me’ is a poem that offers a different perspective on the theme of love."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649462Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8067-4
  a curric:KeyLearningPoint ;
  rdfs:label """One way we can reflect on a poem and its themes is to think about our own personal response to it."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649466Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7921-1
  a curric:KeyLearningPoint ;
  rdfs:label """In the book, Joseph has had very negative experiences of schooling which cause him to be anxious about attending."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649471Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7921-2
  a curric:KeyLearningPoint ;
  rdfs:label "When we read, we often think about characters' motives."@en ;
  dcterms:modified "2026-02-12T08:59:21.649476Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7921-3
  a curric:KeyLearningPoint ;
  rdfs:label """We base our understanding of motives partly on what is made explicit by the author."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649481Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7921-4
  a curric:KeyLearningPoint ;
  rdfs:label """We may also infer motives based on the characters' actions, our own knowledge and our experiences."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649485Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3401-1
  a curric:KeyLearningPoint ;
  rdfs:label """The plan includes keywords and subject-specific vocabulary related to the section."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649576Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3401-2
  a curric:KeyLearningPoint ;
  rdfs:label "Taking notes is a skill."@en ;
  dcterms:modified "2026-02-12T08:59:21.649581Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3401-3
  a curric:KeyLearningPoint ;
  rdfs:label """Notes should not be written in full sentences and bullet points can be used to order notes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649586Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3401-4
  a curric:KeyLearningPoint ;
  rdfs:label "Key vocabulary and linguistic devices should be logged in a plan."@en ;
  dcterms:modified "2026-02-12T08:59:21.649591Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3401-5
  a curric:KeyLearningPoint ;
  rdfs:label "The plan should be clearly structured in the order of the section."@en ;
  dcterms:modified "2026-02-12T08:59:21.649595Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4824-1
  a curric:KeyLearningPoint ;
  rdfs:label "Writing at speed is a valuable skill to develop."@en ;
  dcterms:modified "2026-02-12T08:59:21.649600Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4824-2
  a curric:KeyLearningPoint ;
  rdfs:label "Writing at speed can decrease the legibility and accuracy of your writing."@en ;
  dcterms:modified "2026-02-12T08:59:21.649604Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4824-3
  a curric:KeyLearningPoint ;
  rdfs:label "Your hand and wrist muscles can get tired when you are writing at speed."@en ;
  dcterms:modified "2026-02-12T08:59:21.649609Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4824-4
  a curric:KeyLearningPoint ;
  rdfs:label """Regular practice, hand exercises and taking breaks can help to improve the speed and accuracy of your handwriting."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649614Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4824-5
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to find a balance between speed, accuracy and legibility when writing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649621Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6107-1
  a curric:KeyLearningPoint ;
  rdfs:label """Publishing our work is the final stage of the writing process where we prepare our writing ready for an audience to see."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649655Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6107-2
  a curric:KeyLearningPoint ;
  rdfs:label """Published work should be written in clear, joined handwriting with letters that start on the line."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649659Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6107-3
  a curric:KeyLearningPoint ;
  rdfs:label "A published non-chronological report will usually include a picture or diagram."@en ;
  dcterms:modified "2026-02-12T08:59:21.649664Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6107-4
  a curric:KeyLearningPoint ;
  rdfs:label """We indent each new paragraph and underline subheadings with a ruler and we follow any appropriate layout conventions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649669Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8638-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the build-up is to build action and suspense leading up to the climax."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649674Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8638-2
  a curric:KeyLearningPoint ;
  rdfs:label """In this section of the build-up, Arrietty sets off on her first borrowing expedition and reaches the infamous clock."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649678Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8638-3
  a curric:KeyLearningPoint ;
  rdfs:label """A range of precise and ambitious vocabulary is used to describe key moments in the build-up."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649683Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8638-4
  a curric:KeyLearningPoint ;
  rdfs:label """‘Show and tell’ language shows a character’s feelings by describing their actions, body language and facial expressions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649687Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8638-5
  a curric:KeyLearningPoint ;
  rdfs:label """A plan contains precise vocabulary, is written in note format and follows a sequence of events."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649692Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8059-1
  a curric:KeyLearningPoint ;
  rdfs:label """The poem describes the snow leopard as an elusive and majestic animal that lives in remote regions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649696Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8059-2
  a curric:KeyLearningPoint ;
  rdfs:label """The poem can be described as a fixed verse poem; it consists of thirteen two-line verses and two single line verses."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649701Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8059-3
  a curric:KeyLearningPoint ;
  rdfs:label "The poem uses enjambment to affect the pacing of the poem."@en ;
  dcterms:modified "2026-02-12T08:59:21.649706Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8059-4
  a curric:KeyLearningPoint ;
  rdfs:label """Imagery is used in the poem to convey the sights and sensations of the encounter between the snow leopard and the tahr."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649712Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5824-1
  a curric:KeyLearningPoint ;
  rdfs:label """Editing is the process of improving writing to ensure text flow and overall quality."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649717Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5824-2
  a curric:KeyLearningPoint ;
  rdfs:label """Editing involves making improvements to a piece of writing without completely rewriting it."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649725Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5824-3
  a curric:KeyLearningPoint ;
  rdfs:label """Punctuation, sentence structure, grammar, vocabulary and spelling are sensible areas to focus on in editing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649729Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5824-4
  a curric:KeyLearningPoint ;
  rdfs:label "Editing is a vital part of the writing process."@en ;
  dcterms:modified "2026-02-12T08:59:21.649734Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7665-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of climactic writing is to take the drama to the highest point of tension to evoke emotions in the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649739Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7665-2
  a curric:KeyLearningPoint ;
  rdfs:label """A very emotive scene in ‘Whale Rider’ describes Paikea's encounter with stranded whales on a beach."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649744Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7665-3
  a curric:KeyLearningPoint ;
  rdfs:label """Precise and ambitious vocabulary, including 'show-not-tell' language, is used to convey an emotive atmosphere."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649748Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7665-4
  a curric:KeyLearningPoint ;
  rdfs:label "Direct speech and characters' inner thoughts are used to convey their emotions."@en ;
  dcterms:modified "2026-02-12T08:59:21.649753Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7665-5
  a curric:KeyLearningPoint ;
  rdfs:label """Notes in a plan should not be written in full sentences and bullet points can be used to make notes clear."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649758Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7868-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘The Wild Robot’ follows the unexpected arrival of a robot on an island after its crate is washed ashore during a storm."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649786Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7868-2
  a curric:KeyLearningPoint ;
  rdfs:label """The robot, called Roz, learns human-like characteristics and emotions, such as care, friendship and love."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649791Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7868-3
  a curric:KeyLearningPoint ;
  rdfs:label """'The Wild Robot' is in the form of an illustrated chapter book, combining words and illustration."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649796Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7868-4
  a curric:KeyLearningPoint ;
  rdfs:label """'The Wild Robot' explores themes of identity, survival, adaptation, the natural world and technology."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649803Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7637-1
  a curric:KeyLearningPoint ;
  rdfs:label """The more precise and descriptive the writing, the easier for the reader to picture the scene."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649827Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7637-2
  a curric:KeyLearningPoint ;
  rdfs:label """Reading writing aloud is a helpful way to ensure precision of language choices and focus on vivid details."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649832Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7637-3
  a curric:KeyLearningPoint ;
  rdfs:label """Identifying the key elements such as colours, shapes, textures and emotions conveyed in the text is important."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649836Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7637-4
  a curric:KeyLearningPoint ;
  rdfs:label "Careful and detailed illustrations can match the writer's writing."@en ;
  dcterms:modified "2026-02-12T08:59:21.649841Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7637-5
  a curric:KeyLearningPoint ;
  rdfs:label """Illustrations can help bring writing to life and allow the reader to picture the descriptions even more."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649848Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7869-1
  a curric:KeyLearningPoint ;
  rdfs:label "Attitudes and perceptions of the central character, Roz, change over time."@en ;
  dcterms:modified "2026-02-12T08:59:21.649853Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7869-2
  a curric:KeyLearningPoint ;
  rdfs:label """Characters within the text depict a range of emotions. Character traits can be understood from these."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649858Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7869-3
  a curric:KeyLearningPoint ;
  rdfs:label "Character traits can be explored through the illustrations in addition to words."@en ;
  dcterms:modified "2026-02-12T08:59:21.649863Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7869-4
  a curric:KeyLearningPoint ;
  rdfs:label """Making connections and recommendations can significantly enhance the reading experience and broaden understanding."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649867Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5465-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Anansi and the Antelope Baby' is an African folktale."@en ;
  dcterms:modified "2026-02-12T08:59:21.649903Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5465-2
  a curric:KeyLearningPoint ;
  rdfs:label """Folktales belong to the genre of folklore in which oral stories are shared, adapted and passed down over time."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649908Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5465-3
  a curric:KeyLearningPoint ;
  rdfs:label """Folklore stories originate from a range of cultures but have features in common, e.g. learning a moral or lesson."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649913Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5465-4
  a curric:KeyLearningPoint ;
  rdfs:label "Anansi stories originated in Ghana and are influenced by African culture."@en ;
  dcterms:modified "2026-02-12T08:59:21.649917Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5465-5
  a curric:KeyLearningPoint ;
  rdfs:label """Anansi is a smart but mischievous spider who encounters a range of tricky circumstances with other animals."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649922Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1320-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of a conclusion is to summarise the key points in a text, providing closure to the subject."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649927Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1320-2
  a curric:KeyLearningPoint ;
  rdfs:label """A summary sentence is the opening sentence of a conclusion and summarises the key points in a text."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649931Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1320-3
  a curric:KeyLearningPoint ;
  rdfs:label "A conclusion begins with a formal fronted adverbial."@en ;
  dcterms:modified "2026-02-12T08:59:21.649936Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1320-4
  a curric:KeyLearningPoint ;
  rdfs:label "There are no new facts or information about the subject in the conclusion."@en ;
  dcterms:modified "2026-02-12T08:59:21.649941Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1320-5
  a curric:KeyLearningPoint ;
  rdfs:label """A conclusion finishes with the writer suggesting to the reader how to find out more about the subject."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649945Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4814-1
  a curric:KeyLearningPoint ;
  rdfs:label "Common exception words do not follow regular spelling or phonics rules."@en ;
  dcterms:modified "2026-02-12T08:59:21.649950Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4814-2
  a curric:KeyLearningPoint ;
  rdfs:label """Letters in the common exception words will be joined using a range of joins depending on the letters in the word."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649955Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4814-3
  a curric:KeyLearningPoint ;
  rdfs:label "The first letter always has a lead in and the last letter always has a lead out."@en ;
  dcterms:modified "2026-02-12T08:59:21.649959Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4814-4
  a curric:KeyLearningPoint ;
  rdfs:label "There is appropriate spacing between the letters."@en ;
  dcterms:modified "2026-02-12T08:59:21.649966Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4814-5
  a curric:KeyLearningPoint ;
  rdfs:label "You don't lift your pencil when forming the joins."@en ;
  dcterms:modified "2026-02-12T08:59:21.649971Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4834-1
  a curric:KeyLearningPoint ;
  rdfs:label "Print and cursive are the two most common handwriting styles."@en ;
  dcterms:modified "2026-02-12T08:59:21.649977Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4834-2
  a curric:KeyLearningPoint ;
  rdfs:label "Tasks that require speed and fluency should be completed in cursive handwriting."@en ;
  dcterms:modified "2026-02-12T08:59:21.649981Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4834-3
  a curric:KeyLearningPoint ;
  rdfs:label """Tasks that require a personal or formal approach should be written in cursive handwriting."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649988Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4834-4
  a curric:KeyLearningPoint ;
  rdfs:label """The cursive style of handwriting is often used for formal writing, such as letters, invitations and thank you notes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649993Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4834-5
  a curric:KeyLearningPoint ;
  rdfs:label """When writing in cursive, letter formation, spacing and using the correct joins ensure the writing is legible."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649998Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4826-1
  a curric:KeyLearningPoint ;
  rdfs:label """A famous quotation is a well-known phrase, statement, or passage attributed to a particular person, work, or source."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650002Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4826-2
  a curric:KeyLearningPoint ;
  rdfs:label "The quotation is demarcated with inverted commas."@en ;
  dcterms:modified "2026-02-12T08:59:21.650007Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4826-3
  a curric:KeyLearningPoint ;
  rdfs:label "The quotation starts with a capital letter."@en ;
  dcterms:modified "2026-02-12T08:59:21.650012Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4826-4
  a curric:KeyLearningPoint ;
  rdfs:label """After forming a capital letter, you need to lift your pencil to start the next part of the word."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650016Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4826-5
  a curric:KeyLearningPoint ;
  rdfs:label """A range of joins will be used depending on which letters are joining to which letters."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650021Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6157-1
  a curric:KeyLearningPoint ;
  rdfs:label "Writing is most successful when it is planned."@en ;
  dcterms:modified "2026-02-12T08:59:21.650026Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6157-2
  a curric:KeyLearningPoint ;
  rdfs:label """The introduction of a journalistic report will include a summary of the event, including who, what, where, when  & why."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650031Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6157-3
  a curric:KeyLearningPoint ;
  rdfs:label """The main paragraphs will be themed around different perspectives, integrating relevant facts."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650035Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6157-4
  a curric:KeyLearningPoint ;
  rdfs:label """The conclusion will include an official perspective, the most up-to-date information and a look to the future."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650040Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6157-5
  a curric:KeyLearningPoint ;
  rdfs:label """We can plan to use subject-specific vocabulary relevant to the subject of the report."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650047Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8092-1
  a curric:KeyLearningPoint ;
  rdfs:label """Characterisation is the way an author and illustrator develop the personalities and traits of the characters in a story."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650071Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8092-2
  a curric:KeyLearningPoint ;
  rdfs:label """Readers can tell lots about characters through their appearance, dialogue, their actions and how they are depicted."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650079Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8092-3
  a curric:KeyLearningPoint ;
  rdfs:label """Pages with no text can be called wordless (these can also be referred to as ‘silent’)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650083Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8092-4
  a curric:KeyLearningPoint ;
  rdfs:label """Having explored the characters in greater detail, readers can make predictions about what might happen next."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650088Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7667-1
  a curric:KeyLearningPoint ;
  rdfs:label """The emotive scene is written over two paragraphs and it is important to demonstrate a change in atmosphere."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650112Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7667-2
  a curric:KeyLearningPoint ;
  rdfs:label """Using a range of sentence types (simple, compound and complex) improves text flow and cohesion."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650116Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7667-3
  a curric:KeyLearningPoint ;
  rdfs:label """Precise and ambitious vocabulary, including 'show-not-tell' language, is used to convey an emotive atmosphere."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650121Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7667-4
  a curric:KeyLearningPoint ;
  rdfs:label """Direct speech and characters' internal thoughts are used to convey their emotions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650126Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7667-5
  a curric:KeyLearningPoint ;
  rdfs:label """Oral rehearsal before writing helps to structure grammatically correct sentences and check for sense."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650130Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7631-1
  a curric:KeyLearningPoint ;
  rdfs:label """Descriptive writing uses figurative language to create vivid pictures in the reader's mind."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650362Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7631-2
  a curric:KeyLearningPoint ;
  rdfs:label """Descriptive writing appeals to the reader's five senses: sight, sound, smell, taste and touch."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650366Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7631-3
  a curric:KeyLearningPoint ;
  rdfs:label "Descriptive writing uses precise and ambitious vocabulary."@en ;
  dcterms:modified "2026-02-12T08:59:21.650371Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7631-4
  a curric:KeyLearningPoint ;
  rdfs:label "Simile and personification are types of figurative language."@en ;
  dcterms:modified "2026-02-12T08:59:21.650376Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3404-1
  a curric:KeyLearningPoint ;
  rdfs:label "A subheading signals to the reader what the section is about."@en ;
  dcterms:modified "2026-02-12T08:59:21.650512Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3404-2
  a curric:KeyLearningPoint ;
  rdfs:label """Careful selection of nouns and pronouns ensures cohesion within sentences and across sections of the report."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650518Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3404-3
  a curric:KeyLearningPoint ;
  rdfs:label """A section about one feature of the report's subject contains specific facts and information to keep the reader engaged."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650522Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3404-4
  a curric:KeyLearningPoint ;
  rdfs:label """Writers choose varied fronted adverbials and different sentence types to ensure the text flows for the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650527Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3404-5
  a curric:KeyLearningPoint ;
  rdfs:label """Sentences should be said aloud before writing to ensure they make sense and read back once written to check for errors."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650531Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7929-1
  a curric:KeyLearningPoint ;
  rdfs:label """Both of Floella's parents leave for England. Floella and three siblings are split and live with guardians."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650536Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7929-2
  a curric:KeyLearningPoint ;
  rdfs:label """Migration to England during the Windrush period (1948-1971) was driven by a combination of factors."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650541Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7929-3
  a curric:KeyLearningPoint ;
  rdfs:label """Floella's characterisation changes as a result of the circumstances she now finds herself in."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650545Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7929-4
  a curric:KeyLearningPoint ;
  rdfs:label """Characterisation is the way an author & illustrator describe and develop the personalities and traits of the characters."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650550Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6155-1
  a curric:KeyLearningPoint ;
  rdfs:label """Climate change is driven by human activity - specifically, an increase in greenhouse gases."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650660Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6155-2
  a curric:KeyLearningPoint ;
  rdfs:label "Climate change will have significant impacts on the planet and human beings."@en ;
  dcterms:modified "2026-02-12T08:59:21.650664Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6155-3
  a curric:KeyLearningPoint ;
  rdfs:label """We can discuss who has responsibility to address climate change and what should be done to improve the situation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650671Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6155-4
  a curric:KeyLearningPoint ;
  rdfs:label """As part of this process of discussion, people may make speeches on either side of the debate."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650676Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6155-5
  a curric:KeyLearningPoint ;
  rdfs:label """We can use the PEPS (point, explanation, proof, summary) structure to help make a speech persuasive."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650681Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2728-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the climax is to describe the main action and take the suspense and excitement to its highest point."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650706Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2728-2
  a curric:KeyLearningPoint ;
  rdfs:label """Direct speech is punctuated using inverted commas. Dialogue moves the action forward."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650711Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2728-3
  a curric:KeyLearningPoint ;
  rdfs:label "Notes from a plan are used to form full sentences."@en ;
  dcterms:modified "2026-02-12T08:59:21.650715Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2728-4
  a curric:KeyLearningPoint ;
  rdfs:label """A range of sentence types (simple, compound and complex) improves text flow for the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650720Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2728-5
  a curric:KeyLearningPoint ;
  rdfs:label "A range of fronted adverbials is used to improve text flow."@en ;
  dcterms:modified "2026-02-12T08:59:21.650724Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5847-1
  a curric:KeyLearningPoint ;
  rdfs:label "A play script is the written form of a play."@en ;
  dcterms:modified "2026-02-12T08:59:21.650731Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5847-2
  a curric:KeyLearningPoint ;
  rdfs:label """Audiences can draw inferences and make conclusions about a character based on their words, expressions and actions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650736Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5847-3
  a curric:KeyLearningPoint ;
  rdfs:label "Vocabulary can be generated to precisely describe a scene for the reader."@en ;
  dcterms:modified "2026-02-12T08:59:21.650740Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5847-4
  a curric:KeyLearningPoint ;
  rdfs:label "Shakespearean characters often experience internal conflict."@en ;
  dcterms:modified "2026-02-12T08:59:21.650745Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5847-5
  a curric:KeyLearningPoint ;
  rdfs:label "Macbeth's decision making is influenced by his wife and his desire for power."@en ;
  dcterms:modified "2026-02-12T08:59:21.650752Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5819-1
  a curric:KeyLearningPoint ;
  rdfs:label "A character is a person, animal or figure in a story."@en ;
  dcterms:modified "2026-02-12T08:59:21.650756Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5819-2
  a curric:KeyLearningPoint ;
  rdfs:label "We can use expanded noun phrases to add detail and description to a noun."@en ;
  dcterms:modified "2026-02-12T08:59:21.650761Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5819-3
  a curric:KeyLearningPoint ;
  rdfs:label "A simile describes something by comparing it to something else."@en ;
  dcterms:modified "2026-02-12T08:59:21.650766Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7870-1
  a curric:KeyLearningPoint ;
  rdfs:label """The front cover of a text is part of the peritext; this also includes the blurb, endpapers and title page."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650773Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7870-2
  a curric:KeyLearningPoint ;
  rdfs:label """The peritext can give the readers clues and hints about what is contained in the story."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650782Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7870-3
  a curric:KeyLearningPoint ;
  rdfs:label """Levi Pinfold uses words and illustrations to show the events of the story and how the characters are feeling."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650787Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7870-4
  a curric:KeyLearningPoint ;
  rdfs:label """Readers can form personal reflections about texts by engaging with the words and illustrations in a meaningful way."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650792Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7870-5
  a curric:KeyLearningPoint ;
  rdfs:label """A prediction can be based on the words and illustrations in the text or a reader's own personal experience."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650796Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5848-1
  a curric:KeyLearningPoint ;
  rdfs:label """A soliloquy is a type of monologue that occurs when a character voices their thoughts and feelings aloud."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650819Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5848-2
  a curric:KeyLearningPoint ;
  rdfs:label """Playwrights include soliloquies to give the audience an insight into characters' feelings."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650823Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5848-3
  a curric:KeyLearningPoint ;
  rdfs:label """In Shakespeare's plays, high status characters' soliloquies follow iambic pentameter structure."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650828Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5848-4
  a curric:KeyLearningPoint ;
  rdfs:label "Soliloquies are written in the first person."@en ;
  dcterms:modified "2026-02-12T08:59:21.650832Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5848-5
  a curric:KeyLearningPoint ;
  rdfs:label "Other characters are silent during the speaker's soliloquy."@en ;
  dcterms:modified "2026-02-12T08:59:21.650837Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6377-1
  a curric:KeyLearningPoint ;
  rdfs:label "Drama can be a very useful tool when analysing characters in a text."@en ;
  dcterms:modified "2026-02-12T08:59:21.650842Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6377-2
  a curric:KeyLearningPoint ;
  rdfs:label "Dialogue is when two or more characters are speaking in a text."@en ;
  dcterms:modified "2026-02-12T08:59:21.650846Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6377-3
  a curric:KeyLearningPoint ;
  rdfs:label """When performing drama, we need to consider how intonation, facial expression and gestures enable us to convey emotions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650851Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6377-4
  a curric:KeyLearningPoint ;
  rdfs:label "Effective teamwork is an essential element of drama."@en ;
  dcterms:modified "2026-02-12T08:59:21.650856Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6273-1
  a curric:KeyLearningPoint ;
  rdfs:label """There are examples of Western and traditional Moroccan clothing represented within both stories."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650955Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6273-2
  a curric:KeyLearningPoint ;
  rdfs:label "Connections are ways in which you connect personally with a text."@en ;
  dcterms:modified "2026-02-12T08:59:21.650959Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6273-3
  a curric:KeyLearningPoint ;
  rdfs:label """The way that one reader connects might be different to another based on their own life experiences."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650964Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6273-4
  a curric:KeyLearningPoint ;
  rdfs:label "Connections can be from text-to-self, text-to-text or text-to-world."@en ;
  dcterms:modified "2026-02-12T08:59:21.650968Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6273-5
  a curric:KeyLearningPoint ;
  rdfs:label """There are connections between the two stories in ‘Mirror’ - involving characters, objects and clothing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650973Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2721-1
  a curric:KeyLearningPoint ;
  rdfs:label """'Jabberwocky' can be interpreted to follow this narrative structure: opening, build-up, climax, resolution."""@en ;
  dcterms:modified "2026-02-12T08:59:21.651084Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2721-2
  a curric:KeyLearningPoint ;
  rdfs:label """Accurate and ambitious descriptions of the characters and setting rely on careful and precise language choices."""@en ;
  dcterms:modified "2026-02-12T08:59:21.651088Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2721-3
  a curric:KeyLearningPoint ;
  rdfs:label """Some vocabulary is more precise than others; careful vocabulary choice is paramount to evoke setting and atmosphere."""@en ;
  dcterms:modified "2026-02-12T08:59:21.651093Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2721-4
  a curric:KeyLearningPoint ;
  rdfs:label """Different nouns and adjectives are used to refer to characters to avoid repetition."""@en ;
  dcterms:modified "2026-02-12T08:59:21.651097Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2721-5
  a curric:KeyLearningPoint ;
  rdfs:label """Imagining colours as we write helps us choose ambitious vocabulary that describes images as positive or negative."""@en ;
  dcterms:modified "2026-02-12T08:59:21.651102Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6274-1
  a curric:KeyLearningPoint ;
  rdfs:label """In 'Mirror' the afterword describes why Jeannie Baker was inspired to make the text and how she created the artwork."""@en ;
  dcterms:modified "2026-02-12T08:59:21.651106Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6274-2
  a curric:KeyLearningPoint ;
  rdfs:label "A theme is a big idea, topic or message that recurs within a story."@en ;
  dcterms:modified "2026-02-12T08:59:21.651111Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6274-3
  a curric:KeyLearningPoint ;
  rdfs:label """Readers can interpret their own big idea or message from a narrative; readers may interpret a text in different ways."""@en ;
  dcterms:modified "2026-02-12T08:59:21.651116Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6274-4
  a curric:KeyLearningPoint ;
  rdfs:label """Settings and events depicted in the book contribute to the boys’ sense of identity and belonging."""@en ;
  dcterms:modified "2026-02-12T08:59:21.651121Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6274-5
  a curric:KeyLearningPoint ;
  rdfs:label """Culture and traditions in each setting are conveyed through unique clothing, architecture, food and daily activities."""@en ;
  dcterms:modified "2026-02-12T08:59:21.651125Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8043-1
  a curric:KeyLearningPoint ;
  rdfs:label """'Who Has Seen the Wind?' is a short, simple poem that explores the invisible and mysterious nature of the wind."""@en ;
  dcterms:modified "2026-02-12T08:59:21.651132Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8043-2
  a curric:KeyLearningPoint ;
  rdfs:label "Personification is describing a non-living thing as if it is a person."@en ;
  dcterms:modified "2026-02-12T08:59:21.651137Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8043-3
  a curric:KeyLearningPoint ;
  rdfs:label """The poem uses rhetorical questions to demonstrate the mysterious nature of the wind."""@en ;
  dcterms:modified "2026-02-12T08:59:21.651142Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8043-4
  a curric:KeyLearningPoint ;
  rdfs:label """The structure of a poem is the way it is ordered, including its pattern of lines, verses and rhyme."""@en ;
  dcterms:modified "2026-02-12T08:59:21.651146Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6737-1
  a curric:KeyLearningPoint ;
  rdfs:label """Narratives are often written in the third person, but we can switch perspectives during a narrative."""@en ;
  dcterms:modified "2026-02-12T08:59:21.651152Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6737-2
  a curric:KeyLearningPoint ;
  rdfs:label """Including first person perspectives allows us to show the protagonist's thoughts."""@en ;
  dcterms:modified "2026-02-12T08:59:21.651156Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6737-3
  a curric:KeyLearningPoint ;
  rdfs:label """An internal monologue is a type of first person writing focused on the protagonist's inner thoughts."""@en ;
  dcterms:modified "2026-02-12T08:59:21.651161Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6737-4
  a curric:KeyLearningPoint ;
  rdfs:label """We can use a range of language techniques to lend internal monologue an informal tone."""@en ;
  dcterms:modified "2026-02-12T08:59:21.651165Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6737-5
  a curric:KeyLearningPoint ;
  rdfs:label "We can include sensory details to show more of the protagonist's emotions."@en ;
  dcterms:modified "2026-02-12T08:59:21.651170Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8896-1
  a curric:KeyLearningPoint ;
  rdfs:label """Skimming and scanning using your finger is a way to retrieve information accurately and quickly from a text"""@en ;
  dcterms:modified "2026-02-12T08:59:21.651214Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8896-2
  a curric:KeyLearningPoint ;
  rdfs:label "Reading between the lines to search for clues can help to infer meaning"@en ;
  dcterms:modified "2026-02-12T08:59:21.651223Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8896-3
  a curric:KeyLearningPoint ;
  rdfs:label "Evidence from the text helps us to justify our inferences"@en ;
  dcterms:modified "2026-02-12T08:59:21.651227Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8896-4
  a curric:KeyLearningPoint ;
  rdfs:label "Different characters have different experiences and perspectives of each other"@en ;
  dcterms:modified "2026-02-12T08:59:21.651232Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4807-1
  a curric:KeyLearningPoint ;
  rdfs:label """A suffix is a letter or group of letters at the end of a word which creates another word."""@en ;
  dcterms:modified "2026-02-12T08:59:21.651239Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4807-2
  a curric:KeyLearningPoint ;
  rdfs:label "The words start with a lead in and finish with a lead out."@en ;
  dcterms:modified "2026-02-12T08:59:21.651244Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4807-3
  a curric:KeyLearningPoint ;
  rdfs:label """The pencil does not lift when forming the join, only after to add the cross to a t or a dot to an i or a j."""@en ;
  dcterms:modified "2026-02-12T08:59:21.651248Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4807-4
  a curric:KeyLearningPoint ;
  rdfs:label "There are four cursive joins."@en ;
  dcterms:modified "2026-02-12T08:59:21.651253Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4807-5
  a curric:KeyLearningPoint ;
  rdfs:label """The join used depends on which letter is joining to which letter within a letter string."""@en ;
  dcterms:modified "2026-02-12T08:59:21.651257Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2722-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the opening is to engage the reader and introduce the setting and characters."""@en ;
  dcterms:modified "2026-02-12T08:59:21.651262Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2722-2
  a curric:KeyLearningPoint ;
  rdfs:label """When we plan, we log precise and ambitious vocabulary to help paint vivid pictures for our reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.651266Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2722-3
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials of time, place and manner are included in a plan to add extra detail about the action."""@en ;
  dcterms:modified "2026-02-12T08:59:21.651271Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2722-4
  a curric:KeyLearningPoint ;
  rdfs:label """Dialogue is the written conversation between two or more characters within a narrative and it moves the story forward."""@en ;
  dcterms:modified "2026-02-12T08:59:21.651275Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2722-5
  a curric:KeyLearningPoint ;
  rdfs:label """Show-not-tell language is a writing technique for showing a character’s feelings to a reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.651280Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2744-1
  a curric:KeyLearningPoint ;
  rdfs:label "Inverted commas are the punctuation that signal direct speech to the reader."@en ;
  dcterms:modified "2026-02-12T08:59:21.651285Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2744-2
  a curric:KeyLearningPoint ;
  rdfs:label "A speech interrupted sentence begins with a character's spoken words."@en ;
  dcterms:modified "2026-02-12T08:59:21.651289Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2744-3
  a curric:KeyLearningPoint ;
  rdfs:label "The character's spoken words are interrupted by the reporting clause."@en ;
  dcterms:modified "2026-02-12T08:59:21.651294Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2744-4
  a curric:KeyLearningPoint ;
  rdfs:label """The character's spoken words resume after the reporting clause and the speech interrupted sentence ends."""@en ;
  dcterms:modified "2026-02-12T08:59:21.651298Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2744-5
  a curric:KeyLearningPoint ;
  rdfs:label """A character's spoken words must be chosen carefully to include a natural break when punctuating speech interrupted."""@en ;
  dcterms:modified "2026-02-12T08:59:21.651310Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6417-1
  a curric:KeyLearningPoint ;
  rdfs:label "Writing is most successful when we orally rehearse before writing."@en ;
  dcterms:modified "2026-02-12T08:59:21.651337Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6417-2
  a curric:KeyLearningPoint ;
  rdfs:label "A diary can include events and feelings written in the past and present tense."@en ;
  dcterms:modified "2026-02-12T08:59:21.651341Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6417-3
  a curric:KeyLearningPoint ;
  rdfs:label """We use a range of cohesive devices in all writing, including different punctuation, sentence types and parenthesis."""@en ;
  dcterms:modified "2026-02-12T08:59:21.651346Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6417-4
  a curric:KeyLearningPoint ;
  rdfs:label """Because a diary is a personal piece of writing, it can have a conversational tone."""@en ;
  dcterms:modified "2026-02-12T08:59:21.651350Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6417-5
  a curric:KeyLearningPoint ;
  rdfs:label """We can create a conversational tone using questions, exclamatives, verbless sentences and conversational openers."""@en ;
  dcterms:modified "2026-02-12T08:59:21.651355Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7829-1
  a curric:KeyLearningPoint ;
  rdfs:label """Babe shows many positive character traits, including kindness, politeness, determination and friendliness."""@en ;
  dcterms:modified "2026-02-12T08:59:21.651360Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7829-2
  a curric:KeyLearningPoint ;
  rdfs:label "Babe's kindness and determination helps him to form relationships."@en ;
  dcterms:modified "2026-02-12T08:59:21.651364Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7829-3
  a curric:KeyLearningPoint ;
  rdfs:label "Farmer Hogget forms a bond with Babe and Fly accepts Babe and teaches him."@en ;
  dcterms:modified "2026-02-12T08:59:21.651369Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7829-4
  a curric:KeyLearningPoint ;
  rdfs:label """Role on the wall is a reading activity which helps us develop our understanding of characters in a story or text."""@en ;
  dcterms:modified "2026-02-12T08:59:21.651373Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7829-5
  a curric:KeyLearningPoint ;
  rdfs:label "We can support our ideas with evidence from the text."@en ;
  dcterms:modified "2026-02-12T08:59:21.651377Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1103-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Howl' is a verb which means to cry or wail."@en ;
  dcterms:modified "2026-02-12T08:59:21.651399Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1103-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Whirlwind' is a noun which means a hurricane or tornado."@en ;
  dcterms:modified "2026-02-12T08:59:21.651406Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1103-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Windswept' is an adjective which means beaten by the wind and untidy."@en ;
  dcterms:modified "2026-02-12T08:59:21.651410Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4808-1
  a curric:KeyLearningPoint ;
  rdfs:label """A suffix is a letter or group of letters at the end of a word which creates another word."""@en ;
  dcterms:modified "2026-02-12T08:59:21.651989Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4808-2
  a curric:KeyLearningPoint ;
  rdfs:label "The words start with a lead in and finish with a lead out."@en ;
  dcterms:modified "2026-02-12T08:59:21.651994Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4808-3
  a curric:KeyLearningPoint ;
  rdfs:label """The pencil does not lift when forming the join, only after to add the cross to a t or a dot to an i or a j."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652001Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4808-4
  a curric:KeyLearningPoint ;
  rdfs:label "There are four cursive joins."@en ;
  dcterms:modified "2026-02-12T08:59:21.652006Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4808-5
  a curric:KeyLearningPoint ;
  rdfs:label """The join used depends on which letter is joining to which letter within a letter string."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652010Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5699-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the climax is to give the reader the most dramatic action and increase the tension to its height."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652015Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5699-2
  a curric:KeyLearningPoint ;
  rdfs:label "Precise and ambitious vocabulary is logged in a plan for future use."@en ;
  dcterms:modified "2026-02-12T08:59:21.652020Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5699-3
  a curric:KeyLearningPoint ;
  rdfs:label """Notes should not be written in full sentences and bullet points can be used to make notes clear."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652024Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5699-4
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials of time, place and manner indicate when, where and how an action takes place."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652028Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8642-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the build-up is to build action and suspense leading up to the climax."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652035Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8642-2
  a curric:KeyLearningPoint ;
  rdfs:label """In this section of the build-up, Arrietty explores the outside world and spots the eye of a human “bean”."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652040Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8642-3
  a curric:KeyLearningPoint ;
  rdfs:label "The atmosphere and Arrietty’s emotions shift after she spots the eye."@en ;
  dcterms:modified "2026-02-12T08:59:21.652047Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8642-4
  a curric:KeyLearningPoint ;
  rdfs:label """A range of precise and ambitious vocabulary, including ‘show and tell’ language, is used to describe key moments."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652052Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8642-5
  a curric:KeyLearningPoint ;
  rdfs:label """‘Show and tell’ language shows a character’s feelings by describing their actions, body language and facial expressions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652057Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2727-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the climax is to describe the main action and to take the tension and excitement to its highest point."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652110Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2727-2
  a curric:KeyLearningPoint ;
  rdfs:label """When we plan, we log precise and ambitious vocabulary to help paint vivid pictures for our reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652116Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2727-3
  a curric:KeyLearningPoint ;
  rdfs:label "An effective plan's vocabulary is organised neatly and concisely in note form."@en ;
  dcterms:modified "2026-02-12T08:59:21.652121Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2727-4
  a curric:KeyLearningPoint ;
  rdfs:label """Dialogue is the written conversation between two or more characters within a narrative and it moves the story forward."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652125Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2727-5
  a curric:KeyLearningPoint ;
  rdfs:label """Show-not-tell language is a writing technique for showing a character’s feelings to a reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652130Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5469-1
  a curric:KeyLearningPoint ;
  rdfs:label "A moral is a lesson that can be learnt from a story or experience."@en ;
  dcterms:modified "2026-02-12T08:59:21.652134Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5469-2
  a curric:KeyLearningPoint ;
  rdfs:label """Exploring character traits and themes within a folktale can help us infer a moral from the story."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652139Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5469-3
  a curric:KeyLearningPoint ;
  rdfs:label """Readers may have different interpretations of a text, its meaning or the moral drawn from it."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652143Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5469-4
  a curric:KeyLearningPoint ;
  rdfs:label """Personal responses to a story may vary as a result of an individual's own life experiences."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652148Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5469-5
  a curric:KeyLearningPoint ;
  rdfs:label """Making comparisons between a story and our life experiences can help us reflect on our own character and actions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652153Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6729-1
  a curric:KeyLearningPoint ;
  rdfs:label "Writing is most successful when structure, content and vocabulary are planned."@en ;
  dcterms:modified "2026-02-12T08:59:21.652157Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6729-2
  a curric:KeyLearningPoint ;
  rdfs:label """We aim to use a range of narrative elements in our writing and to set an appropriate mood with them."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652164Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6729-3
  a curric:KeyLearningPoint ;
  rdfs:label """We use a range of cohesive devices to connect ideas, including a variety of fronted adverbials."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652168Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6729-4
  a curric:KeyLearningPoint ;
  rdfs:label "We can create compound adjectives using hyphens to add descriptive detail."@en ;
  dcterms:modified "2026-02-12T08:59:21.652173Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6729-5
  a curric:KeyLearningPoint ;
  rdfs:label "We can use dialogue to add to the tense mood of our writing."@en ;
  dcterms:modified "2026-02-12T08:59:21.652180Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7898-1
  a curric:KeyLearningPoint ;
  rdfs:label "A theme is a big idea, topic or message that recurs within a story."@en ;
  dcterms:modified "2026-02-12T08:59:21.652208Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7898-2
  a curric:KeyLearningPoint ;
  rdfs:label """Themes can be incredibly relevant and link to significant issues regardless of the time in which the text was written."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652213Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7898-3
  a curric:KeyLearningPoint ;
  rdfs:label "At the end of the text, the author offers resolutions to many of the characters."@en ;
  dcterms:modified "2026-02-12T08:59:21.652217Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7898-4
  a curric:KeyLearningPoint ;
  rdfs:label """The theme of identity is conveyed through Oliver’s emotional journey to finding out who he is; it is a central theme."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652222Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7666-1
  a curric:KeyLearningPoint ;
  rdfs:label """This emotive scene is written over two paragraphs and it is important to demonstrate a change in atmosphere across them."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652277Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7666-2
  a curric:KeyLearningPoint ;
  rdfs:label """Using a range of sentence types (simple, compound and complex) improves text flow and cohesion."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652281Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7666-3
  a curric:KeyLearningPoint ;
  rdfs:label """Precise and ambitious vocabulary, including 'show-not-tell' language, is used to convey an emotive atmosphere."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652286Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7666-4
  a curric:KeyLearningPoint ;
  rdfs:label """‘Show-not-tell’ shows a character’s feelings with description of their actions, body language and facial expressions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652290Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7666-5
  a curric:KeyLearningPoint ;
  rdfs:label """Oral rehearsal before writing helps to structure grammatically correct sentences and check for sense."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652295Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6758-1
  a curric:KeyLearningPoint ;
  rdfs:label """Editing is a critical part of the writing process. A growth mindset helps us benefit most from editing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652322Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6758-2
  a curric:KeyLearningPoint ;
  rdfs:label """Writing is most successful when editing is used to rethink, rephrase and reconsider first ideas."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652326Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6758-3
  a curric:KeyLearningPoint ;
  rdfs:label """Editing is most successful when it is chunked by punctuation, sentence structure, vocabulary and cohesive devices."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652331Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6758-4
  a curric:KeyLearningPoint ;
  rdfs:label """We can connect ideas in a range of different ways, using different cohesive devices - there is rarely only one way."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652335Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6758-5
  a curric:KeyLearningPoint ;
  rdfs:label """We use a less formal tone when quoting real people's speech; we use a formal tone elsewhere in our text."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652340Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5844-1
  a curric:KeyLearningPoint ;
  rdfs:label "Writing is most successful when it is planned."@en ;
  dcterms:modified "2026-02-12T08:59:21.652344Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5844-2
  a curric:KeyLearningPoint ;
  rdfs:label """A narrative opening should engage the reader and describe the setting and any characters who are present."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652353Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5844-3
  a curric:KeyLearningPoint ;
  rdfs:label "This narrative opening will be written in the third person."@en ;
  dcterms:modified "2026-02-12T08:59:21.652358Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5844-4
  a curric:KeyLearningPoint ;
  rdfs:label "Dialogue can be used to convey character and advance the action."@en ;
  dcterms:modified "2026-02-12T08:59:21.652363Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5844-5
  a curric:KeyLearningPoint ;
  rdfs:label """Variation in vocabulary and sentence structure engages the reader and improves text cohesion."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652367Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5846-1
  a curric:KeyLearningPoint ;
  rdfs:label """A protagonist is the leading character or one of the major characters in a narrative."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652372Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5846-2
  a curric:KeyLearningPoint ;
  rdfs:label "Macbeth is the protagonist of Shakespeare's ’Macbeth’."@en ;
  dcterms:modified "2026-02-12T08:59:21.652377Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5846-3
  a curric:KeyLearningPoint ;
  rdfs:label "Inner conflict is a key theme in many of Shakespeare's plays."@en ;
  dcterms:modified "2026-02-12T08:59:21.652381Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5846-4
  a curric:KeyLearningPoint ;
  rdfs:label """We can make inferences about characters' feelings and personalities based on their actions, expressions and words."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652386Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5846-5
  a curric:KeyLearningPoint ;
  rdfs:label "Macbeth is a highly conflicted character."@en ;
  dcterms:modified "2026-02-12T08:59:21.652390Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5664-1
  a curric:KeyLearningPoint ;
  rdfs:label """After Grendel is defeated, another monster - his mother - arrives at Heorot, taking away a Dane."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652395Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5664-2
  a curric:KeyLearningPoint ;
  rdfs:label "Beowulf and his companions travel across bleak countryside to find her lair."@en ;
  dcterms:modified "2026-02-12T08:59:21.652400Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5664-3
  a curric:KeyLearningPoint ;
  rdfs:label """Beowulf fights with Grendel's mother, narrowly avoiding death before killing her with a special sword."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652404Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5664-4
  a curric:KeyLearningPoint ;
  rdfs:label """Authors make specific language choices in their writing in order to have a specific effect on the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652410Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5664-5
  a curric:KeyLearningPoint ;
  rdfs:label """A kenning is an Old English way of replacing a noun with a two-word phrase that describes it indirectly."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652415Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7628-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the resolution is to resolve a story and to solve any of the characters’ problems."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652420Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7628-2
  a curric:KeyLearningPoint ;
  rdfs:label """A range of sentence types (simple, compound and complex) improves text flow for the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652427Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7628-3
  a curric:KeyLearningPoint ;
  rdfs:label "Notes from a plan can be used to form full sentences."@en ;
  dcterms:modified "2026-02-12T08:59:21.652432Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7628-4
  a curric:KeyLearningPoint ;
  rdfs:label "Paragraphs are used to indicate the start of a new idea or key moment."@en ;
  dcterms:modified "2026-02-12T08:59:21.652436Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7628-5
  a curric:KeyLearningPoint ;
  rdfs:label """Direct speech is punctuated using inverted commas. Dialogue moves the action forward."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652443Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5695-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the opening is to engage the reader and introduce the setting and characters."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652448Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5695-2
  a curric:KeyLearningPoint ;
  rdfs:label "Precise and ambitious vocabulary is logged on a plan for future use."@en ;
  dcterms:modified "2026-02-12T08:59:21.652455Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5695-3
  a curric:KeyLearningPoint ;
  rdfs:label """Notes should not be written in full sentences and bullet points can be used to make notes clear."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652460Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5695-4
  a curric:KeyLearningPoint ;
  rdfs:label "Show and tell vocabulary describes character emotions in greater detail."@en ;
  dcterms:modified "2026-02-12T08:59:21.652465Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5695-5
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials of time and place indicate when and where an action takes place."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652469Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7675-1
  a curric:KeyLearningPoint ;
  rdfs:label """The plan includes keywords and subject-specific vocabulary related to the section."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652519Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7675-2
  a curric:KeyLearningPoint ;
  rdfs:label "Taking notes is a skill."@en ;
  dcterms:modified "2026-02-12T08:59:21.652524Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7675-3
  a curric:KeyLearningPoint ;
  rdfs:label """Notes should not be written in full sentences and bullet points can be used to order notes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652530Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7675-4
  a curric:KeyLearningPoint ;
  rdfs:label "Key vocabulary and linguistic devices should be logged in a plan."@en ;
  dcterms:modified "2026-02-12T08:59:21.652535Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7675-5
  a curric:KeyLearningPoint ;
  rdfs:label "The plan should be clearly structured in the order of the section."@en ;
  dcterms:modified "2026-02-12T08:59:21.652540Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8055-1
  a curric:KeyLearningPoint ;
  rdfs:label """Texts can be recommended in a variety of ways, including online via Book Award websites or blogs."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652544Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8055-2
  a curric:KeyLearningPoint ;
  rdfs:label """Reflecting on likes, dislikes, puzzles and connections in relation to texts, can influence others to read."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652549Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6272-1
  a curric:KeyLearningPoint ;
  rdfs:label """The Moroccan story is set in the Valley of the Roses; the Western (Australian) setting is based on a suburb of Sydney."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652576Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6272-2
  a curric:KeyLearningPoint ;
  rdfs:label "The two landscapes contrast with each other."@en ;
  dcterms:modified "2026-02-12T08:59:21.652582Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6272-3
  a curric:KeyLearningPoint ;
  rdfs:label "Asking questions about the images helps us to understand their purpose."@en ;
  dcterms:modified "2026-02-12T08:59:21.652587Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6272-4
  a curric:KeyLearningPoint ;
  rdfs:label """A prediction can be based on reading and discussion. It can also link to a reader's own personal experience."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652592Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6272-5
  a curric:KeyLearningPoint ;
  rdfs:label "Drawing comparisons between images helps us to understand their meaning."@en ;
  dcterms:modified "2026-02-12T08:59:21.652596Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7630-1
  a curric:KeyLearningPoint ;
  rdfs:label """A published piece of writing should be visually and linguistically appealing to the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652601Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7630-2
  a curric:KeyLearningPoint ;
  rdfs:label "Neat, joined handwriting is important when publishing a piece of writing."@en ;
  dcterms:modified "2026-02-12T08:59:21.652605Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7630-3
  a curric:KeyLearningPoint ;
  rdfs:label """A piece of published writing is the final, best version that becomes available to others."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652610Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7630-4
  a curric:KeyLearningPoint ;
  rdfs:label """Illustrations provide visual representations of the characters, settings and events described in the text."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652617Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7630-5
  a curric:KeyLearningPoint ;
  rdfs:label """Illustrations can bring the world of the story to life and make it more vivid in the reader's mind."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652622Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7642-1
  a curric:KeyLearningPoint ;
  rdfs:label """The headline and opening of a persuasive advert should be eye-catching and hook the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652626Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7642-2
  a curric:KeyLearningPoint ;
  rdfs:label """Linguistic techniques like alliteration, rhyme, onomatopoeia and personification are used to create catchy headlines."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652631Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7642-3
  a curric:KeyLearningPoint ;
  rdfs:label """Rhetorical questions are a persuasive technique used to hook the reader in the opening of a persuasive advert."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652635Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7642-4
  a curric:KeyLearningPoint ;
  rdfs:label """Persuasive writing should be informed by the unique selling point of the product an advert is about."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652640Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7642-5
  a curric:KeyLearningPoint ;
  rdfs:label """The use of a conditional clause to refer to the possibility of something is a persuasive technique."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652645Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6366-1
  a curric:KeyLearningPoint ;
  rdfs:label """Alred Noyes uses figurative language to hook the reader in and create atmosphere in stanza one."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652779Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6366-2
  a curric:KeyLearningPoint ;
  rdfs:label "Repetition can be used to emphasise a particular word, sentence or phrase."@en ;
  dcterms:modified "2026-02-12T08:59:21.652783Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6366-3
  a curric:KeyLearningPoint ;
  rdfs:label "Personification is when a non-human thing is given human characteristics."@en ;
  dcterms:modified "2026-02-12T08:59:21.652788Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6366-4
  a curric:KeyLearningPoint ;
  rdfs:label """Metaphor is when one thing is described as another; simile involves using 'like' or 'as' to compare two things."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652795Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6366-5
  a curric:KeyLearningPoint ;
  rdfs:label """Alliteration is when two or more words begin with the same starting sound or letter."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652799Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28401-1
  a curric:KeyLearningPoint ;
  rdfs:label "The layout of a poem refers to the way the poem is organised on the page."@en ;
  dcterms:modified "2026-02-12T08:59:21.652804Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28401-2
  a curric:KeyLearningPoint ;
  rdfs:label """Poets can use different layouts and line breaks to convey the plot, characters and emotions of the story."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652809Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28401-3
  a curric:KeyLearningPoint ;
  rdfs:label """Goodfellow mixes up the visual arrangements of the poems, which helps the reader understand the characters' emotions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652813Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28401-4
  a curric:KeyLearningPoint ;
  rdfs:label """Characterisation is the way authors & illustrators describe & develop the personalities & traits of the characters."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652818Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7648-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the opening is to engage the reader and introduce the setting and characters."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652932Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7648-2
  a curric:KeyLearningPoint ;
  rdfs:label """When we plan, we log precise and ambitious vocabulary to help paint vivid pictures for our reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652938Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7648-3
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials of time, place and manner are included in a plan to add extra detail about the action."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652942Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7648-4
  a curric:KeyLearningPoint ;
  rdfs:label """Dialogue is the written conversation between two characters or more within a narrative and it moves the story forward."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652947Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7648-5
  a curric:KeyLearningPoint ;
  rdfs:label """Figurative language is used in narrative writing to create vivid pictures for the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652951Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6694-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the climax is to describe the main action and take the suspense and excitement to its highest point."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652956Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6694-2
  a curric:KeyLearningPoint ;
  rdfs:label """Precise and ambitious vocabulary create vivid images for the reader for each key moment of the climax."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652961Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6694-3
  a curric:KeyLearningPoint ;
  rdfs:label "An effective plan has vocabulary organised concisely and neatly."@en ;
  dcterms:modified "2026-02-12T08:59:21.652965Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6694-4
  a curric:KeyLearningPoint ;
  rdfs:label """Careful verb and adverb selection can convey characters' feelings through ‘show and tell’."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652970Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6694-5
  a curric:KeyLearningPoint ;
  rdfs:label "The emotions of the character change through the key moments of the climax."@en ;
  dcterms:modified "2026-02-12T08:59:21.652974Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6748-1
  a curric:KeyLearningPoint ;
  rdfs:label "Editing is a critical part of the writing process."@en ;
  dcterms:modified "2026-02-12T08:59:21.653021Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6748-2
  a curric:KeyLearningPoint ;
  rdfs:label """Writing is most successful when editing is used to rethink, rephrase and reconsider first ideas."""@en ;
  dcterms:modified "2026-02-12T08:59:21.653026Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6748-3
  a curric:KeyLearningPoint ;
  rdfs:label "Editing can be done by oneself, with a peer or with a teacher."@en ;
  dcterms:modified "2026-02-12T08:59:21.653030Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6748-4
  a curric:KeyLearningPoint ;
  rdfs:label """Editing is most successful when it is chunked by punctuation, sentence structure, vocabulary and cohesive devices."""@en ;
  dcterms:modified "2026-02-12T08:59:21.653035Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6748-5
  a curric:KeyLearningPoint ;
  rdfs:label "A growth mindset helps us benefit most from editing."@en ;
  dcterms:modified "2026-02-12T08:59:21.653039Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4817-1
  a curric:KeyLearningPoint ;
  rdfs:label """A kenning poem is a poem constructed using a series of kennings to describe a person, object, or concept."""@en ;
  dcterms:modified "2026-02-12T08:59:21.653044Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4817-2
  a curric:KeyLearningPoint ;
  rdfs:label "Each line of the poem starts on a new line and with a capital letter."@en ;
  dcterms:modified "2026-02-12T08:59:21.653048Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4817-3
  a curric:KeyLearningPoint ;
  rdfs:label """After forming a capital letter, you need to lift your pencil to start the next part of the word."""@en ;
  dcterms:modified "2026-02-12T08:59:21.653053Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4817-4
  a curric:KeyLearningPoint ;
  rdfs:label """Each letter string contains different letter joins depending on which letters are in the word."""@en ;
  dcterms:modified "2026-02-12T08:59:21.653057Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4817-5
  a curric:KeyLearningPoint ;
  rdfs:label "You don't lift your pencil when forming the joins."@en ;
  dcterms:modified "2026-02-12T08:59:21.653064Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6271-1
  a curric:KeyLearningPoint ;
  rdfs:label """In the Western story, panels are designed to be read from left to right; the Moroccan story is read from right to left."""@en ;
  dcterms:modified "2026-02-12T08:59:21.653470Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6271-2
  a curric:KeyLearningPoint ;
  rdfs:label "Looking for contextual clues help us to infer meaning from images."@en ;
  dcterms:modified "2026-02-12T08:59:21.653474Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6271-3
  a curric:KeyLearningPoint ;
  rdfs:label "Inferring meaning can help us to build our understanding of the story."@en ;
  dcterms:modified "2026-02-12T08:59:21.653479Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6271-4
  a curric:KeyLearningPoint ;
  rdfs:label "Drawing comparisons between images helps us to understand their meaning."@en ;
  dcterms:modified "2026-02-12T08:59:21.653483Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4822-1
  a curric:KeyLearningPoint ;
  rdfs:label """A famous quotation is a well-known phrase, statement, or passage attributed to a particular person, work, or source."""@en ;
  dcterms:modified "2026-02-12T08:59:21.653488Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4822-2
  a curric:KeyLearningPoint ;
  rdfs:label "The quotation is demarcated with inverted commas."@en ;
  dcterms:modified "2026-02-12T08:59:21.653493Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4822-3
  a curric:KeyLearningPoint ;
  rdfs:label "The quotation starts with a capital letter."@en ;
  dcterms:modified "2026-02-12T08:59:21.653497Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4822-4
  a curric:KeyLearningPoint ;
  rdfs:label """After forming a capital letter, you need to lift your pencil to start the next part of the word."""@en ;
  dcterms:modified "2026-02-12T08:59:21.653502Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4822-5
  a curric:KeyLearningPoint ;
  rdfs:label """A range of joins will be used depending on which letters are joining to which letters."""@en ;
  dcterms:modified "2026-02-12T08:59:21.653506Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1092-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Hurtle' is a verb which means to rush or move very quickly."@en ;
  dcterms:modified "2026-02-12T08:59:21.653510Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1092-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Scamper' is a verb which means to scurry or dash."@en ;
  dcterms:modified "2026-02-12T08:59:21.653515Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1092-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Charge', 'dart', 'dash' and 'scurry' are other verbs related to running."@en ;
  dcterms:modified "2026-02-12T08:59:21.653519Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1088-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Scrutinise' is a verb, which means to inspect or study."@en ;
  dcterms:modified "2026-02-12T08:59:21.653524Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1088-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Glimpse' is a verb, which means to spot or get a quick look."@en ;
  dcterms:modified "2026-02-12T08:59:21.653528Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1088-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Peer', 'squint', 'gawk' and 'gaze' are other verbs related to looking or seeing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.653533Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7882-1
  a curric:KeyLearningPoint ;
  rdfs:label """The text is told from the perspective of Julie; she reflects on her time in Year 6 when Chingis joined her class."""@en ;
  dcterms:modified "2026-02-12T08:59:21.653566Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7882-2
  a curric:KeyLearningPoint ;
  rdfs:label """Chingis is a young boy who, along with his brother Nergui, immigrates from Mongolia to Liverpool."""@en ;
  dcterms:modified "2026-02-12T08:59:21.653570Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7882-3
  a curric:KeyLearningPoint ;
  rdfs:label """The text explores the rich history of Chingis’ home country, its landscape and nomadic culture."""@en ;
  dcterms:modified "2026-02-12T08:59:21.653575Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7882-4
  a curric:KeyLearningPoint ;
  rdfs:label """A theme is a big idea, topic or message that recurs within a story; identifying themes within a text involves inference."""@en ;
  dcterms:modified "2026-02-12T08:59:21.653579Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7882-5
  a curric:KeyLearningPoint ;
  rdfs:label """Julie begins to understand the challenges that Chingis and his family face in trying to remain in the country."""@en ;
  dcterms:modified "2026-02-12T08:59:21.653584Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6156-1
  a curric:KeyLearningPoint ;
  rdfs:label "Journalistic reports contain a mixture of facts and individuals' perspectives."@en ;
  dcterms:modified "2026-02-12T08:59:21.653744Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6156-2
  a curric:KeyLearningPoint ;
  rdfs:label """Journalists obtain facts through research, observation and requests for information."""@en ;
  dcterms:modified "2026-02-12T08:59:21.653750Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6156-3
  a curric:KeyLearningPoint ;
  rdfs:label "Journalists can obtain individuals' perspectives using interviews."@en ;
  dcterms:modified "2026-02-12T08:59:21.653755Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6156-4
  a curric:KeyLearningPoint ;
  rdfs:label """Journalists are obliged to record quotations accurately to reflect individuals' perspectives."""@en ;
  dcterms:modified "2026-02-12T08:59:21.653760Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6156-5
  a curric:KeyLearningPoint ;
  rdfs:label """We can use role play as a way of empathising with different perspectives and generating ideas for writing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.653764Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1354-1
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: available, vegetable, physical and symbol."@en ;
  dcterms:modified "2026-02-12T08:59:21.653787Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1354-2
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: convenience, existence and conscience."@en ;
  dcterms:modified "2026-02-12T08:59:21.653792Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1354-3
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: equipped, attached and thorough."@en ;
  dcterms:modified "2026-02-12T08:59:21.653796Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1354-4
  a curric:KeyLearningPoint ;
  rdfs:label "Spelling strategies help us to notice how words are spelled."@en ;
  dcterms:modified "2026-02-12T08:59:21.653801Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1354-5
  a curric:KeyLearningPoint ;
  rdfs:label """The practice spelling strategy you choose often depends on the spelling you are practising and what makes it difficult."""@en ;
  dcterms:modified "2026-02-12T08:59:21.653805Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4860-1
  a curric:KeyLearningPoint ;
  rdfs:label "The purpose of the introduction is to give general information to the reader."@en ;
  dcterms:modified "2026-02-12T08:59:21.654242Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4860-2
  a curric:KeyLearningPoint ;
  rdfs:label """The introduction outlines what the reader will learn from the non-chronological report."""@en ;
  dcterms:modified "2026-02-12T08:59:21.654278Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4860-3
  a curric:KeyLearningPoint ;
  rdfs:label """The facts in the opening are general about King Tut; they become more specific in later paragraphs."""@en ;
  dcterms:modified "2026-02-12T08:59:21.654283Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4860-4
  a curric:KeyLearningPoint ;
  rdfs:label "An introduction ends with a command to the reader to continue reading."@en ;
  dcterms:modified "2026-02-12T08:59:21.654288Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4860-5
  a curric:KeyLearningPoint ;
  rdfs:label """A compound sentence is formed of two main clauses joined with a co-ordinating conjunction."""@en ;
  dcterms:modified "2026-02-12T08:59:21.654293Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8068-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘My Heart is a Volcano’ is split into three verses with four lines in each; each verse follows an ABCB rhyme scheme."""@en ;
  dcterms:modified "2026-02-12T08:59:21.654297Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8068-2
  a curric:KeyLearningPoint ;
  rdfs:label """Through the use of metaphors, the poem conveys the atmosphere as it follows the speaker's emotional journey."""@en ;
  dcterms:modified "2026-02-12T08:59:21.654304Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8068-3
  a curric:KeyLearningPoint ;
  rdfs:label """Understanding a poem, its language, imagery and the impression it creates will help create an impactful performance."""@en ;
  dcterms:modified "2026-02-12T08:59:21.654309Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8068-4
  a curric:KeyLearningPoint ;
  rdfs:label """Performances can be improved by considering the rhythm and flow of the poem, use of voice, gestures and body language."""@en ;
  dcterms:modified "2026-02-12T08:59:21.654314Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6350-1
  a curric:KeyLearningPoint ;
  rdfs:label "Writing is most successful when it is planned."@en ;
  dcterms:modified "2026-02-12T08:59:21.654319Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6350-2
  a curric:KeyLearningPoint ;
  rdfs:label "We can plan to use a range of persuasive techniques in a persuasive letter."@en ;
  dcterms:modified "2026-02-12T08:59:21.654323Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6350-3
  a curric:KeyLearningPoint ;
  rdfs:label """When we generate ideas for persuasive techniques, we are thinking about the effect they will have on the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.654328Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6350-4
  a curric:KeyLearningPoint ;
  rdfs:label """We can use precise expanded noun phrases to describe the reader when creating flattery."""@en ;
  dcterms:modified "2026-02-12T08:59:21.654332Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1100-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Dusk' is a noun which means twilight or nightfall."@en ;
  dcterms:modified "2026-02-12T08:59:21.654337Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1100-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Eerie' is an adjective which means weird, ghostly or creepy."@en ;
  dcterms:modified "2026-02-12T08:59:21.654341Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1100-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Nocturnal' is an adjective which means nightly or active at night."@en ;
  dcterms:modified "2026-02-12T08:59:21.654346Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1100-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Twilight', 'moonlit' and 'sleepless' are other rich vocabulary associated with night."""@en ;
  dcterms:modified "2026-02-12T08:59:21.654350Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6380-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of an editing lesson is to improve your writing and make necessary corrections."""@en ;
  dcterms:modified "2026-02-12T08:59:21.654759Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6380-2
  a curric:KeyLearningPoint ;
  rdfs:label """Vocabulary, grammar and punctuation can be changed to make writing more effectively meet its purpose."""@en ;
  dcterms:modified "2026-02-12T08:59:21.654764Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6380-3
  a curric:KeyLearningPoint ;
  rdfs:label """Specific rules of how to punctuate speech first and speech second sentences must be checked during the editing process."""@en ;
  dcterms:modified "2026-02-12T08:59:21.654769Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8042-1
  a curric:KeyLearningPoint ;
  rdfs:label """Poets can use a range of poetic devices to enhance the meaning or impact of their poems."""@en ;
  dcterms:modified "2026-02-12T08:59:21.655327Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8042-2
  a curric:KeyLearningPoint ;
  rdfs:label "Personification is describing a non-living thing as if it is a person."@en ;
  dcterms:modified "2026-02-12T08:59:21.655332Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8042-3
  a curric:KeyLearningPoint ;
  rdfs:label """Imagery is the use of language to create a mental picture or sensory experience for the reader or listener."""@en ;
  dcterms:modified "2026-02-12T08:59:21.655336Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8042-4
  a curric:KeyLearningPoint ;
  rdfs:label """Alliteration is when words that begin with the same sound are placed close together."""@en ;
  dcterms:modified "2026-02-12T08:59:21.655344Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1071-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Ecstatic' is an adjective which means blissful or perfectly happy."@en ;
  dcterms:modified "2026-02-12T08:59:21.655480Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1071-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Gleeful' is an adjective which means cheerful or merry."@en ;
  dcterms:modified "2026-02-12T08:59:21.655485Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1071-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Exhilarated' is an adjective which means excited or thrilled."@en ;
  dcterms:modified "2026-02-12T08:59:21.655492Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1071-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Light-hearted', 'overjoyed' and 'contented' are other rich vocabulary associated with happiness."""@en ;
  dcterms:modified "2026-02-12T08:59:21.655497Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1080-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Reek' is a verb which means stink or smell."@en ;
  dcterms:modified "2026-02-12T08:59:21.655501Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1080-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Stench' is a noun which means odour or stink."@en ;
  dcterms:modified "2026-02-12T08:59:21.655506Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1080-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Whiff', 'scent', 'fragrance' and 'odour' are other nouns related to smell."@en ;
  dcterms:modified "2026-02-12T08:59:21.655510Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6378-1
  a curric:KeyLearningPoint ;
  rdfs:label """Direct speech can be written in the form of speech first or speech second sentences."""@en ;
  dcterms:modified "2026-02-12T08:59:21.655515Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6378-2
  a curric:KeyLearningPoint ;
  rdfs:label "Speech first and speech second sentences are punctuated differently."@en ;
  dcterms:modified "2026-02-12T08:59:21.655522Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6378-3
  a curric:KeyLearningPoint ;
  rdfs:label """The reporting clause in a speech sentence explains who spoke and how they said it."""@en ;
  dcterms:modified "2026-02-12T08:59:21.655527Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6378-4
  a curric:KeyLearningPoint ;
  rdfs:label "Additional information can be added to the reporting clause for the reader."@en ;
  dcterms:modified "2026-02-12T08:59:21.655532Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6367-1
  a curric:KeyLearningPoint ;
  rdfs:label "Editing is a vital element of the writing process."@en ;
  dcterms:modified "2026-02-12T08:59:21.655893Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6367-2
  a curric:KeyLearningPoint ;
  rdfs:label "When editing, we must be selective about which parts of our writing to improve."@en ;
  dcterms:modified "2026-02-12T08:59:21.655898Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6367-3
  a curric:KeyLearningPoint ;
  rdfs:label """When editing, we can focus on punctuation, sentence structure, vocabulary and spelling."""@en ;
  dcterms:modified "2026-02-12T08:59:21.655907Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7938-1
  a curric:KeyLearningPoint ;
  rdfs:label "Reader identity is a reflection on who you are as a reader and why you read."@en ;
  dcterms:modified "2026-02-12T08:59:21.656013Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7938-2
  a curric:KeyLearningPoint ;
  rdfs:label "Reading is a very personal experience; it is unique to every reader."@en ;
  dcterms:modified "2026-02-12T08:59:21.656017Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7938-3
  a curric:KeyLearningPoint ;
  rdfs:label "Reading can take many forms; it does not have to be restricted to a book."@en ;
  dcterms:modified "2026-02-12T08:59:21.656022Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7938-4
  a curric:KeyLearningPoint ;
  rdfs:label """A 'Reading River' is a reflection of significant texts in someone's personal experience."""@en ;
  dcterms:modified "2026-02-12T08:59:21.656029Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6371-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the build-up is to introduce key characters and storylines that will grow throughout the plot."""@en ;
  dcterms:modified "2026-02-12T08:59:21.656061Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6371-2
  a curric:KeyLearningPoint ;
  rdfs:label """Writers can use figurative language, poetic devices and ambitious adjectives to engage the reader and create atmosphere."""@en ;
  dcterms:modified "2026-02-12T08:59:21.656066Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6371-3
  a curric:KeyLearningPoint ;
  rdfs:label "A compound adjective is two words joined using a hyphen to form one adjective."@en ;
  dcterms:modified "2026-02-12T08:59:21.656070Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6371-4
  a curric:KeyLearningPoint ;
  rdfs:label """Understanding characters' thoughts and feelings enables us to write in greater depth and bring characters to life."""@en ;
  dcterms:modified "2026-02-12T08:59:21.656075Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6365-1
  a curric:KeyLearningPoint ;
  rdfs:label "'The Highwayman' is an example of a narrative poem."@en ;
  dcterms:modified "2026-02-12T08:59:21.656135Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6365-2
  a curric:KeyLearningPoint ;
  rdfs:label "A narrative poem is a type of poem that tells a story."@en ;
  dcterms:modified "2026-02-12T08:59:21.656139Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6365-3
  a curric:KeyLearningPoint ;
  rdfs:label "'The Highwayman' was set in rural England during the 18th century."@en ;
  dcterms:modified "2026-02-12T08:59:21.656143Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6365-4
  a curric:KeyLearningPoint ;
  rdfs:label "Alfred Noyes is the poet who wrote ’The Highwayman’."@en ;
  dcterms:modified "2026-02-12T08:59:21.656148Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6365-5
  a curric:KeyLearningPoint ;
  rdfs:label "Highwaymen were robbers on horseback who attacked travellers."@en ;
  dcterms:modified "2026-02-12T08:59:21.656152Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1076-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Apprehensive' is an adjective which means feeling nervous or afraid."@en ;
  dcterms:modified "2026-02-12T08:59:21.656535Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1076-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Petrified' is an adjective which means feeling terrified; like being so frightened that you turn into stone."""@en ;
  dcterms:modified "2026-02-12T08:59:21.656540Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1076-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Anxious' is an adjective which means feeling worried or nervous; how you feel when you panic about a test at school."""@en ;
  dcterms:modified "2026-02-12T08:59:21.656545Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1076-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Distressed', 'exasperated' and 'flustered' are other rich vocabulary associated with feeling stressed or scared."""@en ;
  dcterms:modified "2026-02-12T08:59:21.656549Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7872-1
  a curric:KeyLearningPoint ;
  rdfs:label """A character's body language can give clues about what they are thinking or feeling."""@en ;
  dcterms:modified "2026-02-12T08:59:21.656554Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7872-2
  a curric:KeyLearningPoint ;
  rdfs:label """Body language is used in ‘Greenling’ to convey the characterisation of the Barleycorns and the Greenling."""@en ;
  dcterms:modified "2026-02-12T08:59:21.656558Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7872-3
  a curric:KeyLearningPoint ;
  rdfs:label """Understanding a character's motives helps us to understand the story and empathise with the characters."""@en ;
  dcterms:modified "2026-02-12T08:59:21.656563Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7872-4
  a curric:KeyLearningPoint ;
  rdfs:label "A reader’s own experiences can also support inferring a character’s motives."@en ;
  dcterms:modified "2026-02-12T08:59:21.656567Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1449-1
  a curric:KeyLearningPoint ;
  rdfs:label """A prefix is a letter or group of letters at the start of word which creates another word."""@en ;
  dcterms:modified "2026-02-12T08:59:21.656894Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1449-2
  a curric:KeyLearningPoint ;
  rdfs:label "The prefixes dis-, non- and un- mean 'not', mis- usually means 'wrongly'."@en ;
  dcterms:modified "2026-02-12T08:59:21.656898Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1449-3
  a curric:KeyLearningPoint ;
  rdfs:label "Colour blocking is a useful practice strategy."@en ;
  dcterms:modified "2026-02-12T08:59:21.656903Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1449-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum word: recent."@en ;
  dcterms:modified "2026-02-12T08:59:21.656910Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2729-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the resolution is to resolve a story, tying up its 'loose ends' and solving the characters' problems."""@en ;
  dcterms:modified "2026-02-12T08:59:21.656931Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2729-2
  a curric:KeyLearningPoint ;
  rdfs:label """When we plan, we log precise and ambitious vocabulary to help paint vivid pictures for our reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.656936Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2729-3
  a curric:KeyLearningPoint ;
  rdfs:label """Dialogue is the written conversation between two or more characters within a narrative and it moves the story forward."""@en ;
  dcterms:modified "2026-02-12T08:59:21.656940Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2729-4
  a curric:KeyLearningPoint ;
  rdfs:label "A plan is written in note-form, out of full sentences."@en ;
  dcterms:modified "2026-02-12T08:59:21.656945Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2729-5
  a curric:KeyLearningPoint ;
  rdfs:label "Some vocabulary choices are more precise than others."@en ;
  dcterms:modified "2026-02-12T08:59:21.656949Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7883-1
  a curric:KeyLearningPoint ;
  rdfs:label """Readers can form impressions of characters based on what they say, the actions they perform and their appearance."""@en ;
  dcterms:modified "2026-02-12T08:59:21.657087Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7883-2
  a curric:KeyLearningPoint ;
  rdfs:label "During the story, characters and their relationships change and evolve."@en ;
  dcterms:modified "2026-02-12T08:59:21.657092Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7883-3
  a curric:KeyLearningPoint ;
  rdfs:label """Making connections and recommendations can significantly broaden a reader's understanding of literature."""@en ;
  dcterms:modified "2026-02-12T08:59:21.657097Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7656-1
  a curric:KeyLearningPoint ;
  rdfs:label "Maori people were the first people to settle in New Zealand."@en ;
  dcterms:modified "2026-02-12T08:59:21.657568Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7656-2
  a curric:KeyLearningPoint ;
  rdfs:label "Maori culture and tradition play a significant role in national identity."@en ;
  dcterms:modified "2026-02-12T08:59:21.657572Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7656-3
  a curric:KeyLearningPoint ;
  rdfs:label "Maori people have a strong spiritual connection to the land and environment."@en ;
  dcterms:modified "2026-02-12T08:59:21.657577Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7656-4
  a curric:KeyLearningPoint ;
  rdfs:label "‘Whale Rider’ is a novel by Witi Ihimaera and it has been adapted into a film."@en ;
  dcterms:modified "2026-02-12T08:59:21.657581Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7656-5
  a curric:KeyLearningPoint ;
  rdfs:label """‘Whale Rider’ is a powerful story of tradition and it has themes of courage and breaking down barriers."""@en ;
  dcterms:modified "2026-02-12T08:59:21.657586Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3445-1
  a curric:KeyLearningPoint ;
  rdfs:label "A sentence composed of one main clause is a simple sentence."@en ;
  dcterms:modified "2026-02-12T08:59:21.657720Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3445-2
  a curric:KeyLearningPoint ;
  rdfs:label """A sentence composed of at least two main clauses joined by a co-ordinating conjunction is a compound sentence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.657725Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3445-3
  a curric:KeyLearningPoint ;
  rdfs:label """There are three complex sentence structures: the adverbial complex, the relative complex and the non-finite complex."""@en ;
  dcterms:modified "2026-02-12T08:59:21.657729Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3445-4
  a curric:KeyLearningPoint ;
  rdfs:label """Different sentence types allow writers to write cohesively across a paragraph and a whole text."""@en ;
  dcterms:modified "2026-02-12T08:59:21.657734Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3445-5
  a curric:KeyLearningPoint ;
  rdfs:label "Text cohesion ensures text maintains the interest of the reader."@en ;
  dcterms:modified "2026-02-12T08:59:21.657738Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8049-1
  a curric:KeyLearningPoint ;
  rdfs:label """A tanka is a traditional Japanese form of poetry that originated more than 1,300 years ago."""@en ;
  dcterms:modified "2026-02-12T08:59:21.657743Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8049-2
  a curric:KeyLearningPoint ;
  rdfs:label """Tankas consist of five lines with a syllable pattern of 5-7-5-7-7, totalling 31 syllables."""@en ;
  dcterms:modified "2026-02-12T08:59:21.657747Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8049-3
  a curric:KeyLearningPoint ;
  rdfs:label "Tankas often explore themes of nature, emotions and the passage of time."@en ;
  dcterms:modified "2026-02-12T08:59:21.657751Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8049-4
  a curric:KeyLearningPoint ;
  rdfs:label "We can make specific language choices to describe the intensity of the heat."@en ;
  dcterms:modified "2026-02-12T08:59:21.657756Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8049-5
  a curric:KeyLearningPoint ;
  rdfs:label """We can use vocabulary in different ways, depending on its position in a sentence, if it is a verb, adjective or noun."""@en ;
  dcterms:modified "2026-02-12T08:59:21.657760Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1114-1
  a curric:KeyLearningPoint ;
  rdfs:label "Billowing is an adjective which means swelling or expanding."@en ;
  dcterms:modified "2026-02-12T08:59:21.657765Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1114-2
  a curric:KeyLearningPoint ;
  rdfs:label "Dense is an adjective which means thick, solid or heavy."@en ;
  dcterms:modified "2026-02-12T08:59:21.657770Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1114-3
  a curric:KeyLearningPoint ;
  rdfs:label "Hazy is an adjective which means cloudy or misty."@en ;
  dcterms:modified "2026-02-12T08:59:21.657774Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1078-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Bland' is an adjective which means plain and flavourless."@en ;
  dcterms:modified "2026-02-12T08:59:21.657779Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1078-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Savoury' is an adjective which means salty and spicy."@en ;
  dcterms:modified "2026-02-12T08:59:21.657784Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1078-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Tangy' is an adjective which means flavourful and sharp."@en ;
  dcterms:modified "2026-02-12T08:59:21.657820Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1078-4
  a curric:KeyLearningPoint ;
  rdfs:label "'Tart', 'peppery' and 'sugary' are other adjectives related to flavour."@en ;
  dcterms:modified "2026-02-12T08:59:21.657826Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5849-1
  a curric:KeyLearningPoint ;
  rdfs:label "Macbeth is a highly conflicted character."@en ;
  dcterms:modified "2026-02-12T08:59:21.657927Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5849-2
  a curric:KeyLearningPoint ;
  rdfs:label "A soliloquy occurs when a character voices their thoughts and feelings aloud."@en ;
  dcterms:modified "2026-02-12T08:59:21.657932Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5849-3
  a curric:KeyLearningPoint ;
  rdfs:label "Soliloquies are written from the first person perspective."@en ;
  dcterms:modified "2026-02-12T08:59:21.657937Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5849-4
  a curric:KeyLearningPoint ;
  rdfs:label "The opening of this soliloquy outlines Macbeth's dilemma."@en ;
  dcterms:modified "2026-02-12T08:59:21.657941Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5849-5
  a curric:KeyLearningPoint ;
  rdfs:label """The character's confusion can be illustrated through the use of rhetorical questions and exclamations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.657946Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6521-1
  a curric:KeyLearningPoint ;
  rdfs:label "Writing is most successful when structure, content and vocabulary is planned."@en ;
  dcterms:modified "2026-02-12T08:59:21.657950Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6521-2
  a curric:KeyLearningPoint ;
  rdfs:label "Information in this section should be specific and detailed."@en ;
  dcterms:modified "2026-02-12T08:59:21.657955Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6521-3
  a curric:KeyLearningPoint ;
  rdfs:label "Cohesion, making use of research and a formal tone are appropriate in an essay."@en ;
  dcterms:modified "2026-02-12T08:59:21.657959Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6521-4
  a curric:KeyLearningPoint ;
  rdfs:label """An essay can use a bank of research, evidence, statistics and quotes to inform the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.657964Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6270-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘Mirror’ is a dual narrative text: two stories that are made to be read side-by-side."""@en ;
  dcterms:modified "2026-02-12T08:59:21.658489Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6270-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Mirror' can be considered a wordless or silent text."@en ;
  dcterms:modified "2026-02-12T08:59:21.658494Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6270-3
  a curric:KeyLearningPoint ;
  rdfs:label "Different readers may interpret a text in different ways."@en ;
  dcterms:modified "2026-02-12T08:59:21.658498Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6270-4
  a curric:KeyLearningPoint ;
  rdfs:label "Jeannie Baker uses collage artwork to tell the story."@en ;
  dcterms:modified "2026-02-12T08:59:21.658503Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6270-5
  a curric:KeyLearningPoint ;
  rdfs:label """Predictions can be based on what readers have explored within a text or personal experience."""@en ;
  dcterms:modified "2026-02-12T08:59:21.658508Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5666-1
  a curric:KeyLearningPoint ;
  rdfs:label "Beowulf becomes king of Geatland and he reigns for 50 years."@en ;
  dcterms:modified "2026-02-12T08:59:21.658563Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5666-2
  a curric:KeyLearningPoint ;
  rdfs:label """A dragon is provoked to attack the Geats and Beowulf wants to fight it; his young cousin Wiglaf objects."""@en ;
  dcterms:modified "2026-02-12T08:59:21.658568Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5666-3
  a curric:KeyLearningPoint ;
  rdfs:label """Beowulf's sword is useless against the dragon and it bites him; he is able to slay the dragon, but he is wounded."""@en ;
  dcterms:modified "2026-02-12T08:59:21.658572Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5666-4
  a curric:KeyLearningPoint ;
  rdfs:label """As he dies, Beowulf asks Wiglaf to ensure that a barrow is built for him so that his memory lives on."""@en ;
  dcterms:modified "2026-02-12T08:59:21.658577Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5666-5
  a curric:KeyLearningPoint ;
  rdfs:label "We can link stories like 'Beowulf' to themes or big ideas that they raise."@en ;
  dcterms:modified "2026-02-12T08:59:21.658581Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7644-1
  a curric:KeyLearningPoint ;
  rdfs:label "It is crucial to communicate the unique selling point of a product."@en ;
  dcterms:modified "2026-02-12T08:59:21.658914Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7644-2
  a curric:KeyLearningPoint ;
  rdfs:label """A persuasive advert should explain the benefits of a product to the reader, e.g. health benefits."""@en ;
  dcterms:modified "2026-02-12T08:59:21.658918Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7644-3
  a curric:KeyLearningPoint ;
  rdfs:label """For a healthy food product, it is crucial to detail ingredients, nutrients and health benefits."""@en ;
  dcterms:modified "2026-02-12T08:59:21.658923Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7644-4
  a curric:KeyLearningPoint ;
  rdfs:label """A formal fronted adverbial can be used to contrast information within a main clause."""@en ;
  dcterms:modified "2026-02-12T08:59:21.658928Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1129-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Self-conscious' is an adjective which means overly aware of yourself."@en ;
  dcterms:modified "2026-02-12T08:59:21.658955Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1129-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Sheepish' is an adjective which means shy, ashamed or uncomfortable."@en ;
  dcterms:modified "2026-02-12T08:59:21.658960Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1129-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Wary' is an adjective which means careful or cautious."@en ;
  dcterms:modified "2026-02-12T08:59:21.658964Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6762-1
  a curric:KeyLearningPoint ;
  rdfs:label "Writing is most successful when structure, content and vocabulary is planned."@en ;
  dcterms:modified "2026-02-12T08:59:21.659302Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6762-2
  a curric:KeyLearningPoint ;
  rdfs:label "Information in this section should be specific and detailed."@en ;
  dcterms:modified "2026-02-12T08:59:21.659307Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6762-3
  a curric:KeyLearningPoint ;
  rdfs:label "Cohesion, making use of research and a formal tone are appropriate in an essay."@en ;
  dcterms:modified "2026-02-12T08:59:21.659311Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6762-4
  a curric:KeyLearningPoint ;
  rdfs:label """An essay can use a bank of research, evidence, statistics and quotes to inform the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.659316Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6376-1
  a curric:KeyLearningPoint ;
  rdfs:label """When describing a character, we can consider their actions, appearance and feelings."""@en ;
  dcterms:modified "2026-02-12T08:59:21.659354Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6376-2
  a curric:KeyLearningPoint ;
  rdfs:label """Using show-not-tell is a powerful way of helping the reader engage and identify with a character."""@en ;
  dcterms:modified "2026-02-12T08:59:21.659361Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6376-3
  a curric:KeyLearningPoint ;
  rdfs:label "When planning, we record our ideas using notes and bullet points."@en ;
  dcterms:modified "2026-02-12T08:59:21.659366Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6376-4
  a curric:KeyLearningPoint ;
  rdfs:label """Success criteria act as a useful guide to help us remember which skills to include in our writing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.659370Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1122-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Bloodshot' is an adjective which means red and sore."@en ;
  dcterms:modified "2026-02-12T08:59:21.659616Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1122-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Bulging' is an adjective which means swollen or sticking out."@en ;
  dcterms:modified "2026-02-12T08:59:21.659625Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1122-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Expressive' is an adjective which means meaningful or revealing."@en ;
  dcterms:modified "2026-02-12T08:59:21.659630Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1118-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Colossal' is an adjective which means massive or gigantic."@en ;
  dcterms:modified "2026-02-12T08:59:21.659635Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1118-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Robust' is an adjective which means strong and tough."@en ;
  dcterms:modified "2026-02-12T08:59:21.659639Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6373-1
  a curric:KeyLearningPoint ;
  rdfs:label """Alred Noyes uses figurative language to provide imagery and describe events in stanzas five and six."""@en ;
  dcterms:modified "2026-02-12T08:59:21.659683Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6373-2
  a curric:KeyLearningPoint ;
  rdfs:label "Texts written a long time ago may contain unfamiliar vocabulary."@en ;
  dcterms:modified "2026-02-12T08:59:21.659687Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6373-3
  a curric:KeyLearningPoint ;
  rdfs:label """Understanding the author's vocabulary choices is essential to understanding the text fully."""@en ;
  dcterms:modified "2026-02-12T08:59:21.659692Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6373-4
  a curric:KeyLearningPoint ;
  rdfs:label """Analysing a text enables readers to understand the events, characters and their actions in greater depth."""@en ;
  dcterms:modified "2026-02-12T08:59:21.659696Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4823-1
  a curric:KeyLearningPoint ;
