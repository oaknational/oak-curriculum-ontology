oakcurric:keylearningpoint-lesson-1334-2
  a curric:KeyLearningPoint ;
  rdfs:label """The spelling -le often forms letter strings: -cle, -dle, -able, -ckle, -ible and -ple."""@en ;
  dcterms:modified "2026-02-12T08:59:21.743254Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1334-3
  a curric:KeyLearningPoint ;
  rdfs:label """The spelling -el is one of the least common spellings out of the suffixes -le, -el, -al and -il."""@en ;
  dcterms:modified "2026-02-12T08:59:21.743259Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1334-4
  a curric:KeyLearningPoint ;
  rdfs:label """The spelling -il is the least common spelling out of the suffixes -le, -el, -al and -il."""@en ;
  dcterms:modified "2026-02-12T08:59:21.743263Z"^^xsd:dateTime .

