  a curric:KeyLearningPoint ;
  rdfs:label """The layout of a text helps to organise information logically, allowing the reader to navigate through a report easily."""@en ;
  dcterms:modified "2026-02-12T08:59:21.613146Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1323-3
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to use neat, joined handwriting when publishing a non-chronological report."""@en ;
  dcterms:modified "2026-02-12T08:59:21.613156Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1323-4
  a curric:KeyLearningPoint ;
  rdfs:label """A published non-chronological report should be visually and linguistically appealing to the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.613164Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6698-1
  a curric:KeyLearningPoint ;
  rdfs:label "Direct speech between two characters in a narrative forms a dialogue."@en ;
  dcterms:modified "2026-02-12T08:59:21.613171Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6698-2
  a curric:KeyLearningPoint ;
  rdfs:label """Inverted commas are used to demarcate speech and a piece of punctuation separates speech from the reporting clause."""@en ;
  dcterms:modified "2026-02-12T08:59:21.613222Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6698-3
  a curric:KeyLearningPoint ;
  rdfs:label """Precise and ambitious vocabulary shows and tells the reader what happened and how characters are feeling."""@en ;
  dcterms:modified "2026-02-12T08:59:21.613231Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6698-4
  a curric:KeyLearningPoint ;
  rdfs:label "Using a range of sentence types improves text flow for the reader."@en ;
  dcterms:modified "2026-02-12T08:59:21.613238Z"^^xsd:dateTime .

