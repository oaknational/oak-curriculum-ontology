  a curric:PupilLessonOutcome ;
  rdfs:label "I can identify and engage with the key themes in ‘Shackleton's Journey’."@en ;
  dcterms:modified "2026-02-12T08:59:24.444604Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-7864
  a curric:PupilLessonOutcome ;
  rdfs:label "I can explore the myth, ‘The Beginning of the World’."@en ;
  dcterms:modified "2026-02-12T08:59:24.444796Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-7832
  a curric:PupilLessonOutcome ;
  rdfs:label "I can discuss the main ideas of ‘Swallow’s Kiss’."@en ;
  dcterms:modified "2026-02-12T08:59:24.444865Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-8140
  a curric:PupilLessonOutcome ;
  rdfs:label "I can publish a diary entry based on ‘The Journey’."@en ;
  dcterms:modified "2026-02-12T08:59:24.444898Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-8139
  a curric:PupilLessonOutcome ;
  rdfs:label "I can understand the key themes and the characters’ emotions in ‘The Journey’."@en ;
  dcterms:modified "2026-02-12T08:59:24.444934Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-6327
  a curric:PupilLessonOutcome ;
  rdfs:label "I can use evidence in the text to support reasoning."@en ;
  dcterms:modified "2026-02-12T08:59:24.444939Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-5449
  a curric:PupilLessonOutcome ;
  rdfs:label "I can explain what a legend is."@en ;
  dcterms:modified "2026-02-12T08:59:24.445025Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-8133
  a curric:PupilLessonOutcome ;
  rdfs:label "I can identify and analyse layout and linguistic features of a diary entry."@en ;
  dcterms:modified "2026-02-12T08:59:24.445029Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-5452
  a curric:PupilLessonOutcome ;
  rdfs:label "I can understand and describe the character of Mulan."@en ;
  dcterms:modified "2026-02-12T08:59:24.445123Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-5451
  a curric:PupilLessonOutcome ;
  rdfs:label "I can have rich discussions to infer meaning from 'Mulan'."@en ;
