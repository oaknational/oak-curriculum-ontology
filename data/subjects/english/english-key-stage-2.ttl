  dcterms:modified "2026-06-07T15:29:23.367965Z"^^xsd:dateTime .

oakcurric:priorknowledge-89-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Understanding word class helps us when we are writing."@en ;
  dcterms:modified "2026-06-07T15:29:23.367970Z"^^xsd:dateTime .

oakcurric:priorknowledge-89-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "An apostrophe is an important piece of punctuation with more than one purpose."@en ;
  dcterms:modified "2026-06-07T15:29:23.367979Z"^^xsd:dateTime .

oakcurric:priorknowledge-89-5
  a curric:PriorKnowledgeRequirement ;
