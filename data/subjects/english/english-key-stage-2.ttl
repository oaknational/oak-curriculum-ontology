oakcurric:keylearningpoint-lesson-5631-4
  a curric:KeyLearningPoint ;
  rdfs:label """Present tense writing at the end of a diary entry conveys current reflections and feelings."""@en ;
  dcterms:modified "2026-02-12T08:59:21.690992Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5631-5
  a curric:KeyLearningPoint ;
