oakcurric:keylearningpoint-lesson-6695-2
  a curric:KeyLearningPoint ;
  rdfs:label """Precise and ambitious vocabulary shows and tells the reader what happened on Lila’s quest and how she was feeling."""@en ;
  dcterms:modified "2026-02-12T08:59:21.613926Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6695-3
  a curric:KeyLearningPoint ;
  rdfs:label """Using a range of sentence types improves text flow for the reader and conveys key moments of suspense in the climax."""@en ;
  dcterms:modified "2026-02-12T08:59:21.613932Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6695-4
  a curric:KeyLearningPoint ;
  rdfs:label """An adverbial complex sentence is a sentence formed of a main clause and an adverbial subordinate clause."""@en ;
  dcterms:modified "2026-02-12T08:59:21.613939Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6695-5
  a curric:KeyLearningPoint ;
  rdfs:label "Fronted adverbials of time and manner support text flow and help build suspense."@en ;
  dcterms:modified "2026-02-12T08:59:21.613946Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7856-1
  a curric:KeyLearningPoint ;
  rdfs:label "El Deafo is a graphic novel memoir based on author Cece Bell's childhood."@en ;
  dcterms:modified "2026-02-12T08:59:21.614057Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7856-2
  a curric:KeyLearningPoint ;
  rdfs:label """At the age of four, in 1974, Cece is diagnosed as deaf, following a bout of meningitis."""@en ;
  dcterms:modified "2026-02-12T08:59:21.614068Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7856-3
  a curric:KeyLearningPoint ;
  rdfs:label "The narrative follows her journey using a hearing aid and starting school."@en ;
  dcterms:modified "2026-02-12T08:59:21.614075Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7856-4
  a curric:KeyLearningPoint ;
  rdfs:label """Graphic novels have many unique elements which allow readers to make meaning from both words and image."""@en ;
  dcterms:modified "2026-02-12T08:59:21.614082Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7856-5
  a curric:KeyLearningPoint ;
  rdfs:label """People may use Deaf and deaf terms differently based on their personal preferences and experiences."""@en ;
  dcterms:modified "2026-02-12T08:59:21.614088Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8478-1
  a curric:KeyLearningPoint ;
  rdfs:label """Lila’s quest intensifies in the build-up in Chapter 4 of ‘The Firework-Maker’s Daughter’."""@en ;
  dcterms:modified "2026-02-12T08:59:21.614095Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8478-2
  a curric:KeyLearningPoint ;
  rdfs:label "Suspense is a key feature in the build-up of a story."@en ;
  dcterms:modified "2026-02-12T08:59:21.614102Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8478-3
  a curric:KeyLearningPoint ;
  rdfs:label """Moments of suspense keep the reader engaged and wanting to find out what happens next."""@en ;
  dcterms:modified "2026-02-12T08:59:21.614109Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8478-4
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to focus on moments of suspense when summarising the build-up of a story."""@en ;
  dcterms:modified "2026-02-12T08:59:21.614116Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8478-5
  a curric:KeyLearningPoint ;
  rdfs:label """Lila faces many setbacks on her journey which she has to show resilience and determination to overcome."""@en ;
  dcterms:modified "2026-02-12T08:59:21.614123Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7345-1
  a curric:KeyLearningPoint ;
  rdfs:label "Charles Dickens lived during the Victorian era."@en ;
  dcterms:modified "2026-02-12T08:59:21.614311Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7345-2
  a curric:KeyLearningPoint ;
  rdfs:label """He was a very popular author who often represented the contrast between the rich and the poor."""@en ;
  dcterms:modified "2026-02-12T08:59:21.614317Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7345-3
  a curric:KeyLearningPoint ;
  rdfs:label "He wrote ‘A Christmas Carol’ in 1843."@en ;
  dcterms:modified "2026-02-12T08:59:21.614328Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7345-4
  a curric:KeyLearningPoint ;
  rdfs:label "It is set on the lively, bustling streets of Victorian London."@en ;
  dcterms:modified "2026-02-12T08:59:21.614335Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7345-5
  a curric:KeyLearningPoint ;
  rdfs:label """‘A Christmas Carol’ features a character called Scrooge. He is unkind and he doesn’t like Christmas."""@en ;
  dcterms:modified "2026-02-12T08:59:21.614342Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6689-1
  a curric:KeyLearningPoint ;
  rdfs:label """Lila faces physical and emotional challenges that the reader does not know if she will overcome."""@en ;
  dcterms:modified "2026-02-12T08:59:21.614465Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6689-2
  a curric:KeyLearningPoint ;
  rdfs:label """Lila's emotional journey is a key part of building suspense in the build-up of the story."""@en ;
  dcterms:modified "2026-02-12T08:59:21.614472Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6689-3
  a curric:KeyLearningPoint ;
  rdfs:label """Philip Pullman conveys Lila's changing emotions both explicitly and using 'show and tell'."""@en ;
  dcterms:modified "2026-02-12T08:59:21.614478Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6689-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Show and tell' is a narrative technique that conveys a character's feelings through sensory details, actions &thoughts."""@en ;
  dcterms:modified "2026-02-12T08:59:21.614485Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6689-5
  a curric:KeyLearningPoint ;
  rdfs:label """Empathising with a character's emotions can help us develop our own examples of 'show and tell'."""@en ;
  dcterms:modified "2026-02-12T08:59:21.614492Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6697-1
  a curric:KeyLearningPoint ;
  rdfs:label "Direct speech is the term used for a person speaking out loud in a text ."@en ;
  dcterms:modified "2026-02-12T08:59:21.614572Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6697-2
  a curric:KeyLearningPoint ;
  rdfs:label """It is crucial to consider character perspective when developing ideas for direct speech."""@en ;
  dcterms:modified "2026-02-12T08:59:21.614579Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6697-3
  a curric:KeyLearningPoint ;
  rdfs:label "Direct speech between two characters forms a dialogue."@en ;
  dcterms:modified "2026-02-12T08:59:21.614585Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6697-4
  a curric:KeyLearningPoint ;
  rdfs:label """Inverted commas are used to demarcate speech and a piece of punctuation separates speech from the reporting clause."""@en ;
  dcterms:modified "2026-02-12T08:59:21.614592Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6697-5
  a curric:KeyLearningPoint ;
  rdfs:label """A range of synonyms for ‘said’ and use of adverbs can offer detail about how a character spoke and felt."""@en ;
  dcterms:modified "2026-02-12T08:59:21.614599Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7825-1
  a curric:KeyLearningPoint ;
  rdfs:label "Marcy and the Riddle of the Sphinx is a modern myth."@en ;
  dcterms:modified "2026-02-12T08:59:21.614731Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7825-2
  a curric:KeyLearningPoint ;
  rdfs:label "A modern myth incorporates elements from traditional myths."@en ;
  dcterms:modified "2026-02-12T08:59:21.614738Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7825-3
  a curric:KeyLearningPoint ;
  rdfs:label """Some features of a modern myth are mythical creatures, a quest, magical objects and gods and godesses."""@en ;
  dcterms:modified "2026-02-12T08:59:21.614745Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7825-4
  a curric:KeyLearningPoint ;
  rdfs:label "Brownstone's Mythical Collection is a collection of modern myths."@en ;
  dcterms:modified "2026-02-12T08:59:21.614752Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7825-5
  a curric:KeyLearningPoint ;
  rdfs:label "Marcy embarks on an adventure and has to overcome a challenge."@en ;
  dcterms:modified "2026-02-12T08:59:21.614758Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7860-1
  a curric:KeyLearningPoint ;
  rdfs:label "Reading between the lines to search for clues can help to infer meaning"@en ;
  dcterms:modified "2026-02-12T08:59:21.614954Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7860-2
  a curric:KeyLearningPoint ;
  rdfs:label "Evidence from the text helps us to justify our inferences"@en ;
  dcterms:modified "2026-02-12T08:59:21.614960Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7860-3
  a curric:KeyLearningPoint ;
  rdfs:label "Skimming and scanning helps to retrieve and record information from a text"@en ;
  dcterms:modified "2026-02-12T08:59:21.614971Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7860-4
  a curric:KeyLearningPoint ;
  rdfs:label """Role on the wall is a reading activity that helps readers develop their understanding of a character"""@en ;
  dcterms:modified "2026-02-12T08:59:21.614978Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8024-1
  a curric:KeyLearningPoint ;
  rdfs:label "Minuscule, tiny, minute and diminutive are words to describe small objects."@en ;
  dcterms:modified "2026-02-12T08:59:21.615801Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8024-2
  a curric:KeyLearningPoint ;
  rdfs:label "The subject of a poem is what the poem is about."@en ;
  dcterms:modified "2026-02-12T08:59:21.615807Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8024-3
  a curric:KeyLearningPoint ;
  rdfs:label """Poets must decide the tone and emotional impact of their poem before they start generating language."""@en ;
  dcterms:modified "2026-02-12T08:59:21.615817Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8024-4
  a curric:KeyLearningPoint ;
  rdfs:label """Poets should decide the subject of the poem; something that inspires poetry and will be interesting to write about."""@en ;
  dcterms:modified "2026-02-12T08:59:21.615824Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7861-1
  a curric:KeyLearningPoint ;
  rdfs:label "Arthur is chosen for the mission by default"@en ;
  dcterms:modified "2026-02-12T08:59:21.615831Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7861-2
  a curric:KeyLearningPoint ;
  rdfs:label """A hero is a person who displays exceptional courage, bravery, selflessness in the face of adversity"""@en ;
  dcterms:modified "2026-02-12T08:59:21.615837Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7861-3
  a curric:KeyLearningPoint ;
  rdfs:label "The townspeople think he is unlikely to succeed"@en ;
  dcterms:modified "2026-02-12T08:59:21.615844Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7861-4
  a curric:KeyLearningPoint ;
  rdfs:label "Arthur proves that their views are incorrect and shows many qualities of a hero"@en ;
  dcterms:modified "2026-02-12T08:59:21.615851Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7862-1
  a curric:KeyLearningPoint ;
  rdfs:label """The themes of 'Arthur and the Golden Rope' include resilience, heroism, collaboration and courage."""@en ;
  dcterms:modified "2026-02-12T08:59:21.616050Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7862-2
  a curric:KeyLearningPoint ;
  rdfs:label "A theme is a big idea, topic or message that recurs within a story."@en ;
  dcterms:modified "2026-02-12T08:59:21.616056Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7862-3
  a curric:KeyLearningPoint ;
  rdfs:label "Texts often have a theme, or big idea, which is repeated through the story."@en ;
  dcterms:modified "2026-02-12T08:59:21.616066Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7862-4
  a curric:KeyLearningPoint ;
  rdfs:label "Readers can interpret their own big idea or message from a narrative."@en ;
  dcterms:modified "2026-02-12T08:59:21.616073Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7862-5
  a curric:KeyLearningPoint ;
  rdfs:label "Different readers may interpret a text in different ways."@en ;
  dcterms:modified "2026-02-12T08:59:21.616079Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5692-1
  a curric:KeyLearningPoint ;
  rdfs:label "'The Man on the Moon’ is a short film about a man who lives on the moon."@en ;
  dcterms:modified "2026-02-12T08:59:21.616616Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5692-2
  a curric:KeyLearningPoint ;
  rdfs:label """Visual literacy writing units use short films or moving picture as the stimulus for writing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.616622Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5692-3
  a curric:KeyLearningPoint ;
  rdfs:label "Imagination must be used to picture a man living on the moon."@en ;
  dcterms:modified "2026-02-12T08:59:21.616632Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5692-4
  a curric:KeyLearningPoint ;
  rdfs:label """Pupils will have different responses to the same clip and these should be discussed."""@en ;
  dcterms:modified "2026-02-12T08:59:21.616639Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5692-5
  a curric:KeyLearningPoint ;
  rdfs:label """Hot-seating is a drama technique that helps pupils understand and empathise with fictional characters."""@en ;
  dcterms:modified "2026-02-12T08:59:21.616646Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7859-1
  a curric:KeyLearningPoint ;
  rdfs:label "Arthur is the protagonist."@en ;
  dcterms:modified "2026-02-12T08:59:21.616887Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7859-2
  a curric:KeyLearningPoint ;
  rdfs:label "Arthur does not exhibit typical character traits of a hero."@en ;
  dcterms:modified "2026-02-12T08:59:21.616894Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7859-3
  a curric:KeyLearningPoint ;
  rdfs:label "The villagers in Arthur’s hometown do not respond well to Arthur."@en ;
  dcterms:modified "2026-02-12T08:59:21.616900Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7859-4
  a curric:KeyLearningPoint ;
  rdfs:label """A feature of a modern myth is that they often feature gods and goddesses with extraordinary powers and abilities."""@en ;
  dcterms:modified "2026-02-12T08:59:21.616907Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7859-5
  a curric:KeyLearningPoint ;
  rdfs:label """'Arthur and the Golden Rope' has connections to Norse Mythology. Norse gods & goddesses are characters within the text."""@en ;
  dcterms:modified "2026-02-12T08:59:21.616913Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6355-1
  a curric:KeyLearningPoint ;
  rdfs:label """Little Red Riding Hood is a traditional tale which has been adapted and retold in different ways."""@en ;
  dcterms:modified "2026-02-12T08:59:21.617121Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6355-2
  a curric:KeyLearningPoint ;
  rdfs:label "Journalistic reports provide information about current events and news."@en ;
  dcterms:modified "2026-02-12T08:59:21.617128Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6355-3
  a curric:KeyLearningPoint ;
  rdfs:label """A newsworthy event is something that is interesting or important enough to warrant reporting to the public."""@en ;
  dcterms:modified "2026-02-12T08:59:21.617134Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6355-4
  a curric:KeyLearningPoint ;
  rdfs:label "The wolf's actions would be considered a crime and newsworthy."@en ;
  dcterms:modified "2026-02-12T08:59:21.617141Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6355-5
  a curric:KeyLearningPoint ;
  rdfs:label """The wolf would be considered the perpetrator and the grandmother and Little Red Riding Hood would be the victims."""@en ;
  dcterms:modified "2026-02-12T08:59:21.617147Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2715-1
  a curric:KeyLearningPoint ;
  rdfs:label """An explanation text is a non-fiction text providing information about how or why something works."""@en ;
  dcterms:modified "2026-02-12T08:59:21.618101Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2715-2
  a curric:KeyLearningPoint ;
  rdfs:label """The structure of an explanation text is an introduction, a sequence of paragraphs in chronological order and a closing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.618110Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2715-3
  a curric:KeyLearningPoint ;
  rdfs:label """Vocabulary used in an explanation text is subject-specific, factual and the tone is usually formal."""@en ;
  dcterms:modified "2026-02-12T08:59:21.618117Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2715-4
  a curric:KeyLearningPoint ;
  rdfs:label "Conjunctions ensure cohesion within sentences and paragraphs."@en ;
  dcterms:modified "2026-02-12T08:59:21.618123Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2715-5
  a curric:KeyLearningPoint ;
  rdfs:label "Explanation texts are written in the present tense."@en ;
  dcterms:modified "2026-02-12T08:59:21.618129Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5702-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of a resolution is to resolve the story and give the reader a chance to reflect."""@en ;
  dcterms:modified "2026-02-12T08:59:21.618167Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5702-2
  a curric:KeyLearningPoint ;
  rdfs:label "Saying sentences aloud before they are written helps to check for sense."@en ;
  dcterms:modified "2026-02-12T08:59:21.618173Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5702-3
  a curric:KeyLearningPoint ;
  rdfs:label """Using the full range of sentence types (simple, compound and complex) improves text flow for the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.618179Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5702-4
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials of time, place and manner describe the action in the main clause in further detail."""@en ;
  dcterms:modified "2026-02-12T08:59:21.618185Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5702-5
  a curric:KeyLearningPoint ;
  rdfs:label "The narrative is written in the past tense."@en ;
  dcterms:modified "2026-02-12T08:59:21.618191Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2717-1
  a curric:KeyLearningPoint ;
  rdfs:label """The main paragraphs in an explanation text tell the reader how the process of digestion is carried out."""@en ;
  dcterms:modified "2026-02-12T08:59:21.618298Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2717-2
  a curric:KeyLearningPoint ;
  rdfs:label """Subject-specific, scientific vocabulary ensures the reader learns accurate information."""@en ;
  dcterms:modified "2026-02-12T08:59:21.618304Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2717-3
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials of order and place organise the paragraphs in a clear, chronological way."""@en ;
  dcterms:modified "2026-02-12T08:59:21.618310Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2717-4
  a curric:KeyLearningPoint ;
  rdfs:label "Subordinating conjunctions are used to begin an adverbial clause."@en ;
  dcterms:modified "2026-02-12T08:59:21.618316Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2717-5
  a curric:KeyLearningPoint ;
  rdfs:label """An adverbial clause can be joined with a main clause to form an adverbial complex sentence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.618322Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5701-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the resolution is to resolve the story and give readers a chance to reflect."""@en ;
  dcterms:modified "2026-02-12T08:59:21.618526Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5701-2
  a curric:KeyLearningPoint ;
  rdfs:label "Precise and ambitious vocabulary is logged on a plan for future use."@en ;
  dcterms:modified "2026-02-12T08:59:21.618532Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5701-3
  a curric:KeyLearningPoint ;
  rdfs:label """Notes should not be written in full sentences and bullet points can be used to make notes clear."""@en ;
  dcterms:modified "2026-02-12T08:59:21.618538Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5701-4
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials of time, place and manner indicate when, where and how an action takes place."""@en ;
  dcterms:modified "2026-02-12T08:59:21.618544Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7858-1
  a curric:KeyLearningPoint ;
  rdfs:label "Arthur and the Golden Rope is a modern myth."@en ;
  dcterms:modified "2026-02-12T08:59:21.618574Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7858-2
  a curric:KeyLearningPoint ;
  rdfs:label "A modern myth incorporates elements from traditional myths."@en ;
  dcterms:modified "2026-02-12T08:59:21.618580Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7858-3
  a curric:KeyLearningPoint ;
  rdfs:label """Some features of a modern myth are mythical creatures, a quest, magical objects and gods and godesses."""@en ;
  dcterms:modified "2026-02-12T08:59:21.618586Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7858-4
  a curric:KeyLearningPoint ;
  rdfs:label "Brownstone's Mythical Collection is a collection of modern myths."@en ;
  dcterms:modified "2026-02-12T08:59:21.618592Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8038-1
  a curric:KeyLearningPoint ;
  rdfs:label """Poems can be published with illustrations or art work to help the reader engage with the poetry further."""@en ;
  dcterms:modified "2026-02-12T08:59:21.618764Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8038-2
