    oakcurric:thread-developing-fiction-writing ,
    oakcurric:thread-nineteenth-century-literature .

oakcurric:unit-134
  a curric:Unit ;
  rdfs:label "Suffixes, etymology and homophones"@en ;
  curric:slug "suffixes-etymology-and-homophones" ;
  rdfs:comment """In this unit, pupils learn spelling and grammar conventions associated with more
  suffixes like -ic, -ary and -ery. Pupils learn how the spelling of a word can relate to
  its etymological origin and its meaning. They also complete further investigations of
  compound words."""@en ;
  curric:whyThisWhyNow """This unit uses and builds on pupils' knowledge of spelling and grammar
  conventions associated with noun and adjective suffixes like -ity, -ness, -tion, -sion,
  -ssion, -cian, -cial and -tial learnt in the Year 4 unit 'Year 4: Noun and adjective
  suffixes'. Here, pupils learn more suffixes like -ic, -ary and -ery, reviewing how the
  addition of a suffix can affect the grammar of a word, as well as learning how the spelling
  of a word can relate to its origin and meaning. This unit prepares pupils for further
  etymological work in the Year 5 unit 'Year 5: Etymology and prefixes'.""" ;
  curric:hasPriorKnowledgeRequirement
    oakcurric:priorknowledge-134-1 ,
    oakcurric:priorknowledge-134-2 ,
    oakcurric:priorknowledge-134-3 ,
    oakcurric:priorknowledge-134-4 ,
    oakcurric:priorknowledge-134-5 ,
    oakcurric:priorknowledge-134-6 ;
  curric:id "134"^^xsd:positiveInteger;
