  communication"""@en ;
  dcterms:modified "2026-06-07T15:29:23.358808Z"^^xsd:dateTime .

oakcurric:priorknowledge-686-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "A letter can be sent in an envelope via post."@en ;
  dcterms:modified "2026-06-07T15:29:23.358819Z"^^xsd:dateTime .

oakcurric:priorknowledge-686-3
  a curric:PriorKnowledgeRequirement ;
