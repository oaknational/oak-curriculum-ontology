oakcurric:priorknowledge-86-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The purpose of a non-chronological report is to inform its reader about a particular
  (usually real) subject."""@en ;
  dcterms:modified "2026-06-07T15:29:25.348241Z"^^xsd:dateTime .

oakcurric:priorknowledge-86-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Non-chronological reports are a type of factual, non-fiction writing."@en ;
  dcterms:modified "2026-06-07T15:29:25.348251Z"^^xsd:dateTime .

oakcurric:priorknowledge-86-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Non-chronological reports are organised into paragraphs of related content each with
  its own subheading."""@en ;
  dcterms:modified "2026-06-07T15:29:25.348257Z"^^xsd:dateTime .

oakcurric:priorknowledge-86-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Non-chronological reports can contain visual information, most commonly diagrams or
  photographs accompanied by a caption."""@en ;
  dcterms:modified "2026-06-07T15:29:25.348261Z"^^xsd:dateTime .

oakcurric:priorknowledge-86-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Grammatical and linguistic features of non-chronological reports include apostrophes
  for singular possession, subject-specific vocabulary and causal conjunctions."""@en ;
  dcterms:modified "2026-06-07T15:29:25.348266Z"^^xsd:dateTime .

oakcurric:priorknowledge-86-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Nouns can be referred to in different ways in order to avoid repetition."@en ;
  dcterms:modified "2026-06-07T15:29:25.348271Z"^^xsd:dateTime .

oakcurric:priorknowledge-86-7
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Text flow can be achieved by writing simple, compound and adverbial complex
  sentences."""@en ;
  dcterms:modified "2026-06-07T15:29:25.348279Z"^^xsd:dateTime .

oakcurric:priorknowledge-86-8
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Formal fronted adverbials are sentence starters followed by a comma."@en ;
  dcterms:modified "2026-06-07T15:29:25.348284Z"^^xsd:dateTime .

oakcurric:priorknowledge-86-9
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """An apostrophe for singular possession is a punctuation mark used to show if a noun
  belongs to another singular noun."""@en ;
  dcterms:modified "2026-06-07T15:29:25.348289Z"^^xsd:dateTime .

oakcurric:priorknowledge-305-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "A main clause is a group of words that contains a verb and makes complete sense."@en ;
  dcterms:modified "2026-06-07T15:29:25.350068Z"^^xsd:dateTime .

oakcurric:priorknowledge-305-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """A simple sentence is formed of one main clause and there are four types of simple
  sentence: statement, question, command and exclamation."""@en ;
  dcterms:modified "2026-06-07T15:29:25.350078Z"^^xsd:dateTime .

oakcurric:priorknowledge-305-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """A compound sentence is formed of two main clauses that are joined by a co-ordinating
  conjunction."""@en ;
  dcterms:modified "2026-06-07T15:29:25.350084Z"^^xsd:dateTime .

oakcurric:priorknowledge-305-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """A subordinate clause is a group of words that contains a verb that does not make
  complete sense."""@en ;
  dcterms:modified "2026-06-07T15:29:25.350088Z"^^xsd:dateTime .

oakcurric:priorknowledge-305-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """An adverbial complex sentence is formed of at least one main clause and an adverbial
  subordinate clause."""@en ;
  dcterms:modified "2026-06-07T15:29:25.350093Z"^^xsd:dateTime .

oakcurric:priorknowledge-305-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """A relative complex sentence is formed of at least one main clause and a relative
  subordinate clause."""@en ;
  dcterms:modified "2026-06-07T15:29:25.350097Z"^^xsd:dateTime .

oakcurric:priorknowledge-305-7
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """A non-finite complex sentence is formed of at least one main clause and a non-finite
  subordinate clause."""@en ;
  dcterms:modified "2026-06-07T15:29:25.350101Z"^^xsd:dateTime .

oakcurric:priorknowledge-305-8
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Different sentence structures allow writers to communicate clearly and with interest
  to the reader."""@en ;
  dcterms:modified "2026-06-07T15:29:25.350110Z"^^xsd:dateTime .

oakcurric:priorknowledge-305-9
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "A range of sentence types in writing creates text cohesion."@en ;
  dcterms:modified "2026-06-07T15:29:25.350114Z"^^xsd:dateTime .

oakcurric:priorknowledge-305-10
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """A comma is an important piece of punctuation with more than one purpose, often used
  to demarcate clauses in compound and complex sentence structures."""@en ;
  dcterms:modified "2026-06-07T15:29:25.350119Z"^^xsd:dateTime .

oakcurric:priorknowledge-230-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Punctuation helps form grammar rules to use the English language correctly."@en ;
  dcterms:modified "2026-06-07T15:29:25.385803Z"^^xsd:dateTime .

oakcurric:priorknowledge-230-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Word class helps to form complete sentences that make sense."@en ;
  dcterms:modified "2026-06-07T15:29:25.385826Z"^^xsd:dateTime .

oakcurric:priorknowledge-230-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Some punctuation marks have more than one purpose."@en ;
  dcterms:modified "2026-06-07T15:29:25.385833Z"^^xsd:dateTime .

oakcurric:priorknowledge-230-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Inverted commas in speech sentences show the reader that a character is speaking in
  a text."""@en ;
  dcterms:modified "2026-06-07T15:29:25.385839Z"^^xsd:dateTime .

oakcurric:priorknowledge-230-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Different speech sentences have different sets of punctuation rules."@en ;
  dcterms:modified "2026-06-07T15:29:25.385854Z"^^xsd:dateTime .

oakcurric:priorknowledge-230-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """A speech first sentence begins with a character's spoken words followed by a
  reporting clause."""@en ;
  dcterms:modified "2026-06-07T15:29:25.385862Z"^^xsd:dateTime .

oakcurric:priorknowledge-230-7
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """A speech second sentence begins with a reporting clause followed by a character's
  spoken words."""@en ;
  dcterms:modified "2026-06-07T15:29:25.385867Z"^^xsd:dateTime .

oakcurric:priorknowledge-230-8
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "An apostrophe can show contraction of two words."@en ;
  dcterms:modified "2026-06-07T15:29:25.385872Z"^^xsd:dateTime .

oakcurric:priorknowledge-230-9
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """An apostrophe can show if a noun belongs to another singular noun or if a noun
  belongs to another plural noun."""@en ;
  dcterms:modified "2026-06-07T15:29:25.385881Z"^^xsd:dateTime .

oakcurric:priorknowledge-230-10
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Accurate use of punctuation helps make writing clear for the reader."@en ;
  dcterms:modified "2026-06-07T15:29:25.385886Z"^^xsd:dateTime .

oakcurric:priorknowledge-3645-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Speaking in full sentences helps the listener understand what is being said."@en ;
  dcterms:modified "2026-06-07T15:29:25.398679Z"^^xsd:dateTime .

oakcurric:priorknowledge-3645-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Successful speaking includes speaking loudly and clearly enough for everyone to
  hear."""@en ;
  dcterms:modified "2026-06-07T15:29:25.398695Z"^^xsd:dateTime .

oakcurric:priorknowledge-3645-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Speaking with volume helps to hold an audience's attention."@en ;
  dcterms:modified "2026-06-07T15:29:25.398701Z"^^xsd:dateTime .

oakcurric:priorknowledge-3645-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Standing to speak helps to get the audience's attention."@en ;
  dcterms:modified "2026-06-07T15:29:25.398706Z"^^xsd:dateTime .

oakcurric:priorknowledge-3645-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Actions help to add meaning to a performance."@en ;
  dcterms:modified "2026-06-07T15:29:25.398712Z"^^xsd:dateTime .

oakcurric:priorknowledge-3645-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Successful listening includes looking at the person speaking and paying close
  attention."""@en ;
  dcterms:modified "2026-06-07T15:29:25.398717Z"^^xsd:dateTime .

oakcurric:priorknowledge-909-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Poems are a form of writing"@en ;
  dcterms:modified "2026-06-07T15:29:25.401405Z"^^xsd:dateTime .

oakcurric:priorknowledge-909-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "A poet is the name for a person who writes poetry"@en ;
  dcterms:modified "2026-06-07T15:29:25.401420Z"^^xsd:dateTime .

oakcurric:priorknowledge-909-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Poems are often about feelings"@en ;
  dcterms:modified "2026-06-07T15:29:25.401427Z"^^xsd:dateTime .

oakcurric:priorknowledge-909-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Poems do not follow the standard rules of writing"@en ;
  dcterms:modified "2026-06-07T15:29:25.401432Z"^^xsd:dateTime .

oakcurric:priorknowledge-909-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Some poems may use rhyming words"@en ;
  dcterms:modified "2026-06-07T15:29:25.401445Z"^^xsd:dateTime .

oakcurric:priorknowledge-820-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Persuasive writing is a type of non-fiction writing"@en ;
  dcterms:modified "2026-06-07T15:29:25.403828Z"^^xsd:dateTime .

oakcurric:priorknowledge-820-2
