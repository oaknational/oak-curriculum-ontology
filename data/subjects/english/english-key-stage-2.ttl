  a curric:KeyLearningPoint ;
  rdfs:label "The 'ice' spelling can make the sounds 'ice' and 'iss'."@en ;
  dcterms:modified "2026-02-12T08:59:21.718769Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1343-4
  a curric:KeyLearningPoint ;
  rdfs:label """When you hear one of these sounds, the word might contain the 'ou', 'ear' or 'ice' spelling."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718773Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1343-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: forty, rhythm and criticise."@en ;
  dcterms:modified "2026-02-12T08:59:21.718778Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1411-1
  a curric:KeyLearningPoint ;
  rdfs:label "The suffix -al often turns nouns into adjectives."@en ;
  dcterms:modified "2026-02-12T08:59:21.718784Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1411-2
  a curric:KeyLearningPoint ;
  rdfs:label "When the root word ends in a consonant, just add the suffix."@en ;
  dcterms:modified "2026-02-12T08:59:21.718789Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1411-3
  a curric:KeyLearningPoint ;
  rdfs:label "When the root word ends in ‘e’, remove the ‘e’ and add the suffix."@en ;
  dcterms:modified "2026-02-12T08:59:21.718794Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1411-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: disappear, perhaps and experience."@en ;
  dcterms:modified "2026-02-12T08:59:21.718798Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1383-1
  a curric:KeyLearningPoint ;
  rdfs:label """Near-homophones are words that sound similar to each other but have slightly different spellings and different meanings."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718804Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1383-2
  a curric:KeyLearningPoint ;
  rdfs:label """The way that a word is spelt and its place within a sentence will generally tell us its meaning."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718809Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1383-3
  a curric:KeyLearningPoint ;
  rdfs:label "There are no spelling rules for homophones so we must learn them by sight."@en ;
  dcterms:modified "2026-02-12T08:59:21.718813Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1383-4
  a curric:KeyLearningPoint ;
  rdfs:label """How to spell the curriculum words: peculiar, particular, medicine and aggressive."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718818Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2713-1
  a curric:KeyLearningPoint ;
  rdfs:label "Words can be related to each other by meaning."@en ;
  dcterms:modified "2026-02-12T08:59:21.718822Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2713-2
  a curric:KeyLearningPoint ;
  rdfs:label "Synonyms can be used by writers to vary vocabulary choice and create text flow."@en ;
  dcterms:modified "2026-02-12T08:59:21.718827Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2713-3
  a curric:KeyLearningPoint ;
  rdfs:label "Antonyms can be used by writers to create a certain effect for the reader."@en ;
  dcterms:modified "2026-02-12T08:59:21.718831Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2713-4
  a curric:KeyLearningPoint ;
  rdfs:label """Word families are groups of words that have common features, patterns or meanings."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718836Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2713-5
  a curric:KeyLearningPoint ;
  rdfs:label "All words have etymology."@en ;
  dcterms:modified "2026-02-12T08:59:21.718840Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1038-1
  a curric:KeyLearningPoint ;
  rdfs:label "A simple sentence is a sentence about one idea that makes complete sense."@en ;
  dcterms:modified "2026-02-12T08:59:21.718844Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1038-2
  a curric:KeyLearningPoint ;
  rdfs:label """There are four types of simple sentence: statements, questions, commands and exclamations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718849Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1038-3
  a curric:KeyLearningPoint ;
  rdfs:label "Any type of simple sentence must contain a verb."@en ;
  dcterms:modified "2026-02-12T08:59:21.718855Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1038-4
  a curric:KeyLearningPoint ;
  rdfs:label """A group of words that contains a verb and makes complete sense is called a main clause."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718860Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1038-5
  a curric:KeyLearningPoint ;
  rdfs:label "A simple sentence is formed of one main clause."@en ;
  dcterms:modified "2026-02-12T08:59:21.718865Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6144-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of a narrative opening is to introduce the characters and to describe the setting to the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718869Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6144-2
  a curric:KeyLearningPoint ;
  rdfs:label "Saying sentences aloud before they are written helps to check for sense."@en ;
  dcterms:modified "2026-02-12T08:59:21.718874Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6144-3
  a curric:KeyLearningPoint ;
  rdfs:label """Using the full range of sentence types (simple, compound and complex) improves text flow for the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718878Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6144-4
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials of time, place and manner add extra detail to the main clause."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718883Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6144-5
  a curric:KeyLearningPoint ;
  rdfs:label "This narrative version of ‘The BFG’ is written in the past tense."@en ;
  dcterms:modified "2026-02-12T08:59:21.718888Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5997-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of a persuasive letter is to try to convince someone to do something or to change their mind or behaviour."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718892Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5997-2
  a curric:KeyLearningPoint ;
  rdfs:label """Letters written from a character's point of view are written in the first person."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718896Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5997-3
  a curric:KeyLearningPoint ;
  rdfs:label """A persuasive letter has a specific layout: a salutation, two paragraphs and a sign-off."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718901Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5997-4
  a curric:KeyLearningPoint ;
  rdfs:label """Persuasive letters have distinctive linguistic features in order to achieve their purpose."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718905Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5997-5
  a curric:KeyLearningPoint ;
  rdfs:label """A range of persuasive techniques can be used to increase the pressure on the reader to act."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718910Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7855-1
  a curric:KeyLearningPoint ;
  rdfs:label "A summary is the main ideas of a text, usually from more than one paragraph"@en ;
  dcterms:modified "2026-02-12T08:59:21.718914Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7855-2
  a curric:KeyLearningPoint ;
  rdfs:label """Examining an inspirational figure from history can have an impact on our understanding of events in present day"""@en ;
  dcterms:modified "2026-02-12T08:59:21.718919Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7347-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of a setting description is to provide rich detail that creates an atmosphere for the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.720109Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7347-2
  a curric:KeyLearningPoint ;
  rdfs:label """Precise vocabulary, sensory details and personification support in creating a desired atmosphere."""@en ;
  dcterms:modified "2026-02-12T08:59:21.720114Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7347-3
  a curric:KeyLearningPoint ;
  rdfs:label """Prepositions help to describe the setting in a precise way by telling the reader where a noun is."""@en ;
  dcterms:modified "2026-02-12T08:59:21.720118Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7347-4
  a curric:KeyLearningPoint ;
  rdfs:label """Using a range of sentence types (simple, compound and complex) improves text flow for the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.720122Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6357-1
  a curric:KeyLearningPoint ;
  rdfs:label """Journalistic reports are written using formal and factual language to create a serious and objective tone."""@en ;
  dcterms:modified "2026-02-12T08:59:21.720127Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6357-2
  a curric:KeyLearningPoint ;
  rdfs:label """The use of subject-specific vocabulary is crucial in journalistic reports and varies depending on the news event."""@en ;
  dcterms:modified "2026-02-12T08:59:21.720131Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6357-3
  a curric:KeyLearningPoint ;
  rdfs:label """Appropriate synonyms are used in journalistic reports to create a formal tone and to avoid repetition."""@en ;
  dcterms:modified "2026-02-12T08:59:21.720135Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6357-4
  a curric:KeyLearningPoint ;
  rdfs:label """Formal language involves the use of sophisticated vocabulary without the use of contractions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.720140Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1404-1
  a curric:KeyLearningPoint ;
  rdfs:label "The /shun/ suffix can be spelt -tion, -sion, -ssion or -cian."@en ;
  dcterms:modified "2026-02-12T08:59:21.720144Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1404-2
  a curric:KeyLearningPoint ;
  rdfs:label "Words ending in the suffix -cian are nouns and a profession."@en ;
  dcterms:modified "2026-02-12T08:59:21.720148Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1404-3
  a curric:KeyLearningPoint ;
  rdfs:label "Words spelt with -cian often have a root word ending in ‘c’ or ‘cs’."@en ;
  dcterms:modified "2026-02-12T08:59:21.720153Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1404-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: eighth, weight and knowledge."@en ;
  dcterms:modified "2026-02-12T08:59:21.720157Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1377-1
  a curric:KeyLearningPoint ;
  rdfs:label "The suffixes -ance and -ancy can create abstract nouns."@en ;
  dcterms:modified "2026-02-12T08:59:21.720161Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1377-2
  a curric:KeyLearningPoint ;
  rdfs:label "The -ance or -ancy spellings may be found after a ‘hard c’ or ‘hard ‘g’."@en ;
  dcterms:modified "2026-02-12T08:59:21.720168Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1377-3
  a curric:KeyLearningPoint ;
  rdfs:label """Words ending in -ant/-ance/-ancy sometimes have related words where the ‘ay’ vowel sound is clearer."""@en ;
  dcterms:modified "2026-02-12T08:59:21.720173Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1377-4
  a curric:KeyLearningPoint ;
  rdfs:label "Words in word families often have connected meaning and spelling."@en ;
  dcterms:modified "2026-02-12T08:59:21.720177Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1377-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: length, strength, though and although."@en ;
  dcterms:modified "2026-02-12T08:59:21.720182Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1454-1
  a curric:KeyLearningPoint ;
  rdfs:label """Homophones are words that have different spellings and multiple meanings, but sound the same."""@en ;
  dcterms:modified "2026-02-12T08:59:21.720186Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1454-2
  a curric:KeyLearningPoint ;
  rdfs:label """A homonym is a word that has the same spelling or pronunciation as another but a different meaning."""@en ;
  dcterms:modified "2026-02-12T08:59:21.720193Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1454-3
  a curric:KeyLearningPoint ;
  rdfs:label "The meaning of a homonym or homophone is dependent on the context."@en ;
  dcterms:modified "2026-02-12T08:59:21.720197Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1454-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum word: quarter."@en ;
  dcterms:modified "2026-02-12T08:59:21.720202Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5810-1
  a curric:KeyLearningPoint ;
  rdfs:label "A diary entry combines details about events with details about emotions."@en ;
  dcterms:modified "2026-02-12T08:59:21.720206Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5810-2
  a curric:KeyLearningPoint ;
  rdfs:label "We can use certain linguistic features to make an appropriate tone for a diary."@en ;
  dcterms:modified "2026-02-12T08:59:21.720213Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5810-3
  a curric:KeyLearningPoint ;
  rdfs:label """Hyperbole, internal thoughts, rhetorical questions and exclamation sentences make diary writing more personal."""@en ;
  dcterms:modified "2026-02-12T08:59:21.720217Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5810-4
  a curric:KeyLearningPoint ;
  rdfs:label """We connect ideas together in writing with cohesive devices like fronted adverbials and different sentence types."""@en ;
  dcterms:modified "2026-02-12T08:59:21.720222Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5810-5
  a curric:KeyLearningPoint ;
  rdfs:label "We may change tense between past and present during a diary entry."@en ;
  dcterms:modified "2026-02-12T08:59:21.720226Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1422-1
  a curric:KeyLearningPoint ;
  rdfs:label """Words that are pronounced the same but have different spellings and meanings are called homophones."""@en ;
  dcterms:modified "2026-02-12T08:59:21.720231Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1422-2
  a curric:KeyLearningPoint ;
  rdfs:label "Unlike other words we have investigated, there are no patterns for homophones."@en ;
  dcterms:modified "2026-02-12T08:59:21.720263Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1422-3
  a curric:KeyLearningPoint ;
  rdfs:label """The way a word is spelt and its place within a sentence will tell us its meaning."""@en ;
  dcterms:modified "2026-02-12T08:59:21.720268Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1422-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: straight, caught and possess."@en ;
  dcterms:modified "2026-02-12T08:59:21.720273Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6372-1
  a curric:KeyLearningPoint ;
  rdfs:label "Figurative language can be used to create imagery and describe events."@en ;
  dcterms:modified "2026-02-12T08:59:21.720277Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6372-2
  a curric:KeyLearningPoint ;
  rdfs:label "Varying sentence structure and vocabulary choices enhance text cohesion or flow."@en ;
  dcterms:modified "2026-02-12T08:59:21.720284Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6372-3
  a curric:KeyLearningPoint ;
  rdfs:label "A hyphen can be used to join two words to form one compound adjective."@en ;
  dcterms:modified "2026-02-12T08:59:21.720288Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6372-4
  a curric:KeyLearningPoint ;
  rdfs:label """Using show-not-tell enables writers to share characters' emotions, actions and gestures with the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.720293Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6596-1
  a curric:KeyLearningPoint ;
  rdfs:label """A conclusion summarises the key points of the paragraphs preceding it - no new information should be introduced."""@en ;
  dcterms:modified "2026-02-12T08:59:21.721007Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6596-2
  a curric:KeyLearningPoint ;
  rdfs:label "The conclusion paragraph is similar in structure to the introduction paragraph."@en ;
  dcterms:modified "2026-02-12T08:59:21.721012Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6596-3
  a curric:KeyLearningPoint ;
  rdfs:label "Variation in vocabulary choice and sentence structure enhances text cohesion."@en ;
  dcterms:modified "2026-02-12T08:59:21.721016Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6596-4
  a curric:KeyLearningPoint ;
  rdfs:label "Plans should be written in note form and include concise vocabulary choices."@en ;
  dcterms:modified "2026-02-12T08:59:21.721020Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6596-5
  a curric:KeyLearningPoint ;
  rdfs:label "Success criteria and plans should be used to guide the writing process."@en ;
  dcterms:modified "2026-02-12T08:59:21.721025Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7355-1
  a curric:KeyLearningPoint ;
  rdfs:label """The climax takes the suspense to its highest point as Scrooge encounters the Ghost of Christmas Yet to Come."""@en ;
  dcterms:modified "2026-02-12T08:59:21.721115Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7355-2
  a curric:KeyLearningPoint ;
  rdfs:label """The climax is written over two paragraphs and it is important to demonstrate cohesion across them."""@en ;
  dcterms:modified "2026-02-12T08:59:21.721119Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7355-3
  a curric:KeyLearningPoint ;
  rdfs:label """Cohesion refers to how a text flows in order to maintain the interest of the reader and achieve the purpose."""@en ;
  dcterms:modified "2026-02-12T08:59:21.721126Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7355-4
  a curric:KeyLearningPoint ;
  rdfs:label """Scrooge’s emotions increase in intensity across both paragraphs in the climax which supports cohesion."""@en ;
  dcterms:modified "2026-02-12T08:59:21.721130Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7355-5
  a curric:KeyLearningPoint ;
  rdfs:label """Oral rehearsal helps to structure grammatically correct full sentences and supports cohesion."""@en ;
  dcterms:modified "2026-02-12T08:59:21.721135Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1446-1
  a curric:KeyLearningPoint ;
  rdfs:label "The spelling 'mb' is often found at the end of a word, such as climb."@en ;
  dcterms:modified "2026-02-12T08:59:21.721141Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1446-2
  a curric:KeyLearningPoint ;
  rdfs:label "The spelling 'kn' is usually found at the start of a word."@en ;
  dcterms:modified "2026-02-12T08:59:21.721148Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1446-3
  a curric:KeyLearningPoint ;
  rdfs:label "The spelling 'gn' is usually found at the start or end of a word."@en ;
  dcterms:modified "2026-02-12T08:59:21.721153Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1446-4
  a curric:KeyLearningPoint ;
  rdfs:label "The spelling 'wr' is usually found at the start of a word."@en ;
  dcterms:modified "2026-02-12T08:59:21.721159Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1446-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum word: perhaps."@en ;
  dcterms:modified "2026-02-12T08:59:21.721164Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2699-1
  a curric:KeyLearningPoint ;
  rdfs:label "Any conjunction joins words, phrases or clauses."@en ;
  dcterms:modified "2026-02-12T08:59:21.721169Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2699-2
  a curric:KeyLearningPoint ;
  rdfs:label "A co-ordinating conjunction is found in a compound sentence."@en ;
  dcterms:modified "2026-02-12T08:59:21.721173Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2699-3
  a curric:KeyLearningPoint ;
  rdfs:label "A subordinating conjunction is found in an adverbial complex sentence."@en ;
  dcterms:modified "2026-02-12T08:59:21.721178Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2699-4
  a curric:KeyLearningPoint ;
  rdfs:label "Different co-ordinating and subordinating conjunctions have different meanings."@en ;
  dcterms:modified "2026-02-12T08:59:21.721182Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4710-1
  a curric:KeyLearningPoint ;
  rdfs:label "The PEPS structure stands for point, explanation, proof, summary."@en ;
  dcterms:modified "2026-02-12T08:59:21.721187Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4710-2
  a curric:KeyLearningPoint ;
  rdfs:label "Following the PEPS structure helps to organise your speech."@en ;
  dcterms:modified "2026-02-12T08:59:21.721191Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4710-3
  a curric:KeyLearningPoint ;
  rdfs:label "Explaining your point will allow you to share the reasons behind your opinion."@en ;
  dcterms:modified "2026-02-12T08:59:21.721195Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4710-4
  a curric:KeyLearningPoint ;
  rdfs:label "Using proof will make your point stronger."@en ;
  dcterms:modified "2026-02-12T08:59:21.721200Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27902-1
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to express disagreements calmly and respectfully, using a polite tone and language."""@en ;
  dcterms:modified "2026-02-12T08:59:21.721205Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27902-2
  a curric:KeyLearningPoint ;
  rdfs:label "Some disagreements are about opinions; others are about behaviour and choices."@en ;
  dcterms:modified "2026-02-12T08:59:21.721209Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27902-3
  a curric:KeyLearningPoint ;
  rdfs:label """We should recognise that everyone has different opinions and not take offence; it's not a personal attack."""@en ;
  dcterms:modified "2026-02-12T08:59:21.721214Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27902-4
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to try resolving disagreements peacefully by explaining your feelings or compromising when appropriate."""@en ;
  dcterms:modified "2026-02-12T08:59:21.721218Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27902-5
  a curric:KeyLearningPoint ;
  rdfs:label """Compromises are not always appropriate; if they are, we should suggest them calmly and politely."""@en ;
  dcterms:modified "2026-02-12T08:59:21.721222Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1046-1
  a curric:KeyLearningPoint ;
  rdfs:label "The verb carries the tense of a sentence."@en ;
  dcterms:modified "2026-02-12T08:59:21.721229Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1046-2
  a curric:KeyLearningPoint ;
  rdfs:label "Sentences can be formed in the first, second or third person."@en ;
  dcterms:modified "2026-02-12T08:59:21.721234Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1046-3
  a curric:KeyLearningPoint ;
  rdfs:label "First person is the I / we perspective."@en ;
  dcterms:modified "2026-02-12T08:59:21.721238Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1046-4
  a curric:KeyLearningPoint ;
  rdfs:label "Second person is the you singular / you plural perspective."@en ;
  dcterms:modified "2026-02-12T08:59:21.721243Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1046-5
  a curric:KeyLearningPoint ;
  rdfs:label "Third person is the he / she / it / they perspective."@en ;
  dcterms:modified "2026-02-12T08:59:21.721247Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6220-1
  a curric:KeyLearningPoint ;
  rdfs:label """Our essay will give one side of an argument, using a logical order and supported by evidence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.721251Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6220-2
  a curric:KeyLearningPoint ;
  rdfs:label "Evidence can take many forms, including explanations, facts and statistics."@en ;
  dcterms:modified "2026-02-12T08:59:21.721256Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6220-3
  a curric:KeyLearningPoint ;
  rdfs:label """In the second main paragraph, we will explain how deforestation can drive climate change."""@en ;
  dcterms:modified "2026-02-12T08:59:21.721260Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6220-4
  a curric:KeyLearningPoint ;
  rdfs:label "We will include subject-specific vocabulary and a range of linguistic features."@en ;
  dcterms:modified "2026-02-12T08:59:21.721264Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6220-5
  a curric:KeyLearningPoint ;
  rdfs:label """Within a paragraph, the points we make must be in a logical order and connect to one another."""@en ;
  dcterms:modified "2026-02-12T08:59:21.721270Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4870-1
  a curric:KeyLearningPoint ;
  rdfs:label """Research into a subject improves the writing of a non-chronological report about it."""@en ;
  dcterms:modified "2026-02-12T08:59:21.721275Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4870-2
  a curric:KeyLearningPoint ;
  rdfs:label "Tigers are nocturnal, highly-adapted mammals that live in Asia."@en ;
  dcterms:modified "2026-02-12T08:59:21.721282Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4870-3
  a curric:KeyLearningPoint ;
  rdfs:label """Adaptations are features that animals and plants have to help them survive in their environments."""@en ;
  dcterms:modified "2026-02-12T08:59:21.721287Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4870-4
  a curric:KeyLearningPoint ;
  rdfs:label "Tigers’ adaptations enable them to hunt and eat food."@en ;
  dcterms:modified "2026-02-12T08:59:21.721291Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4870-5
  a curric:KeyLearningPoint ;
  rdfs:label "Tigers' diets are carnivorous."@en ;
  dcterms:modified "2026-02-12T08:59:21.721295Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4898-1
  a curric:KeyLearningPoint ;
  rdfs:label "Information in the adaptations section is specific for the reader."@en ;
  dcterms:modified "2026-02-12T08:59:21.721300Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4898-2
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials, subject-specific vocabulary, relative complex sentences and parenthesis enhance text cohesion."""@en ;
  dcterms:modified "2026-02-12T08:59:21.721304Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4898-3
  a curric:KeyLearningPoint ;
  rdfs:label """Parenthesis is additional information added to the sentence that can be demarcated using a pair of brackets."""@en ;
  dcterms:modified "2026-02-12T08:59:21.721308Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4898-4
  a curric:KeyLearningPoint ;
  rdfs:label "Plans should be used when writing to generate initial ideas and build upon them."@en ;
  dcterms:modified "2026-02-12T08:59:21.721315Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4898-5
  a curric:KeyLearningPoint ;
  rdfs:label "Success criteria help us understand what to include in our writing."@en ;
  dcterms:modified "2026-02-12T08:59:21.721320Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4848-1
  a curric:KeyLearningPoint ;
  rdfs:label "The opening provides the reader with general information about the event."@en ;
  dcterms:modified "2026-02-12T08:59:21.721324Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4848-2
  a curric:KeyLearningPoint ;
  rdfs:label """The opening includes when, where and what took place as well as who was there and what is currently happening."""@en ;
  dcterms:modified "2026-02-12T08:59:21.721328Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4848-3
  a curric:KeyLearningPoint ;
  rdfs:label """Subject-specific language is used to convey information to the reader in a clear, formal way."""@en ;
  dcterms:modified "2026-02-12T08:59:21.721333Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4848-4
  a curric:KeyLearningPoint ;
  rdfs:label "Journalists use specific phraseology to write for purpose, tone and credibility."@en ;
  dcterms:modified "2026-02-12T08:59:21.721337Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1313-1
  a curric:KeyLearningPoint ;
  rdfs:label "There are four spelling rules when adding -ous to a root word."@en ;
  dcterms:modified "2026-02-12T08:59:21.721342Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1313-2
  a curric:KeyLearningPoint ;
  rdfs:label "Some words ending in -ous do not have a root word we recognise."@en ;
  dcterms:modified "2026-02-12T08:59:21.721346Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1313-3
  a curric:KeyLearningPoint ;
  rdfs:label """When you hear the ‘ee’ sound before -ous, the most likely spelling is an ‘i’, but it is sometimes an ‘e’."""@en ;
  dcterms:modified "2026-02-12T08:59:21.721351Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1313-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: guard, exercise and decide."@en ;
  dcterms:modified "2026-02-12T08:59:21.721355Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4894-1
  a curric:KeyLearningPoint ;
  rdfs:label "Related information is grouped into paragraphs and organised using a subheading."@en ;
  dcterms:modified "2026-02-12T08:59:21.721594Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4894-2
  a curric:KeyLearningPoint ;
  rdfs:label "An introductory sentence explains what the paragraph is about."@en ;
  dcterms:modified "2026-02-12T08:59:21.721599Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4894-3
  a curric:KeyLearningPoint ;
  rdfs:label "Relative clauses give additional detail about the sentence’s subject."@en ;
  dcterms:modified "2026-02-12T08:59:21.721605Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4894-4
  a curric:KeyLearningPoint ;
  rdfs:label "Apostrophes can be used to indicate plural possession."@en ;
  dcterms:modified "2026-02-12T08:59:21.721610Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4894-5
  a curric:KeyLearningPoint ;
  rdfs:label "Referring to aye-ayes using other nouns avoids repetition."@en ;
  dcterms:modified "2026-02-12T08:59:21.721617Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1392-1
  a curric:KeyLearningPoint ;
  rdfs:label "In words of Latin origin, the letter string 'sc' makes the /s/ sound"@en ;
  dcterms:modified "2026-02-12T08:59:21.721657Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1392-2
  a curric:KeyLearningPoint ;
  rdfs:label "When this spelling is used, it is most often before an ‘i’ or ‘e’."@en ;
  dcterms:modified "2026-02-12T08:59:21.721662Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1392-3
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: muscle, suggest and pressure"@en ;
  dcterms:modified "2026-02-12T08:59:21.721666Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1403-1
  a curric:KeyLearningPoint ;
  rdfs:label "The suffix -tion creates abstract nouns."@en ;
  dcterms:modified "2026-02-12T08:59:21.721670Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1403-2
  a curric:KeyLearningPoint ;
  rdfs:label "The most common spelling for the /shun/ suffix is -tion."@en ;
  dcterms:modified "2026-02-12T08:59:21.721675Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1403-3
  a curric:KeyLearningPoint ;
  rdfs:label "Words spelt with -tion often have a root word ending in ‘t’ or ‘te’."@en ;
  dcterms:modified "2026-02-12T08:59:21.721679Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1403-4
  a curric:KeyLearningPoint ;
  rdfs:label "The suffix -ation turns verbs into nouns.  It uses familiar spelling patterns."@en ;
  dcterms:modified "2026-02-12T08:59:21.721683Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1403-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: build, height and eight."@en ;
  dcterms:modified "2026-02-12T08:59:21.721690Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1386-1
  a curric:KeyLearningPoint ;
  rdfs:label """There are many ways to spell the ‘ee’ sound, including ‘ee’, ‘ea’, ‘e-e’, ‘e’, ‘y’, ‘ey’, ‘ie’ and ‘ei’."""@en ;
  dcterms:modified "2026-02-12T08:59:21.721695Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1386-2
  a curric:KeyLearningPoint ;
  rdfs:label """The rule ‘i before e except after c’ can help choose between ‘ie’ and ‘ei’ when spelling ‘ee’."""@en ;
  dcterms:modified "2026-02-12T08:59:21.721699Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1386-3
  a curric:KeyLearningPoint ;
  rdfs:label "The letter string ‘ie’ can represent a range of different sounds."@en ;
  dcterms:modified "2026-02-12T08:59:21.721704Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1386-4
  a curric:KeyLearningPoint ;
  rdfs:label """Some spellings with ‘ie’ are formed from root words ending in ‘y’ and a vowel suffix."""@en ;
  dcterms:modified "2026-02-12T08:59:21.721708Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1386-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: ancient, soldier and bargain."@en ;
  dcterms:modified "2026-02-12T08:59:21.721713Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1420-1
  a curric:KeyLearningPoint ;
  rdfs:label """Compound words are two or three existing words that join together to make one word."""@en ;
  dcterms:modified "2026-02-12T08:59:21.721717Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1420-2
  a curric:KeyLearningPoint ;
  rdfs:label "Compound words are most often nouns."@en ;
  dcterms:modified "2026-02-12T08:59:21.721722Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1420-3
  a curric:KeyLearningPoint ;
  rdfs:label """Compound words have a new meaning, which is often linked to the meaning of the root word."""@en ;
  dcterms:modified "2026-02-12T08:59:21.721726Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1420-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: enough, naughty and forwards."@en ;
  dcterms:modified "2026-02-12T08:59:21.721730Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1047-1
  a curric:KeyLearningPoint ;
  rdfs:label "The verb carries the tense of a sentence."@en ;
  dcterms:modified "2026-02-12T08:59:21.721735Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1047-2
  a curric:KeyLearningPoint ;
  rdfs:label """The simple tense is a tense that does not make use of an auxiliary verb with the main verb in the past and present."""@en ;
  dcterms:modified "2026-02-12T08:59:21.721739Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1047-3
  a curric:KeyLearningPoint ;
  rdfs:label """The progressive tense is a tense that uses an auxiliary verb from the infinitive 'to be' paired with the main verb."""@en ;
  dcterms:modified "2026-02-12T08:59:21.721743Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1047-4
  a curric:KeyLearningPoint ;
  rdfs:label "The progressive tense denotes ongoing action."@en ;
  dcterms:modified "2026-02-12T08:59:21.721748Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1047-5
  a curric:KeyLearningPoint ;
  rdfs:label "The main verb in the progressive tense always ends with the -ing suffix."@en ;
  dcterms:modified "2026-02-12T08:59:21.721752Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6150-1
  a curric:KeyLearningPoint ;
  rdfs:label "The purpose of the build-up is to build tension and suspense."@en ;
  dcterms:modified "2026-02-12T08:59:21.721756Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6150-2
  a curric:KeyLearningPoint ;
  rdfs:label "Saying sentences aloud before they are written helps to check for sense."@en ;
  dcterms:modified "2026-02-12T08:59:21.721763Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6150-3
  a curric:KeyLearningPoint ;
  rdfs:label """Using the full range of sentence types (simple, compound and complex) improves text flow for the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.721767Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6150-4
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials of time, place and manner describe the action in the main clause in further detail."""@en ;
  dcterms:modified "2026-02-12T08:59:21.721774Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6150-5
  a curric:KeyLearningPoint ;
  rdfs:label """'Show-not-tell' language shows a character’s feelings by describing their actions, body language and facial expressions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.721779Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1373-1
  a curric:KeyLearningPoint ;
  rdfs:label "If the word is a profession, the noun will generally end in \"-cian\"."@en ;
  dcterms:modified "2026-02-12T08:59:21.721783Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1373-2
  a curric:KeyLearningPoint ;
  rdfs:label "If the root word ends in \"ss\" or \"mit\", remove the \"ss\" or \"t\" and add \"-ssion\"."@en ;
  dcterms:modified "2026-02-12T08:59:21.721790Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1373-3
  a curric:KeyLearningPoint ;
  rdfs:label """If the root word is a verb ending in "se" or "de", remove the "se" or "de" and add "-sion"."""@en ;
  dcterms:modified "2026-02-12T08:59:21.721796Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1373-4
  a curric:KeyLearningPoint ;
  rdfs:label "If the root word ends in \"c\" or \"cs\", remove the \"c\" or \"cs\" and add \"-cian\"."@en ;
  dcterms:modified "2026-02-12T08:59:21.721801Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1373-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: possession, occasion and occasionally."@en ;
  dcterms:modified "2026-02-12T08:59:21.721806Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1389-1
  a curric:KeyLearningPoint ;
  rdfs:label """Soft c and hard c refer to two different sounds that the letter c can represent in English spelling."""@en ;
  dcterms:modified "2026-02-12T08:59:21.722442Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1389-2
  a curric:KeyLearningPoint ;
  rdfs:label """If the vowel letters ‘a’, ‘o’ or ‘u’ or a consonant letter follows the letter c it is pronounced as a hard c."""@en ;
  dcterms:modified "2026-02-12T08:59:21.722446Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1389-3
  a curric:KeyLearningPoint ;
  rdfs:label """If the vowel letters ‘e’, ‘i’ or ‘y’ follow the letter c it is pronounced as a soft c."""@en ;
  dcterms:modified "2026-02-12T08:59:21.722455Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1389-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: decide, notice and centre."@en ;
  dcterms:modified "2026-02-12T08:59:21.722459Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4700-1
  a curric:KeyLearningPoint ;
  rdfs:label "A debate is a structured argument between two teams."@en ;
  dcterms:modified "2026-02-12T08:59:21.722464Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4700-2
  a curric:KeyLearningPoint ;
  rdfs:label "An opinion is a view or belief that a person has."@en ;
  dcterms:modified "2026-02-12T08:59:21.722468Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4700-3
  a curric:KeyLearningPoint ;
  rdfs:label "In a debate, an opinion must be justified with reasoning."@en ;
  dcterms:modified "2026-02-12T08:59:21.722473Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4705-1
  a curric:KeyLearningPoint ;
  rdfs:label """When making a speech in a debate, a person should have written notes to help them."""@en ;
  dcterms:modified "2026-02-12T08:59:21.722479Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4705-2
  a curric:KeyLearningPoint ;
  rdfs:label "Notes do not need to be written in full sentences."@en ;
  dcterms:modified "2026-02-12T08:59:21.722484Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4705-3
  a curric:KeyLearningPoint ;
  rdfs:label "Notes should not be read word for word."@en ;
  dcterms:modified "2026-02-12T08:59:21.722489Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7933-1
  a curric:KeyLearningPoint ;
  rdfs:label "The character of Sam changes dramatically from the start of the text to the end."@en ;
  dcterms:modified "2026-02-12T08:59:21.722704Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7933-2
  a curric:KeyLearningPoint ;
  rdfs:label """Characters within the text depict a range of emotions. Character traits can be understood from these."""@en ;
  dcterms:modified "2026-02-12T08:59:21.722709Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7933-3
  a curric:KeyLearningPoint ;
  rdfs:label """Character traits can be explored through the text’s illustrations or words used by the characters."""@en ;
  dcterms:modified "2026-02-12T08:59:21.722713Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7933-4
  a curric:KeyLearningPoint ;
  rdfs:label """Making connections and recommendations can significantly enhance the reading experience and broaden understanding."""@en ;
  dcterms:modified "2026-02-12T08:59:21.722720Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1443-1
  a curric:KeyLearningPoint ;
  rdfs:label "-er and -est are suffixes that can be used to change the meaning of a root word."@en ;
  dcterms:modified "2026-02-12T08:59:21.722725Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1443-2
  a curric:KeyLearningPoint ;
  rdfs:label "The strategy 'big letters' is a useful practice strategy."@en ;
  dcterms:modified "2026-02-12T08:59:21.722729Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1443-3
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum word: special."@en ;
  dcterms:modified "2026-02-12T08:59:21.722734Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5816-1
  a curric:KeyLearningPoint ;
  rdfs:label """'Romeo and Juliet' is a tragedy that raises themes around family, social obligations, love and conflict."""@en ;
  dcterms:modified "2026-02-12T08:59:21.722738Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5816-2
  a curric:KeyLearningPoint ;
  rdfs:label "We can use a piece of art like a play as a stimulus for a discussion."@en ;
  dcterms:modified "2026-02-12T08:59:21.722743Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5816-3
  a curric:KeyLearningPoint ;
  rdfs:label """We can consider factual questions, discussion questions and philosophical questions raised by the play."""@en ;
  dcterms:modified "2026-02-12T08:59:21.722749Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5816-4
  a curric:KeyLearningPoint ;
  rdfs:label """Philosophical questions are questions that are not context-linked - they could be discussed without knowing the play."""@en ;
  dcterms:modified "2026-02-12T08:59:21.722754Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5816-5
  a curric:KeyLearningPoint ;
  rdfs:label "When debating, we build on others' answers and we disagree respectfully."@en ;
  dcterms:modified "2026-02-12T08:59:21.722758Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5813-1
  a curric:KeyLearningPoint ;
  rdfs:label """We are planning a narrative retelling of the duel scene in Act III Scene 1, using the same events."""@en ;
  dcterms:modified "2026-02-12T08:59:21.722764Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5813-2
  a curric:KeyLearningPoint ;
  rdfs:label """Narrative includes overlapping elements of dialogue, description, emotion and action."""@en ;
  dcterms:modified "2026-02-12T08:59:21.722769Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5813-3
  a curric:KeyLearningPoint ;
  rdfs:label """We can include all of these narrative elements in our plan in order to ensure we have covered all the content we need."""@en ;
  dcterms:modified "2026-02-12T08:59:21.722774Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5813-4
  a curric:KeyLearningPoint ;
  rdfs:label "Our plan is written in note form, in the third person and the past tense."@en ;
  dcterms:modified "2026-02-12T08:59:21.722778Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5813-5
  a curric:KeyLearningPoint ;
  rdfs:label """We are following a structure of four paragraphs, tracking the key events of the animated version of the scene."""@en ;
  dcterms:modified "2026-02-12T08:59:21.722782Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1418-1
  a curric:KeyLearningPoint ;
  rdfs:label """When there are two of the same consonants beside each other, we call this a double consonant."""@en ;
  dcterms:modified "2026-02-12T08:59:21.722787Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1418-2
  a curric:KeyLearningPoint ;
  rdfs:label "Double consonants are often found after short vowel sounds."@en ;
  dcterms:modified "2026-02-12T08:59:21.722791Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1418-3
  a curric:KeyLearningPoint ;
  rdfs:label "Some letters are never doubled, 'h' 'k' 'j' 'v'."@en ;
  dcterms:modified "2026-02-12T08:59:21.722795Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1418-4
  a curric:KeyLearningPoint ;
  rdfs:label """Some letters are rarely doubled, 'c' 'z'. When they are, they usually come from another language."""@en ;
  dcterms:modified "2026-02-12T08:59:21.722800Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1418-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: peculiar, particular and quarter."@en ;
  dcterms:modified "2026-02-12T08:59:21.722806Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6152-1
  a curric:KeyLearningPoint ;
  rdfs:label """A published piece of writing should be visually and linguistically appealing to the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.722811Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6152-2
  a curric:KeyLearningPoint ;
  rdfs:label "Neat, joined handwriting is important when publishing a piece of writing."@en ;
  dcterms:modified "2026-02-12T08:59:21.722816Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6152-3
  a curric:KeyLearningPoint ;
  rdfs:label """A piece of published writing is the final, best version that becomes available to others."""@en ;
  dcterms:modified "2026-02-12T08:59:21.722820Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6152-4
  a curric:KeyLearningPoint ;
  rdfs:label """Illustrations provide visual representations of the characters, settings and events described in the text."""@en ;
  dcterms:modified "2026-02-12T08:59:21.722824Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6152-5
  a curric:KeyLearningPoint ;
  rdfs:label """Illustrations can bring the world of the story to life and make it more vivid in the reader's mind."""@en ;
  dcterms:modified "2026-02-12T08:59:21.722829Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1028-1
  a curric:KeyLearningPoint ;
  rdfs:label """A non-chronological report is a non-fiction text that informs about a subject or event."""@en ;
  dcterms:modified "2026-02-12T08:59:21.722833Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1028-2
  a curric:KeyLearningPoint ;
  rdfs:label """An introduction, two sections and a conclusion is how we can structure a non-chronological report."""@en ;
  dcterms:modified "2026-02-12T08:59:21.722838Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1028-3
  a curric:KeyLearningPoint ;
  rdfs:label "Subheadings are used to signal sections of a non-chronological report."@en ;
  dcterms:modified "2026-02-12T08:59:21.722845Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1028-4
  a curric:KeyLearningPoint ;
  rdfs:label """An introduction contains general facts; specific facts come in the later sections."""@en ;
  dcterms:modified "2026-02-12T08:59:21.722851Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1028-5
  a curric:KeyLearningPoint ;
  rdfs:label "P.A.L.L. helps writers plan, write and edit a text."@en ;
  dcterms:modified "2026-02-12T08:59:21.722856Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1375-1
  a curric:KeyLearningPoint ;
  rdfs:label "The suffixes -ible and -able create adjectives."@en ;
  dcterms:modified "2026-02-12T08:59:21.722860Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1375-2
  a curric:KeyLearningPoint ;
  rdfs:label """Removing the -ible suffix does not usually leave a recognisable root word in English, e.g. visible - vis."""@en ;
  dcterms:modified "2026-02-12T08:59:21.722865Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1375-3
  a curric:KeyLearningPoint ;
  rdfs:label """Adjectives ending in the suffix -ible and adverbs ending in the suffix -ibly are connected in spelling and meaning."""@en ;
  dcterms:modified "2026-02-12T08:59:21.722872Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1375-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: possible, material and straight."@en ;
  dcterms:modified "2026-02-12T08:59:21.722876Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1363-1
  a curric:KeyLearningPoint ;
  rdfs:label "Adding the -ing suffix turns the verb into the progressive tense."@en ;
  dcterms:modified "2026-02-12T08:59:21.722881Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1363-2
  a curric:KeyLearningPoint ;
  rdfs:label "The progressive tense makes use of an auxiliary verb with the main verb."@en ;
  dcterms:modified "2026-02-12T08:59:21.722885Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1363-3
  a curric:KeyLearningPoint ;
  rdfs:label """When adding the suffix -ing, different spelling rules are used depending on the spelling of the root word."""@en ;
  dcterms:modified "2026-02-12T08:59:21.722890Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1363-4
  a curric:KeyLearningPoint ;
  rdfs:label """You can just add ing; remove the 'e', add -ing; or double the consonant, add -ing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.722894Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1363-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: heard, forty and according."@en ;
  dcterms:modified "2026-02-12T08:59:21.722899Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27891-1
  a curric:KeyLearningPoint ;
  rdfs:label "A debate is a structured argument between two teams."@en ;
  dcterms:modified "2026-02-12T08:59:21.723079Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27891-2
  a curric:KeyLearningPoint ;
  rdfs:label "An opinion is a view or belief that a person has."@en ;
  dcterms:modified "2026-02-12T08:59:21.723083Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27891-3
  a curric:KeyLearningPoint ;
  rdfs:label "An important aspect of debating is justifying opinions."@en ;
  dcterms:modified "2026-02-12T08:59:21.723087Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27891-4
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to speak in a loud, clear voice, make eye contact with the audience and stand up straight."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723092Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1346-1
  a curric:KeyLearningPoint ;
  rdfs:label """The suffixes -ant and -ance are used if there is a related word with the 'a' or 'ay' sound in the right position."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723349Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1346-2
  a curric:KeyLearningPoint ;
  rdfs:label """Changing the -ant suffix to -ance can change the word from an adjective to an abstract noun."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723353Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1346-3
  a curric:KeyLearningPoint ;
  rdfs:label "The suffix -ant sometimes becomes -ancy, e.g. pregnant-pregnancy."@en ;
  dcterms:modified "2026-02-12T08:59:21.723360Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1346-4
  a curric:KeyLearningPoint ;
  rdfs:label """Examples of words that do not follow the above guidance and just need to be learned: assistant-assistance."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723367Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1346-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: nuisance, sincere and guarantee."@en ;
  dcterms:modified "2026-02-12T08:59:21.723372Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1439-1
  a curric:KeyLearningPoint ;
  rdfs:label "-ly is a suffix that can be used to create adverbs."@en ;
  dcterms:modified "2026-02-12T08:59:21.723377Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1439-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Colour blocks' is a useful practice strategy."@en ;
  dcterms:modified "2026-02-12T08:59:21.723381Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1439-3
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: eight and weight."@en ;
  dcterms:modified "2026-02-12T08:59:21.723385Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1439-4
  a curric:KeyLearningPoint ;
  rdfs:label "There are four key rules for spelling using the suffix -ly."@en ;
  dcterms:modified "2026-02-12T08:59:21.723390Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4874-1
  a curric:KeyLearningPoint ;
  rdfs:label """A section of a non-chronological report contains specific information for the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723394Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4874-2
  a curric:KeyLearningPoint ;
  rdfs:label """Writers can use a range of cohesive devices to ensure their sentences flow and the text’s purpose is achieved."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723399Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4874-3
  a curric:KeyLearningPoint ;
  rdfs:label """The diet section includes an introductory sentence, followed by specific information, then a linking sentence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723403Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4874-4
  a curric:KeyLearningPoint ;
  rdfs:label """We can use success criteria to help us identify what a successful piece of writing includes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723408Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4874-5
  a curric:KeyLearningPoint ;
  rdfs:label "The writing process involves planning, drafting, editing and publishing."@en ;
  dcterms:modified "2026-02-12T08:59:21.723413Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1370-1
  a curric:KeyLearningPoint ;
  rdfs:label "The suffixes -al and -ic create adjectives."@en ;
  dcterms:modified "2026-02-12T08:59:21.723417Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1370-2
  a curric:KeyLearningPoint ;
  rdfs:label "When the root word ends in a consonant, usually just add the suffix."@en ;
  dcterms:modified "2026-02-12T08:59:21.723421Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1370-3
  a curric:KeyLearningPoint ;
  rdfs:label "When the root word ends in ‘e’, remove the ‘e’ and add the suffix."@en ;
  dcterms:modified "2026-02-12T08:59:21.723426Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1370-4
  a curric:KeyLearningPoint ;
  rdfs:label "When the root word ends in 'y', remove the 'y' and add the suffix -ic."@en ;
  dcterms:modified "2026-02-12T08:59:21.723430Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1370-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: physical, natural and actual."@en ;
  dcterms:modified "2026-02-12T08:59:21.723435Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8026-1
  a curric:KeyLearningPoint ;
  rdfs:label """Performing poetry to an audience is an important part of the process of creating poetry."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723641Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8026-2
  a curric:KeyLearningPoint ;
  rdfs:label """When performing poetry, you can vary your volume, pace and use gestures to have an impact on the audience."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723645Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8026-3
  a curric:KeyLearningPoint ;
  rdfs:label """Deciding upon and creating a desired atmosphere is important when performing poetry."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723650Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8026-4
  a curric:KeyLearningPoint ;
  rdfs:label "We can improve our performances of poetry through practice."@en ;
  dcterms:modified "2026-02-12T08:59:21.723657Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7350-1
  a curric:KeyLearningPoint ;
  rdfs:label """The build-up of ‘A Christmas Carol’ creates an eerie atmosphere leading up to the Ghost of Marley appearing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.724189Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7350-2
  a curric:KeyLearningPoint ;
  rdfs:label "A key feature of the build-up is the building of suspense for the reader."@en ;
  dcterms:modified "2026-02-12T08:59:21.724193Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7350-3
  a curric:KeyLearningPoint ;
  rdfs:label """The build-up will be written over two paragraphs where the suspense gradually increases."""@en ;
  dcterms:modified "2026-02-12T08:59:21.724197Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7350-4
  a curric:KeyLearningPoint ;
  rdfs:label """The use of precise vocabulary describing a range of sensory details helps to convey an eerie atmosphere."""@en ;
  dcterms:modified "2026-02-12T08:59:21.724202Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7350-5
  a curric:KeyLearningPoint ;
  rdfs:label """The use of ‘show and tell’ to describe Scrooge’s experiences conveys his emotions and supports in building suspense."""@en ;
  dcterms:modified "2026-02-12T08:59:21.724206Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1333-1
  a curric:KeyLearningPoint ;
  rdfs:label "Regular plurals follow spelling rules."@en ;
  dcterms:modified "2026-02-12T08:59:21.724211Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1333-2
  a curric:KeyLearningPoint ;
  rdfs:label "There are no rules for irregular plurals; you just have to learn them."@en ;
  dcterms:modified "2026-02-12T08:59:21.724215Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1333-3
  a curric:KeyLearningPoint ;
  rdfs:label """Examples of irregular plural nouns include: formula - formulae, woman - women, tooth - teeth, index - indices."""@en ;
  dcterms:modified "2026-02-12T08:59:21.724220Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1333-4
  a curric:KeyLearningPoint ;
  rdfs:label "We can look for naughty letters to help us to remember tricky spellings."@en ;
  dcterms:modified "2026-02-12T08:59:21.724224Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1333-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: equip and equipment."@en ;
  dcterms:modified "2026-02-12T08:59:21.724228Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6723-1
  a curric:KeyLearningPoint ;
  rdfs:label "Presenting our ideas orally is a way of showing our understanding of a subject."@en ;
  dcterms:modified "2026-02-12T08:59:21.724419Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6723-2
  a curric:KeyLearningPoint ;
  rdfs:label """Speaking to a group can be stressful; making notes and rehearsing first makes it easier."""@en ;
  dcterms:modified "2026-02-12T08:59:21.724424Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6723-3
  a curric:KeyLearningPoint ;
  rdfs:label """We can use fronted adverbials of cause to show causal relationships between steps in an explanation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.724429Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6723-4
  a curric:KeyLearningPoint ;
  rdfs:label """When we present, we use clear diction, appropriate volume, positive body language and eye contact to engage an audience."""@en ;
  dcterms:modified "2026-02-12T08:59:21.724433Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6723-5
  a curric:KeyLearningPoint ;
  rdfs:label """Darwin's theory of evolution by natural selection can be applied to any animal adaptation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.724437Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4703-1
  a curric:KeyLearningPoint ;
  rdfs:label "A point of information is a brief attempted interruption of someone’s speech."@en ;
  dcterms:modified "2026-02-12T08:59:21.724442Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4703-2
  a curric:KeyLearningPoint ;
  rdfs:label "A point of information is similar to a rebuttal."@en ;
  dcterms:modified "2026-02-12T08:59:21.724446Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6364-1
  a curric:KeyLearningPoint ;
  rdfs:label """Oral presentation is an important aspect of delivering journalistic reports and news."""@en ;
  dcterms:modified "2026-02-12T08:59:21.724450Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6364-2
  a curric:KeyLearningPoint ;
  rdfs:label """Projection, pace and diction are important for ensuring the audience can hear and understand you."""@en ;
  dcterms:modified "2026-02-12T08:59:21.724455Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6364-3
  a curric:KeyLearningPoint ;
  rdfs:label """Eye contact, body language and tone are important for connecting to the audience and conveying a topic appropriately"""@en ;
  dcterms:modified "2026-02-12T08:59:21.724459Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6364-4
  a curric:KeyLearningPoint ;
  rdfs:label """Reading over our writing and rehearsing it supports the successful delivery of an oral presentation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.724464Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27609-1
  a curric:KeyLearningPoint ;
  rdfs:label """Doing rehearsals will help you to reflect on your performance and improve before delivering it to an audience."""@en ;
  dcterms:modified "2026-02-12T08:59:21.724468Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27609-2
  a curric:KeyLearningPoint ;
  rdfs:label """Changes in voice, facial expressions and body language are used to tell a story with charisma."""@en ;
  dcterms:modified "2026-02-12T08:59:21.724472Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27609-3
  a curric:KeyLearningPoint ;
  rdfs:label """There are general techniques used for any oral presentation to ensure the audience can hear you and is engaged."""@en ;
  dcterms:modified "2026-02-12T08:59:21.724476Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27609-4
  a curric:KeyLearningPoint ;
  rdfs:label """How you orally tell a story changes throughout the different sections of a story to meet the purpose."""@en ;
  dcterms:modified "2026-02-12T08:59:21.724481Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3459-1
  a curric:KeyLearningPoint ;
  rdfs:label "A colon is a piece of punctuation with more than one purpose."@en ;
  dcterms:modified "2026-02-12T08:59:21.724488Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3459-2
  a curric:KeyLearningPoint ;
  rdfs:label "A colon is always placed after a main clause."@en ;
  dcterms:modified "2026-02-12T08:59:21.724492Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3459-3
  a curric:KeyLearningPoint ;
  rdfs:label "A colon can introduce an explanation of the noun preceding it."@en ;
  dcterms:modified "2026-02-12T08:59:21.724497Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3459-4
  a curric:KeyLearningPoint ;
  rdfs:label "A colon can help to improve text cohesion."@en ;
  dcterms:modified "2026-02-12T08:59:21.724503Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1053-1
  a curric:KeyLearningPoint ;
  rdfs:label "An apostrophe is an important piece of punctuation."@en ;
  dcterms:modified "2026-02-12T08:59:21.724508Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1053-2
  a curric:KeyLearningPoint ;
  rdfs:label "An apostrophe has more than one purpose."@en ;
  dcterms:modified "2026-02-12T08:59:21.724513Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1053-3
  a curric:KeyLearningPoint ;
  rdfs:label "An apostrophe can show if a noun belongs to another plural noun."@en ;
  dcterms:modified "2026-02-12T08:59:21.724517Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1053-4
  a curric:KeyLearningPoint ;
  rdfs:label "Apostrophes for plural possession are useful to make our meaning clear."@en ;
  dcterms:modified "2026-02-12T08:59:21.724521Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1053-5
  a curric:KeyLearningPoint ;
  rdfs:label "An apostrophe sits at the same height as the ascender of a letter."@en ;
  dcterms:modified "2026-02-12T08:59:21.724526Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6215-1
  a curric:KeyLearningPoint ;
  rdfs:label """Essays can either examine both sides of an issue in a balanced way, or they can argue persuasively on one side only."""@en ;
  dcterms:modified "2026-02-12T08:59:21.724532Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6215-2
  a curric:KeyLearningPoint ;
  rdfs:label "Essays include subject-specific language and they are written in formal tone."@en ;
  dcterms:modified "2026-02-12T08:59:21.724537Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6215-3
  a curric:KeyLearningPoint ;
  rdfs:label "A one-sided essay presents a logical argument that reveals a series of points."@en ;
  dcterms:modified "2026-02-12T08:59:21.724541Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6215-4
  a curric:KeyLearningPoint ;
  rdfs:label """Points made within essays must be explained and backed up by evidence in order to be effective."""@en ;
  dcterms:modified "2026-02-12T08:59:21.724546Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6215-5
  a curric:KeyLearningPoint ;
  rdfs:label """A range of fronted adverbials, sentence types and parenthesis in brackets are linguistic features of essays."""@en ;
  dcterms:modified "2026-02-12T08:59:21.724550Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7352-1
  a curric:KeyLearningPoint ;
  rdfs:label """The second paragraph of the build-up heightens the suspense and reveals the Ghost of Jacob Marley."""@en ;
  dcterms:modified "2026-02-12T08:59:21.724838Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7352-2
  a curric:KeyLearningPoint ;
  rdfs:label """Precise vocabulary is used to describe sensory details and ‘show and tell’ conveys Scrooge’s emotions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.725246Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7352-3
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials of time, place and manner add greater detail to the main clause and support in building suspense."""@en ;
  dcterms:modified "2026-02-12T08:59:21.725251Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7352-4
  a curric:KeyLearningPoint ;
  rdfs:label """Marley informs Scrooge of the visits he will be paid by the Ghosts of Christmas Past, Present and Future."""@en ;
  dcterms:modified "2026-02-12T08:59:21.725256Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7352-5
  a curric:KeyLearningPoint ;
  rdfs:label """Reported speech is used to share the important messages Marley conveys without quoting him directly."""@en ;
  dcterms:modified "2026-02-12T08:59:21.725260Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1325-1
  a curric:KeyLearningPoint ;
  rdfs:label """Two or more words that sound the same but have different meanings or spellings are called homophones."""@en ;
  dcterms:modified "2026-02-12T08:59:21.725266Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1325-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Whose' and 'who's' are homophones."@en ;
  dcterms:modified "2026-02-12T08:59:21.725271Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1325-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Stationary' and 'stationery' are homophones."@en ;
  dcterms:modified "2026-02-12T08:59:21.725276Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1325-4
  a curric:KeyLearningPoint ;
  rdfs:label "We can look for naughty letters to help us to remember tricky spellings."@en ;
  dcterms:modified "2026-02-12T08:59:21.725282Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1325-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: according and individual."@en ;
  dcterms:modified "2026-02-12T08:59:21.725287Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1338-1
  a curric:KeyLearningPoint ;
  rdfs:label "If the root word ends in 'tion', use the suffix -tious."@en ;
  dcterms:modified "2026-02-12T08:59:21.725291Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1338-2
  a curric:KeyLearningPoint ;
  rdfs:label "Exceptions or harder root words include: fictitious."@en ;
  dcterms:modified "2026-02-12T08:59:21.725296Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1338-3
  a curric:KeyLearningPoint ;
  rdfs:label "The suffix -tious generally turns a noun into an adjective."@en ;
  dcterms:modified "2026-02-12T08:59:21.725300Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1338-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: conscious and embarrass"@en ;
  dcterms:modified "2026-02-12T08:59:21.725304Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6007-1
  a curric:KeyLearningPoint ;
  rdfs:label "A formal letter should be written using a formal tone."@en ;
  dcterms:modified "2026-02-12T08:59:21.725309Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6007-2
  a curric:KeyLearningPoint ;
  rdfs:label "A formal letter has specific layout features."@en ;
  dcterms:modified "2026-02-12T08:59:21.725316Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6007-3
  a curric:KeyLearningPoint ;
  rdfs:label """An introduction contains three sentences: one introductory, one setting-up the argument & one sharing the purpose."""@en ;
  dcterms:modified "2026-02-12T08:59:21.725320Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1029-1
  a curric:KeyLearningPoint ;
  rdfs:label "Linguistic features are structures of language that use words."@en ;
  dcterms:modified "2026-02-12T08:59:21.725327Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1029-2
  a curric:KeyLearningPoint ;
  rdfs:label "Subject-specific vocabulary is used in a non-chronological report."@en ;
  dcterms:modified "2026-02-12T08:59:21.725332Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1029-3
  a curric:KeyLearningPoint ;
  rdfs:label "Expanded noun phrases list two adjectives that describe a noun."@en ;
  dcterms:modified "2026-02-12T08:59:21.725336Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1029-4
  a curric:KeyLearningPoint ;
  rdfs:label """There are different types of fronted adverbials that do different things for the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.725341Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1029-5
  a curric:KeyLearningPoint ;
  rdfs:label "Language in a non-chronological report is formal and factual."@en ;
  dcterms:modified "2026-02-12T08:59:21.725345Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1033-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the section is to inform the reader of a Portia spider's hunting style and diet."""@en ;
  dcterms:modified "2026-02-12T08:59:21.725349Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1033-2
  a curric:KeyLearningPoint ;
  rdfs:label """Portia spiders hunt in two ways: abseiling and attacking their prey and plucking the web to imitate a trapped spider."""@en ;
  dcterms:modified "2026-02-12T08:59:21.725356Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1033-3
  a curric:KeyLearningPoint ;
  rdfs:label """Precise, factual verbs are needed to accurately describe the way the spider hunts its prey."""@en ;
  dcterms:modified "2026-02-12T08:59:21.725361Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1033-4
  a curric:KeyLearningPoint ;
  rdfs:label """Notes are taken out of full sentences and they capture the most important facts for writing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.725365Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1033-5
  a curric:KeyLearningPoint ;
  rdfs:label "A subheading is useful to organise notes in a plan."@en ;
  dcterms:modified "2026-02-12T08:59:21.725373Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1388-1
  a curric:KeyLearningPoint ;
  rdfs:label """Soft c and hard c refer to two different sounds that the letter c can represent, depending on what follows it."""@en ;
  dcterms:modified "2026-02-12T08:59:21.726038Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1388-2
  a curric:KeyLearningPoint ;
  rdfs:label """If the vowel letters ‘a’, ‘o’ or ‘u’ or a consonant letter follows the letter c it is pronounced as a hard c."""@en ;
  dcterms:modified "2026-02-12T08:59:21.726046Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1388-3
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: calendar, occur and occupy."@en ;
  dcterms:modified "2026-02-12T08:59:21.726051Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2731-1
  a curric:KeyLearningPoint ;
  rdfs:label "A sentence composed of one main clause is a simple sentence."@en ;
  dcterms:modified "2026-02-12T08:59:21.726056Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2731-2
  a curric:KeyLearningPoint ;
  rdfs:label """A sentence composed of at least two main clauses joined by a co-ordinating conjunction is a compound sentence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.726060Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2731-3
  a curric:KeyLearningPoint ;
  rdfs:label """A sentence composed of at least one main clause and an adverbial subordinate clause is an adverbial complex sentence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.726065Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2731-4
  a curric:KeyLearningPoint ;
  rdfs:label """A sentence composed of at least one main clause and a relative subordinate clause is a relative complex sentence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.726069Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2731-5
  a curric:KeyLearningPoint ;
  rdfs:label """Specific comma rules apply to the demarcation of clauses in compound and complex sentence structures."""@en ;
  dcterms:modified "2026-02-12T08:59:21.726073Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1328-1
  a curric:KeyLearningPoint ;
  rdfs:label """If the root word contains a short vowel sound, double the consonant and add the suffix -ed."""@en ;
  dcterms:modified "2026-02-12T08:59:21.726078Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1328-2
  a curric:KeyLearningPoint ;
  rdfs:label """If the root word ends in 'y', remove the 'y' and add -ied unless there is a vowel before the 'y'."""@en ;
  dcterms:modified "2026-02-12T08:59:21.726082Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1328-3
  a curric:KeyLearningPoint ;
  rdfs:label "If the root word is a verb that ends in 'e', remove the 'e' and add -ed."@en ;
  dcterms:modified "2026-02-12T08:59:21.726086Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1328-4
  a curric:KeyLearningPoint ;
  rdfs:label """There are specific rules for words containing the stressed or unstressed 'fer' spelling."""@en ;
  dcterms:modified "2026-02-12T08:59:21.726091Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1328-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: determined, suggest."@en ;
  dcterms:modified "2026-02-12T08:59:21.726095Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1329-1
  a curric:KeyLearningPoint ;
  rdfs:label """If the root word contains a short vowel sound, double the consonant and add the suffix -ing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.726100Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1329-2
  a curric:KeyLearningPoint ;
  rdfs:label "If the root word ends in 'y', just add the suffix -ing."@en ;
  dcterms:modified "2026-02-12T08:59:21.726104Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1329-3
  a curric:KeyLearningPoint ;
  rdfs:label """If the root word is a verb that ends in 'e', remove the 'e' and add the suffix -ing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.726108Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1329-4
  a curric:KeyLearningPoint ;
  rdfs:label """There are specific rules for words containing the stressed or unstressed 'fer' spelling."""@en ;
  dcterms:modified "2026-02-12T08:59:21.726112Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1329-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: appreciate, curiosity."@en ;
  dcterms:modified "2026-02-12T08:59:21.726117Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1348-1
  a curric:KeyLearningPoint ;
  rdfs:label """The -able and -ably endings are the most common spellings for this sound and are therefore the best bet."""@en ;
  dcterms:modified "2026-02-12T08:59:21.726121Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1348-2
  a curric:KeyLearningPoint ;
  rdfs:label """Removing the -able suffix generally leaves a recognisable word, e.g. understand - understandable"""@en ;
  dcterms:modified "2026-02-12T08:59:21.726128Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1348-3
  a curric:KeyLearningPoint ;
  rdfs:label """Words in word families using the suffixes -ation, -able and -ably are connected in spelling and meaning."""@en ;
  dcterms:modified "2026-02-12T08:59:21.726135Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1348-4
  a curric:KeyLearningPoint ;
  rdfs:label """Drop the final -e of the root word before adding the suffix -able unless the words end in -ce or -ge"""@en ;
  dcterms:modified "2026-02-12T08:59:21.726140Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1348-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: privilege, system."@en ;
  dcterms:modified "2026-02-12T08:59:21.726144Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1440-1
  a curric:KeyLearningPoint ;
  rdfs:label """-ful and -less are suffixes that can be used to change the meaning of a root word."""@en ;
  dcterms:modified "2026-02-12T08:59:21.726148Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1440-2
  a curric:KeyLearningPoint ;
  rdfs:label "Some root words can use the suffixes -ful and -less."@en ;
  dcterms:modified "2026-02-12T08:59:21.726153Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1440-3
  a curric:KeyLearningPoint ;
  rdfs:label """The -less and -ful suffixes start with a consonant, so the root word usually doesn’t change when the suffix is added."""@en ;
  dcterms:modified "2026-02-12T08:59:21.726157Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1440-4
  a curric:KeyLearningPoint ;
  rdfs:label """If the root word has more than one syllable and ends in a consonant +y, then ‘y’ is replaced by ‘i’ before the suffix."""@en ;
  dcterms:modified "2026-02-12T08:59:21.726162Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1440-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: reign and island."@en ;
  dcterms:modified "2026-02-12T08:59:21.726166Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4896-1
  a curric:KeyLearningPoint ;
  rdfs:label "Editing is an essential part of the writing process."@en ;
  dcterms:modified "2026-02-12T08:59:21.726172Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4896-2
  a curric:KeyLearningPoint ;
  rdfs:label """Editing does not involve rewriting the entire piece but being selective about what to edit and improve."""@en ;
  dcterms:modified "2026-02-12T08:59:21.726177Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4896-3
  a curric:KeyLearningPoint ;
  rdfs:label """Punctuation, sentence structure, grammar, vocabulary precision and spelling can all be edited."""@en ;
  dcterms:modified "2026-02-12T08:59:21.726182Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4896-4
  a curric:KeyLearningPoint ;
  rdfs:label "The purpose of editing is to ensure the text meets its text purpose."@en ;
  dcterms:modified "2026-02-12T08:59:21.726186Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4899-1
  a curric:KeyLearningPoint ;
  rdfs:label "The conclusion is the final paragraph of a non-chronological report."@en ;
  dcterms:modified "2026-02-12T08:59:21.726191Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4899-2
  a curric:KeyLearningPoint ;
  rdfs:label "The purpose of the conclusion is to summarise the key information of the report."@en ;
  dcterms:modified "2026-02-12T08:59:21.726197Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4899-3
  a curric:KeyLearningPoint ;
  rdfs:label "Only general information is included in the conclusion."@en ;
  dcterms:modified "2026-02-12T08:59:21.726202Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4899-4
  a curric:KeyLearningPoint ;
  rdfs:label """Success criteria can be used to help a writer understand what to include in their writing to make it successful."""@en ;
  dcterms:modified "2026-02-12T08:59:21.726206Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1433-1
  a curric:KeyLearningPoint ;
  rdfs:label "-es is a suffix that can turn a singular noun into a plural."@en ;
  dcterms:modified "2026-02-12T08:59:21.726211Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1433-2
  a curric:KeyLearningPoint ;
  rdfs:label "Using the strategy 'pyramid letters' is a useful practice strategy."@en ;
  dcterms:modified "2026-02-12T08:59:21.726217Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1433-3
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum word: learn."@en ;
  dcterms:modified "2026-02-12T08:59:21.726222Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7346-1
  a curric:KeyLearningPoint ;
  rdfs:label "‘A Christmas Carol’ is set in Victorian London during the Christmas period."@en ;
  dcterms:modified "2026-02-12T08:59:21.726501Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7346-2
  a curric:KeyLearningPoint ;
  rdfs:label "The atmosphere is the tone or mood created in a narrative."@en ;
  dcterms:modified "2026-02-12T08:59:21.726506Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7346-3
  a curric:KeyLearningPoint ;
  rdfs:label """Precise vocabulary, including a range of sensory details, conveys the atmosphere in a narrative setting description."""@en ;
  dcterms:modified "2026-02-12T08:59:21.726510Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7346-4
  a curric:KeyLearningPoint ;
  rdfs:label """Personification is a linguistic device used to describe a non-living thing as if it acts or feels like a human."""@en ;
  dcterms:modified "2026-02-12T08:59:21.726514Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1356-1
  a curric:KeyLearningPoint ;
  rdfs:label "A hyphen can be used to join a prefix to a root word but there are no set rules."@en ;
  dcterms:modified "2026-02-12T08:59:21.726519Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1356-2
  a curric:KeyLearningPoint ;
  rdfs:label """Hyphens are more commonly used to prevent two vowels appearing next to each other e.g. re-enter and co-ordinate."""@en ;
  dcterms:modified "2026-02-12T08:59:21.726526Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1356-3
  a curric:KeyLearningPoint ;
  rdfs:label """Hyphens are often used with the prefixes ex- and self- e.g. ex-president and self-care."""@en ;
  dcterms:modified "2026-02-12T08:59:21.726530Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1356-4
  a curric:KeyLearningPoint ;
  rdfs:label """Hyphens can join a prefix to a root word to avoid ambiguity in meaning e.g. re-cover or recover."""@en ;
  dcterms:modified "2026-02-12T08:59:21.726535Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1356-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: interrupt and exaggerate."@en ;
  dcterms:modified "2026-02-12T08:59:21.726539Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1424-1
  a curric:KeyLearningPoint ;
  rdfs:label """A suffix is a letter or group of letters at the end of a word which creates another word."""@en ;
  dcterms:modified "2026-02-12T08:59:21.726543Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1424-2
  a curric:KeyLearningPoint ;
  rdfs:label "-ed is a suffix that can be used to create the past tense."@en ;
  dcterms:modified "2026-02-12T08:59:21.726548Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1424-3
  a curric:KeyLearningPoint ;
  rdfs:label "Some root words just add -ed to create the past tense."@en ;
  dcterms:modified "2026-02-12T08:59:21.726553Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1424-4
  a curric:KeyLearningPoint ;
  rdfs:label """Some root words lose the final e and add the suffix -ed to create the past tense."""@en ;
  dcterms:modified "2026-02-12T08:59:21.726557Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1424-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum word: circle."@en ;
  dcterms:modified "2026-02-12T08:59:21.726569Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2702-1
  a curric:KeyLearningPoint ;
  rdfs:label "A relative clause joined to a main clause forms a relative complex sentence."@en ;
  dcterms:modified "2026-02-12T08:59:21.727290Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2702-2
  a curric:KeyLearningPoint ;
  rdfs:label "The relative clause often interrupts the main clause."@en ;
  dcterms:modified "2026-02-12T08:59:21.727297Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2702-3
  a curric:KeyLearningPoint ;
  rdfs:label """A relative clause often interrupts after the subject of the main clause at the start of the sentence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.727301Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2702-4
  a curric:KeyLearningPoint ;
  rdfs:label """A pair of commas is used around the relative clause to demarcate it from the main clause."""@en ;
  dcterms:modified "2026-02-12T08:59:21.727306Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2700-1
  a curric:KeyLearningPoint ;
  rdfs:label """Any subordinate clause is a group of words that contains a verb and does not make complete sense."""@en ;
  dcterms:modified "2026-02-12T08:59:21.727310Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2700-2
  a curric:KeyLearningPoint ;
  rdfs:label "Any subordinate clause must join to a main clause to make sense."@en ;
  dcterms:modified "2026-02-12T08:59:21.727315Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2700-3
  a curric:KeyLearningPoint ;
  rdfs:label """A relative clause is a type of subordinate clause which starts with a relative pronoun."""@en ;
  dcterms:modified "2026-02-12T08:59:21.727319Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2700-4
  a curric:KeyLearningPoint ;
  rdfs:label """A previously-learnt type of subordinate clause is the adverbial clause that starts with a subordinating conjunction."""@en ;
  dcterms:modified "2026-02-12T08:59:21.727323Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1051-1
  a curric:KeyLearningPoint ;
  rdfs:label "Direct speech is the term used for a character speaking out loud in a text."@en ;
  dcterms:modified "2026-02-12T08:59:21.727328Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1051-2
  a curric:KeyLearningPoint ;
  rdfs:label "There is a set of rules for how to accurately punctuate direct speech."@en ;
  dcterms:modified "2026-02-12T08:59:21.727332Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1051-3
  a curric:KeyLearningPoint ;
  rdfs:label """Inverted commas are the punctuation marks that signal direct speech to the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.727336Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1051-4
  a curric:KeyLearningPoint ;
  rdfs:label "The speech sentence spoken by a character must start with a capital letter."@en ;
  dcterms:modified "2026-02-12T08:59:21.727341Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1051-5
  a curric:KeyLearningPoint ;
  rdfs:label """If direct speech comes first in a sentence with the reporting clause second, it can be called a speech first sentence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.727345Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5814-1
  a curric:KeyLearningPoint ;
  rdfs:label "We have planned the structure, content and vocabulary for our narrative."@en ;
  dcterms:modified "2026-02-12T08:59:21.727349Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5814-2
  a curric:KeyLearningPoint ;
  rdfs:label """When we write, we use cohesive devices to connect our plan notes together into coherent sentences."""@en ;
  dcterms:modified "2026-02-12T08:59:21.727354Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5814-3
  a curric:KeyLearningPoint ;
  rdfs:label "We can use fronted adverbials of time to add pace to our writing."@en ;
  dcterms:modified "2026-02-12T08:59:21.727358Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5814-4
  a curric:KeyLearningPoint ;
  rdfs:label """We should aim to include all the narrative elements of action, description, dialogue and emotions in our writing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.727362Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5814-5
  a curric:KeyLearningPoint ;
  rdfs:label "Oral rehearsal prior to writing helps us to write more easily."@en ;
  dcterms:modified "2026-02-12T08:59:21.727369Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2710-1
  a curric:KeyLearningPoint ;
  rdfs:label """Prepositions tell the reader where or when something is in relation to something else."""@en ;
  dcterms:modified "2026-02-12T08:59:21.727373Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2710-2
  a curric:KeyLearningPoint ;
  rdfs:label "Prepositions can indicate time, place or cause."@en ;
  dcterms:modified "2026-02-12T08:59:21.727378Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2710-3
  a curric:KeyLearningPoint ;
  rdfs:label "Prepositions can be single words or groups of words."@en ;
  dcterms:modified "2026-02-12T08:59:21.727385Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2710-4
  a curric:KeyLearningPoint ;
  rdfs:label "A phrase is a group of words with no verb."@en ;
  dcterms:modified "2026-02-12T08:59:21.727389Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6593-1
  a curric:KeyLearningPoint ;
  rdfs:label """In the sections, writers share detailed, specific information about an aspect of the person's life with the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.727393Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6593-2
  a curric:KeyLearningPoint ;
  rdfs:label """Section paragraphs can include a topic sentence, specific information and a linking sentence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.727398Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6593-3
  a curric:KeyLearningPoint ;
  rdfs:label """The introductory sentence indicates what the paragraph will be about and linking sentence links onto the next paragraph."""@en ;
  dcterms:modified "2026-02-12T08:59:21.727402Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6593-4
  a curric:KeyLearningPoint ;
  rdfs:label "When planning, we should record ideas in concise, bullet-pointed notes."@en ;
  dcterms:modified "2026-02-12T08:59:21.727407Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6557-1
  a curric:KeyLearningPoint ;
  rdfs:label "Speakers must speak audibly and fluently to communicate meaning clearly."@en ;
  dcterms:modified "2026-02-12T08:59:21.727411Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6557-2
  a curric:KeyLearningPoint ;
  rdfs:label "Speaking in an appropriate register enhances communication."@en ;
  dcterms:modified "2026-02-12T08:59:21.727416Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6557-3
  a curric:KeyLearningPoint ;
  rdfs:label """Text meaning and the reader's emotions can be shown through intonation, tone, volume and gestures."""@en ;
  dcterms:modified "2026-02-12T08:59:21.727420Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6557-4
  a curric:KeyLearningPoint ;
  rdfs:label "Facial expressions can be used to convey emotions."@en ;
  dcterms:modified "2026-02-12T08:59:21.727424Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1384-1
  a curric:KeyLearningPoint ;
  rdfs:label """There are many ways to spell the ‘ee’ sound. ‘ee’, ‘ea’ and ‘e-e’ are the most common."""@en ;
  dcterms:modified "2026-02-12T08:59:21.727828Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1384-2
  a curric:KeyLearningPoint ;
  rdfs:label """The spellings ‘e’, ‘y’, ‘ey’, ‘ie’ and ‘ei’ are other ways to represent the ‘ee’ phoneme."""@en ;
  dcterms:modified "2026-02-12T08:59:21.727833Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1384-3
  a curric:KeyLearningPoint ;
  rdfs:label """The rule ‘i before e except after c’ can help us choose between ‘ie’ and ‘ei’ when spelling ‘ee’."""@en ;
  dcterms:modified "2026-02-12T08:59:21.727838Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1384-4
  a curric:KeyLearningPoint ;
  rdfs:label "There are exceptions, including ‘protein’, ‘caffeine’ and ‘seize’."@en ;
  dcterms:modified "2026-02-12T08:59:21.727842Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1384-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: achieve, believe and possess."@en ;
  dcterms:modified "2026-02-12T08:59:21.727847Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1408-1
  a curric:KeyLearningPoint ;
  rdfs:label "It is common to see a ‘c’ or a ‘t’ before the suffix -ial"@en ;
  dcterms:modified "2026-02-12T08:59:21.727851Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1408-2
  a curric:KeyLearningPoint ;
  rdfs:label "The /shul/ ending can be spelt -cial or -tial"@en ;
  dcterms:modified "2026-02-12T08:59:21.727855Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1408-3
  a curric:KeyLearningPoint ;
  rdfs:label "If the letter before the /shul/ ending is a consonant, -tial is usually used"@en ;
  dcterms:modified "2026-02-12T08:59:21.727860Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1408-4
  a curric:KeyLearningPoint ;
  rdfs:label "If the letter before the /shul/ ending is a vowel, -cial is usually used"@en ;
  dcterms:modified "2026-02-12T08:59:21.727864Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1408-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: breathe and library"@en ;
  dcterms:modified "2026-02-12T08:59:21.727868Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6356-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of a journalistic report is to provide information about a newsworthy event to its reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.727873Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6356-2
  a curric:KeyLearningPoint ;
  rdfs:label """A newsworthy event is something that is interesting or important enough to warrant reporting to the public."""@en ;
  dcterms:modified "2026-02-12T08:59:21.727880Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6356-3
  a curric:KeyLearningPoint ;
  rdfs:label """Journalistic reports follow a specific structure; headline, opening, recount, quotes and closing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.727884Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6356-4
  a curric:KeyLearningPoint ;
  rdfs:label "Journalistic reports are written using formal and objective language and tone."@en ;
  dcterms:modified "2026-02-12T08:59:21.727889Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6356-5
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials and complex sentences are key linguistic features of a journalistic report."""@en ;
  dcterms:modified "2026-02-12T08:59:21.727893Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2736-1
  a curric:KeyLearningPoint ;
  rdfs:label "Determiners are a word class."@en ;
  dcterms:modified "2026-02-12T08:59:21.727897Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2736-2
  a curric:KeyLearningPoint ;
  rdfs:label "A determiner introduces a noun in a clause or phrase."@en ;
  dcterms:modified "2026-02-12T08:59:21.727902Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2736-3
  a curric:KeyLearningPoint ;
  rdfs:label "Determiners can be articles or possessive pronouns."@en ;
  dcterms:modified "2026-02-12T08:59:21.727906Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2736-4
  a curric:KeyLearningPoint ;
  rdfs:label """Articles determine the specificity of a noun whilst possessive pronouns determine the owner of a noun."""@en ;
  dcterms:modified "2026-02-12T08:59:21.727913Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2736-5
  a curric:KeyLearningPoint ;
  rdfs:label """A determiner may be followed by an adjective or pair of adjectives then the noun."""@en ;
  dcterms:modified "2026-02-12T08:59:21.727917Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27901-1
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to speak clearly and use precise, concise language to convey your thoughts and ideas effectively."""@en ;
  dcterms:modified "2026-02-12T08:59:21.728193Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27901-2
  a curric:KeyLearningPoint ;
  rdfs:label """Articulating yourself well can help to communicate ideas and build stronger relationships."""@en ;
  dcterms:modified "2026-02-12T08:59:21.728197Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27901-3
  a curric:KeyLearningPoint ;
  rdfs:label """Being articulate enables us to advocate for ourselves, stand up for our rights and support others who may need help."""@en ;
  dcterms:modified "2026-02-12T08:59:21.728201Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27901-4
  a curric:KeyLearningPoint ;
  rdfs:label """When we advocate for ourselves and others, we can be polite and express gratitude as well as saying what we need."""@en ;
  dcterms:modified "2026-02-12T08:59:21.728206Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4873-1
  a curric:KeyLearningPoint ;
  rdfs:label "Related information is grouped into paragraphs and organised using a subheading."@en ;
  dcterms:modified "2026-02-12T08:59:21.728210Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4873-2
  a curric:KeyLearningPoint ;
  rdfs:label "An introductory sentence explains what the paragraph is about."@en ;
  dcterms:modified "2026-02-12T08:59:21.728214Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4873-3
  a curric:KeyLearningPoint ;
  rdfs:label "Relative clauses give additional detail about the sentence’s subject."@en ;
  dcterms:modified "2026-02-12T08:59:21.728221Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4873-4
  a curric:KeyLearningPoint ;
  rdfs:label "Apostrophes are used to indicate plural possession."@en ;
  dcterms:modified "2026-02-12T08:59:21.728228Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4873-5
  a curric:KeyLearningPoint ;
  rdfs:label """Referring to tigers using other nouns enhances text cohesion and avoids repetition."""@en ;
  dcterms:modified "2026-02-12T08:59:21.728232Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6146-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of a narrative opening is to introduce the characters and to describe the setting to the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.728237Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6146-2
  a curric:KeyLearningPoint ;
  rdfs:label "Saying sentences aloud before they are written helps to check for sense."@en ;
  dcterms:modified "2026-02-12T08:59:21.728241Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6146-3
  a curric:KeyLearningPoint ;
  rdfs:label """Using the full range of sentence types (simple, compound and complex) improves text flow for the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.728246Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6146-4
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials of time, place and manner add extra detail to the main clause."""@en ;
  dcterms:modified "2026-02-12T08:59:21.728250Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6146-5
  a curric:KeyLearningPoint ;
  rdfs:label """'Show-not-tell' language shows a character’s feelings by describing their actions, body language and facial expressions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.728256Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1371-1
  a curric:KeyLearningPoint ;
  rdfs:label "The suffixes -less and -ful create adjectives."@en ;
  dcterms:modified "2026-02-12T08:59:21.728261Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1371-2
  a curric:KeyLearningPoint ;
  rdfs:label """The suffix -ful means ‘full of’ or ‘having qualities of’ and the suffix -less means ‘without’ or ‘lacking’."""@en ;
  dcterms:modified "2026-02-12T08:59:21.728266Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1371-3
  a curric:KeyLearningPoint ;
  rdfs:label """The suffixes start with a consonant. This means the root word usually doesn’t change when the suffix is added."""@en ;
  dcterms:modified "2026-02-12T08:59:21.728270Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1371-4
  a curric:KeyLearningPoint ;
  rdfs:label """If the root word  ends in a consonant +y, then the ‘y’ is replaced by ‘i’ before the suffix."""@en ;
  dcterms:modified "2026-02-12T08:59:21.728274Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1371-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: awkward, bruise, regular and therefore."@en ;
  dcterms:modified "2026-02-12T08:59:21.728279Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1374-1
  a curric:KeyLearningPoint ;
  rdfs:label "Most words in English with the -able or -ible suffix will use -able."@en ;
  dcterms:modified "2026-02-12T08:59:21.728283Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1374-2
  a curric:KeyLearningPoint ;
  rdfs:label """Removing the -able suffix generally leaves a recognisable word, e.g. agreeable - agree."""@en ;
  dcterms:modified "2026-02-12T08:59:21.728288Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1374-3
  a curric:KeyLearningPoint ;
  rdfs:label """Words in word families using the suffixes -ation, -able and -ably are connected in spelling and meaning."""@en ;
  dcterms:modified "2026-02-12T08:59:21.728292Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1374-4
  a curric:KeyLearningPoint ;
  rdfs:label "If the root word ends in ‘ce’ or ‘ge’, keep the ‘e’ before adding -able."@en ;
  dcterms:modified "2026-02-12T08:59:21.728297Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1374-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words:  symbol, system and identity."@en ;
  dcterms:modified "2026-02-12T08:59:21.728301Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1307-1
  a curric:KeyLearningPoint ;
  rdfs:label "The suffix -en often turns adjectives and nouns into verbs."@en ;
  dcterms:modified "2026-02-12T08:59:21.728305Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1307-2
  a curric:KeyLearningPoint ;
  rdfs:label "When the root word ends in a consonant, we often just add the suffix."@en ;
  dcterms:modified "2026-02-12T08:59:21.728310Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1307-3
  a curric:KeyLearningPoint ;
  rdfs:label """When the root word ends in a vowel, we remove the final vowel and add the suffix."""@en ;
  dcterms:modified "2026-02-12T08:59:21.728314Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1307-4
  a curric:KeyLearningPoint ;
  rdfs:label """When the root word ends in a consonant with a short vowel, we double the consonant and add the suffix."""@en ;
  dcterms:modified "2026-02-12T08:59:21.728318Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1307-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: consider, interest and history."@en ;
  dcterms:modified "2026-02-12T08:59:21.728323Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7353-1
  a curric:KeyLearningPoint ;
  rdfs:label "Editing is the process of making changes to improve writing."@en ;
  dcterms:modified "2026-02-12T08:59:21.729358Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7353-2
  a curric:KeyLearningPoint ;
  rdfs:label """The job of an editor is to check punctuation and to make improvements to sentence structure and language choices."""@en ;
  dcterms:modified "2026-02-12T08:59:21.729362Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7353-3
  a curric:KeyLearningPoint ;
  rdfs:label """When editing punctuation, missing or incorrectly used capital letters, full stops and commas are checked."""@en ;
  dcterms:modified "2026-02-12T08:59:21.729366Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7353-4
  a curric:KeyLearningPoint ;
  rdfs:label """When editing sentence structure, changes to the way sentences are constructed to improve text flow are made."""@en ;
  dcterms:modified "2026-02-12T08:59:21.729371Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7353-5
  a curric:KeyLearningPoint ;
  rdfs:label """When editing vocabulary, reviews of word and phrase choice are made to ensure appropriate tone is achieved."""@en ;
  dcterms:modified "2026-02-12T08:59:21.729375Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5769-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the main body of this diary entry is to describe events, thoughts and feelings in detail."""@en ;
  dcterms:modified "2026-02-12T08:59:21.729379Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5769-2
  a curric:KeyLearningPoint ;
  rdfs:label "Sentences can be opened in a variety of ways to improve the flow of the text."@en ;
  dcterms:modified "2026-02-12T08:59:21.729386Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5769-3
  a curric:KeyLearningPoint ;
  rdfs:label "The main body is primarily written in the past tense."@en ;
  dcterms:modified "2026-02-12T08:59:21.729391Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5769-4
  a curric:KeyLearningPoint ;
  rdfs:label "Adverbials of time can be used to sequence events."@en ;
  dcterms:modified "2026-02-12T08:59:21.729395Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5769-5
  a curric:KeyLearningPoint ;
  rdfs:label "Informal tone can be achieved through use of contractions and exclamations."@en ;
  dcterms:modified "2026-02-12T08:59:21.729399Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5768-1
  a curric:KeyLearningPoint ;
  rdfs:label "The opening of a diary can include a general recount of the day’s events."@en ;
  dcterms:modified "2026-02-12T08:59:21.729404Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5768-2
  a curric:KeyLearningPoint ;
  rdfs:label "The opening includes references to the character’s thoughts and feelings."@en ;
  dcterms:modified "2026-02-12T08:59:21.729408Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5768-3
  a curric:KeyLearningPoint ;
  rdfs:label """Informal tone can be achieved through use of contractions, vocabulary choice and exclamations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.729413Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5768-4
  a curric:KeyLearningPoint ;
  rdfs:label "Plans and success criteria should be referred to during the writing process."@en ;
  dcterms:modified "2026-02-12T08:59:21.729419Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1351-1
  a curric:KeyLearningPoint ;
  rdfs:label """A silent 'h' can be found in different places within a word and next to different letters."""@en ;
  dcterms:modified "2026-02-12T08:59:21.729437Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1351-2
  a curric:KeyLearningPoint ;
  rdfs:label """A silent 'p' can be found in different places within a word and next to different letters."""@en ;
  dcterms:modified "2026-02-12T08:59:21.729441Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1351-3
  a curric:KeyLearningPoint ;
  rdfs:label "A silent 'n' is generally found at the end of the word after the letter m."@en ;
  dcterms:modified "2026-02-12T08:59:21.729446Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1351-4
  a curric:KeyLearningPoint ;
  rdfs:label """A silent 'l' generally comes after a vowel and often changes the sound of the vowel."""@en ;
  dcterms:modified "2026-02-12T08:59:21.729452Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1351-5
  a curric:KeyLearningPoint ;
  rdfs:label """How to spell words with the silent letter 's' and the curriculum words: environment, twelfth and desperate."""@en ;
  dcterms:modified "2026-02-12T08:59:21.729459Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1452-1
  a curric:KeyLearningPoint ;
  rdfs:label "Homonyms are words which have the same spellings but multiple meanings."@en ;
  dcterms:modified "2026-02-12T08:59:21.729527Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1452-2
  a curric:KeyLearningPoint ;
  rdfs:label "The meaning of a homonym is dependent on the context."@en ;
  dcterms:modified "2026-02-12T08:59:21.729531Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1452-3
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum word: woman and women."@en ;
  dcterms:modified "2026-02-12T08:59:21.729535Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1455-1
  a curric:KeyLearningPoint ;
  rdfs:label """Homophones are words that have different spellings and multiple meanings, but sound the same."""@en ;
  dcterms:modified "2026-02-12T08:59:21.729539Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1455-2
  a curric:KeyLearningPoint ;
  rdfs:label "The meaning of a homophone is dependent on the context."@en ;
  dcterms:modified "2026-02-12T08:59:21.729544Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1455-3
  a curric:KeyLearningPoint ;
  rdfs:label "Using the strategy 'naughty letters' is a useful practice strategy."@en ;
  dcterms:modified "2026-02-12T08:59:21.729548Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1455-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum word: address."@en ;
  dcterms:modified "2026-02-12T08:59:21.729552Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6218-1
  a curric:KeyLearningPoint ;
  rdfs:label """Our essay will give one side of an argument, using a logical order and supported by evidence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.729557Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6218-2
  a curric:KeyLearningPoint ;
  rdfs:label "Evidence can take many forms, including explanations, facts and statistics."@en ;
  dcterms:modified "2026-02-12T08:59:21.729561Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6218-3
  a curric:KeyLearningPoint ;
  rdfs:label """In the introduction, we will explain how deforestation relates to the Amazon rainforest."""@en ;
  dcterms:modified "2026-02-12T08:59:21.729565Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6218-4
  a curric:KeyLearningPoint ;
  rdfs:label "We will include subject-specific vocabulary and a range of linguistic features."@en ;
  dcterms:modified "2026-02-12T08:59:21.729572Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1416-1
  a curric:KeyLearningPoint ;
  rdfs:label "The /sh/ sound can be spelt 'sh' or 'ch'."@en ;
  dcterms:modified "2026-02-12T08:59:21.730028Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1416-2
  a curric:KeyLearningPoint ;
  rdfs:label "Many words in the English language come from other languages."@en ;
  dcterms:modified "2026-02-12T08:59:21.730032Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1416-3
  a curric:KeyLearningPoint ;
  rdfs:label """Words that contain the /sh/ sound spelt 'ch' often come from the French language."""@en ;
  dcterms:modified "2026-02-12T08:59:21.730036Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1416-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: certain, important and woman."@en ;
  dcterms:modified "2026-02-12T08:59:21.730041Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27896-1
  a curric:KeyLearningPoint ;
  rdfs:label "A speech is written for a specific audience in order to achieve its purpose."@en ;
  dcterms:modified "2026-02-12T08:59:21.730045Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27896-2
  a curric:KeyLearningPoint ;
  rdfs:label "Speeches can inform an audience about something they may not already know about."@en ;
  dcterms:modified "2026-02-12T08:59:21.730049Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27896-3
  a curric:KeyLearningPoint ;
  rdfs:label "The purpose of a speech is always to impact the audience in some way."@en ;
  dcterms:modified "2026-02-12T08:59:21.730053Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27896-4
  a curric:KeyLearningPoint ;
  rdfs:label "A speech will often try to persuade an audience to agree with its main themes."@en ;
  dcterms:modified "2026-02-12T08:59:21.730058Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6358-1
  a curric:KeyLearningPoint ;
  rdfs:label """The opening paragraph of a journalistic report provides an overview of the news event."""@en ;
  dcterms:modified "2026-02-12T08:59:21.730062Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6358-2
  a curric:KeyLearningPoint ;
  rdfs:label "The opening answers the questions what, where, when and who."@en ;
  dcterms:modified "2026-02-12T08:59:21.730066Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6358-3
  a curric:KeyLearningPoint ;
  rdfs:label """Formal and subject-specific vocabulary is used to write the opening of a journalistic report."""@en ;
  dcterms:modified "2026-02-12T08:59:21.730071Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6358-4
  a curric:KeyLearningPoint ;
  rdfs:label "The use of formal language creates a serious, factual and objective tone."@en ;
  dcterms:modified "2026-02-12T08:59:21.730077Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6358-5
  a curric:KeyLearningPoint ;
  rdfs:label """A relative complex sentence allows the writer to provide extra detail about the people involved."""@en ;
  dcterms:modified "2026-02-12T08:59:21.730082Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5770-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the main body of this diary entry is to describe events, thoughts and feelings in detail."""@en ;
  dcterms:modified "2026-02-12T08:59:21.730086Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5770-2
  a curric:KeyLearningPoint ;
  rdfs:label "Adverbials of time can be used to sequence events."@en ;
  dcterms:modified "2026-02-12T08:59:21.730092Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5770-3
  a curric:KeyLearningPoint ;
  rdfs:label "The main body of this diary entry is primarily written in the past tense."@en ;
  dcterms:modified "2026-02-12T08:59:21.730096Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5770-4
  a curric:KeyLearningPoint ;
  rdfs:label """Informal tone can be achieved through use of contractions, vocabulary choice and exclamations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.730101Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27900-1
  a curric:KeyLearningPoint ;
  rdfs:label """Times of transition in life can provoke different emotions such as excitement, sadness or nervousness."""@en ;
  dcterms:modified "2026-02-12T08:59:21.730230Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27900-2
  a curric:KeyLearningPoint ;
  rdfs:label """Talking about feelings can help a person to feel more comfortable and less anxious."""@en ;
  dcterms:modified "2026-02-12T08:59:21.730234Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27900-3
  a curric:KeyLearningPoint ;
  rdfs:label "An essential part of having a discussion is the ability to actively listen."@en ;
  dcterms:modified "2026-02-12T08:59:21.730238Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27900-4
  a curric:KeyLearningPoint ;
  rdfs:label """Active listening helps a person understand different perspectives and empathise with other people's experiences."""@en ;
  dcterms:modified "2026-02-12T08:59:21.730242Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27900-5
  a curric:KeyLearningPoint ;
  rdfs:label """Moving from primary school to secondary school can be both exciting and daunting."""@en ;
  dcterms:modified "2026-02-12T08:59:21.730246Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5767-1
  a curric:KeyLearningPoint ;
  rdfs:label """Diaries are informal in tone; this can be achieved through use of certain linguistic features, like contracted words."""@en ;
  dcterms:modified "2026-02-12T08:59:21.730528Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5767-2
  a curric:KeyLearningPoint ;
  rdfs:label "Diaries include references to the character’s thoughts and feelings."@en ;
  dcterms:modified "2026-02-12T08:59:21.730534Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5767-3
  a curric:KeyLearningPoint ;
  rdfs:label "Diaries are written from the first person perspective."@en ;
  dcterms:modified "2026-02-12T08:59:21.730538Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5767-4
  a curric:KeyLearningPoint ;
  rdfs:label "Writers can convey their feelings using 'tell' and 'show-not-tell' descriptions."@en ;
  dcterms:modified "2026-02-12T08:59:21.730543Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1353-1
  a curric:KeyLearningPoint ;
  rdfs:label "The /s/ sound in Latin-origin words is generally spelt 'sc'."@en ;
  dcterms:modified "2026-02-12T08:59:21.730547Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1353-2
  a curric:KeyLearningPoint ;
  rdfs:label "The /k/ sound in Greek-origin words is generally spelt 'ch'."@en ;
  dcterms:modified "2026-02-12T08:59:21.730551Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1353-3
  a curric:KeyLearningPoint ;
  rdfs:label "The /f/ sound in Greek-origin words is generally spelt 'ph'."@en ;
  dcterms:modified "2026-02-12T08:59:21.730555Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1353-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: stomach, yacht and ancient."@en ;
  dcterms:modified "2026-02-12T08:59:21.730559Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1040-1
  a curric:KeyLearningPoint ;
  rdfs:label """A group of words that contains a verb and makes complete sense is called a main clause."""@en ;
  dcterms:modified "2026-02-12T08:59:21.730563Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1040-2
  a curric:KeyLearningPoint ;
  rdfs:label "Co-ordinating conjunctions join two main clauses to form a compound sentence."@en ;
  dcterms:modified "2026-02-12T08:59:21.730568Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1040-3
  a curric:KeyLearningPoint ;
  rdfs:label """If the co-ordinating conjunction "but" or "or" is used, there must be a comma before it in a compound sentence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.730572Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1040-4
  a curric:KeyLearningPoint ;
  rdfs:label "The comma tells the reader where the main clause demarcation is."@en ;
  dcterms:modified "2026-02-12T08:59:21.730576Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1040-5
  a curric:KeyLearningPoint ;
  rdfs:label "Different co-ordinating conjunctions have different meanings."@en ;
  dcterms:modified "2026-02-12T08:59:21.730580Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4708-1
  a curric:KeyLearningPoint ;
  rdfs:label """A speech is the communication of someone’s thoughts, through words, to an audience."""@en ;
  dcterms:modified "2026-02-12T08:59:21.730586Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4708-2
  a curric:KeyLearningPoint ;
  rdfs:label "Lots of different jobs require people to make speeches."@en ;
  dcterms:modified "2026-02-12T08:59:21.730591Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4708-3
  a curric:KeyLearningPoint ;
  rdfs:label "The purpose of making a speech is to have an impact on your audience."@en ;
  dcterms:modified "2026-02-12T08:59:21.730595Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4708-4
  a curric:KeyLearningPoint ;
  rdfs:label """A successful speech will persuade an audience to agree with the main themes of the speech."""@en ;
  dcterms:modified "2026-02-12T08:59:21.730601Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2705-1
  a curric:KeyLearningPoint ;
  rdfs:label "The verb carries the tense of a sentence."@en ;
  dcterms:modified "2026-02-12T08:59:21.730606Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2705-2
  a curric:KeyLearningPoint ;
  rdfs:label "The perfect tense can denote present, past or future action."@en ;
  dcterms:modified "2026-02-12T08:59:21.730610Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2705-3
  a curric:KeyLearningPoint ;
  rdfs:label """The perfect tense is a tense that makes use of an auxiliary verb based on 'to have' and a main verb."""@en ;
  dcterms:modified "2026-02-12T08:59:21.730615Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2705-4
  a curric:KeyLearningPoint ;
  rdfs:label """The auxiliary verb is followed by a past tense form of the main verb in the perfect tense."""@en ;
  dcterms:modified "2026-02-12T08:59:21.730619Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6217-1
  a curric:KeyLearningPoint ;
  rdfs:label """Our essay will give one side of an argument, with a logical argument building to a conclusion that mirrors the title."""@en ;
  dcterms:modified "2026-02-12T08:59:21.730623Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6217-2
  a curric:KeyLearningPoint ;
  rdfs:label """Writing is best when we are sure of the ideas we are trying to communicate and how they relate logically to one another."""@en ;
  dcterms:modified "2026-02-12T08:59:21.730627Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6217-3
  a curric:KeyLearningPoint ;
  rdfs:label """We can organise a set of ideas into a logical order in order to make our argument most effective."""@en ;
  dcterms:modified "2026-02-12T08:59:21.730632Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6217-4
  a curric:KeyLearningPoint ;
  rdfs:label """We also need to organise ideas into paragraphs that build logically on from each other towards the conclusion."""@en ;
  dcterms:modified "2026-02-12T08:59:21.730636Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1327-1
  a curric:KeyLearningPoint ;
  rdfs:label """Two or more words that sound the same but have different meanings or spellings are called homophones."""@en ;
  dcterms:modified "2026-02-12T08:59:21.730745Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1327-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Licence' and 'license' and 'practice' and 'practise' are homophones."@en ;
  dcterms:modified "2026-02-12T08:59:21.730749Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1327-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Prophecy' and 'prophesy' are homophones."@en ;
  dcterms:modified "2026-02-12T08:59:21.730754Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1327-4
  a curric:KeyLearningPoint ;
  rdfs:label "We can look for naughty letters to help us to remember tricky spellings."@en ;
  dcterms:modified "2026-02-12T08:59:21.730758Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1327-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: temperature and aggressive."@en ;
  dcterms:modified "2026-02-12T08:59:21.730764Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3463-1
  a curric:KeyLearningPoint ;
  rdfs:label """Bullet points are useful to lay out key information clearly in a non-fiction text."""@en ;
  dcterms:modified "2026-02-12T08:59:21.730768Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3463-2
  a curric:KeyLearningPoint ;
  rdfs:label "Bullet points space information out for the reader."@en ;
  dcterms:modified "2026-02-12T08:59:21.730772Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3463-3
  a curric:KeyLearningPoint ;
  rdfs:label "Bullet points often come after a main clause or a subheading."@en ;
  dcterms:modified "2026-02-12T08:59:21.730776Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3463-4
  a curric:KeyLearningPoint ;
  rdfs:label "List items only need capitals and full stops when they are complete sentences."@en ;
  dcterms:modified "2026-02-12T08:59:21.730780Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1393-1
  a curric:KeyLearningPoint ;
  rdfs:label "In polysyllabic words, some vowels can be unstressed and hard to hear and spell."@en ;
  dcterms:modified "2026-02-12T08:59:21.731316Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1393-2
  a curric:KeyLearningPoint ;
  rdfs:label "Saying the word how it is spelt can help to learn the spelling."@en ;
  dcterms:modified "2026-02-12T08:59:21.731320Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1393-3
  a curric:KeyLearningPoint ;
  rdfs:label """Thinking of the root word and identifying prefixes and suffixes can help to learn the spelling."""@en ;
  dcterms:modified "2026-02-12T08:59:21.731324Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1393-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: variety, various, imagine and definite."@en ;
  dcterms:modified "2026-02-12T08:59:21.731328Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2712-1
  a curric:KeyLearningPoint ;
  rdfs:label "A fronted adverbial is a sentence starter that is followed by a comma."@en ;
  dcterms:modified "2026-02-12T08:59:21.731332Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2712-2
  a curric:KeyLearningPoint ;
  rdfs:label "A fronted adverbial can be a single word or phrase."@en ;
  dcterms:modified "2026-02-12T08:59:21.731337Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2712-3
  a curric:KeyLearningPoint ;
  rdfs:label "A fronted adverbial can be a clause."@en ;
  dcterms:modified "2026-02-12T08:59:21.731341Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2712-4
  a curric:KeyLearningPoint ;
  rdfs:label "A clause is a group of words that contains a verb."@en ;
  dcterms:modified "2026-02-12T08:59:21.731345Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2712-5
  a curric:KeyLearningPoint ;
  rdfs:label "A fronted adverbial can express detail about time, place or manner."@en ;
  dcterms:modified "2026-02-12T08:59:21.731349Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4895-1
  a curric:KeyLearningPoint ;
  rdfs:label """A section of a non-chronological report contains specific information for the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.731355Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4895-2
  a curric:KeyLearningPoint ;
  rdfs:label """Writers can use a range of cohesive devices to ensure their sentences flow and the text’s purpose is achieved."""@en ;
  dcterms:modified "2026-02-12T08:59:21.731362Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4895-3
  a curric:KeyLearningPoint ;
  rdfs:label """The diet section includes an introductory sentence, followed by specific information, then a linking sentence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.731366Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4895-4
  a curric:KeyLearningPoint ;
  rdfs:label """We can use success criteria to help us identify what a successful piece of writing includes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.731371Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4895-5
  a curric:KeyLearningPoint ;
  rdfs:label "The writing process involves planning, drafting, editing and publishing."@en ;
  dcterms:modified "2026-02-12T08:59:21.731375Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1428-1
  a curric:KeyLearningPoint ;
  rdfs:label """When -ing is added to the end of a word, it can show the past tense or the present tense."""@en ;
  dcterms:modified "2026-02-12T08:59:21.731379Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1428-2
  a curric:KeyLearningPoint ;
  rdfs:label """If the root word has a short vowel and a single consonant, the consonant letter is doubled when the suffix is added."""@en ;
  dcterms:modified "2026-02-12T08:59:21.731383Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1428-3
  a curric:KeyLearningPoint ;
  rdfs:label "If the verb ends in a \"y\", just add \"-ing\"."@en ;
  dcterms:modified "2026-02-12T08:59:21.731387Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1428-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum word: answer."@en ;
  dcterms:modified "2026-02-12T08:59:21.731391Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7932-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘Cloud Busting’ focuses on the relationship between two ‘friends’: Davey and Sam."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732104Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7932-2
  a curric:KeyLearningPoint ;
  rdfs:label "The story is told as a verse novel."@en ;
  dcterms:modified "2026-02-12T08:59:21.732108Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7932-3
  a curric:KeyLearningPoint ;
  rdfs:label "‘Cloud Busting’ uses both fixed verse and free verse poetry."@en ;
  dcterms:modified "2026-02-12T08:59:21.732112Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7932-4
  a curric:KeyLearningPoint ;
  rdfs:label """‘Cloud Busting’ is written in both the present and the past, through use of flashbacks."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732116Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7932-5
  a curric:KeyLearningPoint ;
  rdfs:label """A range of poetic forms are used by the author including haikus, blank verse, limericks and concrete / shape poems."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732122Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1337-1
  a curric:KeyLearningPoint ;
  rdfs:label """The /shun/ sound can be spelt four different ways: -tion, -cian, -sion and -ssion."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732128Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1337-2
  a curric:KeyLearningPoint ;
  rdfs:label "The /shun/ sound is sometimes spelt 'sion' or 'ssion'."@en ;
  dcterms:modified "2026-02-12T08:59:21.732133Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1337-3
  a curric:KeyLearningPoint ;
  rdfs:label """The suffix -sion is used for the /shun/ or /zhun/ sound when the root word ends in 'd', 'de' or 'se'."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732137Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1337-4
  a curric:KeyLearningPoint ;
  rdfs:label """The suffix -ssion is used for the /shun/ sound when the root word ends in 'ss' or 'mit'."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732141Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1337-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: profession and develop"@en ;
  dcterms:modified "2026-02-12T08:59:21.732145Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1342-1
  a curric:KeyLearningPoint ;
  rdfs:label "The 'ough' spelling can make a variety of sounds."@en ;
  dcterms:modified "2026-02-12T08:59:21.732149Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1342-2
  a curric:KeyLearningPoint ;
  rdfs:label "The 'au' spelling can make a variety of sounds."@en ;
  dcterms:modified "2026-02-12T08:59:21.732153Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1342-3
  a curric:KeyLearningPoint ;
  rdfs:label """When you hear one of these sounds, the word might contain the 'ough' or 'au' spelling."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732157Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1342-4
  a curric:KeyLearningPoint ;
  rdfs:label "The pronunciation of the 'au' letter string may vary depending on accent."@en ;
  dcterms:modified "2026-02-12T08:59:21.732173Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1342-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: amateur and sacrifice."@en ;
  dcterms:modified "2026-02-12T08:59:21.732178Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1369-1
  a curric:KeyLearningPoint ;
  rdfs:label "The suffixes -ary and -ery can turn some words into nouns."@en ;
  dcterms:modified "2026-02-12T08:59:21.732182Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1369-2
  a curric:KeyLearningPoint ;
  rdfs:label "The ending -ery is more common."@en ;
  dcterms:modified "2026-02-12T08:59:21.732186Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1369-3
  a curric:KeyLearningPoint ;
  rdfs:label "When a word ends in a consonant, just add the suffix."@en ;
  dcterms:modified "2026-02-12T08:59:21.732190Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1369-4
  a curric:KeyLearningPoint ;
  rdfs:label "When a word ends in ‘e’, remove the ‘e’, then add the suffix."@en ;
  dcterms:modified "2026-02-12T08:59:21.732194Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1369-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: February, ordinary, necessary and interest."@en ;
  dcterms:modified "2026-02-12T08:59:21.732198Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4890-1
  a curric:KeyLearningPoint ;
  rdfs:label "The conclusion is the final paragraph of a non-chronological report."@en ;
  dcterms:modified "2026-02-12T08:59:21.732722Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4890-2
  a curric:KeyLearningPoint ;
  rdfs:label "Information in the conclusion should be general."@en ;
  dcterms:modified "2026-02-12T08:59:21.732726Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4890-3
  a curric:KeyLearningPoint ;
  rdfs:label """Writers can use a range of cohesive devices to enhance text flow and keep the reader engaged."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732732Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4890-4
  a curric:KeyLearningPoint ;
  rdfs:label "Effective planning leads to successful writing outcomes."@en ;
  dcterms:modified "2026-02-12T08:59:21.732737Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5462-1
  a curric:KeyLearningPoint ;
  rdfs:label "We can use a range of strategies to build comprehension of the text."@en ;
  dcterms:modified "2026-02-12T08:59:21.732740Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5462-2
  a curric:KeyLearningPoint ;
  rdfs:label "Skimming and scanning can help us to retrieve key information."@en ;
  dcterms:modified "2026-02-12T08:59:21.732744Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5462-3
  a curric:KeyLearningPoint ;
  rdfs:label "We can use inference to draw conclusions about the text by searching for clues."@en ;
  dcterms:modified "2026-02-12T08:59:21.732748Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5462-4
  a curric:KeyLearningPoint ;
  rdfs:label """Discussing the text with others improves understanding and offers opportunities for hearing different perspectives."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732752Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1030-1
  a curric:KeyLearningPoint ;
  rdfs:label "A title opens a non-chronological report."@en ;
  dcterms:modified "2026-02-12T08:59:21.732756Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1030-2
  a curric:KeyLearningPoint ;
  rdfs:label "The purpose of the introduction is to give general information to the reader."@en ;
  dcterms:modified "2026-02-12T08:59:21.732759Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1030-3
  a curric:KeyLearningPoint ;
  rdfs:label """The introduction outlines what the reader will learn from the non-chronological report."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732763Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1030-4
  a curric:KeyLearningPoint ;
  rdfs:label """Expanded noun phrases and synonyms for ‘spider’ are used to refer to the subject in different ways."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732770Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3446-1
  a curric:KeyLearningPoint ;
  rdfs:label """Adverbial clauses and relative clauses are types of subordinate clause; they must be joined to a main clause."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732774Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3446-2
  a curric:KeyLearningPoint ;
  rdfs:label """Adverbial clauses start with subordinating conjunctions; there are many of these with different purposes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732781Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3446-3
  a curric:KeyLearningPoint ;
  rdfs:label """Relative clauses start with relative pronouns; occasionally in informal language, the relative pronoun is omitted."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732785Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3446-4
  a curric:KeyLearningPoint ;
  rdfs:label """Adverbial clauses can be placed before or after a main clause in an adverbial complex sentence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732789Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3446-5
  a curric:KeyLearningPoint ;
  rdfs:label """Relative clauses are placed after the noun or noun phrase they tell us more about (and can be at the end of a sentence)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732793Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1331-1
  a curric:KeyLearningPoint ;
  rdfs:label "If the root word ends in 'y', remove the 'y' and add -iest."@en ;
  dcterms:modified "2026-02-12T08:59:21.733079Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1331-2
  a curric:KeyLearningPoint ;
  rdfs:label "If the root word ends in 'e', remove the 'e' and add -est."@en ;
  dcterms:modified "2026-02-12T08:59:21.733083Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1331-3
  a curric:KeyLearningPoint ;
  rdfs:label """If the root word contains a short vowel sound, double the consonant and add -est."""@en ;
  dcterms:modified "2026-02-12T08:59:21.733087Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1331-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Most' is irregular because it does not follow the same pattern. The comparative 'more' becomes 'most'."""@en ;
  dcterms:modified "2026-02-12T08:59:21.733091Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1331-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: secretary and controversy."@en ;
  dcterms:modified "2026-02-12T08:59:21.733120Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1341-1
  a curric:KeyLearningPoint ;
  rdfs:label "The suffix -cial is common after a vowel letter."@en ;
  dcterms:modified "2026-02-12T08:59:21.733125Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1341-2
  a curric:KeyLearningPoint ;
  rdfs:label "The suffix -tial is common after a consonant letter."@en ;
  dcterms:modified "2026-02-12T08:59:21.733129Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1341-3
  a curric:KeyLearningPoint ;
  rdfs:label "Words ending in the suffix -cial or -tial are generally adjectives."@en ;
  dcterms:modified "2026-02-12T08:59:21.733133Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1341-4
  a curric:KeyLearningPoint ;
  rdfs:label "Exceptions include: financial, commercial, provincial."@en ;
  dcterms:modified "2026-02-12T08:59:21.733137Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1341-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: occur, occupy and communicate."@en ;
  dcterms:modified "2026-02-12T08:59:21.733143Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1054-1
  a curric:KeyLearningPoint ;
  rdfs:label "An apostrophe has more than one purpose."@en ;
  dcterms:modified "2026-02-12T08:59:21.733147Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1054-2
  a curric:KeyLearningPoint ;
  rdfs:label "An apostrophe can show if a noun belongs to another singular noun."@en ;
  dcterms:modified "2026-02-12T08:59:21.733151Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1054-3
  a curric:KeyLearningPoint ;
  rdfs:label "An apostrophe can show if a noun belongs to another plural noun."@en ;
  dcterms:modified "2026-02-12T08:59:21.733155Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1054-4
  a curric:KeyLearningPoint ;
  rdfs:label """There are rules for where to place the apostrophe for possession depending on if the noun is singular or plural."""@en ;
  dcterms:modified "2026-02-12T08:59:21.733159Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1054-5
  a curric:KeyLearningPoint ;
  rdfs:label """Apostrophes for singular possession or for plural possession are useful to make our meaning clear."""@en ;
  dcterms:modified "2026-02-12T08:59:21.733168Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27897-1
  a curric:KeyLearningPoint ;
  rdfs:label "A speaker can provoke an emotional response from an audience."@en ;
  dcterms:modified "2026-02-12T08:59:21.733172Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27897-2
  a curric:KeyLearningPoint ;
  rdfs:label "Provoking an emotional response may help a speaker to achieve their purpose."@en ;
  dcterms:modified "2026-02-12T08:59:21.733176Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27897-3
  a curric:KeyLearningPoint ;
  rdfs:label "Greta Thunberg is a Swedish activist and environmentalist."@en ;
  dcterms:modified "2026-02-12T08:59:21.733180Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27897-4
  a curric:KeyLearningPoint ;
  rdfs:label """Greta Thunberg made a speech at the United Nations Climate Change Conference when she was just 15 years old."""@en ;
  dcterms:modified "2026-02-12T08:59:21.733184Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6002-1
  a curric:KeyLearningPoint ;
  rdfs:label "Reading aloud involves speaking in front of others and listening to others."@en ;
  dcterms:modified "2026-02-12T08:59:21.733188Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6002-2
  a curric:KeyLearningPoint ;
  rdfs:label "Reading aloud involves speaking at a suitable volume and pace."@en ;
  dcterms:modified "2026-02-12T08:59:21.733192Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6002-3
  a curric:KeyLearningPoint ;
  rdfs:label """Reading with expression means reading with feelings and emotion to bring the words to life."""@en ;
  dcterms:modified "2026-02-12T08:59:21.733196Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6002-4
  a curric:KeyLearningPoint ;
  rdfs:label """Making eye contact with the audience helps the reader to connect with the audience."""@en ;
  dcterms:modified "2026-02-12T08:59:21.733200Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6002-5
  a curric:KeyLearningPoint ;
  rdfs:label """Confident body language and use of facial expressions are an important aspect of reading aloud."""@en ;
  dcterms:modified "2026-02-12T08:59:21.733235Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1390-1
  a curric:KeyLearningPoint ;
  rdfs:label "In words of Greek origin, the letter string 'ch' makes the /k/ sound."@en ;
  dcterms:modified "2026-02-12T08:59:21.733855Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1390-2
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: stomach, important and certain."@en ;
  dcterms:modified "2026-02-12T08:59:21.733859Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4702-1
  a curric:KeyLearningPoint ;
  rdfs:label "The motion is the name for the belief or proposal that is being debated."@en ;
  dcterms:modified "2026-02-12T08:59:21.734033Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4702-2
  a curric:KeyLearningPoint ;
  rdfs:label "The team that agrees with the motion is called the proposition."@en ;
  dcterms:modified "2026-02-12T08:59:21.734036Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4702-3
  a curric:KeyLearningPoint ;
  rdfs:label "The team that disagrees with the motion is called the opposition."@en ;
  dcterms:modified "2026-02-12T08:59:21.734040Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4702-4
  a curric:KeyLearningPoint ;
  rdfs:label """A rebuttal point is a counter-argument made against something specific that the opposing team has said."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734044Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2738-1
  a curric:KeyLearningPoint ;
  rdfs:label """A fronted adverbial is a sentence starter followed by a comma that expresses detail about time, place, manner or cause."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734050Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2738-2
  a curric:KeyLearningPoint ;
  rdfs:label "A fronted adverbial can be a single word, phrase or clause."@en ;
  dcterms:modified "2026-02-12T08:59:21.734054Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2738-3
  a curric:KeyLearningPoint ;
  rdfs:label "A clause is a group of words that contains a verb."@en ;
  dcterms:modified "2026-02-12T08:59:21.734058Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2738-4
  a curric:KeyLearningPoint ;
  rdfs:label "A phrase is a group of words with no verb."@en ;
  dcterms:modified "2026-02-12T08:59:21.734062Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2738-5
  a curric:KeyLearningPoint ;
  rdfs:label "A variety of fronted adverbials are useful to achieve text flow."@en ;
  dcterms:modified "2026-02-12T08:59:21.734066Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1350-1
  a curric:KeyLearningPoint ;
  rdfs:label """A silent 'b' generally comes towards the end of a word and next to a 't' or after the letter 'm'."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734070Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1350-2
  a curric:KeyLearningPoint ;
  rdfs:label "A silent 'w' might come at the beginning of a word before the letter 'r'."@en ;
  dcterms:modified "2026-02-12T08:59:21.734074Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1350-3
  a curric:KeyLearningPoint ;
  rdfs:label "A silent 'k' always comes at the beginning of a word and before the letter 'n'."@en ;
  dcterms:modified "2026-02-12T08:59:21.734078Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1350-4
  a curric:KeyLearningPoint ;
  rdfs:label """A silent 'g' can come at the beginning of a word or at the end of a word, but it generally comes before the letter 'n'."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734082Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1350-5
  a curric:KeyLearningPoint ;
  rdfs:label """How to spell words with the silent letter 't' and the curriculum words: government, parliament, rhyme."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734088Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8065-1
  a curric:KeyLearningPoint ;
  rdfs:label """'Blackbird' is a cinquain by John Foster with five lines of a set syllabic structure."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734092Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8065-2
  a curric:KeyLearningPoint ;
  rdfs:label """‘Hawk Roosting’ can be described as a fixed verse poem; it consists of six verses, each with four lines."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734096Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8065-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Hawk Roosting' is written in first-person perspective."@en ;
  dcterms:modified "2026-02-12T08:59:21.734100Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8065-4
  a curric:KeyLearningPoint ;
  rdfs:label "We can explore poems in depth by reading them aloud and performing them."@en ;
  dcterms:modified "2026-02-12T08:59:21.734104Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27898-1
  a curric:KeyLearningPoint ;
  rdfs:label "A speaker can connect with an audience in a variety of different ways."@en ;
  dcterms:modified "2026-02-12T08:59:21.734108Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27898-2
  a curric:KeyLearningPoint ;
  rdfs:label """A speaker can use personal experiences and anecdotes to connect with an audience."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734112Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27898-3
  a curric:KeyLearningPoint ;
  rdfs:label """Emma Watson is an actress and she is best-known for playing Hermione in the Harry Potter films."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734115Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27898-4
  a curric:KeyLearningPoint ;
  rdfs:label """Emma Watson is an activist, humanitarian and speaker, who gave a famous speech as UN Women Goodwill Ambassador in 2014."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734120Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5463-1
  a curric:KeyLearningPoint ;
  rdfs:label """'The Pebble in my Pocket' is a narrative non-fiction text that teaches us about the history of our world."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734126Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5463-2
  a curric:KeyLearningPoint ;
  rdfs:label """The pebble is 480 million years old and has existed in many forms, landscapes and climates."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734130Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5463-3
  a curric:KeyLearningPoint ;
  rdfs:label """The author, Meredith Hooper, conveys a deeper meaning behind the pebble's journey through her writing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734134Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5463-4
  a curric:KeyLearningPoint ;
  rdfs:label """Everything that exists has a story to tell and helps us to build our understanding of the world."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734138Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1036-1
  a curric:KeyLearningPoint ;
  rdfs:label "The purpose of a conclusion is to summarise the information from the text."@en ;
  dcterms:modified "2026-02-12T08:59:21.734142Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1036-2
  a curric:KeyLearningPoint ;
  rdfs:label "A summary sentence summarises the key information from the text."@en ;
  dcterms:modified "2026-02-12T08:59:21.734146Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1036-3
  a curric:KeyLearningPoint ;
  rdfs:label "A conclusion begins with a formal fronted adverbial."@en ;
  dcterms:modified "2026-02-12T08:59:21.734151Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1036-4
  a curric:KeyLearningPoint ;
  rdfs:label "No new information about the subject is needed in the conclusion."@en ;
  dcterms:modified "2026-02-12T08:59:21.734155Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1036-5
  a curric:KeyLearningPoint ;
  rdfs:label "A conclusion finishes with the writer suggesting to the reader to find out more."@en ;
  dcterms:modified "2026-02-12T08:59:21.734159Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4857-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the closing is to summarise what is currently happening and what is likely to happen next."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734163Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4857-2
  a curric:KeyLearningPoint ;
  rdfs:label "Information in the closing should be general."@en ;
  dcterms:modified "2026-02-12T08:59:21.734167Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4857-3
  a curric:KeyLearningPoint ;
  rdfs:label """Cohesion is vital when considering how to engage the reader and share information with them in a clear, succinct way."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734171Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4857-4
  a curric:KeyLearningPoint ;
  rdfs:label """Using the structure of introductory sentence, general information and concluding sentence enhances text cohesion."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734175Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1310-1
  a curric:KeyLearningPoint ;
  rdfs:label "The suffix -ous often turns nouns into adjectives and often means 'full of'."@en ;
  dcterms:modified "2026-02-12T08:59:21.734204Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1310-2
  a curric:KeyLearningPoint ;
  rdfs:label "If the root word ends in 'ge', just add -ous."@en ;
  dcterms:modified "2026-02-12T08:59:21.734208Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1310-3
  a curric:KeyLearningPoint ;
  rdfs:label "If the root word ends in 'e', remove the 'e', then add -ous."@en ;
  dcterms:modified "2026-02-12T08:59:21.734212Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1310-4
  a curric:KeyLearningPoint ;
  rdfs:label "If the root word ends in 'our', change 'our' to 'or', then add -ous."@en ;
  dcterms:modified "2026-02-12T08:59:21.734216Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1310-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: thought, purpose and suppose."@en ;
  dcterms:modified "2026-02-12T08:59:21.734220Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7357-1
  a curric:KeyLearningPoint ;
  rdfs:label """Characterisation is the way an author describes and develops the personalities and traits of the characters in a story."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734433Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7357-2
  a curric:KeyLearningPoint ;
  rdfs:label "Authors choose adjectives carefully to build a picture of a character."@en ;
  dcterms:modified "2026-02-12T08:59:21.734437Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7357-3
  a curric:KeyLearningPoint ;
  rdfs:label """The way a character treats others helps us understand a character, build an opinion and become invested in the story."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734442Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7357-4
  a curric:KeyLearningPoint ;
  rdfs:label """Authors use contrasting characters to helps highlight particular characteristics."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734449Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7357-5
  a curric:KeyLearningPoint ;
  rdfs:label """In the summary, Scrooge meets four ghosts who give him a new perspective on life."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734453Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1407-1
  a curric:KeyLearningPoint ;
  rdfs:label """The most common spelling of the /shun/ suffix is -tion and these words often have a root word ending in ‘t’ or ‘te’."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734459Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1407-2
  a curric:KeyLearningPoint ;
  rdfs:label """Words spelt with -sion often have a root word ending in ‘d’, ‘de’ or ‘se’ and can sound like /zhun/."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734463Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1407-3
  a curric:KeyLearningPoint ;
  rdfs:label "Words spelt with -ssion often have a root word ending in ‘ss’ or ‘mit’."@en ;
  dcterms:modified "2026-02-12T08:59:21.734467Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1407-4
  a curric:KeyLearningPoint ;
  rdfs:label """Words spelt with -cian often have a root word ending in ‘c’ or ‘cs’ and are used for professions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734471Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1407-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: potatoes, minute and breath."@en ;
  dcterms:modified "2026-02-12T08:59:21.734475Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6001-1
  a curric:KeyLearningPoint ;
  rdfs:label "Editing is the process of making changes to improve our writing."@en ;
  dcterms:modified "2026-02-12T08:59:21.734478Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6001-2
  a curric:KeyLearningPoint ;
  rdfs:label "Editing can be done by oneself, with a peer or with a teacher."@en ;
  dcterms:modified "2026-02-12T08:59:21.734482Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6001-3
  a curric:KeyLearningPoint ;
  rdfs:label """When editing punctuation, missing or incorrectly used capital letters, full stops, question marks & commas are checked."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734486Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6001-4
  a curric:KeyLearningPoint ;
  rdfs:label """When editing sentence structure, the way sentences are constructed is checked to improve and enhance text flow."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734490Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6001-5
  a curric:KeyLearningPoint ;
  rdfs:label "When editing language, choices of words and phrases are carefully reviewed."@en ;
  dcterms:modified "2026-02-12T08:59:21.734494Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4846-1
  a curric:KeyLearningPoint ;
  rdfs:label """A journalistic report is a non-fiction text that provides information about a particular event."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734498Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4846-2
  a curric:KeyLearningPoint ;
  rdfs:label """A journalistic report can be organised into an opening, paragraphs organised by theme and a closing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734502Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4846-3
  a curric:KeyLearningPoint ;
  rdfs:label "The title of a journalistic report is called a headline."@en ;
  dcterms:modified "2026-02-12T08:59:21.734505Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4846-4
  a curric:KeyLearningPoint ;
  rdfs:label "Journalistic language brings a formal, objective tone to the report."@en ;
  dcterms:modified "2026-02-12T08:59:21.734509Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4846-5
  a curric:KeyLearningPoint ;
  rdfs:label """Features include a range of fronted adverbials, journalistic language, relative complex sentences and parenthesis."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734515Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1429-1
  a curric:KeyLearningPoint ;
  rdfs:label """When -ing is added to the end of a word, it can show the past tense or the present tense."""@en ;
  dcterms:modified "2026-02-12T08:59:21.735086Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1429-2
  a curric:KeyLearningPoint ;
  rdfs:label "Using the strategy \"big letters\" is a useful practice strategy."@en ;
  dcterms:modified "2026-02-12T08:59:21.735090Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1429-3
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum word: history."@en ;
  dcterms:modified "2026-02-12T08:59:21.735093Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4868-1
  a curric:KeyLearningPoint ;
  rdfs:label "A non-chronological report is a type of non-fiction text."@en ;
  dcterms:modified "2026-02-12T08:59:21.735097Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4868-2
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of a non-chronological report is to inform the reader about a particular subject."""@en ;
  dcterms:modified "2026-02-12T08:59:21.735103Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4868-3
  a curric:KeyLearningPoint ;
  rdfs:label """Information in a non-chronological report is organised using a title, subheadings and paragraphs."""@en ;
  dcterms:modified "2026-02-12T08:59:21.735107Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4868-4
  a curric:KeyLearningPoint ;
  rdfs:label """Linguistic features help to introduce, link and bring to life specific, factual information."""@en ;
  dcterms:modified "2026-02-12T08:59:21.735111Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1451-1
  a curric:KeyLearningPoint ;
  rdfs:label """The prefixes de-, re-, sub- and super- can be added without changing the spelling of the root word."""@en ;
  dcterms:modified "2026-02-12T08:59:21.735115Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1451-2
  a curric:KeyLearningPoint ;
  rdfs:label "Spotting a ‘word in a word’ is a useful practice strategy."@en ;
  dcterms:modified "2026-02-12T08:59:21.735119Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1451-3
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum word: continue."@en ;
  dcterms:modified "2026-02-12T08:59:21.735123Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1451-4
  a curric:KeyLearningPoint ;
  rdfs:label "The prefixes de- can mean undo and re- can mean again."@en ;
  dcterms:modified "2026-02-12T08:59:21.735127Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1451-5
  a curric:KeyLearningPoint ;
  rdfs:label "The prefix sub- can mean under and super- can mean above."@en ;
  dcterms:modified "2026-02-12T08:59:21.735131Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1457-1
  a curric:KeyLearningPoint ;
  rdfs:label "Compound words are words made up of two or more pre-existing words."@en ;
  dcterms:modified "2026-02-12T08:59:21.735134Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1457-2
  a curric:KeyLearningPoint ;
  rdfs:label """The spelling of both words remains the same when the words are combined together."""@en ;
  dcterms:modified "2026-02-12T08:59:21.735138Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1457-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Colour blocking' is a useful practice strategy."@en ;
  dcterms:modified "2026-02-12T08:59:21.735142Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1457-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum word: strange."@en ;
  dcterms:modified "2026-02-12T08:59:21.735148Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1340-1
  a curric:KeyLearningPoint ;
  rdfs:label "It is common to see a ‘c’ or a ‘t’ before the suffix -ial."@en ;
  dcterms:modified "2026-02-12T08:59:21.735152Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1340-2
  a curric:KeyLearningPoint ;
  rdfs:label "Words ending in the suffix -cial or -tial are generally adjectives."@en ;
  dcterms:modified "2026-02-12T08:59:21.735156Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1340-3
  a curric:KeyLearningPoint ;
  rdfs:label "The suffix -cial is usually used after a vowel."@en ;
  dcterms:modified "2026-02-12T08:59:21.735160Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1340-4
  a curric:KeyLearningPoint ;
  rdfs:label "The suffix -tial is common after a consonant letter."@en ;
  dcterms:modified "2026-02-12T08:59:21.735164Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1340-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: cemetery and language."@en ;
  dcterms:modified "2026-02-12T08:59:21.735167Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6552-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the main body is to clearly state the writer’s most persuasive points."""@en ;
  dcterms:modified "2026-02-12T08:59:21.735172Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6552-2
  a curric:KeyLearningPoint ;
  rdfs:label "Using a plan and success criteria can help inform the writing process."@en ;
  dcterms:modified "2026-02-12T08:59:21.735175Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6552-3
  a curric:KeyLearningPoint ;
  rdfs:label """Presumption and veiled threat are appropriate persuasive techniques to use in the main body."""@en ;
  dcterms:modified "2026-02-12T08:59:21.735179Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6552-4
  a curric:KeyLearningPoint ;
  rdfs:label """Points backed up by evidence, statistics, quotes or anecdotes are effective in making the writer sound credible."""@en ;
  dcterms:modified "2026-02-12T08:59:21.735183Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27625-1
  a curric:KeyLearningPoint ;
  rdfs:label "The motion is the name for the belief or proposal that is being debated."@en ;
  dcterms:modified "2026-02-12T08:59:21.735187Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27625-2
  a curric:KeyLearningPoint ;
  rdfs:label "The motion in a debate always starts with the words 'This house ...'."@en ;
  dcterms:modified "2026-02-12T08:59:21.735193Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27625-3
  a curric:KeyLearningPoint ;
  rdfs:label """There are different types of motion: beliefs ('This house believes that ...') and proposals ('This house would ...')."""@en ;
  dcterms:modified "2026-02-12T08:59:21.735197Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27625-4
  a curric:KeyLearningPoint ;
  rdfs:label """A debate motion is most effective when it is relevant to the lives of the people in the debate and the audience."""@en ;
  dcterms:modified "2026-02-12T08:59:21.735224Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27625-5
  a curric:KeyLearningPoint ;
  rdfs:label """An effective debate motion will encourage critical thinking and mature discussion."""@en ;
  dcterms:modified "2026-02-12T08:59:21.735229Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6722-1
  a curric:KeyLearningPoint ;
  rdfs:label """In a biography, we write using a formal tone in the third person; our writing is mostly, but not all, in the past tense."""@en ;
  dcterms:modified "2026-02-12T08:59:21.735233Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6722-2
  a curric:KeyLearningPoint ;
  rdfs:label "We use a range of cohesive devices to connect ideas together."@en ;
  dcterms:modified "2026-02-12T08:59:21.735237Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6722-3
  a curric:KeyLearningPoint ;
  rdfs:label "We orally rehearse our sentences before we write, using our notes."@en ;
  dcterms:modified "2026-02-12T08:59:21.735240Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6722-4
  a curric:KeyLearningPoint ;
  rdfs:label """We can include parenthesis to add extra details to a sentence, including using brackets and relative clauses."""@en ;
  dcterms:modified "2026-02-12T08:59:21.735246Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6722-5
  a curric:KeyLearningPoint ;
  rdfs:label """We give a title for the biography as a whole and subheadings for each paragraph. Each paragraph is indented."""@en ;
  dcterms:modified "2026-02-12T08:59:21.735250Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1458-1
  a curric:KeyLearningPoint ;
  rdfs:label """The pronounciation of a word helps to identify if it is spelt with -sure or -ture."""@en ;
  dcterms:modified "2026-02-12T08:59:21.735547Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1458-2
  a curric:KeyLearningPoint ;
  rdfs:label """The -ture ending to a word can be confused with a root word ending in '(t)ch+er', such as 'teacher' or 'richer'."""@en ;
  dcterms:modified "2026-02-12T08:59:21.735553Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1458-3
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum word: caught."@en ;
  dcterms:modified "2026-02-12T08:59:21.735560Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6006-1
  a curric:KeyLearningPoint ;
  rdfs:label "A formal letter should be written using a formal tone."@en ;
  dcterms:modified "2026-02-12T08:59:21.735564Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6006-2
  a curric:KeyLearningPoint ;
  rdfs:label """Formal writing can be identified by its serious, unemotional and impersonal tone."""@en ;
  dcterms:modified "2026-02-12T08:59:21.735568Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6006-3
  a curric:KeyLearningPoint ;
  rdfs:label "An introduction contains one introductory sentence."@en ;
  dcterms:modified "2026-02-12T08:59:21.735572Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6006-4
  a curric:KeyLearningPoint ;
  rdfs:label """It also contains a sentence to set-up the argument & a sentence sharing the purpose of the letter."""@en ;
  dcterms:modified "2026-02-12T08:59:21.735576Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1412-1
  a curric:KeyLearningPoint ;
  rdfs:label "The suffix -ic often turns nouns into adjectives."@en ;
  dcterms:modified "2026-02-12T08:59:21.735579Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1412-2
  a curric:KeyLearningPoint ;
  rdfs:label "When the root word ends in 'e', remove the 'e' and add the suffix -ic."@en ;
  dcterms:modified "2026-02-12T08:59:21.735583Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1412-3
  a curric:KeyLearningPoint ;
  rdfs:label "When the root word ends in 'y', remove the 'y' and add the suffix -ic."@en ;
  dcterms:modified "2026-02-12T08:59:21.735587Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1412-4
  a curric:KeyLearningPoint ;
  rdfs:label "When the root word does not end in 'e' or 'y', just add the suffix -ic."@en ;
  dcterms:modified "2026-02-12T08:59:21.735591Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1412-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: sentence, experiment and question."@en ;
  dcterms:modified "2026-02-12T08:59:21.735595Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27903-1
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to express yourself clearly and confidently in various social situations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.735599Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27903-2
  a curric:KeyLearningPoint ;
  rdfs:label """It is normal for people to agree and disagree with each other in a variety of social situations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.735602Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27903-3
  a curric:KeyLearningPoint ;
  rdfs:label "We can solve conflicts in groups by agreeing and disagreeing respectfully."@en ;
  dcterms:modified "2026-02-12T08:59:21.735606Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27903-4
  a curric:KeyLearningPoint ;
  rdfs:label """When we meet new adults, we can make a good first impression by being polite and respectful."""@en ;
  dcterms:modified "2026-02-12T08:59:21.735634Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27903-5
  a curric:KeyLearningPoint ;
  rdfs:label "When we meet new children, we can try to make friends by having conversations."@en ;
  dcterms:modified "2026-02-12T08:59:21.735658Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4888-1
  a curric:KeyLearningPoint ;
  rdfs:label "Presenting involves speaking in front of others and listening to others."@en ;
  dcterms:modified "2026-02-12T08:59:21.735663Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4888-2
  a curric:KeyLearningPoint ;
  rdfs:label """Presenting includes voice projection, speaking with clear diction, making eye contact and using strong body language."""@en ;
  dcterms:modified "2026-02-12T08:59:21.735668Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4888-3
  a curric:KeyLearningPoint ;
  rdfs:label "Voice projection is not the same as shouting."@en ;
  dcterms:modified "2026-02-12T08:59:21.735673Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4888-4
  a curric:KeyLearningPoint ;
  rdfs:label "Practising pronouncing tricky words helps develop clear diction when presenting."@en ;
  dcterms:modified "2026-02-12T08:59:21.735677Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1431-1
  a curric:KeyLearningPoint ;
  rdfs:label "-s is a suffix that can turn a singular noun into a plural."@en ;
  dcterms:modified "2026-02-12T08:59:21.735681Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1431-2
  a curric:KeyLearningPoint ;
  rdfs:label "-es is a suffix that can turn a singular noun into a plural."@en ;
  dcterms:modified "2026-02-12T08:59:21.735685Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1431-3
  a curric:KeyLearningPoint ;
  rdfs:label "Using the strategy \"colour blocks\" is a useful practice strategy."@en ;
  dcterms:modified "2026-02-12T08:59:21.735689Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1431-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum word: thought."@en ;
  dcterms:modified "2026-02-12T08:59:21.735710Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1391-1
  a curric:KeyLearningPoint ;
  rdfs:label "In words of Greek origin, the letter string 'ph' makes the /f/ sound"@en ;
  dcterms:modified "2026-02-12T08:59:21.736378Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1391-2
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: vegetable, language, library and vehicle"@en ;
  dcterms:modified "2026-02-12T08:59:21.736382Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1391-3
  a curric:KeyLearningPoint ;
  rdfs:label """Knowing which words have Greek etymology can help us to choose the correct spelling"""@en ;
  dcterms:modified "2026-02-12T08:59:21.736385Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1391-4
  a curric:KeyLearningPoint ;
  rdfs:label "Most words with the 'ph' spelling are nouns"@en ;
  dcterms:modified "2026-02-12T08:59:21.736391Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20366-1
  a curric:KeyLearningPoint ;
  rdfs:label "If the root word ends in a ‘sh’, ‘ch’, ‘ss’ or ‘x’, then add the suffix -es."@en ;
  dcterms:modified "2026-02-12T08:59:21.736396Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20366-2
  a curric:KeyLearningPoint ;
  rdfs:label "If the root word ends in an ‘o’, it can use -s or -es."@en ;
  dcterms:modified "2026-02-12T08:59:21.736399Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20366-3
  a curric:KeyLearningPoint ;
  rdfs:label """If the root word ends in a ‘f’ or ‘fe’, then the ‘f’ or 'fe' is replaced by ‘v’ before adding the suffix -es."""@en ;
  dcterms:modified "2026-02-12T08:59:21.736403Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20366-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell curriculum words: programme and identity"@en ;
  dcterms:modified "2026-02-12T08:59:21.736407Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2732-1
  a curric:KeyLearningPoint ;
  rdfs:label """A comma is written before 'but' or 'or' co-ordinating conjunctions in a compound sentence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.736536Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2732-2
  a curric:KeyLearningPoint ;
  rdfs:label """If the adverbial clause is first in an adverbial complex sentence, it is followed by a comma before the main clause."""@en ;
  dcterms:modified "2026-02-12T08:59:21.736540Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2732-3
  a curric:KeyLearningPoint ;
  rdfs:label """If the main clause is first in an adverbial complex sentence, it is not followed by a comma before the adverbial clause."""@en ;
  dcterms:modified "2026-02-12T08:59:21.736544Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2732-4
  a curric:KeyLearningPoint ;
  rdfs:label """A relative clause often interrupts after the subject of the main clause at the start of the sentence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.736550Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2732-5
  a curric:KeyLearningPoint ;
  rdfs:label """A pair of commas is used around the relative clause to demarcate it from the main clause."""@en ;
  dcterms:modified "2026-02-12T08:59:21.736554Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6553-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of an editing lesson is to improve your writing and make necessary corrections."""@en ;
  dcterms:modified "2026-02-12T08:59:21.736558Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6553-2
  a curric:KeyLearningPoint ;
  rdfs:label """Vocabulary, grammar and punctuation can be changed to make writing more effective."""@en ;
  dcterms:modified "2026-02-12T08:59:21.736562Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6553-3
  a curric:KeyLearningPoint ;
  rdfs:label "Editing is a vital element of the writing process."@en ;
  dcterms:modified "2026-02-12T08:59:21.736567Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1352-1
  a curric:KeyLearningPoint ;
  rdfs:label "The 'sh' sound in words of French origin is generally spelt 'ch'."@en ;
  dcterms:modified "2026-02-12T08:59:21.736572Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1352-2
  a curric:KeyLearningPoint ;
  rdfs:label "The 'g' sound in words of French origin is generally spelt 'gue'."@en ;
  dcterms:modified "2026-02-12T08:59:21.736576Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1352-3
  a curric:KeyLearningPoint ;
  rdfs:label "The 'k' sound in words of French origin is generally spelt 'que'."@en ;
  dcterms:modified "2026-02-12T08:59:21.736580Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1352-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: muscle, foreign and restaurant."@en ;
  dcterms:modified "2026-02-12T08:59:21.736583Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1344-1
  a curric:KeyLearningPoint ;
  rdfs:label """There are many ways to spell the ‘ee’ sound. ‘ee’, ‘ea’ and ‘e-e’ are the most common."""@en ;
  dcterms:modified "2026-02-12T08:59:21.736588Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1344-2
  a curric:KeyLearningPoint ;
  rdfs:label """Most words follow the rule: 'i' before 'e' except after 'c' where the sound is 'ee'."""@en ;
  dcterms:modified "2026-02-12T08:59:21.736591Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1344-3
  a curric:KeyLearningPoint ;
  rdfs:label """The 'ie' spelling can also break other learnt rules or be used when the sound is not 'ee'."""@en ;
  dcterms:modified "2026-02-12T08:59:21.736595Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1344-4
  a curric:KeyLearningPoint ;
  rdfs:label "The letter string ‘ie’ can represent a range of different sounds."@en ;
  dcterms:modified "2026-02-12T08:59:21.736600Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1344-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: sufficient, variety and achieve."@en ;
  dcterms:modified "2026-02-12T08:59:21.736604Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8020-1
  a curric:KeyLearningPoint ;
  rdfs:label "Haikus are short poems consisting of three lines."@en ;
  dcterms:modified "2026-02-12T08:59:21.736607Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8020-2
  a curric:KeyLearningPoint ;
  rdfs:label "Haikus have a specific number of syllables in each line."@en ;
  dcterms:modified "2026-02-12T08:59:21.736611Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8020-3
  a curric:KeyLearningPoint ;
  rdfs:label """A haiku is a traditional form of Japaense poetry that consists of three lines with a syllable count of 5-7-5."""@en ;
  dcterms:modified "2026-02-12T08:59:21.736615Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8020-4
  a curric:KeyLearningPoint ;
  rdfs:label "A haiku is traditionally written about nature."@en ;
  dcterms:modified "2026-02-12T08:59:21.736619Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1415-1
  a curric:KeyLearningPoint ;
  rdfs:label "The suffix -ery often turns words into nouns."@en ;
  dcterms:modified "2026-02-12T08:59:21.736623Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1415-2
  a curric:KeyLearningPoint ;
  rdfs:label "When the root word is obvious, the suffix -ery is often used."@en ;
  dcterms:modified "2026-02-12T08:59:21.736627Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1415-3
  a curric:KeyLearningPoint ;
  rdfs:label "When the root word ends in 'e', remove the 'e' and add the suffix -ery."@en ;
  dcterms:modified "2026-02-12T08:59:21.736631Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1415-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: regular, calendar and continue."@en ;
  dcterms:modified "2026-02-12T08:59:21.736635Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1405-1
  a curric:KeyLearningPoint ;
  rdfs:label "Words ending in the suffix -sion are nouns."@en ;
  dcterms:modified "2026-02-12T08:59:21.737224Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1405-2
  a curric:KeyLearningPoint ;
  rdfs:label "The suffix -sion sometimes makes the sound /zhun/ like ‘division’."@en ;
  dcterms:modified "2026-02-12T08:59:21.737228Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1405-3
  a curric:KeyLearningPoint ;
  rdfs:label "Words spelt with -sion often have a root word ending in ‘d’, ‘de’ or ‘se’."@en ;
  dcterms:modified "2026-02-12T08:59:21.737232Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1405-4
  a curric:KeyLearningPoint ;
  rdfs:label "The /shun/ suffix can be spelt -tion, -sion, -ssion or -cian."@en ;
  dcterms:modified "2026-02-12T08:59:21.737236Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1405-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: reign, island and February."@en ;
  dcterms:modified "2026-02-12T08:59:21.737242Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1402-1
  a curric:KeyLearningPoint ;
  rdfs:label "The suffix -ness turns adjectives into abstract nouns."@en ;
  dcterms:modified "2026-02-12T08:59:21.737246Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1402-2
  a curric:KeyLearningPoint ;
  rdfs:label "For most words, just add the suffix -ness."@en ;
  dcterms:modified "2026-02-12T08:59:21.737250Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1402-3
  a curric:KeyLearningPoint ;
  rdfs:label "When a word ends in ‘y’, replace the ‘y’ with ‘i’, then add the suffix -ness."@en ;
  dcterms:modified "2026-02-12T08:59:21.737254Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1402-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: heart, accident and accidentally."@en ;
  dcterms:modified "2026-02-12T08:59:21.737258Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7851-1
  a curric:KeyLearningPoint ;
  rdfs:label """Walter Tull's Scrapbook represents the true story of Walter Tull's life as a fictionalised scrapbook."""@en ;
  dcterms:modified "2026-02-12T08:59:21.737283Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7851-2
  a curric:KeyLearningPoint ;
  rdfs:label "The text uses actual photos, documents and records."@en ;
  dcterms:modified "2026-02-12T08:59:21.737287Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7851-3
  a curric:KeyLearningPoint ;
  rdfs:label """A biography is a non-fiction text which focuses on someone's life journey. It is written by another person."""@en ;
  dcterms:modified "2026-02-12T08:59:21.737290Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7851-4
  a curric:KeyLearningPoint ;
  rdfs:label """Knowing the historical and cultural context helps us understand the author’s perspective."""@en ;
  dcterms:modified "2026-02-12T08:59:21.737294Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1394-1
  a curric:KeyLearningPoint ;
  rdfs:label "In polysyllabic words, some vowels can be unstressed and hard to hear and spell."@en ;
  dcterms:modified "2026-02-12T08:59:21.737472Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1394-2
  a curric:KeyLearningPoint ;
  rdfs:label "Saying the word how it is spelt can help to learn the spelling."@en ;
  dcterms:modified "2026-02-12T08:59:21.737476Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1394-3
  a curric:KeyLearningPoint ;
  rdfs:label "Spotting a word inside another word can help to learn the spelling."@en ;
  dcterms:modified "2026-02-12T08:59:21.737479Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1394-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: favourite, persuade and queue."@en ;
  dcterms:modified "2026-02-12T08:59:21.737485Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1401-1
  a curric:KeyLearningPoint ;
  rdfs:label "The suffix -ity turns adjectives into abstract nouns."@en ;
  dcterms:modified "2026-02-12T08:59:21.737489Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1401-2
  a curric:KeyLearningPoint ;
  rdfs:label "When a word ends in ‘e’, remove the ‘e’, then add the suffix -ity."@en ;
  dcterms:modified "2026-02-12T08:59:21.737493Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1401-3
  a curric:KeyLearningPoint ;
  rdfs:label "When a word ends in a consonant, just add the suffix -ity."@en ;
  dcterms:modified "2026-02-12T08:59:21.737499Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1401-4
  a curric:KeyLearningPoint ;
  rdfs:label """How to spell irregular words with the suffix -ity, such as ability and simplicity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.737503Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1401-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: arrive, actual and actually."@en ;
  dcterms:modified "2026-02-12T08:59:21.737507Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1358-1
  a curric:KeyLearningPoint ;
  rdfs:label """Many suffixes follow the same or similar spelling rules to create generalised rules, but there are always exceptions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.737511Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1358-2
  a curric:KeyLearningPoint ;
  rdfs:label "The suffixes -ed and -ing change the tense of a word."@en ;
  dcterms:modified "2026-02-12T08:59:21.737515Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1358-3
  a curric:KeyLearningPoint ;
  rdfs:label "The suffixes -s and -es change a noun from singular to plural."@en ;
  dcterms:modified "2026-02-12T08:59:21.737519Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1358-4
  a curric:KeyLearningPoint ;
  rdfs:label """The suffixes -en, -ate, -ise and -ify often turn adjectives and nouns into verbs."""@en ;
  dcterms:modified "2026-02-12T08:59:21.737523Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1358-5
  a curric:KeyLearningPoint ;
  rdfs:label "The suffixes -al, -ic, -ful and -less create adjectives."@en ;
  dcterms:modified "2026-02-12T08:59:21.737527Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1039-1
  a curric:KeyLearningPoint ;
  rdfs:label "A simple sentence is a main clause about one idea."@en ;
  dcterms:modified "2026-02-12T08:59:21.737531Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1039-2
  a curric:KeyLearningPoint ;
  rdfs:label "A compound sentence is a sentence formed of two main clauses and a joining word."@en ;
  dcterms:modified "2026-02-12T08:59:21.737535Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1039-3
  a curric:KeyLearningPoint ;
  rdfs:label """Co-ordinating conjunction is the term for a word that joins two main clauses to form a compound sentence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.737539Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1039-4
  a curric:KeyLearningPoint ;
  rdfs:label "There are three co-ordinating conjunctions: \"and\", \"but\" and \"or\"."@en ;
  dcterms:modified "2026-02-12T08:59:21.737542Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1039-5
  a curric:KeyLearningPoint ;
  rdfs:label "Each co-ordinating conjunction has a different purpose."@en ;
  dcterms:modified "2026-02-12T08:59:21.737546Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4889-1
  a curric:KeyLearningPoint ;
  rdfs:label "a non-chronological report is a type of non-fiction text"@en ;
  dcterms:modified "2026-02-12T08:59:21.737550Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4889-2
  a curric:KeyLearningPoint ;
  rdfs:label """the purpose of a non-chronological report is to inform the reader about a particular subject"""@en ;
  dcterms:modified "2026-02-12T08:59:21.737554Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4889-3
  a curric:KeyLearningPoint ;
  rdfs:label """information in a non-chronological report is organised using a title, subheadings and paragraphs"""@en ;
  dcterms:modified "2026-02-12T08:59:21.737560Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4889-4
  a curric:KeyLearningPoint ;
  rdfs:label """linguistic features help to introduce, link and bring to life specific, factual information"""@en ;
  dcterms:modified "2026-02-12T08:59:21.737564Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4854-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the recount section is to engage the reader and provide them with specific facts about the topic."""@en ;
  dcterms:modified "2026-02-12T08:59:21.737568Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4854-2
  a curric:KeyLearningPoint ;
  rdfs:label "Using a range of different sentence structures enhances text cohesion."@en ;
  dcterms:modified "2026-02-12T08:59:21.737574Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4854-3
  a curric:KeyLearningPoint ;
  rdfs:label """Using different types of complex sentence enables us to share information with our reader in different ways."""@en ;
  dcterms:modified "2026-02-12T08:59:21.737578Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4854-4
  a curric:KeyLearningPoint ;
  rdfs:label """When writing, we should use our plans and success criteria so our writing can be as effective as possible."""@en ;
  dcterms:modified "2026-02-12T08:59:21.737582Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1311-1
  a curric:KeyLearningPoint ;
  rdfs:label "The suffix -ous often turns nouns into adjectives and often means 'full of'."@en ;
  dcterms:modified "2026-02-12T08:59:21.737586Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1311-2
  a curric:KeyLearningPoint ;
  rdfs:label "If the root word ends in 'ge', just add -ous."@en ;
  dcterms:modified "2026-02-12T08:59:21.737590Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1311-3
  a curric:KeyLearningPoint ;
  rdfs:label "If the root word ends in 'e', remove the 'e', then add -ous."@en ;
  dcterms:modified "2026-02-12T08:59:21.737594Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1311-4
  a curric:KeyLearningPoint ;
  rdfs:label "If the root word ends in 'our', change 'our' to 'or', then add -ous."@en ;
  dcterms:modified "2026-02-12T08:59:21.737598Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1311-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: promise and favourite."@en ;
  dcterms:modified "2026-02-12T08:59:21.737601Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27779-1
  a curric:KeyLearningPoint ;
  rdfs:label """A speaker can engage an audience through a variety of techniques, including repetition."""@en ;
  dcterms:modified "2026-02-12T08:59:21.737750Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27779-2
  a curric:KeyLearningPoint ;
  rdfs:label """Martin Luther King Jr.'s famous speech entitled 'I Have A Dream' uses repetition to engage the audience."""@en ;
  dcterms:modified "2026-02-12T08:59:21.737754Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27779-3
  a curric:KeyLearningPoint ;
  rdfs:label """‘I Have a Dream’ by Martin Luther King Jr. was written to help bring about racial equality."""@en ;
  dcterms:modified "2026-02-12T08:59:21.737758Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27606-1
  a curric:KeyLearningPoint ;
  rdfs:label "Fairy tales are fiction stories about magical and imaginary beings and lands."@en ;
  dcterms:modified "2026-02-12T08:59:21.737762Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27606-2
  a curric:KeyLearningPoint ;
  rdfs:label """Fairy tales belong to the genre of folklore in which stories are orally shared and passed down over time."""@en ;
  dcterms:modified "2026-02-12T08:59:21.737766Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27606-3
  a curric:KeyLearningPoint ;
  rdfs:label "Stories can be structured in four parts and each part has a different purpose."@en ;
  dcterms:modified "2026-02-12T08:59:21.737770Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27606-4
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to sequence a story correctly so that it can be enjoyed and understood."""@en ;
  dcterms:modified "2026-02-12T08:59:21.737774Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1037-1
  a curric:KeyLearningPoint ;
  rdfs:label "Presenting involves speaking in front of others and listening to others."@en ;
  dcterms:modified "2026-02-12T08:59:21.737778Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1037-2
  a curric:KeyLearningPoint ;
  rdfs:label """Presenting involves speaking with clear diction and suitable volume, making eye contact and using strong body language."""@en ;
  dcterms:modified "2026-02-12T08:59:21.737782Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1037-3
  a curric:KeyLearningPoint ;
  rdfs:label "Practising pronouncing tricky words helps develop clear diction when presenting."@en ;
  dcterms:modified "2026-02-12T08:59:21.737786Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1037-4
  a curric:KeyLearningPoint ;
  rdfs:label "Rehearsing helps the presenter to speak more confidently and fluently."@en ;
  dcterms:modified "2026-02-12T08:59:21.737790Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1037-5
  a curric:KeyLearningPoint ;
  rdfs:label "Pauses at the end of sentences can help the audience follow what is being said."@en ;
  dcterms:modified "2026-02-12T08:59:21.737793Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1304-1
  a curric:KeyLearningPoint ;
  rdfs:label "Adding the suffix -ing turns the verb into the progressive tense."@en ;
  dcterms:modified "2026-02-12T08:59:21.737799Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1304-2
  a curric:KeyLearningPoint ;
  rdfs:label "When the word ends in 'e', remove the 'e' and add the suffix -ing."@en ;
  dcterms:modified "2026-02-12T08:59:21.737803Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1304-3
  a curric:KeyLearningPoint ;
  rdfs:label "When the word ends in 'y', just add the suffix -ing."@en ;
