  a curric:KeyLearningPoint ;
  rdfs:label """An adverbial complex sentence has a main clause and an adverbial clause that starts with a subordinating conjunction."""@en ;
  dcterms:modified "2026-02-12T08:59:21.612515Z"^^xsd:dateTime .

