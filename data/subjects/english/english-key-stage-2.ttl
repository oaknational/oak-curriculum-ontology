  dcterms:modified "2026-02-12T08:59:21.612522Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5999-5
  a curric:KeyLearningPoint ;
  rdfs:label """First person perspective is the point of view where the writer is the 'I' character."""@en ;
  dcterms:modified "2026-02-12T08:59:21.612529Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8175-1
  a curric:KeyLearningPoint ;
  rdfs:label "A letter is a piece of writing that someone sends to someone else."@en ;
