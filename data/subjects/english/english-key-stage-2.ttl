  dcterms:modified "2026-02-12T08:59:21.643563Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8643-1
  a curric:KeyLearningPoint ;
  rdfs:label """In this section of the build-up, the suspense heightens when Arrietty encounters the eye of a human “bean”."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643568Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8643-2
  a curric:KeyLearningPoint ;
  rdfs:label """The use of precise and ambitious vocabulary, including ‘show and tell’ language supports the building of suspense."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643575Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8643-3
  a curric:KeyLearningPoint ;
  rdfs:label "Rhetorical questions can be used to convey a character’s inner thoughts."@en ;
