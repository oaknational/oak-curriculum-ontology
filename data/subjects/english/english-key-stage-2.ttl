  a curric:KeyLearningPoint ;
  rdfs:label """The appearance section informs the reader of adaptations of the spider that allow it to be a successful predator."""@en ;
  dcterms:modified "2026-02-12T08:59:21.612802Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1031-2
  a curric:KeyLearningPoint ;
  rdfs:label "Portia spiders have a range of physical adaptations."@en ;
  dcterms:modified "2026-02-12T08:59:21.612809Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1031-3
  a curric:KeyLearningPoint ;
  rdfs:label """Viewpoint fronted adverbials and formal fronted adverbials are used at the start of sentences for cohesion."""@en ;
  dcterms:modified "2026-02-12T08:59:21.612815Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1031-4
  a curric:KeyLearningPoint ;
  rdfs:label "Facts get increasingly specific throughout one section."@en ;
  dcterms:modified "2026-02-12T08:59:21.612822Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1031-5
  a curric:KeyLearningPoint ;
  rdfs:label """Notes should not be written in full sentences and bullet points can be used to order notes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.612829Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8018-1
  a curric:KeyLearningPoint ;
  rdfs:label "Learning a poem by heart means you can say it from memory."@en ;
  dcterms:modified "2026-02-12T08:59:21.613053Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8018-2
  a curric:KeyLearningPoint ;
  rdfs:label "Reciting a poem means to say it aloud after learning it."@en ;
  dcterms:modified "2026-02-12T08:59:21.613059Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8018-3
  a curric:KeyLearningPoint ;
  rdfs:label "Saying the poem out loud many times will help when learning it by heart."@en ;
  dcterms:modified "2026-02-12T08:59:21.613066Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8018-4
  a curric:KeyLearningPoint ;
  rdfs:label """We can follow four steps to learn a poem by heart: 'Hear it', 'Read it', 'Check it', 'Practise it'."""@en ;
  dcterms:modified "2026-02-12T08:59:21.613077Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1323-1
  a curric:KeyLearningPoint ;
  rdfs:label """Visuals and captions make information easier to understand and remember for the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.613139Z"^^xsd:dateTime .

