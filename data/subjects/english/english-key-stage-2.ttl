oakcurric:keylearningpoint-lesson-6189-1
  a curric:KeyLearningPoint ;
  rdfs:label "Because an essay is a non-fiction piece of writing, it must be based on facts."@en ;
  dcterms:modified "2026-02-12T08:59:21.643594Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6189-2
  a curric:KeyLearningPoint ;
  rdfs:label "Facts are obtained through research, using reliable sources."@en ;
  dcterms:modified "2026-02-12T08:59:21.643599Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6189-3
  a curric:KeyLearningPoint ;
  rdfs:label "Research can be collated using bullet points under different headings."@en ;
  dcterms:modified "2026-02-12T08:59:21.643604Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6189-4
  a curric:KeyLearningPoint ;
  rdfs:label "Our essay will show just one side of an argument."@en ;
  dcterms:modified "2026-02-12T08:59:21.643612Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6189-5
  a curric:KeyLearningPoint ;
  rdfs:label """We can break an essay question down into smaller questions in order to structure our essay."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643617Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6191-1
  a curric:KeyLearningPoint ;
  rdfs:label "A logical argument should run through an essay, leading towards a conclusion."@en ;
  dcterms:modified "2026-02-12T08:59:21.643648Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6191-2
  a curric:KeyLearningPoint ;
  rdfs:label """We should be confident in setting out this logical argument in its entirety before we begin to write."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643653Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6191-3
  a curric:KeyLearningPoint ;
  rdfs:label """Within an essay, a range of linguistic features and punctuation will be used to connect ideas."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643657Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6191-4
  a curric:KeyLearningPoint ;
  rdfs:label """These linguistic features can be used to show cause and effect, contrast and 'adding on'."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643662Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6191-5
  a curric:KeyLearningPoint ;
