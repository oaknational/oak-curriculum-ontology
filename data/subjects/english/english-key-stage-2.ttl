# ----------------------------------------------------------------------
# Key Learning Points
# ----------------------------------------------------------------------

oakcurric:keylearningpoint-lesson-1077-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Desolate' is an adjective which means feeling miserable, depressed or lonely."@en ;
  dcterms:modified "2026-02-12T08:59:21.481874Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1077-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Melancholy' is an adjective which means gloomy or depressed, despairing about everything."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481880Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1077-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Inconsolable' is an adjective which means very unhappy or heartbroken; feeling so sad it's impossible to cheer you up."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481884Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1077-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Wistful', 'glum' and 'yearning' are other rich vocabulary associated with feeling sad."""@en ;
  dcterms:modified "2026-02-12T08:59:21.481889Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6550-1
  a curric:KeyLearningPoint ;
  rdfs:label "An introductory sentence indicates what the paragraph will be about."@en ;
  dcterms:modified "2026-02-12T08:59:21.482066Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6550-2
  a curric:KeyLearningPoint ;
  rdfs:label "Flattery and presumption are appropriate devices to use in the introduction."@en ;
  dcterms:modified "2026-02-12T08:59:21.482070Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6550-3
  a curric:KeyLearningPoint ;
  rdfs:label """The introduction must clearly communicate why the author is writing to the recipient."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482074Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6550-4
  a curric:KeyLearningPoint ;
  rdfs:label "This persuasive letter is formal in tone."@en ;
  dcterms:modified "2026-02-12T08:59:21.482080Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6328-1
  a curric:KeyLearningPoint ;
  rdfs:label """'Shackleton's Journey' includes themes of leadership, resilience, hope and exploration."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482811Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6328-2
  a curric:KeyLearningPoint ;
  rdfs:label """Shackleton is recognised as an excellent leader, who remained determined in the face of adversity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482815Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6328-3
  a curric:KeyLearningPoint ;
  rdfs:label """Ernest Shackleton set an excellent example to his crew; he was an inspirational role model."""@en ;
  dcterms:modified "2026-02-12T08:59:21.482819Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7864-1
  a curric:KeyLearningPoint ;
  rdfs:label "Reading between the lines to search for clues can help to infer meaning"@en ;
  dcterms:modified "2026-02-12T08:59:21.483644Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7864-2
  a curric:KeyLearningPoint ;
  rdfs:label "Evidence from the text helps us to justify our inferences"@en ;
  dcterms:modified "2026-02-12T08:59:21.483648Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7864-3
  a curric:KeyLearningPoint ;
  rdfs:label """It was believed that the Earth was squeezed out of the sea and sifted out of the sky"""@en ;
  dcterms:modified "2026-02-12T08:59:21.483652Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7864-4
  a curric:KeyLearningPoint ;
  rdfs:label "It was believed that Chronos disentangled the elements"@en ;
  dcterms:modified "2026-02-12T08:59:21.483656Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7864-5
  a curric:KeyLearningPoint ;
  rdfs:label "Gods, godesses, giants and Titans all lived together on Earth"@en ;
  dcterms:modified "2026-02-12T08:59:21.483660Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7832-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Swallow's Kiss' is written in free verse."@en ;
  dcterms:modified "2026-02-12T08:59:21.483980Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7832-2
  a curric:KeyLearningPoint ;
  rdfs:label """Free verse is any form of poetry that does not rely on consistent patterns of rhyme and meter."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483985Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7832-3
  a curric:KeyLearningPoint ;
  rdfs:label """It is told from the perspective of Blessing, a young girl whose mother travelled across roads and seas to seek refuge."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483991Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7832-4
  a curric:KeyLearningPoint ;
  rdfs:label """Blessing's close relationship with her family is mirrored in the members of the community that are supporting them."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483995Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8140-1
  a curric:KeyLearningPoint ;
  rdfs:label "Children often use drawings in their diaries as a way of telling stories."@en ;
  dcterms:modified "2026-02-12T08:59:21.484164Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8140-2
  a curric:KeyLearningPoint ;
  rdfs:label "A doodle is a sketch completed absent-mindedly."@en ;
  dcterms:modified "2026-02-12T08:59:21.484168Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8140-3
  a curric:KeyLearningPoint ;
  rdfs:label "Neat, joined handwriting is important when publishing a diary entry."@en ;
  dcterms:modified "2026-02-12T08:59:21.484172Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8140-4
  a curric:KeyLearningPoint ;
  rdfs:label """A published diary entry should be visually and linguistically appealing to the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484176Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8139-1
  a curric:KeyLearningPoint ;
  rdfs:label "A  theme is a big idea, topic or message that appears in a story."@en ;
  dcterms:modified "2026-02-12T08:59:21.484329Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8139-2
  a curric:KeyLearningPoint ;
  rdfs:label "Themes in a story are used to convey deeper meaning and messages to the reader."@en ;
  dcterms:modified "2026-02-12T08:59:21.484334Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8139-3
  a curric:KeyLearningPoint ;
  rdfs:label """‘The Journey’ explores the following themes: war and conflict, resilience, hope and displacement."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484338Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8139-4
  a curric:KeyLearningPoint ;
  rdfs:label "The girl’s emotions change throughout the narrative."@en ;
  dcterms:modified "2026-02-12T08:59:21.484342Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8139-5
  a curric:KeyLearningPoint ;
  rdfs:label "Expressing thoughts and emotions is a key part of writing a diary entry."@en ;
  dcterms:modified "2026-02-12T08:59:21.484346Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6327-1
  a curric:KeyLearningPoint ;
  rdfs:label "Reading between the lines to search for clues can help to infer meaning."@en ;
  dcterms:modified "2026-02-12T08:59:21.484350Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6327-2
  a curric:KeyLearningPoint ;
  rdfs:label "Evidence from the text helps us to justify our inferences."@en ;
  dcterms:modified "2026-02-12T08:59:21.484354Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6327-3
  a curric:KeyLearningPoint ;
  rdfs:label """An impression can be formed from reader’s initial feelings from reading the text, or prior experience."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484357Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5449-1
  a curric:KeyLearningPoint ;
  rdfs:label "‘Mulan’ is a legend which belongs to the genre of folklore."@en ;
  dcterms:modified "2026-02-12T08:59:21.484754Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5449-2
  a curric:KeyLearningPoint ;
  rdfs:label """Folklore is a genre in which oral stories are passed down over time and they originate from a range of cultures."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484758Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5449-3
  a curric:KeyLearningPoint ;
  rdfs:label """Legends are a type of folktale that reflect some element of true history and convey an important moral or lesson."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484762Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5449-4
  a curric:KeyLearningPoint ;
  rdfs:label """‘Mulan’ originated in China during a time of real war and it challenges ideas around the role of women."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484766Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5449-5
  a curric:KeyLearningPoint ;
  rdfs:label """The legend of ‘Mulan’ is about a young girl who disguises herself as a boy in order to fight in the army."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484772Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8133-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of a diary entry is to recount important personal experiences and to express feelings."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484778Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8133-2
  a curric:KeyLearningPoint ;
  rdfs:label """A diary entry follows a specific structure; it is written in the first person and it uses informal language."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484783Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8133-3
  a curric:KeyLearningPoint ;
  rdfs:label """Simple past and progressive past tenses recount what the writer experienced and felt."""@en ;
