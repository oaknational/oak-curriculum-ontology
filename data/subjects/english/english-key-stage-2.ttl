# ----------------------------------------------------------------------
# Key Learning Points
# ----------------------------------------------------------------------

oakcurric:keylearningpoint-lesson-1306-1
  a curric:KeyLearningPoint ;
  rdfs:label """A suffix is a letter or group of letters at the end of a word which creates another
  word and can change the word class."""@en ;
  dcterms:modified "2026-06-07T15:30:28.999550Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1306-2
  a curric:KeyLearningPoint ;
  rdfs:label "The suffix -ate often turns adjectives and nouns into verbs."@en ;
  dcterms:modified "2026-06-07T15:30:28.999555Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1306-3
  a curric:KeyLearningPoint ;
  rdfs:label "When the root word ends in a consonant, we often just add the suffix."@en ;
  dcterms:modified "2026-06-07T15:30:28.999559Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1306-4
  a curric:KeyLearningPoint ;
  rdfs:label """When the root word ends in a vowel, we remove the final vowel and add the
  suffix."""@en ;
  dcterms:modified "2026-06-07T15:30:28.999563Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1306-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: business, possession and answer."@en ;
  dcterms:modified "2026-06-07T15:30:28.999568Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2726-1
  a curric:KeyLearningPoint ;
  rdfs:label "Editing is the process of making changes to improve our writing."@en ;
  dcterms:modified "2026-06-07T15:30:28.999615Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2726-2
  a curric:KeyLearningPoint ;
  rdfs:label "Editing can be done by oneself, with a peer or with a teacher."@en ;
  dcterms:modified "2026-06-07T15:30:28.999620Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2726-3
  a curric:KeyLearningPoint ;
  rdfs:label """When editing punctuation, missing or incorrectly used capital letters, full stops,
  inverted commas & commas are checked."""@en ;
  dcterms:modified "2026-06-07T15:30:28.999624Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2726-4
  a curric:KeyLearningPoint ;
  rdfs:label """When editing sentence structure, the way sentences are constructed is checked to
  improve and enhance text flow."""@en ;
  dcterms:modified "2026-06-07T15:30:28.999628Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2726-5
  a curric:KeyLearningPoint ;
  rdfs:label "When editing language, choices of words and phrases are carefully reviewed."@en ;
  dcterms:modified "2026-06-07T15:30:28.999634Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6380-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of an editing lesson is to improve your writing and make necessary
  corrections."""@en ;
  dcterms:modified "2026-06-07T15:30:28.999639Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6380-2
  a curric:KeyLearningPoint ;
  rdfs:label """Vocabulary, grammar and punctuation can be changed to make writing more effectively
  meet its purpose."""@en ;
  dcterms:modified "2026-06-07T15:30:28.999643Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6380-3
  a curric:KeyLearningPoint ;
  rdfs:label """Specific rules of how to punctuate speech first and speech second sentences must be
  checked during the editing process."""@en ;
  dcterms:modified "2026-06-07T15:30:28.999647Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8635-1
  a curric:KeyLearningPoint ;
  rdfs:label """The opening introduces the Clock family as the main characters and describes the
  setting of their home."""@en ;
  dcterms:modified "2026-06-07T15:30:28.999663Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8635-2
  a curric:KeyLearningPoint ;
  rdfs:label """The Clock family live under the kitchen floorboards and access the upstairs through
  a hole at the bottom of a clock."""@en ;
  dcterms:modified "2026-06-07T15:30:28.999667Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8635-3
  a curric:KeyLearningPoint ;
  rdfs:label """The Clock family’s home is made up of items borrowed from the human “beans”, which
  are used in new ways."""@en ;
  dcterms:modified "2026-06-07T15:30:28.999671Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8635-4
  a curric:KeyLearningPoint ;
  rdfs:label """A character trait is a special quality that makes a character in a story unique or
  interesting."""@en ;
  dcterms:modified "2026-06-07T15:30:28.999675Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8635-5
  a curric:KeyLearningPoint ;
  rdfs:label """We can infer different character traits of Pod, Homily and Arrietty through
  exploring their experiences and actions."""@en ;
  dcterms:modified "2026-06-07T15:30:28.999680Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4901-1
  a curric:KeyLearningPoint ;
  rdfs:label "Presenting involves speaking in front of others and listening to others."@en ;
  dcterms:modified "2026-06-07T15:30:28.999684Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4901-2
  a curric:KeyLearningPoint ;
  rdfs:label """Presenting includes using voice projection, speaking with clear diction, making eye
  contact and strong body language."""@en ;
  dcterms:modified "2026-06-07T15:30:28.999688Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4901-3
  a curric:KeyLearningPoint ;
  rdfs:label "Voice projection is not the same as shouting."@en ;
  dcterms:modified "2026-06-07T15:30:28.999692Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4901-4
  a curric:KeyLearningPoint ;
  rdfs:label "Practising pronouncing tricky words helps develop clear diction when presenting."@en ;
  dcterms:modified "2026-06-07T15:30:28.999696Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4879-1
  a curric:KeyLearningPoint ;
  rdfs:label "The conclusion is the final paragraph of a non-chronological report."@en ;
  dcterms:modified "2026-06-07T15:30:28.999700Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4879-2
  a curric:KeyLearningPoint ;
  rdfs:label "The purpose of the conclusion is to summarise the key information of the report."@en ;
  dcterms:modified "2026-06-07T15:30:28.999704Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4879-3
  a curric:KeyLearningPoint ;
  rdfs:label "Only general information is included in the conclusion."@en ;
  dcterms:modified "2026-06-07T15:30:28.999711Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4879-4
  a curric:KeyLearningPoint ;
  rdfs:label """Success criteria can be used to help a writer understand what to include in their
  writing to make it successful."""@en ;
  dcterms:modified "2026-06-07T15:30:28.999718Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2703-1
  a curric:KeyLearningPoint ;
  rdfs:label "The verb carries the tense of a sentence."@en ;
  dcterms:modified "2026-06-07T15:30:28.999722Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2703-2
  a curric:KeyLearningPoint ;
  rdfs:label "Sentences can be formed in the first, second or third person."@en ;
  dcterms:modified "2026-06-07T15:30:28.999726Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2703-3
  a curric:KeyLearningPoint ;
  rdfs:label "The simple tense can denote present, past or future action."@en ;
  dcterms:modified "2026-06-07T15:30:28.999730Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2703-4
  a curric:KeyLearningPoint ;
  rdfs:label """The simple tense is a tense that does not make use of an auxiliary verb in addition
  to the main verb."""@en ;
  dcterms:modified "2026-06-07T15:30:28.999734Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2703-5
  a curric:KeyLearningPoint ;
  rdfs:label "Tense is often maintained within sentences."@en ;
  dcterms:modified "2026-06-07T15:30:28.999738Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1096-1
  a curric:KeyLearningPoint ;
  rdfs:label """'Idyllic' is an adjective which means ideal or perfect; like a beautiful place where
  you can relax in the sun."""@en ;
  dcterms:modified "2026-06-07T15:30:28.999871Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1096-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Verdant' is an adjective which means green and leafy; like a lush valley where
  sheep graze on the grass ."""@en ;
  dcterms:modified "2026-06-07T15:30:28.999875Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1096-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Rolling' is an adjective which means rippling, wavy or tumbling; like gentle hills
  that rise & fall like endless waves."""@en ;
  dcterms:modified "2026-06-07T15:30:28.999879Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1096-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Lush', 'scenic' and 'secluded' are other rich vocabulary associated with the
  countryside."""@en ;
  dcterms:modified "2026-06-07T15:30:28.999886Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6012-1
  a curric:KeyLearningPoint ;
  rdfs:label """The conclusion is the last paragraph that summarises the key information of the
  letter."""@en ;
  dcterms:modified "2026-06-07T15:30:28.999891Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6012-2
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the conclusion is to thank the reader, encourage action and emphasise
  the purpose of the letter."""@en ;
  dcterms:modified "2026-06-07T15:30:28.999895Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6012-3
  a curric:KeyLearningPoint ;
  rdfs:label "Veiled threats provide a threat that isn’t directly stated but is implied."@en ;
  dcterms:modified "2026-06-07T15:30:28.999899Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6012-4
  a curric:KeyLearningPoint ;
  rdfs:label """Presumption can make the reader feel like you already believe they’ll do what you
  are asking."""@en ;
  dcterms:modified "2026-06-07T15:30:28.999903Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5495-1
  a curric:KeyLearningPoint ;
  rdfs:label """A grammatically accurate sentence has a subject and a verb. It can contain an
  object."""@en ;
  dcterms:modified "2026-06-07T15:30:28.999907Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5495-2
  a curric:KeyLearningPoint ;
  rdfs:label "A sentence can be written or spoken in the active voice."@en ;
  dcterms:modified "2026-06-07T15:30:28.999911Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5495-3
  a curric:KeyLearningPoint ;
  rdfs:label "A sentence can be written or spoken in the passive voice."@en ;
  dcterms:modified "2026-06-07T15:30:28.999915Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5495-4
  a curric:KeyLearningPoint ;
  rdfs:label "The active voice and passive voice are useful for different purposes."@en ;
  dcterms:modified "2026-06-07T15:30:28.999919Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7877-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘Princess Sophia Duleep Singh: My Story’ is a historical fiction text set between
  1886-1928."""@en ;
  dcterms:modified "2026-06-07T15:30:28.999923Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7877-2
  a curric:KeyLearningPoint ;
  rdfs:label """Sophia's life was intertwined with significant events related to the British
  Empire's rule over India."""@en ;
  dcterms:modified "2026-06-07T15:30:28.999927Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7877-3
  a curric:KeyLearningPoint ;
  rdfs:label """The text explores British history as well as celebrating diversity, with strong
  themes of family & justice."""@en ;
  dcterms:modified "2026-06-07T15:30:28.999931Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8090-1
  a curric:KeyLearningPoint ;
  rdfs:label """When writing a poem about a place, it’s important to paint a vivid picture of the
  setting through our description."""@en ;
  dcterms:modified "2026-06-07T15:30:28.999935Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8090-2
  a curric:KeyLearningPoint ;
  rdfs:label """Sensory description can be used to help the reader visualise the place being written
  about."""@en ;
  dcterms:modified "2026-06-07T15:30:28.999940Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8090-3
  a curric:KeyLearningPoint ;
  rdfs:label "Imagery we create can convey an atmosphere."@en ;
  dcterms:modified "2026-06-07T15:30:28.999944Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8090-4
  a curric:KeyLearningPoint ;
  rdfs:label "We can use poems that we have studied to inspire us in our own poem."@en ;
  dcterms:modified "2026-06-07T15:30:28.999951Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8090-5
  a curric:KeyLearningPoint ;
  rdfs:label """Using enjambment in our poems can enhance the flow of the poem, engaging the reader
  or listener."""@en ;
  dcterms:modified "2026-06-07T15:30:28.999955Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1349-1
  a curric:KeyLearningPoint ;
  rdfs:label """The suffix -ible is common if a complete root word cannot be heard before it, e.g.
  legible, invincible."""@en ;
  dcterms:modified "2026-06-07T15:30:28.999977Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1349-2
  a curric:KeyLearningPoint ;
  rdfs:label """If there is an obvious root, the suffix -ible usually follows stems ending in an 's'
  sound e.g. response - responsible."""@en ;
  dcterms:modified "2026-06-07T15:30:28.999981Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1349-3
  a curric:KeyLearningPoint ;
  rdfs:label """Removing the -ible suffix does not usually leave a recognisable root word in
  English, e.g. visible - vis."""@en ;
  dcterms:modified "2026-06-07T15:30:28.999985Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1349-4
  a curric:KeyLearningPoint ;
  rdfs:label """Adjectives ending in the suffix -ible and adverbs ending in the suffix -ibly are
  connected in spelling and meaning."""@en ;
  dcterms:modified "2026-06-07T15:30:28.999989Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1349-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: definite and immediate."@en ;
  dcterms:modified "2026-06-07T15:30:28.999995Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4806-1
  a curric:KeyLearningPoint ;
  rdfs:label """A suffix is a letter or group of letters at the end of a word which creates another
  word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.000040Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4806-2
  a curric:KeyLearningPoint ;
  rdfs:label "The words start with a lead in and finish with a lead out."@en ;
  dcterms:modified "2026-06-07T15:30:29.000047Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4806-3
  a curric:KeyLearningPoint ;
  rdfs:label """The pencil does not lift when forming the join, only after to add the cross to a t
  or a dot to an i or a j."""@en ;
  dcterms:modified "2026-06-07T15:30:29.000051Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4806-4
  a curric:KeyLearningPoint ;
  rdfs:label "There are four cursive joins."@en ;
  dcterms:modified "2026-06-07T15:30:29.000056Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4806-5
  a curric:KeyLearningPoint ;
  rdfs:label """The join used depends on which letter is joining to which letter within a letter
  string."""@en ;
  dcterms:modified "2026-06-07T15:30:29.000060Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7915-1
  a curric:KeyLearningPoint ;
  rdfs:label """'A Kind of Spark' is a novel set in Scotland and written by Elle McNicoll, who is
  autistic herself."""@en ;
  dcterms:modified "2026-06-07T15:30:29.000064Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7915-2
  a curric:KeyLearningPoint ;
  rdfs:label """Addie, the main protagonist, is autistic, but this does not define her
  exclusively."""@en ;
  dcterms:modified "2026-06-07T15:30:29.000068Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7915-3
  a curric:KeyLearningPoint ;
  rdfs:label "The book is written in the first person from Addie's perspective."@en ;
  dcterms:modified "2026-06-07T15:30:29.000072Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7915-4
  a curric:KeyLearningPoint ;
  rdfs:label "When we read, we make inferences about characters based on evidence in the text."@en ;
  dcterms:modified "2026-06-07T15:30:29.000076Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7915-5
  a curric:KeyLearningPoint ;
  rdfs:label """At the start of the book, Addie has a close relationship with her sister Keedie -
  but not with her sister Nina."""@en ;
  dcterms:modified "2026-06-07T15:30:29.000080Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6740-1
  a curric:KeyLearningPoint ;
  rdfs:label """We are writing about an event from the build-up, using a third person
  perspective."""@en ;
  dcterms:modified "2026-06-07T15:30:29.000451Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6740-2
  a curric:KeyLearningPoint ;
  rdfs:label """We are then using internal monologue to reflect on the same event from Addie's
  perspective."""@en ;
  dcterms:modified "2026-06-07T15:30:29.000455Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6740-3
  a curric:KeyLearningPoint ;
  rdfs:label "Using a plan and orally rehearsing our writing helps us to do our best writing."@en ;
  dcterms:modified "2026-06-07T15:30:29.000459Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6740-4
  a curric:KeyLearningPoint ;
  rdfs:label """We should aim to use a complete range of sentence types and language features in our
  writing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.000465Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6722-1
  a curric:KeyLearningPoint ;
  rdfs:label """In a biography, we write using a formal tone in the third person; our writing is
  mostly, but not all, in the past tense."""@en ;
  dcterms:modified "2026-06-07T15:30:29.000489Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6722-2
  a curric:KeyLearningPoint ;
  rdfs:label "We use a range of cohesive devices to connect ideas together."@en ;
  dcterms:modified "2026-06-07T15:30:29.000493Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6722-3
  a curric:KeyLearningPoint ;
  rdfs:label "We orally rehearse our sentences before we write, using our notes."@en ;
  dcterms:modified "2026-06-07T15:30:29.000497Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6722-4
  a curric:KeyLearningPoint ;
  rdfs:label """We can include parenthesis to add extra details to a sentence, including using
  brackets and relative clauses."""@en ;
  dcterms:modified "2026-06-07T15:30:29.000502Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6722-5
  a curric:KeyLearningPoint ;
  rdfs:label """We give a title for the biography as a whole and subheadings for each paragraph.
  Each paragraph is indented."""@en ;
  dcterms:modified "2026-06-07T15:30:29.000506Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27625-1
  a curric:KeyLearningPoint ;
  rdfs:label "The motion is the name for the belief or proposal that is being debated."@en ;
  dcterms:modified "2026-06-07T15:30:29.000510Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27625-2
  a curric:KeyLearningPoint ;
  rdfs:label "The motion in a debate always starts with the words 'This house ...'."@en ;
  dcterms:modified "2026-06-07T15:30:29.000515Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27625-3
  a curric:KeyLearningPoint ;
  rdfs:label """There are different types of motion: beliefs ('This house believes that ...') and
  proposals ('This house would ...')."""@en ;
  dcterms:modified "2026-06-07T15:30:29.000519Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27625-4
  a curric:KeyLearningPoint ;
  rdfs:label """A debate motion is most effective when it is relevant to the lives of the people in
  the debate and the audience."""@en ;
  dcterms:modified "2026-06-07T15:30:29.000523Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27625-5
  a curric:KeyLearningPoint ;
  rdfs:label """An effective debate motion will encourage critical thinking and mature
  discussion."""@en ;
  dcterms:modified "2026-06-07T15:30:29.000527Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7938-1
  a curric:KeyLearningPoint ;
  rdfs:label "Reader identity is a reflection on who you are as a reader and why you read."@en ;
  dcterms:modified "2026-06-07T15:30:29.000531Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7938-2
  a curric:KeyLearningPoint ;
  rdfs:label "Reading is a very personal experience; it is unique to every reader."@en ;
  dcterms:modified "2026-06-07T15:30:29.000535Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7938-3
  a curric:KeyLearningPoint ;
  rdfs:label "Reading can take many forms; it does not have to be restricted to a book."@en ;
  dcterms:modified "2026-06-07T15:30:29.000539Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7938-4
  a curric:KeyLearningPoint ;
  rdfs:label """A 'Reading River' is a reflection of significant texts in someone's personal
  experience."""@en ;
  dcterms:modified "2026-06-07T15:30:29.000546Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6552-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the main body is to clearly state the writer’s most persuasive
  points."""@en ;
  dcterms:modified "2026-06-07T15:30:29.000727Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6552-2
  a curric:KeyLearningPoint ;
  rdfs:label "Using a plan and success criteria can help inform the writing process."@en ;
  dcterms:modified "2026-06-07T15:30:29.000731Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6552-3
  a curric:KeyLearningPoint ;
  rdfs:label """Presumption and veiled threat are appropriate persuasive techniques to use in the
  main body."""@en ;
  dcterms:modified "2026-06-07T15:30:29.000735Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6552-4
  a curric:KeyLearningPoint ;
  rdfs:label """Points backed up by evidence, statistics, quotes or anecdotes are effective in
  making the writer sound credible."""@en ;
  dcterms:modified "2026-06-07T15:30:29.000739Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1340-1
  a curric:KeyLearningPoint ;
  rdfs:label "It is common to see a ‘c’ or a ‘t’ before the suffix -ial."@en ;
  dcterms:modified "2026-06-07T15:30:29.000746Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1340-2
  a curric:KeyLearningPoint ;
  rdfs:label "Words ending in the suffix -cial or -tial are generally adjectives."@en ;
  dcterms:modified "2026-06-07T15:30:29.000750Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1340-3
  a curric:KeyLearningPoint ;
  rdfs:label "The suffix -cial is usually used after a vowel."@en ;
  dcterms:modified "2026-06-07T15:30:29.000754Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1340-4
  a curric:KeyLearningPoint ;
  rdfs:label "The suffix -tial is common after a consonant letter."@en ;
  dcterms:modified "2026-06-07T15:30:29.000758Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1340-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: cemetery and language."@en ;
  dcterms:modified "2026-06-07T15:30:29.000762Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8062-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘The Tyger’ is a poem written by William Blake in 1794 as part of the collection
  titled ‘Songs of Experience’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.000766Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8062-2
  a curric:KeyLearningPoint ;
  rdfs:label """Imagery may be interpreted differently depending on the reader or listener's
  experiences."""@en ;
  dcterms:modified "2026-06-07T15:30:29.000770Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8062-3
  a curric:KeyLearningPoint ;
  rdfs:label """The poem uses symbolism; the use of symbols that represent ideas beyond their
  literal meaning."""@en ;
  dcterms:modified "2026-06-07T15:30:29.000774Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8062-4
  a curric:KeyLearningPoint ;
  rdfs:label """The poem references two animals: the lamb and the tiger; these can symbolise a range
  of emotions and themes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.000778Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8062-5
  a curric:KeyLearningPoint ;
  rdfs:label """A take-away idea within a text may link to themes that are explored and developed in
  it."""@en ;
  dcterms:modified "2026-06-07T15:30:29.000782Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1457-1
  a curric:KeyLearningPoint ;
  rdfs:label "Compound words are words made up of two or more pre-existing words."@en ;
  dcterms:modified "2026-06-07T15:30:29.000786Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1457-2
  a curric:KeyLearningPoint ;
  rdfs:label """The spelling of both words remains the same when the words are combined
  together."""@en ;
  dcterms:modified "2026-06-07T15:30:29.000790Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1457-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Colour blocking' is a useful practice strategy."@en ;
  dcterms:modified "2026-06-07T15:30:29.000797Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1457-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum word: strange."@en ;
  dcterms:modified "2026-06-07T15:30:29.000801Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1451-1
  a curric:KeyLearningPoint ;
  rdfs:label """The prefixes de-, re-, sub- and super- can be added without changing the spelling of
  the root word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.000805Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1451-2
  a curric:KeyLearningPoint ;
  rdfs:label "Spotting a ‘word in a word’ is a useful practice strategy."@en ;
  dcterms:modified "2026-06-07T15:30:29.000810Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1451-3
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum word: continue."@en ;
  dcterms:modified "2026-06-07T15:30:29.000814Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1451-4
  a curric:KeyLearningPoint ;
  rdfs:label "The prefixes de- can mean undo and re- can mean again."@en ;
  dcterms:modified "2026-06-07T15:30:29.000847Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1451-5
  a curric:KeyLearningPoint ;
  rdfs:label "The prefix sub- can mean under and super- can mean above."@en ;
  dcterms:modified "2026-06-07T15:30:29.000854Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1051-1
  a curric:KeyLearningPoint ;
  rdfs:label "Direct speech is the term used for a character speaking out loud in a text."@en ;
  dcterms:modified "2026-06-07T15:30:29.000877Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1051-2
  a curric:KeyLearningPoint ;
  rdfs:label "There is a set of rules for how to accurately punctuate direct speech."@en ;
  dcterms:modified "2026-06-07T15:30:29.000881Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1051-3
  a curric:KeyLearningPoint ;
  rdfs:label """Inverted commas are the punctuation marks that signal direct speech to the
  reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.000885Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1051-4
  a curric:KeyLearningPoint ;
  rdfs:label "The speech sentence spoken by a character must start with a capital letter."@en ;
  dcterms:modified "2026-06-07T15:30:29.000889Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1051-5
  a curric:KeyLearningPoint ;
  rdfs:label """If direct speech comes first in a sentence with the reporting clause second, it can
  be called a speech first sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.000894Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4868-1
  a curric:KeyLearningPoint ;
  rdfs:label "A non-chronological report is a type of non-fiction text."@en ;
  dcterms:modified "2026-06-07T15:30:29.000898Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4868-2
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of a non-chronological report is to inform the reader about a particular
  subject."""@en ;
  dcterms:modified "2026-06-07T15:30:29.000906Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4868-3
  a curric:KeyLearningPoint ;
  rdfs:label """Information in a non-chronological report is organised using a title, subheadings
  and paragraphs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.000912Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4868-4
  a curric:KeyLearningPoint ;
  rdfs:label """Linguistic features help to introduce, link and bring to life specific, factual
  information."""@en ;
  dcterms:modified "2026-06-07T15:30:29.000920Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6416-1
  a curric:KeyLearningPoint ;
  rdfs:label "Writing is most successful when we orally rehearse before writing."@en ;
  dcterms:modified "2026-06-07T15:30:29.001114Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6416-2
  a curric:KeyLearningPoint ;
  rdfs:label "A diary can include events and feelings written in the past and present tense."@en ;
  dcterms:modified "2026-06-07T15:30:29.001118Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6416-3
  a curric:KeyLearningPoint ;
  rdfs:label """We use a range of cohesive devices in all writing, including different punctuation,
  sentence types and parenthesis."""@en ;
  dcterms:modified "2026-06-07T15:30:29.001123Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6416-4
  a curric:KeyLearningPoint ;
  rdfs:label """Because a diary is a personal piece of writing, it can have a conversational
  tone."""@en ;
  dcterms:modified "2026-06-07T15:30:29.001127Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6416-5
  a curric:KeyLearningPoint ;
  rdfs:label """We can create a conversational tone using questions, exclamatives, verbless
  sentences and conversational openers."""@en ;
  dcterms:modified "2026-06-07T15:30:29.001131Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6371-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the build-up is to introduce key characters and storylines that will
  grow throughout the plot."""@en ;
  dcterms:modified "2026-06-07T15:30:29.001156Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6371-2
  a curric:KeyLearningPoint ;
  rdfs:label """Writers can use figurative language, poetic devices and ambitious adjectives to
  engage the reader and create atmosphere."""@en ;
  dcterms:modified "2026-06-07T15:30:29.001161Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6371-3
  a curric:KeyLearningPoint ;
  rdfs:label "A compound adjective is two words joined using a hyphen to form one adjective."@en ;
  dcterms:modified "2026-06-07T15:30:29.001165Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6371-4
  a curric:KeyLearningPoint ;
  rdfs:label """Understanding characters' thoughts and feelings enables us to write in greater depth
  and bring characters to life."""@en ;
  dcterms:modified "2026-06-07T15:30:29.001169Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6365-1
  a curric:KeyLearningPoint ;
  rdfs:label "'The Highwayman' is an example of a narrative poem."@en ;
  dcterms:modified "2026-06-07T15:30:29.001231Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6365-2
  a curric:KeyLearningPoint ;
  rdfs:label "A narrative poem is a type of poem that tells a story."@en ;
  dcterms:modified "2026-06-07T15:30:29.001235Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6365-3
  a curric:KeyLearningPoint ;
  rdfs:label "'The Highwayman' was set in rural England during the 18th century."@en ;
  dcterms:modified "2026-06-07T15:30:29.001239Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6365-4
  a curric:KeyLearningPoint ;
  rdfs:label "Alfred Noyes is the poet who wrote ’The Highwayman’."@en ;
  dcterms:modified "2026-06-07T15:30:29.001313Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6365-5
  a curric:KeyLearningPoint ;
  rdfs:label "Highwaymen were robbers on horseback who attacked travellers."@en ;
  dcterms:modified "2026-06-07T15:30:29.001319Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5457-1
  a curric:KeyLearningPoint ;
  rdfs:label """A theme is a big idea, topic or message that recurs within a story and authors use
  these to convey deeper meaning."""@en ;
  dcterms:modified "2026-06-07T15:30:29.001363Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5457-2
  a curric:KeyLearningPoint ;
  rdfs:label """Identifying the themes within ‘The Moon Dragons’ helps us understand the deeper
  meaning behind the story."""@en ;
  dcterms:modified "2026-06-07T15:30:29.001368Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5457-3
  a curric:KeyLearningPoint ;
  rdfs:label """Themes are often communicated through exploring negative and positive character
  traits."""@en ;
  dcterms:modified "2026-06-07T15:30:29.001372Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5457-4
  a curric:KeyLearningPoint ;
  rdfs:label """Key themes such as bravery, protection and morality are conveyed through Alina’s
  admirable character traits."""@en ;
  dcterms:modified "2026-06-07T15:30:29.001376Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5457-5
  a curric:KeyLearningPoint ;
  rdfs:label """The themes within ‘The Moon Dragons’ help us consider the complexities of human
  morality."""@en ;
  dcterms:modified "2026-06-07T15:30:29.001380Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1061-1
  a curric:KeyLearningPoint ;
  rdfs:label "The purpose of the introduction is to give general information to the reader."@en ;
  dcterms:modified "2026-06-07T15:30:29.001384Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1061-2
  a curric:KeyLearningPoint ;
  rdfs:label """The introduction outlines what the reader will learn from the non-chronological
  report."""@en ;
  dcterms:modified "2026-06-07T15:30:29.001388Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1061-3
  a curric:KeyLearningPoint ;
  rdfs:label """The facts in the introduction are general facts about the Stone Age; they become
  more specific in later paragraphs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.001392Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1061-4
  a curric:KeyLearningPoint ;
  rdfs:label "An introduction ends with a command to the reader to continue reading."@en ;
  dcterms:modified "2026-06-07T15:30:29.001396Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1061-5
  a curric:KeyLearningPoint ;
  rdfs:label "Viewpoint fronted adverbials can be useful to introduce a fact."@en ;
  dcterms:modified "2026-06-07T15:30:29.001400Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2739-1
  a curric:KeyLearningPoint ;
  rdfs:label "The verb carries the tense of a sentence."@en ;
  dcterms:modified "2026-06-07T15:30:29.001417Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2739-2
  a curric:KeyLearningPoint ;
  rdfs:label "Sentences can be formed in the first, second or third person."@en ;
  dcterms:modified "2026-06-07T15:30:29.001421Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2739-3
  a curric:KeyLearningPoint ;
  rdfs:label "The simple tense can denote present, past or future action."@en ;
  dcterms:modified "2026-06-07T15:30:29.001428Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2739-4
  a curric:KeyLearningPoint ;
  rdfs:label """The simple tense is a tense that does not make use of an auxiliary verb in the past
  and present forms."""@en ;
  dcterms:modified "2026-06-07T15:30:29.001432Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2739-5
  a curric:KeyLearningPoint ;
  rdfs:label """Tense is maintained at both sentence and whole text level (although verbs within
  sentences may vary in tense)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.001436Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1429-1
  a curric:KeyLearningPoint ;
  rdfs:label """When -ing is added to the end of a word, it can show the past tense or the present
  tense."""@en ;
  dcterms:modified "2026-06-07T15:30:29.001453Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1429-2
  a curric:KeyLearningPoint ;
  rdfs:label "Using the strategy \"big letters\" is a useful practice strategy."@en ;
  dcterms:modified "2026-06-07T15:30:29.001457Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1429-3
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum word: history."@en ;
  dcterms:modified "2026-06-07T15:30:29.001461Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6748-1
  a curric:KeyLearningPoint ;
  rdfs:label "Editing is a critical part of the writing process."@en ;
  dcterms:modified "2026-06-07T15:30:29.004727Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6748-2
  a curric:KeyLearningPoint ;
  rdfs:label """Writing is most successful when editing is used to rethink, rephrase and reconsider
  first ideas."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004733Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6748-3
  a curric:KeyLearningPoint ;
  rdfs:label "Editing can be done by oneself, with a peer or with a teacher."@en ;
  dcterms:modified "2026-06-07T15:30:29.004738Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6748-4
  a curric:KeyLearningPoint ;
  rdfs:label """Editing is most successful when it is chunked by punctuation, sentence structure,
  vocabulary and cohesive devices."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004744Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6748-5
  a curric:KeyLearningPoint ;
  rdfs:label "A growth mindset helps us benefit most from editing."@en ;
  dcterms:modified "2026-06-07T15:30:29.004751Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4817-1
  a curric:KeyLearningPoint ;
  rdfs:label """A kenning poem is a poem constructed using a series of kennings to describe a
  person, object, or concept."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004755Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4817-2
  a curric:KeyLearningPoint ;
  rdfs:label "Each line of the poem starts on a new line and with a capital letter."@en ;
  dcterms:modified "2026-06-07T15:30:29.004759Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4817-3
  a curric:KeyLearningPoint ;
  rdfs:label """After forming a capital letter, you need to lift your pencil to start the next part
  of the word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004764Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4817-4
  a curric:KeyLearningPoint ;
  rdfs:label """Each letter string contains different letter joins depending on which letters are in
  the word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004768Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4817-5
  a curric:KeyLearningPoint ;
  rdfs:label "You don't lift your pencil when forming the joins."@en ;
  dcterms:modified "2026-06-07T15:30:29.004772Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6156-1
  a curric:KeyLearningPoint ;
  rdfs:label "Journalistic reports contain a mixture of facts and individuals' perspectives."@en ;
  dcterms:modified "2026-06-07T15:30:29.004809Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6156-2
  a curric:KeyLearningPoint ;
  rdfs:label """Journalists obtain facts through research, observation and requests for
  information."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004813Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6156-3
  a curric:KeyLearningPoint ;
  rdfs:label "Journalists can obtain individuals' perspectives using interviews."@en ;
  dcterms:modified "2026-06-07T15:30:29.004817Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6156-4
  a curric:KeyLearningPoint ;
  rdfs:label """Journalists are obliged to record quotations accurately to reflect individuals'
  perspectives."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004822Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6156-5
  a curric:KeyLearningPoint ;
  rdfs:label """We can use role play as a way of empathising with different perspectives and
  generating ideas for writing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004828Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1076-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Apprehensive' is an adjective which means feeling nervous or afraid."@en ;
  dcterms:modified "2026-06-07T15:30:29.004907Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1076-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Petrified' is an adjective which means feeling terrified; like being so frightened
  that you turn into stone."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004911Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1076-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Anxious' is an adjective which means feeling worried or nervous; how you feel when
  you panic about a test at school."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004915Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1076-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Distressed', 'exasperated' and 'flustered' are other rich vocabulary associated
  with feeling stressed or scared."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004919Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2732-1
  a curric:KeyLearningPoint ;
  rdfs:label """A comma is written before 'but' or 'or' co-ordinating conjunctions in a compound
  sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004978Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2732-2
  a curric:KeyLearningPoint ;
  rdfs:label """If the adverbial clause is first in an adverbial complex sentence, it is followed by
  a comma before the main clause."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004982Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2732-3
  a curric:KeyLearningPoint ;
  rdfs:label """If the main clause is first in an adverbial complex sentence, it is not followed by
  a comma before the adverbial clause."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004988Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2732-4
  a curric:KeyLearningPoint ;
  rdfs:label """A relative clause often interrupts after the subject of the main clause at the start
  of the sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004992Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2732-5
  a curric:KeyLearningPoint ;
  rdfs:label """A pair of commas is used around the relative clause to demarcate it from the main
  clause."""@en ;
  dcterms:modified "2026-06-07T15:30:29.004996Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6553-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of an editing lesson is to improve your writing and make necessary
  corrections."""@en ;
  dcterms:modified "2026-06-07T15:30:29.005055Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6553-2
  a curric:KeyLearningPoint ;
  rdfs:label """Vocabulary, grammar and punctuation can be changed to make writing more
  effective."""@en ;
  dcterms:modified "2026-06-07T15:30:29.005059Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6553-3
  a curric:KeyLearningPoint ;
  rdfs:label "Editing is a vital element of the writing process."@en ;
  dcterms:modified "2026-06-07T15:30:29.005063Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7872-1
  a curric:KeyLearningPoint ;
  rdfs:label """A character's body language can give clues about what they are thinking or
  feeling."""@en ;
  dcterms:modified "2026-06-07T15:30:29.005229Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7872-2
  a curric:KeyLearningPoint ;
  rdfs:label """Body language is used in ‘Greenling’ to convey the characterisation of the
  Barleycorns and the Greenling."""@en ;
  dcterms:modified "2026-06-07T15:30:29.005233Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7872-3
  a curric:KeyLearningPoint ;
  rdfs:label """Understanding a character's motives helps us to understand the story and empathise
  with the characters."""@en ;
  dcterms:modified "2026-06-07T15:30:29.005237Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7872-4
  a curric:KeyLearningPoint ;
  rdfs:label "A reader’s own experiences can also support inferring a character’s motives."@en ;
  dcterms:modified "2026-06-07T15:30:29.005242Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4860-1
  a curric:KeyLearningPoint ;
  rdfs:label "The purpose of the introduction is to give general information to the reader."@en ;
  dcterms:modified "2026-06-07T15:30:29.251502Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4860-2
  a curric:KeyLearningPoint ;
  rdfs:label """The introduction outlines what the reader will learn from the non-chronological
  report."""@en ;
  dcterms:modified "2026-06-07T15:30:29.251507Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4860-3
  a curric:KeyLearningPoint ;
  rdfs:label """The facts in the opening are general about King Tut; they become more specific in
  later paragraphs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.251512Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4860-4
  a curric:KeyLearningPoint ;
  rdfs:label "An introduction ends with a command to the reader to continue reading."@en ;
  dcterms:modified "2026-06-07T15:30:29.251520Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4860-5
  a curric:KeyLearningPoint ;
  rdfs:label """A compound sentence is formed of two main clauses joined with a co-ordinating
  conjunction."""@en ;
  dcterms:modified "2026-06-07T15:30:29.251526Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4802-1
  a curric:KeyLearningPoint ;
  rdfs:label "The letters all have a lead in and a lead out."@en ;
  dcterms:modified "2026-06-07T15:30:29.252426Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4802-2
  a curric:KeyLearningPoint ;
  rdfs:label """The third join starts at the x-height line and dips below the x-height line and back
  up to join the next letter."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252431Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4802-3
  a curric:KeyLearningPoint ;
  rdfs:label """When joining from a \"w\" or an \"o\", remember the small 'dip down' to aid
  joining."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252435Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4802-4
  a curric:KeyLearningPoint ;
  rdfs:label "The pencil does not lift when forming the join."@en ;
  dcterms:modified "2026-06-07T15:30:29.252440Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4802-5
  a curric:KeyLearningPoint ;
  rdfs:label """When using the third join you leave enough space to ensure the letters are not
  touching without leaving a big gap."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252445Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1352-1
  a curric:KeyLearningPoint ;
  rdfs:label "The 'sh' sound in words of French origin is generally spelt 'ch'."@en ;
  dcterms:modified "2026-06-07T15:30:29.252768Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1352-2
  a curric:KeyLearningPoint ;
  rdfs:label "The 'g' sound in words of French origin is generally spelt 'gue'."@en ;
  dcterms:modified "2026-06-07T15:30:29.252772Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1352-3
  a curric:KeyLearningPoint ;
  rdfs:label "The 'k' sound in words of French origin is generally spelt 'que'."@en ;
  dcterms:modified "2026-06-07T15:30:29.252777Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1352-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: muscle, foreign and restaurant."@en ;
  dcterms:modified "2026-06-07T15:30:29.252782Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1344-1
  a curric:KeyLearningPoint ;
  rdfs:label """There are many ways to spell the ‘ee’ sound. ‘ee’, ‘ea’ and ‘e-e’ are the most
  common."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252786Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1344-2
  a curric:KeyLearningPoint ;
  rdfs:label """Most words follow the rule: 'i' before 'e' except after 'c' where the sound
  is 'ee'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252791Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1344-3
  a curric:KeyLearningPoint ;
  rdfs:label """The 'ie' spelling can also break other learnt rules or be used when the sound is not
  'ee'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.252796Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1344-4
  a curric:KeyLearningPoint ;
  rdfs:label "The letter string ‘ie’ can represent a range of different sounds."@en ;
  dcterms:modified "2026-06-07T15:30:29.252800Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1344-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: sufficient, variety and achieve."@en ;
  dcterms:modified "2026-06-07T15:30:29.252807Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8020-1
  a curric:KeyLearningPoint ;
  rdfs:label "Haikus are short poems consisting of three lines."@en ;
  dcterms:modified "2026-06-07T15:30:29.253144Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8020-2
  a curric:KeyLearningPoint ;
  rdfs:label "Haikus have a specific number of syllables in each line."@en ;
  dcterms:modified "2026-06-07T15:30:29.253148Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8020-3
  a curric:KeyLearningPoint ;
  rdfs:label """A haiku is a traditional form of Japaense poetry that consists of three lines with a
  syllable count of 5-7-5."""@en ;
  dcterms:modified "2026-06-07T15:30:29.253153Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8020-4
  a curric:KeyLearningPoint ;
  rdfs:label "A haiku is traditionally written about nature."@en ;
  dcterms:modified "2026-06-07T15:30:29.253158Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6350-1
  a curric:KeyLearningPoint ;
  rdfs:label "Writing is most successful when it is planned."@en ;
  dcterms:modified "2026-06-07T15:30:29.253253Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6350-2
  a curric:KeyLearningPoint ;
  rdfs:label "We can plan to use a range of persuasive techniques in a persuasive letter."@en ;
  dcterms:modified "2026-06-07T15:30:29.253259Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6350-3
  a curric:KeyLearningPoint ;
  rdfs:label """When we generate ideas for persuasive techniques, we are thinking about the effect
  they will have on the reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.253264Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6350-4
  a curric:KeyLearningPoint ;
  rdfs:label """We can use precise expanded noun phrases to describe the reader when creating
  flattery."""@en ;
  dcterms:modified "2026-06-07T15:30:29.253269Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1415-1
  a curric:KeyLearningPoint ;
  rdfs:label "The suffix -ery often turns words into nouns."@en ;
  dcterms:modified "2026-06-07T15:30:29.253274Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1415-2
  a curric:KeyLearningPoint ;
  rdfs:label "When the root word is obvious, the suffix -ery is often used."@en ;
  dcterms:modified "2026-06-07T15:30:29.253278Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1415-3
  a curric:KeyLearningPoint ;
  rdfs:label "When the root word ends in 'e', remove the 'e' and add the suffix -ery."@en ;
  dcterms:modified "2026-06-07T15:30:29.253285Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1415-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: regular, calendar and continue."@en ;
  dcterms:modified "2026-06-07T15:30:29.253290Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7849-1
  a curric:KeyLearningPoint ;
  rdfs:label """'Varjak Paw' is in the form of an illustrated chapter book, combining words and
  illustration."""@en ;
  dcterms:modified "2026-06-07T15:30:29.253425Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7849-2
  a curric:KeyLearningPoint ;
  rdfs:label "Varjak Paw is a Mesopotamian Blue Kitten and has never left home."@en ;
  dcterms:modified "2026-06-07T15:30:29.253433Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7849-3
  a curric:KeyLearningPoint ;
  rdfs:label """During the text, Varjak must leave his home and family and has to survive on his
  own."""@en ;
  dcterms:modified "2026-06-07T15:30:29.253438Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7849-4
  a curric:KeyLearningPoint ;
  rdfs:label """One of the most prominent themes is identity; identity is who you are and what makes
  you unique."""@en ;
  dcterms:modified "2026-06-07T15:30:29.253444Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4847-1
  a curric:KeyLearningPoint ;
  rdfs:label """Information can be gathered from a range of different sources (both primary and
  secondary)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.254621Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4847-2
  a curric:KeyLearningPoint ;
  rdfs:label """Journalists research the topic of their reports in order to write accurately about
  the topic."""@en ;
  dcterms:modified "2026-06-07T15:30:29.254625Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4847-3
  a curric:KeyLearningPoint ;
  rdfs:label "When conducting initial research, facts can be kept general."@en ;
  dcterms:modified "2026-06-07T15:30:29.254629Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7669-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of a resolution is to resolve the story and give the reader a chance to
  reflect."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259586Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7669-2
  a curric:KeyLearningPoint ;
  rdfs:label """Using the full range of sentence types (simple, compound and complex) improves text
  flow and cohesion."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259590Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7669-3
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials of time, place and manner describe the action in the main clause
  in further detail."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259593Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7669-4
  a curric:KeyLearningPoint ;
  rdfs:label """Oral rehearsal before writing helps to structure grammatically correct sentences and
  check for sense."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259599Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1309-1
  a curric:KeyLearningPoint ;
  rdfs:label "The suffix -ise often turns adjectives and nouns into verbs."@en ;
  dcterms:modified "2026-06-07T15:30:29.259653Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1309-2
  a curric:KeyLearningPoint ;
  rdfs:label "When the root word ends in a consonant, we often just add the suffix."@en ;
  dcterms:modified "2026-06-07T15:30:29.259656Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1309-3
  a curric:KeyLearningPoint ;
  rdfs:label "When the root word ends in a ‘y’, we remove the ‘y’ and add the suffix."@en ;
  dcterms:modified "2026-06-07T15:30:29.259660Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1309-4
  a curric:KeyLearningPoint ;
  rdfs:label """A suffix is a letter or group of letters at the end of a word which creates another
  word and can change the word class."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259664Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1309-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: probably, occasion and occasionally."@en ;
  dcterms:modified "2026-06-07T15:30:29.259668Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2740-1
  a curric:KeyLearningPoint ;
  rdfs:label "The verb carries the tense of a sentence."@en ;
  dcterms:modified "2026-06-07T15:30:29.259761Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2740-2
  a curric:KeyLearningPoint ;
  rdfs:label "The progressive tense can denote present, past or future action."@en ;
  dcterms:modified "2026-06-07T15:30:29.259765Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2740-3
  a curric:KeyLearningPoint ;
  rdfs:label """The progressive tense is a tense that makes use of an auxiliary verb from the
  infinitive 'to be' with the main verb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259771Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2740-4
  a curric:KeyLearningPoint ;
  rdfs:label "The progressive tense denotes ongoing action."@en ;
  dcterms:modified "2026-06-07T15:30:29.259775Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2740-5
  a curric:KeyLearningPoint ;
  rdfs:label "The main verb in the progressive tense always ends with the -ing suffix."@en ;
  dcterms:modified "2026-06-07T15:30:29.259779Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8879-1
  a curric:KeyLearningPoint ;
  rdfs:label """In Chapter 4 of ‘The Iron Man’, the world faces threat from a flying creature named
  the space-bat-angel-dragon."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259784Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8879-2
  a curric:KeyLearningPoint ;
  rdfs:label """In Chapter 5 of ‘The Iron Man’, the Iron Man defeats the space-bat-angel-dragon and
  protects the Earth."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259788Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8879-3
  a curric:KeyLearningPoint ;
  rdfs:label """A character arc is a character’s transformation or journey over the course of a
  story."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259792Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8879-4
  a curric:KeyLearningPoint ;
  rdfs:label """We can examine the Iron Man’s character arc by considering how he is viewed by
  others over the course of the story."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259796Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8879-5
  a curric:KeyLearningPoint ;
  rdfs:label """The Iron Man’s character evolves from one that is feared into one that is understood
  and viewed as a hero."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259799Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8474-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the climax is to describe the main action and take the suspense to
  its highest point."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259803Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8474-2
  a curric:KeyLearningPoint ;
  rdfs:label """In the climax, the Iron Man resurfaces from the earth and Hogarth persuades the
  farmers not to harm him."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259807Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8474-3
  a curric:KeyLearningPoint ;
  rdfs:label """Precise and ambitious vocabulary, as well as ‘show and tell’, help take the suspense
  to its highest point in the climax."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259811Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8474-4
  a curric:KeyLearningPoint ;
  rdfs:label "Direct speech is used to convey Hogarth’s intentions to the Iron Man."@en ;
  dcterms:modified "2026-06-07T15:30:29.259815Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8474-5
  a curric:KeyLearningPoint ;
  rdfs:label "A plan includes notes, a sequence of events and ambitious vocabulary."@en ;
  dcterms:modified "2026-06-07T15:30:29.259818Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27900-1
  a curric:KeyLearningPoint ;
  rdfs:label """Times of transition in life can provoke different emotions such as excitement,
  sadness or nervousness."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259859Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27900-2
  a curric:KeyLearningPoint ;
  rdfs:label """Talking about feelings can help a person to feel more comfortable and less
  anxious."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259863Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27900-3
  a curric:KeyLearningPoint ;
  rdfs:label "An essential part of having a discussion is the ability to actively listen."@en ;
  dcterms:modified "2026-06-07T15:30:29.259867Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27900-4
  a curric:KeyLearningPoint ;
  rdfs:label """Active listening helps a person understand different perspectives and empathise with
  other people's experiences."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259871Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27900-5
  a curric:KeyLearningPoint ;
  rdfs:label """Moving from primary school to secondary school can be both exciting and
  daunting."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259874Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9041-1
  a curric:KeyLearningPoint ;
  rdfs:label """'The Adventure of the Blue Carbuncle' is a Sherlock Holmes short story first
  published in 1892."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259918Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9041-2
  a curric:KeyLearningPoint ;
  rdfs:label "The story is told in the first person from the perspective of Dr John Watson."@en ;
  dcterms:modified "2026-06-07T15:30:29.259922Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9041-3
  a curric:KeyLearningPoint ;
  rdfs:label """When you deduce something, you are arriving at a conclusion by logical
  reasoning."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259927Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9041-4
  a curric:KeyLearningPoint ;
  rdfs:label """One of Holmes' key character traits is his ability to deduce information from small
  clues."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259931Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6011-1
  a curric:KeyLearningPoint ;
  rdfs:label """A written argument tries to convince the reader of something using strong reasoning
  to support."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260018Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6011-2
  a curric:KeyLearningPoint ;
  rdfs:label "The PEPS structure stands for: point, explanation, proof, summary."@en ;
  dcterms:modified "2026-06-07T15:30:29.260021Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6011-3
  a curric:KeyLearningPoint ;
  rdfs:label """A conditional clause is a type of subordinate clause that expresses a degree of
  possibility that something might happen."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260025Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6011-4
  a curric:KeyLearningPoint ;
  rdfs:label """A relative clause is a type of subordinate clause that starts with a relative
  pronoun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260029Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28983-1
  a curric:KeyLearningPoint ;
  rdfs:label """'The City of my birth' is a poem written by Karl Nova, published in his 2017
  collection 'Rhythm and Poetry'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260071Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28983-2
  a curric:KeyLearningPoint ;
  rdfs:label """Imagery refers to the use of language that evokes vivid pictures in the reader's
  mind."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260075Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28983-3
  a curric:KeyLearningPoint ;
  rdfs:label """In the poem, Nova uses visual language to paint a vivid picture of London for the
  reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260079Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28983-4
  a curric:KeyLearningPoint ;
  rdfs:label "The atmosphere that Nova creates is one of a busy, energetic and joyful city."@en ;
  dcterms:modified "2026-06-07T15:30:29.260083Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28983-5
  a curric:KeyLearningPoint ;
  rdfs:label """Nova's poetry is influenced by hip-hop culture and it has a natural rhythm
  and flow."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260086Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6116-1
  a curric:KeyLearningPoint ;
  rdfs:label """Information in a section becomes more specific and detailed as the section
  goes on."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260373Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6116-2
  a curric:KeyLearningPoint ;
  rdfs:label "Facts written in a section should be researched and organised prior to writing."@en ;
  dcterms:modified "2026-06-07T15:30:29.260376Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6116-3
  a curric:KeyLearningPoint ;
  rdfs:label "A range of cohesive devices helps us to link facts within and between sentences."@en ;
  dcterms:modified "2026-06-07T15:30:29.260380Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6116-4
  a curric:KeyLearningPoint ;
  rdfs:label """Before we write, we should orally rehearse sentences to ensure our sentences make
  sense and flow well."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260386Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6116-5
  a curric:KeyLearningPoint ;
  rdfs:label """Parenthesis, varied sentence types and a range of fronted adverbials are all
  cohesive devices that can be used."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260392Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6098-1
  a curric:KeyLearningPoint ;
  rdfs:label "Information can be gathered from a range of different sources."@en ;
  dcterms:modified "2026-06-07T15:30:29.260396Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6098-2
  a curric:KeyLearningPoint ;
  rdfs:label "Credibility of each source must be determined."@en ;
  dcterms:modified "2026-06-07T15:30:29.260399Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6098-3
  a curric:KeyLearningPoint ;
  rdfs:label "Origin of a source must be cited."@en ;
  dcterms:modified "2026-06-07T15:30:29.260403Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6098-4
  a curric:KeyLearningPoint ;
  rdfs:label "Full sentences are not required when writing in note form."@en ;
  dcterms:modified "2026-06-07T15:30:29.260407Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6098-5
  a curric:KeyLearningPoint ;
  rdfs:label "Notes can be organised by theme using bullet points."@en ;
  dcterms:modified "2026-06-07T15:30:29.260410Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1379-1
  a curric:KeyLearningPoint ;
  rdfs:label "The suffixes -ence and -ency can create abstract nouns."@en ;
  dcterms:modified "2026-06-07T15:30:29.260556Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1379-2
  a curric:KeyLearningPoint ;
  rdfs:label "The -ence or -ency spellings may be found after a ‘soft c’, ‘soft g’ or ‘qu’."@en ;
  dcterms:modified "2026-06-07T15:30:29.260559Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1379-3
  a curric:KeyLearningPoint ;
  rdfs:label """Words ending in -ence and -ency sometimes have related words where the ‘e’ vowel
  sound is clearer."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260563Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1379-4
  a curric:KeyLearningPoint ;
  rdfs:label "Words in word families often have connected meaning and spelling."@en ;
  dcterms:modified "2026-06-07T15:30:29.260567Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1379-5
  a curric:KeyLearningPoint ;
  rdfs:label """How to spell the curriculum words: accident, accidentally, especially and
  actually."""@en ;
  dcterms:modified "2026-06-07T15:30:29.260570Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1406-1
  a curric:KeyLearningPoint ;
  rdfs:label "The /shun/ suffix can be spelt -tion, -sion, -ssion or -cian."@en ;
  dcterms:modified "2026-06-07T15:30:29.260966Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1406-2
  a curric:KeyLearningPoint ;
  rdfs:label "Words spelt with -ssion often have a root word ending in ‘ss’ or ‘mit’."@en ;
  dcterms:modified "2026-06-07T15:30:29.260970Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1406-3
  a curric:KeyLearningPoint ;
  rdfs:label "Words ending in the suffix suffix -ssion are nouns."@en ;
  dcterms:modified "2026-06-07T15:30:29.260973Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1406-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: century, famous and imagine."@en ;
  dcterms:modified "2026-06-07T15:30:29.260977Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7940-1
  a curric:KeyLearningPoint ;
  rdfs:label "Text recommendations are an important part of developing reading for pleasure"@en ;
  dcterms:modified "2026-06-07T15:30:29.260981Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7940-2
  a curric:KeyLearningPoint ;
  rdfs:label """Making a text recommendation includes a personal reason for why the text was
  relevant to you"""@en ;
  dcterms:modified "2026-06-07T15:30:29.260984Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7940-3
  a curric:KeyLearningPoint ;
  rdfs:label """Making a text recommendation includes a reason that someone else might enjoy the
  text"""@en ;
  dcterms:modified "2026-06-07T15:30:29.260988Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7940-4
  a curric:KeyLearningPoint ;
  rdfs:label "There are a variety of ways we can share our reading preferences with others"@en ;
  dcterms:modified "2026-06-07T15:30:29.260992Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6277-1
  a curric:KeyLearningPoint ;
  rdfs:label """Readers can use layout features of a non-fiction text to navigate sections
  quickly."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261143Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6277-2
  a curric:KeyLearningPoint ;
  rdfs:label """Skimming and scanning is a strategy readers can use to retrieve the information they
  are looking for rapidly."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261147Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6277-3
  a curric:KeyLearningPoint ;
  rdfs:label """The structure and features of a text can help identify keywords or key
  information."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261153Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1127-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Conceited' is an adjective which means vain or proud."@en ;
  dcterms:modified "2026-06-07T15:30:29.261218Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1127-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Presumptuous' is an adjective which means overconfident, arrogant or rude."@en ;
  dcterms:modified "2026-06-07T15:30:29.261222Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1127-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Unflappable' is an adjective which means cool, calm or collected."@en ;
  dcterms:modified "2026-06-07T15:30:29.261225Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6736-1
  a curric:KeyLearningPoint ;
  rdfs:label """The events culminating in the meeting between Miss Murphy and Addie's sisters are a
  key part of the build-up."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261495Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6736-2
  a curric:KeyLearningPoint ;
  rdfs:label """When we write these events, we will need to understand the characters' actions and
  feelings."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261498Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6736-3
  a curric:KeyLearningPoint ;
  rdfs:label "We can use drama to help us understand and remember these actions and feelings."@en ;
  dcterms:modified "2026-06-07T15:30:29.261502Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6736-4
  a curric:KeyLearningPoint ;
  rdfs:label "We will also want to use internal monologue to show Addie's inner thoughts."@en ;
  dcterms:modified "2026-06-07T15:30:29.261506Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6736-5
  a curric:KeyLearningPoint ;
  rdfs:label "We can practise saying these inner thoughts using drama."@en ;
  dcterms:modified "2026-06-07T15:30:29.261509Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1318-1
  a curric:KeyLearningPoint ;
  rdfs:label "A plan includes keywords and subject-specific vocabulary related to the section."@en ;
  dcterms:modified "2026-06-07T15:30:29.261961Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1318-2
  a curric:KeyLearningPoint ;
  rdfs:label "Taking notes is a skill."@en ;
  dcterms:modified "2026-06-07T15:30:29.261965Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1318-3
  a curric:KeyLearningPoint ;
  rdfs:label """Notes should not be written in full sentences and bullet points can be used to order
  notes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261969Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1318-4
  a curric:KeyLearningPoint ;
  rdfs:label "Key vocabulary and linguistic devices should be logged in a plan."@en ;
  dcterms:modified "2026-06-07T15:30:29.261972Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1318-5
  a curric:KeyLearningPoint ;
  rdfs:label "The plan should be clearly structured in the order of the section."@en ;
  dcterms:modified "2026-06-07T15:30:29.261976Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1317-1
  a curric:KeyLearningPoint ;
  rdfs:label "A subheading signals to the reader what the section is about."@en ;
  dcterms:modified "2026-06-07T15:30:29.262155Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1317-2
  a curric:KeyLearningPoint ;
  rdfs:label """Careful selection of nouns and pronouns ensures cohesion within sentences and across
  sections of the report."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262159Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1317-3
  a curric:KeyLearningPoint ;
  rdfs:label """A section about one feature of the report's subject contains specific facts and
  information to keep the reader engaged."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262162Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1317-4
  a curric:KeyLearningPoint ;
  rdfs:label """Writers choose varied fronted adverbials and different sentence types to ensure the
  text flows for the reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262166Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1317-5
  a curric:KeyLearningPoint ;
  rdfs:label """Sentences should be said aloud before writing to ensure they make sense and read
  back once written to check for errors."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262171Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1395-1
  a curric:KeyLearningPoint ;
  rdfs:label """A prefix is a letter or group of letters at the start of a word which changes its
  meaning."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262191Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1395-2
  a curric:KeyLearningPoint ;
  rdfs:label "Adding a prefix does not alter the spelling of the root word."@en ;
  dcterms:modified "2026-06-07T15:30:29.262194Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1395-3
  a curric:KeyLearningPoint ;
  rdfs:label """There are many prefixes that can mean ‘not’, including un-, dis-, in-, il-, im- and
  ir-."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262199Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1395-4
  a curric:KeyLearningPoint ;
  rdfs:label """The prefix in- can also mean ‘in’ or ‘into’ and the prefix mis- usually means
  'wrongly'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262205Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1395-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: immediate, immediately and disappear."@en ;
  dcterms:modified "2026-06-07T15:30:29.262209Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2733-1
  a curric:KeyLearningPoint ;
  rdfs:label """Any subordinate clause is a group of words that contains a verb and does not make
  complete sense."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262274Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2733-2
  a curric:KeyLearningPoint ;
  rdfs:label "Any subordinate clause must join to a main clause to make sense."@en ;
  dcterms:modified "2026-06-07T15:30:29.262278Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2733-3
  a curric:KeyLearningPoint ;
  rdfs:label "A non-finite clause is a type of subordinate clause."@en ;
  dcterms:modified "2026-06-07T15:30:29.262281Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2733-4
  a curric:KeyLearningPoint ;
  rdfs:label """A non-finite clause can start with a verb in the progressive tense that denotes
  ongoing action."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262285Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2733-5
  a curric:KeyLearningPoint ;
  rdfs:label """The previously-learnt types of subordinate clause are the adverbial clause and the
  relative clause."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262289Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2737-1
  a curric:KeyLearningPoint ;
  rdfs:label "Determiners are a word class."@en ;
  dcterms:modified "2026-06-07T15:30:29.262306Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2737-2
  a curric:KeyLearningPoint ;
  rdfs:label "A determiner introduces a noun in a clause."@en ;
  dcterms:modified "2026-06-07T15:30:29.262310Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2737-3
  a curric:KeyLearningPoint ;
  rdfs:label "Determiners can be articles or possessive pronouns."@en ;
  dcterms:modified "2026-06-07T15:30:29.262313Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2737-4
  a curric:KeyLearningPoint ;
  rdfs:label "Determiners can be quantifiers."@en ;
  dcterms:modified "2026-06-07T15:30:29.262317Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2737-5
  a curric:KeyLearningPoint ;
  rdfs:label "Determiners can be demonstratives."@en ;
  dcterms:modified "2026-06-07T15:30:29.262320Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3451-1
  a curric:KeyLearningPoint ;
  rdfs:label "Words can be related to each other by common features, patterns or meaning."@en ;
  dcterms:modified "2026-06-07T15:30:29.262341Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3451-2
  a curric:KeyLearningPoint ;
  rdfs:label """Synonyms and antonyms can be used by writers to vary vocabulary choice and create
  text cohesion."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262345Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3451-3
  a curric:KeyLearningPoint ;
  rdfs:label "All words have etymology."@en ;
  dcterms:modified "2026-06-07T15:30:29.262348Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3451-4
  a curric:KeyLearningPoint ;
  rdfs:label "Adverbs can describe verbs or adjectives."@en ;
  dcterms:modified "2026-06-07T15:30:29.262352Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3451-5
  a curric:KeyLearningPoint ;
  rdfs:label "Prepositions and adverbs have more than one purpose."@en ;
  dcterms:modified "2026-06-07T15:30:29.262356Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8830-1
  a curric:KeyLearningPoint ;
  rdfs:label """The crayons in ‘The Day the Crayons Quit’ use letters to explain to Duncan why they
  are going to quit."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262599Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8830-2
  a curric:KeyLearningPoint ;
  rdfs:label "They all share different emotions in their letters."@en ;
  dcterms:modified "2026-06-07T15:30:29.262603Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8830-3
  a curric:KeyLearningPoint ;
  rdfs:label """Simple sentences can be written in the simple present, progressive present and
  perfect present tense."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262607Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8830-4
  a curric:KeyLearningPoint ;
  rdfs:label """A simple sentence is formed of a main clause; a main clause contains a verb and
  makes sense by itself."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262611Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8830-5
  a curric:KeyLearningPoint ;
  rdfs:label """One type of simple sentence is the statement: it tells the reader a fact or an
  opinion."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262614Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8018-1
  a curric:KeyLearningPoint ;
  rdfs:label "Learning a poem by heart means you can say it from memory."@en ;
  dcterms:modified "2026-06-07T15:30:29.263130Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8018-2
  a curric:KeyLearningPoint ;
  rdfs:label "Reciting a poem means to say it aloud after learning it."@en ;
  dcterms:modified "2026-06-07T15:30:29.263134Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8018-3
  a curric:KeyLearningPoint ;
  rdfs:label "Saying the poem out loud many times will help when learning it by heart."@en ;
  dcterms:modified "2026-06-07T15:30:29.263137Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8018-4
  a curric:KeyLearningPoint ;
  rdfs:label """We can follow four steps to learn a poem by heart: 'Hear it', 'Read it', 'Check it',
  'Practise it'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263141Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6346-1
  a curric:KeyLearningPoint ;
  rdfs:label "A text gives us clues about a character's features and feelings."@en ;
  dcterms:modified "2026-06-07T15:30:29.263242Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6346-2
  a curric:KeyLearningPoint ;
  rdfs:label """Some text clues about a character are explicit and some text clues about a character
  use subtext."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263246Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6346-3
  a curric:KeyLearningPoint ;
  rdfs:label "We can infer a character's traits by examining their behaviour."@en ;
  dcterms:modified "2026-06-07T15:30:29.263249Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6346-4
  a curric:KeyLearningPoint ;
  rdfs:label "Sherlock Holmes is a complex character."@en ;
  dcterms:modified "2026-06-07T15:30:29.263255Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6346-5
  a curric:KeyLearningPoint ;
  rdfs:label """'Shrewd', 'unflappable', 'presumptuous' and 'assertive' are words that can be used
  to describe Sherlock Holmes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263262Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6352-1
  a curric:KeyLearningPoint ;
  rdfs:label "Writing is most successful when it is planned."@en ;
  dcterms:modified "2026-06-07T15:30:29.263329Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6352-2
  a curric:KeyLearningPoint ;
  rdfs:label "The paragraph should give a reason, followed by evidence to support that reason."@en ;
  dcterms:modified "2026-06-07T15:30:29.263332Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6352-3
  a curric:KeyLearningPoint ;
  rdfs:label "We should include a range of persuasive techniques in the paragraph."@en ;
  dcterms:modified "2026-06-07T15:30:29.263336Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6352-4
  a curric:KeyLearningPoint ;
  rdfs:label "Within the paragraph, ideas are connected using cohesive devices."@en ;
  dcterms:modified "2026-06-07T15:30:29.263340Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6352-5
  a curric:KeyLearningPoint ;
  rdfs:label """Parenthesis can be added to clarify a noun using commas or to emphasise a point
  using dashes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263347Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1052-1
  a curric:KeyLearningPoint ;
  rdfs:label "An apostrophe is an important piece of punctuation with more than one purpose."@en ;
  dcterms:modified "2026-06-07T15:30:29.263358Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1052-2
  a curric:KeyLearningPoint ;
  rdfs:label "An apostrophe can contract two words together."@en ;
  dcterms:modified "2026-06-07T15:30:29.263362Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1052-3
  a curric:KeyLearningPoint ;
  rdfs:label "An apostrophe can show if a noun belongs to another singular noun."@en ;
  dcterms:modified "2026-06-07T15:30:29.263366Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1052-4
  a curric:KeyLearningPoint ;
  rdfs:label """Apostrophes for contraction and singular possession are useful in writing for
  different reasons."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263369Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1052-5
  a curric:KeyLearningPoint ;
  rdfs:label "Apostrophes are most deeply understood when word class is understood."@en ;
  dcterms:modified "2026-06-07T15:30:29.263373Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1419-1
  a curric:KeyLearningPoint ;
  rdfs:label """When there are two of the same consonants beside each other, we call this a double
  consonant."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263416Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1419-2
  a curric:KeyLearningPoint ;
  rdfs:label "Double consonants are often found after short vowel sounds."@en ;
  dcterms:modified "2026-06-07T15:30:29.263420Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1419-3
  a curric:KeyLearningPoint ;
  rdfs:label "Contrasting words are pairs or sets of words that have very similar spellings."@en ;
  dcterms:modified "2026-06-07T15:30:29.263424Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1419-4
  a curric:KeyLearningPoint ;
  rdfs:label """Contrasting words are often different because one has a double consonant, which
  impacts the pronunciation of the word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263429Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1419-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: remember, medicine and address."@en ;
  dcterms:modified "2026-06-07T15:30:29.263433Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6149-1
  a curric:KeyLearningPoint ;
  rdfs:label "The purpose of the build-up is to build up suspense and excitement."@en ;
  dcterms:modified "2026-06-07T15:30:29.263501Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6149-2
  a curric:KeyLearningPoint ;
  rdfs:label "Precise and ambitious vocabulary is logged on a plan for future use."@en ;
  dcterms:modified "2026-06-07T15:30:29.263505Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6149-3
  a curric:KeyLearningPoint ;
  rdfs:label """Notes should not be written in full sentences and bullet points can be used to make
  notes clear."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263509Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6149-4
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials of time, place and manner indicate when, where and how action
  takes place."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263512Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6149-5
  a curric:KeyLearningPoint ;
  rdfs:label """'Show-not-tell' language shows a character’s feelings by describing their actions,
  body language and facial expressions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263516Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8808-1
  a curric:KeyLearningPoint ;
  rdfs:label """A range of skills are involved in presenting to ensure that the audience are engaged
  and understand you."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263543Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8808-2
  a curric:KeyLearningPoint ;
  rdfs:label """Building suspense for the audience is the main purpose when presenting a section of
  a narrative build-up."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263547Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8808-3
  a curric:KeyLearningPoint ;
  rdfs:label """Eye contact, projection and diction are important for ensuring the audience can hear
  and understand you."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263551Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8808-4
  a curric:KeyLearningPoint ;
  rdfs:label """Pace, body language and tone are crucial for conveying the atmosphere and a
  character’s emotions in a narrative."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263555Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8808-5
  a curric:KeyLearningPoint ;
  rdfs:label """Pace, body language and tone can be altered in different ways to support the
  building of suspense."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263559Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4855-1
  a curric:KeyLearningPoint ;
  rdfs:label """The quotes paragraph is used to share information from people who were at the scene
  or know more about the event."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263785Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4855-2
  a curric:KeyLearningPoint ;
  rdfs:label "Quotes add credibility to a journalistic report."@en ;
  dcterms:modified "2026-06-07T15:30:29.263789Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4855-3
  a curric:KeyLearningPoint ;
  rdfs:label "Quotes can be written in the form of direct speech or reported speech."@en ;
  dcterms:modified "2026-06-07T15:30:29.263795Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4855-4
  a curric:KeyLearningPoint ;
  rdfs:label "Extra information can be given about the speaker in the reporting clause."@en ;
  dcterms:modified "2026-06-07T15:30:29.263799Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4818-1
  a curric:KeyLearningPoint ;
  rdfs:label """Cursive handwriting involves joining letters together without lifting your
  pencil."""@en ;
  dcterms:modified "2026-06-07T15:30:29.265511Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4818-2
  a curric:KeyLearningPoint ;
  rdfs:label "There are four cursive letter joins."@en ;
  dcterms:modified "2026-06-07T15:30:29.265515Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4818-3
  a curric:KeyLearningPoint ;
  rdfs:label "Which join is used depends on which letter is joining to which letter."@en ;
  dcterms:modified "2026-06-07T15:30:29.265519Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4818-4
  a curric:KeyLearningPoint ;
  rdfs:label "The first letter has a lead in and the last letter has a lead out."@en ;
  dcterms:modified "2026-06-07T15:30:29.265525Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7358-1
  a curric:KeyLearningPoint ;
  rdfs:label """After visits from the three ghosts, Scrooge reflects on his transformation and feels
  grateful for this second chance."""@en ;
  dcterms:modified "2026-06-07T15:30:29.267361Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7358-2
  a curric:KeyLearningPoint ;
  rdfs:label """He embraces the spirit of Christmas and treats all those around him with kindness
  and generosity."""@en ;
  dcterms:modified "2026-06-07T15:30:29.267365Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7358-3
  a curric:KeyLearningPoint ;
  rdfs:label "He accepts Fred’s offer to dinner and promises Bob money and support."@en ;
  dcterms:modified "2026-06-07T15:30:29.267369Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7358-4
  a curric:KeyLearningPoint ;
  rdfs:label "Scrooge’s transformation has a big impact on Bob and his family."@en ;
  dcterms:modified "2026-06-07T15:30:29.267373Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1088-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Scrutinise' is a verb, which means to inspect or study."@en ;
  dcterms:modified "2026-06-07T15:30:29.267398Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1088-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Glimpse' is a verb, which means to spot or get a quick look."@en ;
  dcterms:modified "2026-06-07T15:30:29.267402Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1088-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Peer', 'squint', 'gawk' and 'gaze' are other verbs related to looking or
  seeing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.267406Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1092-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Hurtle' is a verb which means to rush or move very quickly."@en ;
  dcterms:modified "2026-06-07T15:30:29.267463Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1092-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Scamper' is a verb which means to scurry or dash."@en ;
  dcterms:modified "2026-06-07T15:30:29.267467Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1092-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Charge', 'dart', 'dash' and 'scurry' are other verbs related to running."@en ;
  dcterms:modified "2026-06-07T15:30:29.267471Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7673-1
  a curric:KeyLearningPoint ;
  rdfs:label """The plan includes keywords and subject-specific vocabulary related to the
  section."""@en ;
  dcterms:modified "2026-06-07T15:30:29.267489Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7673-2
  a curric:KeyLearningPoint ;
  rdfs:label "Taking notes is a skill."@en ;
  dcterms:modified "2026-06-07T15:30:29.267493Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7673-3
  a curric:KeyLearningPoint ;
  rdfs:label """Notes should not be written in full sentences and bullet points can be used to order
  notes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.267497Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7673-4
  a curric:KeyLearningPoint ;
  rdfs:label "Key vocabulary and linguistic devices should be logged in a plan."@en ;
  dcterms:modified "2026-06-07T15:30:29.267501Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7673-5
  a curric:KeyLearningPoint ;
  rdfs:label "The plan should be clearly structured in the order of the section."@en ;
  dcterms:modified "2026-06-07T15:30:29.267505Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4822-1
  a curric:KeyLearningPoint ;
  rdfs:label """A famous quotation is a well-known phrase, statement, or passage attributed to a
  particular person, work, or source."""@en ;
  dcterms:modified "2026-06-07T15:30:29.267509Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4822-2
  a curric:KeyLearningPoint ;
  rdfs:label "The quotation is demarcated with inverted commas."@en ;
  dcterms:modified "2026-06-07T15:30:29.267512Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4822-3
  a curric:KeyLearningPoint ;
  rdfs:label "The quotation starts with a capital letter."@en ;
  dcterms:modified "2026-06-07T15:30:29.267516Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4822-4
  a curric:KeyLearningPoint ;
  rdfs:label """After forming a capital letter, you need to lift your pencil to start the next part
  of the word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.267521Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4822-5
  a curric:KeyLearningPoint ;
  rdfs:label """A range of joins will be used depending on which letters are joining to which
  letters."""@en ;
  dcterms:modified "2026-06-07T15:30:29.267525Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1438-1
  a curric:KeyLearningPoint ;
  rdfs:label """-ly is a suffix that can be used to create adverbs. For most words just add
  -ly."""@en ;
  dcterms:modified "2026-06-07T15:30:29.267529Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1438-2
  a curric:KeyLearningPoint ;
  rdfs:label "For words ending in 'ic' add -ally."@en ;
  dcterms:modified "2026-06-07T15:30:29.267533Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1438-3
  a curric:KeyLearningPoint ;
  rdfs:label "For two syllablle root words ending in 'y', remove the 'y', add -ily."@en ;
  dcterms:modified "2026-06-07T15:30:29.267536Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1438-4
  a curric:KeyLearningPoint ;
  rdfs:label "For root words ending in 'le', remove the 'le', add -ly."@en ;
  dcterms:modified "2026-06-07T15:30:29.267540Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1438-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum word: build."@en ;
  dcterms:modified "2026-06-07T15:30:29.267544Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2711-1
  a curric:KeyLearningPoint ;
  rdfs:label "A fronted adverbial is a sentence starter that is followed by a comma."@en ;
  dcterms:modified "2026-06-07T15:30:29.267548Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2711-2
  a curric:KeyLearningPoint ;
  rdfs:label "A fronted adverbial can be a single word."@en ;
  dcterms:modified "2026-06-07T15:30:29.267551Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2711-3
  a curric:KeyLearningPoint ;
  rdfs:label "A fronted adverbial can be a phrase."@en ;
  dcterms:modified "2026-06-07T15:30:29.267557Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2711-4
  a curric:KeyLearningPoint ;
  rdfs:label "A phrase is a group of words with no verb."@en ;
  dcterms:modified "2026-06-07T15:30:29.267561Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2711-5
  a curric:KeyLearningPoint ;
  rdfs:label "A fronted adverbial can express detail about time, place or manner."@en ;
  dcterms:modified "2026-06-07T15:30:29.267565Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1417-1
  a curric:KeyLearningPoint ;
  rdfs:label """Words that contain the /g/ sound spelt 'gue' often come from the French
  language."""@en ;
  dcterms:modified "2026-06-07T15:30:29.267588Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1417-2
  a curric:KeyLearningPoint ;
  rdfs:label """Words that contain the /k/ sound spelt 'que' often come from the French
  language."""@en ;
  dcterms:modified "2026-06-07T15:30:29.267592Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1417-3
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: increase, extreme and surprise."@en ;
  dcterms:modified "2026-06-07T15:30:29.267598Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6692-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of a build-up is to move the main character’s journey forward and build
  tension."""@en ;
  dcterms:modified "2026-06-07T15:30:29.267602Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6692-2
  a curric:KeyLearningPoint ;
  rdfs:label """Precise and ambitious vocabulary creates vivid images for the reader for each key
  moment of the build-up."""@en ;
  dcterms:modified "2026-06-07T15:30:29.267606Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6692-3
  a curric:KeyLearningPoint ;
  rdfs:label "An effective plan has vocabulary organised concisely and neatly."@en ;
  dcterms:modified "2026-06-07T15:30:29.267610Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6692-4
  a curric:KeyLearningPoint ;
  rdfs:label """Careful verb and adverb selection can convey characters' feelings through show and
  tell."""@en ;
  dcterms:modified "2026-06-07T15:30:29.267613Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6692-5
  a curric:KeyLearningPoint ;
  rdfs:label "The emotions of the character change through the key moments of the build-up."@en ;
  dcterms:modified "2026-06-07T15:30:29.267617Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4853-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of a recount paragraph is to give the reader specific information about
  an aspect of the topic."""@en ;
  dcterms:modified "2026-06-07T15:30:29.267621Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4853-2
  a curric:KeyLearningPoint ;
  rdfs:label """Non-finite complex sentences are formed of a main clause and a non-finite
  subordinate clause."""@en ;
  dcterms:modified "2026-06-07T15:30:29.267624Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4853-3
  a curric:KeyLearningPoint ;
  rdfs:label "Varying sentence types and structure enhance text cohesion."@en ;
  dcterms:modified "2026-06-07T15:30:29.267628Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4853-4
  a curric:KeyLearningPoint ;
  rdfs:label "When we plan, bullet points are used that are written in note form."@en ;
  dcterms:modified "2026-06-07T15:30:29.267632Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7922-1
  a curric:KeyLearningPoint ;
  rdfs:label "In this section of the book, we see Joseph subjected to bullying."@en ;
  dcterms:modified "2026-06-07T15:30:29.267742Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7922-2
  a curric:KeyLearningPoint ;
  rdfs:label """Adonis intervenes, putting Bert at risk; Joseph helps Bert escape, but he is not
  thanked for this."""@en ;
  dcterms:modified "2026-06-07T15:30:29.267746Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7922-3
  a curric:KeyLearningPoint ;
  rdfs:label """We can compare character experiences across a book, identifying a character's lows
  and highs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.267750Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7922-4
  a curric:KeyLearningPoint ;
  rdfs:label """We can try and spot connections between different characters and their
  experiences."""@en ;
  dcterms:modified "2026-06-07T15:30:29.267754Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7922-5
  a curric:KeyLearningPoint ;
  rdfs:label "These connections might be intended by the author or not."@en ;
  dcterms:modified "2026-06-07T15:30:29.267758Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1119-1
  a curric:KeyLearningPoint ;
  rdfs:label "Gargantuan is an adjective which means huge or enormous."@en ;
  dcterms:modified "2026-06-07T15:30:29.269028Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1119-2
  a curric:KeyLearningPoint ;
  rdfs:label "Bulky is an adjective which means large, heavily built or stocky."@en ;
  dcterms:modified "2026-06-07T15:30:29.269032Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1119-3
  a curric:KeyLearningPoint ;
  rdfs:label "A dictionary can be useful to help us spell words."@en ;
  dcterms:modified "2026-06-07T15:30:29.269036Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1315-1
  a curric:KeyLearningPoint ;
  rdfs:label """An introduction's purpose is to give general facts to the reader and to encourage
  them to read on."""@en ;
  dcterms:modified "2026-06-07T15:30:29.270011Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1315-2
  a curric:KeyLearningPoint ;
  rdfs:label """The introduction gives general facts about the unique characteristics of the
  anglerfish."""@en ;
  dcterms:modified "2026-06-07T15:30:29.270015Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1315-3
  a curric:KeyLearningPoint ;
  rdfs:label """The introduction tells the reader what they will learn in the rest of the
  report."""@en ;
  dcterms:modified "2026-06-07T15:30:29.270021Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4831-1
  a curric:KeyLearningPoint ;
  rdfs:label "Pen and pencil are the most common tools used to write or draw with."@en ;
  dcterms:modified "2026-06-07T15:30:29.270056Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4831-2
  a curric:KeyLearningPoint ;
  rdfs:label """Making a choice between pen and pencil depends on the task and the desired
  outcome."""@en ;
  dcterms:modified "2026-06-07T15:30:29.270059Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4831-3
  a curric:KeyLearningPoint ;
  rdfs:label """Using a pencil allows for mistakes to be corrected easily with an eraser, which is
  ideal for sketching and drafting."""@en ;
  dcterms:modified "2026-06-07T15:30:29.270063Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4831-4
  a curric:KeyLearningPoint ;
  rdfs:label """Using a pen is ideal for final drafts as pen is permanent and looks neat and
  professional."""@en ;
  dcterms:modified "2026-06-07T15:30:29.270067Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4831-5
  a curric:KeyLearningPoint ;
  rdfs:label "Over time you will develop a personal preference for using pen or pencil."@en ;
  dcterms:modified "2026-06-07T15:30:29.270071Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1405-1
  a curric:KeyLearningPoint ;
  rdfs:label "Words ending in the suffix -sion are nouns."@en ;
  dcterms:modified "2026-06-07T15:30:29.270075Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1405-2
  a curric:KeyLearningPoint ;
  rdfs:label "The suffix -sion sometimes makes the sound /zhun/ like ‘division’."@en ;
  dcterms:modified "2026-06-07T15:30:29.270079Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1405-3
  a curric:KeyLearningPoint ;
  rdfs:label "Words spelt with -sion often have a root word ending in ‘d’, ‘de’ or ‘se’."@en ;
  dcterms:modified "2026-06-07T15:30:29.270082Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1405-4
  a curric:KeyLearningPoint ;
  rdfs:label "The /shun/ suffix can be spelt -tion, -sion, -ssion or -cian."@en ;
  dcterms:modified "2026-06-07T15:30:29.270086Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1405-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: reign, island and February."@en ;
  dcterms:modified "2026-06-07T15:30:29.270092Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1402-1
  a curric:KeyLearningPoint ;
  rdfs:label "The suffix -ness turns adjectives into abstract nouns."@en ;
  dcterms:modified "2026-06-07T15:30:29.270096Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1402-2
  a curric:KeyLearningPoint ;
  rdfs:label "For most words, just add the suffix -ness."@en ;
  dcterms:modified "2026-06-07T15:30:29.270100Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1402-3
  a curric:KeyLearningPoint ;
  rdfs:label "When a word ends in ‘y’, replace the ‘y’ with ‘i’, then add the suffix -ness."@en ;
  dcterms:modified "2026-06-07T15:30:29.270104Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1402-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: heart, accident and accidentally."@en ;
  dcterms:modified "2026-06-07T15:30:29.270109Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8072-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘Back to Me’ can be considered a list poem; it contains 15 lines, with between 1-4
  words in each."""@en ;
  dcterms:modified "2026-06-07T15:30:29.270114Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8072-2
  a curric:KeyLearningPoint ;
  rdfs:label """Readers might connect to their thoughts, feelings and sense of identity in similar
  or different ways."""@en ;
  dcterms:modified "2026-06-07T15:30:29.270117Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8072-3
  a curric:KeyLearningPoint ;
  rdfs:label "‘Find Me’ is a fixed verse poem, split into 12 two-line verses."@en ;
  dcterms:modified "2026-06-07T15:30:29.270121Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8072-4
  a curric:KeyLearningPoint ;
  rdfs:label """A technique that poets can use to draw attention to specific lines is by changing
  the rhythm of the poem."""@en ;
  dcterms:modified "2026-06-07T15:30:29.270125Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8072-5
  a curric:KeyLearningPoint ;
  rdfs:label "'Friend' and 'Everyone' are poems by Laura Mucha."@en ;
  dcterms:modified "2026-06-07T15:30:29.270131Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8063-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘The Tyger’ is a fixed verse poem; each verse has a rhyme scheme of AABB & a clear
  syllable pattern when reading aloud."""@en ;
  dcterms:modified "2026-06-07T15:30:29.270154Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8063-2
  a curric:KeyLearningPoint ;
  rdfs:label """Understanding a poem, its language and the impression it creates will help us to
  create an impactful performance."""@en ;
  dcterms:modified "2026-06-07T15:30:29.270158Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8063-3
  a curric:KeyLearningPoint ;
  rdfs:label """We can improve our performances by considering the rhythm and flow of the poem, our
  use of voice and use of gestures."""@en ;
  dcterms:modified "2026-06-07T15:30:29.270161Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8063-4
  a curric:KeyLearningPoint ;
  rdfs:label "We can improve our performances of poetry through practice."@en ;
  dcterms:modified "2026-06-07T15:30:29.270167Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8051-1
  a curric:KeyLearningPoint ;
  rdfs:label """Poems can be published with illustrations to help the reader engage with the poetry
  further."""@en ;
  dcterms:modified "2026-06-07T15:30:29.270171Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8051-2
  a curric:KeyLearningPoint ;
  rdfs:label "Illustrations can be influenced by both the content and form of the poem."@en ;
  dcterms:modified "2026-06-07T15:30:29.270175Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8051-3
  a curric:KeyLearningPoint ;
  rdfs:label """A poem’s illustrations can be based on imagery, emotions, rhythm and flow, and the
  intended audience."""@en ;
  dcterms:modified "2026-06-07T15:30:29.270178Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8051-4
  a curric:KeyLearningPoint ;
  rdfs:label """The layout of words and illustrations in a poem can make it more visually appealing
  to the reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.270182Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6347-1
  a curric:KeyLearningPoint ;
  rdfs:label """We can imagine Sherlock Holmes receiving lots of letters from potential clients
  asking him to help."""@en ;
  dcterms:modified "2026-06-07T15:30:29.270188Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6347-2
  a curric:KeyLearningPoint ;
  rdfs:label """We can imagine Holmes would only take on interesting cases, perhaps from people in
  desperate need."""@en ;
  dcterms:modified "2026-06-07T15:30:29.270191Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6347-3
  a curric:KeyLearningPoint ;
  rdfs:label """A letter to Holmes would have been formal in tone, given his position in
  society."""@en ;
  dcterms:modified "2026-06-07T15:30:29.270195Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6347-4
  a curric:KeyLearningPoint ;
  rdfs:label "A persuasive letter contains elements of both persuasion and explanation."@en ;
  dcterms:modified "2026-06-07T15:30:29.270199Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6347-5
  a curric:KeyLearningPoint ;
  rdfs:label "The explanation must be coherent and a range of persuasive devices can be used."@en ;
  dcterms:modified "2026-06-07T15:30:29.270202Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6413-1
  a curric:KeyLearningPoint ;
  rdfs:label """Caribbean immigrants were drawn to the UK by the promise of better pay and living
  conditions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.270247Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6413-2
  a curric:KeyLearningPoint ;
  rdfs:label """The Windrush arrivals were given some support by the British government, but they
  faced discrimination."""@en ;
  dcterms:modified "2026-06-07T15:30:29.270251Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6413-3
  a curric:KeyLearningPoint ;
  rdfs:label """It could be hard to find housing and many could only find jobs at a lower level than
  they were qualified for."""@en ;
  dcterms:modified "2026-06-07T15:30:29.270257Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6413-4
  a curric:KeyLearningPoint ;
  rdfs:label """The weather and appearance of Britain was also a shock to some of the Windrush
  immigrants."""@en ;
  dcterms:modified "2026-06-07T15:30:29.270261Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6413-5
  a curric:KeyLearningPoint ;
  rdfs:label """Nevertheless, many stayed in Britain and their descendants live here to this
  day."""@en ;
  dcterms:modified "2026-06-07T15:30:29.270265Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6367-1
  a curric:KeyLearningPoint ;
  rdfs:label "Editing is a vital element of the writing process."@en ;
  dcterms:modified "2026-06-07T15:30:29.270268Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6367-2
  a curric:KeyLearningPoint ;
  rdfs:label "When editing, we must be selective about which parts of our writing to improve."@en ;
  dcterms:modified "2026-06-07T15:30:29.270272Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6367-3
  a curric:KeyLearningPoint ;
  rdfs:label """When editing, we can focus on punctuation, sentence structure, vocabulary and
  spelling."""@en ;
  dcterms:modified "2026-06-07T15:30:29.270276Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5700-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the climax is to describe the highest tension, pace and action and to
  start to solve the problem."""@en ;
  dcterms:modified "2026-06-07T15:30:29.270280Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5700-2
  a curric:KeyLearningPoint ;
  rdfs:label "Saying sentences aloud before they are written helps to check for sense."@en ;
  dcterms:modified "2026-06-07T15:30:29.270283Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5700-3
  a curric:KeyLearningPoint ;
  rdfs:label """Using the full range of sentence types (simple, compound and complex) improves text
  flow for the reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.270287Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5700-4
  a curric:KeyLearningPoint ;
  rdfs:label """A rhetorical question engages the reader and makes them feel more curious about the
  narrative."""@en ;
  dcterms:modified "2026-06-07T15:30:29.270291Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5700-5
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials of time, place and manner describe the action in the main clause
  in further detail."""@en ;
  dcterms:modified "2026-06-07T15:30:29.270295Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6274-1
  a curric:KeyLearningPoint ;
  rdfs:label """In 'Mirror' the afterword describes why Jeannie Baker was inspired to make the text
  and how she created the artwork."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271035Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6274-2
  a curric:KeyLearningPoint ;
  rdfs:label "A theme is a big idea, topic or message that recurs within a story."@en ;
  dcterms:modified "2026-06-07T15:30:29.271039Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6274-3
  a curric:KeyLearningPoint ;
  rdfs:label """Readers can interpret their own big idea or message from a narrative; readers may
  interpret a text in different ways."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271044Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6274-4
  a curric:KeyLearningPoint ;
  rdfs:label """Settings and events depicted in the book contribute to the boys’ sense of identity
  and belonging."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271048Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6274-5
  a curric:KeyLearningPoint ;
  rdfs:label """Culture and traditions in each setting are conveyed through unique clothing,
  architecture, food and daily activities."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271052Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4803-1
  a curric:KeyLearningPoint ;
  rdfs:label "The letters all have a lead in and a lead out."@en ;
  dcterms:modified "2026-06-07T15:30:29.271392Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4803-2
  a curric:KeyLearningPoint ;
  rdfs:label "The fourth join goes from the x-height line up towards the ascender line."@en ;
  dcterms:modified "2026-06-07T15:30:29.271396Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4803-3
  a curric:KeyLearningPoint ;
  rdfs:label """When joining to the letter t, the join reaches to between the x-height line and the
  ascender line."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271401Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4803-4
  a curric:KeyLearningPoint ;
  rdfs:label "The pencil does not lift when forming the join."@en ;
  dcterms:modified "2026-06-07T15:30:29.271406Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4803-5
  a curric:KeyLearningPoint ;
  rdfs:label """When forming the letter f, it has two loops: at the top of the lead in and at the
  bottom ready for the lead out."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271409Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7347-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of a setting description is to provide rich detail that creates an
  atmosphere for the reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271896Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7347-2
  a curric:KeyLearningPoint ;
  rdfs:label """Precise vocabulary, sensory details and personification support in creating a
  desired atmosphere."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271899Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7347-3
  a curric:KeyLearningPoint ;
  rdfs:label """Prepositions help to describe the setting in a precise way by telling the reader
  where a noun is."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271903Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7347-4
  a curric:KeyLearningPoint ;
  rdfs:label """Using a range of sentence types (simple, compound and complex) improves text flow
  for the reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271938Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7918-1
  a curric:KeyLearningPoint ;
  rdfs:label """When we give our opinion about a text, we often need to justify our view with
  evidence or explanations."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271943Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7918-2
  a curric:KeyLearningPoint ;
  rdfs:label "Specific language choices are made by the author to convey meaning."@en ;
  dcterms:modified "2026-06-07T15:30:29.271947Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7918-3
  a curric:KeyLearningPoint ;
  rdfs:label """We can compare characters within and between texts, including the same character at
  different points in a text."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271950Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7918-4
  a curric:KeyLearningPoint ;
  rdfs:label "Making these comparisons helps us to understand characters better."@en ;
  dcterms:modified "2026-06-07T15:30:29.271954Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1314-1
  a curric:KeyLearningPoint ;
  rdfs:label """Subject-specific, factual vocabulary, including numeral facts, is used in a
  non-chronological report."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271972Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1314-2
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials of cause are used at the start of a sentence that gives an effect
  to the cause in the previous one."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271980Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1314-3
  a curric:KeyLearningPoint ;
  rdfs:label """Sentences can start with a range of fronted adverbials like formal and viewpoint
  fronted adverbials."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271986Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1314-4
  a curric:KeyLearningPoint ;
  rdfs:label """Non-chronological reports are non-fiction texts that inform the reader about a
  specific subject."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271989Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6721-1
  a curric:KeyLearningPoint ;
  rdfs:label """In a biography, we write using a formal tone in the third person; our writing is
  mostly, but not all, in the past tense."""@en ;
  dcterms:modified "2026-06-07T15:30:29.272012Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6721-2
  a curric:KeyLearningPoint ;
  rdfs:label "We use a range of cohesive devices to connect ideas together."@en ;
  dcterms:modified "2026-06-07T15:30:29.272015Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6721-3
  a curric:KeyLearningPoint ;
  rdfs:label "We orally rehearse our sentences before we write."@en ;
  dcterms:modified "2026-06-07T15:30:29.272019Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6721-4
  a curric:KeyLearningPoint ;
  rdfs:label """We use our notes from our plan to help us write (including the subject-specific
  vocabulary we planned to use)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.272023Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6721-5
  a curric:KeyLearningPoint ;
  rdfs:label """We give a title for the biography as a whole and subheadings for each paragraph.
  Each paragraph is indented."""@en ;
  dcterms:modified "2026-06-07T15:30:29.272026Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8773-1
  a curric:KeyLearningPoint ;
  rdfs:label """Using the layout features to navigate a non-fiction text helps us to
  understand it."""@en ;
  dcterms:modified "2026-06-07T15:30:29.272030Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8773-2
  a curric:KeyLearningPoint ;
  rdfs:label """Using strategies like skimming and scanning for key words helps us retrieve
  information quickly."""@en ;
  dcterms:modified "2026-06-07T15:30:29.272034Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8773-3
  a curric:KeyLearningPoint ;
  rdfs:label """Summarising what has been read helps knowledge to stick and builds
  comprehension."""@en ;
  dcterms:modified "2026-06-07T15:30:29.272037Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8773-4
  a curric:KeyLearningPoint ;
  rdfs:label """Creatures on our planet create light naturally through the processes of
  bioluminescence and biofluorescence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.272041Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8773-5
  a curric:KeyLearningPoint ;
  rdfs:label """Understanding the science behind glowing creatures can help us protect the planet
  and understand diseases."""@en ;
  dcterms:modified "2026-06-07T15:30:29.272045Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7874-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘Greenling’ can be considered a fable, its moral might link to the conservation &
  preservation of the environment."""@en ;
  dcterms:modified "2026-06-07T15:30:29.272068Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7874-2
  a curric:KeyLearningPoint ;
  rdfs:label "A theme is a big idea, topic or message that recurs within a story."@en ;
  dcterms:modified "2026-06-07T15:30:29.272071Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7874-3
  a curric:KeyLearningPoint ;
  rdfs:label """Some of the themes of 'Greenling' are sustainability, acceptance and the power of
  nature."""@en ;
  dcterms:modified "2026-06-07T15:30:29.272075Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7874-4
  a curric:KeyLearningPoint ;
  rdfs:label """Revisiting a text can allow readers to discuss questions that focus on themes that
  are not explicitly stated in the text"""@en ;
  dcterms:modified "2026-06-07T15:30:29.272079Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6357-1
  a curric:KeyLearningPoint ;
  rdfs:label """Journalistic reports are written using formal and factual language to create a
  serious and objective tone."""@en ;
  dcterms:modified "2026-06-07T15:30:29.272082Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6357-2
  a curric:KeyLearningPoint ;
  rdfs:label """The use of subject-specific vocabulary is crucial in journalistic reports and varies
  depending on the news event."""@en ;
  dcterms:modified "2026-06-07T15:30:29.272086Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6357-3
  a curric:KeyLearningPoint ;
  rdfs:label """Appropriate synonyms are used in journalistic reports to create a formal tone and to
  avoid repetition."""@en ;
  dcterms:modified "2026-06-07T15:30:29.272089Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6357-4
  a curric:KeyLearningPoint ;
  rdfs:label """Formal language involves the use of sophisticated vocabulary without the use of
  contractions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.272093Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1404-1
  a curric:KeyLearningPoint ;
  rdfs:label "The /shun/ suffix can be spelt -tion, -sion, -ssion or -cian."@en ;
  dcterms:modified "2026-06-07T15:30:29.272118Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1404-2
  a curric:KeyLearningPoint ;
  rdfs:label "Words ending in the suffix -cian are nouns and a profession."@en ;
  dcterms:modified "2026-06-07T15:30:29.272121Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1404-3
  a curric:KeyLearningPoint ;
  rdfs:label "Words spelt with -cian often have a root word ending in ‘c’ or ‘cs’."@en ;
  dcterms:modified "2026-06-07T15:30:29.272128Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1404-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: eighth, weight and knowledge."@en ;
  dcterms:modified "2026-06-07T15:30:29.272132Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1377-1
  a curric:KeyLearningPoint ;
  rdfs:label "The suffixes -ance and -ancy can create abstract nouns."@en ;
  dcterms:modified "2026-06-07T15:30:29.272150Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1377-2
  a curric:KeyLearningPoint ;
  rdfs:label "The -ance or -ancy spellings may be found after a ‘hard c’ or ‘hard ‘g’."@en ;
  dcterms:modified "2026-06-07T15:30:29.272154Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1377-3
  a curric:KeyLearningPoint ;
  rdfs:label """Words ending in -ant/-ance/-ancy sometimes have related words where the ‘ay’ vowel
  sound is clearer."""@en ;
  dcterms:modified "2026-06-07T15:30:29.272158Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1377-4
  a curric:KeyLearningPoint ;
  rdfs:label "Words in word families often have connected meaning and spelling."@en ;
  dcterms:modified "2026-06-07T15:30:29.272162Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1377-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: length, strength, though and although."@en ;
  dcterms:modified "2026-06-07T15:30:29.272165Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6115-1
  a curric:KeyLearningPoint ;
  rdfs:label """Information in a section becomes more specific and detailed as the section
  goes on."""@en ;
  dcterms:modified "2026-06-07T15:30:29.272205Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6115-2
  a curric:KeyLearningPoint ;
  rdfs:label "Facts written in a section should be researched and organised prior to writing."@en ;
  dcterms:modified "2026-06-07T15:30:29.272209Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6115-3
  a curric:KeyLearningPoint ;
  rdfs:label "A range of cohesive devices helps us to link facts within and between sentences."@en ;
  dcterms:modified "2026-06-07T15:30:29.272213Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6115-4
  a curric:KeyLearningPoint ;
  rdfs:label """Before we write, we should orally rehearse sentences to ensure our sentences make
  sense and flow well."""@en ;
  dcterms:modified "2026-06-07T15:30:29.272217Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6115-5
  a curric:KeyLearningPoint ;
  rdfs:label """Parenthesis, varied sentence types and a range of fronted adverbials are all
  cohesive devices that can be used."""@en ;
  dcterms:modified "2026-06-07T15:30:29.272221Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6188-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of an essay can be to present a coherent argument in response to a
  stimulus or question."""@en ;
  dcterms:modified "2026-06-07T15:30:29.272224Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6188-2
  a curric:KeyLearningPoint ;
  rdfs:label "Understanding the question is critical to a successful essay answer."@en ;
  dcterms:modified "2026-06-07T15:30:29.272230Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6188-3
  a curric:KeyLearningPoint ;
  rdfs:label "An essay can attempt to persuade the reader of a certain viewpoint."@en ;
  dcterms:modified "2026-06-07T15:30:29.272234Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6188-4
  a curric:KeyLearningPoint ;
  rdfs:label "An essay follows a logical argument going step by step towards a conclusion."@en ;
  dcterms:modified "2026-06-07T15:30:29.272238Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6188-5
  a curric:KeyLearningPoint ;
  rdfs:label """A range of linguistic features contribute to the formal tone of an essay and make it
  persuasive."""@en ;
  dcterms:modified "2026-06-07T15:30:29.272242Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1454-1
  a curric:KeyLearningPoint ;
  rdfs:label """Homophones are words that have different spellings and multiple meanings, but sound
  the same."""@en ;
  dcterms:modified "2026-06-07T15:30:29.272246Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1454-2
  a curric:KeyLearningPoint ;
  rdfs:label """A homonym is a word that has the same spelling or pronunciation as another but a
  different meaning."""@en ;
  dcterms:modified "2026-06-07T15:30:29.272249Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1454-3
  a curric:KeyLearningPoint ;
  rdfs:label "The meaning of a homonym or homophone is dependent on the context."@en ;
  dcterms:modified "2026-06-07T15:30:29.272255Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1454-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum word: quarter."@en ;
  dcterms:modified "2026-06-07T15:30:29.272259Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1097-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Impenetrable' is an adjective which means dense or inaccessible."@en ;
  dcterms:modified "2026-06-07T15:30:29.272263Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1097-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Barren' is an adjective which means empty or bare."@en ;
  dcterms:modified "2026-06-07T15:30:29.272267Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1097-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Teeming' is an adjective which means full or crowded."@en ;
  dcterms:modified "2026-06-07T15:30:29.272273Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1097-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Overgrown', 'withered' and 'tangled' are other rich vocabulary associated with the
  outdoors."""@en ;
  dcterms:modified "2026-06-07T15:30:29.272277Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5810-1
  a curric:KeyLearningPoint ;
  rdfs:label "A diary entry combines details about events with details about emotions."@en ;
  dcterms:modified "2026-06-07T15:30:29.272281Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5810-2
  a curric:KeyLearningPoint ;
  rdfs:label "We can use certain linguistic features to make an appropriate tone for a diary."@en ;
  dcterms:modified "2026-06-07T15:30:29.272284Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5810-3
  a curric:KeyLearningPoint ;
  rdfs:label """Hyperbole, internal thoughts, rhetorical questions and exclamation sentences make
  diary writing more personal."""@en ;
  dcterms:modified "2026-06-07T15:30:29.272288Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5810-4
  a curric:KeyLearningPoint ;
  rdfs:label """We connect ideas together in writing with cohesive devices like fronted adverbials
  and different sentence types."""@en ;
  dcterms:modified "2026-06-07T15:30:29.272292Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5810-5
  a curric:KeyLearningPoint ;
  rdfs:label "We may change tense between past and present during a diary entry."@en ;
  dcterms:modified "2026-06-07T15:30:29.272296Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1422-1
  a curric:KeyLearningPoint ;
  rdfs:label """Words that are pronounced the same but have different spellings and meanings are
  called homophones."""@en ;
  dcterms:modified "2026-06-07T15:30:29.272311Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1422-2
  a curric:KeyLearningPoint ;
  rdfs:label "Unlike other words we have investigated, there are no patterns for homophones."@en ;
  dcterms:modified "2026-06-07T15:30:29.272336Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1422-3
  a curric:KeyLearningPoint ;
  rdfs:label """The way a word is spelt and its place within a sentence will tell us its
  meaning."""@en ;
  dcterms:modified "2026-06-07T15:30:29.272340Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1422-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: straight, caught and possess."@en ;
  dcterms:modified "2026-06-07T15:30:29.272344Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7833-1
  a curric:KeyLearningPoint ;
  rdfs:label "Swallow's Kiss has themes of empathy, friendship and respect."@en ;
  dcterms:modified "2026-06-07T15:30:29.272359Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7833-2
  a curric:KeyLearningPoint ;
  rdfs:label """Blessing demonstrates lots of positive emotions and character traits in the
  story."""@en ;
  dcterms:modified "2026-06-07T15:30:29.272364Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7833-3
  a curric:KeyLearningPoint ;
  rdfs:label """Throughout the story, Blessing makes a wish for others by touching the mark on her
  lip, made when she was a baby."""@en ;
  dcterms:modified "2026-06-07T15:30:29.272368Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7833-4
  a curric:KeyLearningPoint ;
  rdfs:label """Making connections and recommendations can enhance the reading experience and widen
  the reader’s understanding of texts."""@en ;
  dcterms:modified "2026-06-07T15:30:29.272372Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6372-1
  a curric:KeyLearningPoint ;
  rdfs:label "Figurative language can be used to create imagery and describe events."@en ;
  dcterms:modified "2026-06-07T15:30:29.272389Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6372-2
  a curric:KeyLearningPoint ;
  rdfs:label "Varying sentence structure and vocabulary choices enhance text cohesion or flow."@en ;
  dcterms:modified "2026-06-07T15:30:29.272393Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6372-3
  a curric:KeyLearningPoint ;
  rdfs:label "A hyphen can be used to join two words to form one compound adjective."@en ;
  dcterms:modified "2026-06-07T15:30:29.272397Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6372-4
  a curric:KeyLearningPoint ;
  rdfs:label """Using show-not-tell enables writers to share characters' emotions, actions and
  gestures with the reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.272400Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8470-1
  a curric:KeyLearningPoint ;
  rdfs:label """The opening of ‘The Iron Man’ introduces the protagonist and conveys a mysterious
  atmosphere within the setting."""@en ;
  dcterms:modified "2026-06-07T15:30:29.272406Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8470-2
  a curric:KeyLearningPoint ;
  rdfs:label """The use of precise and ambitious vocabulary engages the reader and conveys the
  mysterious atmosphere."""@en ;
  dcterms:modified "2026-06-07T15:30:29.272410Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8470-3
  a curric:KeyLearningPoint ;
  rdfs:label "Using a range of sentence types supports text flow."@en ;
  dcterms:modified "2026-06-07T15:30:29.272414Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8470-4
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials of time, place and manner add greater detail to a sentence and
  help convey the desired atmosphere."""@en ;
  dcterms:modified "2026-06-07T15:30:29.272417Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2724-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the build-up is to develop the characters and build up the
  excitement."""@en ;
  dcterms:modified "2026-06-07T15:30:29.272421Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2724-2
  a curric:KeyLearningPoint ;
  rdfs:label """When we plan, we log precise and ambitious vocabulary to help paint vivid pictures
  for our reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.272425Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2724-3
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials of time, place and manner are included in a plan to add extra
  detail about the action."""@en ;
  dcterms:modified "2026-06-07T15:30:29.272429Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2724-4
  a curric:KeyLearningPoint ;
  rdfs:label "A plan is most often written in note-form, out of full sentences."@en ;
  dcterms:modified "2026-06-07T15:30:29.272433Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1106-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Blistering' is an adjective which means harsh or scorching."@en ;
  dcterms:modified "2026-06-07T15:30:29.272439Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1106-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Perspire' is a verb which means to drip with sweat."@en ;
  dcterms:modified "2026-06-07T15:30:29.272443Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1106-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Radiant' is an adjective which means bright, brilliant or glowing."@en ;
  dcterms:modified "2026-06-07T15:30:29.272447Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7670-1
  a curric:KeyLearningPoint ;
  rdfs:label """A piece of published writing is the final, best version and should be visually
  appealing to the reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.272450Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7670-2
  a curric:KeyLearningPoint ;
  rdfs:label "Neat, joined handwriting is important when publishing a piece of writing."@en ;
  dcterms:modified "2026-06-07T15:30:29.272454Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7670-3
  a curric:KeyLearningPoint ;
  rdfs:label """Illustrations can bring the world of the story to life and make it more vivid in the
  reader's mind."""@en ;
  dcterms:modified "2026-06-07T15:30:29.272457Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7670-4
  a curric:KeyLearningPoint ;
  rdfs:label "Reading aloud involves speaking to an audience at a suitable volume and pace."@en ;
  dcterms:modified "2026-06-07T15:30:29.272461Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7670-5
  a curric:KeyLearningPoint ;
  rdfs:label """Reading with expression means reading with feeling and emotion to bring the words to
  life for the audience."""@en ;
  dcterms:modified "2026-06-07T15:30:29.272465Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4804-1
  a curric:KeyLearningPoint ;
  rdfs:label "The letters all have a lead in and a lead out."@en ;
  dcterms:modified "2026-06-07T15:30:29.274083Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4804-2
  a curric:KeyLearningPoint ;
  rdfs:label """The third join starts at the x-height line and dips below the x-height line and back
  up to join the next letter."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274086Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4804-3
  a curric:KeyLearningPoint ;
  rdfs:label """When connecting the letter e, with the third join, the dip down starts the formation
  of the letter e."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274090Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4804-4
  a curric:KeyLearningPoint ;
  rdfs:label "The pencil does not lift when forming the join."@en ;
  dcterms:modified "2026-06-07T15:30:29.274094Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4804-5
  a curric:KeyLearningPoint ;
  rdfs:label """When using the third join you leave enough space to ensure the letters are not
  touching without leaving a big gap."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274097Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3470-1
  a curric:KeyLearningPoint ;
  rdfs:label "Activity inside the hive is an important part of the honey-making process."@en ;
  dcterms:modified "2026-06-07T15:30:29.274114Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3470-2
  a curric:KeyLearningPoint ;
  rdfs:label "The main sections in an explanation text follow a clear, sequenced order."@en ;
  dcterms:modified "2026-06-07T15:30:29.274118Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3470-3
  a curric:KeyLearningPoint ;
  rdfs:label """Notes should not be written in full sentences and bullet points can be used to make
  notes clear."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274124Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3470-4
  a curric:KeyLearningPoint ;
  rdfs:label """Facts become increasingly specific throughout one section of an explanation
  text."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274130Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5770-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the main body of this diary entry is to describe events, thoughts and
  feelings in detail."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274164Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5770-2
  a curric:KeyLearningPoint ;
  rdfs:label "Adverbials of time can be used to sequence events."@en ;
  dcterms:modified "2026-06-07T15:30:29.274168Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5770-3
  a curric:KeyLearningPoint ;
  rdfs:label "The main body of this diary entry is primarily written in the past tense."@en ;
  dcterms:modified "2026-06-07T15:30:29.274171Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5770-4
  a curric:KeyLearningPoint ;
  rdfs:label """Informal tone can be achieved through use of contractions, vocabulary choice and
  exclamations."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274175Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5630-1
  a curric:KeyLearningPoint ;
  rdfs:label """This paragraph recounts the final part of the boy’s journey and his discovery that
  his dad is at his grandma’s."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274179Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5630-2
  a curric:KeyLearningPoint ;
  rdfs:label """The boys emotions heighten and he experiences intense fear leading up to him being
  reunited with his grandma and dad."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274185Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5630-3
  a curric:KeyLearningPoint ;
  rdfs:label """Thoughts and feelings can be explicitly stated and conveyed through the use of ‘show
  and tell’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274189Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5630-4
  a curric:KeyLearningPoint ;
  rdfs:label "There is a shift from past to present tense during the final paragraph."@en ;
  dcterms:modified "2026-06-07T15:30:29.274192Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5630-5
  a curric:KeyLearningPoint ;
  rdfs:label """Present tense writing at the end of a diary entry conveys current reflections and
  feelings."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274196Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6358-1
  a curric:KeyLearningPoint ;
  rdfs:label """The opening paragraph of a journalistic report provides an overview of the news
  event."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274318Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6358-2
  a curric:KeyLearningPoint ;
  rdfs:label "The opening answers the questions what, where, when and who."@en ;
  dcterms:modified "2026-06-07T15:30:29.274321Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6358-3
  a curric:KeyLearningPoint ;
  rdfs:label """Formal and subject-specific vocabulary is used to write the opening of a
  journalistic report."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274325Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6358-4
  a curric:KeyLearningPoint ;
  rdfs:label "The use of formal language creates a serious, factual and objective tone."@en ;
  dcterms:modified "2026-06-07T15:30:29.274331Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6358-5
  a curric:KeyLearningPoint ;
  rdfs:label """A relative complex sentence allows the writer to provide extra detail about the
  people involved."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274334Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8011-1
  a curric:KeyLearningPoint ;
  rdfs:label """Joseph Coelho’s poems are easy to read and engaging, with playful rhythms and
  subjects that young readers can relate to."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274429Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8011-2
  a curric:KeyLearningPoint ;
  rdfs:label "Joseph Coelho often writes poems with imaginative themes."@en ;
  dcterms:modified "2026-06-07T15:30:29.274432Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8011-3
  a curric:KeyLearningPoint ;
  rdfs:label """The poem ‘Things that Lurk in the Library’ is about the magic and wonder of
  libraries, books and reading."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274436Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8011-4
  a curric:KeyLearningPoint ;
  rdfs:label """The poet uses personification to create vivid imagery and a sense of the mystery and
  magic of libraries."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274440Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6351-1
  a curric:KeyLearningPoint ;
  rdfs:label "Writing is most successful when it is planned."@en ;
  dcterms:modified "2026-06-07T15:30:29.274444Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6351-2
  a curric:KeyLearningPoint ;
  rdfs:label """The paragraph should give a reason (followed by evidence to support that reason) why
  the recipient should help."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274447Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6351-3
  a curric:KeyLearningPoint ;
  rdfs:label "We should include a range of persuasive techniques in the paragraph."@en ;
  dcterms:modified "2026-06-07T15:30:29.274451Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6351-4
  a curric:KeyLearningPoint ;
  rdfs:label "Within the paragraph, ideas are connected using cohesive devices."@en ;
  dcterms:modified "2026-06-07T15:30:29.274455Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6351-5
  a curric:KeyLearningPoint ;
  rdfs:label """A colon can be used after a main clause to introduce an explanation which is also a
  main clause."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274459Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27896-1
  a curric:KeyLearningPoint ;
  rdfs:label "A speech is written for a specific audience in order to achieve its purpose."@en ;
  dcterms:modified "2026-06-07T15:30:29.274569Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27896-2
  a curric:KeyLearningPoint ;
  rdfs:label "Speeches can inform an audience about something they may not already know about."@en ;
  dcterms:modified "2026-06-07T15:30:29.274573Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27896-3
  a curric:KeyLearningPoint ;
  rdfs:label "The purpose of a speech is always to impact the audience in some way."@en ;
  dcterms:modified "2026-06-07T15:30:29.274577Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27896-4
  a curric:KeyLearningPoint ;
  rdfs:label "A speech will often try to persuade an audience to agree with its main themes."@en ;
  dcterms:modified "2026-06-07T15:30:29.274581Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1416-1
  a curric:KeyLearningPoint ;
  rdfs:label "The /sh/ sound can be spelt 'sh' or 'ch'."@en ;
  dcterms:modified "2026-06-07T15:30:29.274584Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1416-2
  a curric:KeyLearningPoint ;
  rdfs:label "Many words in the English language come from other languages."@en ;
  dcterms:modified "2026-06-07T15:30:29.274588Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1416-3
  a curric:KeyLearningPoint ;
  rdfs:label """Words that contain the /sh/ sound spelt 'ch' often come from the French
  language."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274592Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1416-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: certain, important and woman."@en ;
  dcterms:modified "2026-06-07T15:30:29.274596Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8636-1
  a curric:KeyLearningPoint ;
  rdfs:label """The setting of ‘The Borrowers’ is the Clock family home, which is underneath the
  floorboards of an old, English house."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274633Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8636-2
  a curric:KeyLearningPoint ;
  rdfs:label """A preposition of place is a word or words that can tell the reader where a
  noun is."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274637Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8636-3
  a curric:KeyLearningPoint ;
  rdfs:label """Prepositions and precise vocabulary are crucial for describing an intricate
  setting."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274641Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8636-4
  a curric:KeyLearningPoint ;
  rdfs:label """Relative complex sentences are useful for adding details about nouns within a
  setting."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274646Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28400-1
  a curric:KeyLearningPoint ;
  rdfs:label """Characterisation is the way an author & illustrator describe & develop the
  personalities & traits of the characters."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274688Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28400-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Role on the wall' is a reading activity that helps readers develop their
  understanding of a character."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274691Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28400-3
  a curric:KeyLearningPoint ;
  rdfs:label """“The Beast” refers to Nate’s internal struggle with anger and frustration, which he
  can sometimes struggle to control."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274695Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28400-4
  a curric:KeyLearningPoint ;
  rdfs:label """Characters can change and develop throughout a narrative and traits they show do not
  always remain fixed."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274701Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7850-1
  a curric:KeyLearningPoint ;
  rdfs:label """Character traits can be explored through the text’s illustrations or words used by
  the characters."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274750Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7850-2
  a curric:KeyLearningPoint ;
  rdfs:label "Different readers may interpret a text in different ways."@en ;
  dcterms:modified "2026-06-07T15:30:29.274753Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7850-3
  a curric:KeyLearningPoint ;
  rdfs:label """Discussing books by building on others and our own views can help us to deepen our
  understanding of a text."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274757Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7850-4
  a curric:KeyLearningPoint ;
  rdfs:label """Making links to other characters and stories helps to deepen our awareness
  of texts."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274761Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6752-1
  a curric:KeyLearningPoint ;
  rdfs:label "Writing is most successful when structure, content and vocabulary are planned."@en ;
  dcterms:modified "2026-06-07T15:30:29.274851Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6752-2
  a curric:KeyLearningPoint ;
  rdfs:label "Our climax should have a tense, fast-paced mood."@en ;
  dcterms:modified "2026-06-07T15:30:29.274855Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6752-3
  a curric:KeyLearningPoint ;
  rdfs:label """We combine descriptive details and emotive details to paint a clear picture for the
  reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274859Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6752-4
  a curric:KeyLearningPoint ;
  rdfs:label """We can use a range of linguistic techniques and cohesive devices for increasing the
  pace."""@en ;
  dcterms:modified "2026-06-07T15:30:29.274863Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6752-5
  a curric:KeyLearningPoint ;
  rdfs:label "We use precise vocabulary to add to the impression of speed."@en ;
  dcterms:modified "2026-06-07T15:30:29.274867Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7863-1
  a curric:KeyLearningPoint ;
  rdfs:label "A Greek myth is a traditional story that originates from ancient Greece"@en ;
  dcterms:modified "2026-06-07T15:30:29.276288Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7863-2
  a curric:KeyLearningPoint ;
  rdfs:label "Myths feature gods, godesses and various mythical creatures"@en ;
  dcterms:modified "2026-06-07T15:30:29.276291Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7863-3
  a curric:KeyLearningPoint ;
  rdfs:label "A traditional myth explains a culture's beliefs and customs"@en ;
  dcterms:modified "2026-06-07T15:30:29.276295Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7863-4
  a curric:KeyLearningPoint ;
  rdfs:label "Myths share several common features and themes"@en ;
  dcterms:modified "2026-06-07T15:30:29.276299Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6743-1
  a curric:KeyLearningPoint ;
  rdfs:label "Writing is most successful when it is planned."@en ;
  dcterms:modified "2026-06-07T15:30:29.276343Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6743-2
  a curric:KeyLearningPoint ;
  rdfs:label "Vocabulary can be generated to precisely match the emotions of a character."@en ;
  dcterms:modified "2026-06-07T15:30:29.276346Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6743-3
  a curric:KeyLearningPoint ;
  rdfs:label "Thinking hard about vocabulary makes writing outcomes more powerful."@en ;
  dcterms:modified "2026-06-07T15:30:29.276352Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6743-4
  a curric:KeyLearningPoint ;
  rdfs:label """Vocabulary choices can be made to highlight the emotions of a character to the
  reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.276356Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6743-5
  a curric:KeyLearningPoint ;
  rdfs:label """Precision in describing a character's emotions means getting inside the character's
  head."""@en ;
  dcterms:modified "2026-06-07T15:30:29.276360Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6739-1
  a curric:KeyLearningPoint ;
  rdfs:label """We are writing about an event from the build-up, using a third person
  perspective."""@en ;
  dcterms:modified "2026-06-07T15:30:29.276364Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6739-2
  a curric:KeyLearningPoint ;
  rdfs:label """We are then using internal monologue to reflect on the same event from Addie's
  perspective."""@en ;
  dcterms:modified "2026-06-07T15:30:29.276367Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6739-3
  a curric:KeyLearningPoint ;
  rdfs:label "Using a plan and orally rehearsing our writing helps us to do our best writing."@en ;
  dcterms:modified "2026-06-07T15:30:29.276371Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6739-4
  a curric:KeyLearningPoint ;
  rdfs:label """We should aim to use a complete range of sentence types and language features in our
  writing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.276375Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4825-1
  a curric:KeyLearningPoint ;
  rdfs:label "Pen and pencil are the most common tools used to write or draw with."@en ;
  dcterms:modified "2026-06-07T15:30:29.276380Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4825-2
  a curric:KeyLearningPoint ;
  rdfs:label """Making a choice between pen and pencil depends on the task and the desired
  outcome."""@en ;
  dcterms:modified "2026-06-07T15:30:29.276384Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4825-3
  a curric:KeyLearningPoint ;
  rdfs:label """Using a pencil allows for mistakes to be corrected easily with an eraser, which is
  ideal for sketching and drafting."""@en ;
  dcterms:modified "2026-06-07T15:30:29.276390Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4825-4
  a curric:KeyLearningPoint ;
  rdfs:label """Using a pen is ideal for final drafts as pen is permanent and looks neat and
  professional."""@en ;
  dcterms:modified "2026-06-07T15:30:29.276394Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4825-5
  a curric:KeyLearningPoint ;
  rdfs:label "Over time you will develop a personal preference for using pen or pencil."@en ;
  dcterms:modified "2026-06-07T15:30:29.276398Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4801-1
  a curric:KeyLearningPoint ;
  rdfs:label "The letters all have a lead in and a lead out."@en ;
  dcterms:modified "2026-06-07T15:30:29.276424Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4801-2
  a curric:KeyLearningPoint ;
  rdfs:label """The second join goes from the baseline to above the x-height line towards the
  ascender line."""@en ;
  dcterms:modified "2026-06-07T15:30:29.276429Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4801-3
  a curric:KeyLearningPoint ;
  rdfs:label """The pencil only lifts to add the dot to the i and the cross to the t once the letter
  string is complete."""@en ;
  dcterms:modified "2026-06-07T15:30:29.276434Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4801-4
  a curric:KeyLearningPoint ;
  rdfs:label """When forming the letter f it has two loops; one at the top of the lead in and one at
  the bottom ready for the lead out."""@en ;
  dcterms:modified "2026-06-07T15:30:29.276437Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4801-5
  a curric:KeyLearningPoint ;
  rdfs:label """When joining to the letter t, the join goes up to between the x-height line and the
  ascender line."""@en ;
  dcterms:modified "2026-06-07T15:30:29.276441Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1343-1
  a curric:KeyLearningPoint ;
  rdfs:label "The 'ou' spelling can make the sounds 'or', 'u', 'ow' and 'oo'."@en ;
  dcterms:modified "2026-06-07T15:30:29.276445Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1343-2
  a curric:KeyLearningPoint ;
  rdfs:label "The 'ear' spelling can make the sounds 'ear', 'air', 'ar' and 'er'."@en ;
  dcterms:modified "2026-06-07T15:30:29.276448Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1343-3
  a curric:KeyLearningPoint ;
  rdfs:label "The 'ice' spelling can make the sounds 'ice' and 'iss'."@en ;
  dcterms:modified "2026-06-07T15:30:29.276454Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1343-4
  a curric:KeyLearningPoint ;
  rdfs:label """When you hear one of these sounds, the word might contain the 'ou', 'ear' or 'ice'
  spelling."""@en ;
  dcterms:modified "2026-06-07T15:30:29.276458Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1343-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: forty, rhythm and criticise."@en ;
  dcterms:modified "2026-06-07T15:30:29.276462Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1411-1
  a curric:KeyLearningPoint ;
  rdfs:label "The suffix -al often turns nouns into adjectives."@en ;
  dcterms:modified "2026-06-07T15:30:29.276488Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1411-2
  a curric:KeyLearningPoint ;
  rdfs:label "When the root word ends in a consonant, just add the suffix."@en ;
  dcterms:modified "2026-06-07T15:30:29.276491Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1411-3
  a curric:KeyLearningPoint ;
  rdfs:label "When the root word ends in ‘e’, remove the ‘e’ and add the suffix."@en ;
  dcterms:modified "2026-06-07T15:30:29.276495Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1411-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: disappear, perhaps and experience."@en ;
  dcterms:modified "2026-06-07T15:30:29.276499Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1383-1
  a curric:KeyLearningPoint ;
  rdfs:label """Near-homophones are words that sound similar to each other but have slightly
  different spellings and different meanings."""@en ;
  dcterms:modified "2026-06-07T15:30:29.276561Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1383-2
  a curric:KeyLearningPoint ;
  rdfs:label """The way that a word is spelt and its place within a sentence will generally tell us
  its meaning."""@en ;
  dcterms:modified "2026-06-07T15:30:29.276565Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1383-3
  a curric:KeyLearningPoint ;
  rdfs:label "There are no spelling rules for homophones so we must learn them by sight."@en ;
  dcterms:modified "2026-06-07T15:30:29.276569Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1383-4
  a curric:KeyLearningPoint ;
  rdfs:label """How to spell the curriculum words: peculiar, particular, medicine and
  aggressive."""@en ;
  dcterms:modified "2026-06-07T15:30:29.276572Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8081-1
  a curric:KeyLearningPoint ;
  rdfs:label "'London' was published in 1794."@en ;
  dcterms:modified "2026-06-07T15:30:29.276622Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8081-2
  a curric:KeyLearningPoint ;
  rdfs:label """William Blake was an English poet and artist who believed in social and racial
  equality."""@en ;
  dcterms:modified "2026-06-07T15:30:29.276625Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8081-3
  a curric:KeyLearningPoint ;
  rdfs:label "In the poem, the narrator is describing a walk around the city of London."@en ;
  dcterms:modified "2026-06-07T15:30:29.276629Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8081-4
  a curric:KeyLearningPoint ;
  rdfs:label "Romanticism was a movement in art and literature."@en ;
  dcterms:modified "2026-06-07T15:30:29.276633Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8081-5
  a curric:KeyLearningPoint ;
  rdfs:label """Romantic poets were often critical of industrialisation and valued the simplicity
  and purity of rural life."""@en ;
  dcterms:modified "2026-06-07T15:30:29.276637Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7881-1
  a curric:KeyLearningPoint ;
  rdfs:label """On 2nd July 1928, all British women finally succeeded in achieving the right to
  vote."""@en ;
  dcterms:modified "2026-06-07T15:30:29.276641Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7881-2
  a curric:KeyLearningPoint ;
  rdfs:label "Inequality is a significant theme of the text."@en ;
  dcterms:modified "2026-06-07T15:30:29.276647Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7881-3
  a curric:KeyLearningPoint ;
  rdfs:label """Inequality is shown not only in the suffragette movement but also the experiences of
  the Duleep Singh sisters."""@en ;
  dcterms:modified "2026-06-07T15:30:29.276651Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7881-4
  a curric:KeyLearningPoint ;
  rdfs:label """Suffragettes employed various tactics, strategies and approaches to draw attention
  to their cause."""@en ;
  dcterms:modified "2026-06-07T15:30:29.276654Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7881-5
  a curric:KeyLearningPoint ;
  rdfs:label """Princess Sophia Duleep Singh’s legacy includes her efforts in charity work, medicine
  and political reform."""@en ;
  dcterms:modified "2026-06-07T15:30:29.276658Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2713-1
  a curric:KeyLearningPoint ;
  rdfs:label "Words can be related to each other by meaning."@en ;
  dcterms:modified "2026-06-07T15:30:29.276719Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2713-2
  a curric:KeyLearningPoint ;
  rdfs:label "Synonyms can be used by writers to vary vocabulary choice and create text flow."@en ;
  dcterms:modified "2026-06-07T15:30:29.276722Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2713-3
  a curric:KeyLearningPoint ;
  rdfs:label "Antonyms can be used by writers to create a certain effect for the reader."@en ;
  dcterms:modified "2026-06-07T15:30:29.276726Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2713-4
  a curric:KeyLearningPoint ;
  rdfs:label """Word families are groups of words that have common features, patterns or
  meanings."""@en ;
  dcterms:modified "2026-06-07T15:30:29.276730Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2713-5
  a curric:KeyLearningPoint ;
  rdfs:label "All words have etymology."@en ;
  dcterms:modified "2026-06-07T15:30:29.276733Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5845-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of an editing lesson is to improve writing and make necessary
  corrections."""@en ;
  dcterms:modified "2026-06-07T15:30:29.276737Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5845-2
  a curric:KeyLearningPoint ;
  rdfs:label """Vocabulary, grammar and punctuation can be changed to make writing more
  effective."""@en ;
  dcterms:modified "2026-06-07T15:30:29.276743Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5845-3
  a curric:KeyLearningPoint ;
  rdfs:label "We edit to ensure that our use of tense is consistent and correct."@en ;
  dcterms:modified "2026-06-07T15:30:29.276747Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1038-1
  a curric:KeyLearningPoint ;
  rdfs:label "A simple sentence is a sentence about one idea that makes complete sense."@en ;
  dcterms:modified "2026-06-07T15:30:29.276751Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1038-2
  a curric:KeyLearningPoint ;
  rdfs:label """There are four types of simple sentence: statements, questions, commands and
  exclamations."""@en ;
  dcterms:modified "2026-06-07T15:30:29.276755Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1038-3
  a curric:KeyLearningPoint ;
  rdfs:label "Any type of simple sentence must contain a verb."@en ;
  dcterms:modified "2026-06-07T15:30:29.276758Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1038-4
  a curric:KeyLearningPoint ;
  rdfs:label """A group of words that contains a verb and makes complete sense is called a main
  clause."""@en ;
  dcterms:modified "2026-06-07T15:30:29.276764Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1038-5
  a curric:KeyLearningPoint ;
  rdfs:label "A simple sentence is formed of one main clause."@en ;
  dcterms:modified "2026-06-07T15:30:29.276768Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8463-1
  a curric:KeyLearningPoint ;
  rdfs:label "‘The BFG’ is a fiction text that was published in 1982."@en ;
  dcterms:modified "2026-06-07T15:30:29.276772Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8463-2
  a curric:KeyLearningPoint ;
  rdfs:label """‘The BFG’ was written by Roald Dahl (1916-1990) and he is a famous children’s
  author."""@en ;
  dcterms:modified "2026-06-07T15:30:29.276778Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8463-3
  a curric:KeyLearningPoint ;
  rdfs:label "The protagonists in ‘The BFG’ are Sophie, a young orphan, and the BFG."@en ;
  dcterms:modified "2026-06-07T15:30:29.276782Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8463-4
  a curric:KeyLearningPoint ;
  rdfs:label "The main settings of ‘The BFG’ are the orphanage, Giant World and Dream World."@en ;
  dcterms:modified "2026-06-07T15:30:29.276786Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8463-5
  a curric:KeyLearningPoint ;
  rdfs:label """Summarising the key events in a story helps us to build our understanding of the
  text and the meaning behind it."""@en ;
  dcterms:modified "2026-06-07T15:30:29.276790Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6144-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of a narrative opening is to introduce the characters and to describe
  the setting to the reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.276809Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6144-2
  a curric:KeyLearningPoint ;
  rdfs:label "Saying sentences aloud before they are written helps to check for sense."@en ;
  dcterms:modified "2026-06-07T15:30:29.276813Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6144-3
  a curric:KeyLearningPoint ;
  rdfs:label """Using the full range of sentence types (simple, compound and complex) improves text
  flow for the reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.276819Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6144-4
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials of time, place and manner add extra detail to the main
  clause."""@en ;
  dcterms:modified "2026-06-07T15:30:29.276823Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6144-5
  a curric:KeyLearningPoint ;
  rdfs:label "This narrative version of ‘The BFG’ is written in the past tense."@en ;
  dcterms:modified "2026-06-07T15:30:29.276827Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5997-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of a persuasive letter is to try to convince someone to do something or
  to change their mind or behaviour."""@en ;
  dcterms:modified "2026-06-07T15:30:29.277312Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5997-2
  a curric:KeyLearningPoint ;
  rdfs:label """Letters written from a character's point of view are written in the first
  person."""@en ;
  dcterms:modified "2026-06-07T15:30:29.277316Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5997-3
  a curric:KeyLearningPoint ;
  rdfs:label """A persuasive letter has a specific layout: a salutation, two paragraphs and a
  sign-off."""@en ;
  dcterms:modified "2026-06-07T15:30:29.277320Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5997-4
  a curric:KeyLearningPoint ;
  rdfs:label """Persuasive letters have distinctive linguistic features in order to achieve their
  purpose."""@en ;
  dcterms:modified "2026-06-07T15:30:29.277324Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5997-5
  a curric:KeyLearningPoint ;
  rdfs:label """A range of persuasive techniques can be used to increase the pressure on the reader
  to act."""@en ;
  dcterms:modified "2026-06-07T15:30:29.277328Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8878-1
  a curric:KeyLearningPoint ;
  rdfs:label """In Chapter 3 of ‘The Iron Man’, Hogarth persuades the farmers to respond differently
  to the Iron Man."""@en ;
  dcterms:modified "2026-06-07T15:30:29.277367Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8878-2
  a curric:KeyLearningPoint ;
  rdfs:label "Hogarth identifies the Iron Man’s needs and comes up with a solution."@en ;
  dcterms:modified "2026-06-07T15:30:29.277371Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8878-3
  a curric:KeyLearningPoint ;
  rdfs:label """Characterisation is the way an author describes and develops the personalities and
  traits of characters in the story."""@en ;
  dcterms:modified "2026-06-07T15:30:29.277375Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8878-4
  a curric:KeyLearningPoint ;
  rdfs:label """We can identify Hogarth’s character traits by exploring his experiences and
  interactions and making inferences."""@en ;
  dcterms:modified "2026-06-07T15:30:29.277378Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8878-5
  a curric:KeyLearningPoint ;
  rdfs:label """Hogarth displays a range of character traits such as being compassionate and
  resourceful."""@en ;
  dcterms:modified "2026-06-07T15:30:29.277382Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2723-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the opening is to engage the reader and introduce the setting and
  characters."""@en ;
  dcterms:modified "2026-06-07T15:30:29.277386Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2723-2
  a curric:KeyLearningPoint ;
  rdfs:label """Using a range of sentence types (simple, compound and complex) improves text flow
  for the reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.277389Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2723-3
  a curric:KeyLearningPoint ;
  rdfs:label """Direct speech is punctuated using inverted commas; dialogue moves the action
  forward."""@en ;
  dcterms:modified "2026-06-07T15:30:29.277395Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2723-4
  a curric:KeyLearningPoint ;
  rdfs:label "Notes from the plan can be used to form full sentences."@en ;
  dcterms:modified "2026-06-07T15:30:29.277399Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2723-5
  a curric:KeyLearningPoint ;
  rdfs:label "A new paragraph is used to signal the start of a new idea or key moment."@en ;
  dcterms:modified "2026-06-07T15:30:29.277403Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6761-1
  a curric:KeyLearningPoint ;
  rdfs:label "Writing is most successful when it is planned."@en ;
  dcterms:modified "2026-06-07T15:30:29.278790Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6761-2
  a curric:KeyLearningPoint ;
  rdfs:label "Understanding the essay title is critical to a successful essay answer."@en ;
  dcterms:modified "2026-06-07T15:30:29.278794Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6761-3
  a curric:KeyLearningPoint ;
  rdfs:label """An essay can use a bank of research, evidence and statistics to inform the
  reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.278797Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6761-4
  a curric:KeyLearningPoint ;
  rdfs:label "A structure that supports the line of argument must be logical."@en ;
  dcterms:modified "2026-06-07T15:30:29.278803Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6725-1
  a curric:KeyLearningPoint ;
  rdfs:label """We are going to be writing a narrative retelling of most of the story of 'Beowulf
  and the dragon'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.278807Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6725-2
  a curric:KeyLearningPoint ;
  rdfs:label "We will be covering the build-up, climax and resolution of this mini-story."@en ;
  dcterms:modified "2026-06-07T15:30:29.278811Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6725-3
  a curric:KeyLearningPoint ;
  rdfs:label """To be ready to write, we need to know the events really well. To do this, we can
  create a text map."""@en ;
  dcterms:modified "2026-06-07T15:30:29.278815Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6725-4
  a curric:KeyLearningPoint ;
  rdfs:label "We can use the text map to rehearse saying the events we will cover."@en ;
  dcterms:modified "2026-06-07T15:30:29.278818Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6725-5
  a curric:KeyLearningPoint ;
  rdfs:label """We can also use it for storytelling - saying the events out loud as if telling a
  story."""@en ;
  dcterms:modified "2026-06-07T15:30:29.278824Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27628-1
  a curric:KeyLearningPoint ;
  rdfs:label "Self-reflection is an important tool to use for improving."@en ;
  dcterms:modified "2026-06-07T15:30:29.278828Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27628-2
  a curric:KeyLearningPoint ;
  rdfs:label """The winning team in a debate can be decided by an audience vote, or a judge, or a
  panel of judges."""@en ;
  dcterms:modified "2026-06-07T15:30:29.278834Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27628-3
  a curric:KeyLearningPoint ;
  rdfs:label """The judges award a score out of ten in four different areas: content, style,
  delivery and points of information."""@en ;
  dcterms:modified "2026-06-07T15:30:29.278838Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1335-1
  a curric:KeyLearningPoint ;
  rdfs:label "The suffix -al is the second most common spelling for the 'l' sound."@en ;
  dcterms:modified "2026-06-07T15:30:29.278860Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1335-2
  a curric:KeyLearningPoint ;
  rdfs:label """If the root word makes sense by itself, it is often likely to have the
  suffix -al."""@en ;
  dcterms:modified "2026-06-07T15:30:29.278864Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1335-3
  a curric:KeyLearningPoint ;
  rdfs:label """The suffix -al often turns nouns into adjectives and often follows the letters 'on'
  and 'ic'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.278868Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1335-4
  a curric:KeyLearningPoint ;
  rdfs:label "When the root word ends in ‘e’, remove the ‘e’ and add the suffix."@en ;
  dcterms:modified "2026-06-07T15:30:29.278872Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1335-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: correspond and persuade."@en ;
  dcterms:modified "2026-06-07T15:30:29.278876Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1330-1
  a curric:KeyLearningPoint ;
  rdfs:label "If the root word ends in 'y', remove the 'y' and add -ier."@en ;
  dcterms:modified "2026-06-07T15:30:29.278880Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1330-2
  a curric:KeyLearningPoint ;
  rdfs:label "If the root word ends in 'e', remove the 'e' and add -er."@en ;
  dcterms:modified "2026-06-07T15:30:29.278883Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1330-3
  a curric:KeyLearningPoint ;
  rdfs:label "If the root word contains a short vowel sound, double the consonant and add -er."@en ;
  dcterms:modified "2026-06-07T15:30:29.278887Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1330-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Good' is irregular as it does not follow the same pattern. Instead we have good,
  better and best."""@en ;
  dcterms:modified "2026-06-07T15:30:29.278891Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1330-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: necessary and average."@en ;
  dcterms:modified "2026-06-07T15:30:29.278894Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3464-1
  a curric:KeyLearningPoint ;
  rdfs:label """An explanation text is a non-fiction text that explains a particular process or
  subject in detail."""@en ;
  dcterms:modified "2026-06-07T15:30:29.278937Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3464-2
  a curric:KeyLearningPoint ;
  rdfs:label """An explanation text can start with an introduction and then explains a sequenced
  process in chronological order."""@en ;
  dcterms:modified "2026-06-07T15:30:29.278941Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3464-3
  a curric:KeyLearningPoint ;
  rdfs:label """Vocabulary within an explanation text is subject-specific and factual, creating a
  formal tone."""@en ;
  dcterms:modified "2026-06-07T15:30:29.278944Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3464-4
  a curric:KeyLearningPoint ;
  rdfs:label """Formal fronted adverbials, ordering fronted adverbials and fronted adverbials of
  cause are used to enhance text flow."""@en ;
  dcterms:modified "2026-06-07T15:30:29.278948Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3464-5
  a curric:KeyLearningPoint ;
  rdfs:label "Explanation texts are written in the present tense."@en ;
  dcterms:modified "2026-06-07T15:30:29.278952Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3465-1
  a curric:KeyLearningPoint ;
  rdfs:label "Honey making is a complex, natural process which takes a very long time."@en ;
  dcterms:modified "2026-06-07T15:30:29.278955Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3465-2
  a curric:KeyLearningPoint ;
  rdfs:label "Bees visit thousands of colourful flowers to collect nectar with their tongue."@en ;
  dcterms:modified "2026-06-07T15:30:29.278959Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3465-3
  a curric:KeyLearningPoint ;
  rdfs:label """The nectar travels to the honey stomach where the enzymes break it down into smaller
  molecules."""@en ;
  dcterms:modified "2026-06-07T15:30:29.278963Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3465-4
  a curric:KeyLearningPoint ;
  rdfs:label """The bees transfer the nectar into the honeycomb cells and flap their wings to
  evaporate the water from the nectar."""@en ;
  dcterms:modified "2026-06-07T15:30:29.278966Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3465-5
  a curric:KeyLearningPoint ;
  rdfs:label "Bees seal the cells with a wax lid. The honey cannot leak or expire."@en ;
  dcterms:modified "2026-06-07T15:30:29.278970Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1345-1
  a curric:KeyLearningPoint ;
  rdfs:label """The 'ee' sound spelt 'ei' generally comes after the letter 'c' (deceive) or at the
  beginning of a word (either)"""@en ;
  dcterms:modified "2026-06-07T15:30:29.278974Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1345-2
  a curric:KeyLearningPoint ;
  rdfs:label """Exceptions include: protein, caffeine, seize, weird, foreign as well as either and
  neither if pronounced as such."""@en ;
  dcterms:modified "2026-06-07T15:30:29.278978Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1345-3
  a curric:KeyLearningPoint ;
  rdfs:label "The 'ei' spelling can also make a long 'ay' sound and break other learnt rules."@en ;
  dcterms:modified "2026-06-07T15:30:29.278985Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1345-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: neighbour and soldier."@en ;
  dcterms:modified "2026-06-07T15:30:29.278989Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8175-1
  a curric:KeyLearningPoint ;
  rdfs:label "A letter is a piece of writing that someone sends to someone else."@en ;
  dcterms:modified "2026-06-07T15:30:29.279029Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8175-2
  a curric:KeyLearningPoint ;
  rdfs:label """First person perspective is the point of view where the speaker is the 'I'
  character."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279033Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8175-3
  a curric:KeyLearningPoint ;
  rdfs:label "A compliment means to say something nice to someone else."@en ;
  dcterms:modified "2026-06-07T15:30:29.279036Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8175-4
  a curric:KeyLearningPoint ;
  rdfs:label "The layout of a text refers to the way the information is organised on the page."@en ;
  dcterms:modified "2026-06-07T15:30:29.279040Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8057-1
  a curric:KeyLearningPoint ;
  rdfs:label "‘The Invaders’ and ‘Kingfisher’ are two poems based on a similar theme: birds."@en ;
  dcterms:modified "2026-06-07T15:30:29.279067Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8057-2
  a curric:KeyLearningPoint ;
  rdfs:label """Both poems are written in free verse, they do not adhere to a specific rhyme scheme
  or meter."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279070Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8057-3
  a curric:KeyLearningPoint ;
  rdfs:label """‘The Invaders’ describes the competition between two rival species, the sparrows and
  starlings."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279074Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8057-4
  a curric:KeyLearningPoint ;
  rdfs:label """‘Kingfisher’ describes the story of a kingfisher who successfully hunts for its
  food."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279078Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8057-5
  a curric:KeyLearningPoint ;
  rdfs:label "Both poems use imagery to convey an atmosphere to the reader or listener."@en ;
  dcterms:modified "2026-06-07T15:30:29.279082Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8019-1
  a curric:KeyLearningPoint ;
  rdfs:label """'Ozymandias' is a sonnet by Percy Bysshe Shelley that describes a ruined statue of a
  once-powerful king."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279086Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8019-2
  a curric:KeyLearningPoint ;
  rdfs:label "This poem explores the themes of life and death and the passing of time."@en ;
  dcterms:modified "2026-06-07T15:30:29.279090Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8019-3
  a curric:KeyLearningPoint ;
  rdfs:label """A sonnet is a form of poetry with fourteen lines, which usually follows a rhyme
  scheme."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279093Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8019-4
  a curric:KeyLearningPoint ;
  rdfs:label "Percy Bysshe Shelley is one of Britain’s most famous poets."@en ;
  dcterms:modified "2026-06-07T15:30:29.279097Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7880-1
  a curric:KeyLearningPoint ;
  rdfs:label """Suffragettes were campaigning for the right for women to vote; this was something
  that was not permitted at the time."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279154Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7880-2
  a curric:KeyLearningPoint ;
  rdfs:label """Emmeline Pankhurst is the leader of the WSPU (the Women’s Social and Political
  Union)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279158Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7880-3
  a curric:KeyLearningPoint ;
  rdfs:label "Reading between the lines to search for clues can help to infer meaning."@en ;
  dcterms:modified "2026-06-07T15:30:29.279162Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7880-4
  a curric:KeyLearningPoint ;
  rdfs:label "Evidence from the text helps us to justify our inferences."@en ;
  dcterms:modified "2026-06-07T15:30:29.279166Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6013-1
  a curric:KeyLearningPoint ;
  rdfs:label """Editing is the process of improving writing to ensure text flow and overall
  quality."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279172Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6013-2
  a curric:KeyLearningPoint ;
  rdfs:label """Editing involves making improvements to a piece of writing without completely
  rewriting it."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279176Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6013-3
  a curric:KeyLearningPoint ;
  rdfs:label "Editing is a vital part of the writing process."@en ;
  dcterms:modified "2026-06-07T15:30:29.279180Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1043-1
  a curric:KeyLearningPoint ;
  rdfs:label """The position of an adverbial subordinate clause can move in an adverbial complex
  sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279183Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1043-2
  a curric:KeyLearningPoint ;
  rdfs:label """If the adverbial clause comes first in the sentence, it is followed by a comma to
  demarcate from the main clause."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279187Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1043-3
  a curric:KeyLearningPoint ;
  rdfs:label "If the main clause comes first in the sentence, there is no comma used."@en ;
  dcterms:modified "2026-06-07T15:30:29.279192Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1043-4
  a curric:KeyLearningPoint ;
  rdfs:label "A comma is a punctuation mark that has more than one purpose."@en ;
  dcterms:modified "2026-06-07T15:30:29.279196Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1043-5
  a curric:KeyLearningPoint ;
  rdfs:label """Commas often help the reader see clause demarcation in a range of sentence
  types."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279202Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4709-1
  a curric:KeyLearningPoint ;
  rdfs:label "A speech should have a clear purpose."@en ;
  dcterms:modified "2026-06-07T15:30:29.279206Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4709-2
  a curric:KeyLearningPoint ;
  rdfs:label "A speech may use techniques such as rhetorical questions or repetition."@en ;
  dcterms:modified "2026-06-07T15:30:29.279210Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1423-1
  a curric:KeyLearningPoint ;
  rdfs:label """Words that are pronounced the same but have different spellings and meanings are
  called homophones."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279214Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1423-2
  a curric:KeyLearningPoint ;
  rdfs:label "Unlike other words we have investigated, there are no patterns for homophones."@en ;
  dcterms:modified "2026-06-07T15:30:29.279218Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1423-3
  a curric:KeyLearningPoint ;
  rdfs:label """The way a word is spelt and its place within a sentence will tell us its
  meaning."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279222Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1423-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: ordinary, grammar and women."@en ;
  dcterms:modified "2026-06-07T15:30:29.279257Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4893-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the introduction is to engage the reader and give them general
  information about the report's subject."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279262Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4893-2
  a curric:KeyLearningPoint ;
  rdfs:label "Aye-ayes can be referred to in the singular or plural throughout a report."@en ;
  dcterms:modified "2026-06-07T15:30:29.279266Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4893-3
  a curric:KeyLearningPoint ;
  rdfs:label """Writers plan and say each sentence aloud before writing it down so that they write
  more coherent sentences."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279270Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4893-4
  a curric:KeyLearningPoint ;
  rdfs:label """The writing process involves planning, drafting, checking, editing and publishing a
  piece of writing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279276Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6147-1
  a curric:KeyLearningPoint ;
  rdfs:label "The purpose of the build-up is to build up suspense and excitement."@en ;
  dcterms:modified "2026-06-07T15:30:29.279292Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6147-2
  a curric:KeyLearningPoint ;
  rdfs:label "Precise and ambitious vocabulary is logged on a plan for future use."@en ;
  dcterms:modified "2026-06-07T15:30:29.279295Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6147-3
  a curric:KeyLearningPoint ;
  rdfs:label """Notes should not be written in full sentences and bullet points can be used to make
  notes clear."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279299Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6147-4
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials of time, place and manner indicate when, where and how action
  takes place."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279303Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6147-5
  a curric:KeyLearningPoint ;
  rdfs:label """Show-not-tell language shows a character’s feelings by describing their actions,
  body language and facial expressions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279308Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2716-1
  a curric:KeyLearningPoint ;
  rdfs:label """An introduction's purpose is to give general facts about the topic and to tell the
  reader what they will learn."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279361Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2716-2
  a curric:KeyLearningPoint ;
  rdfs:label """Digestion is the process of breaking down food into particles small enough to be
  absorbed into the bloodstream."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279365Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2716-3
  a curric:KeyLearningPoint ;
  rdfs:label """The scientific definition of digestion, and the use of scientific vocabulary, are
  essential for introducing the subject."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279369Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2716-4
  a curric:KeyLearningPoint ;
  rdfs:label """The relative pronoun \"which\" can be used to embed a relative clause within a main
  clause to add detail."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279373Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2716-5
  a curric:KeyLearningPoint ;
  rdfs:label """A relative complex sentence is formed of a main clause and a relative subordinate
  clause."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279377Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6523-1
  a curric:KeyLearningPoint ;
  rdfs:label "The conclusion is the final paragraph of a non-fiction text."@en ;
  dcterms:modified "2026-06-07T15:30:29.279382Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6523-2
  a curric:KeyLearningPoint ;
  rdfs:label "Information in the conclusion should be kept general."@en ;
  dcterms:modified "2026-06-07T15:30:29.279386Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6523-3
  a curric:KeyLearningPoint ;
  rdfs:label """Plans should be used to document key, concise ideas. They can be built upon when
  writing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279390Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6523-4
  a curric:KeyLearningPoint ;
  rdfs:label "When writing, we should use our success criteria and plan to guide us."@en ;
  dcterms:modified "2026-06-07T15:30:29.279394Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6523-5
  a curric:KeyLearningPoint ;
  rdfs:label """Using a range of cohesive devices enhances text flow and helps achieve the text
  purpose."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279398Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1064-1
  a curric:KeyLearningPoint ;
  rdfs:label """Notes should be written in note form and bullet points can be used to order
  notes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279416Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1064-2
  a curric:KeyLearningPoint ;
  rdfs:label """Viewpoint fronted adverbials and formal fronted adverbials are used at the start of
  sentences for cohesion."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279420Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1064-3
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the houses paragraph is to show how housing of the Mesolithic period
  differed to that of the Neolithic."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279424Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1064-4
  a curric:KeyLearningPoint ;
  rdfs:label """Mesolithic people were nomadic: they carried their homes with them as they
  moved."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279427Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1064-5
  a curric:KeyLearningPoint ;
  rdfs:label "Neolithic people began settling in small communties in houses built of stone."@en ;
  dcterms:modified "2026-06-07T15:30:29.279431Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7636-1
  a curric:KeyLearningPoint ;
  rdfs:label """Sentences should be said aloud before writing to ensure they make sense and read
  back once written to check for errors."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279435Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7636-2
  a curric:KeyLearningPoint ;
  rdfs:label """Ambitious vocabulary and figurative language create a vivid picture in the reader's
  mind."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279439Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7636-3
  a curric:KeyLearningPoint ;
  rdfs:label """Writers choose varied fronted adverbials and different sentence types to ensure the
  text flows for the reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279442Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7636-4
  a curric:KeyLearningPoint ;
  rdfs:label """Careful selection of nouns and pronouns ensures cohesion within sentences and across
  sections of a written piece."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279446Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7636-5
  a curric:KeyLearningPoint ;
  rdfs:label """Past simple, progressive and perfect verb forms can be used to improve text
  cohesion."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279452Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7661-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of a narrative opening is to introduce the characters and to describe
  the setting to the reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279456Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7661-2
  a curric:KeyLearningPoint ;
  rdfs:label """Using a range of sentence types (simple, compound and complex) improves text flow
  for the reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279459Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7661-3
  a curric:KeyLearningPoint ;
  rdfs:label """A fronted adverbial of time, place or manner adds extra detail to the main clause
  that follows it."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279463Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7661-4
  a curric:KeyLearningPoint ;
  rdfs:label "This narrative version of ‘Whale Rider’ is written in the past tense."@en ;
  dcterms:modified "2026-06-07T15:30:29.279467Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7661-5
  a curric:KeyLearningPoint ;
  rdfs:label """Oral rehearsal before writing helps to structure grammatically correct sentences and
  check for sense."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279470Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7921-1
  a curric:KeyLearningPoint ;
  rdfs:label """In the book, Joseph has had very negative experiences of schooling which cause him
  to be anxious about attending."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279474Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7921-2
  a curric:KeyLearningPoint ;
  rdfs:label "When we read, we often think about characters' motives."@en ;
  dcterms:modified "2026-06-07T15:30:29.279480Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7921-3
  a curric:KeyLearningPoint ;
  rdfs:label """We base our understanding of motives partly on what is made explicit by the
  author."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279484Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7921-4
  a curric:KeyLearningPoint ;
  rdfs:label """We may also infer motives based on the characters' actions, our own knowledge and
  our experiences."""@en ;
  dcterms:modified "2026-06-07T15:30:29.279487Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7355-1
  a curric:KeyLearningPoint ;
  rdfs:label """The climax takes the suspense to its highest point as Scrooge encounters the Ghost
  of Christmas Yet to Come."""@en ;
  dcterms:modified "2026-06-07T15:30:29.280986Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7355-2
  a curric:KeyLearningPoint ;
  rdfs:label """The climax is written over two paragraphs and it is important to demonstrate
  cohesion across them."""@en ;
  dcterms:modified "2026-06-07T15:30:29.280990Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7355-3
  a curric:KeyLearningPoint ;
  rdfs:label """Cohesion refers to how a text flows in order to maintain the interest of the reader
  and achieve the purpose."""@en ;
  dcterms:modified "2026-06-07T15:30:29.280993Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7355-4
  a curric:KeyLearningPoint ;
  rdfs:label """Scrooge’s emotions increase in intensity across both paragraphs in the climax which
  supports cohesion."""@en ;
  dcterms:modified "2026-06-07T15:30:29.280997Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7355-5
  a curric:KeyLearningPoint ;
  rdfs:label """Oral rehearsal helps to structure grammatically correct full sentences and supports
  cohesion."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281001Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3401-1
  a curric:KeyLearningPoint ;
  rdfs:label """The plan includes keywords and subject-specific vocabulary related to the
  section."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281005Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3401-2
  a curric:KeyLearningPoint ;
  rdfs:label "Taking notes is a skill."@en ;
  dcterms:modified "2026-06-07T15:30:29.281008Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3401-3
  a curric:KeyLearningPoint ;
  rdfs:label """Notes should not be written in full sentences and bullet points can be used to order
  notes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281012Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3401-4
  a curric:KeyLearningPoint ;
  rdfs:label "Key vocabulary and linguistic devices should be logged in a plan."@en ;
  dcterms:modified "2026-06-07T15:30:29.281016Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3401-5
  a curric:KeyLearningPoint ;
  rdfs:label "The plan should be clearly structured in the order of the section."@en ;
  dcterms:modified "2026-06-07T15:30:29.281021Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4824-1
  a curric:KeyLearningPoint ;
  rdfs:label "Writing at speed is a valuable skill to develop."@en ;
  dcterms:modified "2026-06-07T15:30:29.281025Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4824-2
  a curric:KeyLearningPoint ;
  rdfs:label "Writing at speed can decrease the legibility and accuracy of your writing."@en ;
  dcterms:modified "2026-06-07T15:30:29.281029Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4824-3
  a curric:KeyLearningPoint ;
  rdfs:label "Your hand and wrist muscles can get tired when you are writing at speed."@en ;
  dcterms:modified "2026-06-07T15:30:29.281033Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4824-4
  a curric:KeyLearningPoint ;
  rdfs:label """Regular practice, hand exercises and taking breaks can help to improve the speed and
  accuracy of your handwriting."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281037Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4824-5
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to find a balance between speed, accuracy and legibility when
  writing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281042Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1118-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Colossal' is an adjective which means massive or gigantic."@en ;
  dcterms:modified "2026-06-07T15:30:29.281096Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1118-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Robust' is an adjective which means strong and tough."@en ;
  dcterms:modified "2026-06-07T15:30:29.281100Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1122-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Bloodshot' is an adjective which means red and sore."@en ;
  dcterms:modified "2026-06-07T15:30:29.281103Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1122-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Bulging' is an adjective which means swollen or sticking out."@en ;
  dcterms:modified "2026-06-07T15:30:29.281107Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1122-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Expressive' is an adjective which means meaningful or revealing."@en ;
  dcterms:modified "2026-06-07T15:30:29.281110Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7870-1
  a curric:KeyLearningPoint ;
  rdfs:label """The front cover of a text is part of the peritext; this also includes the blurb,
  endpapers and title page."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281114Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7870-2
  a curric:KeyLearningPoint ;
  rdfs:label """The peritext can give the readers clues and hints about what is contained in the
  story."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281120Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7870-3
  a curric:KeyLearningPoint ;
  rdfs:label """Levi Pinfold uses words and illustrations to show the events of the story and how
  the characters are feeling."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281124Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7870-4
  a curric:KeyLearningPoint ;
  rdfs:label """Readers can form personal reflections about texts by engaging with the words and
  illustrations in a meaningful way."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281127Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7870-5
  a curric:KeyLearningPoint ;
  rdfs:label """A prediction can be based on the words and illustrations in the text or a reader's
  own personal experience."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281131Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28385-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘Doing Nothing’ is a poem found in the poetry collection, ‘Dear Ugly Sisters’ by
  Laura Mucha."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281153Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28385-2
  a curric:KeyLearningPoint ;
  rdfs:label """The poem is about the practice of mindfulness and the rhythm varies in the poem to
  reflect the atmosphere."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281157Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28385-3
  a curric:KeyLearningPoint ;
  rdfs:label "‘Travel by Book’ is is a fixed verse poem, which follows the AAAB rhyme scheme."@en ;
  dcterms:modified "2026-06-07T15:30:29.281161Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28385-4
  a curric:KeyLearningPoint ;
  rdfs:label """The poem has a clear, steady rhythm, which gives the poem a flowing and musical
  quality."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281167Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28385-5
  a curric:KeyLearningPoint ;
  rdfs:label "Doing deep breaths before performing can help us to feel calm and reduce nerves."@en ;
  dcterms:modified "2026-06-07T15:30:29.281170Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1446-1
  a curric:KeyLearningPoint ;
  rdfs:label "The spelling 'mb' is often found at the end of a word, such as climb."@en ;
  dcterms:modified "2026-06-07T15:30:29.281174Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1446-2
  a curric:KeyLearningPoint ;
  rdfs:label "The spelling 'kn' is usually found at the start of a word."@en ;
  dcterms:modified "2026-06-07T15:30:29.281178Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1446-3
  a curric:KeyLearningPoint ;
  rdfs:label "The spelling 'gn' is usually found at the start or end of a word."@en ;
  dcterms:modified "2026-06-07T15:30:29.281182Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1446-4
  a curric:KeyLearningPoint ;
  rdfs:label "The spelling 'wr' is usually found at the start of a word."@en ;
  dcterms:modified "2026-06-07T15:30:29.281185Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1446-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum word: perhaps."@en ;
  dcterms:modified "2026-06-07T15:30:29.281262Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6107-1
  a curric:KeyLearningPoint ;
  rdfs:label """Publishing our work is the final stage of the writing process where we prepare our
  writing ready for an audience to see."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281268Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6107-2
  a curric:KeyLearningPoint ;
  rdfs:label """Published work should be written in clear, joined handwriting with letters that
  start on the line."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281272Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6107-3
  a curric:KeyLearningPoint ;
  rdfs:label "A published non-chronological report will usually include a picture or diagram."@en ;
  dcterms:modified "2026-06-07T15:30:29.281276Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6107-4
  a curric:KeyLearningPoint ;
  rdfs:label """We indent each new paragraph and underline subheadings with a ruler and we follow
  any appropriate layout conventions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281280Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5848-1
  a curric:KeyLearningPoint ;
  rdfs:label """A soliloquy is a type of monologue that occurs when a character voices their
  thoughts and feelings aloud."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281299Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5848-2
  a curric:KeyLearningPoint ;
  rdfs:label """Playwrights include soliloquies to give the audience an insight into characters'
  feelings."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281303Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5848-3
  a curric:KeyLearningPoint ;
  rdfs:label """In Shakespeare's plays, high status characters' soliloquies follow iambic pentameter
  structure."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281307Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5848-4
  a curric:KeyLearningPoint ;
  rdfs:label "Soliloquies are written in the first person."@en ;
  dcterms:modified "2026-06-07T15:30:29.281313Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5848-5
  a curric:KeyLearningPoint ;
  rdfs:label "Other characters are silent during the speaker's soliloquy."@en ;
  dcterms:modified "2026-06-07T15:30:29.281317Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2699-1
  a curric:KeyLearningPoint ;
  rdfs:label "Any conjunction joins words, phrases or clauses."@en ;
  dcterms:modified "2026-06-07T15:30:29.281323Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2699-2
  a curric:KeyLearningPoint ;
  rdfs:label "A co-ordinating conjunction is found in a compound sentence."@en ;
  dcterms:modified "2026-06-07T15:30:29.281328Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2699-3
  a curric:KeyLearningPoint ;
  rdfs:label "A subordinating conjunction is found in an adverbial complex sentence."@en ;
  dcterms:modified "2026-06-07T15:30:29.281332Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2699-4
  a curric:KeyLearningPoint ;
  rdfs:label "Different co-ordinating and subordinating conjunctions have different meanings."@en ;
  dcterms:modified "2026-06-07T15:30:29.281336Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4710-1
  a curric:KeyLearningPoint ;
  rdfs:label "The PEPS structure stands for point, explanation, proof, summary."@en ;
  dcterms:modified "2026-06-07T15:30:29.281340Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4710-2
  a curric:KeyLearningPoint ;
  rdfs:label "Following the PEPS structure helps to organise your speech."@en ;
  dcterms:modified "2026-06-07T15:30:29.281360Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4710-3
  a curric:KeyLearningPoint ;
  rdfs:label "Explaining your point will allow you to share the reasons behind your opinion."@en ;
  dcterms:modified "2026-06-07T15:30:29.281363Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4710-4
  a curric:KeyLearningPoint ;
  rdfs:label "Using proof will make your point stronger."@en ;
  dcterms:modified "2026-06-07T15:30:29.281367Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27902-1
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to express disagreements calmly and respectfully, using a polite
  tone and language."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281371Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27902-2
  a curric:KeyLearningPoint ;
  rdfs:label "Some disagreements are about opinions; others are about behaviour and choices."@en ;
  dcterms:modified "2026-06-07T15:30:29.281375Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27902-3
  a curric:KeyLearningPoint ;
  rdfs:label """We should recognise that everyone has different opinions and not take offence; it's
  not a personal attack."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281379Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27902-4
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to try resolving disagreements peacefully by explaining your
  feelings or compromising when appropriate."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281382Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27902-5
  a curric:KeyLearningPoint ;
  rdfs:label """Compromises are not always appropriate; if they are, we should suggest them calmly
  and politely."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281386Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1046-1
  a curric:KeyLearningPoint ;
  rdfs:label "The verb carries the tense of a sentence."@en ;
  dcterms:modified "2026-06-07T15:30:29.281405Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1046-2
  a curric:KeyLearningPoint ;
  rdfs:label "Sentences can be formed in the first, second or third person."@en ;
  dcterms:modified "2026-06-07T15:30:29.281409Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1046-3
  a curric:KeyLearningPoint ;
  rdfs:label "First person is the I / we perspective."@en ;
  dcterms:modified "2026-06-07T15:30:29.281415Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1046-4
  a curric:KeyLearningPoint ;
  rdfs:label "Second person is the you singular / you plural perspective."@en ;
  dcterms:modified "2026-06-07T15:30:29.281419Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1046-5
  a curric:KeyLearningPoint ;
  rdfs:label "Third person is the he / she / it / they perspective."@en ;
  dcterms:modified "2026-06-07T15:30:29.281423Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6220-1
  a curric:KeyLearningPoint ;
  rdfs:label """Our essay will give one side of an argument, using a logical order and supported by
  evidence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281426Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6220-2
  a curric:KeyLearningPoint ;
  rdfs:label "Evidence can take many forms, including explanations, facts and statistics."@en ;
  dcterms:modified "2026-06-07T15:30:29.281430Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6220-3
  a curric:KeyLearningPoint ;
  rdfs:label """In the second main paragraph, we will explain how deforestation can drive climate
  change."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281434Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6220-4
  a curric:KeyLearningPoint ;
  rdfs:label "We will include subject-specific vocabulary and a range of linguistic features."@en ;
  dcterms:modified "2026-06-07T15:30:29.281438Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6220-5
  a curric:KeyLearningPoint ;
  rdfs:label """Within a paragraph, the points we make must be in a logical order and connect to one
  another."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281442Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4870-1
  a curric:KeyLearningPoint ;
  rdfs:label """Research into a subject improves the writing of a non-chronological report
  about it."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281446Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4870-2
  a curric:KeyLearningPoint ;
  rdfs:label "Tigers are nocturnal, highly-adapted mammals that live in Asia."@en ;
  dcterms:modified "2026-06-07T15:30:29.281450Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4870-3
  a curric:KeyLearningPoint ;
  rdfs:label """Adaptations are features that animals and plants have to help them survive in their
  environments."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281454Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4870-4
  a curric:KeyLearningPoint ;
  rdfs:label "Tigers’ adaptations enable them to hunt and eat food."@en ;
  dcterms:modified "2026-06-07T15:30:29.281458Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4870-5
  a curric:KeyLearningPoint ;
  rdfs:label "Tigers' diets are carnivorous."@en ;
  dcterms:modified "2026-06-07T15:30:29.281462Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4898-1
  a curric:KeyLearningPoint ;
  rdfs:label "Information in the adaptations section is specific for the reader."@en ;
  dcterms:modified "2026-06-07T15:30:29.281508Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4898-2
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials, subject-specific vocabulary, relative complex sentences and
  parenthesis enhance text cohesion."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281512Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4898-3
  a curric:KeyLearningPoint ;
  rdfs:label """Parenthesis is additional information added to the sentence that can be demarcated
  using a pair of brackets."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281516Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4898-4
  a curric:KeyLearningPoint ;
  rdfs:label "Plans should be used when writing to generate initial ideas and build upon them."@en ;
  dcterms:modified "2026-06-07T15:30:29.281520Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4898-5
  a curric:KeyLearningPoint ;
  rdfs:label "Success criteria help us understand what to include in our writing."@en ;
  dcterms:modified "2026-06-07T15:30:29.281523Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8638-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the build-up is to build action and suspense leading up to the
  climax."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281544Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8638-2
  a curric:KeyLearningPoint ;
  rdfs:label """In this section of the build-up, Arrietty sets off on her first borrowing expedition
  and reaches the infamous clock."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281550Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8638-3
  a curric:KeyLearningPoint ;
  rdfs:label """A range of precise and ambitious vocabulary is used to describe key moments in the
  build-up."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281556Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8638-4
  a curric:KeyLearningPoint ;
  rdfs:label """‘Show and tell’ language shows a character’s feelings by describing their actions,
  body language and facial expressions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281561Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8638-5
  a curric:KeyLearningPoint ;
  rdfs:label """A plan contains precise vocabulary, is written in note format and follows a sequence
  of events."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281564Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28401-1
  a curric:KeyLearningPoint ;
  rdfs:label "The layout of a poem refers to the way the poem is organised on the page."@en ;
  dcterms:modified "2026-06-07T15:30:29.281568Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28401-2
  a curric:KeyLearningPoint ;
  rdfs:label """Poets can use different layouts and line breaks to convey the plot, characters and
  emotions of the story."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281572Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28401-3
  a curric:KeyLearningPoint ;
  rdfs:label """Goodfellow mixes up the visual arrangements of the poems, which helps the reader
  understand the characters' emotions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281576Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28401-4
  a curric:KeyLearningPoint ;
  rdfs:label """Characterisation is the way authors & illustrators describe & develop the
  personalities & traits of the characters."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281580Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6377-1
  a curric:KeyLearningPoint ;
  rdfs:label "Drama can be a very useful tool when analysing characters in a text."@en ;
  dcterms:modified "2026-06-07T15:30:29.281603Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6377-2
  a curric:KeyLearningPoint ;
  rdfs:label "Dialogue is when two or more characters are speaking in a text."@en ;
  dcterms:modified "2026-06-07T15:30:29.281607Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6377-3
  a curric:KeyLearningPoint ;
  rdfs:label """When performing drama, we need to consider how intonation, facial expression and
  gestures enable us to convey emotions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281610Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6377-4
  a curric:KeyLearningPoint ;
  rdfs:label "Effective teamwork is an essential element of drama."@en ;
  dcterms:modified "2026-06-07T15:30:29.281614Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4848-1
  a curric:KeyLearningPoint ;
  rdfs:label "The opening provides the reader with general information about the event."@en ;
  dcterms:modified "2026-06-07T15:30:29.281694Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4848-2
  a curric:KeyLearningPoint ;
  rdfs:label """The opening includes when, where and what took place as well as who was there and
  what is currently happening."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281700Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4848-3
  a curric:KeyLearningPoint ;
  rdfs:label """Subject-specific language is used to convey information to the reader in a clear,
  formal way."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281704Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4848-4
  a curric:KeyLearningPoint ;
  rdfs:label "Journalists use specific phraseology to write for purpose, tone and credibility."@en ;
  dcterms:modified "2026-06-07T15:30:29.281708Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5824-1
  a curric:KeyLearningPoint ;
  rdfs:label """Editing is the process of improving writing to ensure text flow and overall
  quality."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281712Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5824-2
  a curric:KeyLearningPoint ;
  rdfs:label """Editing involves making improvements to a piece of writing without completely
  rewriting it."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281716Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5824-3
  a curric:KeyLearningPoint ;
  rdfs:label """Punctuation, sentence structure, grammar, vocabulary and spelling are sensible areas
  to focus on in editing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281719Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5824-4
  a curric:KeyLearningPoint ;
  rdfs:label "Editing is a vital part of the writing process."@en ;
  dcterms:modified "2026-06-07T15:30:29.281723Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1313-1
  a curric:KeyLearningPoint ;
  rdfs:label "There are four spelling rules when adding -ous to a root word."@en ;
  dcterms:modified "2026-06-07T15:30:29.281727Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1313-2
  a curric:KeyLearningPoint ;
  rdfs:label "Some words ending in -ous do not have a root word we recognise."@en ;
  dcterms:modified "2026-06-07T15:30:29.281733Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1313-3
  a curric:KeyLearningPoint ;
  rdfs:label """When you hear the ‘ee’ sound before -ous, the most likely spelling is an ‘i’, but it
  is sometimes an ‘e’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281737Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1313-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: guard, exercise and decide."@en ;
  dcterms:modified "2026-06-07T15:30:29.281741Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7665-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of climactic writing is to take the drama to the highest point of
  tension to evoke emotions in the reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281745Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7665-2
  a curric:KeyLearningPoint ;
  rdfs:label """A very emotive scene in ‘Whale Rider’ describes Paikea's encounter with stranded
  whales on a beach."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281751Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7665-3
  a curric:KeyLearningPoint ;
  rdfs:label """Precise and ambitious vocabulary, including 'show-not-tell' language, is used to
  convey an emotive atmosphere."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281755Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7665-4
  a curric:KeyLearningPoint ;
  rdfs:label "Direct speech and characters' inner thoughts are used to convey their emotions."@en ;
  dcterms:modified "2026-06-07T15:30:29.281759Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7665-5
  a curric:KeyLearningPoint ;
  rdfs:label """Notes in a plan should not be written in full sentences and bullet points can be
  used to make notes clear."""@en ;
  dcterms:modified "2026-06-07T15:30:29.281771Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5465-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Anansi and the Antelope Baby' is an African folktale."@en ;
  dcterms:modified "2026-06-07T15:30:29.282606Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5465-2
  a curric:KeyLearningPoint ;
  rdfs:label """Folktales belong to the genre of folklore in which oral stories are shared, adapted
  and passed down over time."""@en ;
  dcterms:modified "2026-06-07T15:30:29.282611Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5465-3
  a curric:KeyLearningPoint ;
  rdfs:label """Folklore stories originate from a range of cultures but have features in common,
  e.g. learning a moral or lesson."""@en ;
  dcterms:modified "2026-06-07T15:30:29.282615Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5465-4
  a curric:KeyLearningPoint ;
  rdfs:label "Anansi stories originated in Ghana and are influenced by African culture."@en ;
  dcterms:modified "2026-06-07T15:30:29.282638Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5465-5
  a curric:KeyLearningPoint ;
  rdfs:label """Anansi is a smart but mischievous spider who encounters a range of tricky
  circumstances with other animals."""@en ;
  dcterms:modified "2026-06-07T15:30:29.282643Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1320-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of a conclusion is to summarise the key points in a text, providing
  closure to the subject."""@en ;
  dcterms:modified "2026-06-07T15:30:29.282726Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1320-2
  a curric:KeyLearningPoint ;
  rdfs:label """A summary sentence is the opening sentence of a conclusion and summarises the key
  points in a text."""@en ;
  dcterms:modified "2026-06-07T15:30:29.282730Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1320-3
  a curric:KeyLearningPoint ;
  rdfs:label "A conclusion begins with a formal fronted adverbial."@en ;
  dcterms:modified "2026-06-07T15:30:29.282734Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1320-4
  a curric:KeyLearningPoint ;
  rdfs:label "There are no new facts or information about the subject in the conclusion."@en ;
  dcterms:modified "2026-06-07T15:30:29.282738Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1320-5
  a curric:KeyLearningPoint ;
  rdfs:label """A conclusion finishes with the writer suggesting to the reader how to find out more
  about the subject."""@en ;
  dcterms:modified "2026-06-07T15:30:29.282742Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4814-1
  a curric:KeyLearningPoint ;
  rdfs:label "Common exception words do not follow regular spelling or phonics rules."@en ;
  dcterms:modified "2026-06-07T15:30:29.282746Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4814-2
  a curric:KeyLearningPoint ;
  rdfs:label """Letters in the common exception words will be joined using a range of joins
  depending on the letters in the word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.282750Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4814-3
  a curric:KeyLearningPoint ;
  rdfs:label "The first letter always has a lead in and the last letter always has a lead out."@en ;
  dcterms:modified "2026-06-07T15:30:29.282754Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4814-4
  a curric:KeyLearningPoint ;
  rdfs:label "There is appropriate spacing between the letters."@en ;
  dcterms:modified "2026-06-07T15:30:29.282759Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4814-5
  a curric:KeyLearningPoint ;
  rdfs:label "You don't lift your pencil when forming the joins."@en ;
  dcterms:modified "2026-06-07T15:30:29.282778Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4834-1
  a curric:KeyLearningPoint ;
  rdfs:label "Print and cursive are the two most common handwriting styles."@en ;
  dcterms:modified "2026-06-07T15:30:29.282783Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4834-2
  a curric:KeyLearningPoint ;
  rdfs:label "Tasks that require speed and fluency should be completed in cursive handwriting."@en ;
  dcterms:modified "2026-06-07T15:30:29.282804Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4834-3
  a curric:KeyLearningPoint ;
  rdfs:label """Tasks that require a personal or formal approach should be written in cursive
  handwriting."""@en ;
  dcterms:modified "2026-06-07T15:30:29.282810Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4834-4
  a curric:KeyLearningPoint ;
  rdfs:label """The cursive style of handwriting is often used for formal writing, such as letters,
  invitations and thank you notes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.282815Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4834-5
  a curric:KeyLearningPoint ;
  rdfs:label """When writing in cursive, letter formation, spacing and using the correct joins
  ensure the writing is legible."""@en ;
  dcterms:modified "2026-06-07T15:30:29.282818Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4826-1
  a curric:KeyLearningPoint ;
  rdfs:label """A famous quotation is a well-known phrase, statement, or passage attributed to a
  particular person, work, or source."""@en ;
  dcterms:modified "2026-06-07T15:30:29.282822Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4826-2
  a curric:KeyLearningPoint ;
  rdfs:label "The quotation is demarcated with inverted commas."@en ;
  dcterms:modified "2026-06-07T15:30:29.282826Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4826-3
  a curric:KeyLearningPoint ;
  rdfs:label "The quotation starts with a capital letter."@en ;
  dcterms:modified "2026-06-07T15:30:29.282829Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4826-4
  a curric:KeyLearningPoint ;
  rdfs:label """After forming a capital letter, you need to lift your pencil to start the next part
  of the word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.282833Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4826-5
  a curric:KeyLearningPoint ;
  rdfs:label """A range of joins will be used depending on which letters are joining to which
  letters."""@en ;
  dcterms:modified "2026-06-07T15:30:29.282837Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6157-1
  a curric:KeyLearningPoint ;
  rdfs:label "Writing is most successful when it is planned."@en ;
  dcterms:modified "2026-06-07T15:30:29.282840Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6157-2
  a curric:KeyLearningPoint ;
  rdfs:label """The introduction of a journalistic report will include a summary of the event,
  including who, what, where, when & why."""@en ;
  dcterms:modified "2026-06-07T15:30:29.282844Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6157-3
  a curric:KeyLearningPoint ;
  rdfs:label """The main paragraphs will be themed around different perspectives, integrating
  relevant facts."""@en ;
  dcterms:modified "2026-06-07T15:30:29.282847Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6157-4
  a curric:KeyLearningPoint ;
  rdfs:label """The conclusion will include an official perspective, the most up-to-date information
  and a look to the future."""@en ;
  dcterms:modified "2026-06-07T15:30:29.282851Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6157-5
  a curric:KeyLearningPoint ;
  rdfs:label """We can plan to use subject-specific vocabulary relevant to the subject of the
  report."""@en ;
  dcterms:modified "2026-06-07T15:30:29.282855Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1392-1
  a curric:KeyLearningPoint ;
  rdfs:label "In words of Latin origin, the letter string 'sc' makes the /s/ sound"@en ;
  dcterms:modified "2026-06-07T15:30:29.282895Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1392-2
  a curric:KeyLearningPoint ;
  rdfs:label "When this spelling is used, it is most often before an ‘i’ or ‘e’."@en ;
  dcterms:modified "2026-06-07T15:30:29.282898Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1392-3
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: muscle, suggest and pressure"@en ;
  dcterms:modified "2026-06-07T15:30:29.282902Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6273-1
  a curric:KeyLearningPoint ;
  rdfs:label """There are examples of Western and traditional Moroccan clothing represented within
  both stories."""@en ;
  dcterms:modified "2026-06-07T15:30:29.282906Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6273-2
  a curric:KeyLearningPoint ;
  rdfs:label "Connections are ways in which you connect personally with a text."@en ;
  dcterms:modified "2026-06-07T15:30:29.282909Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6273-3
  a curric:KeyLearningPoint ;
  rdfs:label """The way that one reader connects might be different to another based on their own
  life experiences."""@en ;
  dcterms:modified "2026-06-07T15:30:29.282913Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6273-4
  a curric:KeyLearningPoint ;
  rdfs:label "Connections can be from text-to-self, text-to-text or text-to-world."@en ;
  dcterms:modified "2026-06-07T15:30:29.282917Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6273-5
  a curric:KeyLearningPoint ;
  rdfs:label """There are connections between the two stories in ‘Mirror’ - involving characters,
  objects and clothing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.282921Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8092-1
  a curric:KeyLearningPoint ;
  rdfs:label """Characterisation is the way an author and illustrator develop the personalities and
  traits of the characters in a story."""@en ;
  dcterms:modified "2026-06-07T15:30:29.283136Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8092-2
  a curric:KeyLearningPoint ;
  rdfs:label """Readers can tell lots about characters through their appearance, dialogue, their
  actions and how they are depicted."""@en ;
  dcterms:modified "2026-06-07T15:30:29.283140Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8092-3
  a curric:KeyLearningPoint ;
  rdfs:label """Pages with no text can be called wordless (these can also be referred to as
  ‘silent’)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.283144Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8092-4
  a curric:KeyLearningPoint ;
  rdfs:label """Having explored the characters in greater detail, readers can make predictions about
  what might happen next."""@en ;
  dcterms:modified "2026-06-07T15:30:29.283147Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1403-1
  a curric:KeyLearningPoint ;
  rdfs:label "The suffix -tion creates abstract nouns."@en ;
  dcterms:modified "2026-06-07T15:30:29.283151Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1403-2
  a curric:KeyLearningPoint ;
  rdfs:label "The most common spelling for the /shun/ suffix is -tion."@en ;
  dcterms:modified "2026-06-07T15:30:29.283155Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1403-3
  a curric:KeyLearningPoint ;
  rdfs:label "Words spelt with -tion often have a root word ending in ‘t’ or ‘te’."@en ;
  dcterms:modified "2026-06-07T15:30:29.283158Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1403-4
  a curric:KeyLearningPoint ;
  rdfs:label "The suffix -ation turns verbs into nouns.  It uses familiar spelling patterns."@en ;
  dcterms:modified "2026-06-07T15:30:29.283162Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1403-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: build, height and eight."@en ;
  dcterms:modified "2026-06-07T15:30:29.283173Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1386-1
  a curric:KeyLearningPoint ;
  rdfs:label """There are many ways to spell the ‘ee’ sound, including ‘ee’, ‘ea’, ‘e-e’, ‘e’, ‘y’,
  ‘ey’, ‘ie’ and ‘ei’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.283178Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1386-2
  a curric:KeyLearningPoint ;
  rdfs:label """The rule ‘i before e except after c’ can help choose between ‘ie’ and ‘ei’ when
  spelling ‘ee’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.283182Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1386-3
  a curric:KeyLearningPoint ;
  rdfs:label "The letter string ‘ie’ can represent a range of different sounds."@en ;
  dcterms:modified "2026-06-07T15:30:29.283185Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1386-4
  a curric:KeyLearningPoint ;
  rdfs:label """Some spellings with ‘ie’ are formed from root words ending in ‘y’ and a vowel
  suffix."""@en ;
  dcterms:modified "2026-06-07T15:30:29.283189Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1386-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: ancient, soldier and bargain."@en ;
  dcterms:modified "2026-06-07T15:30:29.283193Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8066-1
  a curric:KeyLearningPoint ;
  rdfs:label """After we have taken time to understand a poem’s meaning, themes and structure, we
  can learn a poem off by heart."""@en ;
  dcterms:modified "2026-06-07T15:30:29.283197Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8066-2
  a curric:KeyLearningPoint ;
  rdfs:label """Learning poetry by heart offers a range of benefits to pupils both emotionally and
  academically."""@en ;
  dcterms:modified "2026-06-07T15:30:29.283200Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8066-3
  a curric:KeyLearningPoint ;
  rdfs:label "We can use a range of strategies to support us learning poetry by heart."@en ;
  dcterms:modified "2026-06-07T15:30:29.283204Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8066-4
  a curric:KeyLearningPoint ;
  rdfs:label """Once we have been able to practise the poem several times, we can perform the poem
  aloud in a recital."""@en ;
  dcterms:modified "2026-06-07T15:30:29.283208Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1420-1
  a curric:KeyLearningPoint ;
  rdfs:label """Compound words are two or three existing words that join together to make
  one word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.283230Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1420-2
  a curric:KeyLearningPoint ;
  rdfs:label "Compound words are most often nouns."@en ;
  dcterms:modified "2026-06-07T15:30:29.283234Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1420-3
  a curric:KeyLearningPoint ;
  rdfs:label """Compound words have a new meaning, which is often linked to the meaning of the root
  word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.283238Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1420-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: enough, naughty and forwards."@en ;
  dcterms:modified "2026-06-07T15:30:29.283244Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1078-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Bland' is an adjective which means plain and flavourless."@en ;
  dcterms:modified "2026-06-07T15:30:29.283248Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1078-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Savoury' is an adjective which means salty and spicy."@en ;
  dcterms:modified "2026-06-07T15:30:29.283252Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1078-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Tangy' is an adjective which means flavourful and sharp."@en ;
  dcterms:modified "2026-06-07T15:30:29.283255Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1078-4
  a curric:KeyLearningPoint ;
  rdfs:label "'Tart', 'peppery' and 'sugary' are other adjectives related to flavour."@en ;
  dcterms:modified "2026-06-07T15:30:29.283259Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1047-1
  a curric:KeyLearningPoint ;
  rdfs:label "The verb carries the tense of a sentence."@en ;
  dcterms:modified "2026-06-07T15:30:29.283284Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1047-2
  a curric:KeyLearningPoint ;
  rdfs:label """The simple tense is a tense that does not make use of an auxiliary verb with the
  main verb in the past and present."""@en ;
  dcterms:modified "2026-06-07T15:30:29.283288Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1047-3
  a curric:KeyLearningPoint ;
  rdfs:label """The progressive tense is a tense that uses an auxiliary verb from the infinitive 'to
  be' paired with the main verb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.283292Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1047-4
  a curric:KeyLearningPoint ;
  rdfs:label "The progressive tense denotes ongoing action."@en ;
  dcterms:modified "2026-06-07T15:30:29.283295Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1047-5
  a curric:KeyLearningPoint ;
  rdfs:label "The main verb in the progressive tense always ends with the -ing suffix."@en ;
  dcterms:modified "2026-06-07T15:30:29.283301Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6150-1
  a curric:KeyLearningPoint ;
  rdfs:label "The purpose of the build-up is to build tension and suspense."@en ;
  dcterms:modified "2026-06-07T15:30:29.283328Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6150-2
  a curric:KeyLearningPoint ;
  rdfs:label "Saying sentences aloud before they are written helps to check for sense."@en ;
  dcterms:modified "2026-06-07T15:30:29.283332Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6150-3
  a curric:KeyLearningPoint ;
  rdfs:label """Using the full range of sentence types (simple, compound and complex) improves text
  flow for the reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.283336Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6150-4
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials of time, place and manner describe the action in the main clause
  in further detail."""@en ;
  dcterms:modified "2026-06-07T15:30:29.283340Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6150-5
  a curric:KeyLearningPoint ;
  rdfs:label """'Show-not-tell' language shows a character’s feelings by describing their actions,
  body language and facial expressions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.283343Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1373-1
  a curric:KeyLearningPoint ;
  rdfs:label "If the word is a profession, the noun will generally end in \"-cian\"."@en ;
  dcterms:modified "2026-06-07T15:30:29.283347Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1373-2
  a curric:KeyLearningPoint ;
  rdfs:label """If the root word ends in \"ss\" or \"mit\", remove the \"ss\" or \"t\" and add
  \"-ssion\"."""@en ;
  dcterms:modified "2026-06-07T15:30:29.283351Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1373-3
  a curric:KeyLearningPoint ;
  rdfs:label """If the root word is a verb ending in \"se\" or \"de\", remove the \"se\" or \"de\"
  and add \"-sion\"."""@en ;
  dcterms:modified "2026-06-07T15:30:29.283354Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1373-4
  a curric:KeyLearningPoint ;
  rdfs:label """If the root word ends in \"c\" or \"cs\", remove the \"c\" or \"cs\" and add
  \"-cian\"."""@en ;
  dcterms:modified "2026-06-07T15:30:29.283358Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1373-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: possession, occasion and occasionally."@en ;
  dcterms:modified "2026-06-07T15:30:29.283362Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1114-1
  a curric:KeyLearningPoint ;
  rdfs:label "Billowing is an adjective which means swelling or expanding."@en ;
  dcterms:modified "2026-06-07T15:30:29.283384Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1114-2
  a curric:KeyLearningPoint ;
  rdfs:label "Dense is an adjective which means thick, solid or heavy."@en ;
  dcterms:modified "2026-06-07T15:30:29.283389Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1114-3
  a curric:KeyLearningPoint ;
  rdfs:label "Hazy is an adjective which means cloudy or misty."@en ;
  dcterms:modified "2026-06-07T15:30:29.283395Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7667-1
  a curric:KeyLearningPoint ;
  rdfs:label """The emotive scene is written over two paragraphs and it is important to demonstrate
  a change in atmosphere."""@en ;
  dcterms:modified "2026-06-07T15:30:29.283399Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7667-2
  a curric:KeyLearningPoint ;
  rdfs:label """Using a range of sentence types (simple, compound and complex) improves text flow
  and cohesion."""@en ;
  dcterms:modified "2026-06-07T15:30:29.283403Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7667-3
  a curric:KeyLearningPoint ;
  rdfs:label """Precise and ambitious vocabulary, including 'show-not-tell' language, is used to
  convey an emotive atmosphere."""@en ;
  dcterms:modified "2026-06-07T15:30:29.283406Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7667-4
  a curric:KeyLearningPoint ;
  rdfs:label """Direct speech and characters' internal thoughts are used to convey their
  emotions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.283410Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7667-5
  a curric:KeyLearningPoint ;
  rdfs:label """Oral rehearsal before writing helps to structure grammatically correct sentences and
  check for sense."""@en ;
  dcterms:modified "2026-06-07T15:30:29.283414Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3404-1
  a curric:KeyLearningPoint ;
  rdfs:label "A subheading signals to the reader what the section is about."@en ;
  dcterms:modified "2026-06-07T15:30:29.284892Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3404-2
  a curric:KeyLearningPoint ;
  rdfs:label """Careful selection of nouns and pronouns ensures cohesion within sentences and across
  sections of the report."""@en ;
  dcterms:modified "2026-06-07T15:30:29.284896Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3404-3
  a curric:KeyLearningPoint ;
  rdfs:label """A section about one feature of the report's subject contains specific facts and
  information to keep the reader engaged."""@en ;
  dcterms:modified "2026-06-07T15:30:29.284900Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3404-4
  a curric:KeyLearningPoint ;
  rdfs:label """Writers choose varied fronted adverbials and different sentence types to ensure the
  text flows for the reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.284904Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3404-5
  a curric:KeyLearningPoint ;
  rdfs:label """Sentences should be said aloud before writing to ensure they make sense and read
  back once written to check for errors."""@en ;
  dcterms:modified "2026-06-07T15:30:29.284908Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7929-1
  a curric:KeyLearningPoint ;
  rdfs:label """Both of Floella's parents leave for England. Floella and three siblings are split
  and live with guardians."""@en ;
  dcterms:modified "2026-06-07T15:30:29.284912Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7929-2
  a curric:KeyLearningPoint ;
  rdfs:label """Migration to England during the Windrush period (1948-1971) was driven by a
  combination of factors."""@en ;
  dcterms:modified "2026-06-07T15:30:29.284915Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7929-3
  a curric:KeyLearningPoint ;
  rdfs:label """Floella's characterisation changes as a result of the circumstances she now finds
  herself in."""@en ;
  dcterms:modified "2026-06-07T15:30:29.284921Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7929-4
  a curric:KeyLearningPoint ;
  rdfs:label """Characterisation is the way an author & illustrator describe and develop the
  personalities and traits of the characters."""@en ;
  dcterms:modified "2026-06-07T15:30:29.284925Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1327-1
  a curric:KeyLearningPoint ;
  rdfs:label """Two or more words that sound the same but have different meanings or spellings are
  called homophones."""@en ;
  dcterms:modified "2026-06-07T15:30:29.284929Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1327-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Licence' and 'license' and 'practice' and 'practise' are homophones."@en ;
  dcterms:modified "2026-06-07T15:30:29.284932Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1327-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Prophecy' and 'prophesy' are homophones."@en ;
  dcterms:modified "2026-06-07T15:30:29.284936Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1327-4
  a curric:KeyLearningPoint ;
  rdfs:label "We can look for naughty letters to help us to remember tricky spellings."@en ;
  dcterms:modified "2026-06-07T15:30:29.284940Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1327-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: temperature and aggressive."@en ;
  dcterms:modified "2026-06-07T15:30:29.284943Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1121-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Flawless' is an adjective which means perfect or impeccable."@en ;
  dcterms:modified "2026-06-07T15:30:29.284968Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1121-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Mesmerising' is an adjective which means very attractive or bewitching."@en ;
  dcterms:modified "2026-06-07T15:30:29.284972Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1121-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Statuesque' is an adjective which means tall, beautiful and dignified."@en ;
  dcterms:modified "2026-06-07T15:30:29.284975Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1073-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Flabbergasted' is an adjective which means shocked or amazed."@en ;
  dcterms:modified "2026-06-07T15:30:29.284979Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1073-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Astonished' is an adjective which means surprised or amazed."@en ;
  dcterms:modified "2026-06-07T15:30:29.284983Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1073-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Speechless' is an adjective which means you are dumbstruck or lost for words."@en ;
  dcterms:modified "2026-06-07T15:30:29.284986Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1073-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Alarmed', 'startled' and 'stunned' are other rich vocabulary associated with
  surprise."""@en ;
  dcterms:modified "2026-06-07T15:30:29.284992Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4811-1
  a curric:KeyLearningPoint ;
  rdfs:label """A prefix is a letter or group of letters added to the start of a word to change its
  meaning."""@en ;
  dcterms:modified "2026-06-07T15:30:29.285017Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4811-2
  a curric:KeyLearningPoint ;
  rdfs:label "The words start with a lead in and finish with a lead out."@en ;
  dcterms:modified "2026-06-07T15:30:29.285021Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4811-3
  a curric:KeyLearningPoint ;
  rdfs:label """The pencil does not lift when forming the join, only after to add the cross to a t
  or a dot to an i or a j."""@en ;
  dcterms:modified "2026-06-07T15:30:29.285027Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4811-4
  a curric:KeyLearningPoint ;
  rdfs:label "There are four cursive joins."@en ;
  dcterms:modified "2026-06-07T15:30:29.285031Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4811-5
  a curric:KeyLearningPoint ;
  rdfs:label """The join used depends on which letter is joining to which letter within a letter
  string."""@en ;
  dcterms:modified "2026-06-07T15:30:29.285035Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2709-1
  a curric:KeyLearningPoint ;
  rdfs:label "Determiners are a word class."@en ;
  dcterms:modified "2026-06-07T15:30:29.285039Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2709-2
  a curric:KeyLearningPoint ;
  rdfs:label "A determiner introduces a noun in a clause or phrase."@en ;
  dcterms:modified "2026-06-07T15:30:29.285042Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2709-3
  a curric:KeyLearningPoint ;
  rdfs:label """A determiner may be followed by an adjective or pair of adjectives then the
  noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.285046Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2709-4
  a curric:KeyLearningPoint ;
  rdfs:label "Determiners can be articles."@en ;
  dcterms:modified "2026-06-07T15:30:29.285050Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2709-5
  a curric:KeyLearningPoint ;
  rdfs:label "Determiners can be possessive pronouns."@en ;
  dcterms:modified "2026-06-07T15:30:29.285054Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1084-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Rancid' is an adjective which means foul or rotten."@en ;
  dcterms:modified "2026-06-07T15:30:29.285057Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1084-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Nauseating' is an adjective which means sickening or disgusting."@en ;
  dcterms:modified "2026-06-07T15:30:29.285061Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1084-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Inedible', 'repulsive', 'stale' and 'unpalatable' are other adjectives related to
  the word disgusting."""@en ;
  dcterms:modified "2026-06-07T15:30:29.285067Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4890-1
  a curric:KeyLearningPoint ;
  rdfs:label "The conclusion is the final paragraph of a non-chronological report."@en ;
  dcterms:modified "2026-06-07T15:30:29.285071Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4890-2
  a curric:KeyLearningPoint ;
  rdfs:label "Information in the conclusion should be general."@en ;
  dcterms:modified "2026-06-07T15:30:29.285075Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4890-3
  a curric:KeyLearningPoint ;
  rdfs:label """Writers can use a range of cohesive devices to enhance text flow and keep the reader
  engaged."""@en ;
  dcterms:modified "2026-06-07T15:30:29.285079Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4890-4
  a curric:KeyLearningPoint ;
  rdfs:label "Effective planning leads to successful writing outcomes."@en ;
  dcterms:modified "2026-06-07T15:30:29.285083Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1030-1
  a curric:KeyLearningPoint ;
  rdfs:label "A title opens a non-chronological report."@en ;
  dcterms:modified "2026-06-07T15:30:29.285105Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1030-2
  a curric:KeyLearningPoint ;
  rdfs:label "The purpose of the introduction is to give general information to the reader."@en ;
  dcterms:modified "2026-06-07T15:30:29.285109Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1030-3
  a curric:KeyLearningPoint ;
  rdfs:label """The introduction outlines what the reader will learn from the non-chronological
  report."""@en ;
  dcterms:modified "2026-06-07T15:30:29.285113Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1030-4
  a curric:KeyLearningPoint ;
  rdfs:label """Expanded noun phrases and synonyms for ‘spider’ are used to refer to the subject in
  different ways."""@en ;
  dcterms:modified "2026-06-07T15:30:29.285116Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3446-1
  a curric:KeyLearningPoint ;
  rdfs:label """Adverbial clauses and relative clauses are types of subordinate clause; they must be
  joined to a main clause."""@en ;
  dcterms:modified "2026-06-07T15:30:29.285120Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3446-2
  a curric:KeyLearningPoint ;
  rdfs:label """Adverbial clauses start with subordinating conjunctions; there are many of these
  with different purposes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.285124Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3446-3
  a curric:KeyLearningPoint ;
  rdfs:label """Relative clauses start with relative pronouns; occasionally in informal language,
  the relative pronoun is omitted."""@en ;
  dcterms:modified "2026-06-07T15:30:29.285128Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3446-4
  a curric:KeyLearningPoint ;
  rdfs:label """Adverbial clauses can be placed before or after a main clause in an adverbial
  complex sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.285134Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3446-5
  a curric:KeyLearningPoint ;
  rdfs:label """Relative clauses are placed after the noun or noun phrase they tell us more about
  (and can be at the end of a sentence)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.285140Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7657-1
  a curric:KeyLearningPoint ;
  rdfs:label """'Whale Rider' tells the story of Paikea and the challenges she faces and overcomes
  as a young girl in a Maori tribe."""@en ;
  dcterms:modified "2026-06-07T15:30:29.285144Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7657-2
  a curric:KeyLearningPoint ;
  rdfs:label """A narrative can be structured into four key sections: the opening, the build-up, the
  climax and the resolution."""@en ;
  dcterms:modified "2026-06-07T15:30:29.285147Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7657-3
  a curric:KeyLearningPoint ;
  rdfs:label "Each part of a narrative has a specific purpose."@en ;
  dcterms:modified "2026-06-07T15:30:29.285151Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7657-4
  a curric:KeyLearningPoint ;
  rdfs:label """We can use our voice, language choices and expression to retell a story
  effectively."""@en ;
  dcterms:modified "2026-06-07T15:30:29.285155Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7657-5
  a curric:KeyLearningPoint ;
  rdfs:label """When retelling a story, it is important to convey the appropriate tone at each point
  of the story."""@en ;
  dcterms:modified "2026-06-07T15:30:29.285159Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6757-1
  a curric:KeyLearningPoint ;
  rdfs:label """A journalistic report has a formal tone and it combines factual statements with
  different perspectives on an event."""@en ;
  dcterms:modified "2026-06-07T15:30:29.286368Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6757-2
  a curric:KeyLearningPoint ;
  rdfs:label """The main paragraphs give different perspectives, using both direct and reported
  speech."""@en ;
  dcterms:modified "2026-06-07T15:30:29.286374Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6757-3
  a curric:KeyLearningPoint ;
  rdfs:label """The conclusion includes the 'official' perspective, gives the most up-to-date
  information and looks to the future."""@en ;
  dcterms:modified "2026-06-07T15:30:29.286378Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6757-4
  a curric:KeyLearningPoint ;
  rdfs:label "Throughout, a range of cohesive devices can be used to connect ideas together."@en ;
  dcterms:modified "2026-06-07T15:30:29.286382Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7664-1
  a curric:KeyLearningPoint ;
  rdfs:label "Editing is the process of making changes to improve our writing."@en ;
  dcterms:modified "2026-06-07T15:30:29.286386Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7664-2
  a curric:KeyLearningPoint ;
  rdfs:label """To edit punctuation, missing or incorrectly used capital letters, full stops,
  inverted commas and commas are checked."""@en ;
  dcterms:modified "2026-06-07T15:30:29.286390Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7664-3
  a curric:KeyLearningPoint ;
  rdfs:label "When editing language, choices of words and phrases are carefully reviewed."@en ;
  dcterms:modified "2026-06-07T15:30:29.286396Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7664-4
  a curric:KeyLearningPoint ;
  rdfs:label """Knowledge of synonyms is helpful to ensure vocabulary choices match their intended
  effect on the reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.286400Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7664-5
  a curric:KeyLearningPoint ;
  rdfs:label """When editing sentence structure, the way sentences are constructed is checked to
  improve and enhance text flow."""@en ;
  dcterms:modified "2026-06-07T15:30:29.286404Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3444-1
  a curric:KeyLearningPoint ;
  rdfs:label "Any clause is a group of words that contains a verb."@en ;
  dcterms:modified "2026-06-07T15:30:29.286425Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3444-2
  a curric:KeyLearningPoint ;
  rdfs:label "A main clause is a group of words that contains a verb and makes complete sense."@en ;
  dcterms:modified "2026-06-07T15:30:29.286429Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3444-3
  a curric:KeyLearningPoint ;
  rdfs:label """A subordinate clause is a group of words that contains a verb and does not make
  complete sense."""@en ;
  dcterms:modified "2026-06-07T15:30:29.286433Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3444-4
  a curric:KeyLearningPoint ;
  rdfs:label """There are three types of subordinate clause: the adverbial clause, the relative
  clause and the non-finite clause."""@en ;
  dcterms:modified "2026-06-07T15:30:29.286437Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3444-5
  a curric:KeyLearningPoint ;
  rdfs:label "Any type of subordinate clause must be joined to a main clause to make sense."@en ;
  dcterms:modified "2026-06-07T15:30:29.286440Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6520-1
  a curric:KeyLearningPoint ;
  rdfs:label "Writing is most successful when it is planned."@en ;
  dcterms:modified "2026-06-07T15:30:29.286444Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6520-2
  a curric:KeyLearningPoint ;
  rdfs:label "Understanding the question is critical to a successful essay answer."@en ;
  dcterms:modified "2026-06-07T15:30:29.286448Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6520-3
  a curric:KeyLearningPoint ;
  rdfs:label """An essay can use a bank of research, evidence and statistics to convince the reader
  of a certain viewpoint."""@en ;
  dcterms:modified "2026-06-07T15:30:29.286452Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6520-4
  a curric:KeyLearningPoint ;
  rdfs:label "A structure that supports the line of argument must be logical."@en ;
  dcterms:modified "2026-06-07T15:30:29.286456Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8829-1
  a curric:KeyLearningPoint ;
  rdfs:label "'The Day the Crayons Quit' is a children's picture book."@en ;
  dcterms:modified "2026-06-07T15:30:29.286460Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8829-2
  a curric:KeyLearningPoint ;
  rdfs:label """The book is compiled of letters from the crayons to their owner, Duncan, explaining
  why they are going to quit."""@en ;
  dcterms:modified "2026-06-07T15:30:29.286464Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8829-3
  a curric:KeyLearningPoint ;
  rdfs:label """The illustrations visually bring to life the personalities and emotions of each
  crayon character."""@en ;
  dcterms:modified "2026-06-07T15:30:29.286467Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8829-4
  a curric:KeyLearningPoint ;
  rdfs:label """Letters are often written when the writer has a feeling or an opinion about
  something."""@en ;
  dcterms:modified "2026-06-07T15:30:29.286471Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8829-5
  a curric:KeyLearningPoint ;
  rdfs:label """The crayon characters all have different reasons for writing their letter to
  Duncan."""@en ;
  dcterms:modified "2026-06-07T15:30:29.286475Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2747-1
  a curric:KeyLearningPoint ;
  rdfs:label "An apostrophe is an important piece of punctuation with more than one purpose."@en ;
  dcterms:modified "2026-06-07T15:30:29.286496Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2747-2
  a curric:KeyLearningPoint ;
  rdfs:label "An apostrophe can contract two words together."@en ;
  dcterms:modified "2026-06-07T15:30:29.286501Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2747-3
  a curric:KeyLearningPoint ;
  rdfs:label "An apostrophe can show if a noun belongs to another singular noun."@en ;
  dcterms:modified "2026-06-07T15:30:29.286505Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2747-4
  a curric:KeyLearningPoint ;
  rdfs:label "An apostrophe can show if a noun belongs to another plural noun."@en ;
  dcterms:modified "2026-06-07T15:30:29.286509Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2747-5
  a curric:KeyLearningPoint ;
  rdfs:label "Contractions are useful in writing to indicate a character's informal speech."@en ;
  dcterms:modified "2026-06-07T15:30:29.286513Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5807-1
  a curric:KeyLearningPoint ;
  rdfs:label """Writing is most successful when it is planned; this can include planning the
  vocabulary we may wish to include."""@en ;
  dcterms:modified "2026-06-07T15:30:29.286539Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5807-2
  a curric:KeyLearningPoint ;
  rdfs:label """Juliet's diary entries will cover meeting Romeo, discovering he is a Montague and
  agreeing to marry him."""@en ;
  dcterms:modified "2026-06-07T15:30:29.286542Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5807-3
  a curric:KeyLearningPoint ;
  rdfs:label """We will want to give Juliet's first impressions of Romeo by showing how she
  perceives him."""@en ;
  dcterms:modified "2026-06-07T15:30:29.286546Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5807-4
  a curric:KeyLearningPoint ;
  rdfs:label "We will want to show Juliet's emotions at different points in the narrative."@en ;
  dcterms:modified "2026-06-07T15:30:29.286550Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5807-5
  a curric:KeyLearningPoint ;
  rdfs:label "We can use both rich vocabulary and show-not-tell to describe emotions."@en ;
  dcterms:modified "2026-06-07T15:30:29.286554Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5496-1
  a curric:KeyLearningPoint ;
  rdfs:label """A word family is a group of words common in feature, pattern or meaning. Prefixes
  and suffixes can build word families."""@en ;
  dcterms:modified "2026-06-07T15:30:29.286588Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5496-2
  a curric:KeyLearningPoint ;
  rdfs:label """A synonym is a word with the same or similar meaning to another word and an antonym
  has the opposite meaning."""@en ;
  dcterms:modified "2026-06-07T15:30:29.286594Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5496-3
  a curric:KeyLearningPoint ;
  rdfs:label "A pronoun is a word that we use in place of a noun to avoid repetition."@en ;
  dcterms:modified "2026-06-07T15:30:29.286598Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5496-4
  a curric:KeyLearningPoint ;
  rdfs:label """A possessive pronoun is a type of pronoun that denotes possession of a noun by
  another noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.286602Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5496-5
  a curric:KeyLearningPoint ;
  rdfs:label """A preposition is a word that connects a sentence to a noun or noun phrase to show
  where/when/why something's happening."""@en ;
  dcterms:modified "2026-06-07T15:30:29.286608Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5498-1
  a curric:KeyLearningPoint ;
  rdfs:label "A comma is an important punctuation mark with more than one purpose."@en ;
  dcterms:modified "2026-06-07T15:30:29.286662Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5498-2
  a curric:KeyLearningPoint ;
  rdfs:label "Adding extra information to a clause is called parenthesis."@en ;
  dcterms:modified "2026-06-07T15:30:29.286666Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5498-3
  a curric:KeyLearningPoint ;
  rdfs:label "Parenthesis can be punctuated in a variety of ways."@en ;
  dcterms:modified "2026-06-07T15:30:29.286670Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7879-1
  a curric:KeyLearningPoint ;
  rdfs:label """Abdul Karim is a member of Queen Victoria’s household. He is teaching the Queen
  Hindustani."""@en ;
  dcterms:modified "2026-06-07T15:30:29.286673Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7879-2
  a curric:KeyLearningPoint ;
  rdfs:label "Abdul Karim describes India in Chapter 6."@en ;
  dcterms:modified "2026-06-07T15:30:29.286677Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7879-3
  a curric:KeyLearningPoint ;
  rdfs:label """The Duleep Singh sisters visit India in Chapters 9-14; their experiences differ from
  their expectations."""@en ;
  dcterms:modified "2026-06-07T15:30:29.286681Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7879-4
  a curric:KeyLearningPoint ;
  rdfs:label """Reading from a particular perspective may mean that events or thoughts might not be
  balanced."""@en ;
  dcterms:modified "2026-06-07T15:30:29.286685Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7879-5
  a curric:KeyLearningPoint ;
  rdfs:label """Readers can compare and contrast a character’s perspective if they discuss shared or
  similar experiences."""@en ;
  dcterms:modified "2026-06-07T15:30:29.286688Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8073-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘The Land of Blue’ is written by Laura Mucha and illustrated by Victoria Jane
  Wheeler."""@en ;
  dcterms:modified "2026-06-07T15:30:29.286692Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8073-2
  a curric:KeyLearningPoint ;
  rdfs:label """The poem uses symbolism - symbols that represent ideas beyond their literal
  meaning."""@en ;
  dcterms:modified "2026-06-07T15:30:29.286696Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8073-3
  a curric:KeyLearningPoint ;
  rdfs:label """The poem references colours; these can symbolise a range of feelings and
  emotions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.286700Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8073-4
  a curric:KeyLearningPoint ;
  rdfs:label "We can respond to a poem by writing a personal response to it."@en ;
  dcterms:modified "2026-06-07T15:30:29.286704Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8073-5
  a curric:KeyLearningPoint ;
  rdfs:label """Personal responses are reflections that we make about a poem after reading or
  listening to it."""@en ;
  dcterms:modified "2026-06-07T15:30:29.286707Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6118-1
  a curric:KeyLearningPoint ;
  rdfs:label "Editing is a critical part of the writing process."@en ;
  dcterms:modified "2026-06-07T15:30:29.286780Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6118-2
  a curric:KeyLearningPoint ;
  rdfs:label """Writing is most successful when editing is used to rethink, rephrase and reconsider
  first ideas."""@en ;
  dcterms:modified "2026-06-07T15:30:29.286783Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6118-3
  a curric:KeyLearningPoint ;
  rdfs:label "Editing can be done by oneself, with a peer or with a teacher."@en ;
  dcterms:modified "2026-06-07T15:30:29.286787Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6118-4
  a curric:KeyLearningPoint ;
  rdfs:label """Editing is most successful when it is chunked by punctuation, sentence structure,
  vocabulary and cohesive devices."""@en ;
  dcterms:modified "2026-06-07T15:30:29.286793Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6118-5
  a curric:KeyLearningPoint ;
  rdfs:label "A growth mindset helps us benefit most from editing."@en ;
  dcterms:modified "2026-06-07T15:30:29.286797Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27607-1
  a curric:KeyLearningPoint ;
  rdfs:label """There is some vocabulary that is commonly used when retelling a story, particularly
  a fairy tale."""@en ;
  dcterms:modified "2026-06-07T15:30:29.286801Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27607-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Goldilocks and the Three Bears' uses repetition of the number three as a key
  storytelling technique."""@en ;
  dcterms:modified "2026-06-07T15:30:29.286805Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27607-3
  a curric:KeyLearningPoint ;
  rdfs:label "Fronted adverbials of time can be used to help sequence a story."@en ;
  dcterms:modified "2026-06-07T15:30:29.286809Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27607-4
  a curric:KeyLearningPoint ;
  rdfs:label """Using precise vocabulary helps to create vivid descriptions of characters, setting
  and action."""@en ;
  dcterms:modified "2026-06-07T15:30:29.286813Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6272-1
  a curric:KeyLearningPoint ;
  rdfs:label """The Moroccan story is set in the Valley of the Roses; the Western (Australian)
  setting is based on a suburb of Sydney."""@en ;
  dcterms:modified "2026-06-07T15:30:29.286816Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6272-2
  a curric:KeyLearningPoint ;
  rdfs:label "The two landscapes contrast with each other."@en ;
  dcterms:modified "2026-06-07T15:30:29.286822Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6272-3
  a curric:KeyLearningPoint ;
  rdfs:label "Asking questions about the images helps us to understand their purpose."@en ;
  dcterms:modified "2026-06-07T15:30:29.286826Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6272-4
  a curric:KeyLearningPoint ;
  rdfs:label """A prediction can be based on reading and discussion. It can also link to a reader's
  own personal experience."""@en ;
  dcterms:modified "2026-06-07T15:30:29.286830Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6272-5
  a curric:KeyLearningPoint ;
  rdfs:label "Drawing comparisons between images helps us to understand their meaning."@en ;
  dcterms:modified "2026-06-07T15:30:29.286834Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8035-1
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to prepare for performing a poem by analysing the text to develop a
  full understanding."""@en ;
  dcterms:modified "2026-06-07T15:30:29.286859Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8035-2
  a curric:KeyLearningPoint ;
  rdfs:label """Performing a poem requires the performer to use their voice to make the poem
  interesting to listen to."""@en ;
  dcterms:modified "2026-06-07T15:30:29.286862Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8035-3
  a curric:KeyLearningPoint ;
  rdfs:label "Performers of poetry use facial expressions to bring the poems to life."@en ;
  dcterms:modified "2026-06-07T15:30:29.286868Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8035-4
  a curric:KeyLearningPoint ;
  rdfs:label """Using the body to make the performance exciting to watch is a technique that
  performers of poetry use."""@en ;
  dcterms:modified "2026-06-07T15:30:29.286872Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7639-1
  a curric:KeyLearningPoint ;
  rdfs:label """Persuasion is the action or process of trying to change someone's mind or behaviour
  or convince them about something."""@en ;
  dcterms:modified "2026-06-07T15:30:29.286876Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7639-2
  a curric:KeyLearningPoint ;
  rdfs:label """Persuasion can be found all around us and is used to achieve a variety of
  purposes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.286880Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7639-3
  a curric:KeyLearningPoint ;
  rdfs:label """The appearance and layout of a persuasive advert is crucial for capturing the
  reader's interest and engaging them."""@en ;
  dcterms:modified "2026-06-07T15:30:29.286884Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7639-4
  a curric:KeyLearningPoint ;
  rdfs:label """A variety of linguistic techniques are used in persuasive adverts in order to engage
  and persuade the reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.286887Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7639-5
  a curric:KeyLearningPoint ;
  rdfs:label """Linguistic techniques like alliteration, rhetorical questions, exaggeration and
  rhyme are common in persuasive adverts."""@en ;
  dcterms:modified "2026-06-07T15:30:29.286891Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8055-1
  a curric:KeyLearningPoint ;
  rdfs:label """Texts can be recommended in a variety of ways, including online via Book Award
  websites or blogs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.286897Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8055-2
  a curric:KeyLearningPoint ;
  rdfs:label """Reflecting on likes, dislikes, puzzles and connections in relation to texts, can
  influence others to read."""@en ;
  dcterms:modified "2026-06-07T15:30:29.286901Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7677-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of a conclusion is to summarise the key points in a text, providing
  closure to the subject."""@en ;
  dcterms:modified "2026-06-07T15:30:29.286905Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7677-2
  a curric:KeyLearningPoint ;
  rdfs:label """A summary sentence is the opening sentence of a conclusion and summarises the key
  points in a text."""@en ;
  dcterms:modified "2026-06-07T15:30:29.286909Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7677-3
  a curric:KeyLearningPoint ;
  rdfs:label "A conclusion begins with a formal fronted adverbial."@en ;
  dcterms:modified "2026-06-07T15:30:29.286912Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7677-4
  a curric:KeyLearningPoint ;
  rdfs:label "There are no new facts or information about the subject in the conclusion."@en ;
  dcterms:modified "2026-06-07T15:30:29.286916Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7677-5
  a curric:KeyLearningPoint ;
  rdfs:label """A conclusion finishes with the writer suggesting to the reader how to find out more
  about the subject."""@en ;
  dcterms:modified "2026-06-07T15:30:29.286920Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7675-1
  a curric:KeyLearningPoint ;
  rdfs:label """The plan includes keywords and subject-specific vocabulary related to the
  section."""@en ;
  dcterms:modified "2026-06-07T15:30:29.286975Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7675-2
  a curric:KeyLearningPoint ;
  rdfs:label "Taking notes is a skill."@en ;
  dcterms:modified "2026-06-07T15:30:29.286979Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7675-3
  a curric:KeyLearningPoint ;
  rdfs:label """Notes should not be written in full sentences and bullet points can be used to order
  notes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.286983Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7675-4
  a curric:KeyLearningPoint ;
  rdfs:label "Key vocabulary and linguistic devices should be logged in a plan."@en ;
  dcterms:modified "2026-06-07T15:30:29.286987Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7675-5
  a curric:KeyLearningPoint ;
  rdfs:label "The plan should be clearly structured in the order of the section."@en ;
  dcterms:modified "2026-06-07T15:30:29.286991Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3402-1
  a curric:KeyLearningPoint ;
  rdfs:label "A subheading signals to the reader what the section is about."@en ;
  dcterms:modified "2026-06-07T15:30:29.286994Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3402-2
  a curric:KeyLearningPoint ;
  rdfs:label """Careful selection of nouns and pronouns ensures cohesion within sentences and across
  sections of the report."""@en ;
  dcterms:modified "2026-06-07T15:30:29.286998Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3402-3
  a curric:KeyLearningPoint ;
  rdfs:label """A section about one feature of the report's subject contains specific facts and
  information to keep the reader engaged."""@en ;
  dcterms:modified "2026-06-07T15:30:29.287002Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3402-4
  a curric:KeyLearningPoint ;
  rdfs:label """Writers choose varied fronted adverbials and different sentence types to ensure the
  text flows for the reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.287006Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3402-5
  a curric:KeyLearningPoint ;
  rdfs:label """Sentences should be said aloud before writing to ensure they make sense and read
  back once written to check for errors."""@en ;
  dcterms:modified "2026-06-07T15:30:29.287010Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4887-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of a conclusion is to summarise the information of the text for the
  reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.287341Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4887-2
  a curric:KeyLearningPoint ;
  rdfs:label "A summary sentence summarises the key information from the text."@en ;
  dcterms:modified "2026-06-07T15:30:29.287345Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4887-3
  a curric:KeyLearningPoint ;
  rdfs:label "A conclusion can begin with a formal fronted adverbial."@en ;
  dcterms:modified "2026-06-07T15:30:29.287349Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4887-4
  a curric:KeyLearningPoint ;
  rdfs:label "No new information about the subject is given to the reader in the conclusion."@en ;
  dcterms:modified "2026-06-07T15:30:29.287353Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4887-5
  a curric:KeyLearningPoint ;
  rdfs:label """A conclusion finishes with the writer suggesting to the reader how to find
  out more."""@en ;
  dcterms:modified "2026-06-07T15:30:29.287357Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5468-1
  a curric:KeyLearningPoint ;
  rdfs:label "A theme is a big idea, topic or message that recurs in a story."@en ;
  dcterms:modified "2026-06-07T15:30:29.287588Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5468-2
  a curric:KeyLearningPoint ;
  rdfs:label """Anansi folktales explore themes relating to character in order to teach an important
  moral or lesson."""@en ;
  dcterms:modified "2026-06-07T15:30:29.287592Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5468-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Anansi and the Antelope Baby' explores themes such as trickery, kindness, strength
  and loyalty."""@en ;
  dcterms:modified "2026-06-07T15:30:29.287596Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5468-4
  a curric:KeyLearningPoint ;
  rdfs:label "Exploring themes can help us infer greater meaning from a story."@en ;
  dcterms:modified "2026-06-07T15:30:29.287600Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5468-5
  a curric:KeyLearningPoint ;
  rdfs:label """Anansi and Antelope use their strength in different ways to show one another
  kindness and protection."""@en ;
  dcterms:modified "2026-06-07T15:30:29.287603Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7861-1
  a curric:KeyLearningPoint ;
  rdfs:label "Arthur is chosen for the mission by default"@en ;
  dcterms:modified "2026-06-07T15:30:29.287622Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7861-2
  a curric:KeyLearningPoint ;
  rdfs:label """A hero is a person who displays exceptional courage, bravery, selflessness in the
  face of adversity"""@en ;
  dcterms:modified "2026-06-07T15:30:29.287626Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7861-3
  a curric:KeyLearningPoint ;
  rdfs:label "The townspeople think he is unlikely to succeed"@en ;
  dcterms:modified "2026-06-07T15:30:29.287631Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7861-4
  a curric:KeyLearningPoint ;
  rdfs:label "Arthur proves that their views are incorrect and shows many qualities of a hero"@en ;
  dcterms:modified "2026-06-07T15:30:29.287635Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1077-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Desolate' is an adjective which means feeling miserable, depressed or lonely."@en ;
  dcterms:modified "2026-06-07T15:30:29.287639Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1077-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Melancholy' is an adjective which means gloomy or depressed, despairing about
  everything."""@en ;
  dcterms:modified "2026-06-07T15:30:29.287643Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1077-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Inconsolable' is an adjective which means very unhappy or heartbroken; feeling so
  sad it's impossible to cheer you up."""@en ;
  dcterms:modified "2026-06-07T15:30:29.287647Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1077-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Wistful', 'glum' and 'yearning' are other rich vocabulary associated with feeling
  sad."""@en ;
  dcterms:modified "2026-06-07T15:30:29.287653Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27779-1
  a curric:KeyLearningPoint ;
  rdfs:label """A speaker can engage an audience through a variety of techniques, including
  repetition."""@en ;
  dcterms:modified "2026-06-07T15:30:29.287657Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27779-2
  a curric:KeyLearningPoint ;
  rdfs:label """Martin Luther King Jr.'s famous speech entitled 'I Have A Dream' uses repetition to
  engage the audience."""@en ;
  dcterms:modified "2026-06-07T15:30:29.287660Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27779-3
  a curric:KeyLearningPoint ;
  rdfs:label """‘I Have a Dream’ by Martin Luther King Jr. was written to help bring about racial
  equality."""@en ;
  dcterms:modified "2026-06-07T15:30:29.287664Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27606-1
  a curric:KeyLearningPoint ;
  rdfs:label "Fairy tales are fiction stories about magical and imaginary beings and lands."@en ;
  dcterms:modified "2026-06-07T15:30:29.287684Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27606-2
  a curric:KeyLearningPoint ;
  rdfs:label """Fairy tales belong to the genre of folklore in which stories are orally shared and
  passed down over time."""@en ;
  dcterms:modified "2026-06-07T15:30:29.287688Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27606-3
  a curric:KeyLearningPoint ;
  rdfs:label "Stories can be structured in four parts and each part has a different purpose."@en ;
  dcterms:modified "2026-06-07T15:30:29.287691Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27606-4
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to sequence a story correctly so that it can be enjoyed and
  understood."""@en ;
  dcterms:modified "2026-06-07T15:30:29.287695Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1098-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Precipitous' is an adjective which means steep or dangerously high."@en ;
  dcterms:modified "2026-06-07T15:30:29.287719Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1098-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Towering' is an adjective which means extremely tall."@en ;
  dcterms:modified "2026-06-07T15:30:29.287722Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1098-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Rugged' is an adjective which means rough, uneven or craggy."@en ;
  dcterms:modified "2026-06-07T15:30:29.287726Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1098-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Steep', 'summit' and 'crevasse' are other rich vocabulary associated with
  mountains."""@en ;
  dcterms:modified "2026-06-07T15:30:29.287730Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8464-1
  a curric:KeyLearningPoint ;
  rdfs:label """Reading aloud involves using an expressive voice, varying volume, emphasising
  keywords and using facial expressions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.287777Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8464-2
  a curric:KeyLearningPoint ;
  rdfs:label """Roald Dahl uses repetition, ambiguity and a cliffhanger to create a scary atmosphere
  in the opening chapter."""@en ;
  dcterms:modified "2026-06-07T15:30:29.287781Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8464-3
  a curric:KeyLearningPoint ;
  rdfs:label """Inferring is about drawing conclusions or making educated guesses based on
  information and clues provided in a text."""@en ;
  dcterms:modified "2026-06-07T15:30:29.287784Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8464-4
  a curric:KeyLearningPoint ;
  rdfs:label """Evidence from the text is used to support inferences we make about a character or an
  event in a text."""@en ;
  dcterms:modified "2026-06-07T15:30:29.287788Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8464-5
  a curric:KeyLearningPoint ;
  rdfs:label """Precise vocabulary choices, setting descriptions and purposeful sentence structures
  are used to build suspense."""@en ;
  dcterms:modified "2026-06-07T15:30:29.287792Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5697-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the build-up is to develop the characters and introduce a problem to
  increase the tension."""@en ;
  dcterms:modified "2026-06-07T15:30:29.287796Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5697-2
  a curric:KeyLearningPoint ;
  rdfs:label "Precise and ambitious vocabulary is logged on a plan for future use."@en ;
  dcterms:modified "2026-06-07T15:30:29.287799Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5697-3
  a curric:KeyLearningPoint ;
  rdfs:label """Notes should not be written in full sentences and bullet points can be used to make
  notes clear."""@en ;
  dcterms:modified "2026-06-07T15:30:29.287803Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5697-4
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials of time, place and manner indicate when, where and how an action
  takes place."""@en ;
  dcterms:modified "2026-06-07T15:30:29.287807Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1037-1
  a curric:KeyLearningPoint ;
  rdfs:label "Presenting involves speaking in front of others and listening to others."@en ;
  dcterms:modified "2026-06-07T15:30:29.287813Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1037-2
  a curric:KeyLearningPoint ;
  rdfs:label """Presenting involves speaking with clear diction and suitable volume, making eye
  contact and using strong body language."""@en ;
  dcterms:modified "2026-06-07T15:30:29.287817Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1037-3
  a curric:KeyLearningPoint ;
  rdfs:label "Practising pronouncing tricky words helps develop clear diction when presenting."@en ;
  dcterms:modified "2026-06-07T15:30:29.287820Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1037-4
  a curric:KeyLearningPoint ;
  rdfs:label "Rehearsing helps the presenter to speak more confidently and fluently."@en ;
  dcterms:modified "2026-06-07T15:30:29.287824Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1037-5
  a curric:KeyLearningPoint ;
  rdfs:label "Pauses at the end of sentences can help the audience follow what is being said."@en ;
  dcterms:modified "2026-06-07T15:30:29.287828Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1062-1
  a curric:KeyLearningPoint ;
  rdfs:label """Notes should not be written in full sentences and bullet points can be used to order
  notes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.287880Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1062-2
  a curric:KeyLearningPoint ;
  rdfs:label """Viewpoint fronted adverbials and formal fronted adverbials are used at the start of
  sentences for cohesion."""@en ;
  dcterms:modified "2026-06-07T15:30:29.287885Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1062-3
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the diet paragraph is to show how the diet of the Mesolithic period
  differed to that of the Neolithic."""@en ;
  dcterms:modified "2026-06-07T15:30:29.287890Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1062-4
  a curric:KeyLearningPoint ;
  rdfs:label """Mesolithic people were nomadic hunter-gatherers (they hunted animals and foraged for
  berries for food.)"""@en ;
  dcterms:modified "2026-06-07T15:30:29.287893Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1062-5
  a curric:KeyLearningPoint ;
  rdfs:label "Neolithic people began farming, growing crops and using domesticated animals."@en ;
  dcterms:modified "2026-06-07T15:30:29.287897Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7882-1
  a curric:KeyLearningPoint ;
  rdfs:label """The text is told from the perspective of Julie; she reflects on her time in Year 6
  when Chingis joined her class."""@en ;
  dcterms:modified "2026-06-07T15:30:29.287901Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7882-2
  a curric:KeyLearningPoint ;
  rdfs:label """Chingis is a young boy who, along with his brother Nergui, immigrates from Mongolia
  to Liverpool."""@en ;
  dcterms:modified "2026-06-07T15:30:29.287905Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7882-3
  a curric:KeyLearningPoint ;
  rdfs:label """The text explores the rich history of Chingis’ home country, its landscape and
  nomadic culture."""@en ;
  dcterms:modified "2026-06-07T15:30:29.287909Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7882-4
  a curric:KeyLearningPoint ;
  rdfs:label """A theme is a big idea, topic or message that recurs within a story; identifying
  themes within a text involves inference."""@en ;
  dcterms:modified "2026-06-07T15:30:29.287913Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7882-5
  a curric:KeyLearningPoint ;
  rdfs:label """Julie begins to understand the challenges that Chingis and his family face in trying
  to remain in the country."""@en ;
  dcterms:modified "2026-06-07T15:30:29.287918Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1304-1
  a curric:KeyLearningPoint ;
  rdfs:label "Adding the suffix -ing turns the verb into the progressive tense."@en ;
  dcterms:modified "2026-06-07T15:30:29.287960Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1304-2
  a curric:KeyLearningPoint ;
  rdfs:label "When the word ends in 'e', remove the 'e' and add the suffix -ing."@en ;
  dcterms:modified "2026-06-07T15:30:29.287966Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1304-3
  a curric:KeyLearningPoint ;
  rdfs:label "When the word ends in 'y', just add the suffix -ing."@en ;
  dcterms:modified "2026-06-07T15:30:29.287970Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1304-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: length, strength and fruit."@en ;
  dcterms:modified "2026-06-07T15:30:29.287974Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6738-1
  a curric:KeyLearningPoint ;
  rdfs:label "Writing is most successful when it is planned."@en ;
  dcterms:modified "2026-06-07T15:30:29.289641Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6738-2
  a curric:KeyLearningPoint ;
  rdfs:label """We can plan to describe particular details and use figurative language to build a
  particular mood."""@en ;
  dcterms:modified "2026-06-07T15:30:29.289647Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6738-3
  a curric:KeyLearningPoint ;
  rdfs:label """Our plan will cover two events from the build-up of 'A Kind of Spark', using a
  tense, anxious mood."""@en ;
  dcterms:modified "2026-06-07T15:30:29.289651Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6738-4
  a curric:KeyLearningPoint ;
  rdfs:label """For each event, we will describe it in the third person and reflect on it using
  internal monologue in the first person."""@en ;
  dcterms:modified "2026-06-07T15:30:29.289656Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5662-1
  a curric:KeyLearningPoint ;
  rdfs:label """Beowulf arrives at Heorot, the Danish court, and he explains his plan to defeat
  Grendel to King Hrothgar."""@en ;
  dcterms:modified "2026-06-07T15:30:29.289694Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5662-2
  a curric:KeyLearningPoint ;
  rdfs:label """One Dane, Unferth, confronts Beowulf and says that he stands no chance against
  Grendel."""@en ;
  dcterms:modified "2026-06-07T15:30:29.289698Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5662-3
  a curric:KeyLearningPoint ;
  rdfs:label """We are given the impression that Beowulf is very confident and that Unferth is very
  rude."""@en ;
  dcterms:modified "2026-06-07T15:30:29.289702Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5662-4
  a curric:KeyLearningPoint ;
  rdfs:label "We can find evidence within the text to support these impressions."@en ;
  dcterms:modified "2026-06-07T15:30:29.289706Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5662-5
  a curric:KeyLearningPoint ;
  rdfs:label "Authors may consciously create impressions by dropping hints in a text."@en ;
  dcterms:modified "2026-06-07T15:30:29.289709Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8054-1
  a curric:KeyLearningPoint ;
  rdfs:label """Historical fiction is a genre in which a fictional plot takes place in the setting
  of particular real historical events."""@en ;
  dcterms:modified "2026-06-07T15:30:29.289713Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8054-2
  a curric:KeyLearningPoint ;
  rdfs:label """Reading about important figures in history can offer readers inspiration in their
  own lives."""@en ;
  dcterms:modified "2026-06-07T15:30:29.289719Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8054-3
  a curric:KeyLearningPoint ;
  rdfs:label """Understanding an inspirational figure's motivations can lead us to connecting with
  them on an emotional level."""@en ;
  dcterms:modified "2026-06-07T15:30:29.289723Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1072-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Tenacious' is an adjective which means determined or strong-willed."@en ;
  dcterms:modified "2026-06-07T15:30:29.289727Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1072-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Persevere' is a verb which means to keep going or carry on."@en ;
  dcterms:modified "2026-06-07T15:30:29.289730Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1072-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Ambitious', 'determined', 'committed' and 'dedicated' are other rich vocabulary
  associated with trying hard."""@en ;
  dcterms:modified "2026-06-07T15:30:29.289734Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1394-1
  a curric:KeyLearningPoint ;
  rdfs:label "In polysyllabic words, some vowels can be unstressed and hard to hear and spell."@en ;
  dcterms:modified "2026-06-07T15:30:29.289738Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1394-2
  a curric:KeyLearningPoint ;
  rdfs:label "Saying the word how it is spelt can help to learn the spelling."@en ;
  dcterms:modified "2026-06-07T15:30:29.290269Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1394-3
  a curric:KeyLearningPoint ;
  rdfs:label "Spotting a word inside another word can help to learn the spelling."@en ;
  dcterms:modified "2026-06-07T15:30:29.290277Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1394-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: favourite, persuade and queue."@en ;
  dcterms:modified "2026-06-07T15:30:29.290281Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8032-1
  a curric:KeyLearningPoint ;
  rdfs:label """Reading and rereading poems leads to a richer response and a greater understanding
  of language within the poem."""@en ;
  dcterms:modified "2026-06-07T15:30:29.290285Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8032-2
  a curric:KeyLearningPoint ;
  rdfs:label """The structure of a poem plays a crucial role in conveying the poet's message and
  evoking emotions in the reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.290289Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8032-3
  a curric:KeyLearningPoint ;
  rdfs:label """Language is how a poet expresses emotions, ideas and experiences using imagery,
  simile and other literary devices."""@en ;
  dcterms:modified "2026-06-07T15:30:29.290293Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8032-4
  a curric:KeyLearningPoint ;
  rdfs:label "A theme is a big idea, topic or message that recurs in a poem."@en ;
  dcterms:modified "2026-06-07T15:30:29.290297Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8032-5
  a curric:KeyLearningPoint ;
  rdfs:label """Engaging in conversations about poems allows us to make connections with our own
  lives and the world around us."""@en ;
  dcterms:modified "2026-06-07T15:30:29.290301Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8094-1
  a curric:KeyLearningPoint ;
  rdfs:label """We can develop our personal response to a text by reflecting on what we have read so
  far."""@en ;
  dcterms:modified "2026-06-07T15:30:29.290323Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8094-2
  a curric:KeyLearningPoint ;
  rdfs:label """When giving a personal response, we can focus on emotional impact, characters,
  narrative elements, atmosphere & setting."""@en ;
  dcterms:modified "2026-06-07T15:30:29.290327Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8094-3
  a curric:KeyLearningPoint ;
  rdfs:label """One of the prominent themes in the text is survival; it follows a family as they
  struggle to survive during a civil war."""@en ;
  dcterms:modified "2026-06-07T15:30:29.290331Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8094-4
  a curric:KeyLearningPoint ;
  rdfs:label """Take-away ideas within a graphic novel may link to themes that are explored and
  developed in it."""@en ;
  dcterms:modified "2026-06-07T15:30:29.290335Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1401-1
  a curric:KeyLearningPoint ;
  rdfs:label "The suffix -ity turns adjectives into abstract nouns."@en ;
  dcterms:modified "2026-06-07T15:30:29.290558Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1401-2
  a curric:KeyLearningPoint ;
  rdfs:label "When a word ends in ‘e’, remove the ‘e’, then add the suffix -ity."@en ;
  dcterms:modified "2026-06-07T15:30:29.290562Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1401-3
  a curric:KeyLearningPoint ;
  rdfs:label "When a word ends in a consonant, just add the suffix -ity."@en ;
  dcterms:modified "2026-06-07T15:30:29.290566Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1401-4
  a curric:KeyLearningPoint ;
  rdfs:label """How to spell irregular words with the suffix -ity, such as ability and
  simplicity."""@en ;
  dcterms:modified "2026-06-07T15:30:29.290570Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1401-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: arrive, actual and actually."@en ;
  dcterms:modified "2026-06-07T15:30:29.290574Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8076-1
  a curric:KeyLearningPoint ;
  rdfs:label "Poems can be written in many different forms and structures."@en ;
  dcterms:modified "2026-06-07T15:30:29.290578Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8076-2
  a curric:KeyLearningPoint ;
  rdfs:label """Poems about personal experiences can be based on emotions and feelings we have
  towards something."""@en ;
  dcterms:modified "2026-06-07T15:30:29.290582Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8076-3
  a curric:KeyLearningPoint ;
  rdfs:label """To help generate ideas, we can complete a mind map of actions and events that are
  associated with our experience."""@en ;
  dcterms:modified "2026-06-07T15:30:29.290586Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8076-4
  a curric:KeyLearningPoint ;
  rdfs:label "Creating a repeated line (anaphora) can support us when writing a poem."@en ;
  dcterms:modified "2026-06-07T15:30:29.290590Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8076-5
  a curric:KeyLearningPoint ;
  rdfs:label """We can experiment with word order, punctuation and phrasing when developing our
  poem."""@en ;
  dcterms:modified "2026-06-07T15:30:29.290594Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1358-1
  a curric:KeyLearningPoint ;
  rdfs:label """Many suffixes follow the same or similar spelling rules to create generalised rules,
  but there are always exceptions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.290644Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1358-2
  a curric:KeyLearningPoint ;
  rdfs:label "The suffixes -ed and -ing change the tense of a word."@en ;
  dcterms:modified "2026-06-07T15:30:29.290649Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1358-3
  a curric:KeyLearningPoint ;
  rdfs:label "The suffixes -s and -es change a noun from singular to plural."@en ;
  dcterms:modified "2026-06-07T15:30:29.290653Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1358-4
  a curric:KeyLearningPoint ;
  rdfs:label """The suffixes -en, -ate, -ise and -ify often turn adjectives and nouns into
  verbs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.290657Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1358-5
  a curric:KeyLearningPoint ;
  rdfs:label "The suffixes -al, -ic, -ful and -less create adjectives."@en ;
  dcterms:modified "2026-06-07T15:30:29.290661Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1039-1
  a curric:KeyLearningPoint ;
  rdfs:label "A simple sentence is a main clause about one idea."@en ;
  dcterms:modified "2026-06-07T15:30:29.290716Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1039-2
  a curric:KeyLearningPoint ;
  rdfs:label "A compound sentence is a sentence formed of two main clauses and a joining word."@en ;
  dcterms:modified "2026-06-07T15:30:29.290720Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1039-3
  a curric:KeyLearningPoint ;
  rdfs:label """Co-ordinating conjunction is the term for a word that joins two main clauses to form
  a compound sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.290724Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1039-4
  a curric:KeyLearningPoint ;
  rdfs:label "There are three co-ordinating conjunctions: \"and\", \"but\" and \"or\"."@en ;
  dcterms:modified "2026-06-07T15:30:29.290728Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1039-5
  a curric:KeyLearningPoint ;
  rdfs:label "Each co-ordinating conjunction has a different purpose."@en ;
  dcterms:modified "2026-06-07T15:30:29.290732Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4889-1
  a curric:KeyLearningPoint ;
  rdfs:label "a non-chronological report is a type of non-fiction text"@en ;
  dcterms:modified "2026-06-07T15:30:29.290736Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4889-2
  a curric:KeyLearningPoint ;
  rdfs:label """the purpose of a non-chronological report is to inform the reader about a particular
  subject"""@en ;
  dcterms:modified "2026-06-07T15:30:29.290740Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4889-3
  a curric:KeyLearningPoint ;
  rdfs:label """information in a non-chronological report is organised using a title, subheadings
  and paragraphs"""@en ;
  dcterms:modified "2026-06-07T15:30:29.290744Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4889-4
  a curric:KeyLearningPoint ;
  rdfs:label """linguistic features help to introduce, link and bring to life specific, factual
  information"""@en ;
  dcterms:modified "2026-06-07T15:30:29.290748Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8634-1
  a curric:KeyLearningPoint ;
  rdfs:label "‘The Borrowers’ is a fantasy fiction text written by Mary Norton in 1952."@en ;
  dcterms:modified "2026-06-07T15:30:29.290752Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8634-2
  a curric:KeyLearningPoint ;
  rdfs:label """‘The Borrowers’ is about miniature people, who secretly live under the floorboards
  of an English house."""@en ;
  dcterms:modified "2026-06-07T15:30:29.290758Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8634-3
  a curric:KeyLearningPoint ;
  rdfs:label """The protagonist in ‘The Borrowers’ is Arrietty, who is the daughter of Pod and
  Homily."""@en ;
  dcterms:modified "2026-06-07T15:30:29.290762Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8634-4
  a curric:KeyLearningPoint ;
  rdfs:label """It is important for stories to have a clear structure so that readers can understand
  and enjoy them."""@en ;
  dcterms:modified "2026-06-07T15:30:29.290766Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4854-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the recount section is to engage the reader and provide them with
  specific facts about the topic."""@en ;
  dcterms:modified "2026-06-07T15:30:29.290770Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4854-2
  a curric:KeyLearningPoint ;
  rdfs:label "Using a range of different sentence structures enhances text cohesion."@en ;
  dcterms:modified "2026-06-07T15:30:29.290774Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4854-3
  a curric:KeyLearningPoint ;
  rdfs:label """Using different types of complex sentence enables us to share information with our
  reader in different ways."""@en ;
  dcterms:modified "2026-06-07T15:30:29.290778Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4854-4
  a curric:KeyLearningPoint ;
  rdfs:label """When writing, we should use our plans and success criteria so our writing can be as
  effective as possible."""@en ;
  dcterms:modified "2026-06-07T15:30:29.290782Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1311-1
  a curric:KeyLearningPoint ;
  rdfs:label "The suffix -ous often turns nouns into adjectives and often means 'full of'."@en ;
  dcterms:modified "2026-06-07T15:30:29.290809Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1311-2
  a curric:KeyLearningPoint ;
  rdfs:label "If the root word ends in 'ge', just add -ous."@en ;
  dcterms:modified "2026-06-07T15:30:29.290813Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1311-3
  a curric:KeyLearningPoint ;
  rdfs:label "If the root word ends in 'e', remove the 'e', then add -ous."@en ;
  dcterms:modified "2026-06-07T15:30:29.290817Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1311-4
  a curric:KeyLearningPoint ;
  rdfs:label "If the root word ends in 'our', change 'our' to 'or', then add -ous."@en ;
  dcterms:modified "2026-06-07T15:30:29.290823Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1311-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: promise and favourite."@en ;
  dcterms:modified "2026-06-07T15:30:29.290827Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2743-1
  a curric:KeyLearningPoint ;
  rdfs:label "A modal verb is a type of auxiliary verb."@en ;
  dcterms:modified "2026-06-07T15:30:29.293322Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2743-2
  a curric:KeyLearningPoint ;
  rdfs:label "A modal verb is most often paired with the main verb of a clause."@en ;
  dcterms:modified "2026-06-07T15:30:29.293326Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2743-3
  a curric:KeyLearningPoint ;
  rdfs:label "A modal verb is not paired with the main verb if it appears in a question."@en ;
  dcterms:modified "2026-06-07T15:30:29.293330Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2743-4
  a curric:KeyLearningPoint ;
  rdfs:label "Modal verbs are often used in speech sentences and persuasive writing."@en ;
  dcterms:modified "2026-06-07T15:30:29.293334Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2743-5
  a curric:KeyLearningPoint ;
  rdfs:label """A modal verb expresses the degree of possibility, intent, ability or necessity of
  the clause."""@en ;
  dcterms:modified "2026-06-07T15:30:29.293337Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5695-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the opening is to engage the reader and introduce the setting and
  characters."""@en ;
  dcterms:modified "2026-06-07T15:30:29.293341Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5695-2
  a curric:KeyLearningPoint ;
  rdfs:label "Precise and ambitious vocabulary is logged on a plan for future use."@en ;
  dcterms:modified "2026-06-07T15:30:29.293345Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5695-3
  a curric:KeyLearningPoint ;
  rdfs:label """Notes should not be written in full sentences and bullet points can be used to make
  notes clear."""@en ;
  dcterms:modified "2026-06-07T15:30:29.293351Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5695-4
  a curric:KeyLearningPoint ;
  rdfs:label "Show and tell vocabulary describes character emotions in greater detail."@en ;
  dcterms:modified "2026-06-07T15:30:29.293356Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5695-5
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials of time and place indicate when and where an action takes
  place."""@en ;
  dcterms:modified "2026-06-07T15:30:29.293360Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7628-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the resolution is to resolve a story and to solve any of the
  characters’ problems."""@en ;
  dcterms:modified "2026-06-07T15:30:29.293463Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7628-2
  a curric:KeyLearningPoint ;
  rdfs:label """A range of sentence types (simple, compound and complex) improves text flow for the
  reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.293467Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7628-3
  a curric:KeyLearningPoint ;
  rdfs:label "Notes from a plan can be used to form full sentences."@en ;
  dcterms:modified "2026-06-07T15:30:29.293471Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7628-4
  a curric:KeyLearningPoint ;
  rdfs:label "Paragraphs are used to indicate the start of a new idea or key moment."@en ;
  dcterms:modified "2026-06-07T15:30:29.293477Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7628-5
  a curric:KeyLearningPoint ;
  rdfs:label """Direct speech is punctuated using inverted commas. Dialogue moves the action
  forward."""@en ;
  dcterms:modified "2026-06-07T15:30:29.293481Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4875-1
  a curric:KeyLearningPoint ;
  rdfs:label "Editing is an essential part of the writing process."@en ;
  dcterms:modified "2026-06-07T15:30:29.293509Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4875-2
  a curric:KeyLearningPoint ;
  rdfs:label """Editing does not involve rewriting the entire piece but is about being selective
  about what to edit and improve."""@en ;
  dcterms:modified "2026-06-07T15:30:29.293513Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4875-3
  a curric:KeyLearningPoint ;
  rdfs:label """Punctuation, sentence structure, grammar, vocabulary precision and spelling can all
  be edited."""@en ;
  dcterms:modified "2026-06-07T15:30:29.293519Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4875-4
  a curric:KeyLearningPoint ;
  rdfs:label "The purpose of editing is to ensure the text meets its text purpose."@en ;
  dcterms:modified "2026-06-07T15:30:29.293523Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1042-1
  a curric:KeyLearningPoint ;
  rdfs:label "The position of an adverbial clause can move in an adverbial complex sentence."@en ;
  dcterms:modified "2026-06-07T15:30:29.293567Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1042-2
  a curric:KeyLearningPoint ;
  rdfs:label "The adverbial clause can come first in the sentence followed by the main clause."@en ;
  dcterms:modified "2026-06-07T15:30:29.293571Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1042-3
  a curric:KeyLearningPoint ;
  rdfs:label """If the adverbial clause comes first in the sentence, it is followed by a comma to
  separate it from the main clause."""@en ;
  dcterms:modified "2026-06-07T15:30:29.293575Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1042-4
  a curric:KeyLearningPoint ;
  rdfs:label "The main clause can come first in the sentence followed by the adverbial clause."@en ;
  dcterms:modified "2026-06-07T15:30:29.293579Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1042-5
  a curric:KeyLearningPoint ;
  rdfs:label "If the main clause comes first in the sentence, no comma is used."@en ;
  dcterms:modified "2026-06-07T15:30:29.293583Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6100-1
  a curric:KeyLearningPoint ;
  rdfs:label "Information can be gathered from a range of different sources."@en ;
  dcterms:modified "2026-06-07T15:30:29.293618Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6100-2
  a curric:KeyLearningPoint ;
  rdfs:label "Credibility of each source must be determined."@en ;
  dcterms:modified "2026-06-07T15:30:29.293622Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6100-3
  a curric:KeyLearningPoint ;
  rdfs:label "Origin of a source must be cited."@en ;
  dcterms:modified "2026-06-07T15:30:29.293626Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6100-4
  a curric:KeyLearningPoint ;
  rdfs:label """Established facts and relevant evidence can be used to strengthen the writer's
  position on a subject."""@en ;
  dcterms:modified "2026-06-07T15:30:29.293632Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6100-5
  a curric:KeyLearningPoint ;
  rdfs:label "Relevant statistics can enhance the evidence cited."@en ;
  dcterms:modified "2026-06-07T15:30:29.293636Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6732-1
  a curric:KeyLearningPoint ;
  rdfs:label "Writing is most successful when structure, content and vocabulary are planned."@en ;
  dcterms:modified "2026-06-07T15:30:29.293860Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6732-2
  a curric:KeyLearningPoint ;
  rdfs:label """We aim to use a range of narrative elements in our writing and to set an appropriate
  mood with them."""@en ;
  dcterms:modified "2026-06-07T15:30:29.293866Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6732-3
  a curric:KeyLearningPoint ;
  rdfs:label """We use a range of cohesive devices to connect ideas, including a variety of fronted
  adverbials."""@en ;
  dcterms:modified "2026-06-07T15:30:29.293871Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6732-4
  a curric:KeyLearningPoint ;
  rdfs:label """Short sentences, rhetorical questions and 'quick' fronted adverbials of time can add
  pace to a piece of writing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.293874Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6732-5
  a curric:KeyLearningPoint ;
  rdfs:label """Dashes can add dramatic effect, often by restating the noun phrase that is being
  described in a different way."""@en ;
  dcterms:modified "2026-06-07T15:30:29.293878Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4830-1
  a curric:KeyLearningPoint ;
  rdfs:label "Writing at speed is a valuable skill to develop."@en ;
  dcterms:modified "2026-06-07T15:30:29.294081Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4830-2
  a curric:KeyLearningPoint ;
  rdfs:label "Writing at speed can decrease the legibility and accuracy of your writing."@en ;
  dcterms:modified "2026-06-07T15:30:29.294085Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4830-3
  a curric:KeyLearningPoint ;
  rdfs:label """Regular practice, hand exercises and taking breaks can help to improve the speed and
  accuracy of your handwriting."""@en ;
  dcterms:modified "2026-06-07T15:30:29.294089Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4830-4
  a curric:KeyLearningPoint ;
  rdfs:label "When you are confident to write, you can increase the speed that you take notes."@en ;
  dcterms:modified "2026-06-07T15:30:29.294095Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4830-5
  a curric:KeyLearningPoint ;
  rdfs:label "Note-taking can improve your learning experience."@en ;
  dcterms:modified "2026-06-07T15:30:29.294101Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7635-1
  a curric:KeyLearningPoint ;
  rdfs:label """Precise and ambitious vocabulary related to the five senses should be included in
  the plan."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295060Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7635-2
  a curric:KeyLearningPoint ;
  rdfs:label """Linguistic devices such as figurative language (similes and personification) should
  be included in the plan."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295064Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7635-3
  a curric:KeyLearningPoint ;
  rdfs:label """The plan should be written in note-form and notes are not written in full
  sentences."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295068Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7635-4
  a curric:KeyLearningPoint ;
  rdfs:label "The 'zoom-in' structure guides the descriptive writing paragraph."@en ;
  dcterms:modified "2026-06-07T15:30:29.295072Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1063-1
  a curric:KeyLearningPoint ;
  rdfs:label "A subheading signals to the reader what the section is about."@en ;
  dcterms:modified "2026-06-07T15:30:29.295076Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1063-2
  a curric:KeyLearningPoint ;
  rdfs:label """A section about one feature of the report's subject contains specific facts and
  information to keep the reader engaged."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295082Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1063-3
  a curric:KeyLearningPoint ;
  rdfs:label """Writers choose varied fronted adverbials and different sentence types to ensure the
  text flows for the reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295086Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1063-4
  a curric:KeyLearningPoint ;
  rdfs:label "A section can be composed of one paragraph."@en ;
  dcterms:modified "2026-06-07T15:30:29.295090Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1063-5
  a curric:KeyLearningPoint ;
  rdfs:label """Sentences should be said aloud before writing to ensure they make sense and read
  back once written to check for errors."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295093Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1032-1
  a curric:KeyLearningPoint ;
  rdfs:label "A subheading signals to the reader what the section is about."@en ;
  dcterms:modified "2026-06-07T15:30:29.295097Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1032-2
  a curric:KeyLearningPoint ;
  rdfs:label """A section about one feature of the report's subject contains specific facts and
  information to keep the reader engaged."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295101Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1032-3
  a curric:KeyLearningPoint ;
  rdfs:label """Writers choose varied fronted adverbials and different sentence types to ensure the
  text flows for the reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295105Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1032-4
  a curric:KeyLearningPoint ;
  rdfs:label "A section can be composed of one paragraph."@en ;
  dcterms:modified "2026-06-07T15:30:29.295109Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1032-5
  a curric:KeyLearningPoint ;
  rdfs:label """Sentences should be said aloud before writing to ensure they make sense and read
  back once written to check for errors."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295113Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1035-1
  a curric:KeyLearningPoint ;
  rdfs:label "Editing is the process of making changes to improve our writing."@en ;
  dcterms:modified "2026-06-07T15:30:29.295117Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1035-2
  a curric:KeyLearningPoint ;
  rdfs:label """When editing punctuation, missing or incorrectly used capital letters, full stops
  and commas are all checked."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295121Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1035-3
  a curric:KeyLearningPoint ;
  rdfs:label """When editing sentence structure, the way sentences are constructed is checked to
  improve and enhance text flow."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295126Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1035-4
  a curric:KeyLearningPoint ;
  rdfs:label "When editing language, choices of words and phrases are carefully reviewed."@en ;
  dcterms:modified "2026-06-07T15:30:29.295131Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8877-1
  a curric:KeyLearningPoint ;
  rdfs:label """In Chapter 2 of ‘The Iron Man’, a character named Hogarth is introduced and he
  encounters the Iron Man."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295135Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8877-2
  a curric:KeyLearningPoint ;
  rdfs:label """The Iron Man is responsible for eating the farmers’ machinery which threatens their
  livelihood and sense of safety."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295139Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8877-3
  a curric:KeyLearningPoint ;
  rdfs:label """Humanity’s response to the Iron Man is one of anger and the farmers develop a plan
  to trap and bury him."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295143Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8877-4
  a curric:KeyLearningPoint ;
  rdfs:label """We can infer deeper emotions of fear and confusion beneath humanity’s angry
  response."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295147Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8877-5
  a curric:KeyLearningPoint ;
  rdfs:label """Hogarth’s emotions shift to sorrow & guilt after the Iron Man is buried as he feels
  a sense of empathy & responsibility."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295151Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6366-1
  a curric:KeyLearningPoint ;
  rdfs:label """Alred Noyes uses figurative language to hook the reader in and create atmosphere in
  stanza one."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295173Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6366-2
  a curric:KeyLearningPoint ;
  rdfs:label "Repetition can be used to emphasise a particular word, sentence or phrase."@en ;
  dcterms:modified "2026-06-07T15:30:29.295177Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6366-3
  a curric:KeyLearningPoint ;
  rdfs:label "Personification is when a non-human thing is given human characteristics."@en ;
  dcterms:modified "2026-06-07T15:30:29.295181Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6366-4
  a curric:KeyLearningPoint ;
  rdfs:label """Metaphor is when one thing is described as another; simile involves using 'like' or
  'as' to compare two things."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295187Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6366-5
  a curric:KeyLearningPoint ;
  rdfs:label """Alliteration is when two or more words begin with the same starting sound or
  letter."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295191Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4872-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the introduction is to engage the reader and give them general
  information about the report's subject."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295240Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4872-2
  a curric:KeyLearningPoint ;
  rdfs:label "Tigers can be referred to in the singular or plural throughout a report."@en ;
  dcterms:modified "2026-06-07T15:30:29.295243Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4872-3
  a curric:KeyLearningPoint ;
  rdfs:label """Writers plan and say each sentence aloud before writing it down so that they write
  more coherent sentences."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295247Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4872-4
  a curric:KeyLearningPoint ;
  rdfs:label """The writing process involves planning, drafting, checking, editing and publishing a
  piece of writing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295251Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28947-1
  a curric:KeyLearningPoint ;
  rdfs:label "A poet uses language to express ideas, thoughts and feelings in a creative way."@en ;
  dcterms:modified "2026-06-07T15:30:29.295267Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28947-2
  a curric:KeyLearningPoint ;
  rdfs:label """Joseph Coelho is a British poet and children’s author, who was appointed Children’s
  Laureate in 2022."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295271Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28947-3
  a curric:KeyLearningPoint ;
  rdfs:label """Joseph Coelho is known for using engaging and emotive themes in his poetry, such as
  identity, family and friendship."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295275Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28947-4
  a curric:KeyLearningPoint ;
  rdfs:label "The poem 'Story Builders' reflects on the process of building a story."@en ;
  dcterms:modified "2026-06-07T15:30:29.295281Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28947-5
  a curric:KeyLearningPoint ;
  rdfs:label """When reading a poem, we can use our voice and tone to create an impression on the
  reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295286Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6117-1
  a curric:KeyLearningPoint ;
  rdfs:label """A conclusion is the final paragraph of a non-fiction text that gives general
  information about the subject."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295345Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6117-2
  a curric:KeyLearningPoint ;
  rdfs:label """A conclusion still has a subheading and an introductory sentence and it uses a range
  of cohesive devices."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295351Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6117-3
  a curric:KeyLearningPoint ;
  rdfs:label """Before we write, we should orally rehearse sentences to ensure our sentences make
  sense and flow well."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295355Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6117-4
  a curric:KeyLearningPoint ;
  rdfs:label """When we have finished our first draft of our writing, we edit it to improve and
  refine it."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295361Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6117-5
  a curric:KeyLearningPoint ;
  rdfs:label """Editing includes looking at sentence structures, vocabulary, cohesive devices,
  spelling and punctuation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295365Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6361-1
  a curric:KeyLearningPoint ;
  rdfs:label """Quotes from witnesses or experts give additional information about the event being
  reported on."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295369Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6361-2
  a curric:KeyLearningPoint ;
  rdfs:label """Quotes from witnesses are often more informal in language and tone from the rest of
  the report."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295373Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6361-3
  a curric:KeyLearningPoint ;
  rdfs:label """A reporting clause is used either before or after speech to tell the reader who the
  quote is from."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295377Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6361-4
  a curric:KeyLearningPoint ;
  rdfs:label """Inverted commas are used to demarcate speech and a piece of punctuation separates
  speech from the reporting clause."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295383Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6361-5
  a curric:KeyLearningPoint ;
  rdfs:label """A range of synonyms for 'said' and use of adverbs can offer detail about the
  emotions of the witness."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295387Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4861-1
  a curric:KeyLearningPoint ;
  rdfs:label """Notes should not be written in full sentences and bullet points can be used to order
  notes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295391Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4861-2
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the paragraph is to explain about King Tut becoming king and what he
  achieved when in power."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295395Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4861-3
  a curric:KeyLearningPoint ;
  rdfs:label """Viewpoint fronted adverbials and formal fronted adverbials are used at the start of
  sentences for cohesion."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295399Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4861-4
  a curric:KeyLearningPoint ;
  rdfs:label """A subheading signals part of a a text and should stand out from the rest of the
  text."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295403Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4861-5
  a curric:KeyLearningPoint ;
  rdfs:label "The plan should include subject-specific vocabulary."@en ;
  dcterms:modified "2026-06-07T15:30:29.295407Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5626-1
  a curric:KeyLearningPoint ;
  rdfs:label """A diary entry recounts experiences chronologically and expresses emotions, thoughts
  and feelings."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295441Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5626-2
  a curric:KeyLearningPoint ;
  rdfs:label "Exaggeration is often used to convey emotions in a diary entry."@en ;
  dcterms:modified "2026-06-07T15:30:29.295445Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5626-3
  a curric:KeyLearningPoint ;
  rdfs:label """Superlatives are used to compare one noun to an entire group of nouns, placing it at
  a higher degree."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295449Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5626-4
  a curric:KeyLearningPoint ;
  rdfs:label "Hyperbole is the use of exaggerated statements or claims."@en ;
  dcterms:modified "2026-06-07T15:30:29.295453Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5626-5
  a curric:KeyLearningPoint ;
  rdfs:label """A plan for a diary entry should include precise and ambitious vocabulary, including
  exaggeration."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295489Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6720-1
  a curric:KeyLearningPoint ;
  rdfs:label "Writing is most successful when it is planned."@en ;
  dcterms:modified "2026-06-07T15:30:29.295523Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6720-2
  a curric:KeyLearningPoint ;
  rdfs:label """Our biography of Charles Darwin will contain paragraphs organised by theme and in
  chronological order."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295527Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6720-3
  a curric:KeyLearningPoint ;
  rdfs:label """We can plan in note form, using our text map to support us in recalling information
  about the subject of the biography."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295531Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6720-4
  a curric:KeyLearningPoint ;
  rdfs:label "When we write, we use a range of cohesive devices to connect ideas together."@en ;
  dcterms:modified "2026-06-07T15:30:29.295535Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7680-1
  a curric:KeyLearningPoint ;
  rdfs:label "Presenting involves speaking in front of others and listening to others."@en ;
  dcterms:modified "2026-06-07T15:30:29.295539Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7680-2
  a curric:KeyLearningPoint ;
  rdfs:label """Presenting involves speaking with clear diction and suitable volume, making eye
  contact and using strong body language."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295542Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7680-3
  a curric:KeyLearningPoint ;
  rdfs:label "Practising pronouncing tricky words helps develop clear diction when presenting."@en ;
  dcterms:modified "2026-06-07T15:30:29.295549Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7680-4
  a curric:KeyLearningPoint ;
  rdfs:label "Rehearsing helps the presenter to speak more confidently and fluently."@en ;
  dcterms:modified "2026-06-07T15:30:29.295553Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7680-5
  a curric:KeyLearningPoint ;
  rdfs:label "Pauses at the end of sentences can help the audience follow what is being said."@en ;
  dcterms:modified "2026-06-07T15:30:29.295557Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7359-1
  a curric:KeyLearningPoint ;
  rdfs:label "A theme is a big idea, topic or message that recurs within a story."@en ;
  dcterms:modified "2026-06-07T15:30:29.295561Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7359-2
  a curric:KeyLearningPoint ;
  rdfs:label "Themes often link together and overlap."@en ;
  dcterms:modified "2026-06-07T15:30:29.295569Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7359-3
  a curric:KeyLearningPoint ;
  rdfs:label "The theme of transformation is an important theme in ‘A Christmas Carol’."@en ;
  dcterms:modified "2026-06-07T15:30:29.295573Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7359-4
  a curric:KeyLearningPoint ;
  rdfs:label """Transformation is depicted through Scrooge's journey from a miserly individual to a
  compassionate and generous one."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295577Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7359-5
  a curric:KeyLearningPoint ;
  rdfs:label """Dickens uses Scrooge’s treatment of others and their treatment of him to convey this
  change."""@en ;
  dcterms:modified "2026-06-07T15:30:29.295581Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3407-1
  a curric:KeyLearningPoint ;
  rdfs:label "Editing is the process of making changes to improve writing."@en ;
  dcterms:modified "2026-06-07T15:30:29.296130Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3407-2
  a curric:KeyLearningPoint ;
  rdfs:label """When editing punctuation, missing or incorrect punctuation, like capital letters,
  full stops and commas, is checked."""@en ;
  dcterms:modified "2026-06-07T15:30:29.296134Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3407-3
  a curric:KeyLearningPoint ;
  rdfs:label """When editing sentence structure, the flow of sentences and the variety of sentence
  types used are checked."""@en ;
  dcterms:modified "2026-06-07T15:30:29.296138Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3407-4
  a curric:KeyLearningPoint ;
  rdfs:label """When editing language, word and phrase choices are checked to ensure they meet the
  tone required."""@en ;
  dcterms:modified "2026-06-07T15:30:29.296142Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7932-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘Cloud Busting’ focuses on the relationship between two ‘friends’: Davey and
  Sam."""@en ;
  dcterms:modified "2026-06-07T15:30:29.296161Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7932-2
  a curric:KeyLearningPoint ;
  rdfs:label "The story is told as a verse novel."@en ;
  dcterms:modified "2026-06-07T15:30:29.296168Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7932-3
  a curric:KeyLearningPoint ;
  rdfs:label "‘Cloud Busting’ uses both fixed verse and free verse poetry."@en ;
  dcterms:modified "2026-06-07T15:30:29.296172Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7932-4
  a curric:KeyLearningPoint ;
  rdfs:label """‘Cloud Busting’ is written in both the present and the past, through use of
  flashbacks."""@en ;
  dcterms:modified "2026-06-07T15:30:29.296176Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7932-5
  a curric:KeyLearningPoint ;
  rdfs:label """A range of poetic forms are used by the author including haikus, blank verse,
  limericks and concrete / shape poems."""@en ;
  dcterms:modified "2026-06-07T15:30:29.296180Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7641-1
  a curric:KeyLearningPoint ;
  rdfs:label "Exaggeration is a key feature of persuasive adverts."@en ;
  dcterms:modified "2026-06-07T15:30:29.296184Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7641-2
  a curric:KeyLearningPoint ;
  rdfs:label "Comparatives and superlatives are techniques used to exaggerate and persuade."@en ;
  dcterms:modified "2026-06-07T15:30:29.296188Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7641-3
  a curric:KeyLearningPoint ;
  rdfs:label "Comparatives are used to compare two or more things."@en ;
  dcterms:modified "2026-06-07T15:30:29.296192Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7641-4
  a curric:KeyLearningPoint ;
  rdfs:label """Superlatives are used to compare one noun to an entire group of nouns, placing it at
  a higher degree."""@en ;
  dcterms:modified "2026-06-07T15:30:29.296196Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7641-5
  a curric:KeyLearningPoint ;
  rdfs:label """Comparatives and superlatives are formed using suffixes or the words 'more' and
  'most' to adapt adjectives."""@en ;
  dcterms:modified "2026-06-07T15:30:29.296200Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1337-1
  a curric:KeyLearningPoint ;
  rdfs:label """The /shun/ sound can be spelt four different ways: -tion, -cian, -sion and
  -ssion."""@en ;
  dcterms:modified "2026-06-07T15:30:29.296206Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1337-2
  a curric:KeyLearningPoint ;
  rdfs:label "The /shun/ sound is sometimes spelt 'sion' or 'ssion'."@en ;
  dcterms:modified "2026-06-07T15:30:29.296210Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1337-3
  a curric:KeyLearningPoint ;
  rdfs:label """The suffix -sion is used for the /shun/ or /zhun/ sound when the root word ends in
  'd', 'de' or 'se'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.296214Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1337-4
  a curric:KeyLearningPoint ;
  rdfs:label """The suffix -ssion is used for the /shun/ sound when the root word ends in 'ss' or
  'mit'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.296218Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1337-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: profession and develop"@en ;
  dcterms:modified "2026-06-07T15:30:29.296222Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8039-1
  a curric:KeyLearningPoint ;
  rdfs:label """Reading and rereading poems leads to a richer response and a greater understanding
  of language within them."""@en ;
  dcterms:modified "2026-06-07T15:30:29.296238Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8039-2
  a curric:KeyLearningPoint ;
  rdfs:label """Analysing a poem’s language allows the reader to observe different writing styles
  and expose diverse language choices."""@en ;
  dcterms:modified "2026-06-07T15:30:29.296244Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8039-3
  a curric:KeyLearningPoint ;
  rdfs:label """Summarising the themes and tone of a poem identifies emotions and main ideas
  conveyed within a poem."""@en ;
  dcterms:modified "2026-06-07T15:30:29.296248Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8039-4
  a curric:KeyLearningPoint ;
  rdfs:label """Engaging the five senses enriches vocabulary by making writing more engaging, vivid
  and impactful."""@en ;
  dcterms:modified "2026-06-07T15:30:29.296252Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4859-1
  a curric:KeyLearningPoint ;
  rdfs:label "King Tut was nine years old when he began ruling Egypt 3000 years ago."@en ;
  dcterms:modified "2026-06-07T15:30:29.296272Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4859-2
  a curric:KeyLearningPoint ;
  rdfs:label "King Tut changed the religion of Ancient Egypt when he ruled."@en ;
  dcterms:modified "2026-06-07T15:30:29.296276Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4859-3
  a curric:KeyLearningPoint ;
  rdfs:label """King Tut died aged 19 after ruling for 10 years. He was mummified so his body was
  preserved for 3000 years."""@en ;
  dcterms:modified "2026-06-07T15:30:29.296280Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4859-4
  a curric:KeyLearningPoint ;
  rdfs:label """The archaeologist Howard Carter discovered his body surrounded by artefacts
  in 1922."""@en ;
  dcterms:modified "2026-06-07T15:30:29.296284Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4859-5
  a curric:KeyLearningPoint ;
  rdfs:label """Two unborn mummified babies were found in the tomb so King Tut never passed the
  throne to his family."""@en ;
  dcterms:modified "2026-06-07T15:30:29.296290Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5756-1
  a curric:KeyLearningPoint ;
  rdfs:label "Editing is the process of making changes to improve our writing."@en ;
  dcterms:modified "2026-06-07T15:30:29.296306Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5756-2
  a curric:KeyLearningPoint ;
  rdfs:label "Editing can be done by oneself, with a peer or with a teacher."@en ;
  dcterms:modified "2026-06-07T15:30:29.296310Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5756-3
  a curric:KeyLearningPoint ;
  rdfs:label """When editing punctuation, missing or incorrectly used capital letters, full stops
  and commas are all checked."""@en ;
  dcterms:modified "2026-06-07T15:30:29.296316Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5756-4
  a curric:KeyLearningPoint ;
  rdfs:label """When editing sentence structure, the way sentences are constructed is checked to
  improve and enhance text flow."""@en ;
  dcterms:modified "2026-06-07T15:30:29.296323Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5756-5
  a curric:KeyLearningPoint ;
  rdfs:label "When editing language, choices of words and phrases are carefully reviewed."@en ;
  dcterms:modified "2026-06-07T15:30:29.296327Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1342-1
  a curric:KeyLearningPoint ;
  rdfs:label "The 'ough' spelling can make a variety of sounds."@en ;
  dcterms:modified "2026-06-07T15:30:29.296350Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1342-2
  a curric:KeyLearningPoint ;
  rdfs:label "The 'au' spelling can make a variety of sounds."@en ;
  dcterms:modified "2026-06-07T15:30:29.296353Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1342-3
  a curric:KeyLearningPoint ;
  rdfs:label """When you hear one of these sounds, the word might contain the 'ough' or 'au'
  spelling."""@en ;
  dcterms:modified "2026-06-07T15:30:29.296357Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1342-4
  a curric:KeyLearningPoint ;
  rdfs:label "The pronunciation of the 'au' letter string may vary depending on accent."@en ;
  dcterms:modified "2026-06-07T15:30:29.296361Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1342-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: amateur and sacrifice."@en ;
  dcterms:modified "2026-06-07T15:30:29.296365Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5492-1
  a curric:KeyLearningPoint ;
  rdfs:label """Any complex sentence is formed of at least one main clause joined to at least one
  subordinate clause."""@en ;
  dcterms:modified "2026-06-07T15:30:29.296385Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5492-2
  a curric:KeyLearningPoint ;
  rdfs:label """There are different types of subordinate clause: adverbial clause, relative clause
  and non-finite clause."""@en ;
  dcterms:modified "2026-06-07T15:30:29.296389Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5492-3
  a curric:KeyLearningPoint ;
  rdfs:label """Any subordinate clause is a group of words that contains a verb and does not make
  complete sense."""@en ;
  dcterms:modified "2026-06-07T15:30:29.296393Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5492-4
  a curric:KeyLearningPoint ;
  rdfs:label "There are three types of complex sentence: adverbial, relative and non-finite."@en ;
  dcterms:modified "2026-06-07T15:30:29.296399Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5492-5
  a curric:KeyLearningPoint ;
  rdfs:label "There are comma rules associated with clause demarcation in complex sentences."@en ;
  dcterms:modified "2026-06-07T15:30:29.296403Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8640-1
  a curric:KeyLearningPoint ;
  rdfs:label "Editing is the process of making changes to improve writing."@en ;
  dcterms:modified "2026-06-07T15:30:29.296423Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8640-2
  a curric:KeyLearningPoint ;
  rdfs:label """The job of an editor is to check punctuation and to make improvements to sentence
  structure and language choices."""@en ;
  dcterms:modified "2026-06-07T15:30:29.296430Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8640-3
  a curric:KeyLearningPoint ;
  rdfs:label """When editing punctuation, missing or incorrectly used capital letters, full stops
  and commas are checked."""@en ;
  dcterms:modified "2026-06-07T15:30:29.296434Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8640-4
  a curric:KeyLearningPoint ;
  rdfs:label """When editing sentence structure, changes to the way sentences are constructed to
  improve text flow are made."""@en ;
  dcterms:modified "2026-06-07T15:30:29.296438Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8640-5
  a curric:KeyLearningPoint ;
  rdfs:label """When editing vocabulary, reviews of word and phrase choice are made to ensure
  appropriate tone is achieved."""@en ;
  dcterms:modified "2026-06-07T15:30:29.296442Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1369-1
  a curric:KeyLearningPoint ;
  rdfs:label "The suffixes -ary and -ery can turn some words into nouns."@en ;
  dcterms:modified "2026-06-07T15:30:29.296446Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1369-2
  a curric:KeyLearningPoint ;
  rdfs:label "The ending -ery is more common."@en ;
  dcterms:modified "2026-06-07T15:30:29.296450Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1369-3
  a curric:KeyLearningPoint ;
  rdfs:label "When a word ends in a consonant, just add the suffix."@en ;
  dcterms:modified "2026-06-07T15:30:29.296454Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1369-4
  a curric:KeyLearningPoint ;
  rdfs:label "When a word ends in ‘e’, remove the ‘e’, then add the suffix."@en ;
  dcterms:modified "2026-06-07T15:30:29.296458Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1369-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: February, ordinary, necessary and interest."@en ;
  dcterms:modified "2026-06-07T15:30:29.296462Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1107-1
  a curric:KeyLearningPoint ;
  rdfs:label "Relentless is an adjective which means constant or non-stop."@en ;
  dcterms:modified "2026-06-07T15:30:29.296466Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1107-2
  a curric:KeyLearningPoint ;
  rdfs:label "Scorching is an adjective which means red-hot or blazing."@en ;
  dcterms:modified "2026-06-07T15:30:29.296470Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1107-3
  a curric:KeyLearningPoint ;
  rdfs:label "Suffocating is an adjective which means stuffy and smothering."@en ;
  dcterms:modified "2026-06-07T15:30:29.296478Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5466-1
  a curric:KeyLearningPoint ;
  rdfs:label "Anansi is a spider in African folktales and he is famous for being a trickster."@en ;
  dcterms:modified "2026-06-07T15:30:29.298266Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5466-2
  a curric:KeyLearningPoint ;
  rdfs:label """Summarising key events and ideas in a story helps to build our understanding
  of it."""@en ;
  dcterms:modified "2026-06-07T15:30:29.298270Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5466-3
  a curric:KeyLearningPoint ;
  rdfs:label "Anansi faces danger and Antelope saves him when no other animal will."@en ;
  dcterms:modified "2026-06-07T15:30:29.298274Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5466-4
  a curric:KeyLearningPoint ;
  rdfs:label """When Antelope and her baby are in danger from hunters, Anansi uses his trickery for
  good to protect Baby Antelope."""@en ;
  dcterms:modified "2026-06-07T15:30:29.298278Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5466-5
  a curric:KeyLearningPoint ;
  rdfs:label """Antelope and Anansi forged a friendship through showing acts of kindness and
  loyalty."""@en ;
  dcterms:modified "2026-06-07T15:30:29.298282Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7357-1
  a curric:KeyLearningPoint ;
  rdfs:label """Characterisation is the way an author describes and develops the personalities and
  traits of the characters in a story."""@en ;
  dcterms:modified "2026-06-07T15:30:29.299759Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7357-2
  a curric:KeyLearningPoint ;
  rdfs:label "Authors choose adjectives carefully to build a picture of a character."@en ;
  dcterms:modified "2026-06-07T15:30:29.299766Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7357-3
  a curric:KeyLearningPoint ;
  rdfs:label """The way a character treats others helps us understand a character, build an opinion
  and become invested in the story."""@en ;
  dcterms:modified "2026-06-07T15:30:29.299770Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7357-4
  a curric:KeyLearningPoint ;
  rdfs:label """Authors use contrasting characters to helps highlight particular
  characteristics."""@en ;
  dcterms:modified "2026-06-07T15:30:29.299776Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7357-5
  a curric:KeyLearningPoint ;
  rdfs:label """In the summary, Scrooge meets four ghosts who give him a new perspective on
  life."""@en ;
  dcterms:modified "2026-06-07T15:30:29.299780Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3406-1
  a curric:KeyLearningPoint ;
  rdfs:label "Editing is the process of making changes to improve writing."@en ;
  dcterms:modified "2026-06-07T15:30:29.299803Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3406-2
  a curric:KeyLearningPoint ;
  rdfs:label """When editing punctuation, missing or incorrect punctuation, like capital letters,
  full stops and commas, is checked."""@en ;
  dcterms:modified "2026-06-07T15:30:29.299807Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3406-3
  a curric:KeyLearningPoint ;
  rdfs:label """When editing sentence structure, the flow of sentences and the variety of sentence
  types used are checked."""@en ;
  dcterms:modified "2026-06-07T15:30:29.299811Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3406-4
  a curric:KeyLearningPoint ;
  rdfs:label """When editing language, word and phrase choices are checked to ensure they meet the
  tone required."""@en ;
  dcterms:modified "2026-06-07T15:30:29.299815Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1125-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Shrivelled' is an adjective which means wrinkled or shrunken."@en ;
  dcterms:modified "2026-06-07T15:30:29.299818Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1125-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Squat' is an adjective which means short and stubby."@en ;
  dcterms:modified "2026-06-07T15:30:29.299823Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1125-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Willowy' is an adjective which means tall, slender and graceful."@en ;
  dcterms:modified "2026-06-07T15:30:29.299827Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4867-1
  a curric:KeyLearningPoint ;
  rdfs:label "Presenting involves speaking in front of others and listening to others."@en ;
  dcterms:modified "2026-06-07T15:30:29.299831Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4867-2
  a curric:KeyLearningPoint ;
  rdfs:label """Presenting involves speaking with clear diction and suitable volume, making eye
  contact and using strong body language."""@en ;
  dcterms:modified "2026-06-07T15:30:29.299835Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4867-3
  a curric:KeyLearningPoint ;
  rdfs:label "Practising pronouncing tricky words helps develop clear diction when presenting."@en ;
  dcterms:modified "2026-06-07T15:30:29.299849Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4867-4
  a curric:KeyLearningPoint ;
  rdfs:label "Rehearsing helps the presenter to speak more confidently and fluently."@en ;
  dcterms:modified "2026-06-07T15:30:29.299854Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4867-5
  a curric:KeyLearningPoint ;
  rdfs:label "Pauses at the end of sentences can help the audience follow what is being said."@en ;
  dcterms:modified "2026-06-07T15:30:29.299858Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28382-1
  a curric:KeyLearningPoint ;
  rdfs:label "A poet uses language to express ideas, thoughts and feelings in a creative way."@en ;
  dcterms:modified "2026-06-07T15:30:29.299862Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28382-2
  a curric:KeyLearningPoint ;
  rdfs:label "Laura Mucha is an English writer and award-winning poet."@en ;
  dcterms:modified "2026-06-07T15:30:29.299866Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28382-3
  a curric:KeyLearningPoint ;
  rdfs:label "‘Dear Ugly Sisters’ is Laura Mucha’s debut poetry collection for children."@en ;
  dcterms:modified "2026-06-07T15:30:29.299870Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28382-4
  a curric:KeyLearningPoint ;
  rdfs:label """The poem ‘Dear Ugly Sisters’ is presented as a goodbye letter from Cinderella to the
  ugly sisters."""@en ;
  dcterms:modified "2026-06-07T15:30:29.299874Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1407-1
  a curric:KeyLearningPoint ;
  rdfs:label """The most common spelling of the /shun/ suffix is -tion and these words often have a
  root word ending in ‘t’ or ‘te’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.299878Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1407-2
  a curric:KeyLearningPoint ;
  rdfs:label """Words spelt with -sion often have a root word ending in ‘d’, ‘de’ or ‘se’ and can
  sound like /zhun/."""@en ;
  dcterms:modified "2026-06-07T15:30:29.299882Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1407-3
  a curric:KeyLearningPoint ;
  rdfs:label "Words spelt with -ssion often have a root word ending in ‘ss’ or ‘mit’."@en ;
  dcterms:modified "2026-06-07T15:30:29.299886Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1407-4
  a curric:KeyLearningPoint ;
  rdfs:label """Words spelt with -cian often have a root word ending in ‘c’ or ‘cs’ and are used for
  professions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.299891Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1407-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: potatoes, minute and breath."@en ;
  dcterms:modified "2026-06-07T15:30:29.299895Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6001-1
  a curric:KeyLearningPoint ;
  rdfs:label "Editing is the process of making changes to improve our writing."@en ;
  dcterms:modified "2026-06-07T15:30:29.299913Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6001-2
  a curric:KeyLearningPoint ;
  rdfs:label "Editing can be done by oneself, with a peer or with a teacher."@en ;
  dcterms:modified "2026-06-07T15:30:29.299917Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6001-3
  a curric:KeyLearningPoint ;
  rdfs:label """When editing punctuation, missing or incorrectly used capital letters, full stops,
  question marks & commas are checked."""@en ;
  dcterms:modified "2026-06-07T15:30:29.299921Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6001-4
  a curric:KeyLearningPoint ;
  rdfs:label """When editing sentence structure, the way sentences are constructed is checked to
  improve and enhance text flow."""@en ;
  dcterms:modified "2026-06-07T15:30:29.299928Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6001-5
  a curric:KeyLearningPoint ;
  rdfs:label "When editing language, choices of words and phrases are carefully reviewed."@en ;
  dcterms:modified "2026-06-07T15:30:29.299932Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4846-1
  a curric:KeyLearningPoint ;
  rdfs:label """A journalistic report is a non-fiction text that provides information about a
  particular event."""@en ;
  dcterms:modified "2026-06-07T15:30:29.299981Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4846-2
  a curric:KeyLearningPoint ;
  rdfs:label """A journalistic report can be organised into an opening, paragraphs organised by
  theme and a closing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.299987Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4846-3
  a curric:KeyLearningPoint ;
  rdfs:label "The title of a journalistic report is called a headline."@en ;
  dcterms:modified "2026-06-07T15:30:29.299991Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4846-4
  a curric:KeyLearningPoint ;
  rdfs:label "Journalistic language brings a formal, objective tone to the report."@en ;
  dcterms:modified "2026-06-07T15:30:29.299995Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4846-5
  a curric:KeyLearningPoint ;
  rdfs:label """Features include a range of fronted adverbials, journalistic language, relative
  complex sentences and parenthesis."""@en ;
  dcterms:modified "2026-06-07T15:30:29.299999Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1104-1
  a curric:KeyLearningPoint ;
  rdfs:label "Clammy is an adjective which means soggy or moist."@en ;
  dcterms:modified "2026-06-07T15:30:29.300037Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1104-2
  a curric:KeyLearningPoint ;
  rdfs:label "Gleaming is an adjective which means shining or bright."@en ;
  dcterms:modified "2026-06-07T15:30:29.300041Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1104-3
  a curric:KeyLearningPoint ;
  rdfs:label "Oppressive is an adjective which means heavy, harsh or overpowering."@en ;
  dcterms:modified "2026-06-07T15:30:29.300045Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6750-1
  a curric:KeyLearningPoint ;
  rdfs:label "Writing is most successful when it is planned."@en ;
  dcterms:modified "2026-06-07T15:30:29.300123Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6750-2
  a curric:KeyLearningPoint ;
  rdfs:label "We need to generate ideas for what to write about based on a stimulus."@en ;
  dcterms:modified "2026-06-07T15:30:29.300127Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6750-3
  a curric:KeyLearningPoint ;
  rdfs:label """We can generate ideas about descriptive details as well as the main character's
  emotions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.300131Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6750-4
  a curric:KeyLearningPoint ;
  rdfs:label """In this part of the climax, Joseph is racing to the zoo to guard Adonis and he is
  struggling with the reality of this."""@en ;
  dcterms:modified "2026-06-07T15:30:29.300135Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6750-5
  a curric:KeyLearningPoint ;
  rdfs:label """The details we generate should build an appropriate mood - in this case, a mood of
  panic and fear."""@en ;
  dcterms:modified "2026-06-07T15:30:29.300139Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1431-1
  a curric:KeyLearningPoint ;
  rdfs:label "-s is a suffix that can turn a singular noun into a plural."@en ;
  dcterms:modified "2026-06-07T15:30:29.302431Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1431-2
  a curric:KeyLearningPoint ;
  rdfs:label "-es is a suffix that can turn a singular noun into a plural."@en ;
  dcterms:modified "2026-06-07T15:30:29.302435Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1431-3
  a curric:KeyLearningPoint ;
  rdfs:label "Using the strategy \"colour blocks\" is a useful practice strategy."@en ;
  dcterms:modified "2026-06-07T15:30:29.302441Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1431-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum word: thought."@en ;
  dcterms:modified "2026-06-07T15:30:29.302445Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6521-1
  a curric:KeyLearningPoint ;
  rdfs:label "Writing is most successful when structure, content and vocabulary is planned."@en ;
  dcterms:modified "2026-06-07T15:30:29.302581Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6521-2
  a curric:KeyLearningPoint ;
  rdfs:label "Information in this section should be specific and detailed."@en ;
  dcterms:modified "2026-06-07T15:30:29.302585Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6521-3
  a curric:KeyLearningPoint ;
  rdfs:label "Cohesion, making use of research and a formal tone are appropriate in an essay."@en ;
  dcterms:modified "2026-06-07T15:30:29.302589Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6521-4
  a curric:KeyLearningPoint ;
  rdfs:label """An essay can use a bank of research, evidence, statistics and quotes to inform the
  reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.302595Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8639-1
  a curric:KeyLearningPoint ;
  rdfs:label """In this section of the build-up, suspense is built around Arrietty setting off on
  her first borrowing expedition."""@en ;
  dcterms:modified "2026-06-07T15:30:29.302600Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8639-2
  a curric:KeyLearningPoint ;
  rdfs:label """The use of precise and ambitious vocabulary, including ‘show and tell’ language
  supports the building of suspense."""@en ;
  dcterms:modified "2026-06-07T15:30:29.302604Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8639-3
  a curric:KeyLearningPoint ;
  rdfs:label """Using a range of sentence types, including adverbial complex sentences, supports
  text flow."""@en ;
  dcterms:modified "2026-06-07T15:30:29.302608Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8639-4
  a curric:KeyLearningPoint ;
  rdfs:label "An adverbial clause begins with a subordinating conjunction."@en ;
  dcterms:modified "2026-06-07T15:30:29.302612Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8639-5
  a curric:KeyLearningPoint ;
  rdfs:label """An adverbial clause is joined with a main clause to form an adverbial complex
  sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.302616Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4888-1
  a curric:KeyLearningPoint ;
  rdfs:label "Presenting involves speaking in front of others and listening to others."@en ;
  dcterms:modified "2026-06-07T15:30:29.302624Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4888-2
  a curric:KeyLearningPoint ;
  rdfs:label """Presenting includes voice projection, speaking with clear diction, making eye
  contact and using strong body language."""@en ;
  dcterms:modified "2026-06-07T15:30:29.302628Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4888-3
  a curric:KeyLearningPoint ;
  rdfs:label "Voice projection is not the same as shouting."@en ;
  dcterms:modified "2026-06-07T15:30:29.302632Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4888-4
  a curric:KeyLearningPoint ;
  rdfs:label "Practising pronouncing tricky words helps develop clear diction when presenting."@en ;
  dcterms:modified "2026-06-07T15:30:29.302636Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1080-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Reek' is a verb which means stink or smell."@en ;
  dcterms:modified "2026-06-07T15:30:29.302669Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1080-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Stench' is a noun which means odour or stink."@en ;
  dcterms:modified "2026-06-07T15:30:29.302675Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1080-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Whiff', 'scent', 'fragrance' and 'odour' are other nouns related to smell."@en ;
  dcterms:modified "2026-06-07T15:30:29.302679Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27903-1
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to express yourself clearly and confidently in various social
  situations."""@en ;
  dcterms:modified "2026-06-07T15:30:29.302829Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27903-2
  a curric:KeyLearningPoint ;
  rdfs:label """It is normal for people to agree and disagree with each other in a variety of social
  situations."""@en ;
  dcterms:modified "2026-06-07T15:30:29.302833Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27903-3
  a curric:KeyLearningPoint ;
  rdfs:label "We can solve conflicts in groups by agreeing and disagreeing respectfully."@en ;
  dcterms:modified "2026-06-07T15:30:29.302838Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27903-4
  a curric:KeyLearningPoint ;
  rdfs:label """When we meet new adults, we can make a good first impression by being polite and
  respectful."""@en ;
  dcterms:modified "2026-06-07T15:30:29.302841Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27903-5
  a curric:KeyLearningPoint ;
  rdfs:label "When we meet new children, we can try to make friends by having conversations."@en ;
  dcterms:modified "2026-06-07T15:30:29.302845Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1412-1
  a curric:KeyLearningPoint ;
  rdfs:label "The suffix -ic often turns nouns into adjectives."@en ;
  dcterms:modified "2026-06-07T15:30:29.302878Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1412-2
  a curric:KeyLearningPoint ;
  rdfs:label "When the root word ends in 'e', remove the 'e' and add the suffix -ic."@en ;
  dcterms:modified "2026-06-07T15:30:29.302882Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1412-3
  a curric:KeyLearningPoint ;
  rdfs:label "When the root word ends in 'y', remove the 'y' and add the suffix -ic."@en ;
  dcterms:modified "2026-06-07T15:30:29.302886Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1412-4
  a curric:KeyLearningPoint ;
  rdfs:label "When the root word does not end in 'e' or 'y', just add the suffix -ic."@en ;
  dcterms:modified "2026-06-07T15:30:29.302890Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1412-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: sentence, experiment and question."@en ;
  dcterms:modified "2026-06-07T15:30:29.302897Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5849-1
  a curric:KeyLearningPoint ;
  rdfs:label "Macbeth is a highly conflicted character."@en ;
  dcterms:modified "2026-06-07T15:30:29.302932Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5849-2
  a curric:KeyLearningPoint ;
  rdfs:label "A soliloquy occurs when a character voices their thoughts and feelings aloud."@en ;
  dcterms:modified "2026-06-07T15:30:29.302936Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5849-3
  a curric:KeyLearningPoint ;
  rdfs:label "Soliloquies are written from the first person perspective."@en ;
  dcterms:modified "2026-06-07T15:30:29.302940Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5849-4
  a curric:KeyLearningPoint ;
  rdfs:label "The opening of this soliloquy outlines Macbeth's dilemma."@en ;
  dcterms:modified "2026-06-07T15:30:29.302944Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5849-5
  a curric:KeyLearningPoint ;
  rdfs:label """The character's confusion can be illustrated through the use of rhetorical questions
  and exclamations."""@en ;
  dcterms:modified "2026-06-07T15:30:29.302947Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6006-1
  a curric:KeyLearningPoint ;
  rdfs:label "A formal letter should be written using a formal tone."@en ;
  dcterms:modified "2026-06-07T15:30:29.302967Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6006-2
  a curric:KeyLearningPoint ;
  rdfs:label """Formal writing can be identified by its serious, unemotional and impersonal
  tone."""@en ;
  dcterms:modified "2026-06-07T15:30:29.302971Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6006-3
  a curric:KeyLearningPoint ;
  rdfs:label "An introduction contains one introductory sentence."@en ;
  dcterms:modified "2026-06-07T15:30:29.302977Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6006-4
  a curric:KeyLearningPoint ;
  rdfs:label """It also contains a sentence to set-up the argument & a sentence sharing the purpose
  of the letter."""@en ;
  dcterms:modified "2026-06-07T15:30:29.302983Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1458-1
  a curric:KeyLearningPoint ;
  rdfs:label """The pronounciation of a word helps to identify if it is spelt with -sure or
  -ture."""@en ;
  dcterms:modified "2026-06-07T15:30:29.303019Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1458-2
  a curric:KeyLearningPoint ;
  rdfs:label """The -ture ending to a word can be confused with a root word ending in '(t)ch+er',
  such as 'teacher' or 'richer'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.303023Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1458-3
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum word: caught."@en ;
  dcterms:modified "2026-06-07T15:30:29.303029Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6192-1
  a curric:KeyLearningPoint ;
  rdfs:label "Our essay gives a logical argument that builds towards a conclusion."@en ;
  dcterms:modified "2026-06-07T15:30:29.303068Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6192-2
  a curric:KeyLearningPoint ;
  rdfs:label """The introduction gives the context of the polar regions while the first main
  paragraph begins to build the argument."""@en ;
  dcterms:modified "2026-06-07T15:30:29.303072Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6192-3
  a curric:KeyLearningPoint ;
  rdfs:label """Throughout the essay, we connect ideas using a range of linguistic features and
  support ideas with evidence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.303076Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6192-4
  a curric:KeyLearningPoint ;
  rdfs:label """It is useful to orally rehearse our ideas before writing to reduce our cognitive
  load."""@en ;
  dcterms:modified "2026-06-07T15:30:29.303616Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6192-5
  a curric:KeyLearningPoint ;
  rdfs:label "We use a formal tone in an essay because we want to sound authoritative."@en ;
  dcterms:modified "2026-06-07T15:30:29.303621Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7912-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘London is the Place for Me’ was written by Aldwyn ‘Lord Kitchener’ Roberts
  in 1948."""@en ;
  dcterms:modified "2026-06-07T15:30:29.303733Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7912-2
  a curric:KeyLearningPoint ;
  rdfs:label """‘Sweet Jamaica’ was written four years after his arrival on the Empire Windrush, in
  1952."""@en ;
  dcterms:modified "2026-06-07T15:30:29.303739Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7912-3
  a curric:KeyLearningPoint ;
  rdfs:label """We can compare and contrast songs with similar themes or messages, noticing the
  impact that they have on us as readers."""@en ;
  dcterms:modified "2026-06-07T15:30:29.303743Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7912-4
  a curric:KeyLearningPoint ;
  rdfs:label """Understanding the context of the songs can support readers to form deeper
  reflections."""@en ;
  dcterms:modified "2026-06-07T15:30:29.303747Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7912-5
  a curric:KeyLearningPoint ;
  rdfs:label """From reading, listening and discussing songs about migration, we can make
  connections to our own lives and experiences."""@en ;
  dcterms:modified "2026-06-07T15:30:29.303751Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6096-1
  a curric:KeyLearningPoint ;
  rdfs:label "A non-chronological report is written out of time order."@en ;
  dcterms:modified "2026-06-07T15:30:29.303769Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6096-2
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of a non-chronological report is to inform and engage the reader about a
  particular subject or event."""@en ;
  dcterms:modified "2026-06-07T15:30:29.303773Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6096-3
  a curric:KeyLearningPoint ;
  rdfs:label """The intended reader of a non-chronological report is likely interested in the
  subject of the report."""@en ;
  dcterms:modified "2026-06-07T15:30:29.303777Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6096-4
  a curric:KeyLearningPoint ;
  rdfs:label """Subheadings are used to signal where each section of information is to the reader of
  a non-chronological report."""@en ;
  dcterms:modified "2026-06-07T15:30:29.303781Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6096-5
  a curric:KeyLearningPoint ;
  rdfs:label "Paragraphs are used within a subheading to organise information by theme."@en ;
  dcterms:modified "2026-06-07T15:30:29.303785Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4809-1
  a curric:KeyLearningPoint ;
  rdfs:label """A suffix is a letter or group of letters at the end of a word which creates another
  word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.303789Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4809-2
  a curric:KeyLearningPoint ;
  rdfs:label "The words start with a lead in and finish with a lead out."@en ;
  dcterms:modified "2026-06-07T15:30:29.303793Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4809-3
  a curric:KeyLearningPoint ;
  rdfs:label """The pencil does not lift when forming the join, only after to add the cross to a t
  or a dot to an i or a j."""@en ;
  dcterms:modified "2026-06-07T15:30:29.303797Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4809-4
  a curric:KeyLearningPoint ;
  rdfs:label "There are four cursive joins."@en ;
  dcterms:modified "2026-06-07T15:30:29.303801Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4809-5
  a curric:KeyLearningPoint ;
  rdfs:label """The join used depends on which letter is joining to which letter within a letter
  string."""@en ;
  dcterms:modified "2026-06-07T15:30:29.303805Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28383-1
  a curric:KeyLearningPoint ;
  rdfs:label """Poets can use a range of poetic devices to enhance the meaning or impact of their
  poems."""@en ;
  dcterms:modified "2026-06-07T15:30:29.303809Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28383-2
  a curric:KeyLearningPoint ;
  rdfs:label "Personification is describing a non-living thing as if it is a person."@en ;
  dcterms:modified "2026-06-07T15:30:29.303813Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28383-3
  a curric:KeyLearningPoint ;
  rdfs:label """Alliteration is when words that begin with the same sound are placed close
  together."""@en ;
  dcterms:modified "2026-06-07T15:30:29.303818Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28383-4
  a curric:KeyLearningPoint ;
  rdfs:label """Understanding a poem, its language and the impression it creates will help us to
  create an impactful performance."""@en ;
  dcterms:modified "2026-06-07T15:30:29.303822Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28383-5
  a curric:KeyLearningPoint ;
  rdfs:label """There are many things we can do to prepare for a performance, including practising
  reading the poem aloud."""@en ;
  dcterms:modified "2026-06-07T15:30:29.303826Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5627-1
  a curric:KeyLearningPoint ;
  rdfs:label "The recount in a diary entry is written mainly in the past tense."@en ;
  dcterms:modified "2026-06-07T15:30:29.303832Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5627-2
  a curric:KeyLearningPoint ;
  rdfs:label """The present perfect tense shows unfinished past actions or past actions that are
  still relevant now."""@en ;
  dcterms:modified "2026-06-07T15:30:29.303836Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5627-3
  a curric:KeyLearningPoint ;
  rdfs:label """The auxiliary verb ‘has’ or ‘have’ is joined to the main verb to change simple past
  tense into perfect present tense."""@en ;
  dcterms:modified "2026-06-07T15:30:29.303840Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5627-4
  a curric:KeyLearningPoint ;
  rdfs:label "Contractions are one element of informal language in a diary entry."@en ;
  dcterms:modified "2026-06-07T15:30:29.303846Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5627-5
  a curric:KeyLearningPoint ;
  rdfs:label """A range of sentence types, including adverbial complex sentences, should be used in
  a diary entry."""@en ;
  dcterms:modified "2026-06-07T15:30:29.303851Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1071-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Ecstatic' is an adjective which means blissful or perfectly happy."@en ;
  dcterms:modified "2026-06-07T15:30:29.303855Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1071-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Gleeful' is an adjective which means cheerful or merry."@en ;
  dcterms:modified "2026-06-07T15:30:29.303859Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1071-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Exhilarated' is an adjective which means excited or thrilled."@en ;
  dcterms:modified "2026-06-07T15:30:29.303863Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1071-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Light-hearted', 'overjoyed' and 'contented' are other rich vocabulary associated
  with happiness."""@en ;
  dcterms:modified "2026-06-07T15:30:29.303866Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6762-1
  a curric:KeyLearningPoint ;
  rdfs:label "Writing is most successful when structure, content and vocabulary is planned."@en ;
  dcterms:modified "2026-06-07T15:30:29.306554Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6762-2
  a curric:KeyLearningPoint ;
  rdfs:label "Information in this section should be specific and detailed."@en ;
  dcterms:modified "2026-06-07T15:30:29.306558Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6762-3
  a curric:KeyLearningPoint ;
  rdfs:label "Cohesion, making use of research and a formal tone are appropriate in an essay."@en ;
  dcterms:modified "2026-06-07T15:30:29.306562Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6762-4
  a curric:KeyLearningPoint ;
  rdfs:label """An essay can use a bank of research, evidence, statistics and quotes to inform the
  reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.306566Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7859-1
  a curric:KeyLearningPoint ;
  rdfs:label "Arthur is the protagonist."@en ;
  dcterms:modified "2026-06-07T15:30:29.306662Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7859-2
  a curric:KeyLearningPoint ;
  rdfs:label "Arthur does not exhibit typical character traits of a hero."@en ;
  dcterms:modified "2026-06-07T15:30:29.306668Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7859-3
  a curric:KeyLearningPoint ;
  rdfs:label "The villagers in Arthur’s hometown do not respond well to Arthur."@en ;
  dcterms:modified "2026-06-07T15:30:29.306672Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7859-4
  a curric:KeyLearningPoint ;
  rdfs:label """A feature of a modern myth is that they often feature gods and goddesses with
  extraordinary powers and abilities."""@en ;
  dcterms:modified "2026-06-07T15:30:29.306676Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7859-5
  a curric:KeyLearningPoint ;
  rdfs:label """'Arthur and the Golden Rope' has connections to Norse Mythology. Norse gods &
  goddesses are characters within the text."""@en ;
  dcterms:modified "2026-06-07T15:30:29.306680Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7939-1
  a curric:KeyLearningPoint ;
  rdfs:label "Series texts can develop motivation to read."@en ;
  dcterms:modified "2026-06-07T15:30:29.307141Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7939-2
  a curric:KeyLearningPoint ;
  rdfs:label "A character might be part of a series of texts"@en ;
  dcterms:modified "2026-06-07T15:30:29.307145Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7939-3
  a curric:KeyLearningPoint ;
  rdfs:label """A character trait is a special quality that make a character in a story unique and
  interesting"""@en ;
  dcterms:modified "2026-06-07T15:30:29.307149Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7939-4
  a curric:KeyLearningPoint ;
  rdfs:label "A character's emotional arc might adapt or change over a series of books"@en ;
  dcterms:modified "2026-06-07T15:30:29.307153Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7643-1
  a curric:KeyLearningPoint ;
  rdfs:label "It is crucial to communicate the unique selling point of a product."@en ;
  dcterms:modified "2026-06-07T15:30:29.307187Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7643-2
  a curric:KeyLearningPoint ;
  rdfs:label """The beginning of persuasive writing should focus on the most appealing aspects of
  the product, e.g. taste."""@en ;
  dcterms:modified "2026-06-07T15:30:29.307191Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7643-3
  a curric:KeyLearningPoint ;
  rdfs:label "A variety of linguistic techniques are used to create persuasive adverts."@en ;
  dcterms:modified "2026-06-07T15:30:29.307195Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7643-4
  a curric:KeyLearningPoint ;
  rdfs:label """Use of a relative complex sentence supports communicating extra detail about a noun
  to the reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.307199Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5631-1
  a curric:KeyLearningPoint ;
  rdfs:label """This paragraph recounts the final part of the boy’s journey and his reunion with his
  dad in the past tense."""@en ;
  dcterms:modified "2026-06-07T15:30:29.307203Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5631-2
  a curric:KeyLearningPoint ;
  rdfs:label """The boy’s emotions heighten and he experiences intense fear before experiencing
  great relief."""@en ;
  dcterms:modified "2026-06-07T15:30:29.307207Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5631-3
  a curric:KeyLearningPoint ;
  rdfs:label """A key linguistic feature in the final paragraph of a diary entry is the shift from
  past to present tense."""@en ;
  dcterms:modified "2026-06-07T15:30:29.307211Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5631-4
  a curric:KeyLearningPoint ;
  rdfs:label """Present tense writing at the end of a diary entry conveys current reflections and
  feelings."""@en ;
  dcterms:modified "2026-06-07T15:30:29.307215Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5631-5
  a curric:KeyLearningPoint ;
  rdfs:label """Rhetorical questions can be used to convey internal questions and emotions in a
  diary entry."""@en ;
  dcterms:modified "2026-06-07T15:30:29.307221Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4702-1
  a curric:KeyLearningPoint ;
  rdfs:label "The motion is the name for the belief or proposal that is being debated."@en ;
  dcterms:modified "2026-06-07T15:30:29.307263Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4702-2
  a curric:KeyLearningPoint ;
  rdfs:label "The team that agrees with the motion is called the proposition."@en ;
  dcterms:modified "2026-06-07T15:30:29.307267Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4702-3
  a curric:KeyLearningPoint ;
  rdfs:label "The team that disagrees with the motion is called the opposition."@en ;
  dcterms:modified "2026-06-07T15:30:29.307271Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4702-4
  a curric:KeyLearningPoint ;
  rdfs:label """A rebuttal point is a counter-argument made against something specific that the
  opposing team has said."""@en ;
  dcterms:modified "2026-06-07T15:30:29.307275Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2738-1
  a curric:KeyLearningPoint ;
  rdfs:label """A fronted adverbial is a sentence starter followed by a comma that expresses detail
  about time, place, manner or cause."""@en ;
  dcterms:modified "2026-06-07T15:30:29.307302Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2738-2
  a curric:KeyLearningPoint ;
  rdfs:label "A fronted adverbial can be a single word, phrase or clause."@en ;
  dcterms:modified "2026-06-07T15:30:29.307306Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2738-3
  a curric:KeyLearningPoint ;
  rdfs:label "A clause is a group of words that contains a verb."@en ;
  dcterms:modified "2026-06-07T15:30:29.307310Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2738-4
  a curric:KeyLearningPoint ;
  rdfs:label "A phrase is a group of words with no verb."@en ;
  dcterms:modified "2026-06-07T15:30:29.307314Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2738-5
  a curric:KeyLearningPoint ;
  rdfs:label "A variety of fronted adverbials are useful to achieve text flow."@en ;
  dcterms:modified "2026-06-07T15:30:29.307318Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5754-1
  a curric:KeyLearningPoint ;
  rdfs:label """Notes should not be written in full sentences and bullet points can be used to order
  notes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.307417Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5754-2
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the paragraph is to explain the importance of exercise and sleep in a
  healthy lifestyle."""@en ;
  dcterms:modified "2026-06-07T15:30:29.307421Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5754-3
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials of cause and formal fronted adverbials are used at the start of
  sentences for cohesion."""@en ;
  dcterms:modified "2026-06-07T15:30:29.307425Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5754-4
  a curric:KeyLearningPoint ;
  rdfs:label """A subheading signals part of a a text and should stand out from the rest of the
  text."""@en ;
  dcterms:modified "2026-06-07T15:30:29.307429Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5754-5
  a curric:KeyLearningPoint ;
  rdfs:label "The plan should include subject-specific vocabulary."@en ;
  dcterms:modified "2026-06-07T15:30:29.307433Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1350-1
  a curric:KeyLearningPoint ;
  rdfs:label """A silent 'b' generally comes towards the end of a word and next to a 't' or after
  the letter 'm'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.307452Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1350-2
  a curric:KeyLearningPoint ;
  rdfs:label "A silent 'w' might come at the beginning of a word before the letter 'r'."@en ;
  dcterms:modified "2026-06-07T15:30:29.307456Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1350-3
  a curric:KeyLearningPoint ;
  rdfs:label "A silent 'k' always comes at the beginning of a word and before the letter 'n'."@en ;
  dcterms:modified "2026-06-07T15:30:29.307461Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1350-4
  a curric:KeyLearningPoint ;
  rdfs:label """A silent 'g' can come at the beginning of a word or at the end of a word, but it
  generally comes before the letter 'n'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.307465Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1350-5
  a curric:KeyLearningPoint ;
  rdfs:label """How to spell words with the silent letter 't' and the curriculum words: government,
  parliament, rhyme."""@en ;
  dcterms:modified "2026-06-07T15:30:29.307468Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8065-1
  a curric:KeyLearningPoint ;
  rdfs:label """'Blackbird' is a cinquain by John Foster with five lines of a set syllabic
  structure."""@en ;
  dcterms:modified "2026-06-07T15:30:29.307473Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8065-2
  a curric:KeyLearningPoint ;
  rdfs:label """‘Hawk Roosting’ can be described as a fixed verse poem; it consists of six verses,
  each with four lines."""@en ;
  dcterms:modified "2026-06-07T15:30:29.307479Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8065-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Hawk Roosting' is written in first-person perspective."@en ;
  dcterms:modified "2026-06-07T15:30:29.307483Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8065-4
  a curric:KeyLearningPoint ;
  rdfs:label "We can explore poems in depth by reading them aloud and performing them."@en ;
  dcterms:modified "2026-06-07T15:30:29.307491Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8089-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘Tempest Avenue’ can be described as a free verse poem; it contains 7 verses and is
  written in first person perspective."""@en ;
  dcterms:modified "2026-06-07T15:30:29.307495Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8089-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Tempest Avenue' is set in Stairfoot, Yorkshire; it is written from the perspective
  of a parent holding their baby."""@en ;
  dcterms:modified "2026-06-07T15:30:29.307499Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8089-3
  a curric:KeyLearningPoint ;
  rdfs:label """The poem uses enjambment, which is when a line in poetry continues onto the next
  line without pause or punctuation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.307503Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8089-4
  a curric:KeyLearningPoint ;
  rdfs:label """Understanding a poem, its language and the impression it creates will help us to
  create an impactful performance."""@en ;
  dcterms:modified "2026-06-07T15:30:29.307507Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27898-1
  a curric:KeyLearningPoint ;
  rdfs:label "A speaker can connect with an audience in a variety of different ways."@en ;
  dcterms:modified "2026-06-07T15:30:29.307567Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27898-2
  a curric:KeyLearningPoint ;
  rdfs:label """A speaker can use personal experiences and anecdotes to connect with an
  audience."""@en ;
  dcterms:modified "2026-06-07T15:30:29.307572Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27898-3
  a curric:KeyLearningPoint ;
  rdfs:label """Emma Watson is an actress and she is best-known for playing Hermione in the Harry
  Potter films."""@en ;
  dcterms:modified "2026-06-07T15:30:29.307575Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27898-4
  a curric:KeyLearningPoint ;
  rdfs:label """Emma Watson is an activist, humanitarian and speaker, who gave a famous speech as UN
  Women Goodwill Ambassador in 2014."""@en ;
  dcterms:modified "2026-06-07T15:30:29.307580Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6376-1
  a curric:KeyLearningPoint ;
  rdfs:label """When describing a character, we can consider their actions, appearance and
  feelings."""@en ;
  dcterms:modified "2026-06-07T15:30:29.307608Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6376-2
  a curric:KeyLearningPoint ;
  rdfs:label """Using show-not-tell is a powerful way of helping the reader engage and identify with
  a character."""@en ;
  dcterms:modified "2026-06-07T15:30:29.307612Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6376-3
  a curric:KeyLearningPoint ;
  rdfs:label "When planning, we record our ideas using notes and bullet points."@en ;
  dcterms:modified "2026-06-07T15:30:29.307616Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6376-4
  a curric:KeyLearningPoint ;
  rdfs:label """Success criteria act as a useful guide to help us remember which skills to include
  in our writing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.307620Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1036-1
  a curric:KeyLearningPoint ;
  rdfs:label "The purpose of a conclusion is to summarise the information from the text."@en ;
  dcterms:modified "2026-06-07T15:30:29.307665Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1036-2
  a curric:KeyLearningPoint ;
  rdfs:label "A summary sentence summarises the key information from the text."@en ;
  dcterms:modified "2026-06-07T15:30:29.307669Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1036-3
  a curric:KeyLearningPoint ;
  rdfs:label "A conclusion begins with a formal fronted adverbial."@en ;
  dcterms:modified "2026-06-07T15:30:29.307673Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1036-4
  a curric:KeyLearningPoint ;
  rdfs:label "No new information about the subject is needed in the conclusion."@en ;
  dcterms:modified "2026-06-07T15:30:29.307677Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1036-5
  a curric:KeyLearningPoint ;
  rdfs:label "A conclusion finishes with the writer suggesting to the reader to find out more."@en ;
  dcterms:modified "2026-06-07T15:30:29.307681Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4857-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the closing is to summarise what is currently happening and what is
  likely to happen next."""@en ;
  dcterms:modified "2026-06-07T15:30:29.307685Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4857-2
  a curric:KeyLearningPoint ;
  rdfs:label "Information in the closing should be general."@en ;
  dcterms:modified "2026-06-07T15:30:29.307689Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4857-3
  a curric:KeyLearningPoint ;
  rdfs:label """Cohesion is vital when considering how to engage the reader and share information
  with them in a clear, succinct way."""@en ;
  dcterms:modified "2026-06-07T15:30:29.307692Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4857-4
  a curric:KeyLearningPoint ;
  rdfs:label """Using the structure of introductory sentence, general information and concluding
  sentence enhances text cohesion."""@en ;
  dcterms:modified "2026-06-07T15:30:29.307696Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1310-1
  a curric:KeyLearningPoint ;
  rdfs:label "The suffix -ous often turns nouns into adjectives and often means 'full of'."@en ;
  dcterms:modified "2026-06-07T15:30:29.307772Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1310-2
  a curric:KeyLearningPoint ;
  rdfs:label "If the root word ends in 'ge', just add -ous."@en ;
  dcterms:modified "2026-06-07T15:30:29.307776Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1310-3
  a curric:KeyLearningPoint ;
  rdfs:label "If the root word ends in 'e', remove the 'e', then add -ous."@en ;
  dcterms:modified "2026-06-07T15:30:29.307780Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1310-4
  a curric:KeyLearningPoint ;
  rdfs:label "If the root word ends in 'our', change 'our' to 'or', then add -ous."@en ;
  dcterms:modified "2026-06-07T15:30:29.307784Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1310-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: thought, purpose and suppose."@en ;
  dcterms:modified "2026-06-07T15:30:29.307788Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7883-1
  a curric:KeyLearningPoint ;
  rdfs:label """Readers can form impressions of characters based on what they say, the actions they
  perform and their appearance."""@en ;
  dcterms:modified "2026-06-07T15:30:29.309795Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7883-2
  a curric:KeyLearningPoint ;
  rdfs:label "During the story, characters and their relationships change and evolve."@en ;
  dcterms:modified "2026-06-07T15:30:29.309799Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7883-3
  a curric:KeyLearningPoint ;
  rdfs:label """Making connections and recommendations can significantly broaden a reader's
  understanding of literature."""@en ;
  dcterms:modified "2026-06-07T15:30:29.309803Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5694-1
  a curric:KeyLearningPoint ;
  rdfs:label "Precise vocabulary is used to accurately describe setting and characters."@en ;
  dcterms:modified "2026-06-07T15:30:29.309854Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5694-2
  a curric:KeyLearningPoint ;
  rdfs:label "Some vocabulary choices are more precise and appropriate than others."@en ;
  dcterms:modified "2026-06-07T15:30:29.309858Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5694-3
  a curric:KeyLearningPoint ;
  rdfs:label """Imagining colours as we write that might evoke feelings for the reader helps us
  choose vocabulary."""@en ;
  dcterms:modified "2026-06-07T15:30:29.309862Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5694-4
  a curric:KeyLearningPoint ;
  rdfs:label "Nouns are referred to in different ways to avoid repetition."@en ;
  dcterms:modified "2026-06-07T15:30:29.309866Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2729-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the resolution is to resolve a story, tying up its 'loose ends' and
  solving the characters' problems."""@en ;
  dcterms:modified "2026-06-07T15:30:29.309870Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2729-2
  a curric:KeyLearningPoint ;
  rdfs:label """When we plan, we log precise and ambitious vocabulary to help paint vivid pictures
  for our reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.309874Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2729-3
  a curric:KeyLearningPoint ;
  rdfs:label """Dialogue is the written conversation between two or more characters within a
  narrative and it moves the story forward."""@en ;
  dcterms:modified "2026-06-07T15:30:29.309878Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2729-4
  a curric:KeyLearningPoint ;
  rdfs:label "A plan is written in note-form, out of full sentences."@en ;
  dcterms:modified "2026-06-07T15:30:29.309882Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2729-5
  a curric:KeyLearningPoint ;
  rdfs:label "Some vocabulary choices are more precise than others."@en ;
  dcterms:modified "2026-06-07T15:30:29.309886Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6690-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of a build-up is to move the main character’s journey forward and build
  tension."""@en ;
  dcterms:modified "2026-06-07T15:30:29.309965Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6690-2
  a curric:KeyLearningPoint ;
  rdfs:label """Precise and ambitious vocabulary creates vivid images for the reader for each key
  moment of the build-up."""@en ;
  dcterms:modified "2026-06-07T15:30:29.309969Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6690-3
  a curric:KeyLearningPoint ;
  rdfs:label "An effective plan has vocabulary organised concisely and neatly."@en ;
  dcterms:modified "2026-06-07T15:30:29.309973Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6690-4
  a curric:KeyLearningPoint ;
  rdfs:label """Careful verb and adverb selection can convey characters' feelings through show and
  tell."""@en ;
  dcterms:modified "2026-06-07T15:30:29.309977Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6690-5
  a curric:KeyLearningPoint ;
  rdfs:label "The emotions of the character change through the key moments of the build-up."@en ;
  dcterms:modified "2026-06-07T15:30:29.309983Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6414-1
  a curric:KeyLearningPoint ;
  rdfs:label """Knowing the events we are going to retell really well before we write frees up our
  brain to focus on writing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.309987Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6414-2
  a curric:KeyLearningPoint ;
  rdfs:label """Using a text map to tell the events of a story is a great way of embedding these
  events in our memory."""@en ;
  dcterms:modified "2026-06-07T15:30:29.309991Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6414-3
  a curric:KeyLearningPoint ;
  rdfs:label """In a diary, we are writing about our experiences and feelings in the past and
  present."""@en ;
  dcterms:modified "2026-06-07T15:30:29.309995Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6414-4
  a curric:KeyLearningPoint ;
  rdfs:label """To write a diary in role as another person, we need to try and empathise with that
  person."""@en ;
  dcterms:modified "2026-06-07T15:30:29.310000Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6414-5
  a curric:KeyLearningPoint ;
  rdfs:label """Role-play and drama are good ways of trying to empathise with a person and consider
  their emotions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.310003Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5999-1
  a curric:KeyLearningPoint ;
  rdfs:label """A persuasive letter is written mainly in the present tense, including the simple,
  progressive and perfect present forms."""@en ;
  dcterms:modified "2026-06-07T15:30:29.310007Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5999-2
  a curric:KeyLearningPoint ;
  rdfs:label """Persuasive letters have distinctive linguistic features in order to achieve their
  purpose."""@en ;
  dcterms:modified "2026-06-07T15:30:29.310011Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5999-3
  a curric:KeyLearningPoint ;
  rdfs:label """An adverbial complex sentence has a main clause and an adverbial clause that starts
  with a subordinating conjunction."""@en ;
  dcterms:modified "2026-06-07T15:30:29.310015Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5999-4
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials of time are sentence starters that tell the reader when something
  happens."""@en ;
  dcterms:modified "2026-06-07T15:30:29.310020Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5999-5
  a curric:KeyLearningPoint ;
  rdfs:label """First person perspective is the point of view where the writer is the 'I'
  character."""@en ;
  dcterms:modified "2026-06-07T15:30:29.310024Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6345-1
  a curric:KeyLearningPoint ;
  rdfs:label "Writing is most successful when structure, content and vocabulary is planned."@en ;
  dcterms:modified "2026-06-07T15:30:29.310027Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6345-2
  a curric:KeyLearningPoint ;
  rdfs:label "Oral rehearsal is an important step in the writing process."@en ;
  dcterms:modified "2026-06-07T15:30:29.310032Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6345-3
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials of place, prepositions and precise vocabulary paint the picture
  for a reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.310036Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6345-4
  a curric:KeyLearningPoint ;
  rdfs:label "Complex sentences can be used to show the connections between ideas."@en ;
  dcterms:modified "2026-06-07T15:30:29.310041Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6345-5
  a curric:KeyLearningPoint ;
  rdfs:label "We can connect linked sentences using a semi-colon."@en ;
  dcterms:modified "2026-06-07T15:30:29.310046Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1100-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Dusk' is a noun which means twilight or nightfall."@en ;
  dcterms:modified "2026-06-07T15:30:29.310050Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1100-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Eerie' is an adjective which means weird, ghostly or creepy."@en ;
  dcterms:modified "2026-06-07T15:30:29.310054Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1100-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Nocturnal' is an adjective which means nightly or active at night."@en ;
  dcterms:modified "2026-06-07T15:30:29.310060Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1100-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Twilight', 'moonlit' and 'sleepless' are other rich vocabulary associated with
  night."""@en ;
  dcterms:modified "2026-06-07T15:30:29.310064Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6193-1
  a curric:KeyLearningPoint ;
  rdfs:label "Our essay gives a logical argument that builds towards a conclusion."@en ;
  dcterms:modified "2026-06-07T15:30:29.310070Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6193-2
  a curric:KeyLearningPoint ;
  rdfs:label """Throughout the essay, we connect ideas using a range of linguistic features and we
  support ideas with evidence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.310075Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6193-3
  a curric:KeyLearningPoint ;
  rdfs:label "We use a formal tone in an essay because we want to sound authoritative."@en ;
  dcterms:modified "2026-06-07T15:30:29.310079Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6193-4
  a curric:KeyLearningPoint ;
  rdfs:label """Our conclusion should directly address the essay question, making the end-point of
  our logical argument clear."""@en ;
  dcterms:modified "2026-06-07T15:30:29.310083Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6193-5
  a curric:KeyLearningPoint ;
  rdfs:label """It is useful to orally rehearse our ideas before writing to reduce our cognitive
  load."""@en ;
  dcterms:modified "2026-06-07T15:30:29.310087Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8093-1
  a curric:KeyLearningPoint ;
  rdfs:label """We can analyse a scene in a graphic novel by exploring the visual, narrative and
  contextual elements."""@en ;
  dcterms:modified "2026-06-07T15:30:29.310111Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8093-2
  a curric:KeyLearningPoint ;
  rdfs:label """Visuals refer to how the panels are presented on the page, the illustration style
  and how characters are portrayed."""@en ;
  dcterms:modified "2026-06-07T15:30:29.310115Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8093-3
  a curric:KeyLearningPoint ;
  rdfs:label "Narrative is how dialogue and text develop the plot and action."@en ;
  dcterms:modified "2026-06-07T15:30:29.310119Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8093-4
  a curric:KeyLearningPoint ;
  rdfs:label """Context refers to what the characters learn in a scene, how they change, as well as
  how the scene fits within the plot."""@en ;
  dcterms:modified "2026-06-07T15:30:29.310123Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8093-5
  a curric:KeyLearningPoint ;
  rdfs:label "We can ask questions about scenes to develop our understanding of the text."@en ;
  dcterms:modified "2026-06-07T15:30:29.310127Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4866-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of a conclusion is to summarise the information of the text for the
  reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.310151Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4866-2
  a curric:KeyLearningPoint ;
  rdfs:label "A summary sentence summarises the key information from the text."@en ;
  dcterms:modified "2026-06-07T15:30:29.310155Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4866-3
  a curric:KeyLearningPoint ;
  rdfs:label "A conclusion can begin with a formal fronted adverbial."@en ;
  dcterms:modified "2026-06-07T15:30:29.310159Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4866-4
  a curric:KeyLearningPoint ;
  rdfs:label "No new information about the subject is given to the reader in the conclusion."@en ;
  dcterms:modified "2026-06-07T15:30:29.310163Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4866-5
  a curric:KeyLearningPoint ;
  rdfs:label """A conclusion finishes with the writer suggesting to the reader how to find
  out more."""@en ;
  dcterms:modified "2026-06-07T15:30:29.310167Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5628-1
  a curric:KeyLearningPoint ;
  rdfs:label """This paragraph of the diary entry recounts the boy’s encounters with characters in
  the forest from his perspective."""@en ;
  dcterms:modified "2026-06-07T15:30:29.310208Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5628-2
  a curric:KeyLearningPoint ;
  rdfs:label """The boy encounters a boy with a cow first, then a girl with long, golden plaits and
  then a pair of abandoned children."""@en ;
  dcterms:modified "2026-06-07T15:30:29.310213Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5628-3
  a curric:KeyLearningPoint ;
  rdfs:label """Thoughts and feelings can be explicitly stated and conveyed through the use of ‘show
  and tell’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.310219Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5628-4
  a curric:KeyLearningPoint ;
  rdfs:label "The boy’s emotions heighten over the course of the encounters."@en ;
  dcterms:modified "2026-06-07T15:30:29.310223Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5628-5
  a curric:KeyLearningPoint ;
  rdfs:label """Your plan should contain precise and ambitious vocabulary and thoughts and feelings
  for each encounter."""@en ;
  dcterms:modified "2026-06-07T15:30:29.310227Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20366-1
  a curric:KeyLearningPoint ;
  rdfs:label "If the root word ends in a ‘sh’, ‘ch’, ‘ss’ or ‘x’, then add the suffix -es."@en ;
  dcterms:modified "2026-06-07T15:30:29.310270Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20366-2
  a curric:KeyLearningPoint ;
  rdfs:label "If the root word ends in an ‘o’, it can use -s or -es."@en ;
  dcterms:modified "2026-06-07T15:30:29.310274Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20366-3
  a curric:KeyLearningPoint ;
  rdfs:label """If the root word ends in a ‘f’ or ‘fe’, then the ‘f’ or 'fe' is replaced by ‘v’
  before adding the suffix -es."""@en ;
  dcterms:modified "2026-06-07T15:30:29.310278Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20366-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell curriculum words: programme and identity"@en ;
  dcterms:modified "2026-06-07T15:30:29.310282Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6547-1
  a curric:KeyLearningPoint ;
  rdfs:label """To persuade is to convince someone to do something through reasoning or
  argument."""@en ;
  dcterms:modified "2026-06-07T15:30:29.310288Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6547-2
  a curric:KeyLearningPoint ;
  rdfs:label "A persuasive letter is often highly formal in tone."@en ;
  dcterms:modified "2026-06-07T15:30:29.310294Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6547-3
  a curric:KeyLearningPoint ;
  rdfs:label "Paragraphs are used to structure a persuasive letter."@en ;
  dcterms:modified "2026-06-07T15:30:29.310298Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6547-4
  a curric:KeyLearningPoint ;
  rdfs:label "Flattery, presumption and veiled threat are examples of persuasive devices."@en ;
  dcterms:modified "2026-06-07T15:30:29.310302Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6547-5
  a curric:KeyLearningPoint ;
  rdfs:label "A persuasive letter contains an address, return address, greeting and sign-off."@en ;
  dcterms:modified "2026-06-07T15:30:29.310306Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1391-1
  a curric:KeyLearningPoint ;
  rdfs:label "In words of Greek origin, the letter string 'ph' makes the /f/ sound"@en ;
  dcterms:modified "2026-06-07T15:30:29.310310Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1391-2
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: vegetable, language, library and vehicle"@en ;
  dcterms:modified "2026-06-07T15:30:29.310317Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1391-3
  a curric:KeyLearningPoint ;
  rdfs:label """Knowing which words have Greek etymology can help us to choose the correct
  spelling"""@en ;
  dcterms:modified "2026-06-07T15:30:29.310321Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1391-4
  a curric:KeyLearningPoint ;
  rdfs:label "Most words with the 'ph' spelling are nouns"@en ;
  dcterms:modified "2026-06-07T15:30:29.310325Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6764-1
  a curric:KeyLearningPoint ;
  rdfs:label "The conclusion is the final paragraph of a non-fiction text."@en ;
  dcterms:modified "2026-06-07T15:30:29.310348Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6764-2
  a curric:KeyLearningPoint ;
  rdfs:label "Information in the conclusion should be kept general."@en ;
  dcterms:modified "2026-06-07T15:30:29.310352Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6764-3
  a curric:KeyLearningPoint ;
  rdfs:label """Plans should be used to document key, concise ideas. They can be built upon when
  writing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.310356Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6764-4
  a curric:KeyLearningPoint ;
  rdfs:label "When writing, we should use our success criteria and plan to guide us."@en ;
  dcterms:modified "2026-06-07T15:30:29.310360Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6764-5
  a curric:KeyLearningPoint ;
  rdfs:label """Using a range of cohesive devices enhances text flow and helps achieve the text
  purpose."""@en ;
  dcterms:modified "2026-06-07T15:30:29.310364Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8034-1
  a curric:KeyLearningPoint ;
  rdfs:label "Poets use vivid description to create imagery."@en ;
  dcterms:modified "2026-06-07T15:30:29.310463Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8034-2
  a curric:KeyLearningPoint ;
  rdfs:label """Poets may choose to use figurative language such as personification to bring their
  poem to life."""@en ;
  dcterms:modified "2026-06-07T15:30:29.310467Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8034-3
  a curric:KeyLearningPoint ;
  rdfs:label """Reading and rereading a poem leads to a richer response and a greater understanding
  of language within the poem."""@en ;
  dcterms:modified "2026-06-07T15:30:29.310471Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8034-4
  a curric:KeyLearningPoint ;
  rdfs:label """Engaging in conversations about poems allows us to make connections with our own
  lives and the world around us."""@en ;
  dcterms:modified "2026-06-07T15:30:29.310475Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8034-5
  a curric:KeyLearningPoint ;
  rdfs:label "A theme is a big idea, topic or message that recurs in a poem."@en ;
  dcterms:modified "2026-06-07T15:30:29.310479Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4863-1
  a curric:KeyLearningPoint ;
  rdfs:label """Notes should not be written in full sentences and bullet points can be used to order
  notes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.310648Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4863-2
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the paragraph is to explain how King Tut died and what happened when
  his tomb was discovered."""@en ;
  dcterms:modified "2026-06-07T15:30:29.310652Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4863-3
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials of cause and formal fronted adverbials are used at the start of
  sentences for cohesion."""@en ;
  dcterms:modified "2026-06-07T15:30:29.310677Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4863-4
  a curric:KeyLearningPoint ;
  rdfs:label """A subheading signals part of a a text and should stand out from the rest of the
  text."""@en ;
  dcterms:modified "2026-06-07T15:30:29.310739Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4863-5
  a curric:KeyLearningPoint ;
  rdfs:label "The plan should include subject-specific vocabulary."@en ;
  dcterms:modified "2026-06-07T15:30:29.310751Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7910-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘London is the Place for Me’ is a fixed verse song; it contains four verses each
  with five lines and a repeated refrain."""@en ;
  dcterms:modified "2026-06-07T15:30:29.310811Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7910-2
  a curric:KeyLearningPoint ;
  rdfs:label """The 1st and 2nd verses can be described as following the rhyme scheme of AABBA; the
  rhyme scheme varies in verses 3 - 5."""@en ;
  dcterms:modified "2026-06-07T15:30:29.310817Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7910-3
  a curric:KeyLearningPoint ;
  rdfs:label """‘London is the Place for Me’ can be described as being in strophic form: it uses the
  same melody repeated for each verse"""@en ;
  dcterms:modified "2026-06-07T15:30:29.310827Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7910-4
  a curric:KeyLearningPoint ;
  rdfs:label """Semantic mapping is a technique used to explore the rich meaning of a word or
  phrase."""@en ;
  dcterms:modified "2026-06-07T15:30:29.310833Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7910-5
  a curric:KeyLearningPoint ;
  rdfs:label """Impressions can be formed about a song once readers or listeners have a secure
  understanding of the language used."""@en ;
  dcterms:modified "2026-06-07T15:30:29.310837Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8075-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘In the Heart of a Book’ is a 20 line poem written by Liz Brownlee; the poem is
  split into 10 two-line verses."""@en ;
  dcterms:modified "2026-06-07T15:30:29.310841Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8075-2
  a curric:KeyLearningPoint ;
  rdfs:label "The poem includes repetition through the use of anaphora."@en ;
  dcterms:modified "2026-06-07T15:30:29.310845Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8075-3
  a curric:KeyLearningPoint ;
  rdfs:label """Anaphora can draw attention to what books can provide readers with emotionally,
  while maintaining the poem’s pace."""@en ;
  dcterms:modified "2026-06-07T15:30:29.310850Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8075-4
  a curric:KeyLearningPoint ;
  rdfs:label """Understanding a poem, its language, imagery & the impression it creates will help us
  to create an impactful performance."""@en ;
  dcterms:modified "2026-06-07T15:30:29.310854Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8050-1
  a curric:KeyLearningPoint ;
  rdfs:label """A tanka is a traditional Japanese form of poetry that originated more than 1,300
  years ago."""@en ;
  dcterms:modified "2026-06-07T15:30:29.310956Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8050-2
  a curric:KeyLearningPoint ;
  rdfs:label "Tankas often explore themes of nature, emotions and the passage of time."@en ;
  dcterms:modified "2026-06-07T15:30:29.310960Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8050-3
  a curric:KeyLearningPoint ;
  rdfs:label "When editing tankas, we can consider the specificity of our language choices."@en ;
  dcterms:modified "2026-06-07T15:30:29.310964Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8050-4
  a curric:KeyLearningPoint ;
  rdfs:label """Editing word choices and phrases can help to improve the imagery and impression
  created by our poems."""@en ;
  dcterms:modified "2026-06-07T15:30:29.310968Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8050-5
  a curric:KeyLearningPoint ;
  rdfs:label "Reading your poem aloud will help you to revise and refine it."@en ;
  dcterms:modified "2026-06-07T15:30:29.310972Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8085-1
  a curric:KeyLearningPoint ;
  rdfs:label """Writing about the impact of a poem allows for a deeper analysis of its
  effectiveness."""@en ;
  dcterms:modified "2026-06-07T15:30:29.311006Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8085-2
  a curric:KeyLearningPoint ;
  rdfs:label "There are certain poetry conventions that we can include in our writing."@en ;
  dcterms:modified "2026-06-07T15:30:29.311011Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8085-3
  a curric:KeyLearningPoint ;
  rdfs:label """Poetry conventions include naming the poet and title of the poem, using quotes and
  referring to the context."""@en ;
  dcterms:modified "2026-06-07T15:30:29.311015Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8085-4
  a curric:KeyLearningPoint ;
  rdfs:label """When writing about the impact of a poem we can discuss the poet, the poem’s imagery
  and structure, and the context."""@en ;
  dcterms:modified "2026-06-07T15:30:29.311019Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1054-1
  a curric:KeyLearningPoint ;
  rdfs:label "An apostrophe has more than one purpose."@en ;
  dcterms:modified "2026-06-07T15:30:29.311146Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1054-2
  a curric:KeyLearningPoint ;
  rdfs:label "An apostrophe can show if a noun belongs to another singular noun."@en ;
  dcterms:modified "2026-06-07T15:30:29.311150Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1054-3
  a curric:KeyLearningPoint ;
  rdfs:label "An apostrophe can show if a noun belongs to another plural noun."@en ;
  dcterms:modified "2026-06-07T15:30:29.311154Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1054-4
  a curric:KeyLearningPoint ;
  rdfs:label """There are rules for where to place the apostrophe for possession depending on if the
  noun is singular or plural."""@en ;
  dcterms:modified "2026-06-07T15:30:29.311160Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1054-5
  a curric:KeyLearningPoint ;
  rdfs:label """Apostrophes for singular possession or for plural possession are useful to make our
  meaning clear."""@en ;
  dcterms:modified "2026-06-07T15:30:29.311164Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27897-1
  a curric:KeyLearningPoint ;
  rdfs:label "A speaker can provoke an emotional response from an audience."@en ;
  dcterms:modified "2026-06-07T15:30:29.311169Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27897-2
  a curric:KeyLearningPoint ;
  rdfs:label "Provoking an emotional response may help a speaker to achieve their purpose."@en ;
  dcterms:modified "2026-06-07T15:30:29.311173Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27897-3
  a curric:KeyLearningPoint ;
  rdfs:label "Greta Thunberg is a Swedish activist and environmentalist."@en ;
  dcterms:modified "2026-06-07T15:30:29.311177Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27897-4
  a curric:KeyLearningPoint ;
  rdfs:label """Greta Thunberg made a speech at the United Nations Climate Change Conference when
  she was just 15 years old."""@en ;
  dcterms:modified "2026-06-07T15:30:29.311181Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6002-1
  a curric:KeyLearningPoint ;
  rdfs:label "Reading aloud involves speaking in front of others and listening to others."@en ;
  dcterms:modified "2026-06-07T15:30:29.311185Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6002-2
  a curric:KeyLearningPoint ;
  rdfs:label "Reading aloud involves speaking at a suitable volume and pace."@en ;
  dcterms:modified "2026-06-07T15:30:29.311189Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6002-3
  a curric:KeyLearningPoint ;
  rdfs:label """Reading with expression means reading with feelings and emotion to bring the words
  to life."""@en ;
  dcterms:modified "2026-06-07T15:30:29.311193Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6002-4
  a curric:KeyLearningPoint ;
  rdfs:label """Making eye contact with the audience helps the reader to connect with the
  audience."""@en ;
  dcterms:modified "2026-06-07T15:30:29.311197Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6002-5
  a curric:KeyLearningPoint ;
  rdfs:label """Confident body language and use of facial expressions are an important aspect of
  reading aloud."""@en ;
  dcterms:modified "2026-06-07T15:30:29.311203Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28403-1
  a curric:KeyLearningPoint ;
  rdfs:label """At the end of the text, Nate leaves primary school with his friends around him &
  Dylan has been released from hospital."""@en ;
  dcterms:modified "2026-06-07T15:30:29.311208Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28403-2
  a curric:KeyLearningPoint ;
  rdfs:label """The theme of identity is conveyed through Nate’s emotional journey to find out who
  he is."""@en ;
  dcterms:modified "2026-06-07T15:30:29.311214Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28403-3
  a curric:KeyLearningPoint ;
  rdfs:label """Hearing from the author and illustrator can enhance the reading process by adding
  layers of meaning and context."""@en ;
  dcterms:modified "2026-06-07T15:30:29.311218Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28403-4
  a curric:KeyLearningPoint ;
  rdfs:label """A take-away idea within a text may link to themes that are explored and developed in
  it."""@en ;
  dcterms:modified "2026-06-07T15:30:29.311222Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28403-5
  a curric:KeyLearningPoint ;
  rdfs:label "We will all have different ideas and responses to a text as we are all unique."@en ;
  dcterms:modified "2026-06-07T15:30:29.311226Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6755-1
  a curric:KeyLearningPoint ;
  rdfs:label "Writing is most successful when it is planned."@en ;
  dcterms:modified "2026-06-07T15:30:29.311230Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6755-2
  a curric:KeyLearningPoint ;
  rdfs:label """In a journalistic report, we can plan both the factual information and perspectives
  we include."""@en ;
  dcterms:modified "2026-06-07T15:30:29.311234Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6755-3
  a curric:KeyLearningPoint ;
  rdfs:label """A journalistic report starts with an introduction giving a summary of the factual
  information."""@en ;
  dcterms:modified "2026-06-07T15:30:29.311238Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6755-4
  a curric:KeyLearningPoint ;
  rdfs:label """The main paragraphs include perspectives using direct and reported speech, along
  with some additional facts."""@en ;
  dcterms:modified "2026-06-07T15:30:29.311245Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6755-5
  a curric:KeyLearningPoint ;
  rdfs:label "The conclusion gives the 'official' perspective and looks to the future."@en ;
  dcterms:modified "2026-06-07T15:30:29.311249Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1341-1
  a curric:KeyLearningPoint ;
  rdfs:label "The suffix -cial is common after a vowel letter."@en ;
  dcterms:modified "2026-06-07T15:30:29.312256Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1341-2
  a curric:KeyLearningPoint ;
  rdfs:label "The suffix -tial is common after a consonant letter."@en ;
  dcterms:modified "2026-06-07T15:30:29.312260Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1341-3
  a curric:KeyLearningPoint ;
  rdfs:label "Words ending in the suffix -cial or -tial are generally adjectives."@en ;
  dcterms:modified "2026-06-07T15:30:29.312264Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1341-4
  a curric:KeyLearningPoint ;
  rdfs:label "Exceptions include: financial, commercial, provincial."@en ;
  dcterms:modified "2026-06-07T15:30:29.312268Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1341-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: occur, occupy and communicate."@en ;
  dcterms:modified "2026-06-07T15:30:29.312272Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1331-1
  a curric:KeyLearningPoint ;
  rdfs:label "If the root word ends in 'y', remove the 'y' and add -iest."@en ;
  dcterms:modified "2026-06-07T15:30:29.312296Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1331-2
  a curric:KeyLearningPoint ;
  rdfs:label "If the root word ends in 'e', remove the 'e' and add -est."@en ;
  dcterms:modified "2026-06-07T15:30:29.312302Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1331-3
  a curric:KeyLearningPoint ;
  rdfs:label """If the root word contains a short vowel sound, double the consonant and add
  -est."""@en ;
  dcterms:modified "2026-06-07T15:30:29.312306Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1331-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Most' is irregular because it does not follow the same pattern. The comparative
  'more' becomes 'most'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.312310Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1331-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: secretary and controversy."@en ;
  dcterms:modified "2026-06-07T15:30:29.312315Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7644-1
  a curric:KeyLearningPoint ;
  rdfs:label "It is crucial to communicate the unique selling point of a product."@en ;
  dcterms:modified "2026-06-07T15:30:29.312319Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7644-2
  a curric:KeyLearningPoint ;
  rdfs:label """A persuasive advert should explain the benefits of a product to the reader, e.g.
  health benefits."""@en ;
  dcterms:modified "2026-06-07T15:30:29.312323Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7644-3
  a curric:KeyLearningPoint ;
  rdfs:label """For a healthy food product, it is crucial to detail ingredients, nutrients and
  health benefits."""@en ;
  dcterms:modified "2026-06-07T15:30:29.312327Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7644-4
  a curric:KeyLearningPoint ;
  rdfs:label """A formal fronted adverbial can be used to contrast information within a main
  clause."""@en ;
  dcterms:modified "2026-06-07T15:30:29.312333Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7645-1
  a curric:KeyLearningPoint ;
  rdfs:label """A slogan is an important feature of persuasive advertising and needs to be memorable
  and catchy."""@en ;
  dcterms:modified "2026-06-07T15:30:29.312430Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7645-2
  a curric:KeyLearningPoint ;
  rdfs:label """The layout of a persuasive advert is crucial for ensuring it is visually appealing
  to the reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.312434Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7645-3
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to use neat and creative presentation when publishing a persuasive
  advert."""@en ;
  dcterms:modified "2026-06-07T15:30:29.312438Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7645-4
  a curric:KeyLearningPoint ;
  rdfs:label """A published persuasive advert should be visually and linguistically appealing to the
  reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.312443Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1390-1
  a curric:KeyLearningPoint ;
  rdfs:label "In words of Greek origin, the letter string 'ch' makes the /k/ sound."@en ;
  dcterms:modified "2026-06-07T15:30:29.312507Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1390-2
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: stomach, important and certain."@en ;
  dcterms:modified "2026-06-07T15:30:29.312511Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6160-1
  a curric:KeyLearningPoint ;
  rdfs:label """Our journalistic report will end with a conclusion that updates the story and gives
  an 'official' position."""@en ;
  dcterms:modified "2026-06-07T15:30:29.312558Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6160-2
  a curric:KeyLearningPoint ;
  rdfs:label "The conclusion will also look to the future to explain what will happen next."@en ;
  dcterms:modified "2026-06-07T15:30:29.312562Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6160-3
  a curric:KeyLearningPoint ;
  rdfs:label """After we finish a first draft, we use editing time to rethink, rephrase and
  reconsider those first ideas."""@en ;
  dcterms:modified "2026-06-07T15:30:29.312568Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6160-4
  a curric:KeyLearningPoint ;
  rdfs:label "Editing can be done by oneself, with a peer or with a teacher."@en ;
  dcterms:modified "2026-06-07T15:30:29.312573Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6160-5
  a curric:KeyLearningPoint ;
  rdfs:label """Editing is most successful when it is chunked by punctuation, sentence structure,
  vocabulary and cohesive devices."""@en ;
  dcterms:modified "2026-06-07T15:30:29.312577Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4828-1
  a curric:KeyLearningPoint ;
  rdfs:label """Journalistic reports use formal language, are usually written in the third person
  and will usually include quotes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.312581Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4828-2
  a curric:KeyLearningPoint ;
  rdfs:label """The title of a journalistic report is called the headline. Most words in the
  headline will start with a capital letter."""@en ;
  dcterms:modified "2026-06-07T15:30:29.312585Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4828-3
  a curric:KeyLearningPoint ;
  rdfs:label """Capital letters are used after inverted commas in speech first and speech second
  sentences."""@en ;
  dcterms:modified "2026-06-07T15:30:29.312591Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4828-4
  a curric:KeyLearningPoint ;
  rdfs:label "Capital letters are formed separately, they do not join to other letters."@en ;
  dcterms:modified "2026-06-07T15:30:29.312596Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4828-5
  a curric:KeyLearningPoint ;
  rdfs:label """The letter formation, spacing and cursive joins need to be correct for the writing
  to be legible."""@en ;
  dcterms:modified "2026-06-07T15:30:29.312600Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3408-1
  a curric:KeyLearningPoint ;
  rdfs:label "Presenting involves speaking in front of others and listening to others."@en ;
  dcterms:modified "2026-06-07T15:30:29.312680Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3408-2
  a curric:KeyLearningPoint ;
  rdfs:label """Presenting involves speaking with clear diction and suitable volume, making eye
  contact and using strong body language."""@en ;
  dcterms:modified "2026-06-07T15:30:29.312684Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3408-3
  a curric:KeyLearningPoint ;
  rdfs:label "Practising pronouncing tricky words helps develop clear diction when presenting."@en ;
  dcterms:modified "2026-06-07T15:30:29.312688Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3408-4
  a curric:KeyLearningPoint ;
  rdfs:label "Rehearsing helps the presenter to speak more confidently and fluently."@en ;
  dcterms:modified "2026-06-07T15:30:29.312693Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3408-5
  a curric:KeyLearningPoint ;
  rdfs:label "Pauses at the end of sentences can help the audience follow what is being said."@en ;
  dcterms:modified "2026-06-07T15:30:29.312697Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7346-1
  a curric:KeyLearningPoint ;
  rdfs:label "‘A Christmas Carol’ is set in Victorian London during the Christmas period."@en ;
  dcterms:modified "2026-06-07T15:30:29.313461Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7346-2
  a curric:KeyLearningPoint ;
  rdfs:label "The atmosphere is the tone or mood created in a narrative."@en ;
  dcterms:modified "2026-06-07T15:30:29.313467Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7346-3
  a curric:KeyLearningPoint ;
  rdfs:label """Precise vocabulary, including a range of sensory details, conveys the atmosphere in
  a narrative setting description."""@en ;
  dcterms:modified "2026-06-07T15:30:29.313471Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7346-4
  a curric:KeyLearningPoint ;
  rdfs:label """Personification is a linguistic device used to describe a non-living thing as if it
  acts or feels like a human."""@en ;
  dcterms:modified "2026-06-07T15:30:29.313475Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1356-1
  a curric:KeyLearningPoint ;
  rdfs:label "A hyphen can be used to join a prefix to a root word but there are no set rules."@en ;
  dcterms:modified "2026-06-07T15:30:29.313590Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1356-2
  a curric:KeyLearningPoint ;
  rdfs:label """Hyphens are more commonly used to prevent two vowels appearing next to each other
  e.g. re-enter and co-ordinate."""@en ;
  dcterms:modified "2026-06-07T15:30:29.313593Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1356-3
  a curric:KeyLearningPoint ;
  rdfs:label """Hyphens are often used with the prefixes ex- and self- e.g. ex-president and
  self-care."""@en ;
  dcterms:modified "2026-06-07T15:30:29.313598Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1356-4
  a curric:KeyLearningPoint ;
  rdfs:label """Hyphens can join a prefix to a root word to avoid ambiguity in meaning e.g. re-cover
  or recover."""@en ;
  dcterms:modified "2026-06-07T15:30:29.313602Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1356-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: interrupt and exaggerate."@en ;
  dcterms:modified "2026-06-07T15:30:29.313606Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6271-1
  a curric:KeyLearningPoint ;
  rdfs:label """In the Western story, panels are designed to be read from left to right; the
  Moroccan story is read from right to left."""@en ;
  dcterms:modified "2026-06-07T15:30:29.313667Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6271-2
  a curric:KeyLearningPoint ;
  rdfs:label "Looking for contextual clues help us to infer meaning from images."@en ;
  dcterms:modified "2026-06-07T15:30:29.313672Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6271-3
  a curric:KeyLearningPoint ;
  rdfs:label "Inferring meaning can help us to build our understanding of the story."@en ;
  dcterms:modified "2026-06-07T15:30:29.313675Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6271-4
  a curric:KeyLearningPoint ;
  rdfs:label "Drawing comparisons between images helps us to understand their meaning."@en ;
  dcterms:modified "2026-06-07T15:30:29.313680Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6109-1
  a curric:KeyLearningPoint ;
  rdfs:label """Text cohesion refers to how a text flows together to maintain the interest of the
  reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.313697Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6109-2
  a curric:KeyLearningPoint ;
  rdfs:label """We can improve text cohesion using cohesive devices that connect information within
  and between sentences."""@en ;
  dcterms:modified "2026-06-07T15:30:29.313702Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6109-3
  a curric:KeyLearningPoint ;
  rdfs:label """Compound and complex sentences can be used to join linked information in one
  sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.313706Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6109-4
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials can be used to show links between information in adjacent
  sentences."""@en ;
  dcterms:modified "2026-06-07T15:30:29.313710Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6109-5
  a curric:KeyLearningPoint ;
  rdfs:label """There are different types of complex sentence and fronted adverbials, which serve
  different purposes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.313714Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28948-1
  a curric:KeyLearningPoint ;
  rdfs:label """Reading and re-reading poems leads to a richer response and a greater understanding
  of language within the poem."""@en ;
  dcterms:modified "2026-06-07T15:30:29.313718Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28948-2
  a curric:KeyLearningPoint ;
  rdfs:label """Engaging in conversations about poems allows us to make connections with our own
  lives and the world around us."""@en ;
  dcterms:modified "2026-06-07T15:30:29.313722Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28948-3
  a curric:KeyLearningPoint ;
  rdfs:label """Comparing poems involves exploring the themes, structures and language
  within them."""@en ;
  dcterms:modified "2026-06-07T15:30:29.313725Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28948-4
  a curric:KeyLearningPoint ;
  rdfs:label "A theme is a big idea, topic or message that recurs in a poem."@en ;
  dcterms:modified "2026-06-07T15:30:29.313732Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28949-1
  a curric:KeyLearningPoint ;
  rdfs:label """Poets can use a range of poetic devices to enhance the meaning or impact of their
  poems."""@en ;
  dcterms:modified "2026-06-07T15:30:29.313860Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28949-2
  a curric:KeyLearningPoint ;
  rdfs:label """Alliteration is when words that begin with the same sound are placed close
  together."""@en ;
  dcterms:modified "2026-06-07T15:30:29.313864Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28949-3
  a curric:KeyLearningPoint ;
  rdfs:label """Onomtopoeia refers to words that imitate the natural sounds associated with the
  objects or actions they refer to."""@en ;
  dcterms:modified "2026-06-07T15:30:29.313868Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28949-4
  a curric:KeyLearningPoint ;
  rdfs:label """Understanding a poem, its language and the impression it creates will help us to
  create an impactful performance."""@en ;
  dcterms:modified "2026-06-07T15:30:29.313872Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28949-5
  a curric:KeyLearningPoint ;
  rdfs:label """There are many things we can do to prepare for a performance, including practising
  reading the poem aloud."""@en ;
  dcterms:modified "2026-06-07T15:30:29.313876Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8024-1
  a curric:KeyLearningPoint ;
  rdfs:label "Minuscule, tiny, minute and diminutive are words to describe small objects."@en ;
  dcterms:modified "2026-06-07T15:30:29.313880Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8024-2
  a curric:KeyLearningPoint ;
  rdfs:label "The subject of a poem is what the poem is about."@en ;
  dcterms:modified "2026-06-07T15:30:29.313885Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8024-3
  a curric:KeyLearningPoint ;
  rdfs:label """Poets must decide the tone and emotional impact of their poem before they start
  generating language."""@en ;
  dcterms:modified "2026-06-07T15:30:29.313889Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8024-4
  a curric:KeyLearningPoint ;
  rdfs:label """Poets should decide the subject of the poem; something that inspires poetry and will
  be interesting to write about."""@en ;
  dcterms:modified "2026-06-07T15:30:29.313893Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8052-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘Cosmic Disco’ is a free verse poem without a strict line length or rhyming
  structure."""@en ;
  dcterms:modified "2026-06-07T15:30:29.313912Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8052-2
  a curric:KeyLearningPoint ;
  rdfs:label """Understanding a poem, its language and the impression it creates will help us to
  create an impactful performance."""@en ;
  dcterms:modified "2026-06-07T15:30:29.313916Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8052-3
  a curric:KeyLearningPoint ;
  rdfs:label "We can improve our performances of poetry through practice."@en ;
  dcterms:modified "2026-06-07T15:30:29.313920Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8052-4
  a curric:KeyLearningPoint ;
  rdfs:label """The rhythm and flow, our use of voice, gestures and movement & showing expression
  and emotion all help our performance."""@en ;
  dcterms:modified "2026-06-07T15:30:29.313924Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1085-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Devour' is a verb which means to eat hungrily or gobble up."@en ;
  dcterms:modified "2026-06-07T15:30:29.313930Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1085-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Demolish' is a verb which means to destroy or eat up."@en ;
  dcterms:modified "2026-06-07T15:30:29.313934Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1085-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Savour', inhale', 'guzzle' and 'gorge' are other verbs related to eating."@en ;
  dcterms:modified "2026-06-07T15:30:29.313938Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6373-1
  a curric:KeyLearningPoint ;
  rdfs:label """Alred Noyes uses figurative language to provide imagery and describe events in
  stanzas five and six."""@en ;
  dcterms:modified "2026-06-07T15:30:29.313991Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6373-2
  a curric:KeyLearningPoint ;
  rdfs:label "Texts written a long time ago may contain unfamiliar vocabulary."@en ;
  dcterms:modified "2026-06-07T15:30:29.313995Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6373-3
  a curric:KeyLearningPoint ;
  rdfs:label """Understanding the author's vocabulary choices is essential to understanding the text
  fully."""@en ;
  dcterms:modified "2026-06-07T15:30:29.313999Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6373-4
  a curric:KeyLearningPoint ;
  rdfs:label """Analysing a text enables readers to understand the events, characters and their
  actions in greater depth."""@en ;
  dcterms:modified "2026-06-07T15:30:29.314005Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1424-1
  a curric:KeyLearningPoint ;
  rdfs:label """A suffix is a letter or group of letters at the end of a word which creates another
  word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.314009Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1424-2
  a curric:KeyLearningPoint ;
  rdfs:label "-ed is a suffix that can be used to create the past tense."@en ;
  dcterms:modified "2026-06-07T15:30:29.314014Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1424-3
  a curric:KeyLearningPoint ;
  rdfs:label "Some root words just add -ed to create the past tense."@en ;
  dcterms:modified "2026-06-07T15:30:29.314018Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1424-4
  a curric:KeyLearningPoint ;
  rdfs:label """Some root words lose the final e and add the suffix -ed to create the past
  tense."""@en ;
  dcterms:modified "2026-06-07T15:30:29.314022Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1424-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum word: circle."@en ;
  dcterms:modified "2026-06-07T15:30:29.314026Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1086-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Submerged' is an adjective, which means to be completely underwater."@en ;
  dcterms:modified "2026-06-07T15:30:29.315404Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1086-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Drenched' is an adjective, which means sopping wet or soaked."@en ;
  dcterms:modified "2026-06-07T15:30:29.315408Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1086-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Immerse', 'squirt', 'douse' and 'plunge' are other verbs related to the
  word wet."""@en ;
  dcterms:modified "2026-06-07T15:30:29.315412Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7916-1
  a curric:KeyLearningPoint ;
  rdfs:label "When we read, we make inferences based on evidence."@en ;
  dcterms:modified "2026-06-07T15:30:29.315438Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7916-2
  a curric:KeyLearningPoint ;
  rdfs:label """We can infer what characters' thoughts might be based on their actions and stated
  words."""@en ;
  dcterms:modified "2026-06-07T15:30:29.315442Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7916-3
  a curric:KeyLearningPoint ;
  rdfs:label """We can also infer characters' motives - their reasons for acting - which might be
  different to their stated motives."""@en ;
  dcterms:modified "2026-06-07T15:30:29.315446Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7916-4
  a curric:KeyLearningPoint ;
  rdfs:label """Our inferences will also make use of empathy - and we should remember we can never
  empathise perfectly with others."""@en ;
  dcterms:modified "2026-06-07T15:30:29.315450Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3403-1
  a curric:KeyLearningPoint ;
  rdfs:label """The plan includes keywords and subject-specific vocabulary related to the
  section."""@en ;
  dcterms:modified "2026-06-07T15:30:29.315454Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3403-2
  a curric:KeyLearningPoint ;
  rdfs:label "Taking notes is a skill."@en ;
  dcterms:modified "2026-06-07T15:30:29.315458Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3403-3
  a curric:KeyLearningPoint ;
  rdfs:label """Notes should not be written in full sentences and bullet points can be used to order
  notes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.315462Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3403-4
  a curric:KeyLearningPoint ;
  rdfs:label "Key vocabulary and linguistic devices should be logged in a plan."@en ;
  dcterms:modified "2026-06-07T15:30:29.315466Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3403-5
  a curric:KeyLearningPoint ;
  rdfs:label "The plan should be clearly structured in the order of the section."@en ;
  dcterms:modified "2026-06-07T15:30:29.315470Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6733-1
  a curric:KeyLearningPoint ;
  rdfs:label "Writing is most successful when structure, content and vocabulary are planned."@en ;
  dcterms:modified "2026-06-07T15:30:29.315486Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6733-2
  a curric:KeyLearningPoint ;
  rdfs:label "We are aiming to set a tense, pacy atmosphere in our climax and resolution."@en ;
  dcterms:modified "2026-06-07T15:30:29.315490Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6733-3
  a curric:KeyLearningPoint ;
  rdfs:label """Short sentences, rhetorical questions and 'quick' fronted adverbials of time can add
  pace to a piece of writing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.315496Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6733-4
  a curric:KeyLearningPoint ;
  rdfs:label "We can use a colon to introduce a question to show a character's inner thoughts."@en ;
  dcterms:modified "2026-06-07T15:30:29.315502Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6733-5
  a curric:KeyLearningPoint ;
  rdfs:label """We can use a relative complex sentence as a cohesive device to add detail after a
  noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.315507Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1123-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Fiery' is an adjective which means hot-tempered, passionate or burning."@en ;
  dcterms:modified "2026-06-07T15:30:29.315529Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1123-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Steely' is an adjective which means cold and determined."@en ;
  dcterms:modified "2026-06-07T15:30:29.315533Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1123-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Vacant' is an adjective which means empty or without emotion."@en ;
  dcterms:modified "2026-06-07T15:30:29.315537Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1126-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Assertive' is an adjective which means forceful or self-confident."@en ;
  dcterms:modified "2026-06-07T15:30:29.315585Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1126-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Audacious' is an adjective which means bold and daring."@en ;
  dcterms:modified "2026-06-07T15:30:29.315589Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1126-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Brazen' is an adjective which means bold and shameless."@en ;
  dcterms:modified "2026-06-07T15:30:29.315611Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1388-1
  a curric:KeyLearningPoint ;
  rdfs:label """Soft c and hard c refer to two different sounds that the letter c can represent,
  depending on what follows it."""@en ;
  dcterms:modified "2026-06-07T15:30:29.315727Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1388-2
  a curric:KeyLearningPoint ;
  rdfs:label """If the vowel letters ‘a’, ‘o’ or ‘u’ or a consonant letter follows the letter c it
  is pronounced as a hard c."""@en ;
  dcterms:modified "2026-06-07T15:30:29.315733Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1388-3
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: calendar, occur and occupy."@en ;
  dcterms:modified "2026-06-07T15:30:29.315738Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2731-1
  a curric:KeyLearningPoint ;
  rdfs:label "A sentence composed of one main clause is a simple sentence."@en ;
  dcterms:modified "2026-06-07T15:30:29.315807Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2731-2
  a curric:KeyLearningPoint ;
  rdfs:label """A sentence composed of at least two main clauses joined by a co-ordinating
  conjunction is a compound sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.315811Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2731-3
  a curric:KeyLearningPoint ;
  rdfs:label """A sentence composed of at least one main clause and an adverbial subordinate clause
  is an adverbial complex sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.315815Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2731-4
  a curric:KeyLearningPoint ;
  rdfs:label """A sentence composed of at least one main clause and a relative subordinate clause is
  a relative complex sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.315819Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2731-5
  a curric:KeyLearningPoint ;
  rdfs:label """Specific comma rules apply to the demarcation of clauses in compound and complex
  sentence structures."""@en ;
  dcterms:modified "2026-06-07T15:30:29.315823Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1328-1
  a curric:KeyLearningPoint ;
  rdfs:label """If the root word contains a short vowel sound, double the consonant and add the
  suffix -ed."""@en ;
  dcterms:modified "2026-06-07T15:30:29.315827Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1328-2
  a curric:KeyLearningPoint ;
  rdfs:label """If the root word ends in 'y', remove the 'y' and add -ied unless there is a vowel
  before the 'y'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.315831Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1328-3
  a curric:KeyLearningPoint ;
  rdfs:label "If the root word is a verb that ends in 'e', remove the 'e' and add -ed."@en ;
  dcterms:modified "2026-06-07T15:30:29.315835Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1328-4
  a curric:KeyLearningPoint ;
  rdfs:label """There are specific rules for words containing the stressed or unstressed 'fer'
  spelling."""@en ;
  dcterms:modified "2026-06-07T15:30:29.315839Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1328-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: determined, suggest."@en ;
  dcterms:modified "2026-06-07T15:30:29.315845Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1329-1
  a curric:KeyLearningPoint ;
  rdfs:label """If the root word contains a short vowel sound, double the consonant and add the
  suffix -ing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.315895Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1329-2
  a curric:KeyLearningPoint ;
  rdfs:label "If the root word ends in 'y', just add the suffix -ing."@en ;
  dcterms:modified "2026-06-07T15:30:29.315899Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1329-3
  a curric:KeyLearningPoint ;
  rdfs:label """If the root word is a verb that ends in 'e', remove the 'e' and add the
  suffix -ing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.315903Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1329-4
  a curric:KeyLearningPoint ;
  rdfs:label """There are specific rules for words containing the stressed or unstressed 'fer'
  spelling."""@en ;
  dcterms:modified "2026-06-07T15:30:29.315906Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1329-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: appreciate, curiosity."@en ;
  dcterms:modified "2026-06-07T15:30:29.315911Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5755-1
  a curric:KeyLearningPoint ;
  rdfs:label "A subheading signals to the reader what the section is about."@en ;
  dcterms:modified "2026-06-07T15:30:29.315915Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5755-2
  a curric:KeyLearningPoint ;
  rdfs:label """A section about one feature of the report's subject contains specific facts and
  information to keep the reader engaged."""@en ;
  dcterms:modified "2026-06-07T15:30:29.315919Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5755-3
  a curric:KeyLearningPoint ;
  rdfs:label """Using the full range of sentence types (simple, compound and complex) improves text
  flow for the reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.315925Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5755-4
  a curric:KeyLearningPoint ;
  rdfs:label """Sentences should be said aloud before writing to ensure they make sense and read
  back once written to check for errors."""@en ;
  dcterms:modified "2026-06-07T15:30:29.315929Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5755-5
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials of cause and formal fronted adverbials are used at the start of
  sentences for cohesion."""@en ;
  dcterms:modified "2026-06-07T15:30:29.315933Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1348-1
  a curric:KeyLearningPoint ;
  rdfs:label """The -able and -ably endings are the most common spellings for this sound and are
  therefore the best bet."""@en ;
  dcterms:modified "2026-06-07T15:30:29.315959Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1348-2
  a curric:KeyLearningPoint ;
  rdfs:label """Removing the -able suffix generally leaves a recognisable word, e.g. understand -
  understandable"""@en ;
  dcterms:modified "2026-06-07T15:30:29.315963Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1348-3
  a curric:KeyLearningPoint ;
  rdfs:label """Words in word families using the suffixes -ation, -able and -ably are connected in
  spelling and meaning."""@en ;
  dcterms:modified "2026-06-07T15:30:29.315967Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1348-4
  a curric:KeyLearningPoint ;
  rdfs:label """Drop the final -e of the root word before adding the suffix -able unless the words
  end in -ce or -ge"""@en ;
  dcterms:modified "2026-06-07T15:30:29.315971Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1348-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: privilege, system."@en ;
  dcterms:modified "2026-06-07T15:30:29.315996Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1440-1
  a curric:KeyLearningPoint ;
  rdfs:label """-ful and -less are suffixes that can be used to change the meaning of a root
  word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.316098Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1440-2
  a curric:KeyLearningPoint ;
  rdfs:label "Some root words can use the suffixes -ful and -less."@en ;
  dcterms:modified "2026-06-07T15:30:29.316103Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1440-3
  a curric:KeyLearningPoint ;
  rdfs:label """The -less and -ful suffixes start with a consonant, so the root word usually doesn’t
  change when the suffix is added."""@en ;
  dcterms:modified "2026-06-07T15:30:29.316107Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1440-4
  a curric:KeyLearningPoint ;
  rdfs:label """If the root word has more than one syllable and ends in a consonant +y, then ‘y’ is
  replaced by ‘i’ before the suffix."""@en ;
  dcterms:modified "2026-06-07T15:30:29.316111Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1440-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: reign and island."@en ;
  dcterms:modified "2026-06-07T15:30:29.316116Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8061-1
  a curric:KeyLearningPoint ;
  rdfs:label """William Blake was an English poet, painter and printmaker, who was born in 1757 and
  died in 1827."""@en ;
  dcterms:modified "2026-06-07T15:30:29.316123Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8061-2
  a curric:KeyLearningPoint ;
  rdfs:label """‘The Tyger’ consists of six verses, each with four lines; each verse has a rhyme
  scheme of AABB."""@en ;
  dcterms:modified "2026-06-07T15:30:29.316127Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8061-3
  a curric:KeyLearningPoint ;
  rdfs:label "The poem 'The Tyger' describes the creation of a powerful and fearsome tiger."@en ;
  dcterms:modified "2026-06-07T15:30:29.316131Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8061-4
  a curric:KeyLearningPoint ;
  rdfs:label """The speaker questions who or what could create such a fearsome and awe-inspiring
  creature."""@en ;
  dcterms:modified "2026-06-07T15:30:29.316135Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6324-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Shackleton's Journey' is presented as a non-fiction picturebook text."@en ;
  dcterms:modified "2026-06-07T15:30:29.316139Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6324-2
  a curric:KeyLearningPoint ;
  rdfs:label """The text chronicles the extraordinary Antarctic expedition led by Sir Ernest
  Shackleton in 1914."""@en ;
  dcterms:modified "2026-06-07T15:30:29.316143Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6324-3
  a curric:KeyLearningPoint ;
  rdfs:label """Antarctica is a vast and frigid continent located at the southernmost part of the
  Earth."""@en ;
  dcterms:modified "2026-06-07T15:30:29.316147Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6324-4
  a curric:KeyLearningPoint ;
  rdfs:label "Exploring the context of a text can allow readers to engage with it more deeply."@en ;
  dcterms:modified "2026-06-07T15:30:29.316151Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6349-1
  a curric:KeyLearningPoint ;
  rdfs:label "Our persuasive letter must include a summary of the mystery."@en ;
  dcterms:modified "2026-06-07T15:30:29.316265Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6349-2
  a curric:KeyLearningPoint ;
  rdfs:label """We can base the details of this summary on a journalistic report about the
  mystery."""@en ;
  dcterms:modified "2026-06-07T15:30:29.316271Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6349-3
  a curric:KeyLearningPoint ;
  rdfs:label """The letter must also give reasons that will persuade Holmes to investigate the
  crime."""@en ;
  dcterms:modified "2026-06-07T15:30:29.316276Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6349-4
  a curric:KeyLearningPoint ;
  rdfs:label "We can generate these reasons by empathising with the main character."@en ;
  dcterms:modified "2026-06-07T15:30:29.316280Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6349-5
  a curric:KeyLearningPoint ;
  rdfs:label "We can record all these ideas in note form."@en ;
  dcterms:modified "2026-06-07T15:30:29.316284Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4896-1
  a curric:KeyLearningPoint ;
  rdfs:label "Editing is an essential part of the writing process."@en ;
  dcterms:modified "2026-06-07T15:30:29.316318Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4896-2
  a curric:KeyLearningPoint ;
  rdfs:label """Editing does not involve rewriting the entire piece but being selective about what
  to edit and improve."""@en ;
  dcterms:modified "2026-06-07T15:30:29.316322Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4896-3
  a curric:KeyLearningPoint ;
  rdfs:label """Punctuation, sentence structure, grammar, vocabulary precision and spelling can all
  be edited."""@en ;
  dcterms:modified "2026-06-07T15:30:29.316326Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4896-4
  a curric:KeyLearningPoint ;
  rdfs:label "The purpose of editing is to ensure the text meets its text purpose."@en ;
  dcterms:modified "2026-06-07T15:30:29.316330Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4899-1
  a curric:KeyLearningPoint ;
  rdfs:label "The conclusion is the final paragraph of a non-chronological report."@en ;
  dcterms:modified "2026-06-07T15:30:29.316358Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4899-2
  a curric:KeyLearningPoint ;
  rdfs:label "The purpose of the conclusion is to summarise the key information of the report."@en ;
  dcterms:modified "2026-06-07T15:30:29.316363Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4899-3
  a curric:KeyLearningPoint ;
  rdfs:label "Only general information is included in the conclusion."@en ;
  dcterms:modified "2026-06-07T15:30:29.316367Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4899-4
  a curric:KeyLearningPoint ;
  rdfs:label """Success criteria can be used to help a writer understand what to include in their
  writing to make it successful."""@en ;
  dcterms:modified "2026-06-07T15:30:29.316373Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6415-1
  a curric:KeyLearningPoint ;
  rdfs:label """Writing is most successful when it is planned. We can plan to describe events and
  feelings for a diary entry."""@en ;
  dcterms:modified "2026-06-07T15:30:29.316427Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6415-2
  a curric:KeyLearningPoint ;
  rdfs:label """A diary entry is most often written retrospectively with no other intended reader
  than the writer themselves."""@en ;
  dcterms:modified "2026-06-07T15:30:29.316431Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6415-3
  a curric:KeyLearningPoint ;
  rdfs:label """A Windrush passenger's diary could contain entries from on the ship and after
  arriving in the UK."""@en ;
  dcterms:modified "2026-06-07T15:30:29.316435Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6415-4
  a curric:KeyLearningPoint ;
  rdfs:label """First person is used to write a diary entry and entries can use both past and
  present tense."""@en ;
  dcterms:modified "2026-06-07T15:30:29.316439Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6415-5
  a curric:KeyLearningPoint ;
  rdfs:label "We can plan to include a range of vocabulary to describe emotions."@en ;
  dcterms:modified "2026-06-07T15:30:29.316443Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2720-1
  a curric:KeyLearningPoint ;
  rdfs:label """'Jabberwocky' was written in 1871 by Lewis Carroll and included in his book 'Alice
  Through the Looking Glass'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.317028Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2720-2
  a curric:KeyLearningPoint ;
  rdfs:label "Speaking in a clear and engaging tone is important when reading a poem aloud."@en ;
  dcterms:modified "2026-06-07T15:30:29.317032Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2720-3
  a curric:KeyLearningPoint ;
  rdfs:label "Nonsense words are completely made up words that do not have a meaning."@en ;
  dcterms:modified "2026-06-07T15:30:29.317036Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2720-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Jabberwocky' tells the story of a young man defeating a dangerous creature: the
  Jabberwock."""@en ;
  dcterms:modified "2026-06-07T15:30:29.317040Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2720-5
  a curric:KeyLearningPoint ;
  rdfs:label """Summarising the verses helps the reader to be able order the key moments
  chronologically."""@en ;
  dcterms:modified "2026-06-07T15:30:29.317044Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8137-1
  a curric:KeyLearningPoint ;
  rdfs:label """When rehearsing and planning to write a diary entry, we do so in the first person
  from the character's perspective."""@en ;
  dcterms:modified "2026-06-07T15:30:29.317048Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8137-2
  a curric:KeyLearningPoint ;
  rdfs:label "An effective plan for a diary entry contains important thoughts and feelings."@en ;
  dcterms:modified "2026-06-07T15:30:29.317056Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8137-3
  a curric:KeyLearningPoint ;
  rdfs:label """A plan is written in note format using bullet points to capture the most important
  information."""@en ;
  dcterms:modified "2026-06-07T15:30:29.317060Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8137-4
  a curric:KeyLearningPoint ;
  rdfs:label "This paragraph will explain what the girl misses about home."@en ;
  dcterms:modified "2026-06-07T15:30:29.317064Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8137-5
  a curric:KeyLearningPoint ;
  rdfs:label "This paragraph will also explain what the girl hopes for in the future."@en ;
  dcterms:modified "2026-06-07T15:30:29.317068Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5822-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the build-up is to develop the plot and characters, introduce a
  problem and build up tension."""@en ;
  dcterms:modified "2026-06-07T15:30:29.317072Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5822-2
  a curric:KeyLearningPoint ;
  rdfs:label """Show-not-tell allows the reader to observe the emotions a character may be
  experiencing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.317076Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5822-3
  a curric:KeyLearningPoint ;
  rdfs:label "A relative clause can be used to give additional information about a noun."@en ;
  dcterms:modified "2026-06-07T15:30:29.317080Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5822-4
  a curric:KeyLearningPoint ;
  rdfs:label "A relative clause always starts with a relative pronoun e.g. ‘who’ or ‘which’."@en ;
  dcterms:modified "2026-06-07T15:30:29.317087Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3454-1
  a curric:KeyLearningPoint ;
  rdfs:label "There are different tenses and ways of forming verbs in English."@en ;
  dcterms:modified "2026-06-07T15:30:29.317154Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3454-2
  a curric:KeyLearningPoint ;
  rdfs:label "The subject of the clause does or is the verb in the active voice."@en ;
  dcterms:modified "2026-06-07T15:30:29.317158Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3454-3
  a curric:KeyLearningPoint ;
  rdfs:label """The active voice makes it clear to the reader who is doing or being the verb in a
  clause."""@en ;
  dcterms:modified "2026-06-07T15:30:29.317162Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3454-4
  a curric:KeyLearningPoint ;
  rdfs:label "In the passive voice, the position of the subject and object changes."@en ;
  dcterms:modified "2026-06-07T15:30:29.317169Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3454-5
  a curric:KeyLearningPoint ;
  rdfs:label """A clause in the passive voice contains two verbs: an auxiliary verb from the
  infinitive 'to be' and the past participle."""@en ;
  dcterms:modified "2026-06-07T15:30:29.317173Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1110-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Balmy' is an adjective which means mild or warm."@en ;
  dcterms:modified "2026-06-07T15:30:29.317231Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1110-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Dewy' is an adjective which means moist or damp."@en ;
  dcterms:modified "2026-06-07T15:30:29.317235Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1110-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Temperate' is an adjective which means mild or pleasant."@en ;
  dcterms:modified "2026-06-07T15:30:29.317239Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7668-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the resolution is to resolve the problem encountered in the story and
  allow readers to reflect."""@en ;
  dcterms:modified "2026-06-07T15:30:29.317244Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7668-2
  a curric:KeyLearningPoint ;
  rdfs:label "Precise and ambitious vocabulary is logged on a plan for future use."@en ;
  dcterms:modified "2026-06-07T15:30:29.317249Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7668-3
  a curric:KeyLearningPoint ;
  rdfs:label """Notes should not be written in full sentences and bullet points can be used to make
  notes clear."""@en ;
  dcterms:modified "2026-06-07T15:30:29.317252Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7668-4
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials of time, place and manner indicate when, where and how an action
  takes place."""@en ;
  dcterms:modified "2026-06-07T15:30:29.317256Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7668-5
  a curric:KeyLearningPoint ;
  rdfs:label "‘Show-not-tell’ language conveys characters' emotions."@en ;
  dcterms:modified "2026-06-07T15:30:29.317260Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1433-1
  a curric:KeyLearningPoint ;
  rdfs:label "-es is a suffix that can turn a singular noun into a plural."@en ;
  dcterms:modified "2026-06-07T15:30:29.317264Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1433-2
  a curric:KeyLearningPoint ;
  rdfs:label "Using the strategy 'pyramid letters' is a useful practice strategy."@en ;
  dcterms:modified "2026-06-07T15:30:29.317268Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1433-3
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum word: learn."@en ;
  dcterms:modified "2026-06-07T15:30:29.317272Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7353-1
  a curric:KeyLearningPoint ;
  rdfs:label "Editing is the process of making changes to improve writing."@en ;
  dcterms:modified "2026-06-07T15:30:29.319184Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7353-2
  a curric:KeyLearningPoint ;
  rdfs:label """The job of an editor is to check punctuation and to make improvements to sentence
  structure and language choices."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319190Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7353-3
  a curric:KeyLearningPoint ;
  rdfs:label """When editing punctuation, missing or incorrectly used capital letters, full stops
  and commas are checked."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319196Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7353-4
  a curric:KeyLearningPoint ;
  rdfs:label """When editing sentence structure, changes to the way sentences are constructed to
  improve text flow are made."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319202Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7353-5
  a curric:KeyLearningPoint ;
  rdfs:label """When editing vocabulary, reviews of word and phrase choice are made to ensure
  appropriate tone is achieved."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319207Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6727-1
  a curric:KeyLearningPoint ;
  rdfs:label "Writing is most successful when it is planned and rehearsed."@en ;
  dcterms:modified "2026-06-07T15:30:29.319231Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6727-2
  a curric:KeyLearningPoint ;
  rdfs:label """When we plan, we can use our text map as our basis, breaking it down into key
  scenes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319235Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6727-3
  a curric:KeyLearningPoint ;
  rdfs:label """For each scene, we make notes about the actions, descriptions, dialogue and emotion
  we might include (where relevant)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319239Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6727-4
  a curric:KeyLearningPoint ;
  rdfs:label """We also plan to include the rich vocabulary that we have generated in previous
  lessons."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319243Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5666-1
  a curric:KeyLearningPoint ;
  rdfs:label "Beowulf becomes king of Geatland and he reigns for 50 years."@en ;
  dcterms:modified "2026-06-07T15:30:29.319314Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5666-2
  a curric:KeyLearningPoint ;
  rdfs:label """A dragon is provoked to attack the Geats and Beowulf wants to fight it; his young
  cousin Wiglaf objects."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319318Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5666-3
  a curric:KeyLearningPoint ;
  rdfs:label """Beowulf's sword is useless against the dragon and it bites him; he is able to slay
  the dragon, but he is wounded."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319322Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5666-4
  a curric:KeyLearningPoint ;
  rdfs:label """As he dies, Beowulf asks Wiglaf to ensure that a barrow is built for him so that his
  memory lives on."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319325Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5666-5
  a curric:KeyLearningPoint ;
  rdfs:label "We can link stories like 'Beowulf' to themes or big ideas that they raise."@en ;
  dcterms:modified "2026-06-07T15:30:29.319332Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6550-1
  a curric:KeyLearningPoint ;
  rdfs:label "An introductory sentence indicates what the paragraph will be about."@en ;
  dcterms:modified "2026-06-07T15:30:29.319416Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6550-2
  a curric:KeyLearningPoint ;
  rdfs:label "Flattery and presumption are appropriate devices to use in the introduction."@en ;
  dcterms:modified "2026-06-07T15:30:29.319421Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6550-3
  a curric:KeyLearningPoint ;
  rdfs:label """The introduction must clearly communicate why the author is writing to the
  recipient."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319428Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6550-4
  a curric:KeyLearningPoint ;
  rdfs:label "This persuasive letter is formal in tone."@en ;
  dcterms:modified "2026-06-07T15:30:29.319432Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5769-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the main body of this diary entry is to describe events, thoughts and
  feelings in detail."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319457Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5769-2
  a curric:KeyLearningPoint ;
  rdfs:label "Sentences can be opened in a variety of ways to improve the flow of the text."@en ;
  dcterms:modified "2026-06-07T15:30:29.319461Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5769-3
  a curric:KeyLearningPoint ;
  rdfs:label "The main body is primarily written in the past tense."@en ;
  dcterms:modified "2026-06-07T15:30:29.319465Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5769-4
  a curric:KeyLearningPoint ;
  rdfs:label "Adverbials of time can be used to sequence events."@en ;
  dcterms:modified "2026-06-07T15:30:29.319469Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5769-5
  a curric:KeyLearningPoint ;
  rdfs:label "Informal tone can be achieved through use of contractions and exclamations."@en ;
  dcterms:modified "2026-06-07T15:30:29.319476Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5768-1
  a curric:KeyLearningPoint ;
  rdfs:label "The opening of a diary can include a general recount of the day’s events."@en ;
  dcterms:modified "2026-06-07T15:30:29.319480Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5768-2
  a curric:KeyLearningPoint ;
  rdfs:label "The opening includes references to the character’s thoughts and feelings."@en ;
  dcterms:modified "2026-06-07T15:30:29.319484Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5768-3
  a curric:KeyLearningPoint ;
  rdfs:label """Informal tone can be achieved through use of contractions, vocabulary choice and
  exclamations."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319488Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5768-4
  a curric:KeyLearningPoint ;
  rdfs:label "Plans and success criteria should be referred to during the writing process."@en ;
  dcterms:modified "2026-06-07T15:30:29.319492Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4864-1
  a curric:KeyLearningPoint ;
  rdfs:label "A subheading signals to the reader what the section is about."@en ;
  dcterms:modified "2026-06-07T15:30:29.319496Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4864-2
  a curric:KeyLearningPoint ;
  rdfs:label """A section about one feature of the report's subject contains specific facts and
  information to keep the reader engaged."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319500Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4864-3
  a curric:KeyLearningPoint ;
  rdfs:label """Using the full range of sentence types (simple, compound and complex) improves text
  flow for the reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319506Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4864-4
  a curric:KeyLearningPoint ;
  rdfs:label """Sentences should be said aloud before writing to ensure they make sense and read
  back once written to check for errors."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319510Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4864-5
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials of cause and formal fronted adverbials are used at the start of
  sentences for cohesion."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319515Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1351-1
  a curric:KeyLearningPoint ;
  rdfs:label """A silent 'h' can be found in different places within a word and next to different
  letters."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319647Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1351-2
  a curric:KeyLearningPoint ;
  rdfs:label """A silent 'p' can be found in different places within a word and next to different
  letters."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319651Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1351-3
  a curric:KeyLearningPoint ;
  rdfs:label "A silent 'n' is generally found at the end of the word after the letter m."@en ;
  dcterms:modified "2026-06-07T15:30:29.319656Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1351-4
  a curric:KeyLearningPoint ;
  rdfs:label """A silent 'l' generally comes after a vowel and often changes the sound of
  the vowel."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319662Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1351-5
  a curric:KeyLearningPoint ;
  rdfs:label """How to spell words with the silent letter 's' and the curriculum words: environment,
  twelfth and desperate."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319666Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9043-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘Frizzy’ is a fictional graphic novel text written by Claribel A. Ortega and
  illustrated by Rose Bousamra."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319672Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9043-2
  a curric:KeyLearningPoint ;
  rdfs:label """The text follows Marlene, a young Dominican-American girl coming to terms with
  growing up."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319676Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9043-3
  a curric:KeyLearningPoint ;
  rdfs:label """Graphic novels include features such as speech bubbles, thought bubbles & sound
  effects to explain what is happening."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319680Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9043-4
  a curric:KeyLearningPoint ;
  rdfs:label """Readers sometimes have to infer what has happened, rather than being told by the
  author or illustrator."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319684Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9043-5
  a curric:KeyLearningPoint ;
  rdfs:label """The text celebrates Spanish language and Dominican culture; this helps ground the
  story in Marlene’s cultural heritage."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319688Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6191-1
  a curric:KeyLearningPoint ;
  rdfs:label "A logical argument should run through an essay, leading towards a conclusion."@en ;
  dcterms:modified "2026-06-07T15:30:29.319692Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6191-2
  a curric:KeyLearningPoint ;
  rdfs:label """We should be confident in setting out this logical argument in its entirety before
  we begin to write."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319696Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6191-3
  a curric:KeyLearningPoint ;
  rdfs:label """Within an essay, a range of linguistic features and punctuation will be used to
  connect ideas."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319700Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6191-4
  a curric:KeyLearningPoint ;
  rdfs:label """These linguistic features can be used to show cause and effect, contrast and 'adding
  on'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319704Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6191-5
  a curric:KeyLearningPoint ;
  rdfs:label "Often, different linguistic features can be used to connect the same ideas."@en ;
  dcterms:modified "2026-06-07T15:30:29.319708Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6189-1
  a curric:KeyLearningPoint ;
  rdfs:label "Because an essay is a non-fiction piece of writing, it must be based on facts."@en ;
  dcterms:modified "2026-06-07T15:30:29.319793Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6189-2
  a curric:KeyLearningPoint ;
  rdfs:label "Facts are obtained through research, using reliable sources."@en ;
  dcterms:modified "2026-06-07T15:30:29.319797Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6189-3
  a curric:KeyLearningPoint ;
  rdfs:label "Research can be collated using bullet points under different headings."@en ;
  dcterms:modified "2026-06-07T15:30:29.319801Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6189-4
  a curric:KeyLearningPoint ;
  rdfs:label "Our essay will show just one side of an argument."@en ;
  dcterms:modified "2026-06-07T15:30:29.319805Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6189-5
  a curric:KeyLearningPoint ;
  rdfs:label """We can break an essay question down into smaller questions in order to structure our
  essay."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319809Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1452-1
  a curric:KeyLearningPoint ;
  rdfs:label "Homonyms are words which have the same spellings but multiple meanings."@en ;
  dcterms:modified "2026-06-07T15:30:29.319831Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1452-2
  a curric:KeyLearningPoint ;
  rdfs:label "The meaning of a homonym is dependent on the context."@en ;
  dcterms:modified "2026-06-07T15:30:29.319835Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1452-3
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum word: woman and women."@en ;
  dcterms:modified "2026-06-07T15:30:29.319839Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1455-1
  a curric:KeyLearningPoint ;
  rdfs:label """Homophones are words that have different spellings and multiple meanings, but sound
  the same."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319843Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1455-2
  a curric:KeyLearningPoint ;
  rdfs:label "The meaning of a homophone is dependent on the context."@en ;
  dcterms:modified "2026-06-07T15:30:29.319847Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1455-3
  a curric:KeyLearningPoint ;
  rdfs:label "Using the strategy 'naughty letters' is a useful practice strategy."@en ;
  dcterms:modified "2026-06-07T15:30:29.319851Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1455-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum word: address."@en ;
  dcterms:modified "2026-06-07T15:30:29.319855Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6218-1
  a curric:KeyLearningPoint ;
  rdfs:label """Our essay will give one side of an argument, using a logical order and supported by
  evidence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319881Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6218-2
  a curric:KeyLearningPoint ;
  rdfs:label "Evidence can take many forms, including explanations, facts and statistics."@en ;
  dcterms:modified "2026-06-07T15:30:29.319888Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6218-3
  a curric:KeyLearningPoint ;
  rdfs:label """In the introduction, we will explain how deforestation relates to the Amazon
  rainforest."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319892Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6218-4
  a curric:KeyLearningPoint ;
  rdfs:label "We will include subject-specific vocabulary and a range of linguistic features."@en ;
  dcterms:modified "2026-06-07T15:30:29.319898Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8643-1
  a curric:KeyLearningPoint ;
  rdfs:label """In this section of the build-up, the suspense heightens when Arrietty encounters the
  eye of a human “bean”."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319964Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8643-2
  a curric:KeyLearningPoint ;
  rdfs:label """The use of precise and ambitious vocabulary, including ‘show and tell’ language
  supports the building of suspense."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319968Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8643-3
  a curric:KeyLearningPoint ;
  rdfs:label "Rhetorical questions can be used to convey a character’s inner thoughts."@en ;
  dcterms:modified "2026-06-07T15:30:29.319975Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8643-4
  a curric:KeyLearningPoint ;
  rdfs:label """A fronted adverbial of time, place or manner indicates when, where or how action in
  the rest of a sentence takes place."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319979Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8643-5
  a curric:KeyLearningPoint ;
  rdfs:label "Using a range of sentence types supports text flow."@en ;
  dcterms:modified "2026-06-07T15:30:29.319983Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7655-1
  a curric:KeyLearningPoint ;
  rdfs:label """A published piece of writing should be visually and linguistically appealing to the
  reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319987Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7655-2
  a curric:KeyLearningPoint ;
  rdfs:label "Neat, joined handwriting is important when publishing a piece of writing."@en ;
  dcterms:modified "2026-06-07T15:30:29.319992Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7655-3
  a curric:KeyLearningPoint ;
  rdfs:label """A piece of published writing is the final, best version that becomes available to
  others."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319996Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7655-4
  a curric:KeyLearningPoint ;
  rdfs:label """Illustrations provide visual representations of the characters, settings and events
  described in the text."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319999Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7655-5
  a curric:KeyLearningPoint ;
  rdfs:label """Illustrations can bring the world of the story to life and make it more vivid in the
  reader's mind."""@en ;
  dcterms:modified "2026-06-07T15:30:29.320004Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5703-1
  a curric:KeyLearningPoint ;
  rdfs:label "Editing is the process of making changes to improve our writing."@en ;
  dcterms:modified "2026-06-07T15:30:29.320196Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5703-2
  a curric:KeyLearningPoint ;
  rdfs:label """When editing punctuation, missing or incorrectly used capital letters, full stops
  and commas are all checked."""@en ;
  dcterms:modified "2026-06-07T15:30:29.320202Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5703-3
  a curric:KeyLearningPoint ;
  rdfs:label """When editing sentence structure, the way sentences are constructed is checked to
  improve and enhance text flow."""@en ;
  dcterms:modified "2026-06-07T15:30:29.320206Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5703-4
  a curric:KeyLearningPoint ;
  rdfs:label "When editing language, choices of words and phrases are carefully reviewed."@en ;
  dcterms:modified "2026-06-07T15:30:29.320211Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1065-1
  a curric:KeyLearningPoint ;
  rdfs:label "A subheading signals to the reader what the section is about."@en ;
  dcterms:modified "2026-06-07T15:30:29.320305Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1065-2
  a curric:KeyLearningPoint ;
  rdfs:label """A section about one feature of the report's subject contains specific facts and
  information to keep the reader engaged."""@en ;
  dcterms:modified "2026-06-07T15:30:29.320309Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1065-3
  a curric:KeyLearningPoint ;
  rdfs:label """Writers choose varied fronted adverbials and different sentence types to ensure the
  text flows for the reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.320313Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1065-4
  a curric:KeyLearningPoint ;
  rdfs:label "A section can be composed of one paragraph."@en ;
  dcterms:modified "2026-06-07T15:30:29.320317Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1065-5
  a curric:KeyLearningPoint ;
  rdfs:label """Sentences should be said aloud before writing to ensure they make sense and read
  back once written to check for errors."""@en ;
  dcterms:modified "2026-06-07T15:30:29.320323Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7634-1
  a curric:KeyLearningPoint ;
  rdfs:label """Sentences should be said aloud before writing to ensure they make sense and read
  back once written to check for errors."""@en ;
  dcterms:modified "2026-06-07T15:30:29.320328Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7634-2
  a curric:KeyLearningPoint ;
  rdfs:label """Ambitious vocabulary and figurative language create a vivid picture in the reader's
  mind."""@en ;
  dcterms:modified "2026-06-07T15:30:29.320332Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7634-3
  a curric:KeyLearningPoint ;
  rdfs:label """Writers choose varied fronted adverbials and different sentence types to ensure the
  text flows for the reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.320338Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7634-4
  a curric:KeyLearningPoint ;
  rdfs:label """Careful selection of nouns and pronouns ensures cohesion within sentences and across
  sections of a written piece."""@en ;
  dcterms:modified "2026-06-07T15:30:29.320342Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7634-5
  a curric:KeyLearningPoint ;
  rdfs:label """Past simple, progressive and perfect verb forms can be used to improve text
  cohesion."""@en ;
  dcterms:modified "2026-06-07T15:30:29.320348Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3399-1
  a curric:KeyLearningPoint ;
  rdfs:label """Subject-specific vocabulary, including numerical facts, is used in a
  non-chronological report."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322491Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3399-2
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials of cause are used to at the start of a sentence to explain a
  reason."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322495Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3399-3
  a curric:KeyLearningPoint ;
  rdfs:label """Sentences can start with a range of fronted adverbials like formal and viewpoint
  fronted adverbials."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322499Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4816-1
  a curric:KeyLearningPoint ;
  rdfs:label "A haiku is a short poem of just three lines."@en ;
  dcterms:modified "2026-06-07T15:30:29.322503Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4816-2
  a curric:KeyLearningPoint ;
  rdfs:label "Each line of the poem starts on a new line and with a capital letter."@en ;
  dcterms:modified "2026-06-07T15:30:29.322507Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4816-3
  a curric:KeyLearningPoint ;
  rdfs:label """After forming a capital letter, you need to lift your pencil to start the next part
  of the word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322511Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4816-4
  a curric:KeyLearningPoint ;
  rdfs:label """Each letter string contains different letter joins depending on which letters are in
  the word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322515Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4816-5
  a curric:KeyLearningPoint ;
  rdfs:label "You don't lift your pencil when forming the joins."@en ;
  dcterms:modified "2026-06-07T15:30:29.322519Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2736-1
  a curric:KeyLearningPoint ;
  rdfs:label "Determiners are a word class."@en ;
  dcterms:modified "2026-06-07T15:30:29.322546Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2736-2
  a curric:KeyLearningPoint ;
  rdfs:label "A determiner introduces a noun in a clause or phrase."@en ;
  dcterms:modified "2026-06-07T15:30:29.322549Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2736-3
  a curric:KeyLearningPoint ;
  rdfs:label "Determiners can be articles or possessive pronouns."@en ;
  dcterms:modified "2026-06-07T15:30:29.322553Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2736-4
  a curric:KeyLearningPoint ;
  rdfs:label """Articles determine the specificity of a noun whilst possessive pronouns determine
  the owner of a noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322557Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2736-5
  a curric:KeyLearningPoint ;
  rdfs:label """A determiner may be followed by an adjective or pair of adjectives then the
  noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322561Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8074-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘One of These Days’ and ‘Being Heard’ are two poems in a collection that share
  themes of resilience."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322587Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8074-2
  a curric:KeyLearningPoint ;
  rdfs:label """Enjambment is when a sentence or phrase runs over onto the next line of poetry
  without punctuation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322591Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8074-3
  a curric:KeyLearningPoint ;
  rdfs:label """Enjambment can be used to create a sense of flow, as well as to emphasise certain
  words or ideas."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322598Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8074-4
  a curric:KeyLearningPoint ;
  rdfs:label "The same theme can be represented in poems in similar or different ways."@en ;
  dcterms:modified "2026-06-07T15:30:29.322602Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5751-1
  a curric:KeyLearningPoint ;
  rdfs:label "The purpose of the introduction is to give general information to the reader."@en ;
  dcterms:modified "2026-06-07T15:30:29.322659Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5751-2
  a curric:KeyLearningPoint ;
  rdfs:label """The introduction outlines what the reader will learn from the non-chronological
  report."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322663Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5751-3
  a curric:KeyLearningPoint ;
  rdfs:label """The facts in the opening are general about healthy lifestyle; they become more
  specific in later paragraphs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322667Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5751-4
  a curric:KeyLearningPoint ;
  rdfs:label "An introduction ends with a command to the reader to continue reading."@en ;
  dcterms:modified "2026-06-07T15:30:29.322670Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5751-5
  a curric:KeyLearningPoint ;
  rdfs:label """A compound sentence is formed of two main clauses joined with a co-ordinating
  conjunction."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322674Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6356-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of a journalistic report is to provide information about a newsworthy
  event to its reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322698Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6356-2
  a curric:KeyLearningPoint ;
  rdfs:label """A newsworthy event is something that is interesting or important enough to warrant
  reporting to the public."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322702Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6356-3
  a curric:KeyLearningPoint ;
  rdfs:label """Journalistic reports follow a specific structure; headline, opening, recount, quotes
  and closing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322706Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6356-4
  a curric:KeyLearningPoint ;
  rdfs:label "Journalistic reports are written using formal and objective language and tone."@en ;
  dcterms:modified "2026-06-07T15:30:29.322710Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6356-5
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials and complex sentences are key linguistic features of a
  journalistic report."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322714Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6270-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘Mirror’ is a dual narrative text: two stories that are made to be read
  side-by-side."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322720Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6270-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Mirror' can be considered a wordless or silent text."@en ;
  dcterms:modified "2026-06-07T15:30:29.322724Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6270-3
  a curric:KeyLearningPoint ;
  rdfs:label "Different readers may interpret a text in different ways."@en ;
  dcterms:modified "2026-06-07T15:30:29.322728Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6270-4
  a curric:KeyLearningPoint ;
  rdfs:label "Jeannie Baker uses collage artwork to tell the story."@en ;
  dcterms:modified "2026-06-07T15:30:29.322734Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6270-5
  a curric:KeyLearningPoint ;
  rdfs:label """Predictions can be based on what readers have explored within a text or personal
  experience."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322738Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1408-1
  a curric:KeyLearningPoint ;
  rdfs:label "It is common to see a ‘c’ or a ‘t’ before the suffix -ial"@en ;
  dcterms:modified "2026-06-07T15:30:29.322769Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1408-2
  a curric:KeyLearningPoint ;
  rdfs:label "The /shul/ ending can be spelt -cial or -tial"@en ;
  dcterms:modified "2026-06-07T15:30:29.322773Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1408-3
  a curric:KeyLearningPoint ;
  rdfs:label "If the letter before the /shul/ ending is a consonant, -tial is usually used"@en ;
  dcterms:modified "2026-06-07T15:30:29.322777Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1408-4
  a curric:KeyLearningPoint ;
  rdfs:label "If the letter before the /shul/ ending is a vowel, -cial is usually used"@en ;
  dcterms:modified "2026-06-07T15:30:29.322780Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1408-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: breathe and library"@en ;
  dcterms:modified "2026-06-07T15:30:29.322784Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1384-1
  a curric:KeyLearningPoint ;
  rdfs:label """There are many ways to spell the ‘ee’ sound. ‘ee’, ‘ea’ and ‘e-e’ are the most
  common."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322849Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1384-2
  a curric:KeyLearningPoint ;
  rdfs:label """The spellings ‘e’, ‘y’, ‘ey’, ‘ie’ and ‘ei’ are other ways to represent the ‘ee’
  phoneme."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322853Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1384-3
  a curric:KeyLearningPoint ;
  rdfs:label """The rule ‘i before e except after c’ can help us choose between ‘ie’ and ‘ei’ when
  spelling ‘ee’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322857Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1384-4
  a curric:KeyLearningPoint ;
  rdfs:label "There are exceptions, including ‘protein’, ‘caffeine’ and ‘seize’."@en ;
  dcterms:modified "2026-06-07T15:30:29.322861Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1384-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: achieve, believe and possess."@en ;
  dcterms:modified "2026-06-07T15:30:29.322865Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27901-1
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to speak clearly and use precise, concise language to convey your
  thoughts and ideas effectively."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322889Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27901-2
  a curric:KeyLearningPoint ;
  rdfs:label """Articulating yourself well can help to communicate ideas and build stronger
  relationships."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322892Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27901-3
  a curric:KeyLearningPoint ;
  rdfs:label """Being articulate enables us to advocate for ourselves, stand up for our rights and
  support others who may need help."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322896Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27901-4
  a curric:KeyLearningPoint ;
  rdfs:label """When we advocate for ourselves and others, we can be polite and express gratitude as
  well as saying what we need."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322900Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4873-1
  a curric:KeyLearningPoint ;
  rdfs:label "Related information is grouped into paragraphs and organised using a subheading."@en ;
  dcterms:modified "2026-06-07T15:30:29.322904Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4873-2
  a curric:KeyLearningPoint ;
  rdfs:label "An introductory sentence explains what the paragraph is about."@en ;
  dcterms:modified "2026-06-07T15:30:29.322908Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4873-3
  a curric:KeyLearningPoint ;
  rdfs:label "Relative clauses give additional detail about the sentence’s subject."@en ;
  dcterms:modified "2026-06-07T15:30:29.322912Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4873-4
  a curric:KeyLearningPoint ;
  rdfs:label "Apostrophes are used to indicate plural possession."@en ;
  dcterms:modified "2026-06-07T15:30:29.322916Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4873-5
  a curric:KeyLearningPoint ;
  rdfs:label """Referring to tigers using other nouns enhances text cohesion and avoids
  repetition."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322920Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6146-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of a narrative opening is to introduce the characters and to describe
  the setting to the reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322944Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6146-2
  a curric:KeyLearningPoint ;
  rdfs:label "Saying sentences aloud before they are written helps to check for sense."@en ;
  dcterms:modified "2026-06-07T15:30:29.322949Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6146-3
  a curric:KeyLearningPoint ;
  rdfs:label """Using the full range of sentence types (simple, compound and complex) improves text
  flow for the reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322954Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6146-4
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials of time, place and manner add extra detail to the main
  clause."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322958Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6146-5
  a curric:KeyLearningPoint ;
  rdfs:label """'Show-not-tell' language shows a character’s feelings by describing their actions,
  body language and facial expressions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322962Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7653-1
  a curric:KeyLearningPoint ;
  rdfs:label """Direct speech is punctuated using inverted commas. Dialogue moves the action
  forward."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322965Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7653-2
  a curric:KeyLearningPoint ;
  rdfs:label "Notes from a plan are used to form full sentences."@en ;
  dcterms:modified "2026-06-07T15:30:29.322969Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7653-3
  a curric:KeyLearningPoint ;
  rdfs:label """A range of sentence types (simple, compound and complex) improves text flow for the
  reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322973Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7653-4
  a curric:KeyLearningPoint ;
  rdfs:label "A range of fronted adverbials is used to improve text flow."@en ;
  dcterms:modified "2026-06-07T15:30:29.322977Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7653-5
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the climax is to describe the main action and to take the tension and
  excitement to its highest point."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322981Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8880-1
  a curric:KeyLearningPoint ;
  rdfs:label """The Iron Man goes from being feared due to his difference, to being understood,
  accepted and ultimately admired."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322985Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8880-2
  a curric:KeyLearningPoint ;
  rdfs:label """A theme is a big idea, topic or message that recurs within a story and authors use
  these to convey deeper meaning."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322989Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8880-3
  a curric:KeyLearningPoint ;
  rdfs:label """Considering the deeper meaning behind the Iron Man’s story can help us identify
  themes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322993Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8880-4
  a curric:KeyLearningPoint ;
  rdfs:label """Key themes such as difference, perception and understanding are explored through the
  Iron Man’s character arc."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322997Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8880-5
  a curric:KeyLearningPoint ;
  rdfs:label """The themes within ‘The Iron Man’ help us learn important lessons about issues and
  topics in our own lives."""@en ;
  dcterms:modified "2026-06-07T15:30:29.323003Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5455-1
  a curric:KeyLearningPoint ;
  rdfs:label """Alina’s motivations for finding the moon dragon was different to everyone else’s and
  she valued them more than gold."""@en ;
  dcterms:modified "2026-06-07T15:30:29.323112Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5455-2
  a curric:KeyLearningPoint ;
  rdfs:label """Asking questions and having rich discussions builds our understanding and allows us
  to hear different perspectives."""@en ;
  dcterms:modified "2026-06-07T15:30:29.323116Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5455-3
  a curric:KeyLearningPoint ;
  rdfs:label "Searching for clues within a text can help us infer greater meaning."@en ;
  dcterms:modified "2026-06-07T15:30:29.323120Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5455-4
  a curric:KeyLearningPoint ;
  rdfs:label "We can retrieve evidence from the text to help us justify our inferences."@en ;
  dcterms:modified "2026-06-07T15:30:29.323124Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5455-5
  a curric:KeyLearningPoint ;
  rdfs:label """A character's actions, experiences and words can be analysed to infer greater
  meaning."""@en ;
  dcterms:modified "2026-06-07T15:30:29.323128Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1371-1
  a curric:KeyLearningPoint ;
  rdfs:label "The suffixes -less and -ful create adjectives."@en ;
  dcterms:modified "2026-06-07T15:30:29.323132Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1371-2
  a curric:KeyLearningPoint ;
  rdfs:label """The suffix -ful means ‘full of’ or ‘having qualities of’ and the suffix -less means
  ‘without’ or ‘lacking’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.323139Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1371-3
  a curric:KeyLearningPoint ;
  rdfs:label """The suffixes start with a consonant. This means the root word usually doesn’t change
  when the suffix is added."""@en ;
  dcterms:modified "2026-06-07T15:30:29.323143Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1371-4
  a curric:KeyLearningPoint ;
  rdfs:label """If the root word ends in a consonant +y, then the ‘y’ is replaced by ‘i’ before the
  suffix."""@en ;
  dcterms:modified "2026-06-07T15:30:29.323147Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1371-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: awkward, bruise, regular and therefore."@en ;
  dcterms:modified "2026-06-07T15:30:29.323151Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1374-1
  a curric:KeyLearningPoint ;
  rdfs:label "Most words in English with the -able or -ible suffix will use -able."@en ;
  dcterms:modified "2026-06-07T15:30:29.323155Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1374-2
  a curric:KeyLearningPoint ;
  rdfs:label """Removing the -able suffix generally leaves a recognisable word, e.g. agreeable -
  agree."""@en ;
  dcterms:modified "2026-06-07T15:30:29.323159Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1374-3
  a curric:KeyLearningPoint ;
  rdfs:label """Words in word families using the suffixes -ation, -able and -ably are connected in
  spelling and meaning."""@en ;
  dcterms:modified "2026-06-07T15:30:29.323162Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1374-4
  a curric:KeyLearningPoint ;
  rdfs:label "If the root word ends in ‘ce’ or ‘ge’, keep the ‘e’ before adding -able."@en ;
  dcterms:modified "2026-06-07T15:30:29.323166Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1374-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words:  symbol, system and identity."@en ;
  dcterms:modified "2026-06-07T15:30:29.323170Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1307-1
  a curric:KeyLearningPoint ;
  rdfs:label "The suffix -en often turns adjectives and nouns into verbs."@en ;
  dcterms:modified "2026-06-07T15:30:29.323195Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1307-2
  a curric:KeyLearningPoint ;
  rdfs:label "When the root word ends in a consonant, we often just add the suffix."@en ;
  dcterms:modified "2026-06-07T15:30:29.323199Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1307-3
  a curric:KeyLearningPoint ;
  rdfs:label """When the root word ends in a vowel, we remove the final vowel and add the
  suffix."""@en ;
  dcterms:modified "2026-06-07T15:30:29.323203Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1307-4
  a curric:KeyLearningPoint ;
  rdfs:label """When the root word ends in a consonant with a short vowel, we double the consonant
  and add the suffix."""@en ;
  dcterms:modified "2026-06-07T15:30:29.323207Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1307-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: consider, interest and history."@en ;
  dcterms:modified "2026-06-07T15:30:29.323211Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1117-1
  a curric:KeyLearningPoint ;
  rdfs:label "Dreary is an adjective which means boring or miserable."@en ;
  dcterms:modified "2026-06-07T15:30:29.323234Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1117-2
  a curric:KeyLearningPoint ;
  rdfs:label "Ominous is an adjective which means scary, threatening or menacing."@en ;
  dcterms:modified "2026-06-07T15:30:29.323238Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1117-3
  a curric:KeyLearningPoint ;
  rdfs:label "Splattered is an adjective which means splashed or sprinkled."@en ;
  dcterms:modified "2026-06-07T15:30:29.323242Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7862-1
  a curric:KeyLearningPoint ;
  rdfs:label """The themes of 'Arthur and the Golden Rope' include resilience, heroism,
  collaboration and courage."""@en ;
  dcterms:modified "2026-06-07T15:30:29.324684Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7862-2
  a curric:KeyLearningPoint ;
  rdfs:label "A theme is a big idea, topic or message that recurs within a story."@en ;
  dcterms:modified "2026-06-07T15:30:29.324688Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7862-3
  a curric:KeyLearningPoint ;
  rdfs:label "Texts often have a theme, or big idea, which is repeated through the story."@en ;
  dcterms:modified "2026-06-07T15:30:29.324694Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7862-4
  a curric:KeyLearningPoint ;
  rdfs:label "Readers can interpret their own big idea or message from a narrative."@en ;
  dcterms:modified "2026-06-07T15:30:29.324698Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7862-5
  a curric:KeyLearningPoint ;
  rdfs:label "Different readers may interpret a text in different ways."@en ;
  dcterms:modified "2026-06-07T15:30:29.324702Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1124-1
  a curric:KeyLearningPoint ;
  rdfs:label "Dainty is an adjective which means small, delicate and pretty."@en ;
  dcterms:modified "2026-06-07T15:30:29.324706Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1124-2
  a curric:KeyLearningPoint ;
  rdfs:label "Diminutive is an adjective which means unusally small."@en ;
  dcterms:modified "2026-06-07T15:30:29.324711Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1124-3
  a curric:KeyLearningPoint ;
  rdfs:label "Miniscule is an adjective which means tiny or microsocpic."@en ;
  dcterms:modified "2026-06-07T15:30:29.324714Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6161-1
  a curric:KeyLearningPoint ;
  rdfs:label "We can present our written work in a range of ways, including orally."@en ;
  dcterms:modified "2026-06-07T15:30:29.324718Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6161-2
  a curric:KeyLearningPoint ;
  rdfs:label """A radio broadcast will usually be briefer and slightly less formal than a written
  journalistic report."""@en ;
  dcterms:modified "2026-06-07T15:30:29.324722Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6161-3
  a curric:KeyLearningPoint ;
  rdfs:label """It may still include statements of fact and reported speech that give different
  perspectives."""@en ;
  dcterms:modified "2026-06-07T15:30:29.324726Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6161-4
  a curric:KeyLearningPoint ;
  rdfs:label """Instead of direct speech, we will hear individuals' accounts as interview
  segments."""@en ;
  dcterms:modified "2026-06-07T15:30:29.324730Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6161-5
  a curric:KeyLearningPoint ;
  rdfs:label """We will use some language specific to radio broadcasts, such as 'correspondent' and
  'studio'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.324734Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7933-1
  a curric:KeyLearningPoint ;
  rdfs:label "The character of Sam changes dramatically from the start of the text to the end."@en ;
  dcterms:modified "2026-06-07T15:30:29.324738Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7933-2
  a curric:KeyLearningPoint ;
  rdfs:label """Characters within the text depict a range of emotions. Character traits can be
  understood from these."""@en ;
  dcterms:modified "2026-06-07T15:30:29.324742Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7933-3
  a curric:KeyLearningPoint ;
  rdfs:label """Character traits can be explored through the text’s illustrations or words used by
  the characters."""@en ;
  dcterms:modified "2026-06-07T15:30:29.324746Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7933-4
  a curric:KeyLearningPoint ;
  rdfs:label """Making connections and recommendations can significantly enhance the reading
  experience and broaden understanding."""@en ;
  dcterms:modified "2026-06-07T15:30:29.324753Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7931-1
  a curric:KeyLearningPoint ;
  rdfs:label "‘Coming to England’ highlights Floella’s resilience and advocacy against racism."@en ;
  dcterms:modified "2026-06-07T15:30:29.324826Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7931-2
  a curric:KeyLearningPoint ;
  rdfs:label """The text has themes of determination, migration, identity and overcoming
  adversity."""@en ;
  dcterms:modified "2026-06-07T15:30:29.324832Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7931-3
  a curric:KeyLearningPoint ;
  rdfs:label """Floella has a strong support network; she describes positive traits that she has
  learnt from both her parents."""@en ;
  dcterms:modified "2026-06-07T15:30:29.324836Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7931-4
  a curric:KeyLearningPoint ;
  rdfs:label "A theme is a big idea, topic or message that recurs within a story."@en ;
  dcterms:modified "2026-06-07T15:30:29.324842Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3468-1
  a curric:KeyLearningPoint ;
  rdfs:label "Activity outside the hive is an important part of the honey-making process."@en ;
  dcterms:modified "2026-06-07T15:30:29.324921Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3468-2
  a curric:KeyLearningPoint ;
  rdfs:label "The main sections in an explanation text follow a clear, sequenced order."@en ;
  dcterms:modified "2026-06-07T15:30:29.324926Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3468-3
  a curric:KeyLearningPoint ;
  rdfs:label """Notes should not be written in full sentences and bullet points can be used to make
  notes clear."""@en ;
  dcterms:modified "2026-06-07T15:30:29.324930Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3468-4
  a curric:KeyLearningPoint ;
  rdfs:label """Facts become increasingly specific throughout one section of an explanation
  text."""@en ;
  dcterms:modified "2026-06-07T15:30:29.324934Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1443-1
  a curric:KeyLearningPoint ;
  rdfs:label "-er and -est are suffixes that can be used to change the meaning of a root word."@en ;
  dcterms:modified "2026-06-07T15:30:29.324973Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1443-2
  a curric:KeyLearningPoint ;
  rdfs:label "The strategy 'big letters' is a useful practice strategy."@en ;
  dcterms:modified "2026-06-07T15:30:29.324977Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1443-3
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum word: special."@en ;
  dcterms:modified "2026-06-07T15:30:29.324981Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6102-1
  a curric:KeyLearningPoint ;
  rdfs:label """A non-chronological report is written to inform the reader about a subject or event
  out of time order."""@en ;
  dcterms:modified "2026-06-07T15:30:29.324985Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6102-2
  a curric:KeyLearningPoint ;
  rdfs:label """The introduction of a non-chronological report summarises the general information
  about the subject."""@en ;
  dcterms:modified "2026-06-07T15:30:29.324989Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6102-3
  a curric:KeyLearningPoint ;
  rdfs:label "Within the introduction, text that flows well and cohesively is important."@en ;
  dcterms:modified "2026-06-07T15:30:29.324996Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6102-4
  a curric:KeyLearningPoint ;
  rdfs:label "Text cohesion can be achieved by using a range of cohesive devices."@en ;
  dcterms:modified "2026-06-07T15:30:29.325000Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6102-5
  a curric:KeyLearningPoint ;
  rdfs:label """We can use compound sentences, complex sentences, fronted adverbials and parenthesis
  as cohesive devices."""@en ;
  dcterms:modified "2026-06-07T15:30:29.325004Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8049-1
  a curric:KeyLearningPoint ;
  rdfs:label """A tanka is a traditional Japanese form of poetry that originated more than 1,300
  years ago."""@en ;
  dcterms:modified "2026-06-07T15:30:29.325026Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8049-2
  a curric:KeyLearningPoint ;
  rdfs:label """Tankas consist of five lines with a syllable pattern of 5-7-5-7-7, totalling 31
  syllables."""@en ;
  dcterms:modified "2026-06-07T15:30:29.325030Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8049-3
  a curric:KeyLearningPoint ;
  rdfs:label "Tankas often explore themes of nature, emotions and the passage of time."@en ;
  dcterms:modified "2026-06-07T15:30:29.325034Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8049-4
  a curric:KeyLearningPoint ;
  rdfs:label "We can make specific language choices to describe the intensity of the heat."@en ;
  dcterms:modified "2026-06-07T15:30:29.325038Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8049-5
  a curric:KeyLearningPoint ;
  rdfs:label """We can use vocabulary in different ways, depending on its position in a sentence, if
  it is a verb, adjective or noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.325042Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5816-1
  a curric:KeyLearningPoint ;
  rdfs:label """'Romeo and Juliet' is a tragedy that raises themes around family, social
  obligations, love and conflict."""@en ;
  dcterms:modified "2026-06-07T15:30:29.325062Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5816-2
  a curric:KeyLearningPoint ;
  rdfs:label "We can use a piece of art like a play as a stimulus for a discussion."@en ;
  dcterms:modified "2026-06-07T15:30:29.325066Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5816-3
  a curric:KeyLearningPoint ;
  rdfs:label """We can consider factual questions, discussion questions and philosophical questions
  raised by the play."""@en ;
  dcterms:modified "2026-06-07T15:30:29.325072Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5816-4
  a curric:KeyLearningPoint ;
  rdfs:label """Philosophical questions are questions that are not context-linked - they could be
  discussed without knowing the play."""@en ;
  dcterms:modified "2026-06-07T15:30:29.325076Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5816-5
  a curric:KeyLearningPoint ;
  rdfs:label "When debating, we build on others' answers and we disagree respectfully."@en ;
  dcterms:modified "2026-06-07T15:30:29.325080Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5813-1
  a curric:KeyLearningPoint ;
  rdfs:label """We are planning a narrative retelling of the duel scene in Act III Scene 1, using
  the same events."""@en ;
  dcterms:modified "2026-06-07T15:30:29.325114Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5813-2
  a curric:KeyLearningPoint ;
  rdfs:label """Narrative includes overlapping elements of dialogue, description, emotion and
  action."""@en ;
  dcterms:modified "2026-06-07T15:30:29.325118Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5813-3
  a curric:KeyLearningPoint ;
  rdfs:label """We can include all of these narrative elements in our plan in order to ensure we
  have covered all the content we need."""@en ;
  dcterms:modified "2026-06-07T15:30:29.325124Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5813-4
  a curric:KeyLearningPoint ;
  rdfs:label "Our plan is written in note form, in the third person and the past tense."@en ;
  dcterms:modified "2026-06-07T15:30:29.325128Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5813-5
  a curric:KeyLearningPoint ;
  rdfs:label """We are following a structure of four paragraphs, tracking the key events of the
  animated version of the scene."""@en ;
  dcterms:modified "2026-06-07T15:30:29.325132Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1418-1
  a curric:KeyLearningPoint ;
  rdfs:label """When there are two of the same consonants beside each other, we call this a double
  consonant."""@en ;
  dcterms:modified "2026-06-07T15:30:29.325157Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1418-2
  a curric:KeyLearningPoint ;
  rdfs:label "Double consonants are often found after short vowel sounds."@en ;
  dcterms:modified "2026-06-07T15:30:29.325161Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1418-3
  a curric:KeyLearningPoint ;
  rdfs:label "Some letters are never doubled, 'h' 'k' 'j' 'v'."@en ;
  dcterms:modified "2026-06-07T15:30:29.325167Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1418-4
  a curric:KeyLearningPoint ;
  rdfs:label """Some letters are rarely doubled, 'c' 'z'. When they are, they usually come from
  another language."""@en ;
  dcterms:modified "2026-06-07T15:30:29.325171Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1418-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: peculiar, particular and quarter."@en ;
  dcterms:modified "2026-06-07T15:30:29.325175Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6152-1
  a curric:KeyLearningPoint ;
  rdfs:label """A published piece of writing should be visually and linguistically appealing to the
  reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.325178Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6152-2
  a curric:KeyLearningPoint ;
  rdfs:label "Neat, joined handwriting is important when publishing a piece of writing."@en ;
  dcterms:modified "2026-06-07T15:30:29.325182Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6152-3
  a curric:KeyLearningPoint ;
  rdfs:label """A piece of published writing is the final, best version that becomes available to
  others."""@en ;
  dcterms:modified "2026-06-07T15:30:29.325186Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6152-4
  a curric:KeyLearningPoint ;
  rdfs:label """Illustrations provide visual representations of the characters, settings and events
  described in the text."""@en ;
  dcterms:modified "2026-06-07T15:30:29.325190Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6152-5
  a curric:KeyLearningPoint ;
  rdfs:label """Illustrations can bring the world of the story to life and make it more vivid in the
  reader's mind."""@en ;
  dcterms:modified "2026-06-07T15:30:29.325194Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1028-1
  a curric:KeyLearningPoint ;
  rdfs:label """A non-chronological report is a non-fiction text that informs about a subject or
  event."""@en ;
  dcterms:modified "2026-06-07T15:30:29.325214Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1028-2
  a curric:KeyLearningPoint ;
  rdfs:label """An introduction, two sections and a conclusion is how we can structure a
  non-chronological report."""@en ;
  dcterms:modified "2026-06-07T15:30:29.325218Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1028-3
  a curric:KeyLearningPoint ;
  rdfs:label "Subheadings are used to signal sections of a non-chronological report."@en ;
  dcterms:modified "2026-06-07T15:30:29.325222Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1028-4
  a curric:KeyLearningPoint ;
  rdfs:label """An introduction contains general facts; specific facts come in the later
  sections."""@en ;
  dcterms:modified "2026-06-07T15:30:29.325228Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1028-5
  a curric:KeyLearningPoint ;
  rdfs:label "P.A.L.L. helps writers plan, write and edit a text."@en ;
  dcterms:modified "2026-06-07T15:30:29.325232Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3445-1
  a curric:KeyLearningPoint ;
  rdfs:label "A sentence composed of one main clause is a simple sentence."@en ;
  dcterms:modified "2026-06-07T15:30:29.325291Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3445-2
  a curric:KeyLearningPoint ;
  rdfs:label """A sentence composed of at least two main clauses joined by a co-ordinating
  conjunction is a compound sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.325297Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3445-3
  a curric:KeyLearningPoint ;
  rdfs:label """There are three complex sentence structures: the adverbial complex, the relative
  complex and the non-finite complex."""@en ;
  dcterms:modified "2026-06-07T15:30:29.325303Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3445-4
  a curric:KeyLearningPoint ;
  rdfs:label """Different sentence types allow writers to write cohesively across a paragraph and a
  whole text."""@en ;
  dcterms:modified "2026-06-07T15:30:29.325308Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3445-5
  a curric:KeyLearningPoint ;
  rdfs:label "Text cohesion ensures text maintains the interest of the reader."@en ;
  dcterms:modified "2026-06-07T15:30:29.325312Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1375-1
  a curric:KeyLearningPoint ;
  rdfs:label "The suffixes -ible and -able create adjectives."@en ;
  dcterms:modified "2026-06-07T15:30:29.325358Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1375-2
  a curric:KeyLearningPoint ;
  rdfs:label """Removing the -ible suffix does not usually leave a recognisable root word in
  English, e.g. visible - vis."""@en ;
  dcterms:modified "2026-06-07T15:30:29.325362Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1375-3
  a curric:KeyLearningPoint ;
  rdfs:label """Adjectives ending in the suffix -ible and adverbs ending in the suffix -ibly are
  connected in spelling and meaning."""@en ;
  dcterms:modified "2026-06-07T15:30:29.325366Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1375-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: possible, material and straight."@en ;
  dcterms:modified "2026-06-07T15:30:29.325370Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1363-1
  a curric:KeyLearningPoint ;
  rdfs:label "Adding the -ing suffix turns the verb into the progressive tense."@en ;
  dcterms:modified "2026-06-07T15:30:29.325376Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1363-2
  a curric:KeyLearningPoint ;
  rdfs:label "The progressive tense makes use of an auxiliary verb with the main verb."@en ;
  dcterms:modified "2026-06-07T15:30:29.325382Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1363-3
  a curric:KeyLearningPoint ;
  rdfs:label """When adding the suffix -ing, different spelling rules are used depending on the
  spelling of the root word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.325387Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1363-4
  a curric:KeyLearningPoint ;
  rdfs:label """You can just add ing; remove the 'e', add -ing; or double the consonant, add
  -ing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.325391Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1363-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: heard, forty and according."@en ;
  dcterms:modified "2026-06-07T15:30:29.325427Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7656-1
  a curric:KeyLearningPoint ;
  rdfs:label "Maori people were the first people to settle in New Zealand."@en ;
  dcterms:modified "2026-06-07T15:30:29.325432Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7656-2
  a curric:KeyLearningPoint ;
  rdfs:label "Maori culture and tradition play a significant role in national identity."@en ;
  dcterms:modified "2026-06-07T15:30:29.325436Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7656-3
  a curric:KeyLearningPoint ;
  rdfs:label "Maori people have a strong spiritual connection to the land and environment."@en ;
  dcterms:modified "2026-06-07T15:30:29.325440Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7656-4
  a curric:KeyLearningPoint ;
  rdfs:label "‘Whale Rider’ is a novel by Witi Ihimaera and it has been adapted into a film."@en ;
  dcterms:modified "2026-06-07T15:30:29.325444Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7656-5
  a curric:KeyLearningPoint ;
  rdfs:label """‘Whale Rider’ is a powerful story of tradition and it has themes of courage and
  breaking down barriers."""@en ;
  dcterms:modified "2026-06-07T15:30:29.325448Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28402-1
  a curric:KeyLearningPoint ;
  rdfs:label """Character relationships refer to the connections and interactions between
  individuals within a narrative."""@en ;
  dcterms:modified "2026-06-07T15:30:29.326530Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28402-2
  a curric:KeyLearningPoint ;
  rdfs:label """We can see that Nate has both positive and negative relationships and that his
  relationships are not static."""@en ;
  dcterms:modified "2026-06-07T15:30:29.326534Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28402-3
  a curric:KeyLearningPoint ;
  rdfs:label "Different moments in the plot can evoke a range of emotions in a character."@en ;
  dcterms:modified "2026-06-07T15:30:29.326538Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28402-4
  a curric:KeyLearningPoint ;
  rdfs:label "We can track a character’s emotions on an emotions graph."@en ;
  dcterms:modified "2026-06-07T15:30:29.326542Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1091-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Gruelling' is an adjective, which means difficult or draining."@en ;
  dcterms:modified "2026-06-07T15:30:29.326894Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1091-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Tedious' is an adjective, which means boring or dull."@en ;
  dcterms:modified "2026-06-07T15:30:29.326898Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1091-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Laborious', 'overwhelming', 'backbreaking' and 'exhausted' are other adjectives
  related to hard-work."""@en ;
  dcterms:modified "2026-06-07T15:30:29.326902Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6745-1
  a curric:KeyLearningPoint ;
  rdfs:label "We are writing a narrative that includes switches in perspective and tense."@en ;
  dcterms:modified "2026-06-07T15:30:29.326946Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6745-2
  a curric:KeyLearningPoint ;
  rdfs:label """In this lesson, we will write only a present tense, first person paragraph in role
  as Addie."""@en ;
  dcterms:modified "2026-06-07T15:30:29.326952Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6745-3
  a curric:KeyLearningPoint ;
  rdfs:label """Because we are in role as Addie, we may use some informal language features like
  short sentences and contractions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.326957Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6745-4
  a curric:KeyLearningPoint ;
  rdfs:label """We will also want to include the full range of sentence structures and
  punctuation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.326961Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6745-5
  a curric:KeyLearningPoint ;
  rdfs:label "Orally rehearsing our writing helps us to be prepared to write."@en ;
  dcterms:modified "2026-06-07T15:30:29.326965Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6278-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘Crazy About Cats’ provides information about different species of cats which can be
  compared and contrasted."""@en ;
  dcterms:modified "2026-06-07T15:30:29.326969Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6278-2
  a curric:KeyLearningPoint ;
  rdfs:label """Non-fiction can develop curiosity by engaging readers' interests and encouraging a
  deeper exploration of topics."""@en ;
  dcterms:modified "2026-06-07T15:30:29.326973Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6278-3
  a curric:KeyLearningPoint ;
  rdfs:label """Readers can ask questions of the text and illustrations to engage more fully with
  the information they have read."""@en ;
  dcterms:modified "2026-06-07T15:30:29.326996Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1389-1
  a curric:KeyLearningPoint ;
  rdfs:label """Soft c and hard c refer to two different sounds that the letter c can represent in
  English spelling."""@en ;
  dcterms:modified "2026-06-07T15:30:29.327000Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1389-2
  a curric:KeyLearningPoint ;
  rdfs:label """If the vowel letters ‘a’, ‘o’ or ‘u’ or a consonant letter follows the letter c it
  is pronounced as a hard c."""@en ;
  dcterms:modified "2026-06-07T15:30:29.327004Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1389-3
  a curric:KeyLearningPoint ;
  rdfs:label """If the vowel letters ‘e’, ‘i’ or ‘y’ follow the letter c it is pronounced as a soft
  c."""@en ;
  dcterms:modified "2026-06-07T15:30:29.327008Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1389-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: decide, notice and centre."@en ;
  dcterms:modified "2026-06-07T15:30:29.327012Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4700-1
  a curric:KeyLearningPoint ;
  rdfs:label "A debate is a structured argument between two teams."@en ;
  dcterms:modified "2026-06-07T15:30:29.327016Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4700-2
  a curric:KeyLearningPoint ;
  rdfs:label "An opinion is a view or belief that a person has."@en ;
  dcterms:modified "2026-06-07T15:30:29.327020Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4700-3
  a curric:KeyLearningPoint ;
  rdfs:label "In a debate, an opinion must be justified with reasoning."@en ;
  dcterms:modified "2026-06-07T15:30:29.327024Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4705-1
  a curric:KeyLearningPoint ;
  rdfs:label """When making a speech in a debate, a person should have written notes to help
  them."""@en ;
  dcterms:modified "2026-06-07T15:30:29.327028Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4705-2
  a curric:KeyLearningPoint ;
  rdfs:label "Notes do not need to be written in full sentences."@en ;
  dcterms:modified "2026-06-07T15:30:29.327032Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4705-3
  a curric:KeyLearningPoint ;
  rdfs:label "Notes should not be read word for word."@en ;
  dcterms:modified "2026-06-07T15:30:29.327036Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4862-1
  a curric:KeyLearningPoint ;
  rdfs:label "A subheading signals to the reader what the section is about."@en ;
  dcterms:modified "2026-06-07T15:30:29.327146Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4862-2
  a curric:KeyLearningPoint ;
  rdfs:label """A section about one feature of the report's subject contains specific facts and
  information to keep the reader engaged."""@en ;
  dcterms:modified "2026-06-07T15:30:29.327150Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4862-3
  a curric:KeyLearningPoint ;
  rdfs:label """Using the full range of sentence types (simple, compound and complex) improves text
  flow for the reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.327156Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4862-4
  a curric:KeyLearningPoint ;
  rdfs:label """Sentences should be said aloud before writing to ensure they make sense and read
  back once written to check for errors."""@en ;
  dcterms:modified "2026-06-07T15:30:29.327161Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4862-5
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials of cause and formal fronted adverbials are used at the start of
  sentences for cohesion."""@en ;
  dcterms:modified "2026-06-07T15:30:29.327164Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7908-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘London is the Place for Me’ was written by Aldwyn ‘Lord Kitchener’ Roberts
  in 1948."""@en ;
  dcterms:modified "2026-06-07T15:30:29.327201Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7908-2
  a curric:KeyLearningPoint ;
  rdfs:label """To better understand the song and its lyrics, we can explore the context in which it
  was written."""@en ;
  dcterms:modified "2026-06-07T15:30:29.327205Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7908-3
  a curric:KeyLearningPoint ;
  rdfs:label """Roberts migrated to the UK aboard the Empire Windrush; his arrival coincided with a
  period of significant change."""@en ;
  dcterms:modified "2026-06-07T15:30:29.327211Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7908-4
  a curric:KeyLearningPoint ;
  rdfs:label """The first two stanzas were sung by Lord Kitchener at the Tilsbury docks, on board
  the HMT Empire Windrush."""@en ;
  dcterms:modified "2026-06-07T15:30:29.327216Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7908-5
  a curric:KeyLearningPoint ;
  rdfs:label """Roberts’ experiences were not the same for all people who migrated from the
  Caribbean."""@en ;
  dcterms:modified "2026-06-07T15:30:29.327220Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8026-1
  a curric:KeyLearningPoint ;
  rdfs:label """Performing poetry to an audience is an important part of the process of creating
  poetry."""@en ;
  dcterms:modified "2026-06-07T15:30:29.327262Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8026-2
  a curric:KeyLearningPoint ;
  rdfs:label """When performing poetry, you can vary your volume, pace and use gestures to have an
  impact on the audience."""@en ;
  dcterms:modified "2026-06-07T15:30:29.327266Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8026-3
  a curric:KeyLearningPoint ;
  rdfs:label """Deciding upon and creating a desired atmosphere is important when performing
  poetry."""@en ;
  dcterms:modified "2026-06-07T15:30:29.327270Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8026-4
  a curric:KeyLearningPoint ;
  rdfs:label "We can improve our performances of poetry through practice."@en ;
  dcterms:modified "2026-06-07T15:30:29.327276Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8087-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘Richmond Park’ is a free verse poem; the poem offers contrasting views of the
  setting it describes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.327280Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8087-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Richmond Park' is based on a place which is near to where the poet grew up."@en ;
  dcterms:modified "2026-06-07T15:30:29.327284Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8087-3
  a curric:KeyLearningPoint ;
  rdfs:label """‘The Old Farmer’s Song’ can be described as a fixed verse poem; it has a consistent
  rhyme scheme."""@en ;
  dcterms:modified "2026-06-07T15:30:29.327290Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8087-4
  a curric:KeyLearningPoint ;
  rdfs:label "Both poems describe the harshness and beauty of rural life."@en ;
  dcterms:modified "2026-06-07T15:30:29.327295Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8087-5
  a curric:KeyLearningPoint ;
  rdfs:label """We can compare and contrast poems with similar themes or messages, noticing the
  impact that they have on us as readers."""@en ;
  dcterms:modified "2026-06-07T15:30:29.327299Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8086-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘Eastbourne’ was written by Joseph Coelho; it describes a walk that the poet/speaker
  takes along a pebbly beach."""@en ;
  dcterms:modified "2026-06-07T15:30:29.327322Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8086-2
  a curric:KeyLearningPoint ;
  rdfs:label "Eastbourne is a Victorian resort town on England’s southeast coast."@en ;
  dcterms:modified "2026-06-07T15:30:29.327326Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8086-3
  a curric:KeyLearningPoint ;
  rdfs:label """In the poem, Coelho uses vivid imagery to describe the setting to the reader or
  listener."""@en ;
  dcterms:modified "2026-06-07T15:30:29.327330Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8086-4
  a curric:KeyLearningPoint ;
  rdfs:label """The use of positive imagery creates a peaceful and serene atmosphere as the
  poet/speaker reflects on their day."""@en ;
  dcterms:modified "2026-06-07T15:30:29.327334Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1449-1
  a curric:KeyLearningPoint ;
  rdfs:label """A prefix is a letter or group of letters at the start of word which creates another
  word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.327354Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1449-2
  a curric:KeyLearningPoint ;
  rdfs:label "The prefixes dis-, non- and un- mean 'not', mis- usually means 'wrongly'."@en ;
  dcterms:modified "2026-06-07T15:30:29.327358Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1449-3
  a curric:KeyLearningPoint ;
  rdfs:label "Colour blocking is a useful practice strategy."@en ;
  dcterms:modified "2026-06-07T15:30:29.327362Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1449-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum word: recent."@en ;
  dcterms:modified "2026-06-07T15:30:29.327368Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6004-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of a persuasive letter is to change someone’s mind or behaviour or
  convince them about something."""@en ;
  dcterms:modified "2026-06-07T15:30:29.327393Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6004-2
  a curric:KeyLearningPoint ;
  rdfs:label "A persuasive letter is often formal in tone."@en ;
  dcterms:modified "2026-06-07T15:30:29.327397Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6004-3
  a curric:KeyLearningPoint ;
  rdfs:label "Flattery, presumption and veiled threat are examples of persuasive devices."@en ;
  dcterms:modified "2026-06-07T15:30:29.327400Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6751-1
  a curric:KeyLearningPoint ;
  rdfs:label """Writing is most successful when the structure, content and vocabulary are
  planned."""@en ;
  dcterms:modified "2026-06-07T15:30:29.327469Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6751-2
  a curric:KeyLearningPoint ;
  rdfs:label """We can plan precise vocabulary to include in our narrative to contribute to a fast,
  threatening mood."""@en ;
  dcterms:modified "2026-06-07T15:30:29.327473Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6751-3
  a curric:KeyLearningPoint ;
  rdfs:label """When we plan the content of our writing, we combine this vocabulary with actions and
  descriptive and emotive details."""@en ;
  dcterms:modified "2026-06-07T15:30:29.327477Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7350-1
  a curric:KeyLearningPoint ;
  rdfs:label """The build-up of ‘A Christmas Carol’ creates an eerie atmosphere leading up to the
  Ghost of Marley appearing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.328975Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7350-2
  a curric:KeyLearningPoint ;
  rdfs:label "A key feature of the build-up is the building of suspense for the reader."@en ;
  dcterms:modified "2026-06-07T15:30:29.328979Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7350-3
  a curric:KeyLearningPoint ;
  rdfs:label """The build-up will be written over two paragraphs where the suspense gradually
  increases."""@en ;
  dcterms:modified "2026-06-07T15:30:29.328983Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7350-4
  a curric:KeyLearningPoint ;
  rdfs:label """The use of precise vocabulary describing a range of sensory details helps to convey
  an eerie atmosphere."""@en ;
  dcterms:modified "2026-06-07T15:30:29.328987Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7350-5
  a curric:KeyLearningPoint ;
  rdfs:label """The use of ‘show and tell’ to describe Scrooge’s experiences conveys his emotions
  and supports in building suspense."""@en ;
  dcterms:modified "2026-06-07T15:30:29.328995Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6765-1
  a curric:KeyLearningPoint ;
  rdfs:label "Presenting involves speaking in front of others and listening to others."@en ;
  dcterms:modified "2026-06-07T15:30:29.328999Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6765-2
  a curric:KeyLearningPoint ;
  rdfs:label """Presenting includes voice projection, speaking with clear diction, making eye
  contact and using strong body language."""@en ;
  dcterms:modified "2026-06-07T15:30:29.329003Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6765-3
  a curric:KeyLearningPoint ;
  rdfs:label "Voice projection is not the same as shouting."@en ;
  dcterms:modified "2026-06-07T15:30:29.329007Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6765-4
  a curric:KeyLearningPoint ;
  rdfs:label "Practising pronouncing tricky words helps develop clear diction when presenting."@en ;
  dcterms:modified "2026-06-07T15:30:29.329011Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7860-1
  a curric:KeyLearningPoint ;
  rdfs:label "Reading between the lines to search for clues can help to infer meaning"@en ;
  dcterms:modified "2026-06-07T15:30:29.329015Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7860-2
  a curric:KeyLearningPoint ;
  rdfs:label "Evidence from the text helps us to justify our inferences"@en ;
  dcterms:modified "2026-06-07T15:30:29.329019Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7860-3
  a curric:KeyLearningPoint ;
  rdfs:label "Skimming and scanning helps to retrieve and record information from a text"@en ;
  dcterms:modified "2026-06-07T15:30:29.329023Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7860-4
  a curric:KeyLearningPoint ;
  rdfs:label """Role on the wall is a reading activity that helps readers develop their
  understanding of a character"""@en ;
  dcterms:modified "2026-06-07T15:30:29.329027Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6726-1
  a curric:KeyLearningPoint ;
  rdfs:label "Rehearsing our storytelling using a text map makes the writing process easier."@en ;
  dcterms:modified "2026-06-07T15:30:29.329031Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6726-2
  a curric:KeyLearningPoint ;
  rdfs:label "We can also plan some of the vocabulary we wish to use to have a certain effect."@en ;
  dcterms:modified "2026-06-07T15:30:29.329035Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6726-3
  a curric:KeyLearningPoint ;
  rdfs:label "We are going to be writing the build-up of 'Beowulf and the dragon'."@en ;
  dcterms:modified "2026-06-07T15:30:29.329039Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6726-4
  a curric:KeyLearningPoint ;
  rdfs:label """We can use rich vocabulary to describe the burned stronghold, the rocky headland and
  the dragon's body."""@en ;
  dcterms:modified "2026-06-07T15:30:29.329043Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6726-5
  a curric:KeyLearningPoint ;
  rdfs:label """We can avoid repeating 'Beowulf' and 'the dragon' by replacing them with varied noun
  phrases."""@en ;
  dcterms:modified "2026-06-07T15:30:29.329047Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6276-1
  a curric:KeyLearningPoint ;
  rdfs:label "Non-fiction texts can be written using formal or informal language"@en ;
  dcterms:modified "2026-06-07T15:30:29.329051Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6276-2
  a curric:KeyLearningPoint ;
  rdfs:label "The language used in a text will depend on the text's purpose and audience"@en ;
  dcterms:modified "2026-06-07T15:30:29.329055Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6276-3
  a curric:KeyLearningPoint ;
  rdfs:label """Owen Davey uses subject specific language to help create a sense of authority and
  reliability for the reader"""@en ;
  dcterms:modified "2026-06-07T15:30:29.329059Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6276-4
  a curric:KeyLearningPoint ;
  rdfs:label "Specific words and phrases can be selected by the author to convey meaning"@en ;
  dcterms:modified "2026-06-07T15:30:29.329066Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6276-5
  a curric:KeyLearningPoint ;
  rdfs:label "Owen Davey uses playful language to engage the reader"@en ;
  dcterms:modified "2026-06-07T15:30:29.329072Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1333-1
  a curric:KeyLearningPoint ;
  rdfs:label "Regular plurals follow spelling rules."@en ;
  dcterms:modified "2026-06-07T15:30:29.329076Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1333-2
  a curric:KeyLearningPoint ;
  rdfs:label "There are no rules for irregular plurals; you just have to learn them."@en ;
  dcterms:modified "2026-06-07T15:30:29.329080Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1333-3
  a curric:KeyLearningPoint ;
  rdfs:label """Examples of irregular plural nouns include: formula - formulae, woman - women, tooth
  - teeth, index - indices."""@en ;
  dcterms:modified "2026-06-07T15:30:29.329084Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1333-4
  a curric:KeyLearningPoint ;
  rdfs:label "We can look for naughty letters to help us to remember tricky spellings."@en ;
  dcterms:modified "2026-06-07T15:30:29.329088Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1333-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: equip and equipment."@en ;
  dcterms:modified "2026-06-07T15:30:29.329092Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1346-1
  a curric:KeyLearningPoint ;
  rdfs:label """The suffixes -ant and -ance are used if there is a related word with the 'a' or 'ay'
  sound in the right position."""@en ;
  dcterms:modified "2026-06-07T15:30:29.329096Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1346-2
  a curric:KeyLearningPoint ;
  rdfs:label """Changing the -ant suffix to -ance can change the word from an adjective to an
  abstract noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.329100Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1346-3
  a curric:KeyLearningPoint ;
  rdfs:label "The suffix -ant sometimes becomes -ancy, e.g. pregnant-pregnancy."@en ;
  dcterms:modified "2026-06-07T15:30:29.329104Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1346-4
  a curric:KeyLearningPoint ;
  rdfs:label """Examples of words that do not follow the above guidance and just need to be learned:
  assistant-assistance."""@en ;
  dcterms:modified "2026-06-07T15:30:29.329108Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1346-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: nuisance, sincere and guarantee."@en ;
  dcterms:modified "2026-06-07T15:30:29.329112Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1439-1
  a curric:KeyLearningPoint ;
  rdfs:label "-ly is a suffix that can be used to create adverbs."@en ;
  dcterms:modified "2026-06-07T15:30:29.329116Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1439-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Colour blocks' is a useful practice strategy."@en ;
  dcterms:modified "2026-06-07T15:30:29.329120Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1439-3
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: eight and weight."@en ;
  dcterms:modified "2026-06-07T15:30:29.329124Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1439-4
  a curric:KeyLearningPoint ;
  rdfs:label "There are four key rules for spelling using the suffix -ly."@en ;
  dcterms:modified "2026-06-07T15:30:29.329130Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6341-1
  a curric:KeyLearningPoint ;
  rdfs:label "Sir Arthur Conan Doyle wrote the ’Sherlock Holmes’ stories starting in 1886."@en ;
  dcterms:modified "2026-06-07T15:30:29.329159Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6341-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Sherlock Holmes' was written in the Victorian Era."@en ;
  dcterms:modified "2026-06-07T15:30:29.329163Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6341-3
  a curric:KeyLearningPoint ;
  rdfs:label """The Victorian city of London was a city of startling contrast between rich
  and poor."""@en ;
  dcterms:modified "2026-06-07T15:30:29.329167Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6341-4
  a curric:KeyLearningPoint ;
  rdfs:label "The Holmes stories are written in the first person from Watson's perspective."@en ;
  dcterms:modified "2026-06-07T15:30:29.329171Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4874-1
  a curric:KeyLearningPoint ;
  rdfs:label """A section of a non-chronological report contains specific information for the
  reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.329175Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4874-2
  a curric:KeyLearningPoint ;
  rdfs:label """Writers can use a range of cohesive devices to ensure their sentences flow and the
  text’s purpose is achieved."""@en ;
  dcterms:modified "2026-06-07T15:30:29.329179Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4874-3
  a curric:KeyLearningPoint ;
  rdfs:label """The diet section includes an introductory sentence, followed by specific
  information, then a linking sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.329183Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4874-4
  a curric:KeyLearningPoint ;
  rdfs:label """We can use success criteria to help us identify what a successful piece of writing
  includes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.329186Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4874-5
  a curric:KeyLearningPoint ;
  rdfs:label "The writing process involves planning, drafting, editing and publishing."@en ;
  dcterms:modified "2026-06-07T15:30:29.329190Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1370-1
  a curric:KeyLearningPoint ;
  rdfs:label "The suffixes -al and -ic create adjectives."@en ;
  dcterms:modified "2026-06-07T15:30:29.329234Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1370-2
  a curric:KeyLearningPoint ;
  rdfs:label "When the root word ends in a consonant, usually just add the suffix."@en ;
  dcterms:modified "2026-06-07T15:30:29.329238Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1370-3
  a curric:KeyLearningPoint ;
  rdfs:label "When the root word ends in ‘e’, remove the ‘e’ and add the suffix."@en ;
  dcterms:modified "2026-06-07T15:30:29.329242Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1370-4
  a curric:KeyLearningPoint ;
  rdfs:label "When the root word ends in 'y', remove the 'y' and add the suffix -ic."@en ;
  dcterms:modified "2026-06-07T15:30:29.329246Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1370-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: physical, natural and actual."@en ;
  dcterms:modified "2026-06-07T15:30:29.329250Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4871-1
  a curric:KeyLearningPoint ;
  rdfs:label """The introduction provides general information and outlines the structure of the full
  report."""@en ;
  dcterms:modified "2026-06-07T15:30:29.331672Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4871-2
  a curric:KeyLearningPoint ;
  rdfs:label "Parenthesis (additional information) can be conveyed using brackets."@en ;
  dcterms:modified "2026-06-07T15:30:29.331677Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4871-3
  a curric:KeyLearningPoint ;
  rdfs:label "Linking sentences at the end of our paragraphs create text cohesion."@en ;
  dcterms:modified "2026-06-07T15:30:29.331681Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4871-4
  a curric:KeyLearningPoint ;
  rdfs:label "Using a plan helps us have more successful writing outcomes"@en ;
  dcterms:modified "2026-06-07T15:30:29.331685Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1368-1
  a curric:KeyLearningPoint ;
  rdfs:label "The suffixes -ity and -ness turns adjectives into abstract nouns."@en ;
  dcterms:modified "2026-06-07T15:30:29.333999Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1368-2
  a curric:KeyLearningPoint ;
  rdfs:label """When a word ends in a consonant, just add the suffix -ity; when it ends in ‘e’,
  remove the ‘e’, then add -ity."""@en ;
  dcterms:modified "2026-06-07T15:30:29.334003Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1368-3
  a curric:KeyLearningPoint ;
  rdfs:label "There are other patterns and irregular words, like ‘ability’ and ‘simplicity’."@en ;
  dcterms:modified "2026-06-07T15:30:29.334007Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1368-4
  a curric:KeyLearningPoint ;
  rdfs:label """For most words, just add the suffix -ness; when a word ends in ‘y’, replace the ‘y’
  with ‘i’, then add the suffix -ness."""@en ;
  dcterms:modified "2026-06-07T15:30:29.334011Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1368-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: business and opportunity."@en ;
  dcterms:modified "2026-06-07T15:30:29.334015Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1421-1
  a curric:KeyLearningPoint ;
  rdfs:label "A solid compound word has two or more words joined together to make one word."@en ;
  dcterms:modified "2026-06-07T15:30:29.334231Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1421-2
  a curric:KeyLearningPoint ;
  rdfs:label "A hyphenated compound word has a hyphen separating two words."@en ;
  dcterms:modified "2026-06-07T15:30:29.334235Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1421-3
  a curric:KeyLearningPoint ;
  rdfs:label """An open compound word has two words that are separated, but are still behaving as
  one noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.334239Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1421-4
  a curric:KeyLearningPoint ;
  rdfs:label """A solid compound word is often the clearest way to combine two words to make a
  compound noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.334243Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1421-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: natural, pressure and strange."@en ;
  dcterms:modified "2026-06-07T15:30:29.334247Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1413-1
  a curric:KeyLearningPoint ;
  rdfs:label "The suffix -ic often turns nouns into adjectives."@en ;
  dcterms:modified "2026-06-07T15:30:29.334291Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1413-2
  a curric:KeyLearningPoint ;
  rdfs:label "When the root word ends in 'e', remove the 'e' and add the suffix -ic."@en ;
  dcterms:modified "2026-06-07T15:30:29.334297Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1413-3
  a curric:KeyLearningPoint ;
  rdfs:label "When the root word ends in 'y', remove the 'y' and add the suffix -ic."@en ;
  dcterms:modified "2026-06-07T15:30:29.334301Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1413-4
  a curric:KeyLearningPoint ;
  rdfs:label "When the root word does not end in 'e' or 'y', just add the suffix -ic."@en ;
  dcterms:modified "2026-06-07T15:30:29.334307Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1413-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: bicycle, centre and recent."@en ;
  dcterms:modified "2026-06-07T15:30:29.334312Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5806-1
  a curric:KeyLearningPoint ;
  rdfs:label "Shakespeare wrote 'Romeo and Juliet' as a play script."@en ;
  dcterms:modified "2026-06-07T15:30:29.334350Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5806-2
  a curric:KeyLearningPoint ;
  rdfs:label "Lines in the script give us clues for how characters feel and think."@en ;
  dcterms:modified "2026-06-07T15:30:29.334354Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5806-3
  a curric:KeyLearningPoint ;
  rdfs:label "Romeo and Juliet meet at a masked ball hosted by Lord Capulet."@en ;
  dcterms:modified "2026-06-07T15:30:29.334358Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5806-4
  a curric:KeyLearningPoint ;
  rdfs:label "Romeo falls instantly in love with Juliet upon first sight."@en ;
  dcterms:modified "2026-06-07T15:30:29.334362Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5806-5
  a curric:KeyLearningPoint ;
  rdfs:label """Romeo overhears Juliet professing her love for him later the same night from her
  balcony."""@en ;
  dcterms:modified "2026-06-07T15:30:29.334367Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6325-1
  a curric:KeyLearningPoint ;
  rdfs:label "Layout is how the content is presented on the page, such as titles and columns"@en ;
  dcterms:modified "2026-06-07T15:30:29.334371Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6325-2
  a curric:KeyLearningPoint ;
  rdfs:label """The layout of a non-fiction text is designed according to its purpose and target
  audience"""@en ;
  dcterms:modified "2026-06-07T15:30:29.334377Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6325-3
  a curric:KeyLearningPoint ;
  rdfs:label """A glossary enhances the accessibility and understanding of a non-fiction text,
  providing definitions for key terms"""@en ;
  dcterms:modified "2026-06-07T15:30:29.334381Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6325-4
  a curric:KeyLearningPoint ;
  rdfs:label """Non-fiction texts can be presented in a range of forms; features can vary from
  text-to-text"""@en ;
  dcterms:modified "2026-06-07T15:30:29.334385Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5494-1
  a curric:KeyLearningPoint ;
  rdfs:label "The verb carries the tense of a clause."@en ;
  dcterms:modified "2026-06-07T15:30:29.334401Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5494-2
  a curric:KeyLearningPoint ;
  rdfs:label """The perfect tense uses auxiliary verbs based on 'to have' and a past tense form of
  the main verb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.334405Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1456-1
  a curric:KeyLearningPoint ;
  rdfs:label "Compound words are words made up of two or more pre-existing words."@en ;
  dcterms:modified "2026-06-07T15:30:29.334445Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1456-2
  a curric:KeyLearningPoint ;
  rdfs:label """The spelling of both words remains the same when the words are combined
  together."""@en ;
  dcterms:modified "2026-06-07T15:30:29.334467Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1456-3
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum word: forwards."@en ;
  dcterms:modified "2026-06-07T15:30:29.334471Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6113-1
  a curric:KeyLearningPoint ;
  rdfs:label """Parenthesis can be achieved with a range of punctuation, including brackets and
  commas."""@en ;
  dcterms:modified "2026-06-07T15:30:29.334507Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6113-2
  a curric:KeyLearningPoint ;
  rdfs:label """Any type of parenthesis is additional information that can be removed without
  compromising grammatical accuracy."""@en ;
  dcterms:modified "2026-06-07T15:30:29.334513Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6113-3
  a curric:KeyLearningPoint ;
  rdfs:label "Brackets are useful in non-fiction writing to add extra, factual information."@en ;
  dcterms:modified "2026-06-07T15:30:29.334541Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6113-4
  a curric:KeyLearningPoint ;
  rdfs:label """Commas can demarcate a relative clause that is inserted into a sentence as
  parenthesis."""@en ;
  dcterms:modified "2026-06-07T15:30:29.334546Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6113-5
  a curric:KeyLearningPoint ;
  rdfs:label "Commas are also useful to drop information into a clause."@en ;
  dcterms:modified "2026-06-07T15:30:29.334550Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6097-1
  a curric:KeyLearningPoint ;
  rdfs:label """Text cohesion refers to how a text flows together to maintain the interest of the
  reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.334613Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6097-2
  a curric:KeyLearningPoint ;
  rdfs:label """We can improve text cohesion using cohesive devices that connect information within
  and between sentences."""@en ;
  dcterms:modified "2026-06-07T15:30:29.334620Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6097-3
  a curric:KeyLearningPoint ;
  rdfs:label """Compound and complex sentences can be used to join linked information in one
  sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.334624Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6097-4
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials can be used to show links between information in adjacent
  sentences."""@en ;
  dcterms:modified "2026-06-07T15:30:29.334629Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6097-5
  a curric:KeyLearningPoint ;
  rdfs:label """There are different types of complex sentence and fronted adverbials, which serve
  different purposes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.334633Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1445-1
  a curric:KeyLearningPoint ;
  rdfs:label "-er and -est are suffixes that can be used to change the meaning of a root word."@en ;
  dcterms:modified "2026-06-07T15:30:29.334734Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1445-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Colour blocks' is a useful practice strategy."@en ;
  dcterms:modified "2026-06-07T15:30:29.334738Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1445-3
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum word: difficult."@en ;
  dcterms:modified "2026-06-07T15:30:29.334742Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4858-1
  a curric:KeyLearningPoint ;
  rdfs:label """A non-chronological report is a non-fiction text providing information about a
  particular subject."""@en ;
  dcterms:modified "2026-06-07T15:30:29.334746Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4858-2
  a curric:KeyLearningPoint ;
  rdfs:label """A non-chronological report can be organised into an introduction, paragraphs
  organised by theme and a conclusion."""@en ;
  dcterms:modified "2026-06-07T15:30:29.334750Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4858-3
  a curric:KeyLearningPoint ;
  rdfs:label """Vocabulary within a non-chronological report is subject-specific and factual; the
  language and tone is formal."""@en ;
  dcterms:modified "2026-06-07T15:30:29.334753Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4858-4
  a curric:KeyLearningPoint ;
  rdfs:label """Conjunctions are an important linguistic feature within non-chronological reports in
  order to ensure cohesion."""@en ;
  dcterms:modified "2026-06-07T15:30:29.334757Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4858-5
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials are an important linguistic feature within non-chronological
  reports in order to ensure cohesion."""@en ;
  dcterms:modified "2026-06-07T15:30:29.334761Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6548-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of a persuasive letter is to persuade or convince the reader to change
  their mind or behaviour."""@en ;
  dcterms:modified "2026-06-07T15:30:29.334773Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6548-2
  a curric:KeyLearningPoint ;
  rdfs:label "Persuasive letters are formal in tone."@en ;
  dcterms:modified "2026-06-07T15:30:29.334777Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6548-3
  a curric:KeyLearningPoint ;
  rdfs:label """Linguistic features are language features that help the text achieve its
  purpose."""@en ;
  dcterms:modified "2026-06-07T15:30:29.334781Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6548-4
  a curric:KeyLearningPoint ;
  rdfs:label """Persuasive techniques are structures or devices used in writing to try to change
  someone’s mind or behaviour."""@en ;
  dcterms:modified "2026-06-07T15:30:29.334785Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6728-1
  a curric:KeyLearningPoint ;
  rdfs:label """As we write, we aim to include a range of narrative elements and to connect ideas
  using a range of cohesive devices."""@en ;
  dcterms:modified "2026-06-07T15:30:29.334881Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6728-2
  a curric:KeyLearningPoint ;
  rdfs:label """A range of types of complex sentence - adverbial, relative and non-finite (-ing) -
  can be used as cohesive devices."""@en ;
  dcterms:modified "2026-06-07T15:30:29.334887Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6728-3
  a curric:KeyLearningPoint ;
  rdfs:label "Colons and semi-colons are also useful cohesive devices."@en ;
  dcterms:modified "2026-06-07T15:30:29.334891Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6728-4
  a curric:KeyLearningPoint ;
  rdfs:label """We can orally rehearse our ideas prior to writing in order to make it easier when we
  come to write."""@en ;
  dcterms:modified "2026-06-07T15:30:29.334895Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1089-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Havoc' is a noun, which means great damage or chaos."@en ;
  dcterms:modified "2026-06-07T15:30:29.335383Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1089-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Turbulent' is a adjective, which means violent and unstable."@en ;
  dcterms:modified "2026-06-07T15:30:29.335387Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1089-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Unruly', 'rebellious' and 'devastating' are other adjectives related to chaos and
  confusion."""@en ;
  dcterms:modified "2026-06-07T15:30:29.335391Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1089-4
  a curric:KeyLearningPoint ;
  rdfs:label "'Commotion' is a noun related to chaos and confusion."@en ;
  dcterms:modified "2026-06-07T15:30:29.335395Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7851-1
  a curric:KeyLearningPoint ;
  rdfs:label """Walter Tull's Scrapbook represents the true story of Walter Tull's life as a
  fictionalised scrapbook."""@en ;
  dcterms:modified "2026-06-07T15:30:29.335399Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7851-2
  a curric:KeyLearningPoint ;
  rdfs:label "The text uses actual photos, documents and records."@en ;
  dcterms:modified "2026-06-07T15:30:29.335403Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7851-3
  a curric:KeyLearningPoint ;
  rdfs:label """A biography is a non-fiction text which focuses on someone's life journey. It is
  written by another person."""@en ;
  dcterms:modified "2026-06-07T15:30:29.335406Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7851-4
  a curric:KeyLearningPoint ;
  rdfs:label """Knowing the historical and cultural context helps us understand the author’s
  perspective."""@en ;
  dcterms:modified "2026-06-07T15:30:29.335411Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6741-1
  a curric:KeyLearningPoint ;
  rdfs:label "Editing is a critical part of the writing process."@en ;
  dcterms:modified "2026-06-07T15:30:29.335415Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6741-2
  a curric:KeyLearningPoint ;
  rdfs:label """Writing is most successful when editing is used to rethink, rephrase and reconsider
  first ideas."""@en ;
  dcterms:modified "2026-06-07T15:30:29.335419Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6741-3
  a curric:KeyLearningPoint ;
  rdfs:label "Editing can be done by oneself, with a peer or with a teacher."@en ;
  dcterms:modified "2026-06-07T15:30:29.335422Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6741-4
  a curric:KeyLearningPoint ;
  rdfs:label """Editing is most successful when it is chunked by punctuation, sentence structure,
  cohesive devices and vocabulary."""@en ;
  dcterms:modified "2026-06-07T15:30:29.335426Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6741-5
  a curric:KeyLearningPoint ;
  rdfs:label "A growth mindset helps us benefit most from editing."@en ;
  dcterms:modified "2026-06-07T15:30:29.335430Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2707-1
  a curric:KeyLearningPoint ;
  rdfs:label "Direct speech is the term used for a character speaking out loud in a text."@en ;
  dcterms:modified "2026-06-07T15:30:29.335437Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2707-2
  a curric:KeyLearningPoint ;
  rdfs:label "A speech first sentence begins with a character's spoken words."@en ;
  dcterms:modified "2026-06-07T15:30:29.335441Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2707-3
  a curric:KeyLearningPoint ;
  rdfs:label """Inverted commas are the punctuation marks that signal direct speech to the
  reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.335445Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2707-4
  a curric:KeyLearningPoint ;
  rdfs:label "The speech sentence spoken by a character must start with a capital letter."@en ;
  dcterms:modified "2026-06-07T15:30:29.335451Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2707-5
  a curric:KeyLearningPoint ;
  rdfs:label "The reporting clause comes after the speech to show who said the speech and how."@en ;
  dcterms:modified "2026-06-07T15:30:29.335455Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4835-1
  a curric:KeyLearningPoint ;
  rdfs:label """Print handwriting is recommended for tasks where clarity, legibility and uniformity
  are essential."""@en ;
  dcterms:modified "2026-06-07T15:30:29.335460Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4835-2
  a curric:KeyLearningPoint ;
  rdfs:label """Application forms and medical forms will require you to fill information out in
  print or block capitals."""@en ;
  dcterms:modified "2026-06-07T15:30:29.335464Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4835-3
  a curric:KeyLearningPoint ;
  rdfs:label """E-mail addresses and postal addresses require the use of print letters or capital
  letters to ensure legibility."""@en ;
  dcterms:modified "2026-06-07T15:30:29.335468Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4835-4
  a curric:KeyLearningPoint ;
  rdfs:label """Block capitals refer to the writing style where each letter is written as a capital
  letter and formed separately."""@en ;
  dcterms:modified "2026-06-07T15:30:29.335472Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4835-5
  a curric:KeyLearningPoint ;
  rdfs:label """Letter formation and letter spacing should be accurate when writing in print to
  ensure legibility."""@en ;
  dcterms:modified "2026-06-07T15:30:29.335476Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1120-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Chiselled' is an adjective which means perfectly carved or sculpted."@en ;
  dcterms:modified "2026-06-07T15:30:29.335499Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1120-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Dazzling' is an adjective which means sparkling or amazing."@en ;
  dcterms:modified "2026-06-07T15:30:29.335503Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1120-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Impeccable' is an adjective which means elegant and perfect."@en ;
  dcterms:modified "2026-06-07T15:30:29.335507Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6717-1
  a curric:KeyLearningPoint ;
  rdfs:label "A biography is a non-fiction text written about someone's life."@en ;
  dcterms:modified "2026-06-07T15:30:29.335558Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6717-2
  a curric:KeyLearningPoint ;
  rdfs:label """Linguistic features of a biography include third person, formal fronted adverbials,
  formal tone and relative clauses."""@en ;
  dcterms:modified "2026-06-07T15:30:29.335562Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6717-3
  a curric:KeyLearningPoint ;
  rdfs:label """Structural features of a biography include a title, paragraphs and information
  grouped by theme."""@en ;
  dcterms:modified "2026-06-07T15:30:29.335566Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6717-4
  a curric:KeyLearningPoint ;
  rdfs:label """A biography is usually written in chronological order and will contain lots of past
  tense verbs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.335573Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6717-5
  a curric:KeyLearningPoint ;
  rdfs:label "Additional factual information can be added to a clause as parenthesis."@en ;
  dcterms:modified "2026-06-07T15:30:29.335577Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6549-1
  a curric:KeyLearningPoint ;
  rdfs:label """The introduction must clearly communicate why the author is writing to the
  recipient."""@en ;
  dcterms:modified "2026-06-07T15:30:29.335736Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6549-2
  a curric:KeyLearningPoint ;
  rdfs:label "This persuasive letter is formal in tone."@en ;
  dcterms:modified "2026-06-07T15:30:29.335742Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6549-3
  a curric:KeyLearningPoint ;
  rdfs:label "An introductory sentence indicates what the paragraph will be about."@en ;
  dcterms:modified "2026-06-07T15:30:29.335747Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6549-4
  a curric:KeyLearningPoint ;
  rdfs:label "Information in the introduction should be kept general."@en ;
  dcterms:modified "2026-06-07T15:30:29.335751Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3471-1
  a curric:KeyLearningPoint ;
  rdfs:label "The steps in the honey-making process are written in chronological order."@en ;
  dcterms:modified "2026-06-07T15:30:29.335755Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3471-2
  a curric:KeyLearningPoint ;
  rdfs:label "Ordering fronted adverbials indicate the order of the steps in a process."@en ;
  dcterms:modified "2026-06-07T15:30:29.335761Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3471-3
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials of cause explain the cause and effect of a fact across two
  sentences."""@en ;
  dcterms:modified "2026-06-07T15:30:29.335765Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3471-4
  a curric:KeyLearningPoint ;
  rdfs:label """Using the full range of sentence types (simple, compound and complex) improves text
  flow for the reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.335769Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3471-5
  a curric:KeyLearningPoint ;
  rdfs:label """Explanation texts include subject-specific vocabulary that is related to the subject
  of the text."""@en ;
  dcterms:modified "2026-06-07T15:30:29.335773Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28384-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘Compliments of Shakespeare’ is a poem found in the poetry collection ‘Dear Ugly
  Sisters’ by Laura Mucha."""@en ;
  dcterms:modified "2026-06-07T15:30:29.336079Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28384-2
  a curric:KeyLearningPoint ;
  rdfs:label """Mucha has taken some of Shakespeare’s insults and turned them into a witty poem
  written in modern day language."""@en ;
  dcterms:modified "2026-06-07T15:30:29.336084Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28384-3
  a curric:KeyLearningPoint ;
  rdfs:label """Understanding a poem, its language and the atmosphere it creates will help us to
  create an impactful performance."""@en ;
  dcterms:modified "2026-06-07T15:30:29.336091Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28384-4
  a curric:KeyLearningPoint ;
  rdfs:label """We can vary our tone, pace and volume to create different effects when performing a
  poem."""@en ;
  dcterms:modified "2026-06-07T15:30:29.336095Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28384-5
  a curric:KeyLearningPoint ;
  rdfs:label """Our facial expressions and body language can help to convey meaning as we
  perform."""@en ;
  dcterms:modified "2026-06-07T15:30:29.336099Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1400-1
  a curric:KeyLearningPoint ;
  rdfs:label """A suffix is a letter or group of letters added to the end of a word to change its
  meaning and sometimes wordclass."""@en ;
  dcterms:modified "2026-06-07T15:30:29.336104Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1400-2
  a curric:KeyLearningPoint ;
  rdfs:label "The suffixes -tion, -ity and -ness create nouns."@en ;
  dcterms:modified "2026-06-07T15:30:29.336108Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1400-3
  a curric:KeyLearningPoint ;
  rdfs:label """An abstract noun is a type of noun that names an idea or quality that cannot be
  seen."""@en ;
  dcterms:modified "2026-06-07T15:30:29.336112Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1400-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: describe, often and notice."@en ;
  dcterms:modified "2026-06-07T15:30:29.336132Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28984-1
  a curric:KeyLearningPoint ;
  rdfs:label """'The City of my birth' is a poem that was written by Karl Nova in 2017 and it is
  influenced by hip-hop culture."""@en ;
  dcterms:modified "2026-06-07T15:30:29.336136Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28984-2
  a curric:KeyLearningPoint ;
  rdfs:label """The atmosphere that the poem creates is one of a busy, energetic and joyful
  city."""@en ;
  dcterms:modified "2026-06-07T15:30:29.336140Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28984-3
  a curric:KeyLearningPoint ;
  rdfs:label "There is a natural rhythm and flow throughout the poem."@en ;
  dcterms:modified "2026-06-07T15:30:29.336144Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28984-4
  a curric:KeyLearningPoint ;
  rdfs:label """Making notes on the poem about which words to emphasise can help a performer get
  ready to perform the poem."""@en ;
  dcterms:modified "2026-06-07T15:30:29.336148Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28984-5
  a curric:KeyLearningPoint ;
  rdfs:label "Practising the poem ahead of time helps to improve a performance."@en ;
  dcterms:modified "2026-06-07T15:30:29.336154Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8088-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘No. 115 Dreams’ is a free verse poem; it contains five verses and a repeated
  refrain."""@en ;
  dcterms:modified "2026-06-07T15:30:29.336181Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8088-2
  a curric:KeyLearningPoint ;
  rdfs:label "‘No. 115 Dreams’ contains several examples of personification."@en ;
  dcterms:modified "2026-06-07T15:30:29.336187Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8088-3
  a curric:KeyLearningPoint ;
  rdfs:label """Rooms and objects are describing family members or events that occurred in the
  house."""@en ;
  dcterms:modified "2026-06-07T15:30:29.336192Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8088-4
  a curric:KeyLearningPoint ;
  rdfs:label """A poem can have multiple meanings and interpretations; each person’s response can be
  different and unique to them."""@en ;
  dcterms:modified "2026-06-07T15:30:29.336196Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8088-5
  a curric:KeyLearningPoint ;
  rdfs:label "We can respond to a poem by writing a personal response to it."@en ;
  dcterms:modified "2026-06-07T15:30:29.336200Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4711-1
  a curric:KeyLearningPoint ;
  rdfs:label "The purpose of your speech is the reason why you are speaking."@en ;
  dcterms:modified "2026-06-07T15:30:29.336243Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4711-2
  a curric:KeyLearningPoint ;
  rdfs:label "Speeches often try to persuade an audience to agree with its main themes."@en ;
  dcterms:modified "2026-06-07T15:30:29.336247Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4711-3
  a curric:KeyLearningPoint ;
  rdfs:label "Speeches can inform an audience about something they may not already know about."@en ;
  dcterms:modified "2026-06-07T15:30:29.336251Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4711-4
  a curric:KeyLearningPoint ;
  rdfs:label "Speeches can provoke an emotional response."@en ;
  dcterms:modified "2026-06-07T15:30:29.336255Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2719-1
  a curric:KeyLearningPoint ;
  rdfs:label """The conclusion of an explanation text summarises the information that has been
  provided."""@en ;
  dcterms:modified "2026-06-07T15:30:29.336259Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2719-2
  a curric:KeyLearningPoint ;
  rdfs:label """The conclusion of an explanation text reviews the most important information using
  subject-specific vocabulary."""@en ;
  dcterms:modified "2026-06-07T15:30:29.336266Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2719-3
  a curric:KeyLearningPoint ;
  rdfs:label """The conclusion of an explanation text is an opportunity to encourage the reader to
  discover more about the subject."""@en ;
  dcterms:modified "2026-06-07T15:30:29.336270Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2719-4
  a curric:KeyLearningPoint ;
  rdfs:label "Using a range of simple, compound and complex sentences supports text flow."@en ;
  dcterms:modified "2026-06-07T15:30:29.336274Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2719-5
  a curric:KeyLearningPoint ;
  rdfs:label "The use of compound and complex sentences are very effective for summarising."@en ;
  dcterms:modified "2026-06-07T15:30:29.336304Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6753-1
  a curric:KeyLearningPoint ;
  rdfs:label "Writing is most successful when structure, content and vocabulary is planned."@en ;
  dcterms:modified "2026-06-07T15:30:29.336432Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6753-2
  a curric:KeyLearningPoint ;
  rdfs:label "Our climax should have a tense, fast-paced mood."@en ;
  dcterms:modified "2026-06-07T15:30:29.336436Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6753-3
  a curric:KeyLearningPoint ;
  rdfs:label """We can combine descriptive details and emotive details to paint a clear picture for
  the reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.336440Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6753-4
  a curric:KeyLearningPoint ;
  rdfs:label """We can use a range of linguistic techniques and cohesive devices for increasing the
  pace."""@en ;
  dcterms:modified "2026-06-07T15:30:29.336444Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6753-5
  a curric:KeyLearningPoint ;
  rdfs:label "We use precise vocabulary to add to the impression of speed."@en ;
  dcterms:modified "2026-06-07T15:30:29.336451Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1323-1
  a curric:KeyLearningPoint ;
  rdfs:label """Visuals and captions make information easier to understand and remember for the
  reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.336624Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1323-2
  a curric:KeyLearningPoint ;
  rdfs:label """The layout of a text helps to organise information logically, allowing the reader to
  navigate through a report easily."""@en ;
  dcterms:modified "2026-06-07T15:30:29.336633Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1323-3
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to use neat, joined handwriting when publishing a non-chronological
  report."""@en ;
  dcterms:modified "2026-06-07T15:30:29.336637Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1323-4
  a curric:KeyLearningPoint ;
  rdfs:label """A published non-chronological report should be visually and linguistically appealing
  to the reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.336643Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8466-1
  a curric:KeyLearningPoint ;
  rdfs:label """Oral rehearsal of a recount ensures we have a clear understanding of the chronology
  of events."""@en ;
  dcterms:modified "2026-06-07T15:30:29.336747Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8466-2
  a curric:KeyLearningPoint ;
  rdfs:label """When rehearsing and planning for a diary entry, we do so in the first person from
  the character's perspective."""@en ;
  dcterms:modified "2026-06-07T15:30:29.336751Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8466-3
  a curric:KeyLearningPoint ;
  rdfs:label """An effective plan for a diary entry contains key events in chronological order and
  thoughts/feelings."""@en ;
  dcterms:modified "2026-06-07T15:30:29.336755Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8466-4
  a curric:KeyLearningPoint ;
  rdfs:label """A plan is written in note format using bullet points to capture the most important
  information."""@en ;
  dcterms:modified "2026-06-07T15:30:29.336759Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8466-5
  a curric:KeyLearningPoint ;
  rdfs:label """Lila's second diary entry will recount her discovering her father's betrayal and her
  decision to leave on her quest."""@en ;
  dcterms:modified "2026-06-07T15:30:29.336763Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5692-1
  a curric:KeyLearningPoint ;
  rdfs:label "'The Man on the Moon’ is a short film about a man who lives on the moon."@en ;
  dcterms:modified "2026-06-07T15:30:29.336769Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5692-2
  a curric:KeyLearningPoint ;
  rdfs:label """Visual literacy writing units use short films or moving picture as the stimulus for
  writing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.336775Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5692-3
  a curric:KeyLearningPoint ;
  rdfs:label "Imagination must be used to picture a man living on the moon."@en ;
  dcterms:modified "2026-06-07T15:30:29.336780Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5692-4
  a curric:KeyLearningPoint ;
  rdfs:label """Pupils will have different responses to the same clip and these should be
  discussed."""@en ;
  dcterms:modified "2026-06-07T15:30:29.336784Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5692-5
  a curric:KeyLearningPoint ;
  rdfs:label """Hot-seating is a drama technique that helps pupils understand and empathise with
  fictional characters."""@en ;
  dcterms:modified "2026-06-07T15:30:29.336788Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5837-1
  a curric:KeyLearningPoint ;
  rdfs:label "William Shakespeare was a renowned English playwright, poet and actor."@en ;
  dcterms:modified "2026-06-07T15:30:29.338040Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5837-2
  a curric:KeyLearningPoint ;
  rdfs:label "Shakespeare lived from 1564 to 1616."@en ;
  dcterms:modified "2026-06-07T15:30:29.338044Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5837-3
  a curric:KeyLearningPoint ;
  rdfs:label """Shakespeare's plays were written at a time when the theatre was an important form of
  entertainment."""@en ;
  dcterms:modified "2026-06-07T15:30:29.338048Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5837-4
  a curric:KeyLearningPoint ;
  rdfs:label """Shakespeare wrote at least 39 plays that can broadly be grouped into tragedies,
  comedies and historical plays."""@en ;
  dcterms:modified "2026-06-07T15:30:29.338052Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5837-5
  a curric:KeyLearningPoint ;
  rdfs:label "Shakespeare's plays centre around complex themes and intricate plot structures."@en ;
  dcterms:modified "2026-06-07T15:30:29.338056Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6693-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of a build-up is to move the main character’s journey forward and build
  tension."""@en ;
  dcterms:modified "2026-06-07T15:30:29.338108Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6693-2
  a curric:KeyLearningPoint ;
  rdfs:label """Precise and ambitious vocabulary shows and tells the reader what happened on her
  journey and how she was feeling."""@en ;
  dcterms:modified "2026-06-07T15:30:29.338112Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6693-3
  a curric:KeyLearningPoint ;
  rdfs:label """Using a range of sentence types (simple, compound and complex) improves text flow
  for the reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.338116Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6693-4
  a curric:KeyLearningPoint ;
  rdfs:label """An adverbial clause is joined with a main clause to form an adverbial complex
  sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.338120Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6693-5
  a curric:KeyLearningPoint ;
  rdfs:label "Rhetorical questions can be used as a narrative device to engage the reader."@en ;
  dcterms:modified "2026-06-07T15:30:29.338124Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7930-1
  a curric:KeyLearningPoint ;
  rdfs:label """Turning points in a text mark the change in direction for a character; this effects
  the plot."""@en ;
  dcterms:modified "2026-06-07T15:30:29.339005Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7930-2
  a curric:KeyLearningPoint ;
  rdfs:label "Significant moments in the text can be both positive or negative."@en ;
  dcterms:modified "2026-06-07T15:30:29.339009Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7930-3
  a curric:KeyLearningPoint ;
  rdfs:label "Turning points can evoke a range of emotions in characters."@en ;
  dcterms:modified "2026-06-07T15:30:29.339012Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5659-1
  a curric:KeyLearningPoint ;
  rdfs:label """When reading non-fiction texts, readers can use the layout features to help navigate
  the text."""@en ;
  dcterms:modified "2026-06-07T15:30:29.339016Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5659-2
  a curric:KeyLearningPoint ;
  rdfs:label "Non-fiction texts can present information in different forms and layouts."@en ;
  dcterms:modified "2026-06-07T15:30:29.339020Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5659-3
  a curric:KeyLearningPoint ;
  rdfs:label "Readers can compare and contrast within and across texts."@en ;
  dcterms:modified "2026-06-07T15:30:29.339024Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5452-1
  a curric:KeyLearningPoint ;
  rdfs:label "The protagonist is a main character or central figure in a story or narrative."@en ;
  dcterms:modified "2026-06-07T15:30:29.339028Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5452-2
  a curric:KeyLearningPoint ;
  rdfs:label """Mulan is the protagonist who drives the actions and whose quest impacts the fate of
  herself, her family and her country."""@en ;
  dcterms:modified "2026-06-07T15:30:29.339035Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5452-3
  a curric:KeyLearningPoint ;
  rdfs:label """Character traits are the special qualities that make a character in a story unique
  and interesting."""@en ;
  dcterms:modified "2026-06-07T15:30:29.339039Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5452-4
  a curric:KeyLearningPoint ;
  rdfs:label """We can identify Mulan’s character traits by exploring her experiences and
  interactions and making inferences."""@en ;
  dcterms:modified "2026-06-07T15:30:29.339043Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5452-5
  a curric:KeyLearningPoint ;
  rdfs:label """Mulan displays a range of character traits such as courage, resilience and
  determination."""@en ;
  dcterms:modified "2026-06-07T15:30:29.339047Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1435-1
  a curric:KeyLearningPoint ;
  rdfs:label "-es is a suffix that can turn a singular noun into a plural."@en ;
  dcterms:modified "2026-06-07T15:30:29.339534Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1435-2
  a curric:KeyLearningPoint ;
  rdfs:label "Using the strategy 'pyramid letters' is a useful practice strategy."@en ;
  dcterms:modified "2026-06-07T15:30:29.339538Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1435-3
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum word: describe."@en ;
  dcterms:modified "2026-06-07T15:30:29.339542Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7902-1
  a curric:KeyLearningPoint ;
  rdfs:label """By reading from a range of perspectives, readers can discover more about characters
  and their relationships."""@en ;
  dcterms:modified "2026-06-07T15:30:29.339546Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7902-2
  a curric:KeyLearningPoint ;
  rdfs:label "Characters and their relationships change and evolve throughout a narrative."@en ;
  dcterms:modified "2026-06-07T15:30:29.339550Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7902-3
  a curric:KeyLearningPoint ;
  rdfs:label """Making connections and recommendations can significantly enhance a reader's
  experience with a text."""@en ;
  dcterms:modified "2026-06-07T15:30:29.339554Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7902-4
  a curric:KeyLearningPoint ;
  rdfs:label """Connections are ways in which you connect personally with a text; these may differ
  based on reader's life experiences."""@en ;
  dcterms:modified "2026-06-07T15:30:29.339558Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5451-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘Mulan’ tells the story of a young girl who disguises herself as a boy in order to
  fight in the army."""@en ;
  dcterms:modified "2026-06-07T15:30:29.339591Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5451-2
  a curric:KeyLearningPoint ;
  rdfs:label """Asking questions and having rich discussions builds our understanding and allows us
  to hear different perspectives."""@en ;
  dcterms:modified "2026-06-07T15:30:29.339595Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5451-3
  a curric:KeyLearningPoint ;
  rdfs:label "Searching for clues within a text can help us infer greater meaning."@en ;
  dcterms:modified "2026-06-07T15:30:29.339599Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5451-4
  a curric:KeyLearningPoint ;
  rdfs:label "We can retrieve evidence from the text to help us justify our inferences."@en ;
  dcterms:modified "2026-06-07T15:30:29.339603Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5451-5
  a curric:KeyLearningPoint ;
  rdfs:label """A character’s actions, experiences and words can be analysed to infer greater
  meaning."""@en ;
  dcterms:modified "2026-06-07T15:30:29.339607Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7891-1
  a curric:KeyLearningPoint ;
  rdfs:label """Walter de la Mare uses a range of poetic devices to create atmosphere in \"The
  Listeners\""""@en ;
  dcterms:modified "2026-06-07T15:30:29.339611Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7891-2
  a curric:KeyLearningPoint ;
  rdfs:label "Readers can interpret the poem in many different ways."@en ;
  dcterms:modified "2026-06-07T15:30:29.339614Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7891-3
  a curric:KeyLearningPoint ;
  rdfs:label "Reading between the lines to search for clues can help to infer meaning."@en ;
  dcterms:modified "2026-06-07T15:30:29.339618Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6756-1
  a curric:KeyLearningPoint ;
  rdfs:label """A journalistic report has a formal tone and it combines factual statements with
  different perspectives on an event."""@en ;
  dcterms:modified "2026-06-07T15:30:29.339622Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6756-2
  a curric:KeyLearningPoint ;
  rdfs:label "The introduction gives a summary and a description of the event."@en ;
  dcterms:modified "2026-06-07T15:30:29.339628Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6756-3
  a curric:KeyLearningPoint ;
  rdfs:label """The main paragraphs give different perspectives using both direct and reported
  speech."""@en ;
  dcterms:modified "2026-06-07T15:30:29.339633Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6756-4
  a curric:KeyLearningPoint ;
  rdfs:label "Throughout, a range of cohesive devices can be used to connect ideas together."@en ;
  dcterms:modified "2026-06-07T15:30:29.339637Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1108-1
  a curric:KeyLearningPoint ;
  rdfs:label "Biting is an adjective which means bitter, cold or harsh."@en ;
  dcterms:modified "2026-06-07T15:30:29.339641Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1108-2
  a curric:KeyLearningPoint ;
  rdfs:label "Brisk is an adjective which means sharp or crisp."@en ;
  dcterms:modified "2026-06-07T15:30:29.339645Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1108-3
  a curric:KeyLearningPoint ;
  rdfs:label "Excruciating is an adjective which means extremely painful."@en ;
  dcterms:modified "2026-06-07T15:30:29.339651Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1365-1
  a curric:KeyLearningPoint ;
  rdfs:label "If the root word ends in a ‘sh’, ‘ch’, ‘ss’ or ‘x’, then add the suffix -es."@en ;
  dcterms:modified "2026-06-07T15:30:29.339655Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1365-2
  a curric:KeyLearningPoint ;
  rdfs:label "If the root word ends in an ‘o’, it can use -s or -es."@en ;
  dcterms:modified "2026-06-07T15:30:29.339662Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1365-3
  a curric:KeyLearningPoint ;
  rdfs:label """If the root word ends in a ‘f’ or ‘fe’, then the ‘f’ is replaced by ‘v’ before
  adding the suffix -es."""@en ;
  dcterms:modified "2026-06-07T15:30:29.339666Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1365-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: twelfth, often and appear."@en ;
  dcterms:modified "2026-06-07T15:30:29.339672Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4852-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of an editing lesson is to improve writing and make necessary
  corrections."""@en ;
  dcterms:modified "2026-06-07T15:30:29.339677Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4852-2
  a curric:KeyLearningPoint ;
  rdfs:label """Vocabulary, grammar and punctuation can be changed to make writing outcomes more
  effective in meeting text purpose."""@en ;
  dcterms:modified "2026-06-07T15:30:29.339714Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4852-3
  a curric:KeyLearningPoint ;
  rdfs:label "When editing, we are selective about which parts of our writing to improve."@en ;
  dcterms:modified "2026-06-07T15:30:29.339720Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4852-4
  a curric:KeyLearningPoint ;
  rdfs:label "Editing does not involve re-writing the entire piece."@en ;
  dcterms:modified "2026-06-07T15:30:29.339724Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7648-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the opening is to engage the reader and introduce the setting and
  characters."""@en ;
  dcterms:modified "2026-06-07T15:30:29.339728Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7648-2
  a curric:KeyLearningPoint ;
  rdfs:label """When we plan, we log precise and ambitious vocabulary to help paint vivid pictures
  for our reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.339732Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7648-3
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials of time, place and manner are included in a plan to add extra
  detail about the action."""@en ;
  dcterms:modified "2026-06-07T15:30:29.339736Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7648-4
  a curric:KeyLearningPoint ;
  rdfs:label """Dialogue is the written conversation between two characters or more within a
  narrative and it moves the story forward."""@en ;
  dcterms:modified "2026-06-07T15:30:29.339740Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7648-5
  a curric:KeyLearningPoint ;
  rdfs:label """Figurative language is used in narrative writing to create vivid pictures for the
  reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.339744Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7647-1
  a curric:KeyLearningPoint ;
  rdfs:label """Expressing the thoughts and emotions of a character helps the reader understand the
  character more."""@en ;
  dcterms:modified "2026-06-07T15:30:29.339748Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7647-2
  a curric:KeyLearningPoint ;
  rdfs:label """Different character traits appear in the story and we use these to draw conclusions
  to infer a moral from the story."""@en ;
  dcterms:modified "2026-06-07T15:30:29.339752Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7647-3
  a curric:KeyLearningPoint ;
  rdfs:label """A moral is a lesson that can be learnt from a story; readers’ interpretations of a
  moral may differ."""@en ;
  dcterms:modified "2026-06-07T15:30:29.339756Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7647-4
  a curric:KeyLearningPoint ;
  rdfs:label "The characters’ emotions change throughout the narrative."@en ;
  dcterms:modified "2026-06-07T15:30:29.339760Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7647-5
  a curric:KeyLearningPoint ;
  rdfs:label """We can look at each character's speech and actions to understand their emotions
  fully."""@en ;
  dcterms:modified "2026-06-07T15:30:29.339764Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6694-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the climax is to describe the main action and take the suspense and
  excitement to its highest point."""@en ;
  dcterms:modified "2026-06-07T15:30:29.339768Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6694-2
  a curric:KeyLearningPoint ;
  rdfs:label """Precise and ambitious vocabulary create vivid images for the reader for each key
  moment of the climax."""@en ;
  dcterms:modified "2026-06-07T15:30:29.339772Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6694-3
  a curric:KeyLearningPoint ;
  rdfs:label "An effective plan has vocabulary organised concisely and neatly."@en ;
  dcterms:modified "2026-06-07T15:30:29.339776Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6694-4
  a curric:KeyLearningPoint ;
  rdfs:label """Careful verb and adverb selection can convey characters' feelings through ‘show and
  tell’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.339782Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6694-5
  a curric:KeyLearningPoint ;
  rdfs:label "The emotions of the character change through the key moments of the climax."@en ;
  dcterms:modified "2026-06-07T15:30:29.339786Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2746-1
  a curric:KeyLearningPoint ;
  rdfs:label "Parenthesis can be achieved with a range of punctuation."@en ;
  dcterms:modified "2026-06-07T15:30:29.339813Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2746-2
  a curric:KeyLearningPoint ;
  rdfs:label """Dashes are a punctuation mark used to add extra information in a clause often for
  dramatic effect."""@en ;
  dcterms:modified "2026-06-07T15:30:29.339817Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2746-3
  a curric:KeyLearningPoint ;
  rdfs:label "Dashes are often written in a pair."@en ;
  dcterms:modified "2026-06-07T15:30:29.339821Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2746-4
  a curric:KeyLearningPoint ;
  rdfs:label "Dashes can be removed from a clause and it will still make sense."@en ;
  dcterms:modified "2026-06-07T15:30:29.339825Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2746-5
  a curric:KeyLearningPoint ;
  rdfs:label """Dashes can be used purposefully in fiction texts to cause a dramatic effect for the
  reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.339829Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1359-1
  a curric:KeyLearningPoint ;
  rdfs:label """Some sounds can be represented by a number of different spellings e.g. the /ee/
  sound."""@en ;
  dcterms:modified "2026-06-07T15:30:29.339855Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1359-2
  a curric:KeyLearningPoint ;
  rdfs:label """The same spellings can represent more than one sound e.g. 'ie', 'ei', 'ough' and
  'ou'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.339861Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1359-3
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: shoulder and committee."@en ;
  dcterms:modified "2026-06-07T15:30:29.339865Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6194-1
  a curric:KeyLearningPoint ;
  rdfs:label """We have completed an essay that makes a persuasive argument for protecting the polar
  regions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.339978Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6194-2
  a curric:KeyLearningPoint ;
  rdfs:label "An essay has a formal tone."@en ;
  dcterms:modified "2026-06-07T15:30:29.339982Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6194-3
  a curric:KeyLearningPoint ;
  rdfs:label """We can use an essay as an inspiration for a speech, which will have a more emotive
  tone."""@en ;
  dcterms:modified "2026-06-07T15:30:29.339986Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6194-4
  a curric:KeyLearningPoint ;
  rdfs:label """When we make a speech, we should plan our ideas and speak clearly and at a good
  volume with positive body language."""@en ;
  dcterms:modified "2026-06-07T15:30:29.339990Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6194-5
  a curric:KeyLearningPoint ;
  rdfs:label """We should use our intonation and body language as well as our word choices to show
  our passion for the subject."""@en ;
  dcterms:modified "2026-06-07T15:30:29.339994Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8045-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘First Snow’ describes a changed landscape as a narrator explores their
  surroundings."""@en ;
  dcterms:modified "2026-06-07T15:30:29.340047Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8045-2
  a curric:KeyLearningPoint ;
  rdfs:label "Rhetorical questions are included in each verse."@en ;
  dcterms:modified "2026-06-07T15:30:29.340051Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8045-3
  a curric:KeyLearningPoint ;
  rdfs:label "'First Snow' uses the rhyme scheme: ABBA."@en ;
  dcterms:modified "2026-06-07T15:30:29.340055Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8045-4
  a curric:KeyLearningPoint ;
  rdfs:label """John Mole uses imagery to create a picture or impression of the scene in the reader
  or listener’s mind."""@en ;
  dcterms:modified "2026-06-07T15:30:29.340059Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7895-1
  a curric:KeyLearningPoint ;
  rdfs:label """Characterisation is the way text creators describe & develop the personalities and
  traits of the characters in a story."""@en ;
  dcterms:modified "2026-06-07T15:30:29.340122Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7895-2
  a curric:KeyLearningPoint ;
  rdfs:label """Many of the characters in ‘Oliver Twist’ are complex - they present as kind and
  helpful when their motives are not."""@en ;
  dcterms:modified "2026-06-07T15:30:29.340126Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7895-3
  a curric:KeyLearningPoint ;
  rdfs:label """Fagin compares Oliver & the Artful Dodger; they both share similar characteristics,
  but have different personalities."""@en ;
  dcterms:modified "2026-06-07T15:30:29.340130Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8091-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘No Country’ is a fictional graphic novel text written by Joe Brady and illustrated
  by Patrice Aggs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.340135Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8091-2
  a curric:KeyLearningPoint ;
  rdfs:label """The text focuses on the lives of one family as they try to navigate the challenges
  of a civil war."""@en ;
  dcterms:modified "2026-06-07T15:30:29.340139Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8091-3
  a curric:KeyLearningPoint ;
  rdfs:label """Graphic novels tell a complete story with illustrations in panels; gutters are the
  spaces between panels."""@en ;
  dcterms:modified "2026-06-07T15:30:29.340142Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8091-4
  a curric:KeyLearningPoint ;
  rdfs:label """Graphic novels include many features (including callouts) to inform the reader of
  what is happening."""@en ;
  dcterms:modified "2026-06-07T15:30:29.340146Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8091-5
  a curric:KeyLearningPoint ;
  rdfs:label """Readers sometimes have to infer what has happened, rather than being told by the
  author or illustrator."""@en ;
  dcterms:modified "2026-06-07T15:30:29.340150Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8040-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘Free verse’ refers to a type of poetry that doesn’t follow a specific rhyme scheme
  or structure."""@en ;
  dcterms:modified "2026-06-07T15:30:29.340170Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8040-2
  a curric:KeyLearningPoint ;
  rdfs:label """The themes and tone of a poem can be inferred from analysing the structure and
  language of the poem."""@en ;
  dcterms:modified "2026-06-07T15:30:29.340175Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8040-3
  a curric:KeyLearningPoint ;
  rdfs:label """Descriptive vocabulary using the five senses enables the poet to paint a vivid
  picture for the reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.340179Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8040-4
  a curric:KeyLearningPoint ;
  rdfs:label """Writing a free verse poem relies on the poet’s creativity rather than following
  rules of traditional poems."""@en ;
  dcterms:modified "2026-06-07T15:30:29.340183Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8040-5
  a curric:KeyLearningPoint ;
  rdfs:label """Both rhyme and rhythm contribute to the overall musical quality of a poem by
  emphasising certain words or emotions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.340187Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8108-1
  a curric:KeyLearningPoint ;
  rdfs:label """Oral presentation is an important part of selling a product and persuading an
  audience."""@en ;
  dcterms:modified "2026-06-07T15:30:29.340191Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8108-2
  a curric:KeyLearningPoint ;
  rdfs:label """Projection, pace and diction are important for ensuring the audience can hear and
  understand you."""@en ;
  dcterms:modified "2026-06-07T15:30:29.340195Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8108-3
  a curric:KeyLearningPoint ;
  rdfs:label """Eye contact, body languge and intonation are important for connecting to the
  audience and engaging them."""@en ;
  dcterms:modified "2026-06-07T15:30:29.340199Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8108-4
  a curric:KeyLearningPoint ;
  rdfs:label """Reading over our writing and rehearsing supports successful delivery of a
  presentation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.340203Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4813-1
  a curric:KeyLearningPoint ;
  rdfs:label """Two or more words that sound the same but have different meanings and spellings are
  called homophones."""@en ;
  dcterms:modified "2026-06-07T15:30:29.340207Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4813-2
  a curric:KeyLearningPoint ;
  rdfs:label "The words start with a lead in and finish with a lead out."@en ;
  dcterms:modified "2026-06-07T15:30:29.340211Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4813-3
  a curric:KeyLearningPoint ;
  rdfs:label "There are four cursive joins."@en ;
  dcterms:modified "2026-06-07T15:30:29.340215Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4813-4
  a curric:KeyLearningPoint ;
  rdfs:label """The join used depends on which letter is joining to which letter within a letter
  string."""@en ;
  dcterms:modified "2026-06-07T15:30:29.340219Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4813-5
  a curric:KeyLearningPoint ;
  rdfs:label "You don't lift your pencil to form the joins."@en ;
  dcterms:modified "2026-06-07T15:30:29.340223Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7345-1
  a curric:KeyLearningPoint ;
  rdfs:label "Charles Dickens lived during the Victorian era."@en ;
  dcterms:modified "2026-06-07T15:30:29.340460Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7345-2
  a curric:KeyLearningPoint ;
  rdfs:label """He was a very popular author who often represented the contrast between the rich and
  the poor."""@en ;
  dcterms:modified "2026-06-07T15:30:29.340464Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7345-3
  a curric:KeyLearningPoint ;
  rdfs:label "He wrote ‘A Christmas Carol’ in 1843."@en ;
  dcterms:modified "2026-06-07T15:30:29.340468Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7345-4
  a curric:KeyLearningPoint ;
  rdfs:label "It is set on the lively, bustling streets of Victorian London."@en ;
  dcterms:modified "2026-06-07T15:30:29.340474Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7345-5
  a curric:KeyLearningPoint ;
  rdfs:label """‘A Christmas Carol’ features a character called Scrooge. He is unkind and he doesn’t
  like Christmas."""@en ;
  dcterms:modified "2026-06-07T15:30:29.340479Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5473-1
  a curric:KeyLearningPoint ;
  rdfs:label """Characterisation is the way an author describes and develops the personalities and
  traits of the characters in a story."""@en ;
  dcterms:modified "2026-06-07T15:30:29.340483Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5473-2
  a curric:KeyLearningPoint ;
  rdfs:label """Authors use a range of methods for characterisation which the reader can
  analyse."""@en ;
  dcterms:modified "2026-06-07T15:30:29.340487Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5473-3
  a curric:KeyLearningPoint ;
  rdfs:label """In 'Hansel and Gretel', there is a clear conflict between good and evil
  characters."""@en ;
  dcterms:modified "2026-06-07T15:30:29.340490Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5473-4
  a curric:KeyLearningPoint ;
  rdfs:label """Anthony Browne uses illustrations to enhance his depiction of characters and convey
  hidden messages."""@en ;
  dcterms:modified "2026-06-07T15:30:29.340494Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7678-1
  a curric:KeyLearningPoint ;
  rdfs:label "Editing is the process of making changes to improve writing."@en ;
  dcterms:modified "2026-06-07T15:30:29.341583Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7678-2
  a curric:KeyLearningPoint ;
  rdfs:label """When editing punctuation, missing or incorrect punctuation, like capital letters,
  full stops and commas, is checked."""@en ;
  dcterms:modified "2026-06-07T15:30:29.341587Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7678-3
  a curric:KeyLearningPoint ;
  rdfs:label """When editing sentence structure, the flow of sentences and the variety of sentence
  types used are checked."""@en ;
  dcterms:modified "2026-06-07T15:30:29.341591Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7678-4
  a curric:KeyLearningPoint ;
  rdfs:label """When editing language, word and phrase choices are checked to ensure they meet the
  tone required."""@en ;
  dcterms:modified "2026-06-07T15:30:29.341595Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6730-1
  a curric:KeyLearningPoint ;
  rdfs:label """Writing is most successful when its structure, content and vocabulary are
  planned."""@en ;
  dcterms:modified "2026-06-07T15:30:29.341620Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6730-2
  a curric:KeyLearningPoint ;
  rdfs:label """It is also useful to orally rehearse storytelling the events we're going to
  write."""@en ;
  dcterms:modified "2026-06-07T15:30:29.341624Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6730-3
  a curric:KeyLearningPoint ;
  rdfs:label """We will need to include rich vocabulary to show the action in the battle between
  Beowulf and the dragon."""@en ;
  dcterms:modified "2026-06-07T15:30:29.341632Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6730-4
  a curric:KeyLearningPoint ;
  rdfs:label """We will also need rich vocabulary to show the emotions Beowulf and Wiglaf
  experience."""@en ;
  dcterms:modified "2026-06-07T15:30:29.341636Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1133-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Lumbering' is an adjective which means moving in a slow and heavy way."@en ;
  dcterms:modified "2026-06-07T15:30:29.341667Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1133-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Inept' is an adjective which means unskilled or incompetent."@en ;
  dcterms:modified "2026-06-07T15:30:29.341671Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1133-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Heavy-handed' is an adjective which means overly forceful."@en ;
  dcterms:modified "2026-06-07T15:30:29.341675Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8027-1
  a curric:KeyLearningPoint ;
  rdfs:label """Reader identity is the process of reflecting on what you enjoy or do not enjoy
  reading"""@en ;
  dcterms:modified "2026-06-07T15:30:29.341679Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8027-2
  a curric:KeyLearningPoint ;
  rdfs:label "Reading can take many forms; it does not have to be restricted to a book"@en ;
  dcterms:modified "2026-06-07T15:30:29.341683Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8027-3
  a curric:KeyLearningPoint ;
  rdfs:label "Reading is a skill that you use every single day"@en ;
  dcterms:modified "2026-06-07T15:30:29.341687Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8027-4
  a curric:KeyLearningPoint ;
  rdfs:label "A reading preference can include what we read and where we read."@en ;
  dcterms:modified "2026-06-07T15:30:29.341691Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6554-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the main body paragraph is to specifically detail key persuasive
  arguments."""@en ;
  dcterms:modified "2026-06-07T15:30:29.341711Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6554-2
  a curric:KeyLearningPoint ;
  rdfs:label "Information in the main body should be specific not vague."@en ;
  dcterms:modified "2026-06-07T15:30:29.341715Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6554-3
  a curric:KeyLearningPoint ;
  rdfs:label "Using a range of sentence types enhances text cohesion."@en ;
  dcterms:modified "2026-06-07T15:30:29.341718Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6554-4
  a curric:KeyLearningPoint ;
  rdfs:label """Points that are backed up by evidence, statistics or anecdotes are effective for
  persuading the recipient of a letter."""@en ;
  dcterms:modified "2026-06-07T15:30:29.341723Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6592-1
  a curric:KeyLearningPoint ;
  rdfs:label """In the sections, writers share detailed, specific information about an aspect of the
  person's life with the reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.341726Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6592-2
  a curric:KeyLearningPoint ;
  rdfs:label """Section paragraphs include a topic sentence, specific information and a linking
  sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.341730Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6592-3
  a curric:KeyLearningPoint ;
  rdfs:label "When planning, we should record ideas in concise, bullet-pointed notes."@en ;
  dcterms:modified "2026-06-07T15:30:29.341734Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6592-4
  a curric:KeyLearningPoint ;
  rdfs:label "When writing, we should use a plan and success criteria to guide us."@en ;
  dcterms:modified "2026-06-07T15:30:29.341740Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6592-5
  a curric:KeyLearningPoint ;
  rdfs:label """Text cohesion is achieved through use of subject-specific vocabulary, fronted
  adverbials and relative complex sentences."""@en ;
  dcterms:modified "2026-06-07T15:30:29.341745Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5766-1
  a curric:KeyLearningPoint ;
  rdfs:label "A diary entry is a type of recount written in the first person."@en ;
  dcterms:modified "2026-06-07T15:30:29.341860Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5766-2
  a curric:KeyLearningPoint ;
  rdfs:label "A diary entry is informal in its tone."@en ;
  dcterms:modified "2026-06-07T15:30:29.341864Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5766-3
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of a diary entry is to recount events and record thoughts and
  feelings."""@en ;
  dcterms:modified "2026-06-07T15:30:29.341868Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5766-4
  a curric:KeyLearningPoint ;
  rdfs:label "A diary entry can be sequenced in chronological order."@en ;
  dcterms:modified "2026-06-07T15:30:29.341872Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5766-5
  a curric:KeyLearningPoint ;
  rdfs:label "A diary entry may switch between past, present and future tenses."@en ;
  dcterms:modified "2026-06-07T15:30:29.341876Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5765-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the opening is to engage the reader and introduce characters and
  plot."""@en ;
  dcterms:modified "2026-06-07T15:30:29.341880Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5765-2
  a curric:KeyLearningPoint ;
  rdfs:label "Using a range of linguistic features helps achieve the text's purpose."@en ;
  dcterms:modified "2026-06-07T15:30:29.341884Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5765-3
  a curric:KeyLearningPoint ;
  rdfs:label """We have learned about three types of complex sentence: adverbial, relative and
  non-finite."""@en ;
  dcterms:modified "2026-06-07T15:30:29.341888Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5765-4
  a curric:KeyLearningPoint ;
  rdfs:label """Using a range of sentence types in narrative writing enhances text cohesion and
  keeps the reader engaged."""@en ;
  dcterms:modified "2026-06-07T15:30:29.341892Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5765-5
  a curric:KeyLearningPoint ;
  rdfs:label """Powerful, precise vocabulary choices engage the reader and help create
  atmosphere."""@en ;
  dcterms:modified "2026-06-07T15:30:29.341895Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4706-1
  a curric:KeyLearningPoint ;
  rdfs:label "A debate usually has a winning team."@en ;
  dcterms:modified "2026-06-07T15:30:29.341899Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4706-2
  a curric:KeyLearningPoint ;
  rdfs:label """The winning team in a debate can be decided by an audience vote, or a judge, or a
  panel of judges."""@en ;
  dcterms:modified "2026-06-07T15:30:29.341903Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4706-3
  a curric:KeyLearningPoint ;
  rdfs:label """The judges award a score out of ten in four different areas: content, style,
  delivery and points of information."""@en ;
  dcterms:modified "2026-06-07T15:30:29.341909Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1437-1
  a curric:KeyLearningPoint ;
  rdfs:label "-y is a suffix that can be used to change some nouns into adjectives."@en ;
  dcterms:modified "2026-06-07T15:30:29.341927Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1437-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Big letters' is a useful practice strategy."@en ;
  dcterms:modified "2026-06-07T15:30:29.341931Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1437-3
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum word: heart."@en ;
  dcterms:modified "2026-06-07T15:30:29.341939Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1437-4
  a curric:KeyLearningPoint ;
  rdfs:label "For root words ending in 'e', you remove the 'e' and just add -y."@en ;
  dcterms:modified "2026-06-07T15:30:29.341944Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1437-5
  a curric:KeyLearningPoint ;
  rdfs:label "For root words with a short vowel sound, you double the consonant and add -y."@en ;
  dcterms:modified "2026-06-07T15:30:29.341948Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1442-1
  a curric:KeyLearningPoint ;
  rdfs:label "-er and -est are suffixes that can be used to change the meaning of a root word."@en ;
  dcterms:modified "2026-06-07T15:30:29.341952Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1442-2
  a curric:KeyLearningPoint ;
  rdfs:label "For some root words you can add the suffix -er."@en ;
  dcterms:modified "2026-06-07T15:30:29.341956Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1442-3
  a curric:KeyLearningPoint ;
  rdfs:label "For some root words you can add the suffix -est."@en ;
  dcterms:modified "2026-06-07T15:30:29.341960Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1442-4
  a curric:KeyLearningPoint ;
  rdfs:label "For root words ending in 'e' you remove the 'e' and add the suffix -er or -est."@en ;
  dcterms:modified "2026-06-07T15:30:29.341964Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1442-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum word: minute."@en ;
  dcterms:modified "2026-06-07T15:30:29.341967Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8022-1
  a curric:KeyLearningPoint ;
  rdfs:label "A synonym is a word that has the same or similar meaning to another word."@en ;
  dcterms:modified "2026-06-07T15:30:29.341984Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8022-2
  a curric:KeyLearningPoint ;
  rdfs:label "Synonyms for ‘big’ include: huge, colossal and gargantuan."@en ;
  dcterms:modified "2026-06-07T15:30:29.341988Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8022-3
  a curric:KeyLearningPoint ;
  rdfs:label "The subject of a poem is what the poem is about."@en ;
  dcterms:modified "2026-06-07T15:30:29.341991Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8022-4
  a curric:KeyLearningPoint ;
  rdfs:label "Poems can provoke emotions and engage our senses."@en ;
  dcterms:modified "2026-06-07T15:30:29.341995Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28411-1
  a curric:KeyLearningPoint ;
  rdfs:label """Play scripts are written with certain conventions that help make a script organised,
  clear and easy to follow."""@en ;
  dcterms:modified "2026-06-07T15:30:29.341999Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28411-2
  a curric:KeyLearningPoint ;
  rdfs:label "Performance techniques are tools that actors use to connect with the audience."@en ;
  dcterms:modified "2026-06-07T15:30:29.342005Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28411-3
  a curric:KeyLearningPoint ;
  rdfs:label "These techniques can be learnt, practised and developed."@en ;
  dcterms:modified "2026-06-07T15:30:29.342010Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28411-4
  a curric:KeyLearningPoint ;
  rdfs:label """Deciding where to stand and how to move is an important part of the rehearsal
  process for the director and actors."""@en ;
  dcterms:modified "2026-06-07T15:30:29.342014Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28411-5
  a curric:KeyLearningPoint ;
  rdfs:label """Plays can have large or small casts - the number of actors who play the different
  characters in a play."""@en ;
  dcterms:modified "2026-06-07T15:30:29.342018Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5490-1
  a curric:KeyLearningPoint ;
  rdfs:label "There are four types of noun: common, proper, collective and abstract."@en ;
  dcterms:modified "2026-06-07T15:30:29.342038Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5490-2
  a curric:KeyLearningPoint ;
  rdfs:label "Nouns, verbs, adjectives and adverbs build clauses."@en ;
  dcterms:modified "2026-06-07T15:30:29.342042Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5490-3
  a curric:KeyLearningPoint ;
  rdfs:label "Determiners introduce nouns."@en ;
  dcterms:modified "2026-06-07T15:30:29.342048Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5490-4
  a curric:KeyLearningPoint ;
  rdfs:label "Modal verbs are a type of auxiliary verb."@en ;
  dcterms:modified "2026-06-07T15:30:29.342052Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5846-1
  a curric:KeyLearningPoint ;
  rdfs:label """A protagonist is the leading character or one of the major characters in a
  narrative."""@en ;
  dcterms:modified "2026-06-07T15:30:29.342074Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5846-2
  a curric:KeyLearningPoint ;
  rdfs:label "Macbeth is the protagonist of Shakespeare's ’Macbeth’."@en ;
  dcterms:modified "2026-06-07T15:30:29.342079Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5846-3
  a curric:KeyLearningPoint ;
  rdfs:label "Inner conflict is a key theme in many of Shakespeare's plays."@en ;
  dcterms:modified "2026-06-07T15:30:29.342084Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5846-4
  a curric:KeyLearningPoint ;
  rdfs:label """We can make inferences about characters' feelings and personalities based on their
  actions, expressions and words."""@en ;
  dcterms:modified "2026-06-07T15:30:29.342089Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5846-5
  a curric:KeyLearningPoint ;
  rdfs:label "Macbeth is a highly conflicted character."@en ;
  dcterms:modified "2026-06-07T15:30:29.342093Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5844-1
  a curric:KeyLearningPoint ;
  rdfs:label "Writing is most successful when it is planned."@en ;
  dcterms:modified "2026-06-07T15:30:29.342108Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5844-2
  a curric:KeyLearningPoint ;
  rdfs:label """A narrative opening should engage the reader and describe the setting and any
  characters who are present."""@en ;
  dcterms:modified "2026-06-07T15:30:29.342112Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5844-3
  a curric:KeyLearningPoint ;
  rdfs:label "This narrative opening will be written in the third person."@en ;
  dcterms:modified "2026-06-07T15:30:29.342116Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5844-4
  a curric:KeyLearningPoint ;
  rdfs:label "Dialogue can be used to convey character and advance the action."@en ;
  dcterms:modified "2026-06-07T15:30:29.342120Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5844-5
  a curric:KeyLearningPoint ;
  rdfs:label """Variation in vocabulary and sentence structure engages the reader and improves text
  cohesion."""@en ;
  dcterms:modified "2026-06-07T15:30:29.342124Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2697-1
  a curric:KeyLearningPoint ;
  rdfs:label "A sentence composed of one main clause is a simple sentence."@en ;
  dcterms:modified "2026-06-07T15:30:29.342129Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2697-2
  a curric:KeyLearningPoint ;
  rdfs:label """There are four types of simple sentence: statement, question, command and
  exclamation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.342134Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2697-3
  a curric:KeyLearningPoint ;
  rdfs:label """A sentence composed of at least two main clauses joined by a co-ordinating
  conjunction is a compound sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.342138Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2697-4
  a curric:KeyLearningPoint ;
  rdfs:label """A sentence composed of at least one main clause and an adverbial subordinate clause
  is an adverbial complex sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.342142Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1364-1
  a curric:KeyLearningPoint ;
  rdfs:label "Adding -s or -es to a noun creates a plural."@en ;
  dcterms:modified "2026-06-07T15:30:29.342212Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1364-2
  a curric:KeyLearningPoint ;
  rdfs:label "If the word ends in a vowel (a, e, i, u) or consonant, just add -s."@en ;
  dcterms:modified "2026-06-07T15:30:29.342217Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1364-3
  a curric:KeyLearningPoint ;
  rdfs:label "If the word ends in 'y' preceded by a vowel, just add -s."@en ;
  dcterms:modified "2026-06-07T15:30:29.342221Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1364-4
  a curric:KeyLearningPoint ;
  rdfs:label "If the word ends in 'y' preceded by a consonant, remove the 'y' and add -ies."@en ;
  dcterms:modified "2026-06-07T15:30:29.342225Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1364-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: group, earth and yacht."@en ;
  dcterms:modified "2026-06-07T15:30:29.342229Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7903-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘Blackberry Blue’ is a collection of six fairy tales, with characters from various
  backgrounds and cultures."""@en ;
  dcterms:modified "2026-06-07T15:30:29.342843Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7903-2
  a curric:KeyLearningPoint ;
  rdfs:label """Each tale contains magical elements and fantastical occurrences, which is a key
  feature of the genre."""@en ;
  dcterms:modified "2026-06-07T15:30:29.342847Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7903-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Blackberry Blue' leans on traditional fairy tales for inspiration."@en ;
  dcterms:modified "2026-06-07T15:30:29.342851Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7903-4
  a curric:KeyLearningPoint ;
  rdfs:label "The theme of good and evil is explored in 'Blackberry Blue'."@en ;
  dcterms:modified "2026-06-07T15:30:29.342855Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7903-5
  a curric:KeyLearningPoint ;
  rdfs:label """'Blackberry Blue' begins with a prologue: a paragraph that sets the stage for the
  fairy tale that is about to follow."""@en ;
  dcterms:modified "2026-06-07T15:30:29.342859Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5851-1
  a curric:KeyLearningPoint ;
  rdfs:label """Macbeth is a highly conflicted character whose confusion can be shown through the
  use of rhetorical questions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.342863Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5851-2
  a curric:KeyLearningPoint ;
  rdfs:label "A soliloquy is written from the first person perspective."@en ;
  dcterms:modified "2026-06-07T15:30:29.342867Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5851-3
  a curric:KeyLearningPoint ;
  rdfs:label "Soliloquies can feature figurative language."@en ;
  dcterms:modified "2026-06-07T15:30:29.342871Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5851-4
  a curric:KeyLearningPoint ;
  rdfs:label "Writers can use non-finite clauses to create text flow in their writing."@en ;
  dcterms:modified "2026-06-07T15:30:29.342875Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5851-5
  a curric:KeyLearningPoint ;
  rdfs:label """This section of the soliloquy is when Macbeth sees a dagger, which he sees as
  another sign to kill King Duncan."""@en ;
  dcterms:modified "2026-06-07T15:30:29.342879Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5463-1
  a curric:KeyLearningPoint ;
  rdfs:label """'The Pebble in my Pocket' is a narrative non-fiction text that teaches us about the
  history of our world."""@en ;
  dcterms:modified "2026-06-07T15:30:29.342929Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5463-2
  a curric:KeyLearningPoint ;
  rdfs:label """The pebble is 480 million years old and has existed in many forms, landscapes and
  climates."""@en ;
  dcterms:modified "2026-06-07T15:30:29.342935Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5463-3
  a curric:KeyLearningPoint ;
  rdfs:label """The author, Meredith Hooper, conveys a deeper meaning behind the pebble's journey
  through her writing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.342940Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5463-4
  a curric:KeyLearningPoint ;
  rdfs:label """Everything that exists has a story to tell and helps us to build our understanding
  of the world."""@en ;
  dcterms:modified "2026-06-07T15:30:29.342944Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5658-1
  a curric:KeyLearningPoint ;
  rdfs:label """The Curiosity rover’s landing was very complex; there were lots of stages
  involved."""@en ;
  dcterms:modified "2026-06-07T15:30:29.344736Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5658-2
  a curric:KeyLearningPoint ;
  rdfs:label "Once it had landed safely, Curiosity set off to explore the surface."@en ;
  dcterms:modified "2026-06-07T15:30:29.344740Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5658-3
  a curric:KeyLearningPoint ;
  rdfs:label """A range of equipment and technology allow the Curiosity to conduct experiments on
  the surface of the planet."""@en ;
  dcterms:modified "2026-06-07T15:30:29.344746Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8029-1
  a curric:KeyLearningPoint ;
  rdfs:label """Making a text recommendation includes a personal reason for why the text was
  relevant to you"""@en ;
  dcterms:modified "2026-06-07T15:30:29.344750Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8029-2
  a curric:KeyLearningPoint ;
  rdfs:label """Making a text recommendation includes a reason that someone else might enjoy the
  text"""@en ;
  dcterms:modified "2026-06-07T15:30:29.344756Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8029-3
  a curric:KeyLearningPoint ;
  rdfs:label "There are a variety of ways we can share our reading preferences with others"@en ;
  dcterms:modified "2026-06-07T15:30:29.344761Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8029-4
  a curric:KeyLearningPoint ;
  rdfs:label """Curating a space at home or at school to share your reading preferences can support
  others in reading for pleasure"""@en ;
  dcterms:modified "2026-06-07T15:30:29.344764Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1075-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Livid' is an adjective which means extremely angry or furious."@en ;
  dcterms:modified "2026-06-07T15:30:29.344803Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1075-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Spiteful' is an adjective which means hateful or mean."@en ;
  dcterms:modified "2026-06-07T15:30:29.344807Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1075-3
  a curric:KeyLearningPoint ;
  rdfs:label """A 'grudge' is an adjective which means hatred; when you stay angry with someone and
  refuse to forgive them."""@en ;
  dcterms:modified "2026-06-07T15:30:29.344811Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1075-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Furious', 'irritated' and 'raging' are other rich vocabulary associated
  with anger."""@en ;
  dcterms:modified "2026-06-07T15:30:29.344815Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5842-1
  a curric:KeyLearningPoint ;
  rdfs:label "Writing is most successful when structure, content and vocabulary is planned."@en ;
  dcterms:modified "2026-06-07T15:30:29.344859Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5842-2
  a curric:KeyLearningPoint ;
  rdfs:label """A narrative opening should engage the reader and describe the setting and any
  characters who are present."""@en ;
  dcterms:modified "2026-06-07T15:30:29.344863Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5842-3
  a curric:KeyLearningPoint ;
  rdfs:label "Using a wide range of precise, ambitious vocabulary enhances text cohesion."@en ;
  dcterms:modified "2026-06-07T15:30:29.344869Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5842-4
  a curric:KeyLearningPoint ;
  rdfs:label "The senses can be appealed to when generating ambitious descriptive vocabulary."@en ;
  dcterms:modified "2026-06-07T15:30:29.344875Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5842-5
  a curric:KeyLearningPoint ;
  rdfs:label "Structuring sentences in a range of ways enhances text cohesion."@en ;
  dcterms:modified "2026-06-07T15:30:29.344879Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6718-1
  a curric:KeyLearningPoint ;
  rdfs:label """Charles Darwin was a British naturalist known for his contributions to the theory of
  evolution."""@en ;
  dcterms:modified "2026-06-07T15:30:29.345948Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6718-2
  a curric:KeyLearningPoint ;
  rdfs:label """A biography is a non-fiction text so we must do research to gather factual
  information."""@en ;
  dcterms:modified "2026-06-07T15:30:29.345952Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6718-3
  a curric:KeyLearningPoint ;
  rdfs:label """A text map can be used to help us learn and remember the key events of someone's
  life."""@en ;
  dcterms:modified "2026-06-07T15:30:29.345956Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6718-4
  a curric:KeyLearningPoint ;
  rdfs:label """In the text map, pictures represent key events (and a few words and numbers can be
  used too)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.345960Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6718-5
  a curric:KeyLearningPoint ;
  rdfs:label "The more we rehearse a text map out loud, the better we will remember it."@en ;
  dcterms:modified "2026-06-07T15:30:29.345964Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7941-1
  a curric:KeyLearningPoint ;
  rdfs:label "Reading can take many forms; all are equally as valid as each other."@en ;
  dcterms:modified "2026-06-07T15:30:29.346011Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7941-2
  a curric:KeyLearningPoint ;
  rdfs:label "Narrative fiction can cover a range of genres, content, settings and styles."@en ;
  dcterms:modified "2026-06-07T15:30:29.346015Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7941-3
  a curric:KeyLearningPoint ;
  rdfs:label """A graphic novel is a type of text combining words and images in long-form,
  sequential art panels."""@en ;
  dcterms:modified "2026-06-07T15:30:29.346019Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5852-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of an editing lesson is to improve writing and make necessary
  corrections."""@en ;
  dcterms:modified "2026-06-07T15:30:29.346023Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5852-2
  a curric:KeyLearningPoint ;
  rdfs:label """Vocabulary, grammar and punctuation can be changed to make writing more
  effective."""@en ;
  dcterms:modified "2026-06-07T15:30:29.346027Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5852-3
  a curric:KeyLearningPoint ;
  rdfs:label """We also edit to ensure tense is consistent and the appropriate atmosphere is
  achieved."""@en ;
  dcterms:modified "2026-06-07T15:30:29.346031Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6343-1
  a curric:KeyLearningPoint ;
  rdfs:label "Writing is most successful when it is planned."@en ;
  dcterms:modified "2026-06-07T15:30:29.346035Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6343-2
  a curric:KeyLearningPoint ;
  rdfs:label """Setting descriptions can start from a bird's eye view and zoom in to a city's
  streets."""@en ;
  dcterms:modified "2026-06-07T15:30:29.346039Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6343-3
  a curric:KeyLearningPoint ;
  rdfs:label """We use adjectives and rich vocabulary and we explore the five senses to set a
  particular mood when describing a setting."""@en ;
  dcterms:modified "2026-06-07T15:30:29.346043Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6343-4
  a curric:KeyLearningPoint ;
  rdfs:label "Fronted adverbials of place and preposition phrases place items in a setting."@en ;
  dcterms:modified "2026-06-07T15:30:29.346047Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6343-5
  a curric:KeyLearningPoint ;
  rdfs:label "We can write a setting description in the third person and the present tense."@en ;
  dcterms:modified "2026-06-07T15:30:29.346051Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8465-1
  a curric:KeyLearningPoint ;
  rdfs:label "We use notes from our plan to form a range of full sentences."@en ;
  dcterms:modified "2026-06-07T15:30:29.346079Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8465-2
  a curric:KeyLearningPoint ;
  rdfs:label "Fronted adverbials of time communicate the chronology of events in a recount."@en ;
  dcterms:modified "2026-06-07T15:30:29.346083Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8465-3
  a curric:KeyLearningPoint ;
  rdfs:label "Conjunctions are used to create a range of sentence types."@en ;
  dcterms:modified "2026-06-07T15:30:29.346087Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8465-4
  a curric:KeyLearningPoint ;
  rdfs:label "Hyperbole is used to exaggerate emotions in a diary entry."@en ;
  dcterms:modified "2026-06-07T15:30:29.346091Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8465-5
  a curric:KeyLearningPoint ;
  rdfs:label """The use of progressive past and simple past tenses is an effective way to recount
  experiences and feelings."""@en ;
  dcterms:modified "2026-06-07T15:30:29.346095Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1087-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Ambush' is a verb which means to make a surprise attack."@en ;
  dcterms:modified "2026-06-07T15:30:29.346115Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1087-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Feud' is a noun which means a disagreement or argument that is never settled."@en ;
  dcterms:modified "2026-06-07T15:30:29.346119Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1087-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Bombard', 'bicker', 'conquer' are other verbs related to fight or battle."@en ;
  dcterms:modified "2026-06-07T15:30:29.346123Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1087-4
  a curric:KeyLearningPoint ;
  rdfs:label "'Siege' is a noun which means a blockade or assault."@en ;
  dcterms:modified "2026-06-07T15:30:29.346127Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4829-1
  a curric:KeyLearningPoint ;
  rdfs:label """Information in a non-chronological report is organised using a title, subheadings
  and paragraphs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.346174Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4829-2
  a curric:KeyLearningPoint ;
  rdfs:label "The subheadings start with a capital letter and are underlined."@en ;
  dcterms:modified "2026-06-07T15:30:29.346178Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4829-3
  a curric:KeyLearningPoint ;
  rdfs:label "The capital letter does not join to the next letter in the letter string."@en ;
  dcterms:modified "2026-06-07T15:30:29.346182Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4829-4
  a curric:KeyLearningPoint ;
  rdfs:label "The joins used depend on which letter is joining to which letter."@en ;
  dcterms:modified "2026-06-07T15:30:29.346185Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4829-5
  a curric:KeyLearningPoint ;
  rdfs:label """The letter formation and letter spacing is accurate to ensure the writing is
  legible."""@en ;
  dcterms:modified "2026-06-07T15:30:29.346189Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2734-1
  a curric:KeyLearningPoint ;
  rdfs:label "The non-finite clause is a type of subordinate clause."@en ;
  dcterms:modified "2026-06-07T15:30:29.346193Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2734-2
  a curric:KeyLearningPoint ;
  rdfs:label "A non-finite clause must join to a main clause to make sense."@en ;
  dcterms:modified "2026-06-07T15:30:29.346197Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2734-3
  a curric:KeyLearningPoint ;
  rdfs:label """The non-finite clause denotes ongoing action that relates to the subject of the main
  clause."""@en ;
  dcterms:modified "2026-06-07T15:30:29.346201Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2734-4
  a curric:KeyLearningPoint ;
  rdfs:label """The action of the non-finite clause occurs simultaneously to the action of the main
  clause."""@en ;
  dcterms:modified "2026-06-07T15:30:29.346205Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2734-5
  a curric:KeyLearningPoint ;
  rdfs:label """A non-finite clause joined with a main clause forms the non-finite complex
  sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.346209Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4800-1
  a curric:KeyLearningPoint ;
  rdfs:label "Cursive handwriting involves joining letters together."@en ;
  dcterms:modified "2026-06-07T15:30:29.346235Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4800-2
  a curric:KeyLearningPoint ;
  rdfs:label "The letters all have a lead in starting at the baseline."@en ;
  dcterms:modified "2026-06-07T15:30:29.346238Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4800-3
  a curric:KeyLearningPoint ;
  rdfs:label "The first join goes from the baseline to the x-height line."@en ;
  dcterms:modified "2026-06-07T15:30:29.346242Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4800-4
  a curric:KeyLearningPoint ;
  rdfs:label "The pencil does not lift when forming the join."@en ;
  dcterms:modified "2026-06-07T15:30:29.346246Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4800-5
  a curric:KeyLearningPoint ;
  rdfs:label "The letter w lead out \"finishes with a small dip down\" to aid joining."@en ;
  dcterms:modified "2026-06-07T15:30:29.346250Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27894-1
  a curric:KeyLearningPoint ;
  rdfs:label "A debate often involves speakers disagreeing with each other."@en ;
  dcterms:modified "2026-06-07T15:30:29.346254Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27894-2
  a curric:KeyLearningPoint ;
  rdfs:label "The motion is the name for the belief or proposal that is being debated."@en ;
  dcterms:modified "2026-06-07T15:30:29.346258Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27894-3
  a curric:KeyLearningPoint ;
  rdfs:label "The PEPS structure stands for: point, explanation, proof, summary."@en ;
  dcterms:modified "2026-06-07T15:30:29.346262Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27894-4
  a curric:KeyLearningPoint ;
  rdfs:label "In a debate, a speaker will make a point and then explain it."@en ;
  dcterms:modified "2026-06-07T15:30:29.346266Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27894-5
  a curric:KeyLearningPoint ;
  rdfs:label "Adding proof gives credibility to an argument."@en ;
  dcterms:modified "2026-06-07T15:30:29.346270Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3467-1
  a curric:KeyLearningPoint ;
  rdfs:label "An explanation text needs a title to signify what the text is about."@en ;
  dcterms:modified "2026-06-07T15:30:29.346352Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3467-2
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of an introduction is to hook the reader in and inform the reader what
  the rest of the text will be about."""@en ;
  dcterms:modified "2026-06-07T15:30:29.346356Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3467-3
  a curric:KeyLearningPoint ;
  rdfs:label """The introduction contains general facts, an outline of what the text will cover and
  a direct appeal to the reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.346360Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3467-4
  a curric:KeyLearningPoint ;
  rdfs:label """Facts and information in the introduction are general; they become more specific and
  detailed in later paragraphs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.346363Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27778-1
  a curric:KeyLearningPoint ;
  rdfs:label """A speech is the communication of someone’s thoughts, through words, to an
  audience."""@en ;
  dcterms:modified "2026-06-07T15:30:29.346370Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27778-2
  a curric:KeyLearningPoint ;
  rdfs:label "The purpose of a speech is always to impact the audience in some way."@en ;
  dcterms:modified "2026-06-07T15:30:29.346374Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27778-3
  a curric:KeyLearningPoint ;
  rdfs:label """A common purpose of a speech is to persuade the audience to agree with the speaker
  about something."""@en ;
  dcterms:modified "2026-06-07T15:30:29.346378Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27778-4
  a curric:KeyLearningPoint ;
  rdfs:label "Points are used to justify the speaker’s opinion in a speech."@en ;
  dcterms:modified "2026-06-07T15:30:29.346384Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6106-1
  a curric:KeyLearningPoint ;
  rdfs:label "Editing is a critical part of the writing process."@en ;
  dcterms:modified "2026-06-07T15:30:29.346400Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6106-2
  a curric:KeyLearningPoint ;
  rdfs:label """Writing is most successful when editing is used to rethink, rephrase and reconsider
  first ideas."""@en ;
  dcterms:modified "2026-06-07T15:30:29.346404Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6106-3
  a curric:KeyLearningPoint ;
  rdfs:label "Editing can be done by oneself, with a peer or with a teacher."@en ;
  dcterms:modified "2026-06-07T15:30:29.346408Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6106-4
  a curric:KeyLearningPoint ;
  rdfs:label """Editing is most successful when it is chunked by punctuation, sentence structure,
  cohesion and vocabulary."""@en ;
  dcterms:modified "2026-06-07T15:30:29.346412Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6106-5
  a curric:KeyLearningPoint ;
  rdfs:label "A growth mindset helps us benefit most from editing."@en ;
  dcterms:modified "2026-06-07T15:30:29.346416Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1101-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Dilapidated' is an adjective which means run-down or shabby."@en ;
  dcterms:modified "2026-06-07T15:30:29.346452Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1101-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Palatial' is an adjective which means vast or splendid."@en ;
  dcterms:modified "2026-06-07T15:30:29.346456Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1101-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Immaculate' is an adjective which means perfect or spotless."@en ;
  dcterms:modified "2026-06-07T15:30:29.346462Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1101-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Cluttered', 'poky' and 'sparse' are other rich vocabulary associated with a
  house."""@en ;
  dcterms:modified "2026-06-07T15:30:29.346502Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6354-1
  a curric:KeyLearningPoint ;
  rdfs:label "Editing is a critical part of the writing process."@en ;
  dcterms:modified "2026-06-07T15:30:29.346566Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6354-2
  a curric:KeyLearningPoint ;
  rdfs:label """Writing is most successful when editing is used to rethink, rephrase and reconsider
  first ideas."""@en ;
  dcterms:modified "2026-06-07T15:30:29.346570Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6354-3
  a curric:KeyLearningPoint ;
  rdfs:label "Editing can be done by oneself, with a peer or with a teacher."@en ;
  dcterms:modified "2026-06-07T15:30:29.346576Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6354-4
  a curric:KeyLearningPoint ;
  rdfs:label """Editing is most successful when it is chunked by punctuation, sentence structure,
  vocabulary and cohesive devices."""@en ;
  dcterms:modified "2026-06-07T15:30:29.346580Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6354-5
  a curric:KeyLearningPoint ;
  rdfs:label "A growth mindset helps us benefit most from editing."@en ;
  dcterms:modified "2026-06-07T15:30:29.346584Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2701-1
  a curric:KeyLearningPoint ;
  rdfs:label """The relative clause is a type of subordinate clause, which must join to a main
  clause to make complete sense."""@en ;
  dcterms:modified "2026-06-07T15:30:29.346588Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2701-2
  a curric:KeyLearningPoint ;
  rdfs:label """The relative clause adds extra, relevant information about a noun or noun phrase
  within a main clause."""@en ;
  dcterms:modified "2026-06-07T15:30:29.346592Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2701-3
  a curric:KeyLearningPoint ;
  rdfs:label "A relative clause often interrupts the main clause."@en ;
  dcterms:modified "2026-06-07T15:30:29.346598Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2701-4
  a curric:KeyLearningPoint ;
  rdfs:label "A relative clause joined with a main clause forms the relative complex sentence."@en ;
  dcterms:modified "2026-06-07T15:30:29.346602Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2696-1
  a curric:KeyLearningPoint ;
  rdfs:label "Any clause is a group of words that contains a verb."@en ;
  dcterms:modified "2026-06-07T15:30:29.346622Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2696-2
  a curric:KeyLearningPoint ;
  rdfs:label "A main clause is a group of words that contains a verb and makes complete sense."@en ;
  dcterms:modified "2026-06-07T15:30:29.346626Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2696-3
  a curric:KeyLearningPoint ;
  rdfs:label """A subordinate clause is a group of words that contains a verb that does not make
  complete sense."""@en ;
  dcterms:modified "2026-06-07T15:30:29.346630Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2696-4
  a curric:KeyLearningPoint ;
  rdfs:label "A subordinate clause must be joined to a main clause to make a complex sentence."@en ;
  dcterms:modified "2026-06-07T15:30:29.346634Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2696-5
  a curric:KeyLearningPoint ;
  rdfs:label """One type of subordinate clause is an adverbial clause, which starts with a
  subordinating conjunction."""@en ;
  dcterms:modified "2026-06-07T15:30:29.346638Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1041-1
  a curric:KeyLearningPoint ;
  rdfs:label """A word that joins a second idea to a main clause in an adverbial complex sentence is
  called a subordinating conjunction."""@en ;
  dcterms:modified "2026-06-07T15:30:29.346675Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1041-2
  a curric:KeyLearningPoint ;
  rdfs:label "A subordinating conjunction is the word that starts an adverbial clause."@en ;
  dcterms:modified "2026-06-07T15:30:29.346679Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1041-3
  a curric:KeyLearningPoint ;
  rdfs:label """A subordinate clause is a group of words that contains a verb and does not make
  complete sense."""@en ;
  dcterms:modified "2026-06-07T15:30:29.346683Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1041-4
  a curric:KeyLearningPoint ;
  rdfs:label "An adverbial clause is a type of subordinate clause."@en ;
  dcterms:modified "2026-06-07T15:30:29.346687Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1041-5
  a curric:KeyLearningPoint ;
  rdfs:label "A main clause joined with any subordinate clause forms a complex sentence."@en ;
  dcterms:modified "2026-06-07T15:30:29.346691Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1049-1
  a curric:KeyLearningPoint ;
  rdfs:label """The simple tense is a tense that does not make use of an auxiliary verb with the
  main verb in the present and past."""@en ;
  dcterms:modified "2026-06-07T15:30:29.346695Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1049-2
  a curric:KeyLearningPoint ;
  rdfs:label """The progressive tense is a tense that makes use of an auxiliary verb from the
  infinitive 'to be' with the main verb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.346699Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1049-3
  a curric:KeyLearningPoint ;
  rdfs:label """The perfect tense is a tense that makes use of an auxiliary verb from the infinitive
  'to have' with the main verb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.346702Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1049-4
  a curric:KeyLearningPoint ;
  rdfs:label """The auxiliary verb is followed by the past tense form of the main verb in the
  perfect tense."""@en ;
  dcterms:modified "2026-06-07T15:30:29.346706Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1049-5
  a curric:KeyLearningPoint ;
  rdfs:label "The past tense form of the verb frequently expresses completed action."@en ;
  dcterms:modified "2026-06-07T15:30:29.346710Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2704-1
  a curric:KeyLearningPoint ;
  rdfs:label "The verb carries the tense of a sentence."@en ;
  dcterms:modified "2026-06-07T15:30:29.346714Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2704-2
  a curric:KeyLearningPoint ;
  rdfs:label "The progressive tense can denote present, past or future action."@en ;
  dcterms:modified "2026-06-07T15:30:29.346718Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2704-3
  a curric:KeyLearningPoint ;
  rdfs:label """The progressive tense is a tense that makes use of an auxiliary verb based on 'to
  be' with a main verb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.346724Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2704-4
  a curric:KeyLearningPoint ;
  rdfs:label "The progressive tense denotes ongoing action."@en ;
  dcterms:modified "2026-06-07T15:30:29.346732Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2704-5
  a curric:KeyLearningPoint ;
  rdfs:label "The main verb in the progressive tense always ends with the -ing suffix."@en ;
  dcterms:modified "2026-06-07T15:30:29.346736Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4892-1
  a curric:KeyLearningPoint ;
  rdfs:label """The introduction provides general information and outlines the structure of the full
  report."""@en ;
  dcterms:modified "2026-06-07T15:30:29.346740Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4892-2
  a curric:KeyLearningPoint ;
  rdfs:label "Parenthesis (additional information) can be conveyed using brackets."@en ;
  dcterms:modified "2026-06-07T15:30:29.346744Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4892-3
  a curric:KeyLearningPoint ;
  rdfs:label "Linking sentences at the end of paragraphs help create text cohesion."@en ;
  dcterms:modified "2026-06-07T15:30:29.346751Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4892-4
  a curric:KeyLearningPoint ;
  rdfs:label "Using passive verbs changes the way information is presented in a sentence."@en ;
  dcterms:modified "2026-06-07T15:30:29.346755Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2727-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the climax is to describe the main action and to take the tension and
  excitement to its highest point."""@en ;
  dcterms:modified "2026-06-07T15:30:29.346759Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2727-2
  a curric:KeyLearningPoint ;
  rdfs:label """When we plan, we log precise and ambitious vocabulary to help paint vivid pictures
  for our reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.346763Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2727-3
  a curric:KeyLearningPoint ;
  rdfs:label "An effective plan's vocabulary is organised neatly and concisely in note form."@en ;
  dcterms:modified "2026-06-07T15:30:29.346771Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2727-4
  a curric:KeyLearningPoint ;
  rdfs:label """Dialogue is the written conversation between two or more characters within a
  narrative and it moves the story forward."""@en ;
  dcterms:modified "2026-06-07T15:30:29.346775Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2727-5
  a curric:KeyLearningPoint ;
  rdfs:label """Show-not-tell language is a writing technique for showing a character’s feelings to
  a reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.346781Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1302-1
  a curric:KeyLearningPoint ;
  rdfs:label """Adding the suffix -ed turns the verb into the past tense and the -ed can sound like
  /id/, /d/ or /t/."""@en ;
  dcterms:modified "2026-06-07T15:30:29.346786Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1302-2
  a curric:KeyLearningPoint ;
  rdfs:label """When a verb has two syllables and the final syllable is stressed, double the
  consonant and add -ed."""@en ;
  dcterms:modified "2026-06-07T15:30:29.346790Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1302-3
  a curric:KeyLearningPoint ;
  rdfs:label "When a verb ends in 'e', remove the 'e' and add the suffix -ed."@en ;
  dcterms:modified "2026-06-07T15:30:29.346794Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1302-4
  a curric:KeyLearningPoint ;
  rdfs:label "When a verb ends in 'y', swap it for an 'i' and add the suffix -ed."@en ;
  dcterms:modified "2026-06-07T15:30:29.346798Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1302-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the common exception words: heard, appear and circle."@en ;
  dcterms:modified "2026-06-07T15:30:29.346801Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1102-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Gust' is a noun which means a blast of air or strong breeze."@en ;
  dcterms:modified "2026-06-07T15:30:29.346828Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1102-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Flurry' is a noun which means a short, swirling gust."@en ;
  dcterms:modified "2026-06-07T15:30:29.346832Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1102-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Blustery' is an adjective which means windy or blowing noisily."@en ;
  dcterms:modified "2026-06-07T15:30:29.346835Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4821-1
  a curric:KeyLearningPoint ;
  rdfs:label "Common exception words do not follow regular spelling or phonics rules."@en ;
  dcterms:modified "2026-06-07T15:30:29.347458Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4821-2
  a curric:KeyLearningPoint ;
  rdfs:label "The words start with a lead in on the line and finish with a lead out."@en ;
  dcterms:modified "2026-06-07T15:30:29.347462Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4821-3
  a curric:KeyLearningPoint ;
  rdfs:label """Letters in the common exception words will be joined using a range of joins
  depending on the letters in the word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.347466Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4821-4
  a curric:KeyLearningPoint ;
  rdfs:label "There is appropriate spacing between the letters."@en ;
  dcterms:modified "2026-06-07T15:30:29.347470Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4821-5
  a curric:KeyLearningPoint ;
  rdfs:label "You don't lift your pencil to form the joins."@en ;
  dcterms:modified "2026-06-07T15:30:29.347474Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5660-1
  a curric:KeyLearningPoint ;
  rdfs:label """Since the text’s publication, the Curiosity rover has continued to explore Mars’
  surface."""@en ;
  dcterms:modified "2026-06-07T15:30:29.347553Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5660-2
  a curric:KeyLearningPoint ;
  rdfs:label """Innovation is a key theme within the text - the team at NASA had to think creatively
  and come up with solutions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.347558Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5660-3
  a curric:KeyLearningPoint ;
  rdfs:label "Revisiting a text can allow readers to discuss questions that focus on themes."@en ;
  dcterms:modified "2026-06-07T15:30:29.347562Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5660-4
  a curric:KeyLearningPoint ;
  rdfs:label """The Curiosity rover mission answered many questions, while posing new ones
  simultaneously."""@en ;
  dcterms:modified "2026-06-07T15:30:29.347566Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8771-1
  a curric:KeyLearningPoint ;
  rdfs:label """'Curious Creatures Glowing in the Dark' is a non-fiction book which provides true
  information."""@en ;
  dcterms:modified "2026-06-07T15:30:29.347570Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8771-2
  a curric:KeyLearningPoint ;
  rdfs:label """Creatures, and other living organisms, can glow in the dark using bioluminescence or
  biofluorescence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.347574Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8771-3
  a curric:KeyLearningPoint ;
  rdfs:label "The book is designed to engage children as its audience."@en ;
  dcterms:modified "2026-06-07T15:30:29.347578Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8771-4
  a curric:KeyLearningPoint ;
  rdfs:label "The layout of a text is determined by its purpose and audience."@en ;
  dcterms:modified "2026-06-07T15:30:29.347582Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8771-5
  a curric:KeyLearningPoint ;
  rdfs:label "The book chunks information into sections and uses fact boxes and illustrations."@en ;
  dcterms:modified "2026-06-07T15:30:29.347586Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5488-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘Escape from Pompeii’ builds tension as the story progresses, drawing readers into
  the narrative of the eruption."""@en ;
  dcterms:modified "2026-06-07T15:30:29.347686Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5488-2
  a curric:KeyLearningPoint ;
  rdfs:label """Tension can be built up in many ways thorough hinting, pacing, illustration,
  character reactions and cliffhangers."""@en ;
  dcterms:modified "2026-06-07T15:30:29.347690Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5488-3
  a curric:KeyLearningPoint ;
  rdfs:label """A turning point in a narrative is a pivotal moment that significantly alters the
  course of the story."""@en ;
  dcterms:modified "2026-06-07T15:30:29.347694Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5488-4
  a curric:KeyLearningPoint ;
  rdfs:label "Turning points can evoke a range of emotions in the character."@en ;
  dcterms:modified "2026-06-07T15:30:29.347697Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1398-1
  a curric:KeyLearningPoint ;
  rdfs:label """A prefix is a letter or group of letters at the start of a word which changes its
  meaning."""@en ;
  dcterms:modified "2026-06-07T15:30:29.347740Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1398-2
  a curric:KeyLearningPoint ;
  rdfs:label "The prefixes co-, com- and con- mean ‘together’ or ‘with’."@en ;
  dcterms:modified "2026-06-07T15:30:29.347744Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1398-3
  a curric:KeyLearningPoint ;
  rdfs:label "The prefix pre- means ‘before’ and pro- means ‘ahead’."@en ;
  dcterms:modified "2026-06-07T15:30:29.347748Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1398-4
  a curric:KeyLearningPoint ;
  rdfs:label """A hyphen can join a prefix to a base word to avoid ambiguity in meaning or
  spelling."""@en ;
  dcterms:modified "2026-06-07T15:30:29.347752Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1398-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: complete, programme and develop."@en ;
  dcterms:modified "2026-06-07T15:30:29.347756Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6555-1
  a curric:KeyLearningPoint ;
  rdfs:label "The main body paragraphs should be factual, specific and detailed."@en ;
  dcterms:modified "2026-06-07T15:30:29.347760Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6555-2
  a curric:KeyLearningPoint ;
  rdfs:label """Flattery, presumption and veiled threat are appropriate persuasive devices to use in
  the main body."""@en ;
  dcterms:modified "2026-06-07T15:30:29.347764Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6555-3
  a curric:KeyLearningPoint ;
  rdfs:label """Points backed up by evidence, statistics, quotes or anecdotes are effective in
  persuading the recipient."""@en ;
  dcterms:modified "2026-06-07T15:30:29.347768Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6555-4
  a curric:KeyLearningPoint ;
  rdfs:label "Plans and success criteria should be referred to during the writing process."@en ;
  dcterms:modified "2026-06-07T15:30:29.347772Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7642-1
  a curric:KeyLearningPoint ;
  rdfs:label """The headline and opening of a persuasive advert should be eye-catching and hook the
  reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.347873Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7642-2
  a curric:KeyLearningPoint ;
  rdfs:label """Linguistic techniques like alliteration, rhyme, onomatopoeia and personification are
  used to create catchy headlines."""@en ;
  dcterms:modified "2026-06-07T15:30:29.347877Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7642-3
  a curric:KeyLearningPoint ;
  rdfs:label """Rhetorical questions are a persuasive technique used to hook the reader in the
  opening of a persuasive advert."""@en ;
  dcterms:modified "2026-06-07T15:30:29.347881Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7642-4
  a curric:KeyLearningPoint ;
  rdfs:label """Persuasive writing should be informed by the unique selling point of the product an
  advert is about."""@en ;
  dcterms:modified "2026-06-07T15:30:29.347885Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7642-5
  a curric:KeyLearningPoint ;
  rdfs:label """The use of a conditional clause to refer to the possibility of something is a
  persuasive technique."""@en ;
  dcterms:modified "2026-06-07T15:30:29.347889Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5773-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the main body is to describe events, thoughts and feelings in
  detail."""@en ;
  dcterms:modified "2026-06-07T15:30:29.347937Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5773-2
  a curric:KeyLearningPoint ;
  rdfs:label "Using a variety of sentence types and structures enhances text cohesion."@en ;
  dcterms:modified "2026-06-07T15:30:29.347944Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5773-3
  a curric:KeyLearningPoint ;
  rdfs:label "Informal tone can be achieved through use of contractions and exclamations."@en ;
  dcterms:modified "2026-06-07T15:30:29.347948Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5773-4
  a curric:KeyLearningPoint ;
  rdfs:label "Adverbials of time can be used to sequence events."@en ;
  dcterms:modified "2026-06-07T15:30:29.347952Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3448-1
  a curric:KeyLearningPoint ;
  rdfs:label "Determiners are a word class."@en ;
  dcterms:modified "2026-06-07T15:30:29.347956Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3448-2
  a curric:KeyLearningPoint ;
  rdfs:label "A determiner introduces a noun in a clause or phrase."@en ;
  dcterms:modified "2026-06-07T15:30:29.347960Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3448-3
  a curric:KeyLearningPoint ;
  rdfs:label "Determiners can be articles, possessive pronouns, quantifiers or demonstratives."@en ;
  dcterms:modified "2026-06-07T15:30:29.347964Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3448-4
  a curric:KeyLearningPoint ;
  rdfs:label """Different determiners have different purposes, chosen by the writer for a
  reason."""@en ;
  dcterms:modified "2026-06-07T15:30:29.347968Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3448-5
  a curric:KeyLearningPoint ;
  rdfs:label """A determiner may be followed by an adjective or pair of adjectives then the
  noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.347971Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1444-1
  a curric:KeyLearningPoint ;
  rdfs:label """-er and \"-est\" are suffixes that can be used to change the meaning of a
  root word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.348071Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1444-2
  a curric:KeyLearningPoint ;
  rdfs:label "For root words ending in 'y', you can remove the 'y' and add -ier or -iest."@en ;
  dcterms:modified "2026-06-07T15:30:29.348075Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1444-3
  a curric:KeyLearningPoint ;
  rdfs:label """For root words with a short vowel sound, you can double the consonant and add the
  suffix -er or -est."""@en ;
  dcterms:modified "2026-06-07T15:30:29.348079Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1444-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words popular and unpopular."@en ;
  dcterms:modified "2026-06-07T15:30:29.348083Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6101-1
  a curric:KeyLearningPoint ;
  rdfs:label """Parenthesis can be achieved with a range of punctuation, including brackets and
  commas."""@en ;
  dcterms:modified "2026-06-07T15:30:29.348098Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6101-2
  a curric:KeyLearningPoint ;
  rdfs:label """Any type of parenthesis is additional information that can be removed without
  compromising grammatical accuracy."""@en ;
  dcterms:modified "2026-06-07T15:30:29.348102Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6101-3
  a curric:KeyLearningPoint ;
  rdfs:label "Brackets are useful in non-fiction writing to add extra, factual information."@en ;
  dcterms:modified "2026-06-07T15:30:29.348106Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6101-4
  a curric:KeyLearningPoint ;
  rdfs:label """Commas can demarcate a relative clause that is inserted into a sentence as
  parenthesis."""@en ;
  dcterms:modified "2026-06-07T15:30:29.348110Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6101-5
  a curric:KeyLearningPoint ;
  rdfs:label "Commas are also useful to drop information into a clause."@en ;
  dcterms:modified "2026-06-07T15:30:29.348114Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8469-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the opening is to engage the reader and to introduce the setting and
  characters."""@en ;
  dcterms:modified "2026-06-07T15:30:29.348201Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8469-2
  a curric:KeyLearningPoint ;
  rdfs:label """When we plan, we note precise and ambitious vocabulary to help paint vivid pictures
  and convey the desired atmosphere."""@en ;
  dcterms:modified "2026-06-07T15:30:29.348205Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8469-3
  a curric:KeyLearningPoint ;
  rdfs:label """A fronted adverbial of time, place or manner indicates when, where or how action in
  the rest of a sentence takes place."""@en ;
  dcterms:modified "2026-06-07T15:30:29.348209Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8469-4
  a curric:KeyLearningPoint ;
  rdfs:label "A plan includes notes, a sequence of events and ambitious vocabulary."@en ;
  dcterms:modified "2026-06-07T15:30:29.348213Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7630-1
  a curric:KeyLearningPoint ;
  rdfs:label """A published piece of writing should be visually and linguistically appealing to the
  reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.348217Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7630-2
  a curric:KeyLearningPoint ;
  rdfs:label "Neat, joined handwriting is important when publishing a piece of writing."@en ;
  dcterms:modified "2026-06-07T15:30:29.348221Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7630-3
  a curric:KeyLearningPoint ;
  rdfs:label """A piece of published writing is the final, best version that becomes available to
  others."""@en ;
  dcterms:modified "2026-06-07T15:30:29.348225Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7630-4
  a curric:KeyLearningPoint ;
  rdfs:label """Illustrations provide visual representations of the characters, settings and events
  described in the text."""@en ;
  dcterms:modified "2026-06-07T15:30:29.348229Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7630-5
  a curric:KeyLearningPoint ;
  rdfs:label """Illustrations can bring the world of the story to life and make it more vivid in the
  reader's mind."""@en ;
  dcterms:modified "2026-06-07T15:30:29.348233Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5818-1
  a curric:KeyLearningPoint ;
  rdfs:label "A setting is where or when a story takes place."@en ;
  dcterms:modified "2026-06-07T15:30:29.348237Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5818-2
  a curric:KeyLearningPoint ;
  rdfs:label """Atmosphere involves how a writer constructs their writing to convey emotions and
  mood to the reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.348241Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5818-3
  a curric:KeyLearningPoint ;
  rdfs:label "The atmosphere in the setting of ‘The Viewer’ is eerie, mysterious and tense."@en ;
  dcterms:modified "2026-06-07T15:30:29.348245Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5818-4
  a curric:KeyLearningPoint ;
  rdfs:label """Personification involves describing objects as if they are people and have
  feelings."""@en ;
  dcterms:modified "2026-06-07T15:30:29.348251Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5818-5
  a curric:KeyLearningPoint ;
  rdfs:label "We can use expanded noun phrases to add detail and description to a noun."@en ;
  dcterms:modified "2026-06-07T15:30:29.348255Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5821-1
  a curric:KeyLearningPoint ;
  rdfs:label """The opening is the first section of a story where the writer describes the setting
  and main characters."""@en ;
  dcterms:modified "2026-06-07T15:30:29.348304Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5821-2
  a curric:KeyLearningPoint ;
  rdfs:label """The opening should be descriptive and use figurative language to build an atmosphere
  for the reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.348308Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5821-3
  a curric:KeyLearningPoint ;
  rdfs:label "A non-finite complex sentence contains a non-finite clause."@en ;
  dcterms:modified "2026-06-07T15:30:29.348312Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5821-4
  a curric:KeyLearningPoint ;
  rdfs:label """A non-finite clause extends the sentence by telling the reader about a second thing
  that the subject is doing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.348316Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5821-5
  a curric:KeyLearningPoint ;
  rdfs:label "A non-finite clause can vary its position in a sentence."@en ;
  dcterms:modified "2026-06-07T15:30:29.348320Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2741-1
  a curric:KeyLearningPoint ;
  rdfs:label "The verb carries the tense of a sentence."@en ;
  dcterms:modified "2026-06-07T15:30:29.348350Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2741-2
  a curric:KeyLearningPoint ;
  rdfs:label "The perfect tense can denote present, past or future action."@en ;
  dcterms:modified "2026-06-07T15:30:29.348354Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2741-3
  a curric:KeyLearningPoint ;
  rdfs:label """The perfect tense is a tense that makes use of an auxiliary verb from the infinitive
  'to have' with the main verb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.348358Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2741-4
  a curric:KeyLearningPoint ;
  rdfs:label """The auxiliary verb is followed by the past participle of the main verb in the
  perfect tense."""@en ;
  dcterms:modified "2026-06-07T15:30:29.348362Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7633-1
  a curric:KeyLearningPoint ;
  rdfs:label """Descriptive and ambitious vocabulary related to the five senses can be included in
  the plan."""@en ;
  dcterms:modified "2026-06-07T15:30:29.348366Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7633-2
  a curric:KeyLearningPoint ;
  rdfs:label """Linguistic devices such as figurative language (similes and personification) should
  be planned."""@en ;
  dcterms:modified "2026-06-07T15:30:29.348372Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7633-3
  a curric:KeyLearningPoint ;
  rdfs:label "Notes are used in planning and they are not written in full sentences."@en ;
  dcterms:modified "2026-06-07T15:30:29.348376Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7633-4
  a curric:KeyLearningPoint ;
  rdfs:label "The 'zoom-in' structure guides the descriptive writing paragraph."@en ;
  dcterms:modified "2026-06-07T15:30:29.348380Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7926-1
  a curric:KeyLearningPoint ;
  rdfs:label """When reflecting on a text, we can consider characterss thoughts, feelings and
  actions and relate them to our own."""@en ;
  dcterms:modified "2026-06-07T15:30:29.348400Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7926-2
  a curric:KeyLearningPoint ;
  rdfs:label """Omar’s strong bond with his brother is one of the core relationships in ‘When Stars
  are Scattered’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.348405Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7926-3
  a curric:KeyLearningPoint ;
  rdfs:label """Throughout the text, Omar picks up on the inequality between what life is like for
  boys and girls at Dadaab."""@en ;
  dcterms:modified "2026-06-07T15:30:29.348411Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7926-4
  a curric:KeyLearningPoint ;
  rdfs:label """The way that one reader connects with a text might be different to another based on
  their own life experiences."""@en ;
  dcterms:modified "2026-06-07T15:30:29.348415Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8043-1
  a curric:KeyLearningPoint ;
  rdfs:label """'Who Has Seen the Wind?' is a short, simple poem that explores the invisible and
  mysterious nature of the wind."""@en ;
  dcterms:modified "2026-06-07T15:30:29.348480Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8043-2
  a curric:KeyLearningPoint ;
  rdfs:label "Personification is describing a non-living thing as if it is a person."@en ;
  dcterms:modified "2026-06-07T15:30:29.348483Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8043-3
  a curric:KeyLearningPoint ;
  rdfs:label """The poem uses rhetorical questions to demonstrate the mysterious nature of
  the wind."""@en ;
  dcterms:modified "2026-06-07T15:30:29.348489Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8043-4
  a curric:KeyLearningPoint ;
  rdfs:label """The structure of a poem is the way it is ordered, including its pattern of lines,
  verses and rhyme."""@en ;
  dcterms:modified "2026-06-07T15:30:29.348494Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7871-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Greenling' is a picturebook text; it can be considered to be a fable."@en ;
  dcterms:modified "2026-06-07T15:30:29.348509Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7871-2
  a curric:KeyLearningPoint ;
  rdfs:label """Fables usually explain the creation of the world, natural events and the origins of
  rituals or customs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.348513Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7871-3
  a curric:KeyLearningPoint ;
  rdfs:label """Words can have multiple meanings; pupils can explore these through a 'word
  explosion'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.348517Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7871-4
  a curric:KeyLearningPoint ;
  rdfs:label """In ‘Greenling’, vignettes offer glimpses into specific moments or aspects of the
  story."""@en ;
  dcterms:modified "2026-06-07T15:30:29.348521Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7871-5
  a curric:KeyLearningPoint ;
  rdfs:label """The Greenling has a positive effect on the Barleycorns and their local
  community."""@en ;
  dcterms:modified "2026-06-07T15:30:29.348525Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3463-1
  a curric:KeyLearningPoint ;
  rdfs:label """Bullet points are useful to lay out key information clearly in a non-fiction
  text."""@en ;
  dcterms:modified "2026-06-07T15:30:29.348603Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3463-2
  a curric:KeyLearningPoint ;
  rdfs:label "Bullet points space information out for the reader."@en ;
  dcterms:modified "2026-06-07T15:30:29.348608Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3463-3
  a curric:KeyLearningPoint ;
  rdfs:label "Bullet points often come after a main clause or a subheading."@en ;
  dcterms:modified "2026-06-07T15:30:29.348613Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3463-4
  a curric:KeyLearningPoint ;
  rdfs:label "List items only need capitals and full stops when they are complete sentences."@en ;
  dcterms:modified "2026-06-07T15:30:29.348617Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6326-1
  a curric:KeyLearningPoint ;
  rdfs:label """The structure and features of a text can help identify keywords or key
  information."""@en ;
  dcterms:modified "2026-06-07T15:30:29.348623Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6326-2
  a curric:KeyLearningPoint ;
  rdfs:label """A glossary can define technical or subject-specific vocabulary to support readers
  with understanding the text."""@en ;
  dcterms:modified "2026-06-07T15:30:29.348628Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6326-3
  a curric:KeyLearningPoint ;
  rdfs:label "Predictions can be justified using information from the pages."@en ;
  dcterms:modified "2026-06-07T15:30:29.348632Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4897-1
  a curric:KeyLearningPoint ;
  rdfs:label "Information in the adaptations section is specific for the reader."@en ;
  dcterms:modified "2026-06-07T15:30:29.348681Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4897-2
  a curric:KeyLearningPoint ;
  rdfs:label """Text cohesion refers to how a piece of writing flows, engages the reader and
  achieves its purpose."""@en ;
  dcterms:modified "2026-06-07T15:30:29.348687Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4897-3
  a curric:KeyLearningPoint ;
  rdfs:label "Brackets can be used for parenthesis."@en ;
  dcterms:modified "2026-06-07T15:30:29.348691Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4897-4
  a curric:KeyLearningPoint ;
  rdfs:label "Planning is an essential part of the writing process."@en ;
  dcterms:modified "2026-06-07T15:30:29.348695Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4897-5
  a curric:KeyLearningPoint ;
  rdfs:label """Plans should include notes, bullet points and initial ideas that can be developed
  further when writing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.348699Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1303-1
  a curric:KeyLearningPoint ;
  rdfs:label "Adding the suffix -ed turns the verb into the past tense."@en ;
  dcterms:modified "2026-06-07T15:30:29.348703Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1303-2
  a curric:KeyLearningPoint ;
  rdfs:label "When the vowel sound is long, we just add the suffix -ed."@en ;
  dcterms:modified "2026-06-07T15:30:29.348707Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1303-3
  a curric:KeyLearningPoint ;
  rdfs:label "When the vowel sound is short, we double the consonant and add the suffix -ed."@en ;
  dcterms:modified "2026-06-07T15:30:29.348711Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1303-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell irregular verbs in the past tense, such as slept."@en ;
  dcterms:modified "2026-06-07T15:30:29.348715Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1303-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the common exception words: different, material and busy."@en ;
  dcterms:modified "2026-06-07T15:30:29.348719Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1116-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Bleak' is an adjective which means gloomy or depressing."@en ;
  dcterms:modified "2026-06-07T15:30:29.348745Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1116-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Downpour' is a noun which means a heavy rainstorm."@en ;
  dcterms:modified "2026-06-07T15:30:29.348748Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1116-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Drab' is an adjective which means dull or grey."@en ;
  dcterms:modified "2026-06-07T15:30:29.348755Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6344-1
  a curric:KeyLearningPoint ;
  rdfs:label "Writing is most successful when structure, content and vocabulary is planned."@en ;
  dcterms:modified "2026-06-07T15:30:29.349758Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6344-2
  a curric:KeyLearningPoint ;
  rdfs:label "Oral rehearsal is an important step in the writing process."@en ;
  dcterms:modified "2026-06-07T15:30:29.349762Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6344-3
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials of place, prepositions and precise vocabulary paint the picture
  for a reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.349766Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6344-4
  a curric:KeyLearningPoint ;
  rdfs:label "Complex sentences can be used to show the connections between ideas."@en ;
  dcterms:modified "2026-06-07T15:30:29.349770Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6344-5
  a curric:KeyLearningPoint ;
  rdfs:label """We can show the historical context of our setting by referring to items from the
  time period."""@en ;
  dcterms:modified "2026-06-07T15:30:29.349774Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7827-1
  a curric:KeyLearningPoint ;
  rdfs:label "Narrative openings often introduce the protagonist and set the scene."@en ;
  dcterms:modified "2026-06-07T15:30:29.349851Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7827-2
  a curric:KeyLearningPoint ;
  rdfs:label "In the opening, the plot of the story is introduced."@en ;
  dcterms:modified "2026-06-07T15:30:29.349855Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7827-3
  a curric:KeyLearningPoint ;
  rdfs:label "'The Sheep-Pig' is set on a farm in England."@en ;
  dcterms:modified "2026-06-07T15:30:29.349859Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7827-4
  a curric:KeyLearningPoint ;
  rdfs:label "The protagonist in 'The Sheep-Pig' is Babe who appears to be unique."@en ;
  dcterms:modified "2026-06-07T15:30:29.349863Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7925-1
  a curric:KeyLearningPoint ;
  rdfs:label """'When Stars are Scattered' is a graphic novel memoir of Omar Mohamed's experience of
  living in a refugee camp in Kenya."""@en ;
  dcterms:modified "2026-06-07T15:30:29.349867Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7925-2
  a curric:KeyLearningPoint ;
  rdfs:label "Omar and his brother, Hassan, have lived in Dadaab refugee camp for seven years."@en ;
  dcterms:modified "2026-06-07T15:30:29.349871Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7925-3
  a curric:KeyLearningPoint ;
  rdfs:label """Omar's brother, Hassan, has complex needs which are depicted and handled
  sensitively."""@en ;
  dcterms:modified "2026-06-07T15:30:29.349875Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7925-4
  a curric:KeyLearningPoint ;
  rdfs:label """Gender inequality is noted in the early chapters; inequality is an important theme
  of the text."""@en ;
  dcterms:modified "2026-06-07T15:30:29.349879Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6155-1
  a curric:KeyLearningPoint ;
  rdfs:label """Climate change is driven by human activity - specifically, an increase in greenhouse
  gases."""@en ;
  dcterms:modified "2026-06-07T15:30:29.349908Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6155-2
  a curric:KeyLearningPoint ;
  rdfs:label "Climate change will have significant impacts on the planet and human beings."@en ;
  dcterms:modified "2026-06-07T15:30:29.349912Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6155-3
  a curric:KeyLearningPoint ;
  rdfs:label """We can discuss who has responsibility to address climate change and what should be
  done to improve the situation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.349916Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6155-4
  a curric:KeyLearningPoint ;
  rdfs:label """As part of this process of discussion, people may make speeches on either side of
  the debate."""@en ;
  dcterms:modified "2026-06-07T15:30:29.349921Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6155-5
  a curric:KeyLearningPoint ;
  rdfs:label """We can use the PEPS (point, explanation, proof, summary) structure to help make a
  speech persuasive."""@en ;
  dcterms:modified "2026-06-07T15:30:29.349927Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6596-1
  a curric:KeyLearningPoint ;
  rdfs:label """A conclusion summarises the key points of the paragraphs preceding it - no new
  information should be introduced."""@en ;
  dcterms:modified "2026-06-07T15:30:29.349931Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6596-2
  a curric:KeyLearningPoint ;
  rdfs:label "The conclusion paragraph is similar in structure to the introduction paragraph."@en ;
  dcterms:modified "2026-06-07T15:30:29.349935Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6596-3
  a curric:KeyLearningPoint ;
  rdfs:label "Variation in vocabulary choice and sentence structure enhances text cohesion."@en ;
  dcterms:modified "2026-06-07T15:30:29.349939Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6596-4
  a curric:KeyLearningPoint ;
  rdfs:label "Plans should be written in note form and include concise vocabulary choices."@en ;
  dcterms:modified "2026-06-07T15:30:29.349943Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6596-5
  a curric:KeyLearningPoint ;
  rdfs:label "Success criteria and plans should be used to guide the writing process."@en ;
  dcterms:modified "2026-06-07T15:30:29.349947Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5767-1
  a curric:KeyLearningPoint ;
  rdfs:label """Diaries are informal in tone; this can be achieved through use of certain linguistic
  features, like contracted words."""@en ;
  dcterms:modified "2026-06-07T15:30:29.349951Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5767-2
  a curric:KeyLearningPoint ;
  rdfs:label "Diaries include references to the character’s thoughts and feelings."@en ;
  dcterms:modified "2026-06-07T15:30:29.349955Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5767-3
  a curric:KeyLearningPoint ;
  rdfs:label "Diaries are written from the first person perspective."@en ;
  dcterms:modified "2026-06-07T15:30:29.349959Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5767-4
  a curric:KeyLearningPoint ;
  rdfs:label "Writers can convey their feelings using 'tell' and 'show-not-tell' descriptions."@en ;
  dcterms:modified "2026-06-07T15:30:29.349963Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1353-1
  a curric:KeyLearningPoint ;
  rdfs:label "The /s/ sound in Latin-origin words is generally spelt 'sc'."@en ;
  dcterms:modified "2026-06-07T15:30:29.349970Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1353-2
  a curric:KeyLearningPoint ;
  rdfs:label "The /k/ sound in Greek-origin words is generally spelt 'ch'."@en ;
  dcterms:modified "2026-06-07T15:30:29.349974Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1353-3
  a curric:KeyLearningPoint ;
  rdfs:label "The /f/ sound in Greek-origin words is generally spelt 'ph'."@en ;
  dcterms:modified "2026-06-07T15:30:29.349978Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1353-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: stomach, yacht and ancient."@en ;
  dcterms:modified "2026-06-07T15:30:29.349982Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8015-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘MORERAPS’ is a type of poem that Joseph Coelho invented to help him remember the
  different poetic devices."""@en ;
  dcterms:modified "2026-06-07T15:30:29.349986Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8015-2
  a curric:KeyLearningPoint ;
  rdfs:label """A poetic device is a technique used by poets to enhance the meaning, sound and
  overall impact of their poems."""@en ;
  dcterms:modified "2026-06-07T15:30:29.349992Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8015-3
  a curric:KeyLearningPoint ;
  rdfs:label """Repetition is the repeated use of sounds, words, phrases or structural elements that
  are repeated for emphasis."""@en ;
  dcterms:modified "2026-06-07T15:30:29.349996Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8015-4
  a curric:KeyLearningPoint ;
  rdfs:label """Personification is a way of describing a non-living thing as if it acts or feels
  like a human."""@en ;
  dcterms:modified "2026-06-07T15:30:29.350000Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8015-5
  a curric:KeyLearningPoint ;
  rdfs:label "The subject of a poem is the main topic or idea that the poet is writing about."@en ;
  dcterms:modified "2026-06-07T15:30:29.350004Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8083-1
  a curric:KeyLearningPoint ;
  rdfs:label """The poem is a dramatic monologue; this is when one person speaks in a poem or story,
  sharing their perspective."""@en ;
  dcterms:modified "2026-06-07T15:30:29.350184Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8083-2
  a curric:KeyLearningPoint ;
  rdfs:label "The poem has a structured form with a consistent rhyme scheme."@en ;
  dcterms:modified "2026-06-07T15:30:29.350189Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8083-3
  a curric:KeyLearningPoint ;
  rdfs:label "The poem has an ABAB rhyme scheme."@en ;
  dcterms:modified "2026-06-07T15:30:29.350193Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8083-4
  a curric:KeyLearningPoint ;
  rdfs:label """Blake uses repetition to emphasise certain words or phrases or to create a
  particular effect."""@en ;
  dcterms:modified "2026-06-07T15:30:29.350197Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8083-5
  a curric:KeyLearningPoint ;
  rdfs:label """Reader's viewpoints about the impact of the poem may differ as we are all
  unique."""@en ;
  dcterms:modified "2026-06-07T15:30:29.350201Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1040-1
  a curric:KeyLearningPoint ;
  rdfs:label """A group of words that contains a verb and makes complete sense is called a main
  clause."""@en ;
  dcterms:modified "2026-06-07T15:30:29.350227Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1040-2
  a curric:KeyLearningPoint ;
  rdfs:label "Co-ordinating conjunctions join two main clauses to form a compound sentence."@en ;
  dcterms:modified "2026-06-07T15:30:29.350231Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1040-3
  a curric:KeyLearningPoint ;
  rdfs:label """If the co-ordinating conjunction \"but\" or \"or\" is used, there must be a comma
  before it in a compound sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.350235Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1040-4
  a curric:KeyLearningPoint ;
  rdfs:label "The comma tells the reader where the main clause demarcation is."@en ;
  dcterms:modified "2026-06-07T15:30:29.350239Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1040-5
  a curric:KeyLearningPoint ;
  rdfs:label "Different co-ordinating conjunctions have different meanings."@en ;
  dcterms:modified "2026-06-07T15:30:29.350243Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4708-1
  a curric:KeyLearningPoint ;
  rdfs:label """A speech is the communication of someone’s thoughts, through words, to an
  audience."""@en ;
  dcterms:modified "2026-06-07T15:30:29.350247Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4708-2
  a curric:KeyLearningPoint ;
  rdfs:label "Lots of different jobs require people to make speeches."@en ;
  dcterms:modified "2026-06-07T15:30:29.350251Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4708-3
  a curric:KeyLearningPoint ;
  rdfs:label "The purpose of making a speech is to have an impact on your audience."@en ;
  dcterms:modified "2026-06-07T15:30:29.350255Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4708-4
  a curric:KeyLearningPoint ;
  rdfs:label """A successful speech will persuade an audience to agree with the main themes of the
  speech."""@en ;
  dcterms:modified "2026-06-07T15:30:29.350259Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2705-1
  a curric:KeyLearningPoint ;
  rdfs:label "The verb carries the tense of a sentence."@en ;
  dcterms:modified "2026-06-07T15:30:29.350262Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2705-2
  a curric:KeyLearningPoint ;
  rdfs:label "The perfect tense can denote present, past or future action."@en ;
  dcterms:modified "2026-06-07T15:30:29.350267Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2705-3
  a curric:KeyLearningPoint ;
  rdfs:label """The perfect tense is a tense that makes use of an auxiliary verb based on 'to have'
  and a main verb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.350271Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2705-4
  a curric:KeyLearningPoint ;
  rdfs:label """The auxiliary verb is followed by a past tense form of the main verb in the perfect
  tense."""@en ;
  dcterms:modified "2026-06-07T15:30:29.350274Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6217-1
  a curric:KeyLearningPoint ;
  rdfs:label """Our essay will give one side of an argument, with a logical argument building to a
  conclusion that mirrors the title."""@en ;
  dcterms:modified "2026-06-07T15:30:29.350342Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6217-2
  a curric:KeyLearningPoint ;
  rdfs:label """Writing is best when we are sure of the ideas we are trying to communicate and how
  they relate logically to one another."""@en ;
  dcterms:modified "2026-06-07T15:30:29.350346Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6217-3
  a curric:KeyLearningPoint ;
  rdfs:label """We can organise a set of ideas into a logical order in order to make our argument
  most effective."""@en ;
  dcterms:modified "2026-06-07T15:30:29.350350Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6217-4
  a curric:KeyLearningPoint ;
  rdfs:label """We also need to organise ideas into paragraphs that build logically on from each
  other towards the conclusion."""@en ;
  dcterms:modified "2026-06-07T15:30:29.350354Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4894-1
  a curric:KeyLearningPoint ;
  rdfs:label "Related information is grouped into paragraphs and organised using a subheading."@en ;
  dcterms:modified "2026-06-07T15:30:29.350393Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4894-2
  a curric:KeyLearningPoint ;
  rdfs:label "An introductory sentence explains what the paragraph is about."@en ;
  dcterms:modified "2026-06-07T15:30:29.350397Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4894-3
  a curric:KeyLearningPoint ;
  rdfs:label "Relative clauses give additional detail about the sentence’s subject."@en ;
  dcterms:modified "2026-06-07T15:30:29.350401Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4894-4
  a curric:KeyLearningPoint ;
  rdfs:label "Apostrophes can be used to indicate plural possession."@en ;
  dcterms:modified "2026-06-07T15:30:29.350405Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4894-5
  a curric:KeyLearningPoint ;
  rdfs:label "Referring to aye-ayes using other nouns avoids repetition."@en ;
  dcterms:modified "2026-06-07T15:30:29.350409Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2722-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the opening is to engage the reader and introduce the setting and
  characters."""@en ;
  dcterms:modified "2026-06-07T15:30:29.350530Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2722-2
  a curric:KeyLearningPoint ;
  rdfs:label """When we plan, we log precise and ambitious vocabulary to help paint vivid pictures
  for our reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.350534Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2722-3
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials of time, place and manner are included in a plan to add extra
  detail about the action."""@en ;
  dcterms:modified "2026-06-07T15:30:29.350538Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2722-4
  a curric:KeyLearningPoint ;
  rdfs:label """Dialogue is the written conversation between two or more characters within a
  narrative and it moves the story forward."""@en ;
  dcterms:modified "2026-06-07T15:30:29.350542Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2722-5
  a curric:KeyLearningPoint ;
  rdfs:label """Show-not-tell language is a writing technique for showing a character’s feelings to
  a reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.350546Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1069-1
  a curric:KeyLearningPoint ;
  rdfs:label """Visuals and captions make information easier to understand and remember for the
  reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.350550Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1069-2
  a curric:KeyLearningPoint ;
  rdfs:label """The layout of a text helps to organise information logically, allowing the reader to
  navigate through a report easily."""@en ;
  dcterms:modified "2026-06-07T15:30:29.350554Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1069-3
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to use neat, joined handwriting when publishing a non-chronological
  report."""@en ;
  dcterms:modified "2026-06-07T15:30:29.350558Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1069-4
  a curric:KeyLearningPoint ;
  rdfs:label """A published non-chronological report should be visually and linguistically appealing
  to the reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.350562Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5819-1
  a curric:KeyLearningPoint ;
  rdfs:label "A character is a person, animal or figure in a story."@en ;
  dcterms:modified "2026-06-07T15:30:29.350567Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5819-2
  a curric:KeyLearningPoint ;
  rdfs:label "We can use expanded noun phrases to add detail and description to a noun."@en ;
  dcterms:modified "2026-06-07T15:30:29.350571Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5819-3
  a curric:KeyLearningPoint ;
  rdfs:label "A simile describes something by comparing it to something else."@en ;
  dcterms:modified "2026-06-07T15:30:29.350575Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5750-1
  a curric:KeyLearningPoint ;
  rdfs:label """There are five main food groups in a balanced diet: protein, fats, carbohydrates,
  dairy and fruit and vegetables."""@en ;
  dcterms:modified "2026-06-07T15:30:29.350902Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5750-2
  a curric:KeyLearningPoint ;
  rdfs:label "Humans should aim to eat 30 plant-based foods a week."@en ;
  dcterms:modified "2026-06-07T15:30:29.350907Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5750-3
  a curric:KeyLearningPoint ;
  rdfs:label """All the food groups need to be eaten in moderation to maintain a healthy, balanced
  diet."""@en ;
  dcterms:modified "2026-06-07T15:30:29.350911Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5750-4
  a curric:KeyLearningPoint ;
  rdfs:label "Exercise is an essential factor towards leading a healthy lifestyle."@en ;
  dcterms:modified "2026-06-07T15:30:29.350915Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5750-5
  a curric:KeyLearningPoint ;
  rdfs:label "Sleep is essential for good health."@en ;
  dcterms:modified "2026-06-07T15:30:29.350919Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7909-1
  a curric:KeyLearningPoint ;
  rdfs:label """The migration of people from the Caribbean to the UK during the Windrush period was
  driven by a combination of factors."""@en ;
  dcterms:modified "2026-06-07T15:30:29.350960Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7909-2
  a curric:KeyLearningPoint ;
  rdfs:label """The song is written from the perspective of someone who had been to London even
  though Roberts had not yet visited."""@en ;
  dcterms:modified "2026-06-07T15:30:29.350964Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7909-3
  a curric:KeyLearningPoint ;
  rdfs:label """To determine the purpose and audience of a song, we can consider the music and
  lyrics of the song."""@en ;
  dcterms:modified "2026-06-07T15:30:29.350968Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7909-4
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose & audience of songs can change over time; when the context of a song
  changes, so can its purpose & audience."""@en ;
  dcterms:modified "2026-06-07T15:30:29.350972Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8058-1
  a curric:KeyLearningPoint ;
  rdfs:label """The poem describes a bird that comes down a garden path and interacts with the
  natural world around it."""@en ;
  dcterms:modified "2026-06-07T15:30:29.350976Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8058-2
  a curric:KeyLearningPoint ;
  rdfs:label """‘A Bird came down the Walk’ can be described as a fixed verse poem; it consists of
  five verses, containing four lines."""@en ;
  dcterms:modified "2026-06-07T15:30:29.350980Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8058-3
  a curric:KeyLearningPoint ;
  rdfs:label "Dashes create a pause in the poem; these can also be called caesuras."@en ;
  dcterms:modified "2026-06-07T15:30:29.350984Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8058-4
  a curric:KeyLearningPoint ;
  rdfs:label """Dashes can be used to create emphasis, add dramatic effect or control the pacing of
  a poem."""@en ;
  dcterms:modified "2026-06-07T15:30:29.350988Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8058-5
  a curric:KeyLearningPoint ;
  rdfs:label """Understanding a poem, its language, imagery & the impression it creates will help us
  to create an impactful performance."""@en ;
  dcterms:modified "2026-06-07T15:30:29.350992Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5840-1
  a curric:KeyLearningPoint ;
  rdfs:label "Writing is most successful when it is planned."@en ;
  dcterms:modified "2026-06-07T15:30:29.350996Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5840-2
  a curric:KeyLearningPoint ;
  rdfs:label "Vocabulary can be generated to precisely set the atmosphere for a scene."@en ;
  dcterms:modified "2026-06-07T15:30:29.351000Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5840-3
  a curric:KeyLearningPoint ;
  rdfs:label "Expanded noun phrases can be used to describe a noun vividly."@en ;
  dcterms:modified "2026-06-07T15:30:29.351004Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5840-4
  a curric:KeyLearningPoint ;
  rdfs:label """Expanded noun phrases can be stretched with 'that' or 'with' to add further detail
  to a description."""@en ;
  dcterms:modified "2026-06-07T15:30:29.351008Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5840-5
  a curric:KeyLearningPoint ;
  rdfs:label """Describing what can be seen, heard, felt and smelt helps readers visualise the
  scene."""@en ;
  dcterms:modified "2026-06-07T15:30:29.351012Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8479-1
  a curric:KeyLearningPoint ;
  rdfs:label """The climax of a story is the point in the narrative where the suspense and
  excitement reaches its highest point."""@en ;
  dcterms:modified "2026-06-07T15:30:29.351076Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8479-2
  a curric:KeyLearningPoint ;
  rdfs:label """‘The Firework-Maker’s Daughter’ reaches climax when Lila meets Razvani and faces the
  biggest challenge of her quest."""@en ;
  dcterms:modified "2026-06-07T15:30:29.351080Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8479-3
  a curric:KeyLearningPoint ;
  rdfs:label """Moments of suspense lead the reader to question whether Lila will succeed or
  survive."""@en ;
  dcterms:modified "2026-06-07T15:30:29.351084Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8479-4
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to focus on key moments of suspense when summarising the climax of a
  story."""@en ;
  dcterms:modified "2026-06-07T15:30:29.351088Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6737-1
  a curric:KeyLearningPoint ;
  rdfs:label """Narratives are often written in the third person, but we can switch perspectives
  during a narrative."""@en ;
  dcterms:modified "2026-06-07T15:30:29.351485Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6737-2
  a curric:KeyLearningPoint ;
  rdfs:label """Including first person perspectives allows us to show the protagonist's
  thoughts."""@en ;
  dcterms:modified "2026-06-07T15:30:29.351491Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6737-3
  a curric:KeyLearningPoint ;
  rdfs:label """An internal monologue is a type of first person writing focused on the protagonist's
  inner thoughts."""@en ;
  dcterms:modified "2026-06-07T15:30:29.351496Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6737-4
  a curric:KeyLearningPoint ;
  rdfs:label """We can use a range of language techniques to lend internal monologue an informal
  tone."""@en ;
  dcterms:modified "2026-06-07T15:30:29.351500Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6737-5
  a curric:KeyLearningPoint ;
  rdfs:label "We can include sensory details to show more of the protagonist's emotions."@en ;
  dcterms:modified "2026-06-07T15:30:29.351506Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1129-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Self-conscious' is an adjective which means overly aware of yourself."@en ;
  dcterms:modified "2026-06-07T15:30:29.351510Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1129-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Sheepish' is an adjective which means shy, ashamed or uncomfortable."@en ;
  dcterms:modified "2026-06-07T15:30:29.351516Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1129-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Wary' is an adjective which means careful or cautious."@en ;
  dcterms:modified "2026-06-07T15:30:29.351520Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1393-1
  a curric:KeyLearningPoint ;
  rdfs:label "In polysyllabic words, some vowels can be unstressed and hard to hear and spell."@en ;
  dcterms:modified "2026-06-07T15:30:29.351536Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1393-2
  a curric:KeyLearningPoint ;
  rdfs:label "Saying the word how it is spelt can help to learn the spelling."@en ;
  dcterms:modified "2026-06-07T15:30:29.351540Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1393-3
  a curric:KeyLearningPoint ;
  rdfs:label """Thinking of the root word and identifying prefixes and suffixes can help to learn
  the spelling."""@en ;
  dcterms:modified "2026-06-07T15:30:29.351544Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1393-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: variety, various, imagine and definite."@en ;
  dcterms:modified "2026-06-07T15:30:29.351548Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8896-1
  a curric:KeyLearningPoint ;
  rdfs:label """Skimming and scanning using your finger is a way to retrieve information accurately
  and quickly from a text"""@en ;
  dcterms:modified "2026-06-07T15:30:29.351606Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8896-2
  a curric:KeyLearningPoint ;
  rdfs:label "Reading between the lines to search for clues can help to infer meaning"@en ;
  dcterms:modified "2026-06-07T15:30:29.351610Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8896-3
  a curric:KeyLearningPoint ;
  rdfs:label "Evidence from the text helps us to justify our inferences"@en ;
  dcterms:modified "2026-06-07T15:30:29.351614Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8896-4
  a curric:KeyLearningPoint ;
  rdfs:label "Different characters have different experiences and perspectives of each other"@en ;
  dcterms:modified "2026-06-07T15:30:29.351618Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4807-1
  a curric:KeyLearningPoint ;
  rdfs:label """A suffix is a letter or group of letters at the end of a word which creates another
  word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.351622Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4807-2
  a curric:KeyLearningPoint ;
  rdfs:label "The words start with a lead in and finish with a lead out."@en ;
  dcterms:modified "2026-06-07T15:30:29.351626Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4807-3
  a curric:KeyLearningPoint ;
  rdfs:label """The pencil does not lift when forming the join, only after to add the cross to a t
  or a dot to an i or a j."""@en ;
  dcterms:modified "2026-06-07T15:30:29.351630Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4807-4
  a curric:KeyLearningPoint ;
  rdfs:label "There are four cursive joins."@en ;
  dcterms:modified "2026-06-07T15:30:29.351634Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4807-5
  a curric:KeyLearningPoint ;
  rdfs:label """The join used depends on which letter is joining to which letter within a letter
  string."""@en ;
  dcterms:modified "2026-06-07T15:30:29.351638Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8016-1
  a curric:KeyLearningPoint ;
  rdfs:label """The poem ‘If All The World Were Paper’ imaginatively explores what we might do if
  everything were made of paper."""@en ;
  dcterms:modified "2026-06-07T15:30:29.351642Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8016-2
  a curric:KeyLearningPoint ;
  rdfs:label """The poem explores the theme of protecting those we love and preserving their
  memory."""@en ;
  dcterms:modified "2026-06-07T15:30:29.351649Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8016-3
  a curric:KeyLearningPoint ;
  rdfs:label "Other themes in the poem include: family, memory, love and imagination."@en ;
  dcterms:modified "2026-06-07T15:30:29.351653Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8016-4
  a curric:KeyLearningPoint ;
  rdfs:label """A metaphor is a way of describing and comparing something by saying that it is
  something else."""@en ;
  dcterms:modified "2026-06-07T15:30:29.351657Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8021-1
  a curric:KeyLearningPoint ;
  rdfs:label "Kennings are phrases of two words that refer to a noun, often used in poetry."@en ;
  dcterms:modified "2026-06-07T15:30:29.351661Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8021-2
  a curric:KeyLearningPoint ;
  rdfs:label "Kennings can describe an object without ever saying what it actually is."@en ;
  dcterms:modified "2026-06-07T15:30:29.351665Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8021-3
  a curric:KeyLearningPoint ;
  rdfs:label "Kennings can provoke the reader's curiosity."@en ;
  dcterms:modified "2026-06-07T15:30:29.351669Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8021-4
  a curric:KeyLearningPoint ;
  rdfs:label "A kenning poem is like a riddle."@en ;
  dcterms:modified "2026-06-07T15:30:29.351673Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2712-1
  a curric:KeyLearningPoint ;
  rdfs:label "A fronted adverbial is a sentence starter that is followed by a comma."@en ;
  dcterms:modified "2026-06-07T15:30:29.351677Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2712-2
  a curric:KeyLearningPoint ;
  rdfs:label "A fronted adverbial can be a single word or phrase."@en ;
  dcterms:modified "2026-06-07T15:30:29.351681Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2712-3
  a curric:KeyLearningPoint ;
  rdfs:label "A fronted adverbial can be a clause."@en ;
  dcterms:modified "2026-06-07T15:30:29.351685Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2712-4
  a curric:KeyLearningPoint ;
  rdfs:label "A clause is a group of words that contains a verb."@en ;
  dcterms:modified "2026-06-07T15:30:29.351688Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2712-5
  a curric:KeyLearningPoint ;
  rdfs:label "A fronted adverbial can express detail about time, place or manner."@en ;
  dcterms:modified "2026-06-07T15:30:29.351692Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2744-1
  a curric:KeyLearningPoint ;
  rdfs:label "Inverted commas are the punctuation that signal direct speech to the reader."@en ;
  dcterms:modified "2026-06-07T15:30:29.351696Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2744-2
  a curric:KeyLearningPoint ;
  rdfs:label "A speech interrupted sentence begins with a character's spoken words."@en ;
  dcterms:modified "2026-06-07T15:30:29.351701Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2744-3
  a curric:KeyLearningPoint ;
  rdfs:label "The character's spoken words are interrupted by the reporting clause."@en ;
  dcterms:modified "2026-06-07T15:30:29.351705Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2744-4
  a curric:KeyLearningPoint ;
  rdfs:label """The character's spoken words resume after the reporting clause and the speech
  interrupted sentence ends."""@en ;
  dcterms:modified "2026-06-07T15:30:29.351709Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2744-5
  a curric:KeyLearningPoint ;
  rdfs:label """A character's spoken words must be chosen carefully to include a natural break when
  punctuating speech interrupted."""@en ;
  dcterms:modified "2026-06-07T15:30:29.351713Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4895-1
  a curric:KeyLearningPoint ;
  rdfs:label """A section of a non-chronological report contains specific information for the
  reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.351717Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4895-2
  a curric:KeyLearningPoint ;
  rdfs:label """Writers can use a range of cohesive devices to ensure their sentences flow and the
  text’s purpose is achieved."""@en ;
  dcterms:modified "2026-06-07T15:30:29.351730Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4895-3
  a curric:KeyLearningPoint ;
  rdfs:label """The diet section includes an introductory sentence, followed by specific
  information, then a linking sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.351734Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4895-4
  a curric:KeyLearningPoint ;
  rdfs:label """We can use success criteria to help us identify what a successful piece of writing
  includes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.351740Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4895-5
  a curric:KeyLearningPoint ;
  rdfs:label "The writing process involves planning, drafting, editing and publishing."@en ;
  dcterms:modified "2026-06-07T15:30:29.351745Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6417-1
  a curric:KeyLearningPoint ;
  rdfs:label "Writing is most successful when we orally rehearse before writing."@en ;
  dcterms:modified "2026-06-07T15:30:29.351749Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6417-2
  a curric:KeyLearningPoint ;
  rdfs:label "A diary can include events and feelings written in the past and present tense."@en ;
  dcterms:modified "2026-06-07T15:30:29.351753Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6417-3
  a curric:KeyLearningPoint ;
  rdfs:label """We use a range of cohesive devices in all writing, including different punctuation,
  sentence types and parenthesis."""@en ;
  dcterms:modified "2026-06-07T15:30:29.351757Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6417-4
  a curric:KeyLearningPoint ;
  rdfs:label """Because a diary is a personal piece of writing, it can have a conversational
  tone."""@en ;
  dcterms:modified "2026-06-07T15:30:29.351761Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6417-5
  a curric:KeyLearningPoint ;
  rdfs:label """We can create a conversational tone using questions, exclamatives, verbless
  sentences and conversational openers."""@en ;
  dcterms:modified "2026-06-07T15:30:29.351767Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7829-1
  a curric:KeyLearningPoint ;
  rdfs:label """Babe shows many positive character traits, including kindness, politeness,
  determination and friendliness."""@en ;
  dcterms:modified "2026-06-07T15:30:29.351771Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7829-2
  a curric:KeyLearningPoint ;
  rdfs:label "Babe's kindness and determination helps him to form relationships."@en ;
  dcterms:modified "2026-06-07T15:30:29.351775Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7829-3
  a curric:KeyLearningPoint ;
  rdfs:label "Farmer Hogget forms a bond with Babe and Fly accepts Babe and teaches him."@en ;
  dcterms:modified "2026-06-07T15:30:29.351779Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7829-4
  a curric:KeyLearningPoint ;
  rdfs:label """Role on the wall is a reading activity which helps us develop our understanding of
  characters in a story or text."""@en ;
  dcterms:modified "2026-06-07T15:30:29.351783Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7829-5
  a curric:KeyLearningPoint ;
  rdfs:label "We can support our ideas with evidence from the text."@en ;
  dcterms:modified "2026-06-07T15:30:29.351787Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1103-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Howl' is a verb which means to cry or wail."@en ;
  dcterms:modified "2026-06-07T15:30:29.351814Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1103-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Whirlwind' is a noun which means a hurricane or tornado."@en ;
  dcterms:modified "2026-06-07T15:30:29.351818Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1103-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Windswept' is an adjective which means beaten by the wind and untidy."@en ;
  dcterms:modified "2026-06-07T15:30:29.351822Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1428-1
  a curric:KeyLearningPoint ;
  rdfs:label """When -ing is added to the end of a word, it can show the past tense or the present
  tense."""@en ;
  dcterms:modified "2026-06-07T15:30:29.351826Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1428-2
  a curric:KeyLearningPoint ;
  rdfs:label """If the root word has a short vowel and a single consonant, the consonant letter is
  doubled when the suffix is added."""@en ;
  dcterms:modified "2026-06-07T15:30:29.351830Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1428-3
  a curric:KeyLearningPoint ;
  rdfs:label "If the verb ends in a \"y\", just add \"-ing\"."@en ;
  dcterms:modified "2026-06-07T15:30:29.351834Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1428-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum word: answer."@en ;
  dcterms:modified "2026-06-07T15:30:29.351838Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8060-1
  a curric:KeyLearningPoint ;
  rdfs:label "‘The Song of the Whale’ was written by Kit Wright in 1982."@en ;
  dcterms:modified "2026-06-07T15:30:29.352512Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8060-2
  a curric:KeyLearningPoint ;
  rdfs:label """Whales face a multitude of threats from humans, which include hunting, pollution and
  captivity in zoos and water parks."""@en ;
  dcterms:modified "2026-06-07T15:30:29.352516Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8060-3
  a curric:KeyLearningPoint ;
  rdfs:label """‘The Panther’ was written by Rainer Maria Rilke between 1902 and 1903; it describes
  a captive panther behind bars."""@en ;
  dcterms:modified "2026-06-07T15:30:29.352520Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8060-4
  a curric:KeyLearningPoint ;
  rdfs:label "Themes of captivity and freedom can be found in both poems."@en ;
  dcterms:modified "2026-06-07T15:30:29.352524Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8060-5
  a curric:KeyLearningPoint ;
  rdfs:label """We can compare and contrast poems with similar themes or messages, noticing the
  impact that they have on us as readers."""@en ;
  dcterms:modified "2026-06-07T15:30:29.352528Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8467-1
  a curric:KeyLearningPoint ;
  rdfs:label "We use notes from our plan to form a range of sentence types."@en ;
  dcterms:modified "2026-06-07T15:30:29.352552Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8467-2
  a curric:KeyLearningPoint ;
  rdfs:label """Diary entries shift between past and present tense to explain what has happened and
  convey current thoughts/feelings."""@en ;
  dcterms:modified "2026-06-07T15:30:29.352556Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8467-3
  a curric:KeyLearningPoint ;
  rdfs:label "Subordinating conjunctions are used to begin an adverbial clause."@en ;
  dcterms:modified "2026-06-07T15:30:29.352559Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8467-4
  a curric:KeyLearningPoint ;
  rdfs:label """An adverbial clause is joined with a main clause to form an adverbial complex
  sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.352566Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8467-5
  a curric:KeyLearningPoint ;
  rdfs:label """Rhetorical questions are an effective way to convey thoughts and emotions in a diary
  entry."""@en ;
  dcterms:modified "2026-06-07T15:30:29.352570Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7868-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘The Wild Robot’ follows the unexpected arrival of a robot on an island after its
  crate is washed ashore during a storm."""@en ;
  dcterms:modified "2026-06-07T15:30:29.352574Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7868-2
  a curric:KeyLearningPoint ;
  rdfs:label """The robot, called Roz, learns human-like characteristics and emotions, such as care,
  friendship and love."""@en ;
  dcterms:modified "2026-06-07T15:30:29.352578Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7868-3
  a curric:KeyLearningPoint ;
  rdfs:label """'The Wild Robot' is in the form of an illustrated chapter book, combining words and
  illustration."""@en ;
  dcterms:modified "2026-06-07T15:30:29.352582Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7868-4
  a curric:KeyLearningPoint ;
  rdfs:label """'The Wild Robot' explores themes of identity, survival, adaptation, the natural
  world and technology."""@en ;
  dcterms:modified "2026-06-07T15:30:29.352586Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6110-1
  a curric:KeyLearningPoint ;
  rdfs:label "Information can be gathered from a range of different sources."@en ;
  dcterms:modified "2026-06-07T15:30:29.353601Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6110-2
  a curric:KeyLearningPoint ;
  rdfs:label "Credibility of each source must be determined."@en ;
  dcterms:modified "2026-06-07T15:30:29.353605Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6110-3
  a curric:KeyLearningPoint ;
  rdfs:label "Origin of a source must be cited."@en ;
  dcterms:modified "2026-06-07T15:30:29.353630Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6110-4
  a curric:KeyLearningPoint ;
  rdfs:label "Full sentences are not required when writing in note form."@en ;
  dcterms:modified "2026-06-07T15:30:29.353634Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6110-5
  a curric:KeyLearningPoint ;
  rdfs:label "Notes can be organised by theme using bullet points."@en ;
  dcterms:modified "2026-06-07T15:30:29.353656Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8059-1
  a curric:KeyLearningPoint ;
  rdfs:label """The poem describes the snow leopard as an elusive and majestic animal that lives in
  remote regions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.353692Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8059-2
  a curric:KeyLearningPoint ;
  rdfs:label """The poem can be described as a fixed verse poem; it consists of thirteen two-line
  verses and two single line verses."""@en ;
  dcterms:modified "2026-06-07T15:30:29.353696Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8059-3
  a curric:KeyLearningPoint ;
  rdfs:label "The poem uses enjambment to affect the pacing of the poem."@en ;
  dcterms:modified "2026-06-07T15:30:29.353700Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8059-4
  a curric:KeyLearningPoint ;
  rdfs:label """Imagery is used in the poem to convey the sights and sensations of the encounter
  between the snow leopard and the tahr."""@en ;
  dcterms:modified "2026-06-07T15:30:29.353706Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4823-1
  a curric:KeyLearningPoint ;
  rdfs:label "The title of the poem has a capital letter."@en ;
  dcterms:modified "2026-06-07T15:30:29.353749Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4823-2
  a curric:KeyLearningPoint ;
  rdfs:label "Each verse of the poem starts on a new line and with a capital letter."@en ;
  dcterms:modified "2026-06-07T15:30:29.353753Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4823-3
  a curric:KeyLearningPoint ;
  rdfs:label """After forming a capital letter, you need to lift your pencil to start the next part
  of the word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.353757Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4823-4
  a curric:KeyLearningPoint ;
  rdfs:label "The joins are all used correctly."@en ;
  dcterms:modified "2026-06-07T15:30:29.353762Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1128-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Diffident' is an adjective which means modest or shy."@en ;
  dcterms:modified "2026-06-07T15:30:29.353822Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1128-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Hesitant' is an adjective which means nervous or uncertain."@en ;
  dcterms:modified "2026-06-07T15:30:29.353826Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1128-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Reticent' is an adjective which means shy and reserved."@en ;
  dcterms:modified "2026-06-07T15:30:29.353830Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2715-1
  a curric:KeyLearningPoint ;
  rdfs:label """An explanation text is a non-fiction text providing information about how or why
  something works."""@en ;
  dcterms:modified "2026-06-07T15:30:29.353854Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2715-2
  a curric:KeyLearningPoint ;
  rdfs:label """The structure of an explanation text is an introduction, a sequence of paragraphs in
  chronological order and a closing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.353859Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2715-3
  a curric:KeyLearningPoint ;
  rdfs:label """Vocabulary used in an explanation text is subject-specific, factual and the tone is
  usually formal."""@en ;
  dcterms:modified "2026-06-07T15:30:29.353864Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2715-4
  a curric:KeyLearningPoint ;
  rdfs:label "Conjunctions ensure cohesion within sentences and paragraphs."@en ;
  dcterms:modified "2026-06-07T15:30:29.353868Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2715-5
  a curric:KeyLearningPoint ;
  rdfs:label "Explanation texts are written in the present tense."@en ;
  dcterms:modified "2026-06-07T15:30:29.353875Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2735-1
  a curric:KeyLearningPoint ;
  rdfs:label "A non-finite clause joined to a main clause forms a non-finite complex sentence."@en ;
  dcterms:modified "2026-06-07T15:30:29.353882Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2735-2
  a curric:KeyLearningPoint ;
  rdfs:label """The non-finite clause denotes ongoing action that relates to the subject of the main
  clause."""@en ;
  dcterms:modified "2026-06-07T15:30:29.353886Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2735-3
  a curric:KeyLearningPoint ;
  rdfs:label """The action of the non-finite clause occurs simultaneously to the action of the main
  clause."""@en ;
  dcterms:modified "2026-06-07T15:30:29.353890Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2735-4
  a curric:KeyLearningPoint ;
  rdfs:label """The non-finite clause can come first in the complex sentence followed by the main
  clause or vice versa."""@en ;
  dcterms:modified "2026-06-07T15:30:29.353894Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2735-5
  a curric:KeyLearningPoint ;
  rdfs:label """A comma is always used to demarcate the non-finite clause from the main clause
  despite its position in the sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.353898Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8478-1
  a curric:KeyLearningPoint ;
  rdfs:label """Lila’s quest intensifies in the build-up in Chapter 4 of ‘The Firework-Maker’s
  Daughter’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.353902Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8478-2
  a curric:KeyLearningPoint ;
  rdfs:label "Suspense is a key feature in the build-up of a story."@en ;
  dcterms:modified "2026-06-07T15:30:29.353906Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8478-3
  a curric:KeyLearningPoint ;
  rdfs:label """Moments of suspense keep the reader engaged and wanting to find out what happens
  next."""@en ;
  dcterms:modified "2026-06-07T15:30:29.353910Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8478-4
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to focus on moments of suspense when summarising the build-up of a
  story."""@en ;
  dcterms:modified "2026-06-07T15:30:29.353914Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8478-5
  a curric:KeyLearningPoint ;
  rdfs:label """Lila faces many setbacks on her journey which she has to show resilience and
  determination to overcome."""@en ;
  dcterms:modified "2026-06-07T15:30:29.353918Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6551-1
  a curric:KeyLearningPoint ;
  rdfs:label "An introductory sentence indicates what the paragraph will be about."@en ;
  dcterms:modified "2026-06-07T15:30:29.354026Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6551-2
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the main body paragraph is to specifically detail key persuasive
  arguments."""@en ;
  dcterms:modified "2026-06-07T15:30:29.354032Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6551-3
  a curric:KeyLearningPoint ;
  rdfs:label """Points backed up by evidence, statistics, quotes or anecdotes are more
  effective."""@en ;
  dcterms:modified "2026-06-07T15:30:29.354037Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6551-4
  a curric:KeyLearningPoint ;
  rdfs:label "Writing clearly and cohesively is a vital element of persuasion."@en ;
  dcterms:modified "2026-06-07T15:30:29.354041Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4808-1
  a curric:KeyLearningPoint ;
  rdfs:label """A suffix is a letter or group of letters at the end of a word which creates another
  word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.354231Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4808-2
  a curric:KeyLearningPoint ;
  rdfs:label "The words start with a lead in and finish with a lead out."@en ;
  dcterms:modified "2026-06-07T15:30:29.354235Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4808-3
  a curric:KeyLearningPoint ;
  rdfs:label """The pencil does not lift when forming the join, only after to add the cross to a t
  or a dot to an i or a j."""@en ;
  dcterms:modified "2026-06-07T15:30:29.354239Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4808-4
  a curric:KeyLearningPoint ;
  rdfs:label "There are four cursive joins."@en ;
  dcterms:modified "2026-06-07T15:30:29.354243Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4808-5
  a curric:KeyLearningPoint ;
  rdfs:label """The join used depends on which letter is joining to which letter within a letter
  string."""@en ;
  dcterms:modified "2026-06-07T15:30:29.354247Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1436-1
  a curric:KeyLearningPoint ;
  rdfs:label "-y is a suffix that can be used to change some nouns into adjectives."@en ;
  dcterms:modified "2026-06-07T15:30:29.354312Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1436-2
  a curric:KeyLearningPoint ;
  rdfs:label "For some root words you can just add the suffix \"-y\"."@en ;
  dcterms:modified "2026-06-07T15:30:29.354316Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1436-3
  a curric:KeyLearningPoint ;
  rdfs:label "For root words ending in 'e', you remove the 'e' and just add -y."@en ;
  dcterms:modified "2026-06-07T15:30:29.354322Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1436-4
  a curric:KeyLearningPoint ;
  rdfs:label "For root words with a short vowel sound, you double the consonant and add -y."@en ;
  dcterms:modified "2026-06-07T15:30:29.354327Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1436-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum word: arrive."@en ;
  dcterms:modified "2026-06-07T15:30:29.354331Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1099-1
  a curric:KeyLearningPoint ;
  rdfs:label """'Treacherous' is an adjective which means dangerous or unsafe; like terrifying
  rapids."""@en ;
  dcterms:modified "2026-06-07T15:30:29.354394Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1099-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Murky' is an adjective which means dark, muddy or cloudy; like water that’s so
  dirty you can barely see through it."""@en ;
  dcterms:modified "2026-06-07T15:30:29.354398Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1099-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Stagnant' is an adjective which means stale or lifeless; like a dirty pond where
  nothing is living or moving."""@en ;
  dcterms:modified "2026-06-07T15:30:29.354403Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1099-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Choppy', 'frothy' and 'shimmering' are other rich vocabulary associated
  with water."""@en ;
  dcterms:modified "2026-06-07T15:30:29.354407Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8642-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the build-up is to build action and suspense leading up to the
  climax."""@en ;
  dcterms:modified "2026-06-07T15:30:29.354410Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8642-2
  a curric:KeyLearningPoint ;
  rdfs:label """In this section of the build-up, Arrietty explores the outside world and spots the
  eye of a human “bean”."""@en ;
  dcterms:modified "2026-06-07T15:30:29.354414Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8642-3
  a curric:KeyLearningPoint ;
  rdfs:label "The atmosphere and Arrietty’s emotions shift after she spots the eye."@en ;
  dcterms:modified "2026-06-07T15:30:29.354418Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8642-4
  a curric:KeyLearningPoint ;
  rdfs:label """A range of precise and ambitious vocabulary, including ‘show and tell’ language, is
  used to describe key moments."""@en ;
  dcterms:modified "2026-06-07T15:30:29.354422Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8642-5
  a curric:KeyLearningPoint ;
  rdfs:label """‘Show and tell’ language shows a character’s feelings by describing their actions,
  body language and facial expressions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.354427Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6379-1
  a curric:KeyLearningPoint ;
  rdfs:label """Reciting a text provides an important opportunity for developing speaking and
  listening skills."""@en ;
  dcterms:modified "2026-06-07T15:30:29.356171Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6379-2
  a curric:KeyLearningPoint ;
  rdfs:label "Speakers need to consider how to keep their audience engaged during a recital."@en ;
  dcterms:modified "2026-06-07T15:30:29.356174Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6379-3
  a curric:KeyLearningPoint ;
  rdfs:label """Speakers can use a range of techniques to ensure that they can be clearly heard and
  are engaging for the audience."""@en ;
  dcterms:modified "2026-06-07T15:30:29.356178Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6379-4
  a curric:KeyLearningPoint ;
  rdfs:label "Memorising a text can enable a more coherent recital."@en ;
  dcterms:modified "2026-06-07T15:30:29.356182Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6379-5
  a curric:KeyLearningPoint ;
  rdfs:label "We can use a range of strategies to support us with memorising a text."@en ;
  dcterms:modified "2026-06-07T15:30:29.356186Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5469-1
  a curric:KeyLearningPoint ;
  rdfs:label "A moral is a lesson that can be learnt from a story or experience."@en ;
  dcterms:modified "2026-06-07T15:30:29.356239Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5469-2
  a curric:KeyLearningPoint ;
  rdfs:label """Exploring character traits and themes within a folktale can help us infer a moral
  from the story."""@en ;
  dcterms:modified "2026-06-07T15:30:29.356243Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5469-3
  a curric:KeyLearningPoint ;
  rdfs:label """Readers may have different interpretations of a text, its meaning or the moral drawn
  from it."""@en ;
  dcterms:modified "2026-06-07T15:30:29.356247Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5469-4
  a curric:KeyLearningPoint ;
  rdfs:label """Personal responses to a story may vary as a result of an individual's own life
  experiences."""@en ;
  dcterms:modified "2026-06-07T15:30:29.356251Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5469-5
  a curric:KeyLearningPoint ;
  rdfs:label """Making comparisons between a story and our life experiences can help us reflect on
  our own character and actions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.356255Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6729-1
  a curric:KeyLearningPoint ;
  rdfs:label "Writing is most successful when structure, content and vocabulary are planned."@en ;
  dcterms:modified "2026-06-07T15:30:29.356279Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6729-2
  a curric:KeyLearningPoint ;
  rdfs:label """We aim to use a range of narrative elements in our writing and to set an appropriate
  mood with them."""@en ;
  dcterms:modified "2026-06-07T15:30:29.356283Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6729-3
  a curric:KeyLearningPoint ;
  rdfs:label """We use a range of cohesive devices to connect ideas, including a variety of fronted
  adverbials."""@en ;
  dcterms:modified "2026-06-07T15:30:29.356286Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6729-4
  a curric:KeyLearningPoint ;
  rdfs:label "We can create compound adjectives using hyphens to add descriptive detail."@en ;
  dcterms:modified "2026-06-07T15:30:29.356290Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6729-5
  a curric:KeyLearningPoint ;
  rdfs:label "We can use dialogue to add to the tense mood of our writing."@en ;
  dcterms:modified "2026-06-07T15:30:29.356294Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6279-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘Crazy About Cats’ encourages various connections: text-to-self, text-to-text, and
  text-to-world."""@en ;
  dcterms:modified "2026-06-07T15:30:29.356298Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6279-2
  a curric:KeyLearningPoint ;
  rdfs:label """Through real-world connections, non-fiction texts can inspire positive actions and
  change in readers."""@en ;
  dcterms:modified "2026-06-07T15:30:29.356302Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6279-3
  a curric:KeyLearningPoint ;
  rdfs:label """Readers can summarise main ideas of non-fiction texts by returning to the contents
  page to reflect on their reading."""@en ;
  dcterms:modified "2026-06-07T15:30:29.356306Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6279-4
  a curric:KeyLearningPoint ;
  rdfs:label "Owen Davey uses a range of formal and informal language to engage the reader."@en ;
  dcterms:modified "2026-06-07T15:30:29.356310Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6279-5
  a curric:KeyLearningPoint ;
  rdfs:label "Readers can focus on a number of features of the text to consider its purpose."@en ;
  dcterms:modified "2026-06-07T15:30:29.356314Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9047-1
  a curric:KeyLearningPoint ;
  rdfs:label """Character traits can be explored through the text’s illustrations or words used by
  the characters."""@en ;
  dcterms:modified "2026-06-07T15:30:29.356398Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9047-2
  a curric:KeyLearningPoint ;
  rdfs:label """Friendships and relationships within the story are not wholly positive; they are
  complex and changeable."""@en ;
  dcterms:modified "2026-06-07T15:30:29.356402Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9047-3
  a curric:KeyLearningPoint ;
  rdfs:label """Making connections and recommendations can enhance the reading experience and
  broaden understanding of literature."""@en ;
  dcterms:modified "2026-06-07T15:30:29.356406Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1324-1
  a curric:KeyLearningPoint ;
  rdfs:label """Two or more words that are spelt the same but have different meanings are called
  homonyms."""@en ;
  dcterms:modified "2026-06-07T15:30:29.356456Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1324-2
  a curric:KeyLearningPoint ;
  rdfs:label """Some homonyms are spelt the same, but have contrasting sounds and different meanings
  (e.g. tear, wind, wound or read)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.356460Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1324-3
  a curric:KeyLearningPoint ;
  rdfs:label "The meaning and word class of homonyms can be determined by their context."@en ;
  dcterms:modified "2026-06-07T15:30:29.356466Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1324-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: community and leisure."@en ;
  dcterms:modified "2026-06-07T15:30:29.356470Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5772-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the main body is to describe events, thoughts and feelings in
  detail."""@en ;
  dcterms:modified "2026-06-07T15:30:29.356506Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5772-2
  a curric:KeyLearningPoint ;
  rdfs:label "Sentences can be opened in a variety of ways to enhance text cohesion."@en ;
  dcterms:modified "2026-06-07T15:30:29.356509Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5772-3
  a curric:KeyLearningPoint ;
  rdfs:label """Adverbial complex sentences consist of a main clause and an adverbial subordinate
  clause."""@en ;
  dcterms:modified "2026-06-07T15:30:29.356513Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5772-4
  a curric:KeyLearningPoint ;
  rdfs:label "Informal tone can be achieved through use of contractions and exclamations."@en ;
  dcterms:modified "2026-06-07T15:30:29.356517Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27780-1
  a curric:KeyLearningPoint ;
  rdfs:label """Michelle Obama is an American lawyer and author who served as the First Lady of the
  United States from 2009 to 2017."""@en ;
  dcterms:modified "2026-06-07T15:30:29.356521Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27780-2
  a curric:KeyLearningPoint ;
  rdfs:label """Successful public speaking includes speaking loudly and clearly and engaging the
  audience."""@en ;
  dcterms:modified "2026-06-07T15:30:29.356525Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27780-3
  a curric:KeyLearningPoint ;
  rdfs:label "A speech is written for a specific audience in order to achieve its purpose."@en ;
  dcterms:modified "2026-06-07T15:30:29.356529Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27780-4
  a curric:KeyLearningPoint ;
  rdfs:label """A speaker can engage an audience through a variety of techniques, including
  rhetorical questions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.356533Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28386-1
  a curric:KeyLearningPoint ;
  rdfs:label """In the poem ‘I’m an Orchestra’, Laura Mucha compares the emotional life of a human
  to an orchestra."""@en ;
  dcterms:modified "2026-06-07T15:30:29.356633Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28386-2
  a curric:KeyLearningPoint ;
  rdfs:label """Poets might use devices such as repetition, rhyme or alliteration to enhance the
  sound of the poem read aloud."""@en ;
  dcterms:modified "2026-06-07T15:30:29.356637Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28386-3
  a curric:KeyLearningPoint ;
  rdfs:label "A metaphor is a way of describing something by saying that it is something else."@en ;
  dcterms:modified "2026-06-07T15:30:29.356641Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28386-4
  a curric:KeyLearningPoint ;
  rdfs:label """Alliteration is when words that begin with the same sound are placed close
  together."""@en ;
  dcterms:modified "2026-06-07T15:30:29.356645Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28386-5
  a curric:KeyLearningPoint ;
  rdfs:label """Marking up a poem for performance involves adding notes to guide delivery,
  emphasising elements like tone & pace."""@en ;
  dcterms:modified "2026-06-07T15:30:29.356649Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7898-1
  a curric:KeyLearningPoint ;
  rdfs:label "A theme is a big idea, topic or message that recurs within a story."@en ;
  dcterms:modified "2026-06-07T15:30:29.356653Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7898-2
  a curric:KeyLearningPoint ;
  rdfs:label """Themes can be incredibly relevant and link to significant issues regardless of the
  time in which the text was written."""@en ;
  dcterms:modified "2026-06-07T15:30:29.356657Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7898-3
  a curric:KeyLearningPoint ;
  rdfs:label "At the end of the text, the author offers resolutions to many of the characters."@en ;
  dcterms:modified "2026-06-07T15:30:29.356661Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7898-4
  a curric:KeyLearningPoint ;
  rdfs:label """The theme of identity is conveyed through Oliver’s emotional journey to finding out
  who he is; it is a central theme."""@en ;
  dcterms:modified "2026-06-07T15:30:29.356665Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8014-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘MORERAPS’ is a type of poem that Joseph Coelho invented to help him remember the
  different poetic devices."""@en ;
  dcterms:modified "2026-06-07T15:30:29.356669Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8014-2
  a curric:KeyLearningPoint ;
  rdfs:label """A poetic device is a technique used by poets to enhance the meaning, sound and
  overall impact of their poems."""@en ;
  dcterms:modified "2026-06-07T15:30:29.356672Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8014-3
  a curric:KeyLearningPoint ;
  rdfs:label """A metaphor is a word or phrase that is used to describe something as if it is
  something else."""@en ;
  dcterms:modified "2026-06-07T15:30:29.356676Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8014-4
  a curric:KeyLearningPoint ;
  rdfs:label """Alliteration is the repetition of the same sound found at the start of words that
  come close together."""@en ;
  dcterms:modified "2026-06-07T15:30:29.356680Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8025-1
  a curric:KeyLearningPoint ;
  rdfs:label """Free verse poems do not require the poet to follow poetic rules, but tend to follow
  the rhythm of natural speech."""@en ;
  dcterms:modified "2026-06-07T15:30:29.356684Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8025-2
  a curric:KeyLearningPoint ;
  rdfs:label """Free verse poems may include a range of poetic techniques such as: alliteration,
  kennings and rhyme."""@en ;
  dcterms:modified "2026-06-07T15:30:29.356688Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8025-3
  a curric:KeyLearningPoint ;
  rdfs:label "Verse refers to a single line or a group of lines within a poem."@en ;
  dcterms:modified "2026-06-07T15:30:29.356692Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8025-4
  a curric:KeyLearningPoint ;
  rdfs:label """Rhyme in poetry is the similarity of sounds between the ending syllables of
  words."""@en ;
  dcterms:modified "2026-06-07T15:30:29.356698Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8025-5
  a curric:KeyLearningPoint ;
  rdfs:label """Poems can evoke a positive or negative emotion and a poet must carefully consider
  what atmosphere they wish to create."""@en ;
  dcterms:modified "2026-06-07T15:30:29.356702Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28412-1
  a curric:KeyLearningPoint ;
  rdfs:label "To improvise means to make something up on the spot and in the moment."@en ;
  dcterms:modified "2026-06-07T15:30:29.356706Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28412-2
  a curric:KeyLearningPoint ;
  rdfs:label "Actors often work together to improvise scenes."@en ;
  dcterms:modified "2026-06-07T15:30:29.356710Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28412-3
  a curric:KeyLearningPoint ;
  rdfs:label "A team of actors is called a cast."@en ;
  dcterms:modified "2026-06-07T15:30:29.356716Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28412-4
  a curric:KeyLearningPoint ;
  rdfs:label "Improvising involves being creative, being quick-thinking and working as a team."@en ;
  dcterms:modified "2026-06-07T15:30:29.356721Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6219-1
  a curric:KeyLearningPoint ;
  rdfs:label """Our essay will give one side of an argument, using a logical order that is supported
  by evidence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.356725Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6219-2
  a curric:KeyLearningPoint ;
  rdfs:label "Evidence can take many forms, including explanations, facts and statistics."@en ;
  dcterms:modified "2026-06-07T15:30:29.356729Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6219-3
  a curric:KeyLearningPoint ;
  rdfs:label """In the first main paragraph, we will explain why deforestation has occurred in the
  Amazon."""@en ;
  dcterms:modified "2026-06-07T15:30:29.356733Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6219-4
  a curric:KeyLearningPoint ;
  rdfs:label "We will include subject-specific vocabulary and a range of linguistic features."@en ;
  dcterms:modified "2026-06-07T15:30:29.356736Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5699-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the climax is to give the reader the most dramatic action and
  increase the tension to its height."""@en ;
  dcterms:modified "2026-06-07T15:30:29.356743Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5699-2
  a curric:KeyLearningPoint ;
  rdfs:label "Precise and ambitious vocabulary is logged in a plan for future use."@en ;
  dcterms:modified "2026-06-07T15:30:29.356747Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5699-3
  a curric:KeyLearningPoint ;
  rdfs:label """Notes should not be written in full sentences and bullet points can be used to make
  notes clear."""@en ;
  dcterms:modified "2026-06-07T15:30:29.356751Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5699-4
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials of time, place and manner indicate when, where and how an action
  takes place."""@en ;
  dcterms:modified "2026-06-07T15:30:29.356755Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4851-1
  a curric:KeyLearningPoint ;
  rdfs:label "An introductory sentence explains what the paragraph is about."@en ;
  dcterms:modified "2026-06-07T15:30:29.356804Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4851-2
  a curric:KeyLearningPoint ;
  rdfs:label """Relative clauses give more detail about the sentence’s subject and they begin with
  relative pronouns ‘who’ or ‘which’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.356808Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4851-3
  a curric:KeyLearningPoint ;
  rdfs:label """Conveying extra information (parenthesis) inside brackets is a tool for giving the
  reader lots of specific information."""@en ;
  dcterms:modified "2026-06-07T15:30:29.356812Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4851-4
  a curric:KeyLearningPoint ;
  rdfs:label """Journalistic reports are formal in tone and they communicate information to the
  reader in a clear, succinct way."""@en ;
  dcterms:modified "2026-06-07T15:30:29.356816Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4851-5
  a curric:KeyLearningPoint ;
  rdfs:label """Journalistic tone is objective; the journalist does not offer their own personal
  opinion."""@en ;
  dcterms:modified "2026-06-07T15:30:29.356821Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1115-1
  a curric:KeyLearningPoint ;
  rdfs:label "Overcast is an adjective which means cloudy or grey."@en ;
  dcterms:modified "2026-06-07T15:30:29.356826Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1115-2
  a curric:KeyLearningPoint ;
  rdfs:label "Swirling is an adjective which means spiralling or twirling."@en ;
  dcterms:modified "2026-06-07T15:30:29.356830Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1115-3
  a curric:KeyLearningPoint ;
  rdfs:label "Wispy is an adjective which means thin or fine."@en ;
  dcterms:modified "2026-06-07T15:30:29.356834Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7666-1
  a curric:KeyLearningPoint ;
  rdfs:label """This emotive scene is written over two paragraphs and it is important to demonstrate
  a change in atmosphere across them."""@en ;
  dcterms:modified "2026-06-07T15:30:29.356939Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7666-2
  a curric:KeyLearningPoint ;
  rdfs:label """Using a range of sentence types (simple, compound and complex) improves text flow
  and cohesion."""@en ;
  dcterms:modified "2026-06-07T15:30:29.356943Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7666-3
  a curric:KeyLearningPoint ;
  rdfs:label """Precise and ambitious vocabulary, including 'show-not-tell' language, is used to
  convey an emotive atmosphere."""@en ;
  dcterms:modified "2026-06-07T15:30:29.356947Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7666-4
  a curric:KeyLearningPoint ;
  rdfs:label """‘Show-not-tell’ shows a character’s feelings with description of their actions, body
  language and facial expressions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.356951Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7666-5
  a curric:KeyLearningPoint ;
  rdfs:label """Oral rehearsal before writing helps to structure grammatically correct sentences and
  check for sense."""@en ;
  dcterms:modified "2026-06-07T15:30:29.356955Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6758-1
  a curric:KeyLearningPoint ;
  rdfs:label """Editing is a critical part of the writing process. A growth mindset helps us benefit
  most from editing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.356970Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6758-2
  a curric:KeyLearningPoint ;
  rdfs:label """Writing is most successful when editing is used to rethink, rephrase and reconsider
  first ideas."""@en ;
  dcterms:modified "2026-06-07T15:30:29.356974Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6758-3
  a curric:KeyLearningPoint ;
  rdfs:label """Editing is most successful when it is chunked by punctuation, sentence structure,
  vocabulary and cohesive devices."""@en ;
  dcterms:modified "2026-06-07T15:30:29.356978Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6758-4
  a curric:KeyLearningPoint ;
  rdfs:label """We can connect ideas in a range of different ways, using different cohesive devices
  - there is rarely only one way."""@en ;
  dcterms:modified "2026-06-07T15:30:29.356984Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6758-5
  a curric:KeyLearningPoint ;
  rdfs:label """We use a less formal tone when quoting real people's speech; we use a formal tone
  elsewhere in our text."""@en ;
  dcterms:modified "2026-06-07T15:30:29.356989Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1434-1
  a curric:KeyLearningPoint ;
  rdfs:label """For words containing an 'f' change the 'f' to a 'v' and add the suffix -es to turn
  them into a plural."""@en ;
  dcterms:modified "2026-06-07T15:30:29.357030Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1434-2
  a curric:KeyLearningPoint ;
  rdfs:label "For words ending in an 'o', add the suffix -es to turn them into a plural."@en ;
  dcterms:modified "2026-06-07T15:30:29.357034Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1434-3
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum word: guard."@en ;
  dcterms:modified "2026-06-07T15:30:29.357040Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5487-1
  a curric:KeyLearningPoint ;
  rdfs:label "‘Escape from Pompeii’ is written from the perspective of Tranio, a young boy."@en ;
  dcterms:modified "2026-06-07T15:30:29.358676Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5487-2
  a curric:KeyLearningPoint ;
  rdfs:label "Characterisation can change over the course of a text’s narrative."@en ;
  dcterms:modified "2026-06-07T15:30:29.358680Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5487-3
  a curric:KeyLearningPoint ;
  rdfs:label """Characterisation can be conveyed through a character’s appearance, their dialogue
  and actions they perform in the text."""@en ;
  dcterms:modified "2026-06-07T15:30:29.358684Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7944-1
  a curric:KeyLearningPoint ;
  rdfs:label """Character traits can be explored through the text’s illustrations or words used by
  the characters."""@en ;
  dcterms:modified "2026-06-07T15:30:29.358804Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7944-2
  a curric:KeyLearningPoint ;
  rdfs:label "Different readers may interpret a text in different ways."@en ;
  dcterms:modified "2026-06-07T15:30:29.358808Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7944-3
  a curric:KeyLearningPoint ;
  rdfs:label """Discussing books by building on other books and our own views can help us to deepen
  our understanding of a text."""@en ;
  dcterms:modified "2026-06-07T15:30:29.358812Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7856-1
  a curric:KeyLearningPoint ;
  rdfs:label "El Deafo is a graphic novel memoir based on author Cece Bell's childhood."@en ;
  dcterms:modified "2026-06-07T15:30:29.359927Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7856-2
  a curric:KeyLearningPoint ;
  rdfs:label """At the age of four, in 1974, Cece is diagnosed as deaf, following a bout of
  meningitis."""@en ;
  dcterms:modified "2026-06-07T15:30:29.359931Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7856-3
  a curric:KeyLearningPoint ;
  rdfs:label "The narrative follows her journey using a hearing aid and starting school."@en ;
  dcterms:modified "2026-06-07T15:30:29.359935Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7856-4
  a curric:KeyLearningPoint ;
  rdfs:label """Graphic novels have many unique elements which allow readers to make meaning from
  both words and image."""@en ;
  dcterms:modified "2026-06-07T15:30:29.359944Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7856-5
  a curric:KeyLearningPoint ;
  rdfs:label """People may use Deaf and deaf terms differently based on their personal preferences
  and experiences."""@en ;
  dcterms:modified "2026-06-07T15:30:29.359948Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5472-1
  a curric:KeyLearningPoint ;
  rdfs:label "Reading between the lines to search for clues can help to infer meaning."@en ;
  dcterms:modified "2026-06-07T15:30:29.359989Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5472-2
  a curric:KeyLearningPoint ;
  rdfs:label "Evidence from the text helps us to justify our inferences."@en ;
  dcterms:modified "2026-06-07T15:30:29.359993Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5472-3
  a curric:KeyLearningPoint ;
  rdfs:label "Asking questions provides an opportunity to deepen our understanding of a text."@en ;
  dcterms:modified "2026-06-07T15:30:29.359997Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7187-1
  a curric:KeyLearningPoint ;
  rdfs:label """The opening of 'The Firework-Maker's Daughter' can be streamlined into four key
  moments."""@en ;
  dcterms:modified "2026-06-07T15:30:29.360062Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7187-2
  a curric:KeyLearningPoint ;
  rdfs:label "Lila's emotions shift and change over the course of these four key moments."@en ;
  dcterms:modified "2026-06-07T15:30:29.360066Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7187-3
  a curric:KeyLearningPoint ;
  rdfs:label "Using empathy can help us develop a greater understanding of Lila's perspective."@en ;
  dcterms:modified "2026-06-07T15:30:29.360070Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7187-4
  a curric:KeyLearningPoint ;
  rdfs:label "We can develop thoughts for Lila that convey and express her emotions."@en ;
  dcterms:modified "2026-06-07T15:30:29.360077Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7187-5
  a curric:KeyLearningPoint ;
  rdfs:label """Emotions can be stated explicitly or conveyed through choice of words and
  phrases."""@en ;
  dcterms:modified "2026-06-07T15:30:29.360081Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7349-1
  a curric:KeyLearningPoint ;
  rdfs:label """The introduction of Scrooge’s character greatly contrasts the general Christmas
  atmosphere in the opening."""@en ;
  dcterms:modified "2026-06-07T15:30:29.360388Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7349-2
  a curric:KeyLearningPoint ;
  rdfs:label """Precise vocabulary, including ‘show and tell’ and direct speech, conveys a
  character’s traits and feelings."""@en ;
  dcterms:modified "2026-06-07T15:30:29.360392Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7349-3
  a curric:KeyLearningPoint ;
  rdfs:label "Using a range of simple, compound and complex sentences supports text flow."@en ;
  dcterms:modified "2026-06-07T15:30:29.360396Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7349-4
  a curric:KeyLearningPoint ;
  rdfs:label """A relative complex sentence uses a relative pronoun (who or which) to provide
  greater detail about a noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.360400Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7349-5
  a curric:KeyLearningPoint ;
  rdfs:label """Inverted commas are used to demarcate speech and a piece of punctuation separates
  speech from the reporting clause."""@en ;
  dcterms:modified "2026-06-07T15:30:29.360404Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6734-1
  a curric:KeyLearningPoint ;
  rdfs:label """The Scottish witch trials occurred during the 16th, 17th and early 18th centuries in
  Scotland."""@en ;
  dcterms:modified "2026-06-07T15:30:29.360408Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6734-2
  a curric:KeyLearningPoint ;
  rdfs:label "Individuals who were prosecuted as witches were often executed."@en ;
  dcterms:modified "2026-06-07T15:30:29.360412Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6734-3
  a curric:KeyLearningPoint ;
  rdfs:label "Witches were recognised by the church as being capable of causing real harm."@en ;
  dcterms:modified "2026-06-07T15:30:29.360416Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6734-4
  a curric:KeyLearningPoint ;
  rdfs:label "Witches were seen as linked to the devil and were therefore also heretical."@en ;
  dcterms:modified "2026-06-07T15:30:29.360420Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6734-5
  a curric:KeyLearningPoint ;
  rdfs:label """Life at this time was very much dominated by the church and the desire to stamp out
  any connections to the devil."""@en ;
  dcterms:modified "2026-06-07T15:30:29.360424Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7919-1
  a curric:KeyLearningPoint ;
  rdfs:label "When we read texts, we connect them to our own experiences and to 'big ideas'."@en ;
  dcterms:modified "2026-06-07T15:30:29.360461Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7919-2
  a curric:KeyLearningPoint ;
  rdfs:label "We can identify these 'big ideas' using concepts and themes."@en ;
  dcterms:modified "2026-06-07T15:30:29.360464Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7919-3
  a curric:KeyLearningPoint ;
  rdfs:label """Readers may interpret texts differently based on their reading of the material or
  their own experiences and beliefs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.360468Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7919-4
  a curric:KeyLearningPoint ;
  rdfs:label """We can support our views about concepts and themes linked to a text by providing
  evidence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.360472Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6759-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of an essay can be to present a coherent argument in response to a
  question or statement."""@en ;
  dcterms:modified "2026-06-07T15:30:29.360476Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6759-2
  a curric:KeyLearningPoint ;
  rdfs:label """To meet its purpose effectively, the tone of an essay must be formal and
  informative."""@en ;
  dcterms:modified "2026-06-07T15:30:29.360480Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6759-3
  a curric:KeyLearningPoint ;
  rdfs:label """Using correct linguistic features of an essay enables writers to meet the text's
  purpose."""@en ;
  dcterms:modified "2026-06-07T15:30:29.360484Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2706-1
  a curric:KeyLearningPoint ;
  rdfs:label "An apostrophe is an important piece of punctuation with more than one purpose."@en ;
  dcterms:modified "2026-06-07T15:30:29.360488Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2706-2
  a curric:KeyLearningPoint ;
  rdfs:label "An apostrophe can contract two words together."@en ;
  dcterms:modified "2026-06-07T15:30:29.360492Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2706-3
  a curric:KeyLearningPoint ;
  rdfs:label "An apostrophe can show if a noun belongs to another singular noun."@en ;
  dcterms:modified "2026-06-07T15:30:29.360495Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2706-4
  a curric:KeyLearningPoint ;
  rdfs:label "An apostrophe can show if a noun belongs to another plural noun."@en ;
  dcterms:modified "2026-06-07T15:30:29.360499Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2706-5
  a curric:KeyLearningPoint ;
  rdfs:label """Apostrophes for contraction and possession are useful in writing for different
  reasons."""@en ;
  dcterms:modified "2026-06-07T15:30:29.360503Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6719-1
  a curric:KeyLearningPoint ;
  rdfs:label """Darwin proposed the theory of evolution by natural selection to explain animals'
  adaptations."""@en ;
  dcterms:modified "2026-06-07T15:30:29.360556Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6719-2
  a curric:KeyLearningPoint ;
  rdfs:label """The theory is based on the idea that within a species, there are variations and
  competition."""@en ;
  dcterms:modified "2026-06-07T15:30:29.360560Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6719-3
  a curric:KeyLearningPoint ;
  rdfs:label """Within a habitat, some individuals will be better-adapted and others will be
  less-well-adapted."""@en ;
  dcterms:modified "2026-06-07T15:30:29.360564Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6719-4
  a curric:KeyLearningPoint ;
  rdfs:label """The better-adapted individuals are more likely to survive and reproduce, passing on
  these advantageous characteristics."""@en ;
  dcterms:modified "2026-06-07T15:30:29.360568Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6719-5
  a curric:KeyLearningPoint ;
  rdfs:label """Over a huge period of time, the advantageous characteristics become normal in the
  species (or can create a new species)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.360572Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1381-1
  a curric:KeyLearningPoint ;
  rdfs:label """When adding suffixes to words ending in ‘fer’, the ‘r’ is doubled if the –fer is
  still stressed."""@en ;
  dcterms:modified "2026-06-07T15:30:29.360576Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1381-2
  a curric:KeyLearningPoint ;
  rdfs:label "The ‘r’ is not doubled if the ‘fer’ is no longer stressed."@en ;
  dcterms:modified "2026-06-07T15:30:29.360580Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1381-3
  a curric:KeyLearningPoint ;
  rdfs:label """We can use a range of strategies to practise spellings and help embed them in our
  memory."""@en ;
  dcterms:modified "2026-06-07T15:30:29.360584Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1381-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: purpose and suppose."@en ;
  dcterms:modified "2026-06-07T15:30:29.360590Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1380-1
  a curric:KeyLearningPoint ;
  rdfs:label """When adding suffixes to words ending ‘fer’, the ‘r’ is doubled if the 'fer' is still
  stressed when the ending is added."""@en ;
  dcterms:modified "2026-06-07T15:30:29.360596Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1380-2
  a curric:KeyLearningPoint ;
  rdfs:label "The ‘r’ is not doubled if the ‘fer’ is no longer stressed."@en ;
  dcterms:modified "2026-06-07T15:30:29.360600Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1380-3
  a curric:KeyLearningPoint ;
  rdfs:label """We can use word maps to link related words and identify connections in the meaning
  and spelling of words."""@en ;
  dcterms:modified "2026-06-07T15:30:29.360604Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1380-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: sincere and sincerely."@en ;
  dcterms:modified "2026-06-07T15:30:29.360608Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1387-1
  a curric:KeyLearningPoint ;
  rdfs:label """There are many ways to spell the ‘ee’ sound, including ‘ee’, ‘ea’, ‘e-e’, ‘e’, ‘y’,
  ‘ey’, ‘ie’ and ‘ei’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.360628Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1387-2
  a curric:KeyLearningPoint ;
  rdfs:label """The rule ‘i before e except after c’ can help choose between ‘ie’ and ‘ei’ when
  spelling ‘ee’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.360631Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1387-3
  a curric:KeyLearningPoint ;
  rdfs:label """The letter string ‘ei’ can represent a range of different sounds, including
  ‘ay’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.360635Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1387-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: height, eighth and foreign."@en ;
  dcterms:modified "2026-06-07T15:30:29.360640Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8009-1
  a curric:KeyLearningPoint ;
  rdfs:label "Joseph Coelho is a British poet and children’s author."@en ;
  dcterms:modified "2026-06-07T15:30:29.360709Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8009-2
  a curric:KeyLearningPoint ;
  rdfs:label """Joseph Coelho is known for using engaging and emotive themes in his poetry, such as
  identity, family and friendship."""@en ;
  dcterms:modified "2026-06-07T15:30:29.360713Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8009-3
  a curric:KeyLearningPoint ;
  rdfs:label """In 2014, he had his very first poetry collection published called ‘Werewolf Club
  Rules’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.360716Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8009-4
  a curric:KeyLearningPoint ;
  rdfs:label """He was appointed Children’s Laureate in 2022 to celebrate his exceptional
  talent."""@en ;
  dcterms:modified "2026-06-07T15:30:29.360722Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1453-1
  a curric:KeyLearningPoint ;
  rdfs:label "A homonym is a word which has the same spelling but multiple meanings."@en ;
  dcterms:modified "2026-06-07T15:30:29.360745Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1453-2
  a curric:KeyLearningPoint ;
  rdfs:label "The meaning of a homonym is dependent on the context."@en ;
  dcterms:modified "2026-06-07T15:30:29.360749Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1453-3
  a curric:KeyLearningPoint ;
  rdfs:label "Using the strategy 'pyramid letters' is a useful practice strategy."@en ;
  dcterms:modified "2026-06-07T15:30:29.360753Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1453-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum word: surprise."@en ;
  dcterms:modified "2026-06-07T15:30:29.360757Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1360-1
  a curric:KeyLearningPoint ;
  rdfs:label """In words of French origin, the 'sh' sound is generally spelt 'ch', the 'g' sound is
  'gue' and the 'k' sound is 'que'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.360826Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1360-2
  a curric:KeyLearningPoint ;
  rdfs:label "In words of Latin origin, the 's' sound is generally spelt 'sc'."@en ;
  dcterms:modified "2026-06-07T15:30:29.360830Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1360-3
  a curric:KeyLearningPoint ;
  rdfs:label """In words of Greek origin, the 'k' sound is generally spelt 'ch' and the 'f' sound is
  'ph'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.360834Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1360-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: interfere, signature."@en ;
  dcterms:modified "2026-06-07T15:30:29.360838Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6009-1
  a curric:KeyLearningPoint ;
  rdfs:label """A written argument tries to convince the reader of something using strong reasoning
  to support."""@en ;
  dcterms:modified "2026-06-07T15:30:29.360961Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6009-2
  a curric:KeyLearningPoint ;
  rdfs:label "The PEPS structure stands for: point, explanation, proof, summary."@en ;
  dcterms:modified "2026-06-07T15:30:29.360967Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6009-3
  a curric:KeyLearningPoint ;
  rdfs:label """Formal fronted adverbials are formal in tone and link one sentence to the previous
  sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.360971Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6009-4
  a curric:KeyLearningPoint ;
  rdfs:label """A fronted adverbial of cause is a sentence starter that tells the reader the cause
  and effect of something."""@en ;
  dcterms:modified "2026-06-07T15:30:29.360977Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1034-1
  a curric:KeyLearningPoint ;
  rdfs:label "A subheading signals to the reader what the section is about."@en ;
  dcterms:modified "2026-06-07T15:30:29.360981Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1034-2
  a curric:KeyLearningPoint ;
  rdfs:label """A section about one feature of the report's subject contains specific facts and
  information to keep the reader engaged."""@en ;
  dcterms:modified "2026-06-07T15:30:29.360985Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1034-3
  a curric:KeyLearningPoint ;
  rdfs:label """Writers choose varied fronted adverbials and different sentence types to ensure the
  text flows for the reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.360989Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1034-4
  a curric:KeyLearningPoint ;
  rdfs:label "A section can be composed of one paragraph."@en ;
  dcterms:modified "2026-06-07T15:30:29.360995Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1034-5
  a curric:KeyLearningPoint ;
  rdfs:label """Sentences should be said aloud before writing to ensure they make sense and read
  back once written to check for errors."""@en ;
  dcterms:modified "2026-06-07T15:30:29.360999Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1362-1
  a curric:KeyLearningPoint ;
  rdfs:label "If the word ends in a consonant, generally just add the suffix -ed."@en ;
  dcterms:modified "2026-06-07T15:30:29.361003Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1362-2
  a curric:KeyLearningPoint ;
  rdfs:label "If the word ends in 'y', remove the 'y' and add -ied."@en ;
  dcterms:modified "2026-06-07T15:30:29.361007Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1362-3
  a curric:KeyLearningPoint ;
  rdfs:label "If the word ends in 'e', remove the 'e' and add -ed."@en ;
  dcterms:modified "2026-06-07T15:30:29.361011Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1362-4
  a curric:KeyLearningPoint ;
  rdfs:label "If there is a short vowel sound, double the consonant and add -ed."@en ;
  dcterms:modified "2026-06-07T15:30:29.361015Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1362-5
  a curric:KeyLearningPoint ;
  rdfs:label """How to spell a range of curriculum words, including equip, equipped and
  attached."""@en ;
  dcterms:modified "2026-06-07T15:30:29.361019Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1372-1
  a curric:KeyLearningPoint ;
  rdfs:label """If the word ends in a consonant, generally just add \"-tion\"; this is the best bet
  for the \"shun\" sound."""@en ;
  dcterms:modified "2026-06-07T15:30:29.361023Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1372-2
  a curric:KeyLearningPoint ;
  rdfs:label "If the word ends in \"t\", remove the \"t\" and add \"-tion\"."@en ;
  dcterms:modified "2026-06-07T15:30:29.361027Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1372-3
  a curric:KeyLearningPoint ;
  rdfs:label "If the word ends in \"te\", remove the \"te\" and add \"-tion\"."@en ;
  dcterms:modified "2026-06-07T15:30:29.361031Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1372-4
  a curric:KeyLearningPoint ;
  rdfs:label """If the word ends in \"e\" or \"y\", remove the \"e\" or \"y\" and add
  \"-ition\"."""@en ;
  dcterms:modified "2026-06-07T15:30:29.361034Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1372-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: competition, mention and position."@en ;
  dcterms:modified "2026-06-07T15:30:29.361038Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7663-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of direct speech in a narrative is to develop characters and advance the
  plot."""@en ;
  dcterms:modified "2026-06-07T15:30:29.361086Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7663-2
  a curric:KeyLearningPoint ;
  rdfs:label """Using a range of sentence types (simple, compound and complex) improves text
  flow."""@en ;
  dcterms:modified "2026-06-07T15:30:29.361090Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7663-3
  a curric:KeyLearningPoint ;
  rdfs:label "Fronted adverbials of time, place or manner add extra detail to a main clause."@en ;
  dcterms:modified "2026-06-07T15:30:29.361094Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7663-4
  a curric:KeyLearningPoint ;
  rdfs:label "This narrative version of 'Whale Rider' is written in the past tense."@en ;
  dcterms:modified "2026-06-07T15:30:29.361098Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7663-5
  a curric:KeyLearningPoint ;
  rdfs:label """Oral rehearsal before writing helps to structure grammatically correct sentences and
  check for sense."""@en ;
  dcterms:modified "2026-06-07T15:30:29.361102Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6695-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the climax is to describe the main action and take the suspense and
  excitement to its highest point."""@en ;
  dcterms:modified "2026-06-07T15:30:29.361416Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6695-2
  a curric:KeyLearningPoint ;
  rdfs:label """Precise and ambitious vocabulary shows and tells the reader what happened on Lila’s
  quest and how she was feeling."""@en ;
  dcterms:modified "2026-06-07T15:30:29.361419Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6695-3
  a curric:KeyLearningPoint ;
  rdfs:label """Using a range of sentence types improves text flow for the reader and conveys key
  moments of suspense in the climax."""@en ;
  dcterms:modified "2026-06-07T15:30:29.361423Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6695-4
  a curric:KeyLearningPoint ;
  rdfs:label """An adverbial complex sentence is a sentence formed of a main clause and an adverbial
  subordinate clause."""@en ;
  dcterms:modified "2026-06-07T15:30:29.361429Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6695-5
  a curric:KeyLearningPoint ;
  rdfs:label "Fronted adverbials of time and manner support text flow and help build suspense."@en ;
  dcterms:modified "2026-06-07T15:30:29.361433Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5702-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of a resolution is to resolve the story and give the reader a chance to
  reflect."""@en ;
  dcterms:modified "2026-06-07T15:30:29.362347Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5702-2
  a curric:KeyLearningPoint ;
  rdfs:label "Saying sentences aloud before they are written helps to check for sense."@en ;
  dcterms:modified "2026-06-07T15:30:29.362351Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5702-3
  a curric:KeyLearningPoint ;
  rdfs:label """Using the full range of sentence types (simple, compound and complex) improves text
  flow for the reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.362355Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5702-4
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials of time, place and manner describe the action in the main clause
  in further detail."""@en ;
  dcterms:modified "2026-06-07T15:30:29.362359Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5702-5
  a curric:KeyLearningPoint ;
  rdfs:label "The narrative is written in the past tense."@en ;
  dcterms:modified "2026-06-07T15:30:29.362363Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6742-1
  a curric:KeyLearningPoint ;
  rdfs:label """Those executed or accused of witchcraft in Early Modern Scotland would often have
  been vulnerable people."""@en ;
  dcterms:modified "2026-06-07T15:30:29.362931Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6742-2
  a curric:KeyLearningPoint ;
  rdfs:label "We can use role play and drama to try and empathise with these characters."@en ;
  dcterms:modified "2026-06-07T15:30:29.362935Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6742-3
  a curric:KeyLearningPoint ;
  rdfs:label "We also need to consider the motivations of their accusers."@en ;
  dcterms:modified "2026-06-07T15:30:29.362938Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6742-4
  a curric:KeyLearningPoint ;
  rdfs:label """We should aim to remember that these were real people who suffered real
  persecution."""@en ;
  dcterms:modified "2026-06-07T15:30:29.362946Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7904-1
  a curric:KeyLearningPoint ;
  rdfs:label """Characterisation is the way an author and illustrator develop the personalities and
  traits of the characters in a story."""@en ;
  dcterms:modified "2026-06-07T15:30:29.363043Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7904-2
  a curric:KeyLearningPoint ;
  rdfs:label "Authors and illustrators use a range of methods to convey characterisation."@en ;
  dcterms:modified "2026-06-07T15:30:29.363047Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7904-3
  a curric:KeyLearningPoint ;
  rdfs:label "Stereotypes can often be found in traditional fairy tales."@en ;
  dcterms:modified "2026-06-07T15:30:29.363051Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7904-4
  a curric:KeyLearningPoint ;
  rdfs:label "Stereotypes can include assumptions based on gender, age and culture."@en ;
  dcterms:modified "2026-06-07T15:30:29.363055Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7904-5
  a curric:KeyLearningPoint ;
  rdfs:label """‘Blackberry Blue’ addresses and challenges stereotypes through its storytelling and
  characterisation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.363059Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9046-1
  a curric:KeyLearningPoint ;
  rdfs:label """'Danny Chung Does Not Do Maths' explores British East/South-East Asian
  prejudice."""@en ;
  dcterms:modified "2026-06-07T15:30:29.363063Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9046-2
  a curric:KeyLearningPoint ;
  rdfs:label "In the story, there are some examples of characters being stereotyped."@en ;
  dcterms:modified "2026-06-07T15:30:29.363066Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9046-3
  a curric:KeyLearningPoint ;
  rdfs:label """The text explores an inter-generational relationship between a grandmother, Nai Nai,
  and her grandson, Danny."""@en ;
  dcterms:modified "2026-06-07T15:30:29.363070Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5450-1
  a curric:KeyLearningPoint ;
  rdfs:label """The legend of ‘Mulan’ is set in China during a period of war where a man from every
  family is required to join the army."""@en ;
  dcterms:modified "2026-06-07T15:30:29.363074Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5450-2
  a curric:KeyLearningPoint ;
  rdfs:label """Mulan’s father and brother are not fit to fight so she decides to join the army in
  order to protect them."""@en ;
  dcterms:modified "2026-06-07T15:30:29.363080Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5450-3
  a curric:KeyLearningPoint ;
  rdfs:label """Mulan disguises herself as a boy in order to be a soldier and she becomes a
  respected and accomplished warrior."""@en ;
  dcterms:modified "2026-06-07T15:30:29.363084Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5450-4
  a curric:KeyLearningPoint ;
  rdfs:label """When the war is won and Mulan returns home, she reveals herself as a girl and her
  soldiers are in awe of her."""@en ;
  dcterms:modified "2026-06-07T15:30:29.363088Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5450-5
  a curric:KeyLearningPoint ;
  rdfs:label """Summarising key events and ideas in a story helps to build our understanding
  of it."""@en ;
  dcterms:modified "2026-06-07T15:30:29.363092Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6099-1
  a curric:KeyLearningPoint ;
  rdfs:label "Information can be gathered from a range of different sources."@en ;
  dcterms:modified "2026-06-07T15:30:29.363139Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6099-2
  a curric:KeyLearningPoint ;
  rdfs:label "Credibility of each source must be determined."@en ;
  dcterms:modified "2026-06-07T15:30:29.363143Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6099-3
  a curric:KeyLearningPoint ;
  rdfs:label "Origin of a source must be cited."@en ;
  dcterms:modified "2026-06-07T15:30:29.363147Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6099-4
  a curric:KeyLearningPoint ;
  rdfs:label "Full sentences are not required when writing in note form."@en ;
  dcterms:modified "2026-06-07T15:30:29.363151Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6099-5
  a curric:KeyLearningPoint ;
  rdfs:label "Notes can be organised by theme using bullet points."@en ;
  dcterms:modified "2026-06-07T15:30:29.363155Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5839-1
  a curric:KeyLearningPoint ;
  rdfs:label "Shakespeare wrote 'Macbeth’ as a play script."@en ;
  dcterms:modified "2026-06-07T15:30:29.363159Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5839-2
  a curric:KeyLearningPoint ;
  rdfs:label """The opening scene of ‘Macbeth’ is a powerful introduction that sets the tone and
  mood for the entire play."""@en ;
  dcterms:modified "2026-06-07T15:30:29.363163Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5839-3
  a curric:KeyLearningPoint ;
  rdfs:label """The scene sets a tone of darkness and uncertainty, foreshadowing the tragic events
  that unfold as the play progresses."""@en ;
  dcterms:modified "2026-06-07T15:30:29.363166Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5839-4
  a curric:KeyLearningPoint ;
  rdfs:label """‘Macbeth’ is written in Early Modern English, which was used from approximately the
  15th century to the 17th century."""@en ;
  dcterms:modified "2026-06-07T15:30:29.363172Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5839-5
  a curric:KeyLearningPoint ;
  rdfs:label """A play script includes dialogue, stage directions, character descriptions,
  instructions for props and sound effects."""@en ;
  dcterms:modified "2026-06-07T15:30:29.363176Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6589-1
  a curric:KeyLearningPoint ;
  rdfs:label "A biography is a non-fiction text written about someone's life."@en ;
  dcterms:modified "2026-06-07T15:30:29.363192Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6589-2
  a curric:KeyLearningPoint ;
  rdfs:label """Linguistic features of a biography include fronted adverbials, facts, relative
  complex sentences and parenthesis."""@en ;
  dcterms:modified "2026-06-07T15:30:29.363196Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6589-3
  a curric:KeyLearningPoint ;
  rdfs:label """Structural features include a title, subheadings and relevant information grouped by
  theme."""@en ;
  dcterms:modified "2026-06-07T15:30:29.363200Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6589-4
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of a biography is to inform the reader about a particular
  individual."""@en ;
  dcterms:modified "2026-06-07T15:30:29.363204Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6589-5
  a curric:KeyLearningPoint ;
  rdfs:label """In biographies, extra, factual information can be added to clauses using brackets or
  commas."""@en ;
  dcterms:modified "2026-06-07T15:30:29.363209Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7854-1
  a curric:KeyLearningPoint ;
  rdfs:label "Skimming and scanning helps to retrieve and record information from a text."@en ;
  dcterms:modified "2026-06-07T15:30:29.363232Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7854-2
  a curric:KeyLearningPoint ;
  rdfs:label "Reading between the lines to search for clues can help to infer meaning."@en ;
  dcterms:modified "2026-06-07T15:30:29.363235Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7854-3
  a curric:KeyLearningPoint ;
  rdfs:label "Evidence from the text helps us to justify our inferences."@en ;
  dcterms:modified "2026-06-07T15:30:29.363239Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4704-1
  a curric:KeyLearningPoint ;
  rdfs:label """An important part of preparing for a debate is generating points for your side of
  the argument."""@en ;
  dcterms:modified "2026-06-07T15:30:29.363265Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4704-2
  a curric:KeyLearningPoint ;
  rdfs:label """The points that your team generates should be ordered from strongest to weakest to
  ensure your best points are included."""@en ;
  dcterms:modified "2026-06-07T15:30:29.363269Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4704-3
  a curric:KeyLearningPoint ;
  rdfs:label "The points generated should be assigned to different members of your team."@en ;
  dcterms:modified "2026-06-07T15:30:29.363273Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4704-4
  a curric:KeyLearningPoint ;
  rdfs:label """A debate team should liaise with each other while writing their speeches to avoid
  repetition."""@en ;
  dcterms:modified "2026-06-07T15:30:29.363277Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4882-1
  a curric:KeyLearningPoint ;
  rdfs:label """Precise vocabulary is used to accurately describe the complex process of
  mummification."""@en ;
  dcterms:modified "2026-06-07T15:30:29.363298Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4882-2
  a curric:KeyLearningPoint ;
  rdfs:label """Adjective choices are formal and technical in an explanation text rather than
  descriptive."""@en ;
  dcterms:modified "2026-06-07T15:30:29.363302Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4882-3
  a curric:KeyLearningPoint ;
  rdfs:label "Verb choices are precise to describe actions accurately."@en ;
  dcterms:modified "2026-06-07T15:30:29.363306Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4882-4
  a curric:KeyLearningPoint ;
  rdfs:label """Synonyms can be used to refer to the nouns in different ways to avoid
  repetition."""@en ;
  dcterms:modified "2026-06-07T15:30:29.363310Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4882-5
  a curric:KeyLearningPoint ;
  rdfs:label "Adverbs are used to add extra detail to the verb."@en ;
  dcterms:modified "2026-06-07T15:30:29.363314Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3456-1
  a curric:KeyLearningPoint ;
  rdfs:label "An apostrophe is an important piece of punctuation with more than one purpose."@en ;
  dcterms:modified "2026-06-07T15:30:29.363318Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3456-2
  a curric:KeyLearningPoint ;
  rdfs:label "An apostrophe can contract two words together."@en ;
  dcterms:modified "2026-06-07T15:30:29.363357Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3456-3
  a curric:KeyLearningPoint ;
  rdfs:label """An apostrophe can show if a noun belongs to another singular noun or to another
  plural noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.363362Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3456-4
  a curric:KeyLearningPoint ;
  rdfs:label """Contractions are useful in writing to indicate a character's informal speech or a
  less formal register."""@en ;
  dcterms:modified "2026-06-07T15:30:29.363366Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3456-5
  a curric:KeyLearningPoint ;
  rdfs:label "Apostrophes for possession are useful to clarify belonging to the reader."@en ;
  dcterms:modified "2026-06-07T15:30:29.363370Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4712-1
  a curric:KeyLearningPoint ;
  rdfs:label "Spending time preparing your speech will help you to make it successful."@en ;
  dcterms:modified "2026-06-07T15:30:29.363374Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4712-2
  a curric:KeyLearningPoint ;
  rdfs:label "The PEPS structure can help you to structure a speech successfully."@en ;
  dcterms:modified "2026-06-07T15:30:29.363378Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1048-1
  a curric:KeyLearningPoint ;
  rdfs:label """Both the simple tense and progressive tense can denote present, past or future
  action."""@en ;
  dcterms:modified "2026-06-07T15:30:29.363384Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1048-2
  a curric:KeyLearningPoint ;
  rdfs:label "The verb carries the tense of a sentence."@en ;
  dcterms:modified "2026-06-07T15:30:29.363388Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1048-3
  a curric:KeyLearningPoint ;
  rdfs:label """The simple tense is a tense that does not use an auxiliary verb in addition to the
  main verb except in the future."""@en ;
  dcterms:modified "2026-06-07T15:30:29.363392Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1048-4
  a curric:KeyLearningPoint ;
  rdfs:label """The progressive tense always makes use of an auxiliary verb from the infinitive 'to
  be' paired with the main verb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.363396Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1048-5
  a curric:KeyLearningPoint ;
  rdfs:label "The progressive tense denotes ongoing action."@en ;
  dcterms:modified "2026-06-07T15:30:29.363400Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5823-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the build-up is to develop the plot and characters, introduce a
  problem and start to build up tension."""@en ;
  dcterms:modified "2026-06-07T15:30:29.363404Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5823-2
  a curric:KeyLearningPoint ;
  rdfs:label """Internal thoughts are the thoughts, ideas, or questions that occur within an
  individual's mind."""@en ;
  dcterms:modified "2026-06-07T15:30:29.363408Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5823-3
  a curric:KeyLearningPoint ;
  rdfs:label """Internal thoughts are written using the same sentence structure as reported
  speech."""@en ;
  dcterms:modified "2026-06-07T15:30:29.363412Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5823-4
  a curric:KeyLearningPoint ;
  rdfs:label """These are important to include in our writing because they tell the reader what a
  character is thinking/feeling."""@en ;
  dcterms:modified "2026-06-07T15:30:29.363416Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5453-1
  a curric:KeyLearningPoint ;
  rdfs:label "A theme is a big idea, topic or message that recurs within a story."@en ;
  dcterms:modified "2026-06-07T15:30:29.364256Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5453-2
  a curric:KeyLearningPoint ;
  rdfs:label """Identifying the themes within ‘Mulan’ helps us understand the deeper meaning behind
  the story."""@en ;
  dcterms:modified "2026-06-07T15:30:29.364260Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5453-3
  a curric:KeyLearningPoint ;
  rdfs:label "A moral is a lesson that can be learnt from a story or experience."@en ;
  dcterms:modified "2026-06-07T15:30:29.364264Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5453-4
  a curric:KeyLearningPoint ;
  rdfs:label """Key themes such as gender roles and the character traits Mulan shows to become a
  trailblazer help us infer a moral."""@en ;
  dcterms:modified "2026-06-07T15:30:29.364268Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5453-5
  a curric:KeyLearningPoint ;
  rdfs:label """Readers may have different interpretations of a text, its meaning or the moral drawn
  from it."""@en ;
  dcterms:modified "2026-06-07T15:30:29.364272Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2717-1
  a curric:KeyLearningPoint ;
  rdfs:label """The main paragraphs in an explanation text tell the reader how the process of
  digestion is carried out."""@en ;
  dcterms:modified "2026-06-07T15:30:29.364298Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2717-2
  a curric:KeyLearningPoint ;
  rdfs:label """Subject-specific, scientific vocabulary ensures the reader learns accurate
  information."""@en ;
  dcterms:modified "2026-06-07T15:30:29.364302Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2717-3
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials of order and place organise the paragraphs in a clear,
  chronological way."""@en ;
  dcterms:modified "2026-06-07T15:30:29.364306Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2717-4
  a curric:KeyLearningPoint ;
  rdfs:label "Subordinating conjunctions are used to begin an adverbial clause."@en ;
  dcterms:modified "2026-06-07T15:30:29.364310Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2717-5
  a curric:KeyLearningPoint ;
  rdfs:label """An adverbial clause can be joined with a main clause to form an adverbial complex
  sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.364314Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5471-1
  a curric:KeyLearningPoint ;
  rdfs:label """We can form judgements about characters and learn morals based on the actions and
  events in the story."""@en ;
  dcterms:modified "2026-06-07T15:30:29.364949Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5471-2
  a curric:KeyLearningPoint ;
  rdfs:label """The story of 'Hansel and Gretel' is an example of how good triumphs over evil in
  fairytales."""@en ;
  dcterms:modified "2026-06-07T15:30:29.364953Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5471-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Hansel and Gretel' contains many of the features of fairytales."@en ;
  dcterms:modified "2026-06-07T15:30:29.364957Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6119-1
  a curric:KeyLearningPoint ;
  rdfs:label """Publishing our work is the final stage of the writing process where we prepare our
  writing ready for an audience to see."""@en ;
  dcterms:modified "2026-06-07T15:30:29.364973Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6119-2
  a curric:KeyLearningPoint ;
  rdfs:label """Published work should be written in clear, joined handwriting with letters that
  start on the line."""@en ;
  dcterms:modified "2026-06-07T15:30:29.364976Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6119-3
  a curric:KeyLearningPoint ;
  rdfs:label "A published non-chronological report will usually include a picture or diagram."@en ;
  dcterms:modified "2026-06-07T15:30:29.364983Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6119-4
  a curric:KeyLearningPoint ;
  rdfs:label """We indent each new paragraph and underline subheadings with a ruler and we follow
  any appropriate layout conventions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.364987Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7183-1
  a curric:KeyLearningPoint ;
  rdfs:label """'The Firework Maker's Daughter' is a quest narrative and the protagonist is named
  Lila."""@en ;
  dcterms:modified "2026-06-07T15:30:29.365054Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7183-2
  a curric:KeyLearningPoint ;
  rdfs:label """The story is influenced by South-East Asian culture and there are clues that imply
  it is set in Indonesia."""@en ;
  dcterms:modified "2026-06-07T15:30:29.365058Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7183-3
  a curric:KeyLearningPoint ;
  rdfs:label """The author provides lots of hints in his writing to give the reader clues and help
  them form predictions about the plot."""@en ;
  dcterms:modified "2026-06-07T15:30:29.365062Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7183-4
  a curric:KeyLearningPoint ;
  rdfs:label """Lila wants to be a firework-maker and discover the secret to it but her father
  Lalchand wants her to find a husband."""@en ;
  dcterms:modified "2026-06-07T15:30:29.365065Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7183-5
  a curric:KeyLearningPoint ;
  rdfs:label """Lila's friend Chulak speaks to Lalchand and finds out the secret ingredient for
  firework-making and where to find it."""@en ;
  dcterms:modified "2026-06-07T15:30:29.365069Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2708-1
  a curric:KeyLearningPoint ;
  rdfs:label "Direct speech is the term used for a character speaking out loud in a text."@en ;
  dcterms:modified "2026-06-07T15:30:29.365494Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2708-2
  a curric:KeyLearningPoint ;
  rdfs:label """A speech second sentence begins with the reporting clause followed by a character's
  spoken words."""@en ;
  dcterms:modified "2026-06-07T15:30:29.365500Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2708-3
  a curric:KeyLearningPoint ;
  rdfs:label """The reporting clause comes before the speech to show who said the speech and
  how."""@en ;
  dcterms:modified "2026-06-07T15:30:29.365504Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2708-4
  a curric:KeyLearningPoint ;
  rdfs:label "The speech sentence spoken by a character must start with a capital letter."@en ;
  dcterms:modified "2026-06-07T15:30:29.365508Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28946-1
  a curric:KeyLearningPoint ;
  rdfs:label """Hearing from the author and illustrator can enhance the reading process by adding
  layers of meaning and context."""@en ;
  dcterms:modified "2026-06-07T15:30:29.365623Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28946-2
  a curric:KeyLearningPoint ;
  rdfs:label "‘Arthur and the Golden Rope’ is written and illustrated by Joe Todd-Stanton."@en ;
  dcterms:modified "2026-06-07T15:30:29.365627Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28946-3
  a curric:KeyLearningPoint ;
  rdfs:label "Authors and illustrators may gain inspiration from many different sources."@en ;
  dcterms:modified "2026-06-07T15:30:29.365631Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28946-4
  a curric:KeyLearningPoint ;
  rdfs:label """Brownstone’s Mythical Collection follows the stories of the Brownstones & their
  adventures through ancient mythologies."""@en ;
  dcterms:modified "2026-06-07T15:30:29.365635Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28946-5
  a curric:KeyLearningPoint ;
  rdfs:label """Joe describes himself as a child who explored a lot on his own and this inspired the
  character of Arthur."""@en ;
  dcterms:modified "2026-06-07T15:30:29.365655Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5664-1
  a curric:KeyLearningPoint ;
  rdfs:label """After Grendel is defeated, another monster - his mother - arrives at Heorot, taking
  away a Dane."""@en ;
  dcterms:modified "2026-06-07T15:30:29.365659Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5664-2
  a curric:KeyLearningPoint ;
  rdfs:label "Beowulf and his companions travel across bleak countryside to find her lair."@en ;
  dcterms:modified "2026-06-07T15:30:29.365663Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5664-3
  a curric:KeyLearningPoint ;
  rdfs:label """Beowulf fights with Grendel's mother, narrowly avoiding death before killing her
  with a special sword."""@en ;
  dcterms:modified "2026-06-07T15:30:29.365667Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5664-4
  a curric:KeyLearningPoint ;
  rdfs:label """Authors make specific language choices in their writing in order to have a specific
  effect on the reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.365674Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5664-5
  a curric:KeyLearningPoint ;
  rdfs:label """A kenning is an Old English way of replacing a noun with a two-word phrase that
  describes it indirectly."""@en ;
  dcterms:modified "2026-06-07T15:30:29.365699Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5752-1
  a curric:KeyLearningPoint ;
  rdfs:label """Notes should not be written in full sentences and bullet points can be used to order
  notes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.365862Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5752-2
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the paragraph is to explain what food should be eaten to form a
  balanced diet."""@en ;
  dcterms:modified "2026-06-07T15:30:29.365869Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5752-3
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials of cause and formal fronted adverbials are used at the start of
  sentences for cohesion."""@en ;
  dcterms:modified "2026-06-07T15:30:29.365873Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5752-4
  a curric:KeyLearningPoint ;
  rdfs:label """A subheading signals part of a a text and should stand out from the rest of the
  text."""@en ;
  dcterms:modified "2026-06-07T15:30:29.365877Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5752-5
  a curric:KeyLearningPoint ;
  rdfs:label "The plan should include subject-specific vocabulary."@en ;
  dcterms:modified "2026-06-07T15:30:29.365881Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5449-1
  a curric:KeyLearningPoint ;
  rdfs:label "‘Mulan’ is a legend which belongs to the genre of folklore."@en ;
  dcterms:modified "2026-06-07T15:30:29.366891Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5449-2
  a curric:KeyLearningPoint ;
  rdfs:label """Folklore is a genre in which oral stories are passed down over time and they
  originate from a range of cultures."""@en ;
  dcterms:modified "2026-06-07T15:30:29.366895Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5449-3
  a curric:KeyLearningPoint ;
  rdfs:label """Legends are a type of folktale that reflect some element of true history and convey
  an important moral or lesson."""@en ;
  dcterms:modified "2026-06-07T15:30:29.366899Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5449-4
  a curric:KeyLearningPoint ;
  rdfs:label """‘Mulan’ originated in China during a time of real war and it challenges ideas around
  the role of women."""@en ;
  dcterms:modified "2026-06-07T15:30:29.366903Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5449-5
  a curric:KeyLearningPoint ;
  rdfs:label """The legend of ‘Mulan’ is about a young girl who disguises herself as a boy in order
  to fight in the army."""@en ;
  dcterms:modified "2026-06-07T15:30:29.366907Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7841-1
  a curric:KeyLearningPoint ;
  rdfs:label """Navigating the features of a non-fiction text can help you read and retrieve
  information on a specific topic."""@en ;
  dcterms:modified "2026-06-07T15:30:29.366925Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7841-2
  a curric:KeyLearningPoint ;
  rdfs:label """Skimming and scanning for keywords can help you accurately retrieve information from
  the text quickly."""@en ;
  dcterms:modified "2026-06-07T15:30:29.366928Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7841-3
  a curric:KeyLearningPoint ;
  rdfs:label """Searching for capital letters helps to find proper nouns quicker, e.g. 'Ganges
  River'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.366932Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7841-4
  a curric:KeyLearningPoint ;
  rdfs:label "Rivers are an important part of life for people around the world."@en ;
  dcterms:modified "2026-06-07T15:30:29.366938Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7841-5
  a curric:KeyLearningPoint ;
  rdfs:label """Rivers are used by humans for a variety of purposes and some have a special meaning
  to religious groups."""@en ;
  dcterms:modified "2026-06-07T15:30:29.366942Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8133-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of a diary entry is to recount important personal experiences and to
  express feelings."""@en ;
  dcterms:modified "2026-06-07T15:30:29.367046Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8133-2
  a curric:KeyLearningPoint ;
  rdfs:label """A diary entry follows a specific structure; it is written in the first person and it
  uses informal language."""@en ;
  dcterms:modified "2026-06-07T15:30:29.367050Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8133-3
  a curric:KeyLearningPoint ;
  rdfs:label """Simple past and progressive past tenses recount what the writer experienced and
  felt."""@en ;
  dcterms:modified "2026-06-07T15:30:29.367054Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8133-4
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials of time support in sequencing events in a recount
  chronologically."""@en ;
  dcterms:modified "2026-06-07T15:30:29.367060Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8133-5
  a curric:KeyLearningPoint ;
  rdfs:label """Present tense is used at points in a diary entry to show how the writer is feeling
  now."""@en ;
  dcterms:modified "2026-06-07T15:30:29.367064Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1090-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Sluggish' is an adjective, which means slow, lazy or lifeless."@en ;
  dcterms:modified "2026-06-07T15:30:29.368393Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1090-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Pampered' is a adjective, which means spoiled or coddled."@en ;
  dcterms:modified "2026-06-07T15:30:29.368397Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1090-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Unwind', 'drowsy', 'soothing' and 'lounge' are other adjectives and verbs related
  to relaxing or being lazy."""@en ;
  dcterms:modified "2026-06-07T15:30:29.368401Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1322-1
  a curric:KeyLearningPoint ;
  rdfs:label "Editing is the process of making changes to improve writing."@en ;
  dcterms:modified "2026-06-07T15:30:29.368421Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1322-2
  a curric:KeyLearningPoint ;
  rdfs:label """When editing punctuation, missing or incorrect punctuation, like capital letters,
  full stops and commas, is checked."""@en ;
  dcterms:modified "2026-06-07T15:30:29.368425Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1322-3
  a curric:KeyLearningPoint ;
  rdfs:label """When editing sentence structure, the flow of sentences and the variety of sentence
  types used are checked."""@en ;
  dcterms:modified "2026-06-07T15:30:29.368429Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1322-4
  a curric:KeyLearningPoint ;
  rdfs:label """When editing language, word and phrase choices are checked to ensure they meet the
  tone required."""@en ;
  dcterms:modified "2026-06-07T15:30:29.368434Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8030-1
  a curric:KeyLearningPoint ;
  rdfs:label """Reading Non-Fiction can develop knowledge of the world around you and the people
  that inhabit it"""@en ;
  dcterms:modified "2026-06-07T15:30:29.368573Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8030-2
  a curric:KeyLearningPoint ;
  rdfs:label """Reading about other people's lives and cultures can develop curiosity about the
  wider world"""@en ;
  dcterms:modified "2026-06-07T15:30:29.368579Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8030-3
  a curric:KeyLearningPoint ;
  rdfs:label "Non-Fiction reading can be presented in a variety of forms"@en ;
  dcterms:modified "2026-06-07T15:30:29.368583Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8030-4
  a curric:KeyLearningPoint ;
  rdfs:label """You can read texts that are based on true stories to learn about history and
  important events"""@en ;
  dcterms:modified "2026-06-07T15:30:29.368587Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8028-1
  a curric:KeyLearningPoint ;
  rdfs:label "Reading allows you to explore your emotions and understand yourself better"@en ;
  dcterms:modified "2026-06-07T15:30:29.368697Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8028-2
  a curric:KeyLearningPoint ;
  rdfs:label """Understanding a character's motivations can lead us to connecting with them on an
  emotional level"""@en ;
  dcterms:modified "2026-06-07T15:30:29.368702Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8028-3
  a curric:KeyLearningPoint ;
  rdfs:label "Favourite characters can be heroes or anti-heroes"@en ;
  dcterms:modified "2026-06-07T15:30:29.368706Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5771-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of an editing lesson is to improve your writing and make necessary
  corrections."""@en ;
  dcterms:modified "2026-06-07T15:30:29.368833Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5771-2
  a curric:KeyLearningPoint ;
  rdfs:label """Vocabulary, grammar and punctuation can be changed to make writing more
  effective."""@en ;
  dcterms:modified "2026-06-07T15:30:29.368837Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5771-3
  a curric:KeyLearningPoint ;
  rdfs:label "Editing is a vital element of the writing process."@en ;
  dcterms:modified "2026-06-07T15:30:29.368841Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5762-1
  a curric:KeyLearningPoint ;
  rdfs:label "The setting description describes where the narrative takes place."@en ;
  dcterms:modified "2026-06-07T15:30:29.368983Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5762-2
  a curric:KeyLearningPoint ;
  rdfs:label "Adverbial detail can be used to enhance text cohesion."@en ;
  dcterms:modified "2026-06-07T15:30:29.368987Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5762-3
  a curric:KeyLearningPoint ;
  rdfs:label """Using a range of sentence types can improve text flow, which can keep the reader
  engaged."""@en ;
  dcterms:modified "2026-06-07T15:30:29.368990Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5762-4
  a curric:KeyLearningPoint ;
  rdfs:label "Apostrophes can be used to indicate plural and singular possession."@en ;
  dcterms:modified "2026-06-07T15:30:29.368994Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5758-1
  a curric:KeyLearningPoint ;
  rdfs:label "Presenting involves speaking in front of others and listening to others."@en ;
  dcterms:modified "2026-06-07T15:30:29.369041Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5758-2
  a curric:KeyLearningPoint ;
  rdfs:label """Presenting involves speaking with clear diction and suitable volume, making eye
  contact and using strong body language."""@en ;
  dcterms:modified "2026-06-07T15:30:29.369045Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5758-3
  a curric:KeyLearningPoint ;
  rdfs:label "Practising pronouncing tricky words helps develop clear diction when presenting."@en ;
  dcterms:modified "2026-06-07T15:30:29.369049Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5758-4
  a curric:KeyLearningPoint ;
  rdfs:label "Rehearsing helps the presenter to speak more confidently and fluently."@en ;
  dcterms:modified "2026-06-07T15:30:29.369053Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5758-5
  a curric:KeyLearningPoint ;
  rdfs:label "Pauses at the end of sentences can help the audience follow what is being said."@en ;
  dcterms:modified "2026-06-07T15:30:29.369057Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6105-1
  a curric:KeyLearningPoint ;
  rdfs:label """A conclusion is the final paragraph of a text and it gives general information about
  the subject."""@en ;
  dcterms:modified "2026-06-07T15:30:29.369442Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6105-2
  a curric:KeyLearningPoint ;
  rdfs:label """A conclusion still has a subheading and an introductory sentence and it uses a range
  of cohesive devices."""@en ;
  dcterms:modified "2026-06-07T15:30:29.369446Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6105-3
  a curric:KeyLearningPoint ;
  rdfs:label """Before we write, we should orally rehearse sentences to ensure our sentences make
  sense and flow well."""@en ;
  dcterms:modified "2026-06-07T15:30:29.369450Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6105-4
  a curric:KeyLearningPoint ;
  rdfs:label """When we have finished our first draft of our writing, we edit it to improve and
  refine it."""@en ;
  dcterms:modified "2026-06-07T15:30:29.369456Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6105-5
  a curric:KeyLearningPoint ;
  rdfs:label """Editing includes looking at sentence structures, vocabulary, cohesive devices,
  spelling and punctuation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.369462Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8013-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘MORERAPS’ is a poem that Joseph Coelho invented to help him remember the different
  poetic devices."""@en ;
  dcterms:modified "2026-06-07T15:30:29.369580Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8013-2
  a curric:KeyLearningPoint ;
  rdfs:label """A poetic device is a technique used by poets to enhance the meaning, sound and
  overall impact of their poems."""@en ;
  dcterms:modified "2026-06-07T15:30:29.369584Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8013-3
  a curric:KeyLearningPoint ;
  rdfs:label """A simile describes something by comparing it to something else, using 'like' or
  'as'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.369588Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8013-4
  a curric:KeyLearningPoint ;
  rdfs:label """Onomatopoeia is a poetic device that uses words that imitate the sound they
  describe."""@en ;
  dcterms:modified "2026-06-07T15:30:29.369592Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8023-1
  a curric:KeyLearningPoint ;
  rdfs:label """There are many different forms of poetry including haikus, kenning poems and free
  verse."""@en ;
  dcterms:modified "2026-06-07T15:30:29.370046Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8023-2
  a curric:KeyLearningPoint ;
  rdfs:label "Free verse poems do not require the poet to follow poetic rules."@en ;
  dcterms:modified "2026-06-07T15:30:29.370050Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8023-3
  a curric:KeyLearningPoint ;
  rdfs:label "Repetition is when a single word, or group of words, is repeated for effect."@en ;
  dcterms:modified "2026-06-07T15:30:29.370056Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8023-4
  a curric:KeyLearningPoint ;
  rdfs:label "Poems can evoke a positive or negative feeling."@en ;
  dcterms:modified "2026-06-07T15:30:29.370060Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5811-1
  a curric:KeyLearningPoint ;
  rdfs:label """The conflict between the Montagues and Capulets comes to a head in Act III
  Scene 1."""@en ;
  dcterms:modified "2026-06-07T15:30:29.370110Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5811-2
  a curric:KeyLearningPoint ;
  rdfs:label """In this scene, Tybalt kills Mercutio and Romeo kills Tybalt in revenge, leading to
  his banishment from Verona."""@en ;
  dcterms:modified "2026-06-07T15:30:29.370115Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5811-3
  a curric:KeyLearningPoint ;
  rdfs:label """We can infer the meaning of Early Modern English when we know the meaning of certain
  key archaic terms."""@en ;
  dcterms:modified "2026-06-07T15:30:29.370119Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5811-4
  a curric:KeyLearningPoint ;
  rdfs:label """Lines in the original script also give us clues for how characters feel and
  think."""@en ;
  dcterms:modified "2026-06-07T15:30:29.370125Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5811-5
  a curric:KeyLearningPoint ;
  rdfs:label """When acting, we can show these emotions through our movements, tone of voice and
  body language."""@en ;
  dcterms:modified "2026-06-07T15:30:29.370129Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6348-1
  a curric:KeyLearningPoint ;
  rdfs:label """The introduction to a persuasive letter will primarily focus on summarising the
  purpose of the letter."""@en ;
  dcterms:modified "2026-06-07T15:30:29.370313Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6348-2
  a curric:KeyLearningPoint ;
  rdfs:label "The introductory sentence will explain the purpose for the letter."@en ;
  dcterms:modified "2026-06-07T15:30:29.370317Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6348-3
  a curric:KeyLearningPoint ;
  rdfs:label "A short summary of the matter will follow, using a range of cohesive devices."@en ;
  dcterms:modified "2026-06-07T15:30:29.370321Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6348-4
  a curric:KeyLearningPoint ;
  rdfs:label """Flattery is used as a persuasive technique in the final sentence to suggest to the
  reader that we need their help."""@en ;
  dcterms:modified "2026-06-07T15:30:29.370325Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1162-1
  a curric:KeyLearningPoint ;
  rdfs:label """Both the progressive tense and perfect tense can denote present, past or future
  action."""@en ;
  dcterms:modified "2026-06-07T15:30:29.370365Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1162-2
  a curric:KeyLearningPoint ;
  rdfs:label "The verb carries the tense of a sentence."@en ;
  dcterms:modified "2026-06-07T15:30:29.370370Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1162-3
  a curric:KeyLearningPoint ;
  rdfs:label """The progressive tense is a tense that makes use of an auxiliary verb from the
  infinitive 'to be' with the main verb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.370373Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1162-4
  a curric:KeyLearningPoint ;
  rdfs:label """The perfect tense is a tense that makes use of an auxiliary verb from the infinitive
  'to have' with the main verb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.370377Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1162-5
  a curric:KeyLearningPoint ;
  rdfs:label """The perfect tense often refers to action that has finished whilst the progressive
  tense denotes ongoing action."""@en ;
  dcterms:modified "2026-06-07T15:30:29.370381Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4876-1
  a curric:KeyLearningPoint ;
  rdfs:label "Information in the adaptations section is specific for the reader."@en ;
  dcterms:modified "2026-06-07T15:30:29.370687Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4876-2
  a curric:KeyLearningPoint ;
  rdfs:label """Text cohesion refers to how a piece of writing flows, engages the reader and
  achieves its purpose."""@en ;
  dcterms:modified "2026-06-07T15:30:29.370691Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4876-3
  a curric:KeyLearningPoint ;
  rdfs:label "Brackets can be used for parenthesis."@en ;
  dcterms:modified "2026-06-07T15:30:29.370695Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4876-4
  a curric:KeyLearningPoint ;
  rdfs:label "Planning is an essential part of the writing process."@en ;
  dcterms:modified "2026-06-07T15:30:29.370699Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4876-5
  a curric:KeyLearningPoint ;
  rdfs:label """Plans should include notes, bullet points and initial ideas that can be developed
  further when writing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.370703Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28399-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘The Final Year’ is an illustrated verse novel that follows Nate as he approaches
  his final year of primary school."""@en ;
  dcterms:modified "2026-06-07T15:30:29.370707Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28399-2
  a curric:KeyLearningPoint ;
  rdfs:label """The poems within ‘The Final Year’ are written in a dialect, reflecting the region of
  Manchester where it is set."""@en ;
  dcterms:modified "2026-06-07T15:30:29.370711Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28399-3
  a curric:KeyLearningPoint ;
  rdfs:label """We can gain an initial understanding of the character of Nate by how he is described
  and how he is illustrated."""@en ;
  dcterms:modified "2026-06-07T15:30:29.371239Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28399-4
  a curric:KeyLearningPoint ;
  rdfs:label """It’s important to not make quick judgements of characters based on a single
  poem."""@en ;
  dcterms:modified "2026-06-07T15:30:29.371245Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28399-5
  a curric:KeyLearningPoint ;
  rdfs:label """Part 1 gives readers an initial impression of Nate, who he is and what his family
  and surroundings are like."""@en ;
  dcterms:modified "2026-06-07T15:30:29.371249Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6369-1
  a curric:KeyLearningPoint ;
  rdfs:label "Apostrophes can be used to indicate plural and singular possession."@en ;
  dcterms:modified "2026-06-07T15:30:29.371253Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6369-2
  a curric:KeyLearningPoint ;
  rdfs:label "Figurative language can be used to create atmosphere and imagery for the reader."@en ;
  dcterms:modified "2026-06-07T15:30:29.371257Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6369-3
  a curric:KeyLearningPoint ;
  rdfs:label """Using a range of types of figurative language, as well as other linguistic devices,
  engages the reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.371261Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6369-4
  a curric:KeyLearningPoint ;
  rdfs:label """Using a range of different sentence types enhances text cohesion and reader
  engagement."""@en ;
  dcterms:modified "2026-06-07T15:30:29.371265Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6369-5
  a curric:KeyLearningPoint ;
  rdfs:label "Planning, drafting, editing and rewriting are all parts of the writing process."@en ;
  dcterms:modified "2026-06-07T15:30:29.371269Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8476-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the resolution is to resolve the problem encountered in the story and
  allow readers to reflect."""@en ;
  dcterms:modified "2026-06-07T15:30:29.371315Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8476-2
  a curric:KeyLearningPoint ;
  rdfs:label """In the resolution, Hogarth leads the Iron Man to a metal scrapyard and he no longer
  needs the farmers' machinery."""@en ;
  dcterms:modified "2026-06-07T15:30:29.371321Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8476-3
  a curric:KeyLearningPoint ;
  rdfs:label """In a resolution, exaggeration is often used to convey the positive emotions felt by
  characters."""@en ;
  dcterms:modified "2026-06-07T15:30:29.371327Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8476-4
  a curric:KeyLearningPoint ;
  rdfs:label """Using a range of synonyms for simple verbs, adjectives and nouns supports
  exaggeration."""@en ;
  dcterms:modified "2026-06-07T15:30:29.371331Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8476-5
  a curric:KeyLearningPoint ;
  rdfs:label "‘Show and tell’ language conveys the Iron Man’s emotions."@en ;
  dcterms:modified "2026-06-07T15:30:29.371335Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3452-1
  a curric:KeyLearningPoint ;
  rdfs:label """The simple, progressive and perfect tense can denote present, past or future
  action."""@en ;
  dcterms:modified "2026-06-07T15:30:29.371339Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3452-2
  a curric:KeyLearningPoint ;
  rdfs:label """The progressive tense is a tense that makes use of an auxiliary verb from the
  infinitive 'to be' with the main verb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.371343Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3452-3
  a curric:KeyLearningPoint ;
  rdfs:label "The progressive tense denotes ongoing action."@en ;
  dcterms:modified "2026-06-07T15:30:29.371347Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3452-4
  a curric:KeyLearningPoint ;
  rdfs:label """The perfect tense is a tense that makes use of an auxiliary verb from the infinitive
  'to have' with the main verb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.371351Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3452-5
  a curric:KeyLearningPoint ;
  rdfs:label "The perfect tense often refers to action that has finished."@en ;
  dcterms:modified "2026-06-07T15:30:29.371355Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1031-1
  a curric:KeyLearningPoint ;
  rdfs:label """The appearance section informs the reader of adaptations of the spider that allow it
  to be a successful predator."""@en ;
  dcterms:modified "2026-06-07T15:30:29.372760Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1031-2
  a curric:KeyLearningPoint ;
  rdfs:label "Portia spiders have a range of physical adaptations."@en ;
  dcterms:modified "2026-06-07T15:30:29.372764Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1031-3
  a curric:KeyLearningPoint ;
  rdfs:label """Viewpoint fronted adverbials and formal fronted adverbials are used at the start of
  sentences for cohesion."""@en ;
  dcterms:modified "2026-06-07T15:30:29.372768Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1031-4
  a curric:KeyLearningPoint ;
  rdfs:label "Facts get increasingly specific throughout one section."@en ;
  dcterms:modified "2026-06-07T15:30:29.372771Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1031-5
  a curric:KeyLearningPoint ;
  rdfs:label """Notes should not be written in full sentences and bullet points can be used to order
  notes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.372775Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7873-1
  a curric:KeyLearningPoint ;
  rdfs:label """There are many themes that are explored in ‘Greenling’ including change and
  transformation, sustainability & rewilding."""@en ;
  dcterms:modified "2026-06-07T15:30:29.375296Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7873-2
  a curric:KeyLearningPoint ;
  rdfs:label """Reading around a text can deepen our understanding of significant themes and ideas
  in a text."""@en ;
  dcterms:modified "2026-06-07T15:30:29.375302Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7873-3
  a curric:KeyLearningPoint ;
  rdfs:label """Sharing personal responses allows readers to engage more deeply with the story and
  build connections to the text."""@en ;
  dcterms:modified "2026-06-07T15:30:29.375306Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7873-4
  a curric:KeyLearningPoint ;
  rdfs:label "Different readers may interpret a text in different ways."@en ;
  dcterms:modified "2026-06-07T15:30:29.375310Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5761-1
  a curric:KeyLearningPoint ;
  rdfs:label "The setting description describes where the narrative takes place."@en ;
  dcterms:modified "2026-06-07T15:30:29.375802Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5761-2
  a curric:KeyLearningPoint ;
  rdfs:label "Adverbial detail describes when, where or how things happened."@en ;
  dcterms:modified "2026-06-07T15:30:29.375806Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5761-3
  a curric:KeyLearningPoint ;
  rdfs:label """Ambitious, precise verbs and descriptive adjectives help the reader visualise the
  scene."""@en ;
  dcterms:modified "2026-06-07T15:30:29.375810Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5761-4
  a curric:KeyLearningPoint ;
  rdfs:label "Using a range of sentence types enhances text cohesion."@en ;
  dcterms:modified "2026-06-07T15:30:29.375814Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7637-1
  a curric:KeyLearningPoint ;
  rdfs:label """The more precise and descriptive the writing, the easier for the reader to picture
  the scene."""@en ;
  dcterms:modified "2026-06-07T15:30:29.375817Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7637-2
  a curric:KeyLearningPoint ;
  rdfs:label """Reading writing aloud is a helpful way to ensure precision of language choices and
  focus on vivid details."""@en ;
  dcterms:modified "2026-06-07T15:30:29.375822Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7637-3
  a curric:KeyLearningPoint ;
  rdfs:label """Identifying the key elements such as colours, shapes, textures and emotions conveyed
  in the text is important."""@en ;
  dcterms:modified "2026-06-07T15:30:29.375825Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7637-4
  a curric:KeyLearningPoint ;
  rdfs:label "Careful and detailed illustrations can match the writer's writing."@en ;
  dcterms:modified "2026-06-07T15:30:29.375829Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7637-5
  a curric:KeyLearningPoint ;
  rdfs:label """Illustrations can help bring writing to life and allow the reader to picture the
  descriptions even more."""@en ;
  dcterms:modified "2026-06-07T15:30:29.375833Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5467-1
  a curric:KeyLearningPoint ;
  rdfs:label """'Anansi and the Antelope Baby' tells the story of how Anansi and Antelope help and
  protect one another."""@en ;
  dcterms:modified "2026-06-07T15:30:29.375985Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5467-2
  a curric:KeyLearningPoint ;
  rdfs:label """Anansi demonstrates admirable character traits such as kindness, loyalty and
  integrity towards Antelope."""@en ;
  dcterms:modified "2026-06-07T15:30:29.375989Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5467-3
  a curric:KeyLearningPoint ;
  rdfs:label "We use a range of strategies to build comprehension of a text."@en ;
  dcterms:modified "2026-06-07T15:30:29.375996Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5467-4
  a curric:KeyLearningPoint ;
  rdfs:label "Skimming and scanning can help us to retrieve key information."@en ;
  dcterms:modified "2026-06-07T15:30:29.376000Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5467-5
  a curric:KeyLearningPoint ;
  rdfs:label "We can use inference to draw conclusions about the text by searching for clues."@en ;
  dcterms:modified "2026-06-07T15:30:29.376004Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7914-1
  a curric:KeyLearningPoint ;
  rdfs:label """Being heroic is not reflected by a character's gender, age or other protected
  characteristic."""@en ;
  dcterms:modified "2026-06-07T15:30:29.376026Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7914-2
  a curric:KeyLearningPoint ;
  rdfs:label "During a text, characters and their relationships change and evolve."@en ;
  dcterms:modified "2026-06-07T15:30:29.376030Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7914-3
  a curric:KeyLearningPoint ;
  rdfs:label """Making connections & recommendations can enhance the reading experience & widen a
  reader’s understanding of literature."""@en ;
  dcterms:modified "2026-06-07T15:30:29.376034Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6591-1
  a curric:KeyLearningPoint ;
  rdfs:label """The introduction provides the reader with general information about who the
  biography is about."""@en ;
  dcterms:modified "2026-06-07T15:30:29.376038Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6591-2
  a curric:KeyLearningPoint ;
  rdfs:label """The introduction explicitly outlines which aspects of the subject's life will be
  explored."""@en ;
  dcterms:modified "2026-06-07T15:30:29.376042Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6591-3
  a curric:KeyLearningPoint ;
  rdfs:label """In the introduction, information should be kept general and it should encourage the
  reader to read on."""@en ;
  dcterms:modified "2026-06-07T15:30:29.376046Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6591-4
  a curric:KeyLearningPoint ;
  rdfs:label """When writing, we should orally rehearse sentences and use our plans and success
  criteria to guide us."""@en ;
  dcterms:modified "2026-06-07T15:30:29.376050Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5774-1
  a curric:KeyLearningPoint ;
  rdfs:label "The closing includes a sign-off from the writer."@en ;
  dcterms:modified "2026-06-07T15:30:29.376054Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5774-2
  a curric:KeyLearningPoint ;
  rdfs:label "The closing includes a summary of key events, thoughts, feelings and questions."@en ;
  dcterms:modified "2026-06-07T15:30:29.376058Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5774-3
  a curric:KeyLearningPoint ;
  rdfs:label "The closing refers to past, present and future events."@en ;
  dcterms:modified "2026-06-07T15:30:29.376062Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5774-4
  a curric:KeyLearningPoint ;
  rdfs:label "The closing may include past, present and future tenses."@en ;
  dcterms:modified "2026-06-07T15:30:29.376066Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6103-1
  a curric:KeyLearningPoint ;
  rdfs:label """Information in a section becomes more specific and detailed as the section
  goes on."""@en ;
  dcterms:modified "2026-06-07T15:30:29.376089Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6103-2
  a curric:KeyLearningPoint ;
  rdfs:label "Facts written in a section should be researched and organised prior to writing."@en ;
  dcterms:modified "2026-06-07T15:30:29.376094Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6103-3
  a curric:KeyLearningPoint ;
  rdfs:label "A range of cohesive devices helps us to link facts within and between sentences."@en ;
  dcterms:modified "2026-06-07T15:30:29.376099Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6103-4
  a curric:KeyLearningPoint ;
  rdfs:label """Before we write, we should orally rehearse sentences to ensure our sentences make
  sense and flow well."""@en ;
  dcterms:modified "2026-06-07T15:30:29.376104Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6103-5
  a curric:KeyLearningPoint ;
  rdfs:label """Parenthesis, varied sentence types and a range of fronted adverbials are all
  cohesive devices that can be used."""@en ;
  dcterms:modified "2026-06-07T15:30:29.376108Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8048-1
  a curric:KeyLearningPoint ;
  rdfs:label "A pantoum is a form of poetry that originated in Malaysia."@en ;
  dcterms:modified "2026-06-07T15:30:29.376235Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8048-2
  a curric:KeyLearningPoint ;
  rdfs:label "Pantoums are characterised by their repeating lines and overlapping structure."@en ;
  dcterms:modified "2026-06-07T15:30:29.376239Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8048-3
  a curric:KeyLearningPoint ;
  rdfs:label """When editing pantoums, we can consider line length, use of rhyme and language
  choices."""@en ;
  dcterms:modified "2026-06-07T15:30:29.376243Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8048-4
  a curric:KeyLearningPoint ;
  rdfs:label """Editing word choices and phrases can help to improve the imagery and impression
  created by our poems."""@en ;
  dcterms:modified "2026-06-07T15:30:29.376247Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8048-5
  a curric:KeyLearningPoint ;
  rdfs:label "Reading your poem aloud will help you to revise and refine it."@en ;
  dcterms:modified "2026-06-07T15:30:29.376260Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27899-1
  a curric:KeyLearningPoint ;
  rdfs:label "A speaker can use humour to build a relationship with an audience."@en ;
  dcterms:modified "2026-06-07T15:30:29.376676Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27899-2
  a curric:KeyLearningPoint ;
  rdfs:label """Telling anecdotes in a speech can help an audience to feel connected to a
  speaker."""@en ;
  dcterms:modified "2026-06-07T15:30:29.376680Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27899-3
  a curric:KeyLearningPoint ;
  rdfs:label """Malala Yousafzai is an activist and actively campaigns for children's rights to
  education and women's rights worldwide."""@en ;
  dcterms:modified "2026-06-07T15:30:29.376686Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27899-4
  a curric:KeyLearningPoint ;
  rdfs:label """She is also a humanitarian, advocate and public speaker, who was the youngest winner
  of the Nobel Peace Prize in 2014."""@en ;
  dcterms:modified "2026-06-07T15:30:29.376690Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8468-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘The Iron Man’ is a science fiction novel about a robotic giant named the
  Iron Man."""@en ;
  dcterms:modified "2026-06-07T15:30:29.376696Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8468-2
  a curric:KeyLearningPoint ;
  rdfs:label """A narrative can be structured into four key sections: the opening, the build-up, the
  climax and the resolution."""@en ;
  dcterms:modified "2026-06-07T15:30:29.376700Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8468-3
  a curric:KeyLearningPoint ;
  rdfs:label "Each part of a narrative has a specific purpose."@en ;
  dcterms:modified "2026-06-07T15:30:29.376704Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8468-4
  a curric:KeyLearningPoint ;
  rdfs:label """Sometimes with longer novels, stories might go through a few cycles of this
  structure."""@en ;
  dcterms:modified "2026-06-07T15:30:29.376708Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8468-5
  a curric:KeyLearningPoint ;
  rdfs:label """You can use your voice, language choices and expression to retell a story
  effectively."""@en ;
  dcterms:modified "2026-06-07T15:30:29.376712Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8475-1
  a curric:KeyLearningPoint ;
  rdfs:label """The climax takes the suspense to its highest point as the Iron Man resurfaces and
  humanity grapples with how to respond."""@en ;
  dcterms:modified "2026-06-07T15:30:29.376784Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8475-2
  a curric:KeyLearningPoint ;
  rdfs:label """Precise and ambitious vocabulary, including ‘show and tell’, help take the suspense
  to its highest point in the climax."""@en ;
  dcterms:modified "2026-06-07T15:30:29.376788Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8475-3
  a curric:KeyLearningPoint ;
  rdfs:label """Using a range of sentence types, including adverbial complex sentences, supports
  text flow."""@en ;
  dcterms:modified "2026-06-07T15:30:29.376792Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8475-4
  a curric:KeyLearningPoint ;
  rdfs:label """Direct speech shows that a person is speaking out loud and the reporting clause
  tells us who said it and how."""@en ;
  dcterms:modified "2026-06-07T15:30:29.376796Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8475-5
  a curric:KeyLearningPoint ;
  rdfs:label """Inverted commas are used to demarcate speech and a piece of punctuation separates
  speech from the reporting clause."""@en ;
  dcterms:modified "2026-06-07T15:30:29.376800Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2721-1
  a curric:KeyLearningPoint ;
  rdfs:label """'Jabberwocky' can be interpreted to follow this narrative structure: opening,
  build-up, climax, resolution."""@en ;
  dcterms:modified "2026-06-07T15:30:29.376989Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2721-2
  a curric:KeyLearningPoint ;
  rdfs:label """Accurate and ambitious descriptions of the characters and setting rely on careful
  and precise language choices."""@en ;
  dcterms:modified "2026-06-07T15:30:29.376993Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2721-3
  a curric:KeyLearningPoint ;
  rdfs:label """Some vocabulary is more precise than others; careful vocabulary choice is paramount
  to evoke setting and atmosphere."""@en ;
  dcterms:modified "2026-06-07T15:30:29.376996Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2721-4
  a curric:KeyLearningPoint ;
  rdfs:label """Different nouns and adjectives are used to refer to characters to avoid
  repetition."""@en ;
  dcterms:modified "2026-06-07T15:30:29.377000Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2721-5
  a curric:KeyLearningPoint ;
  rdfs:label """Imagining colours as we write helps us choose ambitious vocabulary that describes
  images as positive or negative."""@en ;
  dcterms:modified "2026-06-07T15:30:29.377004Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1112-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Deluge' is a noun which means a flood or overflowing water."@en ;
  dcterms:modified "2026-06-07T15:30:29.377160Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1112-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Electrifying' is an adjective which means thrilling or stunning."@en ;
  dcterms:modified "2026-06-07T15:30:29.377164Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1112-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Incessant' is an adjective which means endless or nonstop."@en ;
  dcterms:modified "2026-06-07T15:30:29.377168Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1427-1
  a curric:KeyLearningPoint ;
  rdfs:label """A suffix is a letter or group of letters at the end of a word which creates another
  word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.377516Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1427-2
  a curric:KeyLearningPoint ;
  rdfs:label "Adding \"-ing\" creates an extra syllable to the word."@en ;
  dcterms:modified "2026-06-07T15:30:29.377520Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1427-3
  a curric:KeyLearningPoint ;
  rdfs:label """If the root word ends in the consonant \"e\", the \"e\" is removed before the suffix
  is added."""@en ;
  dcterms:modified "2026-06-07T15:30:29.377524Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1427-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum word: through."@en ;
  dcterms:modified "2026-06-07T15:30:29.377528Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7864-1
  a curric:KeyLearningPoint ;
  rdfs:label "Reading between the lines to search for clues can help to infer meaning"@en ;
  dcterms:modified "2026-06-07T15:30:29.380065Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7864-2
  a curric:KeyLearningPoint ;
  rdfs:label "Evidence from the text helps us to justify our inferences"@en ;
  dcterms:modified "2026-06-07T15:30:29.380069Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7864-3
  a curric:KeyLearningPoint ;
  rdfs:label """It was believed that the Earth was squeezed out of the sea and sifted out of
  the sky"""@en ;
  dcterms:modified "2026-06-07T15:30:29.380073Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7864-4
  a curric:KeyLearningPoint ;
  rdfs:label "It was believed that Chronos disentangled the elements"@en ;
  dcterms:modified "2026-06-07T15:30:29.380077Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7864-5
  a curric:KeyLearningPoint ;
  rdfs:label "Gods, godesses, giants and Titans all lived together on Earth"@en ;
  dcterms:modified "2026-06-07T15:30:29.380081Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2718-1
  a curric:KeyLearningPoint ;
  rdfs:label """The main paragraphs in an explanation text tell the reader how the process of
  digestion is carried out."""@en ;
  dcterms:modified "2026-06-07T15:30:29.380085Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2718-2
  a curric:KeyLearningPoint ;
  rdfs:label """Subject-specific, scientific vocabulary ensures the reader learns accurate
  information."""@en ;
  dcterms:modified "2026-06-07T15:30:29.380089Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2718-3
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials of cause and viewpoint are an important part of explanation texts
  and support text flow."""@en ;
  dcterms:modified "2026-06-07T15:30:29.380093Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2718-4
  a curric:KeyLearningPoint ;
  rdfs:label """Using a variety of simple, compound and complex sentences helps to effectively
  communicate the process being explained."""@en ;
  dcterms:modified "2026-06-07T15:30:29.380097Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2718-5
  a curric:KeyLearningPoint ;
  rdfs:label """Adverbial complex sentences and relative complex sentences are a key part of
  explanation texts and support text flow."""@en ;
  dcterms:modified "2026-06-07T15:30:29.380103Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7188-1
  a curric:KeyLearningPoint ;
  rdfs:label """Oral rehearsal of a recount ensures we have a clear understanding of the chronology
  of events."""@en ;
  dcterms:modified "2026-06-07T15:30:29.380219Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7188-2
  a curric:KeyLearningPoint ;
  rdfs:label """When rehearsing and planning for a diary entry, we do so in the first person from
  the character's perspective."""@en ;
  dcterms:modified "2026-06-07T15:30:29.380223Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7188-3
  a curric:KeyLearningPoint ;
  rdfs:label """An effective plan for a diary entry contains key events in chronological order and
  thoughts/feelings."""@en ;
  dcterms:modified "2026-06-07T15:30:29.380227Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7188-4
  a curric:KeyLearningPoint ;
  rdfs:label """A plan is written in note format using bullet points to capture the most important
  information."""@en ;
  dcterms:modified "2026-06-07T15:30:29.380231Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7188-5
  a curric:KeyLearningPoint ;
  rdfs:label """Lila's first diary entry will recount her day making fireworks and discovering her
  father's views on her future."""@en ;
  dcterms:modified "2026-06-07T15:30:29.380234Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7646-1
  a curric:KeyLearningPoint ;
  rdfs:label """'The Happy Prince' is a story originally written in 1888 by Oscar Wilde, which has
  been adapted into different versions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.380269Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7646-2
  a curric:KeyLearningPoint ;
  rdfs:label """The story tells of a statue of a prince witnessing great poverty and sadness in a
  city."""@en ;
  dcterms:modified "2026-06-07T15:30:29.380272Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7646-3
  a curric:KeyLearningPoint ;
  rdfs:label """Together with a swallow, the prince performs selfless acts of kindness to help the
  poor people of the city."""@en ;
  dcterms:modified "2026-06-07T15:30:29.380276Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7646-4
  a curric:KeyLearningPoint ;
  rdfs:label """The moral of the story in ‘The Happy Prince’ is to be compassionate and to help
  those who are suffering."""@en ;
  dcterms:modified "2026-06-07T15:30:29.380281Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7646-5
  a curric:KeyLearningPoint ;
  rdfs:label """Summarising the key events in a story helps us to build our understanding of the
  text and the meaning behind it."""@en ;
  dcterms:modified "2026-06-07T15:30:29.380288Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7869-1
  a curric:KeyLearningPoint ;
  rdfs:label "Attitudes and perceptions of the central character, Roz, change over time."@en ;
  dcterms:modified "2026-06-07T15:30:29.380464Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7869-2
  a curric:KeyLearningPoint ;
  rdfs:label """Characters within the text depict a range of emotions. Character traits can be
  understood from these."""@en ;
  dcterms:modified "2026-06-07T15:30:29.380468Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7869-3
  a curric:KeyLearningPoint ;
  rdfs:label "Character traits can be explored through the illustrations in addition to words."@en ;
  dcterms:modified "2026-06-07T15:30:29.380472Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7869-4
  a curric:KeyLearningPoint ;
  rdfs:label """Making connections and recommendations can significantly enhance the reading
  experience and broaden understanding."""@en ;
  dcterms:modified "2026-06-07T15:30:29.380476Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6747-1
  a curric:KeyLearningPoint ;
  rdfs:label """In this lesson, we are writing a third person flashback and a first person
  perspective."""@en ;
  dcterms:modified "2026-06-07T15:30:29.380823Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6747-2
  a curric:KeyLearningPoint ;
  rdfs:label """Switching perspectives like this allows us to focus on different elements of the
  narrative at different points."""@en ;
  dcterms:modified "2026-06-07T15:30:29.380830Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6747-3
  a curric:KeyLearningPoint ;
  rdfs:label "Our flashback is likely to be more formal than the first person section."@en ;
  dcterms:modified "2026-06-07T15:30:29.380834Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6747-4
  a curric:KeyLearningPoint ;
  rdfs:label "Both sections should include a range of sentence structures and punctuation."@en ;
  dcterms:modified "2026-06-07T15:30:29.380840Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6747-5
  a curric:KeyLearningPoint ;
  rdfs:label "Orally rehearsing our writing allows us to write more confidently."@en ;
  dcterms:modified "2026-06-07T15:30:29.380845Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6154-1
  a curric:KeyLearningPoint ;
  rdfs:label """A journalistic report contains factual statements mixed with different individuals'
  perspectives."""@en ;
  dcterms:modified "2026-06-07T15:30:29.380935Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6154-2
  a curric:KeyLearningPoint ;
  rdfs:label """It has a formal tone and it is written in the third person, using both past and
  present tense."""@en ;
  dcterms:modified "2026-06-07T15:30:29.380939Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6154-3
  a curric:KeyLearningPoint ;
  rdfs:label """When we give individuals' perspectives, we can use direct speech or reported
  speech."""@en ;
  dcterms:modified "2026-06-07T15:30:29.380943Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6154-4
  a curric:KeyLearningPoint ;
  rdfs:label """Direct speech uses inverted commas to say the exact words a person said; reported
  speech does not."""@en ;
  dcterms:modified "2026-06-07T15:30:29.380947Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6154-5
  a curric:KeyLearningPoint ;
  rdfs:label """A journalistic report contains a range of cohesive devices used to connect ideas
  together."""@en ;
  dcterms:modified "2026-06-07T15:30:29.380951Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6594-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of an editing lesson is to improve writing and to make necessary
  corrections or additions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.381113Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6594-2
  a curric:KeyLearningPoint ;
  rdfs:label """Vocabulary, cohesion and punctuation can be changed to make writing more
  effective."""@en ;
  dcterms:modified "2026-06-07T15:30:29.381117Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6594-3
  a curric:KeyLearningPoint ;
  rdfs:label """When editing, we should be selective about which elements to change and which to
  keep the same."""@en ;
  dcterms:modified "2026-06-07T15:30:29.381121Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1334-1
  a curric:KeyLearningPoint ;
  rdfs:label """The spelling -le is the most common spelling out of the suffixes -le, -el, -al and
  -il."""@en ;
  dcterms:modified "2026-06-07T15:30:29.381742Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1334-2
  a curric:KeyLearningPoint ;
  rdfs:label """The spelling -le often forms letter strings: -cle, -dle, -able, -ckle, -ible and
  -ple."""@en ;
  dcterms:modified "2026-06-07T15:30:29.381746Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1334-3
  a curric:KeyLearningPoint ;
  rdfs:label """The spelling -el is one of the least common spellings out of the suffixes -le, -el,
  -al and -il."""@en ;
  dcterms:modified "2026-06-07T15:30:29.381750Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1334-4
  a curric:KeyLearningPoint ;
  rdfs:label """The spelling -il is the least common spelling out of the suffixes -le, -el, -al and
  -il."""@en ;
  dcterms:modified "2026-06-07T15:30:29.381754Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1334-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: vehicle and apparent."@en ;
  dcterms:modified "2026-06-07T15:30:29.381758Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5624-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘Into the Forest’ is a narrative fiction text written and illustrated by the author
  Anthony Browne."""@en ;
  dcterms:modified "2026-06-07T15:30:29.381807Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5624-2
  a curric:KeyLearningPoint ;
  rdfs:label """The story is about a little boy who goes on a journey through a forest to visit his
  grandma and find his dad."""@en ;
  dcterms:modified "2026-06-07T15:30:29.381811Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5624-3
  a curric:KeyLearningPoint ;
  rdfs:label """On the journey through the forest, the boy encounters characters from familiar fairy
  tales."""@en ;
  dcterms:modified "2026-06-07T15:30:29.381815Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5624-4
  a curric:KeyLearningPoint ;
  rdfs:label """The plot of a story is retold in chronological order using expression to convey
  greater meaning."""@en ;
  dcterms:modified "2026-06-07T15:30:29.381819Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5624-5
  a curric:KeyLearningPoint ;
  rdfs:label """Summarising the key events in a story helps us to build our understanding of the
  text and the meaning behind it."""@en ;
  dcterms:modified "2026-06-07T15:30:29.381825Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4701-1
  a curric:KeyLearningPoint ;
  rdfs:label "It is important to structure your argument when debating."@en ;
  dcterms:modified "2026-06-07T15:30:29.381830Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4701-2
  a curric:KeyLearningPoint ;
  rdfs:label "The PEPS structure stands for: point, explanation, proof, summary."@en ;
  dcterms:modified "2026-06-07T15:30:29.381834Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4701-3
  a curric:KeyLearningPoint ;
  rdfs:label "Structuring your argument will make it more convincing."@en ;
  dcterms:modified "2026-06-07T15:30:29.381838Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1410-1
  a curric:KeyLearningPoint ;
  rdfs:label "The suffix -al often turns nouns into adjectives."@en ;
  dcterms:modified "2026-06-07T15:30:29.381842Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1410-2
  a curric:KeyLearningPoint ;
  rdfs:label "When the root word ends in ‘e’, remove the ‘e’ and add the suffix."@en ;
  dcterms:modified "2026-06-07T15:30:29.381846Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1410-3
  a curric:KeyLearningPoint ;
  rdfs:label """There are many ways to represent the ‘l’ sound in a word, including ‘l’, ‘ll’, ‘le’,
  ‘il’, ‘el’ and ‘al’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.381850Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1410-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: possible, difficult and therefore."@en ;
  dcterms:modified "2026-06-07T15:30:29.381854Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8012-1
  a curric:KeyLearningPoint ;
  rdfs:label """Performing poetry to an audience is an important part of the process of creating
  poetry."""@en ;
  dcterms:modified "2026-06-07T15:30:29.381895Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8012-2
  a curric:KeyLearningPoint ;
  rdfs:label """When performing poetry, you can vary your volume, pace and use gestures to have an
  impact on the audience."""@en ;
  dcterms:modified "2026-06-07T15:30:29.381899Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8012-3
  a curric:KeyLearningPoint ;
  rdfs:label """Deciding upon and creating a desired atmosphere is important when performing
  poetry."""@en ;
  dcterms:modified "2026-06-07T15:30:29.381903Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8012-4
  a curric:KeyLearningPoint ;
  rdfs:label "We can improve our performances of poetry through practice."@en ;
  dcterms:modified "2026-06-07T15:30:29.381907Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3457-1
  a curric:KeyLearningPoint ;
  rdfs:label "A hyphen is a piece of punctuation with more than one purpose."@en ;
  dcterms:modified "2026-06-07T15:30:29.382259Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3457-2
  a curric:KeyLearningPoint ;
  rdfs:label "A hyphen can join two words to make a compound adjective."@en ;
  dcterms:modified "2026-06-07T15:30:29.382263Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3457-3
  a curric:KeyLearningPoint ;
  rdfs:label """A hyphen can join a prefix to a base word to avoid spelling or meaning
  ambiguity."""@en ;
  dcterms:modified "2026-06-07T15:30:29.382267Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3457-4
  a curric:KeyLearningPoint ;
  rdfs:label "An ellipsis can be used to invite the reader to read on or to increase tension."@en ;
  dcterms:modified "2026-06-07T15:30:29.382271Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5497-1
  a curric:KeyLearningPoint ;
  rdfs:label "An apostrophe is an important punctuation mark with more than one purpose."@en ;
  dcterms:modified "2026-06-07T15:30:29.382531Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5497-2
  a curric:KeyLearningPoint ;
  rdfs:label """Speech sentences can be punctuated a variety of ways: speech first, speech second
  and speech interrupted."""@en ;
  dcterms:modified "2026-06-07T15:30:29.382535Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5497-3
  a curric:KeyLearningPoint ;
  rdfs:label """When we avoid using apostrophes for contraction and use serious language, we can
  create a formal tone."""@en ;
  dcterms:modified "2026-06-07T15:30:29.382539Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5847-1
  a curric:KeyLearningPoint ;
  rdfs:label "A play script is the written form of a play."@en ;
  dcterms:modified "2026-06-07T15:30:29.382557Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5847-2
  a curric:KeyLearningPoint ;
  rdfs:label """Audiences can draw inferences and make conclusions about a character based on their
  words, expressions and actions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.382563Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5847-3
  a curric:KeyLearningPoint ;
  rdfs:label "Vocabulary can be generated to precisely describe a scene for the reader."@en ;
  dcterms:modified "2026-06-07T15:30:29.382569Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5847-4
  a curric:KeyLearningPoint ;
  rdfs:label "Shakespearean characters often experience internal conflict."@en ;
  dcterms:modified "2026-06-07T15:30:29.382574Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5847-5
  a curric:KeyLearningPoint ;
  rdfs:label "Macbeth's decision making is influenced by his wife and his desire for power."@en ;
  dcterms:modified "2026-06-07T15:30:29.382578Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5808-1
  a curric:KeyLearningPoint ;
  rdfs:label "Writing is most successful when its content is planned."@en ;
  dcterms:modified "2026-06-07T15:30:29.382601Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5808-2
  a curric:KeyLearningPoint ;
  rdfs:label """A diary entry is most often written retrospectively, but it may contain both present
  and past tense sections."""@en ;
  dcterms:modified "2026-06-07T15:30:29.382605Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5808-3
  a curric:KeyLearningPoint ;
  rdfs:label """Juliet's diary is written as two entries - one on her return from the ball and one
  after the balcony scene."""@en ;
  dcterms:modified "2026-06-07T15:30:29.382609Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5808-4
  a curric:KeyLearningPoint ;
  rdfs:label """A diary entry should include both descriptions of the event(s) and details about the
  emotions that a character feels."""@en ;
  dcterms:modified "2026-06-07T15:30:29.382613Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5808-5
  a curric:KeyLearningPoint ;
  rdfs:label "We can use rich vocabulary and show-not-tell to describe events and emotions."@en ;
  dcterms:modified "2026-06-07T15:30:29.382616Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6151-1
  a curric:KeyLearningPoint ;
  rdfs:label "Editing is the process of making changes to improve our writing."@en ;
  dcterms:modified "2026-06-07T15:30:29.382818Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6151-2
  a curric:KeyLearningPoint ;
  rdfs:label "Editing can be done by oneself, with a peer or with a teacher."@en ;
  dcterms:modified "2026-06-07T15:30:29.382822Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6151-3
  a curric:KeyLearningPoint ;
  rdfs:label """To edit punctuation, missing or incorrectly used capital letters, full stops,
  inverted commas and commas are checked."""@en ;
  dcterms:modified "2026-06-07T15:30:29.382828Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6151-4
  a curric:KeyLearningPoint ;
  rdfs:label """When editing sentence structure, the way sentences are constructed is checked to
  improve and enhance text flow."""@en ;
  dcterms:modified "2026-06-07T15:30:29.382832Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6151-5
  a curric:KeyLearningPoint ;
  rdfs:label "When editing language, choices of words and phrases are carefully reviewed."@en ;
  dcterms:modified "2026-06-07T15:30:29.382838Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5998-1
  a curric:KeyLearningPoint ;
  rdfs:label """When rehearsing and planning for a persuasive letter, we do so in the first person
  from the character's perspective."""@en ;
  dcterms:modified "2026-06-07T15:30:29.382876Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5998-2
  a curric:KeyLearningPoint ;
  rdfs:label """A plan is written in note format using bullet points to capture the most important
  information."""@en ;
  dcterms:modified "2026-06-07T15:30:29.382880Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5998-3
  a curric:KeyLearningPoint ;
  rdfs:label """Persuasive letters have distinctive linguistic features in order to achieve their
  purpose."""@en ;
  dcterms:modified "2026-06-07T15:30:29.382884Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5998-4
  a curric:KeyLearningPoint ;
  rdfs:label """The subordinating conjunction 'because' is used to give a reason for why a character
  is feeling a certain way."""@en ;
  dcterms:modified "2026-06-07T15:30:29.382888Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5998-5
  a curric:KeyLearningPoint ;
  rdfs:label """First person perspective is the point of view where the writer is the 'I'
  character."""@en ;
  dcterms:modified "2026-06-07T15:30:29.382891Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7654-1
  a curric:KeyLearningPoint ;
  rdfs:label "Notes from our plan are used to form full sentences."@en ;
  dcterms:modified "2026-06-07T15:30:29.382895Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7654-2
  a curric:KeyLearningPoint ;
  rdfs:label """A range of sentence types (simple, compound and complex) improves text flow for the
  reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.382899Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7654-3
  a curric:KeyLearningPoint ;
  rdfs:label """A relative complex sentence is formed of a main clause that can be interrupted by a
  relative clause."""@en ;
  dcterms:modified "2026-06-07T15:30:29.382903Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7654-4
  a curric:KeyLearningPoint ;
  rdfs:label """Direct speech is punctuated using inverted commas. Dialogue moves the action
  forward."""@en ;
  dcterms:modified "2026-06-07T15:30:29.382907Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7654-5
  a curric:KeyLearningPoint ;
  rdfs:label "Paragraphs are used to indicate the start of a new idea or key moment."@en ;
  dcterms:modified "2026-06-07T15:30:29.382911Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2728-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the climax is to describe the main action and take the suspense and
  excitement to its highest point."""@en ;
  dcterms:modified "2026-06-07T15:30:29.382917Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2728-2
  a curric:KeyLearningPoint ;
  rdfs:label """Direct speech is punctuated using inverted commas. Dialogue moves the action
  forward."""@en ;
  dcterms:modified "2026-06-07T15:30:29.382922Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2728-3
  a curric:KeyLearningPoint ;
  rdfs:label "Notes from a plan are used to form full sentences."@en ;
  dcterms:modified "2026-06-07T15:30:29.382926Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2728-4
  a curric:KeyLearningPoint ;
  rdfs:label """A range of sentence types (simple, compound and complex) improves text flow for the
  reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.382930Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2728-5
  a curric:KeyLearningPoint ;
  rdfs:label "A range of fronted adverbials is used to improve text flow."@en ;
  dcterms:modified "2026-06-07T15:30:29.382935Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5657-1
  a curric:KeyLearningPoint ;
  rdfs:label "‘Curiosity: The Story of a Mars Rover’ is a non-fiction narrative text."@en ;
  dcterms:modified "2026-06-07T15:30:29.384890Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5657-2
  a curric:KeyLearningPoint ;
  rdfs:label """It contains some, but not all of the features readers might expect from a
  non-fiction text."""@en ;
  dcterms:modified "2026-06-07T15:30:29.384893Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5657-3
  a curric:KeyLearningPoint ;
  rdfs:label """When creating the Curiosity rover, the scientists and team at NASA had to plan for
  lots of different eventualities."""@en ;
  dcterms:modified "2026-06-07T15:30:29.384897Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5657-4
  a curric:KeyLearningPoint ;
  rdfs:label """The Curiosity rover had to conduct its own experiments; it needed all the equipment
  it required to be sent with it."""@en ;
  dcterms:modified "2026-06-07T15:30:29.384901Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5657-5
  a curric:KeyLearningPoint ;
  rdfs:label """To be successful, the team tested for many years, until the rover was ready to
  launch on the 26th November 2011."""@en ;
  dcterms:modified "2026-06-07T15:30:29.384905Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7893-1
  a curric:KeyLearningPoint ;
  rdfs:label "Asking questions about a poem can help identify key themes within it"@en ;
  dcterms:modified "2026-06-07T15:30:29.384909Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7893-2
  a curric:KeyLearningPoint ;
  rdfs:label """There are several key themes in \"The Listeners\" including, the unknown, the
  supernatural, isolation and solitude"""@en ;
  dcterms:modified "2026-06-07T15:30:29.384912Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7893-3
  a curric:KeyLearningPoint ;
  rdfs:label """The Listeners portrays the strangeness of the world, and humankind's inability to
  fully understand it"""@en ;
  dcterms:modified "2026-06-07T15:30:29.384916Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5461-1
  a curric:KeyLearningPoint ;
  rdfs:label """The author, Meredith Hooper, uses rich vocabulary and literary devices throughout
  the text."""@en ;
  dcterms:modified "2026-06-07T15:30:29.384939Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5461-2
  a curric:KeyLearningPoint ;
  rdfs:label """An author's choice of vocabulary can convey deeper meaning and create an impact on
  the reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.384943Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5461-3
  a curric:KeyLearningPoint ;
  rdfs:label "Imagery appeals to the reader's senses and creates an image in their mind."@en ;
  dcterms:modified "2026-06-07T15:30:29.384947Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5461-4
  a curric:KeyLearningPoint ;
  rdfs:label """Similes and personification are powerful tools to help the reader build an
  image."""@en ;
  dcterms:modified "2026-06-07T15:30:29.384955Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5460-1
  a curric:KeyLearningPoint ;
  rdfs:label "Looking at word class can help us to understand unfamiliar vocabulary."@en ;
  dcterms:modified "2026-06-07T15:30:29.384959Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5460-2
  a curric:KeyLearningPoint ;
  rdfs:label """Considering where you've heard a word before can help you infer vocabulary
  meaning."""@en ;
  dcterms:modified "2026-06-07T15:30:29.384963Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5460-3
  a curric:KeyLearningPoint ;
  rdfs:label "Exploring illustrations can help us to understand the meaning of vocabulary."@en ;
  dcterms:modified "2026-06-07T15:30:29.384967Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6111-1
  a curric:KeyLearningPoint ;
  rdfs:label "Information can be gathered from a range of different sources."@en ;
  dcterms:modified "2026-06-07T15:30:29.385941Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6111-2
  a curric:KeyLearningPoint ;
  rdfs:label "Credibility of each source must be determined."@en ;
  dcterms:modified "2026-06-07T15:30:29.385945Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6111-3
  a curric:KeyLearningPoint ;
  rdfs:label "Origin of a source must be cited."@en ;
  dcterms:modified "2026-06-07T15:30:29.385949Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6111-4
  a curric:KeyLearningPoint ;
  rdfs:label "Full sentences are not required when writing in note form."@en ;
  dcterms:modified "2026-06-07T15:30:29.385953Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6111-5
  a curric:KeyLearningPoint ;
  rdfs:label "Notes can be organised by theme using bullet points."@en ;
  dcterms:modified "2026-06-07T15:30:29.385959Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6744-1
  a curric:KeyLearningPoint ;
  rdfs:label "Writing is most successful when it is planned."@en ;
  dcterms:modified "2026-06-07T15:30:29.386863Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6744-2
  a curric:KeyLearningPoint ;
  rdfs:label """Writing can include a shift in perspective from first to third person and a change
  from present to past tense."""@en ;
  dcterms:modified "2026-06-07T15:30:29.386867Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6744-3
  a curric:KeyLearningPoint ;
  rdfs:label "The first person allows the reader to hear Addie's direct thoughts and emotions."@en ;
  dcterms:modified "2026-06-07T15:30:29.386872Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6744-4
  a curric:KeyLearningPoint ;
  rdfs:label """We can also plan to include flashbacks that show past events in the third
  person."""@en ;
  dcterms:modified "2026-06-07T15:30:29.386876Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6744-5
  a curric:KeyLearningPoint ;
  rdfs:label "These flashbacks might be 'triggered' by a certain action in the present."@en ;
  dcterms:modified "2026-06-07T15:30:29.386879Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7917-1
  a curric:KeyLearningPoint ;
  rdfs:label """Looking at interactions between characters can tell readers about their
  relationships."""@en ;
  dcterms:modified "2026-06-07T15:30:29.387163Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7917-2
  a curric:KeyLearningPoint ;
  rdfs:label """Addie and her older sister, Keedie, are both autistic; they have both had different
  experiences of growing up autistic."""@en ;
  dcterms:modified "2026-06-07T15:30:29.387167Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7917-3
  a curric:KeyLearningPoint ;
  rdfs:label "Authors give us lots of clues about relationships between characters."@en ;
  dcterms:modified "2026-06-07T15:30:29.387171Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7917-4
  a curric:KeyLearningPoint ;
  rdfs:label """We can adopt the perspectives of different characters to understand plot points more
  fully."""@en ;
  dcterms:modified "2026-06-07T15:30:29.387175Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27624-1
  a curric:KeyLearningPoint ;
  rdfs:label """A debate is a structured argument between two teams who either agree or disagree
  with a motion."""@en ;
  dcterms:modified "2026-06-07T15:30:29.387405Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27624-2
  a curric:KeyLearningPoint ;
  rdfs:label "The motion is the name for the belief or proposal that is being debated."@en ;
  dcterms:modified "2026-06-07T15:30:29.387408Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27624-3
  a curric:KeyLearningPoint ;
  rdfs:label """An opinion is a view or belief that a person has and robust reasoning supports an
  opinion."""@en ;
  dcterms:modified "2026-06-07T15:30:29.387413Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27624-4
  a curric:KeyLearningPoint ;
  rdfs:label "The PEPS structure stands for: point, explanation, proof, summary."@en ;
  dcterms:modified "2026-06-07T15:30:29.387419Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1074-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Deflated' is an adjective which means feeling hopeless or let down."@en ;
  dcterms:modified "2026-06-07T15:30:29.387479Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1074-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Envious' is an adjective which means jealous or resentful."@en ;
  dcterms:modified "2026-06-07T15:30:29.387483Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1074-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Disheartened', 'regretful', 'humiliated' and 'snubbed' are other rich vocabulary
  associated with feeling bad."""@en ;
  dcterms:modified "2026-06-07T15:30:29.387487Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5489-1
  a curric:KeyLearningPoint ;
  rdfs:label "A theme is a big idea, topic or message that recurs within a story."@en ;
  dcterms:modified "2026-06-07T15:30:29.387522Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5489-2
  a curric:KeyLearningPoint ;
  rdfs:label """Themes can leave us with ideas and questions that we reflect on after reading the
  text."""@en ;
  dcterms:modified "2026-06-07T15:30:29.387526Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5489-3
  a curric:KeyLearningPoint ;
  rdfs:label """The theme of remembrance is conveyed through Tranio and Livia’s return to the
  mountain in the resolution."""@en ;
  dcterms:modified "2026-06-07T15:30:29.387530Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5489-4
  a curric:KeyLearningPoint ;
  rdfs:label "Fluent readers can process text swiftly and efficiently."@en ;
  dcterms:modified "2026-06-07T15:30:29.387534Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7888-1
  a curric:KeyLearningPoint ;
  rdfs:label "Different readers may interpret a text in different ways."@en ;
  dcterms:modified "2026-06-07T15:30:29.387704Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7888-2
  a curric:KeyLearningPoint ;
  rdfs:label "Readers can interpret their own big idea or message from a narrative."@en ;
  dcterms:modified "2026-06-07T15:30:29.387708Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7888-3
  a curric:KeyLearningPoint ;
  rdfs:label """Discussing books by building on others and our own views can help us to deepen our
  understanding of a book."""@en ;
  dcterms:modified "2026-06-07T15:30:29.387713Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7888-4
  a curric:KeyLearningPoint ;
  rdfs:label """Reading between the lines can allow readers to make connections and parallels to
  their own lives."""@en ;
  dcterms:modified "2026-06-07T15:30:29.387718Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27893-1
  a curric:KeyLearningPoint ;
  rdfs:label "People can agree or disagree with other people's opinions."@en ;
  dcterms:modified "2026-06-07T15:30:29.387770Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27893-2
  a curric:KeyLearningPoint ;
  rdfs:label "A debate involves speakers disagreeing with each other."@en ;
  dcterms:modified "2026-06-07T15:30:29.387777Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27893-3
  a curric:KeyLearningPoint ;
  rdfs:label "Choosing a strong point is key to making a convincing argument."@en ;
  dcterms:modified "2026-06-07T15:30:29.387781Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27893-4
  a curric:KeyLearningPoint ;
  rdfs:label """A counter-argument is when you hear someone else's point and then respond with your
  own perspective and reasoning."""@en ;
  dcterms:modified "2026-06-07T15:30:29.387785Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6595-1
  a curric:KeyLearningPoint ;
  rdfs:label """The main body of a biography is split into paragraphs, which are organised
  by theme."""@en ;
  dcterms:modified "2026-06-07T15:30:29.387985Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6595-2
  a curric:KeyLearningPoint ;
  rdfs:label """Using a range of cohesive devices can enhance text flow and achieve text
  purpose."""@en ;
  dcterms:modified "2026-06-07T15:30:29.387991Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6595-3
  a curric:KeyLearningPoint ;
  rdfs:label "A complex sentence includes a main clause and any type of subordinate clause."@en ;
  dcterms:modified "2026-06-07T15:30:29.387996Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6595-4
  a curric:KeyLearningPoint ;
  rdfs:label """Adverbial complex, relative complex and non-finite complex sentences can all be used
  in biographies."""@en ;
  dcterms:modified "2026-06-07T15:30:29.387999Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6595-5
  a curric:KeyLearningPoint ;
  rdfs:label """In biographies, extra, factual information can be added to clauses using
  brackets."""@en ;
  dcterms:modified "2026-06-07T15:30:29.388005Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8033-1
  a curric:KeyLearningPoint ;
  rdfs:label """Reading and rereading poems leads to a richer response and a greater understanding
  of language within the poem."""@en ;
  dcterms:modified "2026-06-07T15:30:29.388041Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8033-2
  a curric:KeyLearningPoint ;
  rdfs:label """Engaging in conversations about poems allows us to make connections with our own
  lives and the world around us."""@en ;
  dcterms:modified "2026-06-07T15:30:29.388045Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8033-3
  a curric:KeyLearningPoint ;
  rdfs:label "Comparing poems explores the themes, structures and language within them."@en ;
  dcterms:modified "2026-06-07T15:30:29.388049Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8033-4
  a curric:KeyLearningPoint ;
  rdfs:label "A theme is a big idea, topic or message that recurs in a poem."@en ;
  dcterms:modified "2026-06-07T15:30:29.388053Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8036-1
  a curric:KeyLearningPoint ;
  rdfs:label """The themes in John Lyons' poems are often about the natural world, weather, animals
  and family."""@en ;
  dcterms:modified "2026-06-07T15:30:29.388789Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8036-2
  a curric:KeyLearningPoint ;
  rdfs:label """The tone in John Lyons' poems is generally positive because lots of his poetry draws
  on memories of his childhood."""@en ;
  dcterms:modified "2026-06-07T15:30:29.388792Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8036-3
  a curric:KeyLearningPoint ;
  rdfs:label """Poets like to use poetic devices such as figurative language to create imagery for
  the reader and listener."""@en ;
  dcterms:modified "2026-06-07T15:30:29.388796Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8036-4
  a curric:KeyLearningPoint ;
  rdfs:label """Figurative language includes the use of similes and personification, which brings
  writing to life."""@en ;
  dcterms:modified "2026-06-07T15:30:29.388800Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8036-5
  a curric:KeyLearningPoint ;
  rdfs:label """Generating ambitious vocabulary creates descriptive-rich writing, which paints vivid
  pictures in the reader's mind.."""@en ;
  dcterms:modified "2026-06-07T15:30:29.388804Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1347-1
  a curric:KeyLearningPoint ;
  rdfs:label "The -ent and -ence suffixes generally come after a soft 'c', soft 'g' and 'qu'."@en ;
  dcterms:modified "2026-06-07T15:30:29.389458Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1347-2
  a curric:KeyLearningPoint ;
  rdfs:label """Words ending in -ent sometimes have related words where the ‘e’ vowel sound is
  clearer, like resident - residential."""@en ;
  dcterms:modified "2026-06-07T15:30:29.389462Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1347-3
  a curric:KeyLearningPoint ;
  rdfs:label """Changing the suffix -ent to the suffix -ence or -ency can change the word from an
  adjective to an abstract noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.389466Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1347-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: hindrance, excellent and relevant."@en ;
  dcterms:modified "2026-06-07T15:30:29.389472Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8079-1
  a curric:KeyLearningPoint ;
  rdfs:label """Making a text recommendation includes a personal reason for why the text was
  relevant to you"""@en ;
  dcterms:modified "2026-06-07T15:30:29.389579Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8079-2
  a curric:KeyLearningPoint ;
  rdfs:label """Making a text recommendation includes a reason that someone else might enjoy the
  text"""@en ;
  dcterms:modified "2026-06-07T15:30:29.389583Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8079-3
  a curric:KeyLearningPoint ;
  rdfs:label """You can read books written by a range of authors/illustrators to learn about
  different cultures and perspectives"""@en ;
  dcterms:modified "2026-06-07T15:30:29.389586Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8079-4
  a curric:KeyLearningPoint ;
  rdfs:label """You can read books in any language that you understand and share these with peers or
  family"""@en ;
  dcterms:modified "2026-06-07T15:30:29.389590Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1441-1
  a curric:KeyLearningPoint ;
  rdfs:label "The suffixes -ful and -less can be used to change the meaning of a root word."@en ;
  dcterms:modified "2026-06-07T15:30:29.389780Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1441-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Look, cover, write and check' is a useful practice strategy."@en ;
  dcterms:modified "2026-06-07T15:30:29.389784Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1441-3
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum word: famous."@en ;
  dcterms:modified "2026-06-07T15:30:29.389790Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1441-4
  a curric:KeyLearningPoint ;
  rdfs:label """The -less and -ful suffixes start with a consonant, so the root word usually doesn’t
  change when the suffix is added."""@en ;
  dcterms:modified "2026-06-07T15:30:29.389794Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1441-5
  a curric:KeyLearningPoint ;
  rdfs:label """If the root word has more than one syllable and ends in a consonant +y, then ‘y’ is
  replaced by ‘i’ before the suffix."""@en ;
  dcterms:modified "2026-06-07T15:30:29.389798Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7897-1
  a curric:KeyLearningPoint ;
  rdfs:label "Inferring meaning can help us to build our understanding of the story."@en ;
  dcterms:modified "2026-06-07T15:30:29.389912Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7897-2
  a curric:KeyLearningPoint ;
  rdfs:label """A turning point in a narrative is a pivotal moment that significantly alters the
  course of the story."""@en ;
  dcterms:modified "2026-06-07T15:30:29.389915Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7897-3
  a curric:KeyLearningPoint ;
  rdfs:label "Turning points can evoke a range of emotions in the character."@en ;
  dcterms:modified "2026-06-07T15:30:29.389921Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7897-4
  a curric:KeyLearningPoint ;
  rdfs:label "We can track a character’s emotions on an emotions graph."@en ;
  dcterms:modified "2026-06-07T15:30:29.389926Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7897-5
  a curric:KeyLearningPoint ;
  rdfs:label """The author creates a turning point in the story by having a cliffhanger where Oliver
  is potentially fatally wounded."""@en ;
  dcterms:modified "2026-06-07T15:30:29.389930Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5491-1
  a curric:KeyLearningPoint ;
  rdfs:label "A simple sentence has one main clause."@en ;
  dcterms:modified "2026-06-07T15:30:29.390723Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5491-2
  a curric:KeyLearningPoint ;
  rdfs:label """There are four types of simple sentence: statement, question, command and
  exclamation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.390729Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5491-3
  a curric:KeyLearningPoint ;
  rdfs:label """A compound sentence has at least two main clauses joined with a co-ordinating
  conjunction."""@en ;
  dcterms:modified "2026-06-07T15:30:29.390733Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5491-4
  a curric:KeyLearningPoint ;
  rdfs:label """Accurate sentences start with capital letters and end with full stops, question
  marks or exclamation marks."""@en ;
  dcterms:modified "2026-06-07T15:30:29.390737Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5491-5
  a curric:KeyLearningPoint ;
  rdfs:label """A comma is placed before the co-ordinating conjunctions 'but' and 'or' in a compound
  sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.390741Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5474-1
  a curric:KeyLearningPoint ;
  rdfs:label "A theme is a big idea, topic or message that recurs within a story."@en ;
  dcterms:modified "2026-06-07T15:30:29.390786Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5474-2
  a curric:KeyLearningPoint ;
  rdfs:label "Readers can interpret the importance of themes, ideas and messages differently."@en ;
  dcterms:modified "2026-06-07T15:30:29.390790Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5474-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Hansel and Gretel' explores a variety of themes linked to morality."@en ;
  dcterms:modified "2026-06-07T15:30:29.390794Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5474-4
  a curric:KeyLearningPoint ;
  rdfs:label """Analysing themes can help us consider human morality and positively impact the
  people we want to be."""@en ;
  dcterms:modified "2026-06-07T15:30:29.390797Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7832-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Swallow's Kiss' is written in free verse."@en ;
  dcterms:modified "2026-06-07T15:30:29.390801Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7832-2
  a curric:KeyLearningPoint ;
  rdfs:label """Free verse is any form of poetry that does not rely on consistent patterns of rhyme
  and meter."""@en ;
  dcterms:modified "2026-06-07T15:30:29.390807Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7832-3
  a curric:KeyLearningPoint ;
  rdfs:label """It is told from the perspective of Blessing, a young girl whose mother travelled
  across roads and seas to seek refuge."""@en ;
  dcterms:modified "2026-06-07T15:30:29.390811Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7832-4
  a curric:KeyLearningPoint ;
  rdfs:label """Blessing's close relationship with her family is mirrored in the members of the
  community that are supporting them."""@en ;
  dcterms:modified "2026-06-07T15:30:29.390815Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7889-1
  a curric:KeyLearningPoint ;
  rdfs:label "The Listeners was written by Walter de la Mare in 1912"@en ;
  dcterms:modified "2026-06-07T15:30:29.391121Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7889-2
  a curric:KeyLearningPoint ;
  rdfs:label "Walter de la Mare was born in April 1873 in England"@en ;
  dcterms:modified "2026-06-07T15:30:29.391125Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7889-3
  a curric:KeyLearningPoint ;
  rdfs:label """The Listeners describes the actions of a Traveller who knocks on the door of a
  seemingly deserted home at night"""@en ;
  dcterms:modified "2026-06-07T15:30:29.391129Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7889-4
  a curric:KeyLearningPoint ;
  rdfs:label """Walter de la Mare's poetry tends to explore themes of imagination, childhood, and
  the mysterious or supernatural"""@en ;
  dcterms:modified "2026-06-07T15:30:29.391133Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5493-1
  a curric:KeyLearningPoint ;
  rdfs:label "The verb carries the tense of a clause."@en ;
  dcterms:modified "2026-06-07T15:30:29.391174Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5493-2
  a curric:KeyLearningPoint ;
  rdfs:label """The simple tense does not make use of an auxiliary verb in addition to the main verb
  except in the future tense."""@en ;
  dcterms:modified "2026-06-07T15:30:29.391177Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5493-3
  a curric:KeyLearningPoint ;
  rdfs:label """The progressive tense denotes ongoing action and uses auxiliary verbs based on 'to
  be'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.391181Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5493-4
  a curric:KeyLearningPoint ;
  rdfs:label """Standard English is often used in writing and uses different verb forms to
  non-Standard English."""@en ;
  dcterms:modified "2026-06-07T15:30:29.391187Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1050-1
  a curric:KeyLearningPoint ;
  rdfs:label "Writers can use speech sentences to show a character speaking in a text."@en ;
  dcterms:modified "2026-06-07T15:30:29.391256Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1050-2
  a curric:KeyLearningPoint ;
  rdfs:label "If a character speaks, the writer must signal this with specific punctuation."@en ;
  dcterms:modified "2026-06-07T15:30:29.391260Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1050-3
  a curric:KeyLearningPoint ;
  rdfs:label """Inverted commas are the punctuation marks that signal direct speech to the
  reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.391266Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1050-4
  a curric:KeyLearningPoint ;
  rdfs:label "Direct speech is the term used for a character speaking out loud in a text."@en ;
  dcterms:modified "2026-06-07T15:30:29.391272Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1050-5
  a curric:KeyLearningPoint ;
  rdfs:label "Direct speech helps us learn more about characters in a text."@en ;
  dcterms:modified "2026-06-07T15:30:29.391276Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8471-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the build-up is to build up suspense and excitement before the
  climax."""@en ;
  dcterms:modified "2026-06-07T15:30:29.391280Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8471-2
  a curric:KeyLearningPoint ;
  rdfs:label "The build-up of 'The Iron Man' describes humanity’s response to the Iron Man."@en ;
  dcterms:modified "2026-06-07T15:30:29.391286Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8471-3
  a curric:KeyLearningPoint ;
  rdfs:label """When we plan, we log precise and ambitious vocabulary to help paint vivid pictures
  for our reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.391290Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8471-4
  a curric:KeyLearningPoint ;
  rdfs:label "A plan includes notes, a sequence of events and ambitious vocabulary."@en ;
  dcterms:modified "2026-06-07T15:30:29.391294Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8471-5
  a curric:KeyLearningPoint ;
  rdfs:label """‘Show-and-tell’ language shows a character’s feelings by describing their actions,
  body language and facial expressions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.391298Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7830-1
  a curric:KeyLearningPoint ;
  rdfs:label "The plot of a story is all the events that happen in it."@en ;
  dcterms:modified "2026-06-07T15:30:29.391321Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7830-2
  a curric:KeyLearningPoint ;
  rdfs:label "A narrative will have a beginning, build-up, climax and ending."@en ;
  dcterms:modified "2026-06-07T15:30:29.391325Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7830-3
  a curric:KeyLearningPoint ;
  rdfs:label """Turning points in a text mark the change in direction of the plot, which affect the
  story."""@en ;
  dcterms:modified "2026-06-07T15:30:29.391329Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7830-4
  a curric:KeyLearningPoint ;
  rdfs:label "Babe forms a relationship with the sheep."@en ;
  dcterms:modified "2026-06-07T15:30:29.391333Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7830-5
  a curric:KeyLearningPoint ;
  rdfs:label "Babe sucessfully herds the sheep and impresses Farmer Hogget and Fly."@en ;
  dcterms:modified "2026-06-07T15:30:29.391337Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5625-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of a diary entry is to recount important experiences and express
  feelings."""@en ;
  dcterms:modified "2026-06-07T15:30:29.393920Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5625-2
  a curric:KeyLearningPoint ;
  rdfs:label """A diary entry has a specific layout, it is written in the first person and it uses
  informal language."""@en ;
  dcterms:modified "2026-06-07T15:30:29.393924Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5625-3
  a curric:KeyLearningPoint ;
  rdfs:label """Simple past and progressive past tenses recount what the writer experienced and
  felt."""@en ;
  dcterms:modified "2026-06-07T15:30:29.393928Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5625-4
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials of time support in sequencing events in a recount
  chronologically."""@en ;
  dcterms:modified "2026-06-07T15:30:29.393932Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5625-5
  a curric:KeyLearningPoint ;
  rdfs:label """The present tense is used towards the end of a diary entry to show how the writer is
  feeling now."""@en ;
  dcterms:modified "2026-06-07T15:30:29.393936Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5805-1
  a curric:KeyLearningPoint ;
  rdfs:label """'Romeo and Juliet' is a tragedy written by William Shakespeare in the 1590s and it
  is based on an Italian story."""@en ;
  dcterms:modified "2026-06-07T15:30:29.394201Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5805-2
  a curric:KeyLearningPoint ;
  rdfs:label """The plot tells of two young lovers, Romeo Montague and Juliet Capulet, who belong to
  feuding families."""@en ;
  dcterms:modified "2026-06-07T15:30:29.394205Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5805-3
  a curric:KeyLearningPoint ;
  rdfs:label """A theme of a play is a central idea that the writer intends the audience to engage
  deeply with."""@en ;
  dcterms:modified "2026-06-07T15:30:29.394209Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5805-4
  a curric:KeyLearningPoint ;
  rdfs:label "Key themes in 'Romeo and Juliet' are love, chance, conflict, youth and death."@en ;
  dcterms:modified "2026-06-07T15:30:29.394212Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8140-1
  a curric:KeyLearningPoint ;
  rdfs:label "Children often use drawings in their diaries as a way of telling stories."@en ;
  dcterms:modified "2026-06-07T15:30:29.394231Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8140-2
  a curric:KeyLearningPoint ;
  rdfs:label "A doodle is a sketch completed absent-mindedly."@en ;
  dcterms:modified "2026-06-07T15:30:29.394236Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8140-3
  a curric:KeyLearningPoint ;
  rdfs:label "Neat, joined handwriting is important when publishing a diary entry."@en ;
  dcterms:modified "2026-06-07T15:30:29.394241Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8140-4
  a curric:KeyLearningPoint ;
  rdfs:label """A published diary entry should be visually and linguistically appealing to the
  reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.394244Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5843-1
  a curric:KeyLearningPoint ;
  rdfs:label "Writing is most successful when it is planned."@en ;
  dcterms:modified "2026-06-07T15:30:29.398027Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5843-2
  a curric:KeyLearningPoint ;
  rdfs:label """A narrative opening should engage the reader and describe the setting and any
  characters who are present."""@en ;
  dcterms:modified "2026-06-07T15:30:29.398031Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5843-3
  a curric:KeyLearningPoint ;
  rdfs:label "This narrative outcome will be written in the third person."@en ;
  dcterms:modified "2026-06-07T15:30:29.398035Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5843-4
  a curric:KeyLearningPoint ;
  rdfs:label "Dialogue can be used to convey character and advance the action."@en ;
  dcterms:modified "2026-06-07T15:30:29.398039Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5843-5
  a curric:KeyLearningPoint ;
  rdfs:label """Variation in vocabulary and sentence structure engages the reader and enhances text
  cohesion."""@en ;
  dcterms:modified "2026-06-07T15:30:29.398045Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6391-1
  a curric:KeyLearningPoint ;
  rdfs:label "Poems can be learned by heart and recited."@en ;
  dcterms:modified "2026-06-07T15:30:29.398068Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6391-2
  a curric:KeyLearningPoint ;
  rdfs:label """Understanding of the poem's meaning can be shown through intonation, tone, volume
  and action."""@en ;
  dcterms:modified "2026-06-07T15:30:29.398072Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6391-3
  a curric:KeyLearningPoint ;
  rdfs:label "Clear diction is essential for the audience to understand the words."@en ;
  dcterms:modified "2026-06-07T15:30:29.398078Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6391-4
  a curric:KeyLearningPoint ;
  rdfs:label """Using a range of recital skills can enhance our performance and audience
  engagement."""@en ;
  dcterms:modified "2026-06-07T15:30:29.398082Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6391-5
  a curric:KeyLearningPoint ;
  rdfs:label "Eye contact is an important aspect of public speaking."@en ;
  dcterms:modified "2026-06-07T15:30:29.398086Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1093-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Meandering' is an adjective which means wandering or following a bendy path."@en ;
  dcterms:modified "2026-06-07T15:30:29.398898Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1093-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Skulk' is a verb, which means to creep or prowl."@en ;
  dcterms:modified "2026-06-07T15:30:29.398902Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1093-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Trudge', 'swagger', 'traverse' and 'stagger' are other verbs related to
  walking."""@en ;
  dcterms:modified "2026-06-07T15:30:29.398924Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6763-1
  a curric:KeyLearningPoint ;
  rdfs:label "Writing is most successful when structure, content and vocabulary is planned."@en ;
  dcterms:modified "2026-06-07T15:30:29.399086Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6763-2
  a curric:KeyLearningPoint ;
  rdfs:label "Information in this section should be specific and detailed."@en ;
  dcterms:modified "2026-06-07T15:30:29.399090Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6763-3
  a curric:KeyLearningPoint ;
  rdfs:label "Cohesion, making use of research and a formal tone are appropriate in an essay."@en ;
  dcterms:modified "2026-06-07T15:30:29.399094Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6763-4
  a curric:KeyLearningPoint ;
  rdfs:label """An essay can use a bank of research, evidence, statistics and quotes to inform the
  reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.399100Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7906-1
  a curric:KeyLearningPoint ;
  rdfs:label """When drawing comparisons to other texts, readers can look for connections in themes,
  events or characters."""@en ;
  dcterms:modified "2026-06-07T15:30:29.399104Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7906-2
  a curric:KeyLearningPoint ;
  rdfs:label """‘Blackberry Blue’ shares lots of similarities with fairy and folk tales, especially
  ‘Cinderella’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.399110Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7906-3
  a curric:KeyLearningPoint ;
  rdfs:label "A theme is a big idea, topic or message that recurs within a story."@en ;
  dcterms:modified "2026-06-07T15:30:29.399115Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7906-4
  a curric:KeyLearningPoint ;
  rdfs:label """Some themes are more complex, they can impart important morals or lessons,
  regardless of when the text was written."""@en ;
  dcterms:modified "2026-06-07T15:30:29.399118Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4880-1
  a curric:KeyLearningPoint ;
  rdfs:label """Mummification is a process to preserve a dead body to make it ready for the
  afterlife."""@en ;
  dcterms:modified "2026-06-07T15:30:29.399238Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4880-2
  a curric:KeyLearningPoint ;
  rdfs:label """Mummification is a complex and long process that needs to be completed in a certain
  order."""@en ;
  dcterms:modified "2026-06-07T15:30:29.399242Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4880-3
  a curric:KeyLearningPoint ;
  rdfs:label "Embalmers were the people whose job it was to mummify corpses in Ancient Egypt."@en ;
  dcterms:modified "2026-06-07T15:30:29.399246Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4880-4
  a curric:KeyLearningPoint ;
  rdfs:label """The corpse was thoroughly cleaned, dried out and wrapped in linen in
  preparation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.399250Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4880-5
  a curric:KeyLearningPoint ;
  rdfs:label """The corpse was placed in a sarcophagus where it could be kept safe in the
  afterlife."""@en ;
  dcterms:modified "2026-06-07T15:30:29.399254Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1385-1
  a curric:KeyLearningPoint ;
  rdfs:label """There are many ways to spell the ‘ee’ sound, including ‘ee’, ‘ea’, ‘e-e’, ‘e’, ‘y’,
  ‘ey’, ‘ie’ and ‘ei’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.399811Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1385-2
  a curric:KeyLearningPoint ;
  rdfs:label """The rule ‘i before e except after c’ can help choose between ‘ie’ and ‘ei’ when
  spelling ‘ee’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.399815Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1385-3
  a curric:KeyLearningPoint ;
  rdfs:label "There are exceptions, including ‘protein’, ‘caffeine’, ‘either’ and ‘seize’."@en ;
  dcterms:modified "2026-06-07T15:30:29.399819Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1385-4
  a curric:KeyLearningPoint ;
  rdfs:label "It is important to practise to help us learn new spellings."@en ;
  dcterms:modified "2026-06-07T15:30:29.399823Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1385-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: rhyme, rhythm and remember."@en ;
  dcterms:modified "2026-06-07T15:30:29.399826Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1376-1
  a curric:KeyLearningPoint ;
  rdfs:label "Words that end with suffixes -ant and -ent can sound like ‘unt’ when we speak."@en ;
  dcterms:modified "2026-06-07T15:30:29.399830Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1376-2
  a curric:KeyLearningPoint ;
  rdfs:label "The -ant spelling may be found after a ‘hard c’ or ‘hard ‘g’."@en ;
  dcterms:modified "2026-06-07T15:30:29.399834Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1376-3
  a curric:KeyLearningPoint ;
  rdfs:label """Words ending in -ant sometimes have related words where the vowel sound is clearer,
  like with participant -participation"""@en ;
  dcterms:modified "2026-06-07T15:30:29.399838Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1376-4
  a curric:KeyLearningPoint ;
  rdfs:label """We just need to learn how to spell many words ending in -ant as there may not be a
  rule or pattern to help us."""@en ;
  dcterms:modified "2026-06-07T15:30:29.399842Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1376-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: relevant, knowledge and familiar."@en ;
  dcterms:modified "2026-06-07T15:30:29.399846Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1378-1
  a curric:KeyLearningPoint ;
  rdfs:label "Words that end with suffixes -ant and -ent can sound like ‘unt’ when we speak."@en ;
  dcterms:modified "2026-06-07T15:30:29.400049Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1378-2
  a curric:KeyLearningPoint ;
  rdfs:label "The -ent spelling may be found after a ‘soft c’, ‘soft ‘g’ or ‘qu’."@en ;
  dcterms:modified "2026-06-07T15:30:29.400053Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1378-3
  a curric:KeyLearningPoint ;
  rdfs:label """Words ending in -ent sometimes have related words where the ‘e’ vowel sound is
  clearer, like resident - residential."""@en ;
  dcterms:modified "2026-06-07T15:30:29.400059Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1378-4
  a curric:KeyLearningPoint ;
  rdfs:label "The letters ‘ent’ can also be found in the noun suffix -ment."@en ;
  dcterms:modified "2026-06-07T15:30:29.400064Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1378-5
  a curric:KeyLearningPoint ;
  rdfs:label """How to spell the curriculum words: different, excellent, experiment and
  equipment."""@en ;
  dcterms:modified "2026-06-07T15:30:29.400068Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7184-1
  a curric:KeyLearningPoint ;
  rdfs:label """Using inference can help us to draw greater conclusions about Lila and Lalchand's
  relationship."""@en ;
  dcterms:modified "2026-06-07T15:30:29.400933Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7184-2
  a curric:KeyLearningPoint ;
  rdfs:label "The relationship between Lila and Lalchand is central to the plot."@en ;
  dcterms:modified "2026-06-07T15:30:29.400937Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7184-3
  a curric:KeyLearningPoint ;
  rdfs:label "Lila and Lalchand have conflicting views on her future."@en ;
  dcterms:modified "2026-06-07T15:30:29.400941Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7184-4
  a curric:KeyLearningPoint ;
  rdfs:label """Lalchand's views are stereotypical of traditional ideas around the role that girls
  and women should play."""@en ;
  dcterms:modified "2026-06-07T15:30:29.400945Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7184-5
  a curric:KeyLearningPoint ;
  rdfs:label """Lila's desires challenge stereotypes for girls and she defies her father in pursuit
  of her dreams."""@en ;
  dcterms:modified "2026-06-07T15:30:29.400949Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6112-1
  a curric:KeyLearningPoint ;
  rdfs:label "Information can be gathered from a range of different sources."@en ;
  dcterms:modified "2026-06-07T15:30:29.401715Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6112-2
  a curric:KeyLearningPoint ;
  rdfs:label "Credibility of each source must be determined."@en ;
  dcterms:modified "2026-06-07T15:30:29.401719Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6112-3
  a curric:KeyLearningPoint ;
  rdfs:label "Origin of a source must be cited."@en ;
  dcterms:modified "2026-06-07T15:30:29.401723Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6112-4
  a curric:KeyLearningPoint ;
  rdfs:label """Established facts and relevant evidence can be used to strengthen the writer's
  position on a subject."""@en ;
  dcterms:modified "2026-06-07T15:30:29.401729Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6112-5
  a curric:KeyLearningPoint ;
  rdfs:label "Relevant statistics can enhance the evidence cited."@en ;
  dcterms:modified "2026-06-07T15:30:29.401733Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6005-1
  a curric:KeyLearningPoint ;
  rdfs:label """Persuasion is the action or process of trying to change someone’s mind or
  behaviour."""@en ;
  dcterms:modified "2026-06-07T15:30:29.401859Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6005-2
  a curric:KeyLearningPoint ;
  rdfs:label "Persuading someone to agree with you all starts with a persuasive point."@en ;
  dcterms:modified "2026-06-07T15:30:29.401863Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6005-3
  a curric:KeyLearningPoint ;
  rdfs:label "A persuasive point is an idea or reason to support your opinion."@en ;
  dcterms:modified "2026-06-07T15:30:29.401869Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6005-4
  a curric:KeyLearningPoint ;
  rdfs:label """Points will usually contain the word ‘because’ which is used to give a reason for an
  opinion."""@en ;
  dcterms:modified "2026-06-07T15:30:29.401874Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5812-1
  a curric:KeyLearningPoint ;
  rdfs:label "The duel scene in Act III Scene 1 has a tense, pacy atmosphere."@en ;
  dcterms:modified "2026-06-07T15:30:29.402244Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5812-2
  a curric:KeyLearningPoint ;
  rdfs:label """When we write, we can choose vocabulary that will build this specific
  atmosphere."""@en ;
  dcterms:modified "2026-06-07T15:30:29.402250Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5812-3
  a curric:KeyLearningPoint ;
  rdfs:label """We will need to know vocabulary specific to duelling in order to describe it in a
  tense, pacy manner."""@en ;
  dcterms:modified "2026-06-07T15:30:29.402256Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5812-4
  a curric:KeyLearningPoint ;
  rdfs:label """We can also select specific vocabulary to show the characters' emotions during the
  duel."""@en ;
  dcterms:modified "2026-06-07T15:30:29.402260Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5812-5
  a curric:KeyLearningPoint ;
  rdfs:label "Using drama to explore vocabulary can help pupils to understand it more deeply."@en ;
  dcterms:modified "2026-06-07T15:30:29.402264Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9042-1
  a curric:KeyLearningPoint ;
  rdfs:label """Different genres of writing make use of different plot and character
  conventions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.402299Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9042-2
  a curric:KeyLearningPoint ;
  rdfs:label """In detective fiction, common character conventions include 'the brilliant detective'
  and 'the faithful sidekick'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.402303Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9042-3
  a curric:KeyLearningPoint ;
  rdfs:label """In detective fiction, common plot conventions include 'the red herring' and 'the big
  reveal'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.402307Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9042-4
  a curric:KeyLearningPoint ;
  rdfs:label """These conventions are not rules: authors constantly subvert and play with them to
  entertain the reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.402311Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9042-5
  a curric:KeyLearningPoint ;
  rdfs:label """In detective fiction, the reader is trying to solve the mystery too so the author
  plans the plot carefully."""@en ;
  dcterms:modified "2026-06-07T15:30:29.402317Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7651-1
  a curric:KeyLearningPoint ;
  rdfs:label """Direct speech is punctuated using inverted commas. Dialogue moves the action
  forward."""@en ;
  dcterms:modified "2026-06-07T15:30:29.402411Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7651-2
  a curric:KeyLearningPoint ;
  rdfs:label "Notes from a plan are used to form full sentences."@en ;
  dcterms:modified "2026-06-07T15:30:29.402417Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7651-3
  a curric:KeyLearningPoint ;
  rdfs:label """A range of sentence types (simple, compound and complex) improves text flow for the
  reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.402422Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7651-4
  a curric:KeyLearningPoint ;
  rdfs:label """A relative complex sentence is formed of a main clause that is interrupted by a
  relative clause."""@en ;
  dcterms:modified "2026-06-07T15:30:29.402426Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7651-5
  a curric:KeyLearningPoint ;
  rdfs:label "Singular possession is shown by use of an apostrophe."@en ;
  dcterms:modified "2026-06-07T15:30:29.402430Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8876-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘The Iron Man’ is a contemporary science fiction novel written by the author Ted
  Hughes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.402457Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8876-2
  a curric:KeyLearningPoint ;
  rdfs:label """Science fiction is a genre of fiction that involves imaginative & futuristic
  concepts linked to science and technology."""@en ;
  dcterms:modified "2026-06-07T15:30:29.402460Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8876-3
  a curric:KeyLearningPoint ;
  rdfs:label """The opening chapter introduces a mysterious robot named the Iron Man as the
  protagonist."""@en ;
  dcterms:modified "2026-06-07T15:30:29.402464Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8876-4
  a curric:KeyLearningPoint ;
  rdfs:label """Ted Hughes creates a mysterious atmosphere in the opening chapter, which leaves the
  reader with many questions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.402468Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8876-5
  a curric:KeyLearningPoint ;
  rdfs:label """A variety of linguistic techniques are used to create vivid imagery and convey a
  mysterious atmosphere."""@en ;
  dcterms:modified "2026-06-07T15:30:29.402472Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5698-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of a build-up is to develop the characters and plot and often to
  introduce a problem."""@en ;
  dcterms:modified "2026-06-07T15:30:29.402586Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5698-2
  a curric:KeyLearningPoint ;
  rdfs:label "Saying sentences aloud before they are written helps to check for sense."@en ;
  dcterms:modified "2026-06-07T15:30:29.402592Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5698-3
  a curric:KeyLearningPoint ;
  rdfs:label """Using the full range of sentence types (simple, compound and complex) improves text
  flow for the reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.402596Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5698-4
  a curric:KeyLearningPoint ;
  rdfs:label """A rhetorical question engages the reader and makes them feel more curious about the
  narrative."""@en ;
  dcterms:modified "2026-06-07T15:30:29.402600Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5698-5
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials of time, place and manner describe the action in the main clause
  in further detail."""@en ;
  dcterms:modified "2026-06-07T15:30:29.402604Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7901-1
  a curric:KeyLearningPoint ;
  rdfs:label "The protagonist of the story is August ‘Auggie’ Pullman."@en ;
  dcterms:modified "2026-06-07T15:30:29.402624Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7901-2
  a curric:KeyLearningPoint ;
  rdfs:label """August was born with a facial deformity which marks him out to be ‘different’ and
  subjected to discrimination."""@en ;
  dcterms:modified "2026-06-07T15:30:29.402628Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7901-3
  a curric:KeyLearningPoint ;
  rdfs:label """August gradually wins over his peers and becomes an integral part of the school
  community."""@en ;
  dcterms:modified "2026-06-07T15:30:29.402632Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7901-4
  a curric:KeyLearningPoint ;
  rdfs:label """The book is structured to show each character's different perspective; these are
  referred to as 'parts'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.402636Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7901-5
  a curric:KeyLearningPoint ;
  rdfs:label """A take-away idea within a text may link to themes that are explored and developed in
  it."""@en ;
  dcterms:modified "2026-06-07T15:30:29.402640Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8139-1
  a curric:KeyLearningPoint ;
  rdfs:label "A  theme is a big idea, topic or message that appears in a story."@en ;
  dcterms:modified "2026-06-07T15:30:29.405311Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8139-2
  a curric:KeyLearningPoint ;
  rdfs:label "Themes in a story are used to convey deeper meaning and messages to the reader."@en ;
  dcterms:modified "2026-06-07T15:30:29.405315Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8139-3
  a curric:KeyLearningPoint ;
  rdfs:label """‘The Journey’ explores the following themes: war and conflict, resilience, hope and
  displacement."""@en ;
  dcterms:modified "2026-06-07T15:30:29.405320Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8139-4
  a curric:KeyLearningPoint ;
  rdfs:label "The girl’s emotions change throughout the narrative."@en ;
  dcterms:modified "2026-06-07T15:30:29.405324Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8139-5
  a curric:KeyLearningPoint ;
  rdfs:label "Expressing thoughts and emotions is a key part of writing a diary entry."@en ;
  dcterms:modified "2026-06-07T15:30:29.405328Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5462-1
  a curric:KeyLearningPoint ;
  rdfs:label "We can use a range of strategies to build comprehension of the text."@en ;
  dcterms:modified "2026-06-07T15:30:29.405332Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5462-2
  a curric:KeyLearningPoint ;
  rdfs:label "Skimming and scanning can help us to retrieve key information."@en ;
  dcterms:modified "2026-06-07T15:30:29.405336Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5462-3
  a curric:KeyLearningPoint ;
  rdfs:label "We can use inference to draw conclusions about the text by searching for clues."@en ;
  dcterms:modified "2026-06-07T15:30:29.405340Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5462-4
  a curric:KeyLearningPoint ;
  rdfs:label """Discussing the text with others improves understanding and offers opportunities for
  hearing different perspectives."""@en ;
  dcterms:modified "2026-06-07T15:30:29.405344Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7671-1
  a curric:KeyLearningPoint ;
  rdfs:label """Subject-specific vocabulary, including numerical facts, is used in a
  non-chronological report."""@en ;
  dcterms:modified "2026-06-07T15:30:29.406210Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7671-2
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials of cause are used at the start of a sentence to explain a
  reason."""@en ;
  dcterms:modified "2026-06-07T15:30:29.406214Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7671-3
  a curric:KeyLearningPoint ;
  rdfs:label """Sentences can start with a range of fronted adverbials like formal and viewpoint
  fronted adverbials."""@en ;
  dcterms:modified "2026-06-07T15:30:29.406251Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6327-1
  a curric:KeyLearningPoint ;
  rdfs:label "Reading between the lines to search for clues can help to infer meaning."@en ;
  dcterms:modified "2026-06-07T15:30:29.406284Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6327-2
  a curric:KeyLearningPoint ;
  rdfs:label "Evidence from the text helps us to justify our inferences."@en ;
  dcterms:modified "2026-06-07T15:30:29.406288Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6327-3
  a curric:KeyLearningPoint ;
  rdfs:label """An impression can be formed from reader’s initial feelings from reading the text, or
  prior experience."""@en ;
  dcterms:modified "2026-06-07T15:30:29.406292Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8044-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘When the Wind Blows’ describes the impact of the wind on the environment;
  'Heatwave' describes a very hot day."""@en ;
  dcterms:modified "2026-06-07T15:30:29.407826Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8044-2
  a curric:KeyLearningPoint ;
  rdfs:label "The poems are split into verses with different numbers of lines in each."@en ;
  dcterms:modified "2026-06-07T15:30:29.407830Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8044-3
  a curric:KeyLearningPoint ;
  rdfs:label """Poems can create a positive or negative impression of something through the language
  choices made."""@en ;
  dcterms:modified "2026-06-07T15:30:29.407834Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8044-4
  a curric:KeyLearningPoint ;
  rdfs:label """Considering and understanding the poet's language helps us form an impression of
  their poems."""@en ;
  dcterms:modified "2026-06-07T15:30:29.407841Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8044-5
  a curric:KeyLearningPoint ;
  rdfs:label "We can be inspired by a poem and create a mirrored version of it."@en ;
  dcterms:modified "2026-06-07T15:30:29.407845Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5838-1
  a curric:KeyLearningPoint ;
  rdfs:label "The play ‘Macbeth’ is a tragedy set in Scotland during the medieval period."@en ;
  dcterms:modified "2026-06-07T15:30:29.407857Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5838-2
  a curric:KeyLearningPoint ;
  rdfs:label """A theme is a central idea that the writer intends the audience to engage deeply
  with."""@en ;
  dcterms:modified "2026-06-07T15:30:29.407862Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5838-3
  a curric:KeyLearningPoint ;
  rdfs:label """The key themes in ‘Macbeth’ are ambition, power, manipulation, betrayal and
  guilt."""@en ;
  dcterms:modified "2026-06-07T15:30:29.407866Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5838-4
  a curric:KeyLearningPoint ;
  rdfs:label """The plot tells of Macbeth, a Scottish general, and his bid to kill others in order
  to become the King of Scotland."""@en ;
  dcterms:modified "2026-06-07T15:30:29.407870Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3400-1
  a curric:KeyLearningPoint ;
  rdfs:label "An introduction's purpose is to give general facts to the reader."@en ;
  dcterms:modified "2026-06-07T15:30:29.408510Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3400-2
  a curric:KeyLearningPoint ;
  rdfs:label """The introduction gives general facts about the time period and origins of the
  Anglo-Saxons."""@en ;
  dcterms:modified "2026-06-07T15:30:29.408515Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3400-3
  a curric:KeyLearningPoint ;
  rdfs:label """The introduction tells the reader what they will learn in the rest of the
  report."""@en ;
  dcterms:modified "2026-06-07T15:30:29.408519Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5663-1
  a curric:KeyLearningPoint ;
  rdfs:label "In Chapter 4, Grendel comes to Heorot and kills Leofric."@en ;
  dcterms:modified "2026-06-07T15:30:29.408736Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5663-2
  a curric:KeyLearningPoint ;
  rdfs:label """Beowulf attacks and he snaps off Grendel's arm, which makes the Geats think that
  Grendel must then die."""@en ;
  dcterms:modified "2026-06-07T15:30:29.408740Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5663-3
  a curric:KeyLearningPoint ;
  rdfs:label """Beowulf and the Geats are rewarded by King Hrothgar for ridding the Danes of
  Grendel."""@en ;
  dcterms:modified "2026-06-07T15:30:29.408744Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5663-4
  a curric:KeyLearningPoint ;
  rdfs:label """Authors describe and develop characters' traits through their actions, dialogue and
  interactions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.408748Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5663-5
  a curric:KeyLearningPoint ;
  rdfs:label """This process of character development is called characterisation and we can find
  evidence of it in texts."""@en ;
  dcterms:modified "2026-06-07T15:30:29.408753Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4820-1
  a curric:KeyLearningPoint ;
  rdfs:label """Two or more words that sound the same but have different meanings and spellings are
  called homophones."""@en ;
  dcterms:modified "2026-06-07T15:30:29.408757Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4820-2
  a curric:KeyLearningPoint ;
  rdfs:label "The words start with a lead in on the line and finish with a lead out."@en ;
  dcterms:modified "2026-06-07T15:30:29.408761Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4820-3
  a curric:KeyLearningPoint ;
  rdfs:label "There are four cursive joins."@en ;
  dcterms:modified "2026-06-07T15:30:29.408765Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4820-4
  a curric:KeyLearningPoint ;
  rdfs:label """The join used depends on which letter is joining to which letter within a letter
  string."""@en ;
  dcterms:modified "2026-06-07T15:30:29.408769Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4820-5
  a curric:KeyLearningPoint ;
  rdfs:label "You don't lift your pencil to form the joins."@en ;
  dcterms:modified "2026-06-07T15:30:29.408773Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7913-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘The Girl of Ink and Stars’ is a novel, which blends the genres of myth and magical
  realism."""@en ;
  dcterms:modified "2026-06-07T15:30:29.408875Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7913-2
  a curric:KeyLearningPoint ;
  rdfs:label """The text has strong links to location and navigation; maps are a central part of the
  narrative."""@en ;
  dcterms:modified "2026-06-07T15:30:29.408879Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7913-3
  a curric:KeyLearningPoint ;
  rdfs:label """In 'The Girl of Ink and Stars', the themes of sacrifice, friendship and redemption
  are explored."""@en ;
  dcterms:modified "2026-06-07T15:30:29.408885Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7913-4
  a curric:KeyLearningPoint ;
  rdfs:label "Different readers may interpret a text in different ways."@en ;
  dcterms:modified "2026-06-07T15:30:29.408890Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7894-1
  a curric:KeyLearningPoint ;
  rdfs:label "Oliver Twist is set in Victorian England."@en ;
  dcterms:modified "2026-06-07T15:30:29.408894Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7894-2
  a curric:KeyLearningPoint ;
  rdfs:label """Charles Dickens is a key author for our cultural heritage; ‘Oliver Twist’ is
  considered a children’s literature classic."""@en ;
  dcterms:modified "2026-06-07T15:30:29.408898Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7894-3
  a curric:KeyLearningPoint ;
  rdfs:label """During Victorian England, there was widespread poverty and living conditions for the
  poor were harsh."""@en ;
  dcterms:modified "2026-06-07T15:30:29.408902Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7894-4
  a curric:KeyLearningPoint ;
  rdfs:label """Dickens’ early experiences influenced his writing and made him care about
  injustice."""@en ;
  dcterms:modified "2026-06-07T15:30:29.408906Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7894-5
  a curric:KeyLearningPoint ;
  rdfs:label """Adapting a text can mean changing some parts of the story based on the target
  audience and new format."""@en ;
  dcterms:modified "2026-06-07T15:30:29.408910Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8053-1
  a curric:KeyLearningPoint ;
  rdfs:label """Reader identity is the process of reflecting on what you enjoy or do not enjoy
  reading."""@en ;
  dcterms:modified "2026-06-07T15:30:29.408914Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8053-2
  a curric:KeyLearningPoint ;
  rdfs:label "Reading can take many forms; it does not have to be restricted to a book."@en ;
  dcterms:modified "2026-06-07T15:30:29.408918Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8053-3
  a curric:KeyLearningPoint ;
  rdfs:label """Researching the author, illustrator or poet can provide us with an insight into how
  a text was created."""@en ;
  dcterms:modified "2026-06-07T15:30:29.408922Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6590-1
  a curric:KeyLearningPoint ;
  rdfs:label """When preparing to write a biography, it is important to thoroughly research the
  person we are writing about."""@en ;
  dcterms:modified "2026-06-07T15:30:29.409034Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6590-2
  a curric:KeyLearningPoint ;
  rdfs:label """Biographies usually share information about the person's life in chronological
  order."""@en ;
  dcterms:modified "2026-06-07T15:30:29.409038Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6590-3
  a curric:KeyLearningPoint ;
  rdfs:label """Recording information in chronological order helps the reader understand how
  different events are related & sequenced."""@en ;
  dcterms:modified "2026-06-07T15:30:29.409044Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1336-1
  a curric:KeyLearningPoint ;
  rdfs:label "The /shun/ sound spelt -tion is the most common spelling."@en ;
  dcterms:modified "2026-06-07T15:30:29.409089Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1336-2
  a curric:KeyLearningPoint ;
  rdfs:label "The /shun/ sound spelt -tion is used when the root word ends with 't' or 'te'."@en ;
  dcterms:modified "2026-06-07T15:30:29.409093Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1336-3
  a curric:KeyLearningPoint ;
  rdfs:label "The /shun/ sound spelt -cian is used for jobs, e.g. politician, mathematician."@en ;
  dcterms:modified "2026-06-07T15:30:29.409097Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1336-4
  a curric:KeyLearningPoint ;
  rdfs:label """The /shun/ sound spelt -cian is used when the root words ends in 'c' or 'cs' e.g.
  politics-politician."""@en ;
  dcterms:modified "2026-06-07T15:30:29.409101Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1336-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: competition and bargain."@en ;
  dcterms:modified "2026-06-07T15:30:29.409105Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5753-1
  a curric:KeyLearningPoint ;
  rdfs:label "A subheading signals to the reader what the section is about."@en ;
  dcterms:modified "2026-06-07T15:30:29.409309Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5753-2
  a curric:KeyLearningPoint ;
  rdfs:label """A section about one feature of the report's subject contains specific facts and
  information to keep the reader engaged."""@en ;
  dcterms:modified "2026-06-07T15:30:29.409314Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5753-3
  a curric:KeyLearningPoint ;
  rdfs:label """Using the full range of sentence types (simple, compound and complex) improves text
  flow for the reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.409318Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5753-4
  a curric:KeyLearningPoint ;
  rdfs:label """Sentences should be said aloud before writing to ensure they make sense and read
  back once written to check for errors."""@en ;
  dcterms:modified "2026-06-07T15:30:29.409322Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5753-5
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials of cause and formal fronted adverbials are used at the start of
  sentences for cohesion."""@en ;
  dcterms:modified "2026-06-07T15:30:29.409326Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7185-1
  a curric:KeyLearningPoint ;
  rdfs:label "The protagonist is a main character or central figure in a story or narrative."@en ;
  dcterms:modified "2026-06-07T15:30:29.409359Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7185-2
  a curric:KeyLearningPoint ;
  rdfs:label "Lila is the protagonist in the story 'The Firework Maker's Daughter'."@en ;
  dcterms:modified "2026-06-07T15:30:29.409363Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7185-3
  a curric:KeyLearningPoint ;
  rdfs:label """Character development builds a unique character with depth, personality and
  motivations that the reader can connect to."""@en ;
  dcterms:modified "2026-06-07T15:30:29.409370Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7185-4
  a curric:KeyLearningPoint ;
  rdfs:label """We can identify Lila's character traits by exploring her experiences and
  interactions and making inferences."""@en ;
  dcterms:modified "2026-06-07T15:30:29.409376Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7185-5
  a curric:KeyLearningPoint ;
  rdfs:label """Lila displays a range of character traits such as resilience, determination and
  courage."""@en ;
  dcterms:modified "2026-06-07T15:30:29.409381Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7826-1
  a curric:KeyLearningPoint ;
  rdfs:label """'Marcy and the Riddle of the Sphinx' contains important themes relevant to
  traditional myths and modern life experiences"""@en ;
  dcterms:modified "2026-06-07T15:30:29.409385Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7826-2
  a curric:KeyLearningPoint ;
  rdfs:label "A theme is a big idea, topic of message that recurs in a story."@en ;
  dcterms:modified "2026-06-07T15:30:29.409392Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7826-3
  a curric:KeyLearningPoint ;
  rdfs:label """Marcy displays courage, integrity and resilience, among other qualities, in her
  quest."""@en ;
  dcterms:modified "2026-06-07T15:30:29.409396Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7826-4
  a curric:KeyLearningPoint ;
  rdfs:label "Readers can interpret a text, its themes and its meaning in different ways."@en ;
  dcterms:modified "2026-06-07T15:30:29.409402Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7826-5
  a curric:KeyLearningPoint ;
  rdfs:label """Discussing books with others can deepen our understanding and allow us to develop
  our own views."""@en ;
  dcterms:modified "2026-06-07T15:30:29.409409Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4886-1
  a curric:KeyLearningPoint ;
  rdfs:label "A subheading signals to the reader what the section is about."@en ;
  dcterms:modified "2026-06-07T15:30:29.409500Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4886-2
  a curric:KeyLearningPoint ;
  rdfs:label "The steps in the mummification process are written in chronological order."@en ;
  dcterms:modified "2026-06-07T15:30:29.409504Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4886-3
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials of cause and formal fronted adverbials are used at the start of
  sentences for cohesion."""@en ;
  dcterms:modified "2026-06-07T15:30:29.409508Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4886-4
  a curric:KeyLearningPoint ;
  rdfs:label """Using the full range of sentence types (simple, compound and complex) improves text
  flow for the reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.409512Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4886-5
  a curric:KeyLearningPoint ;
  rdfs:label """Explanation texts include subject-specific vocabulary that is related to the subject
  of the text."""@en ;
  dcterms:modified "2026-06-07T15:30:29.409516Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27608-1
  a curric:KeyLearningPoint ;
  rdfs:label """Telling a story in a charismatic way helps to engage the audience and hold their
  interest in a narrative throughout."""@en ;
  dcterms:modified "2026-06-07T15:30:29.409919Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27608-2
  a curric:KeyLearningPoint ;
  rdfs:label "Using expression will help make your story interesting to listen to."@en ;
  dcterms:modified "2026-06-07T15:30:29.409923Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27608-3
  a curric:KeyLearningPoint ;
  rdfs:label """Facial expressions can convey a character’s feelings in response to events in the
  story."""@en ;
  dcterms:modified "2026-06-07T15:30:29.409927Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27608-4
  a curric:KeyLearningPoint ;
  rdfs:label """Using body language and gestures to engage an audience will help to keep their
  attention."""@en ;
  dcterms:modified "2026-06-07T15:30:29.409932Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27608-5
  a curric:KeyLearningPoint ;
  rdfs:label """Using a varied tone and different voices for characters will engage the audience and
  make the story easier to follow."""@en ;
  dcterms:modified "2026-06-07T15:30:29.409936Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6519-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of an essay can be to present a coherent argument in response to a
  question."""@en ;
  dcterms:modified "2026-06-07T15:30:29.409956Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6519-2
  a curric:KeyLearningPoint ;
  rdfs:label """To meet its purpose effectively, the tone of an essay must be formal and
  informative."""@en ;
  dcterms:modified "2026-06-07T15:30:29.409960Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6519-3
  a curric:KeyLearningPoint ;
  rdfs:label """Using correct linguistic features of an essay enables writers to meet the text's
  purpose."""@en ;
  dcterms:modified "2026-06-07T15:30:29.409964Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6522-1
  a curric:KeyLearningPoint ;
  rdfs:label "Writing is most successful when structure, content and vocabulary is planned."@en ;
  dcterms:modified "2026-06-07T15:30:29.409985Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6522-2
  a curric:KeyLearningPoint ;
  rdfs:label "Information in this section should be specific and detailed."@en ;
  dcterms:modified "2026-06-07T15:30:29.409988Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6522-3
  a curric:KeyLearningPoint ;
  rdfs:label "Cohesion, making use of research and a formal tone are appropriate in an essay."@en ;
  dcterms:modified "2026-06-07T15:30:29.409992Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6522-4
  a curric:KeyLearningPoint ;
  rdfs:label """An essay can use a bank of research, evidence, statistics and quotes to inform the
  reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.409997Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7652-1
  a curric:KeyLearningPoint ;
  rdfs:label """When we plan, we log precise and ambitious vocabulary to help paint vivid pictures
  for our reader with words."""@en ;
  dcterms:modified "2026-06-07T15:30:29.410015Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7652-2
  a curric:KeyLearningPoint ;
  rdfs:label """Dialogue is the written conversation between two characters or more within a
  narrative and it moves the story forward."""@en ;
  dcterms:modified "2026-06-07T15:30:29.410019Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7652-3
  a curric:KeyLearningPoint ;
  rdfs:label "A plan is written in note-form, out of full sentences."@en ;
  dcterms:modified "2026-06-07T15:30:29.410023Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7652-4
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the climax is to describe the main action and to take the tension and
  excitement to its highest point."""@en ;
  dcterms:modified "2026-06-07T15:30:29.410027Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7652-5
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the resolution is to resolve a story, tying up its 'loose ends',
  allowing readers a chance to reflect."""@en ;
  dcterms:modified "2026-06-07T15:30:29.410031Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7649-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the opening is to engage the reader and introduce the setting and
  characters."""@en ;
  dcterms:modified "2026-06-07T15:30:29.410035Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7649-2
  a curric:KeyLearningPoint ;
  rdfs:label """Using a range of sentence types (simple, compound and complex) improves text flow
  for the reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.410039Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7649-3
  a curric:KeyLearningPoint ;
  rdfs:label """Direct speech is punctuated using inverted commas. Dialogue moves the action
  forward."""@en ;
  dcterms:modified "2026-06-07T15:30:29.410043Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7649-4
  a curric:KeyLearningPoint ;
  rdfs:label """An adverbial clause is joined with a main clause to form an adverbial complex
  sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.410050Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7649-5
  a curric:KeyLearningPoint ;
  rdfs:label "Notes from the plan are used to form full sentences."@en ;
  dcterms:modified "2026-06-07T15:30:29.410054Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1305-1
  a curric:KeyLearningPoint ;
  rdfs:label "Adding the suffix -ing turns the verb into the progressive tense."@en ;
  dcterms:modified "2026-06-07T15:30:29.410074Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1305-2
  a curric:KeyLearningPoint ;
  rdfs:label """When the vowel sound is short with only one consonant after it, double the consonant
  and add the suffix -ing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.410079Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1305-3
  a curric:KeyLearningPoint ;
  rdfs:label """When the vowel sound is short with more than one consonant after the vowel sound,
  just add the suffix -ing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.410083Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1305-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: though, although and through."@en ;
  dcterms:modified "2026-06-07T15:30:29.410087Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1109-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Frosty' is an adjective which means freezing or icy."@en ;
  dcterms:modified "2026-06-07T15:30:29.410257Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1109-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Numbing' is an adjective which means ice-cold or freezing."@en ;
  dcterms:modified "2026-06-07T15:30:29.410261Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1109-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Penetrating' is an adjective which means piercing or sharp."@en ;
  dcterms:modified "2026-06-07T15:30:29.410265Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7658-1
  a curric:KeyLearningPoint ;
  rdfs:label """When exploring a character’s point of view, we experience life as if through their
  eyes; this is called perspective."""@en ;
  dcterms:modified "2026-06-07T15:30:29.410441Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7658-2
  a curric:KeyLearningPoint ;
  rdfs:label "Paikea feels a deep spiritual and ancestral connection to her Maori heritage."@en ;
  dcterms:modified "2026-06-07T15:30:29.410447Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7658-3
  a curric:KeyLearningPoint ;
  rdfs:label """Despite Koro's disapproval, Paikea is determined to prove herself worthy of carrying
  on the leadership of her tribe."""@en ;
  dcterms:modified "2026-06-07T15:30:29.410452Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7658-4
  a curric:KeyLearningPoint ;
  rdfs:label "Koro is deeply entrenched in the traditional beliefs and customs of the tribe."@en ;
  dcterms:modified "2026-06-07T15:30:29.410456Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7658-5
  a curric:KeyLearningPoint ;
  rdfs:label """Koro sees her desire to lead as a challenge and he dismisses her abilities based on
  her gender."""@en ;
  dcterms:modified "2026-06-07T15:30:29.410460Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1425-1
  a curric:KeyLearningPoint ;
  rdfs:label """A suffix is a letter or group of letters at the end of a word which creates another
  word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.411232Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1425-2
  a curric:KeyLearningPoint ;
  rdfs:label "-ed is a suffix that can be used to create the past tense."@en ;
  dcterms:modified "2026-06-07T15:30:29.411236Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1425-3
  a curric:KeyLearningPoint ;
  rdfs:label "If the verb has a short vowel, double the consonant and add -ed."@en ;
  dcterms:modified "2026-06-07T15:30:29.411240Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1425-4
  a curric:KeyLearningPoint ;
  rdfs:label """Change 'y' to 'i' and add –ed (common rule – unless vowel before ‘y’, e.g.
  enjoy-enjoyed)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.411244Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1425-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum word: busy."@en ;
  dcterms:modified "2026-06-07T15:30:29.411248Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7878-1
  a curric:KeyLearningPoint ;
  rdfs:label "Following their mother’s death, Sophia and her family are split up."@en ;
  dcterms:modified "2026-06-07T15:30:29.412043Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7878-2
  a curric:KeyLearningPoint ;
  rdfs:label """Sophia’s father has decided against regaining his kingdom, he has asked Queen
  Victoria for forgiveness."""@en ;
  dcterms:modified "2026-06-07T15:30:29.412047Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7878-3
  a curric:KeyLearningPoint ;
  rdfs:label """Sophia's father remarries after the death of his wife. Sophia has mixed feelings
  about her step-family."""@en ;
  dcterms:modified "2026-06-07T15:30:29.412051Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7878-4
  a curric:KeyLearningPoint ;
  rdfs:label """Sufiya Ahmed writes the Duleep Singhs with some shared character traits and some
  different traits."""@en ;
  dcterms:modified "2026-06-07T15:30:29.412055Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5499-1
  a curric:KeyLearningPoint ;
  rdfs:label """A colon has two functions - it can introduce a list or an explanation. A dash can
  also introduce an explanation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.412059Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5499-2
  a curric:KeyLearningPoint ;
  rdfs:label """A semi-colon has two functions - to separate detailed items in a list or to join two
  closely-related main clauses."""@en ;
  dcterms:modified "2026-06-07T15:30:29.412063Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5499-3
  a curric:KeyLearningPoint ;
  rdfs:label "Using colons and semi-colons can improve text cohesion."@en ;
  dcterms:modified "2026-06-07T15:30:29.412067Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5499-4
  a curric:KeyLearningPoint ;
  rdfs:label "Bullet points are useful in certain non-fiction texts."@en ;
  dcterms:modified "2026-06-07T15:30:29.412071Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5499-5
  a curric:KeyLearningPoint ;
  rdfs:label "Hyphens are used to join two or more words or parts of words together."@en ;
  dcterms:modified "2026-06-07T15:30:29.412109Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5809-1
  a curric:KeyLearningPoint ;
  rdfs:label "A diary entry combines details about events with details about emotions."@en ;
  dcterms:modified "2026-06-07T15:30:29.412140Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5809-2
  a curric:KeyLearningPoint ;
  rdfs:label """We can use certain linguistic features to create an appropriate tone for a
  diary."""@en ;
  dcterms:modified "2026-06-07T15:30:29.412144Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5809-3
  a curric:KeyLearningPoint ;
  rdfs:label """Hyperbole, internal thoughts, rhetorical questions and exclamation sentences make
  diary writing more personal."""@en ;
  dcterms:modified "2026-06-07T15:30:29.412148Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5809-4
  a curric:KeyLearningPoint ;
  rdfs:label """We connect ideas together in writing with cohesive devices like fronted adverbials
  and different sentence types."""@en ;
  dcterms:modified "2026-06-07T15:30:29.412152Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5809-5
  a curric:KeyLearningPoint ;
  rdfs:label "We may change tense between past and present during a diary entry."@en ;
  dcterms:modified "2026-06-07T15:30:29.412157Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3453-1
  a curric:KeyLearningPoint ;
  rdfs:label "A modal verb is a type of auxiliary verb."@en ;
  dcterms:modified "2026-06-07T15:30:29.412161Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3453-2
  a curric:KeyLearningPoint ;
  rdfs:label "A modal verb is most often paired with the main verb of a clause."@en ;
  dcterms:modified "2026-06-07T15:30:29.412165Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3453-3
  a curric:KeyLearningPoint ;
  rdfs:label "A modal verb is not paired with the main verb if it appears in a question."@en ;
  dcterms:modified "2026-06-07T15:30:29.412169Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3453-4
  a curric:KeyLearningPoint ;
  rdfs:label "Modal verbs are often used in speech sentences and persuasive writing."@en ;
  dcterms:modified "2026-06-07T15:30:29.412173Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3453-5
  a curric:KeyLearningPoint ;
  rdfs:label """A modal verb expresses the degree of possibility, intent, ability or necessity of
  the clause."""@en ;
  dcterms:modified "2026-06-07T15:30:29.412177Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7923-1
  a curric:KeyLearningPoint ;
  rdfs:label """In this section of the book, Joseph learns from Mrs F that his father has died in
  the war."""@en ;
  dcterms:modified "2026-06-07T15:30:29.412181Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7923-2
  a curric:KeyLearningPoint ;
  rdfs:label "Joseph goes through a range of emotions, including denial, anger and guilt."@en ;
  dcterms:modified "2026-06-07T15:30:29.412185Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7923-3
  a curric:KeyLearningPoint ;
  rdfs:label """The author uses descriptions of Joseph's actions, speech and thoughts to depict
  these emotions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.412189Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7923-4
  a curric:KeyLearningPoint ;
  rdfs:label "The author also makes specific language choices to enhance certain emotions."@en ;
  dcterms:modified "2026-06-07T15:30:29.412193Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7923-5
  a curric:KeyLearningPoint ;
  rdfs:label "We make inferences about emotions based on evidence within the text."@en ;
  dcterms:modified "2026-06-07T15:30:29.412197Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1426-1
  a curric:KeyLearningPoint ;
  rdfs:label """A suffix is a letter or group of letters at the end of a word which creates another
  word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.412738Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1426-2
  a curric:KeyLearningPoint ;
  rdfs:label "-ed is a suffix that can be used to create the past tense."@en ;
  dcterms:modified "2026-06-07T15:30:29.412742Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1426-3
  a curric:KeyLearningPoint ;
  rdfs:label "Using the strategy \"look, cover, write, check\" is a useful practice strategy."@en ;
  dcterms:modified "2026-06-07T15:30:29.412746Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1426-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum word: fruit."@en ;
  dcterms:modified "2026-06-07T15:30:29.412750Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1432-1
  a curric:KeyLearningPoint ;
  rdfs:label "For words ending in \"sh\", add the suffix \"-es\" to turn them into a plural."@en ;
  dcterms:modified "2026-06-07T15:30:29.413219Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1432-2
  a curric:KeyLearningPoint ;
  rdfs:label "For words ending in \"ch\", add the suffix \"-es\" to turn them into a plural."@en ;
  dcterms:modified "2026-06-07T15:30:29.413223Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1432-3
  a curric:KeyLearningPoint ;
  rdfs:label "For words ending in \"ss\", add the suffix \"-es\" to turn them into a plural."@en ;
  dcterms:modified "2026-06-07T15:30:29.413227Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1432-4
  a curric:KeyLearningPoint ;
  rdfs:label "For words ending in \"x\", add the suffix \"-es\" to turn them into a plural."@en ;
  dcterms:modified "2026-06-07T15:30:29.413231Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1432-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum word: promise."@en ;
  dcterms:modified "2026-06-07T15:30:29.413235Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5459-1
  a curric:KeyLearningPoint ;
  rdfs:label """'The Pebble in my Pocket' is a narrative non-fiction based on the story of a pebble
  and its journey through time."""@en ;
  dcterms:modified "2026-06-07T15:30:29.413685Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5459-2
  a curric:KeyLearningPoint ;
  rdfs:label """The story has two narrators, the girl who finds the pebble today and the narrator
  who tells its history."""@en ;
  dcterms:modified "2026-06-07T15:30:29.413691Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5459-3
  a curric:KeyLearningPoint ;
  rdfs:label """The history of the pebble begins millions of years ago and is told in chronological
  order."""@en ;
  dcterms:modified "2026-06-07T15:30:29.413695Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5459-4
  a curric:KeyLearningPoint ;
  rdfs:label """Everything that exists has a story to tell and can help us to build our
  understanding of the world."""@en ;
  dcterms:modified "2026-06-07T15:30:29.413699Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7892-1
  a curric:KeyLearningPoint ;
  rdfs:label """'The Listeners' by Walter de la Mare is a thirty-six line poem which is separated
  into 5 sentences."""@en ;
  dcterms:modified "2026-06-07T15:30:29.415096Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7892-2
  a curric:KeyLearningPoint ;
  rdfs:label "The poem follows a consistent pattern of rhyme in the scheme of ABCB."@en ;
  dcterms:modified "2026-06-07T15:30:29.415100Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7892-3
  a curric:KeyLearningPoint ;
  rdfs:label """Walter de la Mare chose to create rhyming pairs that are separated by un-rhyming
  lines."""@en ;
  dcterms:modified "2026-06-07T15:30:29.415104Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7892-4
  a curric:KeyLearningPoint ;
  rdfs:label "Walter de la Mare uses poetic devices to have an effect on the reader."@en ;
  dcterms:modified "2026-06-07T15:30:29.415108Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5454-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘The Moon Dragons’ is a picture book and narrative fiction text that belongs to the
  genre of fantasy."""@en ;
  dcterms:modified "2026-06-07T15:30:29.415125Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5454-2
  a curric:KeyLearningPoint ;
  rdfs:label """The plot of the story is based around the search for mythical creatures called moon
  dragons."""@en ;
  dcterms:modified "2026-06-07T15:30:29.415131Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5454-3
  a curric:KeyLearningPoint ;
  rdfs:label """Summarising the key events in a story helps us to build our understanding of the
  text and the meaning behind it."""@en ;
  dcterms:modified "2026-06-07T15:30:29.415135Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5454-4
  a curric:KeyLearningPoint ;
  rdfs:label """The King offers a room filled with gold to anyone who can retrieve a moon dragon but
  nobody succeeds."""@en ;
  dcterms:modified "2026-06-07T15:30:29.415139Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5454-5
  a curric:KeyLearningPoint ;
  rdfs:label """Alina finds the moon dragons but keeps her discovery a secret in order to protect
  them."""@en ;
  dcterms:modified "2026-06-07T15:30:29.415146Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7842-1
  a curric:KeyLearningPoint ;
  rdfs:label """The information learnt depends on which sections of the text the reader has focused
  on."""@en ;
  dcterms:modified "2026-06-07T15:30:29.415656Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7842-2
  a curric:KeyLearningPoint ;
  rdfs:label """Summarising a topic and discussing it with others deepens understanding and helps
  knowledge to stick."""@en ;
  dcterms:modified "2026-06-07T15:30:29.415660Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7842-3
  a curric:KeyLearningPoint ;
  rdfs:label "Rivers are home to many living things and they are a crucial part of human life."@en ;
  dcterms:modified "2026-06-07T15:30:29.415664Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7842-4
  a curric:KeyLearningPoint ;
  rdfs:label "Human activities can cause harm to rivers."@en ;
  dcterms:modified "2026-06-07T15:30:29.415670Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7842-5
  a curric:KeyLearningPoint ;
  rdfs:label """There are ways that humans can protect rivers for the benefit of all living
  things."""@en ;
  dcterms:modified "2026-06-07T15:30:29.415674Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5841-1
  a curric:KeyLearningPoint ;
  rdfs:label "Writing is most successful when it is planned."@en ;
  dcterms:modified "2026-06-07T15:30:29.415678Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5841-2
  a curric:KeyLearningPoint ;
  rdfs:label """A narrative opening should engage the reader and describe the setting and any
  characters who are present."""@en ;
  dcterms:modified "2026-06-07T15:30:29.415683Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5841-3
  a curric:KeyLearningPoint ;
  rdfs:label "This narrative outcome will be written in the third person."@en ;
  dcterms:modified "2026-06-07T15:30:29.415687Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5841-4
  a curric:KeyLearningPoint ;
  rdfs:label "Using a wide range of precise, ambitious vocabulary enhances text cohesion."@en ;
  dcterms:modified "2026-06-07T15:30:29.415691Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6342-1
  a curric:KeyLearningPoint ;
  rdfs:label "Writing is most successful when it is planned."@en ;
  dcterms:modified "2026-06-07T15:30:29.415695Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6342-2
  a curric:KeyLearningPoint ;
  rdfs:label "Vocabulary can be planned to precisely match a setting."@en ;
  dcterms:modified "2026-06-07T15:30:29.415699Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6342-3
  a curric:KeyLearningPoint ;
  rdfs:label """We can mention items from the appropriate time period in order to show the
  historical context of a setting."""@en ;
  dcterms:modified "2026-06-07T15:30:29.415703Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6342-4
  a curric:KeyLearningPoint ;
  rdfs:label """We can use fronted adverbials and preposition phrases to show where items are in a
  setting."""@en ;
  dcterms:modified "2026-06-07T15:30:29.415707Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7853-1
  a curric:KeyLearningPoint ;
  rdfs:label """Words or phrases can be understood and explained by looking at the context they are
  situated in."""@en ;
  dcterms:modified "2026-06-07T15:30:29.415711Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7853-2
  a curric:KeyLearningPoint ;
  rdfs:label "Re-reading a text helps develop our understanding and fluency."@en ;
  dcterms:modified "2026-06-07T15:30:29.415716Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7853-3
  a curric:KeyLearningPoint ;
  rdfs:label "Walter Tull was the first Black British professional outfield football player."@en ;
  dcterms:modified "2026-06-07T15:30:29.415720Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7853-4
  a curric:KeyLearningPoint ;
  rdfs:label """Walter Tull experienced discrimination and prejudice based on the colour of his
  skin."""@en ;
  dcterms:modified "2026-06-07T15:30:29.415724Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7905-1
  a curric:KeyLearningPoint ;
  rdfs:label """The new Queen is poisoning Prince Just. Blackberry Blue cures him and he reappears
  at the climax of the story."""@en ;
  dcterms:modified "2026-06-07T15:30:29.416077Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7905-2
  a curric:KeyLearningPoint ;
  rdfs:label "Readers can infer by using clues from within the text to draw conclusions."@en ;
  dcterms:modified "2026-06-07T15:30:29.416083Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7905-3
  a curric:KeyLearningPoint ;
  rdfs:label """Evidence from the text can be used to develop answers to questions and support
  reasoning."""@en ;
  dcterms:modified "2026-06-07T15:30:29.416087Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7905-4
  a curric:KeyLearningPoint ;
  rdfs:label """Evidence should be concise and justify the point that readers are trying to make in
  relation to the question."""@en ;
  dcterms:modified "2026-06-07T15:30:29.416091Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7905-5
  a curric:KeyLearningPoint ;
  rdfs:label """An impression of a person, place or thing can be formed by a reader's initial
  feelings or from prior experience."""@en ;
  dcterms:modified "2026-06-07T15:30:29.416095Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7840-1
  a curric:KeyLearningPoint ;
  rdfs:label """Non-fiction texts do not have to be read in order from the first to the last
  page."""@en ;
  dcterms:modified "2026-06-07T15:30:29.416099Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7840-2
  a curric:KeyLearningPoint ;
  rdfs:label """Using the features of a non-fiction text helps the reader to navigate the text
  effectively."""@en ;
  dcterms:modified "2026-06-07T15:30:29.416104Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7840-3
  a curric:KeyLearningPoint ;
  rdfs:label """Skimming and scanning for keywords helps the reader find and retrieve important
  information."""@en ;
  dcterms:modified "2026-06-07T15:30:29.416108Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7840-4
  a curric:KeyLearningPoint ;
  rdfs:label """Note-taking is an effective way to summarise the most important information and
  embed new knowledge."""@en ;
  dcterms:modified "2026-06-07T15:30:29.416112Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6691-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of a build-up is to move the main character’s journey forward and build
  tension."""@en ;
  dcterms:modified "2026-06-07T15:30:29.416116Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6691-2
  a curric:KeyLearningPoint ;
  rdfs:label """Precise and ambitious vocabulary shows and tells the reader what happened on her
  journey and how she was feeling."""@en ;
  dcterms:modified "2026-06-07T15:30:29.416120Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6691-3
  a curric:KeyLearningPoint ;
  rdfs:label """Using a range of sentence types (simple, compound and complex) improves text flow
  for the reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.416126Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6691-4
  a curric:KeyLearningPoint ;
  rdfs:label "An adverbial clause begins with a subordinating conjunction."@en ;
  dcterms:modified "2026-06-07T15:30:29.416131Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6691-5
  a curric:KeyLearningPoint ;
  rdfs:label """An adverbial clause is joined with a main clause to form an adverbial complex
  sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.416135Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1430-1
  a curric:KeyLearningPoint ;
  rdfs:label "For some words you can add \"-s\" to turn into a plural."@en ;
  dcterms:modified "2026-06-07T15:30:29.416276Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1430-2
  a curric:KeyLearningPoint ;
  rdfs:label "For words ending in \"y\", you change the \"y\" to an \"i\" and add \"-es\"."@en ;
  dcterms:modified "2026-06-07T15:30:29.416281Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1430-3
  a curric:KeyLearningPoint ;
  rdfs:label """For words ending in \"y\" that have a vowel before the \"y\", you can just add
  \"s\"."""@en ;
  dcterms:modified "2026-06-07T15:30:29.416287Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1430-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: early and probably."@en ;
  dcterms:modified "2026-06-07T15:30:29.416291Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7924-1
  a curric:KeyLearningPoint ;
  rdfs:label """In the final stages of the book, we see Joseph saved by Adonis before Adonis is shot
  dead."""@en ;
  dcterms:modified "2026-06-07T15:30:29.416295Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7924-2
  a curric:KeyLearningPoint ;
  rdfs:label """We also see Joseph and Mrs F united in their grief with Joseph finally learning to
  trust her."""@en ;
  dcterms:modified "2026-06-07T15:30:29.416300Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7924-3
  a curric:KeyLearningPoint ;
  rdfs:label """We can connect books we read to abstract concepts; we can connect this book to our
  understanding of 'compassion'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.416304Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7924-4
  a curric:KeyLearningPoint ;
  rdfs:label """We can also identify themes that run through the book - for example, the idea that
  people are capable of change."""@en ;
  dcterms:modified "2026-06-07T15:30:29.416308Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7928-1
  a curric:KeyLearningPoint ;
  rdfs:label "The weather in Trinidad contrasted between being hot and raining."@en ;
  dcterms:modified "2026-06-07T15:30:29.416341Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7928-2
  a curric:KeyLearningPoint ;
  rdfs:label """Imagery in writing refers to the use of vivid and descriptive language that appeals
  to the senses."""@en ;
  dcterms:modified "2026-06-07T15:30:29.416345Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7928-3
  a curric:KeyLearningPoint ;
  rdfs:label """Imagery is used by the author, Floella Benjamin, during Chapter 4 to convey how she
  experiences her childhood setting."""@en ;
  dcterms:modified "2026-06-07T15:30:29.416351Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6328-1
  a curric:KeyLearningPoint ;
  rdfs:label """'Shackleton's Journey' includes themes of leadership, resilience, hope and
  exploration."""@en ;
  dcterms:modified "2026-06-07T15:30:29.416356Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6328-2
  a curric:KeyLearningPoint ;
  rdfs:label """Shackleton is recognised as an excellent leader, who remained determined in the face
  of adversity."""@en ;
  dcterms:modified "2026-06-07T15:30:29.416362Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6328-3
  a curric:KeyLearningPoint ;
  rdfs:label """Ernest Shackleton set an excellent example to his crew; he was an inspirational role
  model."""@en ;
  dcterms:modified "2026-06-07T15:30:29.416368Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5850-1
  a curric:KeyLearningPoint ;
  rdfs:label "A soliloquy occurs when a character voices their thoughts and feelings aloud."@en ;
  dcterms:modified "2026-06-07T15:30:29.416372Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5850-2
  a curric:KeyLearningPoint ;
  rdfs:label "This soliloquy outlines Macbeth's dilemma."@en ;
  dcterms:modified "2026-06-07T15:30:29.416376Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5850-3
  a curric:KeyLearningPoint ;
  rdfs:label """Soliloquies can feature a range of sentence types, rhetorical questions and modal
  verbs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.416380Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5850-4
  a curric:KeyLearningPoint ;
  rdfs:label "A soliloquy is written from the first person perspective."@en ;
  dcterms:modified "2026-06-07T15:30:29.416385Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7662-1
  a curric:KeyLearningPoint ;
  rdfs:label "Ambitious vocabulary can be logged on a plan for future use."@en ;
  dcterms:modified "2026-06-07T15:30:29.416389Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7662-2
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials of time, place and manner indicate when, where and how action
  takes place."""@en ;
  dcterms:modified "2026-06-07T15:30:29.416393Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7662-3
  a curric:KeyLearningPoint ;
  rdfs:label """Dialogue, using direct speech, moves the plot forward and develops characters in a
  story."""@en ;
  dcterms:modified "2026-06-07T15:30:29.416397Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7662-4
  a curric:KeyLearningPoint ;
  rdfs:label """Show-not-tell language shows a character’s feelings by describing their actions,
  body language and facial expressions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.416401Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7662-5
  a curric:KeyLearningPoint ;
  rdfs:label """Notes should not be written in full sentences and bullet points can be used to make
  notes clear."""@en ;
  dcterms:modified "2026-06-07T15:30:29.416405Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5701-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the resolution is to resolve the story and give readers a chance to
  reflect."""@en ;
  dcterms:modified "2026-06-07T15:30:29.416410Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5701-2
  a curric:KeyLearningPoint ;
  rdfs:label "Precise and ambitious vocabulary is logged on a plan for future use."@en ;
  dcterms:modified "2026-06-07T15:30:29.416414Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5701-3
  a curric:KeyLearningPoint ;
  rdfs:label """Notes should not be written in full sentences and bullet points can be used to make
  notes clear."""@en ;
  dcterms:modified "2026-06-07T15:30:29.416418Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5701-4
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials of time, place and manner indicate when, where and how an action
  takes place."""@en ;
  dcterms:modified "2026-06-07T15:30:29.416422Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1366-1
  a curric:KeyLearningPoint ;
  rdfs:label "The suffixes -en and -ate often turns adjectives and nouns into verbs."@en ;
  dcterms:modified "2026-06-07T15:30:29.416460Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1366-2
  a curric:KeyLearningPoint ;
  rdfs:label "When the root word ends in a consonant, we often just add the suffix."@en ;
  dcterms:modified "2026-06-07T15:30:29.416465Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1366-3
  a curric:KeyLearningPoint ;
  rdfs:label """When the root word ends in a vowel, we remove the final vowel and add the
  suffix."""@en ;
  dcterms:modified "2026-06-07T15:30:29.416469Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1366-4
  a curric:KeyLearningPoint ;
  rdfs:label """When the root word has a short vowel, we double the consonant and add the
  suffix."""@en ;
  dcterms:modified "2026-06-07T15:30:29.416474Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1366-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: separate, desperate and communicate."@en ;
  dcterms:modified "2026-06-07T15:30:29.416480Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1060-1
  a curric:KeyLearningPoint ;
  rdfs:label """A non-chronological report is a non-fiction text that provides information about a
  particular subject."""@en ;
  dcterms:modified "2026-06-07T15:30:29.416485Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1060-2
  a curric:KeyLearningPoint ;
  rdfs:label """Vocabulary within an explanation text is subject-specific and factual, creating a
  formal tone."""@en ;
  dcterms:modified "2026-06-07T15:30:29.416489Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1060-3
  a curric:KeyLearningPoint ;
  rdfs:label """Viewpoint fronted adverbials are a type of sentece starter and they show the
  writer's point of view."""@en ;
  dcterms:modified "2026-06-07T15:30:29.416493Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1060-4
  a curric:KeyLearningPoint ;
  rdfs:label "Formal 'but' fronted adverbials contrast a point made in the previous sentence."@en ;
  dcterms:modified "2026-06-07T15:30:29.416497Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1060-5
  a curric:KeyLearningPoint ;
  rdfs:label "Formal 'and' fronted adverbials build on a point made in the previous sentence."@en ;
  dcterms:modified "2026-06-07T15:30:29.416501Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5456-1
  a curric:KeyLearningPoint ;
  rdfs:label "The protagonist is a main character or central figure in a story or narrative."@en ;
  dcterms:modified "2026-06-07T15:30:29.416506Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5456-2
  a curric:KeyLearningPoint ;
  rdfs:label "Alina is the protagonist in 'The Moon Dragons'."@en ;
  dcterms:modified "2026-06-07T15:30:29.416510Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5456-3
  a curric:KeyLearningPoint ;
  rdfs:label """Character traits are the special qualities that make a character in a story unique
  and interesting."""@en ;
  dcterms:modified "2026-06-07T15:30:29.416514Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5456-4
  a curric:KeyLearningPoint ;
  rdfs:label """We can identify Alina's character traits by exploring her experiences and
  interactions and making inferences."""@en ;
  dcterms:modified "2026-06-07T15:30:29.416518Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5456-5
  a curric:KeyLearningPoint ;
  rdfs:label """Alina displays a range of character traits such as resilience, bravery, and
  morality."""@en ;
  dcterms:modified "2026-06-07T15:30:29.416523Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6368-1
  a curric:KeyLearningPoint ;
  rdfs:label """Adverbials of time, place and manner explain to the reader when, where and how
  things happened."""@en ;
  dcterms:modified "2026-06-07T15:30:29.416528Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6368-2
  a curric:KeyLearningPoint ;
  rdfs:label "Figurative language can be used to create atmosphere and imagery for the reader."@en ;
  dcterms:modified "2026-06-07T15:30:29.416533Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6368-3
  a curric:KeyLearningPoint ;
  rdfs:label """A complex sentence consists of at least one main clause and any type of subordinate
  clause."""@en ;
  dcterms:modified "2026-06-07T15:30:29.416539Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6368-4
  a curric:KeyLearningPoint ;
  rdfs:label "Using a range of sentence types enhances the flow of a text."@en ;
  dcterms:modified "2026-06-07T15:30:29.416544Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6000-1
  a curric:KeyLearningPoint ;
  rdfs:label """Persuasive letters have distinctive linguistic features in order to achieve their
  purpose."""@en ;
  dcterms:modified "2026-06-07T15:30:29.416548Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6000-2
  a curric:KeyLearningPoint ;
  rdfs:label """An adverbial complex sentence is a main clause and an adverbial clause that starts
  with a subordinating conjunction."""@en ;
  dcterms:modified "2026-06-07T15:30:29.416552Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6000-3
  a curric:KeyLearningPoint ;
  rdfs:label "The subordinating conjunction ‘because’ introduces a reason."@en ;
  dcterms:modified "2026-06-07T15:30:29.416556Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6000-4
  a curric:KeyLearningPoint ;
  rdfs:label "Oral rehearsal of full sentences helps to ensure they are structured accurately."@en ;
  dcterms:modified "2026-06-07T15:30:29.416563Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6000-5
  a curric:KeyLearningPoint ;
  rdfs:label """First person perspective is the point of view where the writer is the 'I'
  character."""@en ;
  dcterms:modified "2026-06-07T15:30:29.416567Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2698-1
  a curric:KeyLearningPoint ;
  rdfs:label """A comma is written before \"but\" or \"or\" co-ordinating conjunctions in a compound
  sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.416572Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2698-2
  a curric:KeyLearningPoint ;
  rdfs:label """If the adverbial clause is first in an adverbial complex sentence, it is followed by
  a comma before the main clause."""@en ;
  dcterms:modified "2026-06-07T15:30:29.416576Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2698-3
  a curric:KeyLearningPoint ;
  rdfs:label """If the main clause is first in an adverbial complex sentence, it is not followed by
  a comma before the adverbial clause."""@en ;
  dcterms:modified "2026-06-07T15:30:29.416580Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2698-4
  a curric:KeyLearningPoint ;
  rdfs:label """Commas are often used to demarcate clauses in compound and complex sentence
  structures."""@en ;
  dcterms:modified "2026-06-07T15:30:29.416584Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2698-5
  a curric:KeyLearningPoint ;
  rdfs:label """Commas may be found in a simple sentence for other purposes than clause
  demarcation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.416588Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5815-1
  a curric:KeyLearningPoint ;
  rdfs:label "We have planned the structure, content and vocabulary for our narrative."@en ;
  dcterms:modified "2026-06-07T15:30:29.416592Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5815-2
  a curric:KeyLearningPoint ;
  rdfs:label """When we write, we use cohesive devices to connect these plan notes together into
  coherent sentences."""@en ;
  dcterms:modified "2026-06-07T15:30:29.416599Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5815-3
  a curric:KeyLearningPoint ;
  rdfs:label """We should aim to include all the narrative elements of action, description, dialogue
  and emotions in our writing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.416603Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5815-4
  a curric:KeyLearningPoint ;
  rdfs:label "Oral rehearsal prior to writing helps us to write more easily."@en ;
  dcterms:modified "2026-06-07T15:30:29.416607Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5815-5
  a curric:KeyLearningPoint ;
  rdfs:label "We can use adverbs to add detail to describe how verbs have been done."@en ;
  dcterms:modified "2026-06-07T15:30:29.416612Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7631-1
  a curric:KeyLearningPoint ;
  rdfs:label """Descriptive writing uses figurative language to create vivid pictures in the
  reader's mind."""@en ;
  dcterms:modified "2026-06-07T15:30:29.416616Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7631-2
  a curric:KeyLearningPoint ;
  rdfs:label """Descriptive writing appeals to the reader's five senses: sight, sound, smell, taste
  and touch."""@en ;
  dcterms:modified "2026-06-07T15:30:29.416620Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7631-3
  a curric:KeyLearningPoint ;
  rdfs:label "Descriptive writing uses precise and ambitious vocabulary."@en ;
  dcterms:modified "2026-06-07T15:30:29.416624Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7631-4
  a curric:KeyLearningPoint ;
  rdfs:label "Simile and personification are types of figurative language."@en ;
  dcterms:modified "2026-06-07T15:30:29.416628Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8084-1
  a curric:KeyLearningPoint ;
  rdfs:label """After we have taken time to understand a poem’s meaning, themes and structure, we
  can learn a poem off by heart."""@en ;
  dcterms:modified "2026-06-07T15:30:29.416685Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8084-2
  a curric:KeyLearningPoint ;
  rdfs:label """Learning poetry by heart offers a range of benefits, both emotionally and
  academically."""@en ;
  dcterms:modified "2026-06-07T15:30:29.416690Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8084-3
  a curric:KeyLearningPoint ;
  rdfs:label """Hiding certain words in a poem engages readers in active retrieval practice,
  strengthening our memory recall."""@en ;
  dcterms:modified "2026-06-07T15:30:29.416694Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8084-4
  a curric:KeyLearningPoint ;
  rdfs:label """Understanding a poem, its language and the impression it creates will help us to
  create an impactful performance."""@en ;
  dcterms:modified "2026-06-07T15:30:29.416698Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8084-5
  a curric:KeyLearningPoint ;
  rdfs:label """We can improve our performances by considering the pace, the atmosphere and our own
  use of voice and movement."""@en ;
  dcterms:modified "2026-06-07T15:30:29.416702Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6114-1
  a curric:KeyLearningPoint ;
  rdfs:label """A non-chronological report is written to inform the reader about a subject or event
  out of time order."""@en ;
  dcterms:modified "2026-06-07T15:30:29.416707Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6114-2
  a curric:KeyLearningPoint ;
  rdfs:label """The introduction of a non-chronological report summarises the general information
  about the subject."""@en ;
  dcterms:modified "2026-06-07T15:30:29.416711Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6114-3
  a curric:KeyLearningPoint ;
  rdfs:label "Within the introduction, text that flows well and cohesively is important."@en ;
  dcterms:modified "2026-06-07T15:30:29.416715Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6114-4
  a curric:KeyLearningPoint ;
  rdfs:label "Text cohesion can be achieved by using a range of cohesive devices."@en ;
  dcterms:modified "2026-06-07T15:30:29.416719Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6114-5
  a curric:KeyLearningPoint ;
  rdfs:label """We can use compound sentences, complex sentences, fronted adverbials and parenthesis
  as cohesive devices."""@en ;
  dcterms:modified "2026-06-07T15:30:29.416726Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6104-1
  a curric:KeyLearningPoint ;
  rdfs:label """Information in a section becomes more specific and detailed as the section
  goes on."""@en ;
  dcterms:modified "2026-06-07T15:30:29.416730Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6104-2
  a curric:KeyLearningPoint ;
  rdfs:label "Facts written in a section should be researched and organised prior to writing."@en ;
  dcterms:modified "2026-06-07T15:30:29.416734Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6104-3
  a curric:KeyLearningPoint ;
  rdfs:label "A range of cohesive devices helps us to link facts within and between sentences."@en ;
  dcterms:modified "2026-06-07T15:30:29.416738Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6104-4
  a curric:KeyLearningPoint ;
  rdfs:label """Before we write, we should orally rehearse sentences to ensure our sentences make
  sense and flow well."""@en ;
  dcterms:modified "2026-06-07T15:30:29.416743Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6104-5
  a curric:KeyLearningPoint ;
  rdfs:label """Parenthesis, varied sentence types and a range of fronted adverbials are all
  cohesive devices that can be used."""@en ;
  dcterms:modified "2026-06-07T15:30:29.416747Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27892-1
  a curric:KeyLearningPoint ;
  rdfs:label "The motion is the name for the belief or proposal that is being debated."@en ;
  dcterms:modified "2026-06-07T15:30:29.416774Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27892-2
  a curric:KeyLearningPoint ;
  rdfs:label "An effective motion should be one that people can either agree or disagree with."@en ;
  dcterms:modified "2026-06-07T15:30:29.416778Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27892-3
  a curric:KeyLearningPoint ;
  rdfs:label "An effective motion should be relatable and important."@en ;
  dcterms:modified "2026-06-07T15:30:29.416783Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8056-1
  a curric:KeyLearningPoint ;
  rdfs:label """Reading a range of poetry, from diverse poets, can develop our appreciation of the
  poetic form"""@en ;
  dcterms:modified "2026-06-07T15:30:29.416787Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8056-2
  a curric:KeyLearningPoint ;
  rdfs:label """Poetry can take many forms, including: haiku, limerick, cinquain, sonnet, tanka,
  riddle, acrostic"""@en ;
  dcterms:modified "2026-06-07T15:30:29.416791Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8056-3
  a curric:KeyLearningPoint ;
  rdfs:label "A lyric can be written in poem form; lyrics can express the writer's emotions"@en ;
  dcterms:modified "2026-06-07T15:30:29.416795Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8056-4
  a curric:KeyLearningPoint ;
  rdfs:label """A verse novel is a narrative told through poetry, blending prose and poetic
  elements"""@en ;
  dcterms:modified "2026-06-07T15:30:29.416799Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27627-1
  a curric:KeyLearningPoint ;
  rdfs:label """A debate can be led by a chairperson who introduces the speakers and keeps
  order."""@en ;
  dcterms:modified "2026-06-07T15:30:29.416806Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27627-2
  a curric:KeyLearningPoint ;
  rdfs:label """A debate is timed by a timekeeper so that each speaker has the same amount of time
  to speak."""@en ;
  dcterms:modified "2026-06-07T15:30:29.416810Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27627-3
  a curric:KeyLearningPoint ;
  rdfs:label """A point of information is a brief attempted interruption of someone’s speech and is
  similar to rebuttal."""@en ;
  dcterms:modified "2026-06-07T15:30:29.416814Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6275-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of a non-fiction text is to inform, explain, or provide factual
  information about a particular topic/subject"""@en ;
  dcterms:modified "2026-06-07T15:30:29.416818Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6275-2
  a curric:KeyLearningPoint ;
  rdfs:label "There are several features that non-fiction texts have in common."@en ;
  dcterms:modified "2026-06-07T15:30:29.416823Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6275-3
  a curric:KeyLearningPoint ;
  rdfs:label """An index in a non-fiction text allows readers to quickly locate specific topics,
  terms, or concepts."""@en ;
  dcterms:modified "2026-06-07T15:30:29.416829Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1131-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Discerning' is an adjective which means clear-sighted or selective."@en ;
  dcterms:modified "2026-06-07T15:30:29.416833Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1131-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Innovative' is an adjective which means creative or original."@en ;
  dcterms:modified "2026-06-07T15:30:29.416837Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1131-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Astute' is an adjective which means shrewd or quick-witted."@en ;
  dcterms:modified "2026-06-07T15:30:29.416841Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8077-1
  a curric:KeyLearningPoint ;
  rdfs:label """Reader identity is the process of reflecting on what you enjoy or do not enjoy
  reading"""@en ;
  dcterms:modified "2026-06-07T15:30:29.416878Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8077-2
  a curric:KeyLearningPoint ;
  rdfs:label "Reading is a very personal experience; it is unique to every reader"@en ;
  dcterms:modified "2026-06-07T15:30:29.416884Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8077-3
  a curric:KeyLearningPoint ;
  rdfs:label "Reading can take many forms; it does not have to be restricted to a book"@en ;
  dcterms:modified "2026-06-07T15:30:29.416889Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8077-4
  a curric:KeyLearningPoint ;
  rdfs:label "Texts can connect with readers on an emotional and intellectual level"@en ;
  dcterms:modified "2026-06-07T15:30:29.416893Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8077-5
  a curric:KeyLearningPoint ;
  rdfs:label "Texts can have a profound effect on the reader"@en ;
  dcterms:modified "2026-06-07T15:30:29.416897Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5485-1
  a curric:KeyLearningPoint ;
  rdfs:label """Connecting information in \"Escape from Pompeii\" to our background knowledge can
  help us to deepen our understanding."""@en ;
  dcterms:modified "2026-06-07T15:30:29.416901Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5485-2
  a curric:KeyLearningPoint ;
  rdfs:label "Before the eruption of Mount Vesuvius, Pompeii was a busy Roman city."@en ;
  dcterms:modified "2026-06-07T15:30:29.416905Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5485-3
  a curric:KeyLearningPoint ;
  rdfs:label "Mount Vesuvius erupted on 24 August AD 79."@en ;
  dcterms:modified "2026-06-07T15:30:29.416909Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5485-4
  a curric:KeyLearningPoint ;
  rdfs:label "The city was covered in ash and many people died."@en ;
  dcterms:modified "2026-06-07T15:30:29.416913Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5485-5
  a curric:KeyLearningPoint ;
  rdfs:label "The afterword provides the reader with valuable information and context."@en ;
  dcterms:modified "2026-06-07T15:30:29.416917Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1316-1
  a curric:KeyLearningPoint ;
  rdfs:label """The plan includes keywords and subject-specific vocabulary related to the
  section."""@en ;
  dcterms:modified "2026-06-07T15:30:29.417282Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1316-2
  a curric:KeyLearningPoint ;
  rdfs:label "Taking notes is a skill."@en ;
  dcterms:modified "2026-06-07T15:30:29.417287Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1316-3
  a curric:KeyLearningPoint ;
  rdfs:label """Notes should not be written in full sentences and bullet points can be used to order
  notes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.417291Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1316-4
  a curric:KeyLearningPoint ;
  rdfs:label "Key vocabulary and linguistic devices should be logged in a plan."@en ;
  dcterms:modified "2026-06-07T15:30:29.417295Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1316-5
  a curric:KeyLearningPoint ;
  rdfs:label "The plan should be clearly structured in the order of the section."@en ;
  dcterms:modified "2026-06-07T15:30:29.417299Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1447-1
  a curric:KeyLearningPoint ;
  rdfs:label "The spelling of words with 'silent letters' often reflects old pronunciation."@en ;
  dcterms:modified "2026-06-07T15:30:29.417303Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1447-2
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell words using 'mb', 'wr', 'kn' and 'gn'."@en ;
  dcterms:modified "2026-06-07T15:30:29.417308Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1447-3
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum word: sentence."@en ;
  dcterms:modified "2026-06-07T15:30:29.417312Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1447-4
  a curric:KeyLearningPoint ;
  rdfs:label "Using the strategy 'naughty letters' is a useful practice strategy."@en ;
  dcterms:modified "2026-06-07T15:30:29.417316Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8064-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘Pike’ was written by Ted Hughes in 1960; the poem consists of eleven verses, each
  with four lines."""@en ;
  dcterms:modified "2026-06-07T15:30:29.417320Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8064-2
  a curric:KeyLearningPoint ;
  rdfs:label """Hughes often used animals, landscapes and elemental forces as symbols in his
  work."""@en ;
  dcterms:modified "2026-06-07T15:30:29.417324Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8064-3
  a curric:KeyLearningPoint ;
  rdfs:label """Hughes uses vivid imagery in the poem to create a rich and sensory description of
  the pike and its environment."""@en ;
  dcterms:modified "2026-06-07T15:30:29.417328Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8064-4
  a curric:KeyLearningPoint ;
  rdfs:label """Researching about the subject of a poem can greatly enhance readers'
  understanding."""@en ;
  dcterms:modified "2026-06-07T15:30:29.417333Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8064-5
  a curric:KeyLearningPoint ;
  rdfs:label "The goal of research is to enrich and engage readers in a poem."@en ;
  dcterms:modified "2026-06-07T15:30:29.417337Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5693-1
  a curric:KeyLearningPoint ;
  rdfs:label """Narrative writing can be structured into an opening, a build-up, a climax and a
  resolution."""@en ;
  dcterms:modified "2026-06-07T15:30:29.417341Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5693-2
  a curric:KeyLearningPoint ;
  rdfs:label "Each part of a story has a specific purpose and intended effect for the reader."@en ;
  dcterms:modified "2026-06-07T15:30:29.417345Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5693-3
  a curric:KeyLearningPoint ;
  rdfs:label "'The Man on the Moon’ can be summarised into five key parts."@en ;
  dcterms:modified "2026-06-07T15:30:29.417349Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5693-4
  a curric:KeyLearningPoint ;
  rdfs:label "Sequencing places the story's events in chronological order."@en ;
  dcterms:modified "2026-06-07T15:30:29.417356Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5656-1
  a curric:KeyLearningPoint ;
  rdfs:label "The Mars rover marked a significant development in space exploration."@en ;
  dcterms:modified "2026-06-07T15:30:29.417574Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5656-2
  a curric:KeyLearningPoint ;
  rdfs:label "‘Curiosity: The Story of a Mars Rover’ is a narrative non-fiction book."@en ;
  dcterms:modified "2026-06-07T15:30:29.417578Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5656-3
  a curric:KeyLearningPoint ;
  rdfs:label "The text is told from the perspective of NASA’s Mars rover, ‘Curiosity’."@en ;
  dcterms:modified "2026-06-07T15:30:29.417582Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5656-4
  a curric:KeyLearningPoint ;
  rdfs:label """Exploring the context of Mars and the rover mission helps us understand the text
  better."""@en ;
  dcterms:modified "2026-06-07T15:30:29.417587Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5656-5
  a curric:KeyLearningPoint ;
  rdfs:label "The rover set out to study Martian climate, geology and potential for life."@en ;
  dcterms:modified "2026-06-07T15:30:29.417591Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6735-1
  a curric:KeyLearningPoint ;
  rdfs:label """Addie is the protagonist in 'A Kind of Spark'; she is autistic, but this does not
  define her exclusively."""@en ;
  dcterms:modified "2026-06-07T15:30:29.417725Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6735-2
  a curric:KeyLearningPoint ;
  rdfs:label """Addie has a range of character traits including bravery, determination and
  single-mindedness."""@en ;
  dcterms:modified "2026-06-07T15:30:29.417729Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6735-3
  a curric:KeyLearningPoint ;
  rdfs:label "We can identify character traits by looking at evidence in the text."@en ;
  dcterms:modified "2026-06-07T15:30:29.417733Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6735-4
  a curric:KeyLearningPoint ;
  rdfs:label """We can identify a structure within a narrative including an opening, build-up,
  climax and resolution."""@en ;
  dcterms:modified "2026-06-07T15:30:29.417737Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6735-5
  a curric:KeyLearningPoint ;
  rdfs:label """We can track a character's emotions across a story to understand more about their
  personality."""@en ;
  dcterms:modified "2026-06-07T15:30:29.417741Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1321-1
  a curric:KeyLearningPoint ;
  rdfs:label "Editing is the process of making changes to improve writing."@en ;
  dcterms:modified "2026-06-07T15:30:29.417745Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1321-2
  a curric:KeyLearningPoint ;
  rdfs:label """When editing punctuation, missing or incorrect punctuation, like capital letters,
  full stops and commas, is checked."""@en ;
  dcterms:modified "2026-06-07T15:30:29.417749Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1321-3
  a curric:KeyLearningPoint ;
  rdfs:label """When editing sentence structure, the flow of sentences and the variety of sentence
  types used are checked."""@en ;
  dcterms:modified "2026-06-07T15:30:29.417753Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1321-4
  a curric:KeyLearningPoint ;
  rdfs:label """When editing language, word and phrase choices are checked to ensure they meet the
  tone required."""@en ;
  dcterms:modified "2026-06-07T15:30:29.417757Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4815-1
  a curric:KeyLearningPoint ;
  rdfs:label "Common exception words do not follow regular spelling or phonics rules."@en ;
  dcterms:modified "2026-06-07T15:30:29.417785Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4815-2
  a curric:KeyLearningPoint ;
  rdfs:label """Letters in the common exception words will be joined using a range of joins
  depending on the letters in the word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.417789Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4815-3
  a curric:KeyLearningPoint ;
  rdfs:label "The first letter always has a lead in and the last letter always has a lead out."@en ;
  dcterms:modified "2026-06-07T15:30:29.417795Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4815-4
  a curric:KeyLearningPoint ;
  rdfs:label "There is appropriate spacing between the letters."@en ;
  dcterms:modified "2026-06-07T15:30:29.417799Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4815-5
  a curric:KeyLearningPoint ;
  rdfs:label "You don't lift your pencil when forming the joins."@en ;
  dcterms:modified "2026-06-07T15:30:29.417803Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1399-1
  a curric:KeyLearningPoint ;
  rdfs:label """A prefix is a letter or group of letters at the start of a word which changes its
  meaning."""@en ;
  dcterms:modified "2026-06-07T15:30:29.417807Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1399-2
  a curric:KeyLearningPoint ;
  rdfs:label "The prefixes ad- and af- mean ‘towards’."@en ;
  dcterms:modified "2026-06-07T15:30:29.417811Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1399-3
  a curric:KeyLearningPoint ;
  rdfs:label "The prefix al- means ‘all’ and a- means ‘in the state of’."@en ;
  dcterms:modified "2026-06-07T15:30:29.417816Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1399-4
  a curric:KeyLearningPoint ;
  rdfs:label """A hyphen can join a prefix to a base word to avoid ambiguity in meaning or
  spelling."""@en ;
  dcterms:modified "2026-06-07T15:30:29.417820Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1399-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: experience, extreme and increase."@en ;
  dcterms:modified "2026-06-07T15:30:29.417824Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1339-1
  a curric:KeyLearningPoint ;
  rdfs:label "There are four spelling rules when adding -ous to a root word."@en ;
  dcterms:modified "2026-06-07T15:30:29.417869Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1339-2
  a curric:KeyLearningPoint ;
  rdfs:label "If the root word ends in 'ce', use the suffix -cious"@en ;
  dcterms:modified "2026-06-07T15:30:29.417876Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1339-3
  a curric:KeyLearningPoint ;
  rdfs:label "The suffix -cious generally turns a noun into an adjective."@en ;
  dcterms:modified "2026-06-07T15:30:29.417880Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1339-4
  a curric:KeyLearningPoint ;
  rdfs:label """Exceptions or harder root words to identify include these words: anxious, conscious,
  delicious, suspicious, precious."""@en ;
  dcterms:modified "2026-06-07T15:30:29.417884Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1339-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: prejudice, accommodate and accompany."@en ;
  dcterms:modified "2026-06-07T15:30:29.417889Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4810-1
  a curric:KeyLearningPoint ;
  rdfs:label "-sure and -ture are common spellings for the endings of words."@en ;
  dcterms:modified "2026-06-07T15:30:29.417909Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4810-2
  a curric:KeyLearningPoint ;
  rdfs:label "The words start with a lead in and finish with a lead out."@en ;
  dcterms:modified "2026-06-07T15:30:29.417913Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4810-3
  a curric:KeyLearningPoint ;
  rdfs:label """The pencil does not lift when forming the join, only after to add the cross to a t
  or a dot to an i or a j."""@en ;
  dcterms:modified "2026-06-07T15:30:29.417917Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4810-4
  a curric:KeyLearningPoint ;
  rdfs:label "There are four cursive joins."@en ;
  dcterms:modified "2026-06-07T15:30:29.417923Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4810-5
  a curric:KeyLearningPoint ;
  rdfs:label """The join used depends on which letter is joining to which letter within a letter
  string."""@en ;
  dcterms:modified "2026-06-07T15:30:29.417928Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4881-1
  a curric:KeyLearningPoint ;
  rdfs:label """An explanation text is a non-fiction text that explains a particular process or
  subject in detail."""@en ;
  dcterms:modified "2026-06-07T15:30:29.417955Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4881-2
  a curric:KeyLearningPoint ;
  rdfs:label """An explanation text can start with an introduction and then explain a sequenced
  process in chronological order."""@en ;
  dcterms:modified "2026-06-07T15:30:29.417959Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4881-3
  a curric:KeyLearningPoint ;
  rdfs:label """Vocabulary within an explanation text is subject-specific and factual, creating a
  formal tone."""@en ;
  dcterms:modified "2026-06-07T15:30:29.417963Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4881-4
  a curric:KeyLearningPoint ;
  rdfs:label """Ordering fronted adverbials indicate the chronological order of steps in a
  process."""@en ;
  dcterms:modified "2026-06-07T15:30:29.417967Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4881-5
  a curric:KeyLearningPoint ;
  rdfs:label "Fronted adverbials of cause link an effect to a cause."@en ;
  dcterms:modified "2026-06-07T15:30:29.417971Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4884-1
  a curric:KeyLearningPoint ;
  rdfs:label """Notes should not be written in full sentences and bullet points can be used to order
  notes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.417976Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4884-2
  a curric:KeyLearningPoint ;
  rdfs:label "The main paragraphs in an explanation text follow a clear, chronological order."@en ;
  dcterms:modified "2026-06-07T15:30:29.417980Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4884-3
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials of cause and ordering fronted adverbials are used at the start of
  sentences for cohesion."""@en ;
  dcterms:modified "2026-06-07T15:30:29.417986Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4884-4
  a curric:KeyLearningPoint ;
  rdfs:label """A subheading signals part of a text and should stand out from the rest of
  the text."""@en ;
  dcterms:modified "2026-06-07T15:30:29.417991Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4884-5
  a curric:KeyLearningPoint ;
  rdfs:label "The plan should include subject-specific vocabulary."@en ;
  dcterms:modified "2026-06-07T15:30:29.417995Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7896-1
  a curric:KeyLearningPoint ;
  rdfs:label """Oliver is beginning to settle into life with Mr. Brownlow in Pentonville,
  London."""@en ;
  dcterms:modified "2026-06-07T15:30:29.417999Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7896-2
  a curric:KeyLearningPoint ;
  rdfs:label """Readers can form an impression of a range of characters by focusing on how a
  character is described or depicted in text."""@en ;
  dcterms:modified "2026-06-07T15:30:29.418003Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7896-3
  a curric:KeyLearningPoint ;
  rdfs:label "A prediction is a statement about what you think will happen in the future."@en ;
  dcterms:modified "2026-06-07T15:30:29.418007Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7896-4
  a curric:KeyLearningPoint ;
  rdfs:label """Predictions can be justified using information from the text or readers’ prior
  knowledge about the characters &context."""@en ;
  dcterms:modified "2026-06-07T15:30:29.418011Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7896-5
  a curric:KeyLearningPoint ;
  rdfs:label """Searching for keywords or specific types of words can support readers in answering
  retrieval questions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.418015Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3460-1
  a curric:KeyLearningPoint ;
  rdfs:label "A semi-colon is a piece of punctuation with more than one purpose."@en ;
  dcterms:modified "2026-06-07T15:30:29.418054Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3460-2
  a curric:KeyLearningPoint ;
  rdfs:label "A semi-colon can be used to join two closely-related main clauses."@en ;
  dcterms:modified "2026-06-07T15:30:29.418058Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3460-3
  a curric:KeyLearningPoint ;
  rdfs:label "A semi-colon can help to improve text cohesion."@en ;
  dcterms:modified "2026-06-07T15:30:29.418062Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3461-1
  a curric:KeyLearningPoint ;
  rdfs:label "A semi-colon is a piece of punctuation with more than one purpose."@en ;
  dcterms:modified "2026-06-07T15:30:29.418066Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3461-2
  a curric:KeyLearningPoint ;
  rdfs:label """A semi-colon can be used to separate items in a detailed list in which each item
  includes commas."""@en ;
  dcterms:modified "2026-06-07T15:30:29.418070Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3461-3
  a curric:KeyLearningPoint ;
  rdfs:label "A semi-colon can help to avoid ambiguity in a detailed list."@en ;
  dcterms:modified "2026-06-07T15:30:29.418074Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5763-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the opening is to engage the reader and introduce characters and
  plot."""@en ;
  dcterms:modified "2026-06-07T15:30:29.418103Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5763-2
  a curric:KeyLearningPoint ;
  rdfs:label "Using a range of linguistic devices helps achieve text purpose."@en ;
  dcterms:modified "2026-06-07T15:30:29.418109Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5763-3
  a curric:KeyLearningPoint ;
  rdfs:label """A non-finite complex sentence is formed of a main clause and a non-finite
  subordinate clause."""@en ;
  dcterms:modified "2026-06-07T15:30:29.418114Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7911-1
  a curric:KeyLearningPoint ;
  rdfs:label """'Sweet Jamaica' was written by Lord Kitchener in London, 1952, four years after his
  arrival on HMT Empire Windrush."""@en ;
  dcterms:modified "2026-06-07T15:30:29.418122Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7911-2
  a curric:KeyLearningPoint ;
  rdfs:label """‘Sweet Jamaica’ shows a change in perspective from Lord Kitchener, after he had
  spent time in London."""@en ;
  dcterms:modified "2026-06-07T15:30:29.418126Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7911-3
  a curric:KeyLearningPoint ;
  rdfs:label """The song creates negative imagery in its lyrics, portraying themes of regret,
  nostalgia and homesickness."""@en ;
  dcterms:modified "2026-06-07T15:30:29.418130Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7911-4
  a curric:KeyLearningPoint ;
  rdfs:label """By exploring the context, themes and perspectives, we can gain a better
  understanding of the song."""@en ;
  dcterms:modified "2026-06-07T15:30:29.418134Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7852-1
  a curric:KeyLearningPoint ;
  rdfs:label """A similarity is a feature or aspect that has some resemblance to something else,
  without being identical."""@en ;
  dcterms:modified "2026-06-07T15:30:29.418141Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7852-2
  a curric:KeyLearningPoint ;
  rdfs:label """A difference is a feature or aspect that has a distinct or discernible feature that
  sets it apart from something else."""@en ;
  dcterms:modified "2026-06-07T15:30:29.418145Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7852-3
  a curric:KeyLearningPoint ;
  rdfs:label """Comparing two contexts, provides readers with an in-depth understanding of Walter's
  life."""@en ;
  dcterms:modified "2026-06-07T15:30:29.418149Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6749-1
  a curric:KeyLearningPoint ;
  rdfs:label """'When the Sky Falls' is a complex novel with several plot lines - such as Joseph's
  struggle with reading."""@en ;
  dcterms:modified "2026-06-07T15:30:29.418155Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6749-2
  a curric:KeyLearningPoint ;
  rdfs:label "Different plot lines are resolved at different points in the story."@en ;
  dcterms:modified "2026-06-07T15:30:29.418160Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6749-3
  a curric:KeyLearningPoint ;
  rdfs:label "We can argue that the air raid at the zoo is the climax of the story."@en ;
  dcterms:modified "2026-06-07T15:30:29.418164Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6749-4
  a curric:KeyLearningPoint ;
  rdfs:label """The resolution of the story is not a 'happy ending' - the 'problem' of guarding
  Adonis is resolved by his death."""@en ;
  dcterms:modified "2026-06-07T15:30:29.418168Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6749-5
  a curric:KeyLearningPoint ;
  rdfs:label "The historical context of the climax - the Blitz - is key to the narrative."@en ;
  dcterms:modified "2026-06-07T15:30:29.418172Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1044-1
  a curric:KeyLearningPoint ;
  rdfs:label "A subordinating conjunction starts an adverbial clause."@en ;
  dcterms:modified "2026-06-07T15:30:29.418177Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1044-2
  a curric:KeyLearningPoint ;
  rdfs:label """There are many different subordinating conjunctions that have different
  meanings."""@en ;
  dcterms:modified "2026-06-07T15:30:29.418181Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1044-3
  a curric:KeyLearningPoint ;
  rdfs:label "\"As\" is a subordinating conjunction."@en ;
  dcterms:modified "2026-06-07T15:30:29.418185Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1044-4
  a curric:KeyLearningPoint ;
  rdfs:label """Using \"as\" in an adverbial complex sentence tells the reader a simultaneous action
  or feeling is occurring."""@en ;
  dcterms:modified "2026-06-07T15:30:29.418189Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1044-5
  a curric:KeyLearningPoint ;
  rdfs:label "A preposition can tell the reader where a noun is."@en ;
  dcterms:modified "2026-06-07T15:30:29.418195Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6145-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the opening is to engage the reader and introduce the setting and
  characters."""@en ;
  dcterms:modified "2026-06-07T15:30:29.418316Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6145-2
  a curric:KeyLearningPoint ;
  rdfs:label "Precise and ambitious vocabulary is logged on a plan for future use."@en ;
  dcterms:modified "2026-06-07T15:30:29.418320Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6145-3
  a curric:KeyLearningPoint ;
  rdfs:label """Notes should not be written in full sentences and bullet points can be used to make
  notes clear."""@en ;
  dcterms:modified "2026-06-07T15:30:29.418324Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6145-4
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials of time, place and manner indicate when, where and how action
  takes place."""@en ;
  dcterms:modified "2026-06-07T15:30:29.418329Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6145-5
  a curric:KeyLearningPoint ;
  rdfs:label """'Show-not-tell' language shows a character’s feelings by describing their actions,
  body language and facial expressions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.418333Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6148-1
  a curric:KeyLearningPoint ;
  rdfs:label "The purpose of the build-up is to build tension and suspense."@en ;
  dcterms:modified "2026-06-07T15:30:29.418337Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6148-2
  a curric:KeyLearningPoint ;
  rdfs:label "Saying sentences aloud before they are written helps to check for sense."@en ;
  dcterms:modified "2026-06-07T15:30:29.418341Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6148-3
  a curric:KeyLearningPoint ;
  rdfs:label """Using the full range of sentence types (simple, compound and complex) improves text
  flow for the reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.418345Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6148-4
  a curric:KeyLearningPoint ;
  rdfs:label """A rhetorical question engages the reader and makes them feel more curious about the
  narrative."""@en ;
  dcterms:modified "2026-06-07T15:30:29.418351Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6148-5
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials of time, place and manner describe the action in the main clause
  in further detail."""@en ;
  dcterms:modified "2026-06-07T15:30:29.418356Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8637-1
  a curric:KeyLearningPoint ;
  rdfs:label """In the build-up, Pod is “seen” by a human “bean” and this causes concern for the
  Clock family’s safety."""@en ;
  dcterms:modified "2026-06-07T15:30:29.418401Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8637-2
  a curric:KeyLearningPoint ;
  rdfs:label """Arrietty expresses her discontent being trapped under the floorboards and her desire
  to experience the world above."""@en ;
  dcterms:modified "2026-06-07T15:30:29.418408Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8637-3
  a curric:KeyLearningPoint ;
  rdfs:label "Homily persuades a reluctant Pod to take Arrietty borrowing."@en ;
  dcterms:modified "2026-06-07T15:30:29.418412Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8637-4
  a curric:KeyLearningPoint ;
  rdfs:label """The Clock family have contrasting feelings about Arrietty going on a borrowing
  expedition."""@en ;
  dcterms:modified "2026-06-07T15:30:29.418416Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8637-5
  a curric:KeyLearningPoint ;
  rdfs:label "We can infer a character’s emotions from their actions, words and expressions."@en ;
  dcterms:modified "2026-06-07T15:30:29.418420Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7650-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the build-up is to develop the characters and build up the
  excitement."""@en ;
  dcterms:modified "2026-06-07T15:30:29.418522Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7650-2
  a curric:KeyLearningPoint ;
  rdfs:label """When we plan, we log precise and ambitious vocabulary to help paint vivid pictures
  for our reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.418526Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7650-3
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials of time, place and manner are included in a plan to add extra
  detail about the action."""@en ;
  dcterms:modified "2026-06-07T15:30:29.418530Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7650-4
  a curric:KeyLearningPoint ;
  rdfs:label """Dialogue is the written conversation between two characters or more within a
  narrative and it moves the story forward."""@en ;
  dcterms:modified "2026-06-07T15:30:29.418534Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7650-5
  a curric:KeyLearningPoint ;
  rdfs:label "A plan is written in note-form, out of full sentences."@en ;
  dcterms:modified "2026-06-07T15:30:29.418538Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5696-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of a narrative opening is to introduce the characters and to describe
  the setting to the reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.418570Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5696-2
  a curric:KeyLearningPoint ;
  rdfs:label "Saying sentences aloud before they are written helps to check for sense."@en ;
  dcterms:modified "2026-06-07T15:30:29.418574Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5696-3
  a curric:KeyLearningPoint ;
  rdfs:label """Using the full range of sentence types (simple, compound and complex) improves text
  flow for the reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.418578Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5696-4
  a curric:KeyLearningPoint ;
  rdfs:label """A rhetorical question engages the reader and makes them feel more curious about the
  narrative."""@en ;
  dcterms:modified "2026-06-07T15:30:29.418615Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5696-5
  a curric:KeyLearningPoint ;
  rdfs:label """Show and tell language uses characters' movements, body language and facial
  expressions to describe feelings."""@en ;
  dcterms:modified "2026-06-07T15:30:29.418620Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4849-1
  a curric:KeyLearningPoint ;
  rdfs:label "The opening provides the reader with general information about the event."@en ;
  dcterms:modified "2026-06-07T15:30:29.418624Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4849-2
  a curric:KeyLearningPoint ;
  rdfs:label """The opening includes when, where and what took place and what is currently
  happening."""@en ;
  dcterms:modified "2026-06-07T15:30:29.418629Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4849-3
  a curric:KeyLearningPoint ;
  rdfs:label """Writers use a range of cohesive devices to maintain the reader's interest and
  achieve text purpose."""@en ;
  dcterms:modified "2026-06-07T15:30:29.418635Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4849-4
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the opening is to engage the reader and encourage them to
  read on."""@en ;
  dcterms:modified "2026-06-07T15:30:29.418640Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6754-1
  a curric:KeyLearningPoint ;
  rdfs:label "Before we write, we need to generate a wide range of ideas."@en ;
  dcterms:modified "2026-06-07T15:30:29.418646Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6754-2
  a curric:KeyLearningPoint ;
  rdfs:label """Journalistic writing includes both factual information and a range of different
  perspectives."""@en ;
  dcterms:modified "2026-06-07T15:30:29.418650Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6754-3
  a curric:KeyLearningPoint ;
  rdfs:label """In this case, we can gather 'factual' information from our reading of 'When the Sky
  Falls'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.418655Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6754-4
  a curric:KeyLearningPoint ;
  rdfs:label """We can gather different perspectives by engaging in role play based on our
  understanding of the book."""@en ;
  dcterms:modified "2026-06-07T15:30:29.418659Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6754-5
  a curric:KeyLearningPoint ;
  rdfs:label "These ideas will feed into our planning and writing."@en ;
  dcterms:modified "2026-06-07T15:30:29.418663Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8135-1
  a curric:KeyLearningPoint ;
  rdfs:label """Oral rehearsal of a recount ensures we have a clear understanding of the chronology
  of events."""@en ;
  dcterms:modified "2026-06-07T15:30:29.418687Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8135-2
  a curric:KeyLearningPoint ;
  rdfs:label """When rehearsing and planning for a diary entry, we do so in the first person from
  the character's perspective."""@en ;
  dcterms:modified "2026-06-07T15:30:29.418691Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8135-3
  a curric:KeyLearningPoint ;
  rdfs:label """An effective plan for a diary entry contains key events in chronological order and
  thoughts/feelings."""@en ;
  dcterms:modified "2026-06-07T15:30:29.418695Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8135-4
  a curric:KeyLearningPoint ;
  rdfs:label """A plan is written in note format using bullet points to capture the most important
  information."""@en ;
  dcterms:modified "2026-06-07T15:30:29.418699Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8135-5
  a curric:KeyLearningPoint ;
  rdfs:label """This paragraph will recount the events from the journey in chronological order,
  starting from when the family left home."""@en ;
  dcterms:modified "2026-06-07T15:30:29.418704Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7640-1
  a curric:KeyLearningPoint ;
  rdfs:label """Using a range of adjectives and nouns is important when describing a product in a
  persuasive advert."""@en ;
  dcterms:modified "2026-06-07T15:30:29.418992Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7640-2
  a curric:KeyLearningPoint ;
  rdfs:label """Using a range of synonyms for the product avoids repetition and supports
  text flow."""@en ;
  dcterms:modified "2026-06-07T15:30:29.418996Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7640-3
  a curric:KeyLearningPoint ;
  rdfs:label """Exaggerated and precise adjectives are more appealing and persuasive to the
  reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.419000Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7640-4
  a curric:KeyLearningPoint ;
  rdfs:label "Adjectives and nouns can be paired purposefully to form alliteration."@en ;
  dcterms:modified "2026-06-07T15:30:29.419004Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4805-1
  a curric:KeyLearningPoint ;
  rdfs:label "There are four joins used to connect letters together in cursive handwriting."@en ;
  dcterms:modified "2026-06-07T15:30:29.419265Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4805-2
  a curric:KeyLearningPoint ;
  rdfs:label """The join used depends on which letter is joining to which letter so a range of joins
  can be used in a sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.419271Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4805-3
  a curric:KeyLearningPoint ;
  rdfs:label "A sentence always begins with a capital letter."@en ;
  dcterms:modified "2026-06-07T15:30:29.419275Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4805-4
  a curric:KeyLearningPoint ;
  rdfs:label """A capital letter does not join to the next letter so you lift your pencil after its
  formation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.419279Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4805-5
  a curric:KeyLearningPoint ;
  rdfs:label "The letters all have a lead in and a lead out, except for the capital letter."@en ;
  dcterms:modified "2026-06-07T15:30:29.419284Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8894-1
  a curric:KeyLearningPoint ;
  rdfs:label "‘How to Train Your Dragon’ is an illustrated chapter book."@en ;
  dcterms:modified "2026-06-07T15:30:29.419853Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8894-2
  a curric:KeyLearningPoint ;
  rdfs:label "The text draws influences from Viking history, Norse mythology and folklore."@en ;
  dcterms:modified "2026-06-07T15:30:29.419858Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8894-3
  a curric:KeyLearningPoint ;
  rdfs:label "The text references the notion of being a hero."@en ;
  dcterms:modified "2026-06-07T15:30:29.419862Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8894-4
  a curric:KeyLearningPoint ;
  rdfs:label """Understanding the context of the story can help readers build connections and deepen
  understanding."""@en ;
  dcterms:modified "2026-06-07T15:30:29.419868Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6412-1
  a curric:KeyLearningPoint ;
  rdfs:label """Britain had a vast empire in the early 20th Century, but it was very badly affected
  by WWII and had labour shortages."""@en ;
  dcterms:modified "2026-06-07T15:30:29.419873Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6412-2
  a curric:KeyLearningPoint ;
  rdfs:label """In 1948, a new law clarified that all citizens of the Commonwealth had the right to
  settle and work in the UK."""@en ;
  dcterms:modified "2026-06-07T15:30:29.419877Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6412-3
  a curric:KeyLearningPoint ;
  rdfs:label """There was high unemployment in the Caribbean; many people hoped for better wages and
  living conditions in the UK."""@en ;
  dcterms:modified "2026-06-07T15:30:29.419881Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6412-4
  a curric:KeyLearningPoint ;
  rdfs:label """West Indian immigrants therefore arrived in Britain on ships including the Empire
  Windrush at this time."""@en ;
  dcterms:modified "2026-06-07T15:30:29.419885Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6412-5
  a curric:KeyLearningPoint ;
  rdfs:label "On arrival, they faced discrimination in jobs, services and housing."@en ;
  dcterms:modified "2026-06-07T15:30:29.419892Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6689-1
  a curric:KeyLearningPoint ;
  rdfs:label """Lila faces physical and emotional challenges that the reader does not know if she
  will overcome."""@en ;
  dcterms:modified "2026-06-07T15:30:29.419898Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6689-2
  a curric:KeyLearningPoint ;
  rdfs:label """Lila's emotional journey is a key part of building suspense in the build-up of the
  story."""@en ;
  dcterms:modified "2026-06-07T15:30:29.419902Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6689-3
  a curric:KeyLearningPoint ;
  rdfs:label """Philip Pullman conveys Lila's changing emotions both explicitly and using 'show and
  tell'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.419906Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6689-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Show and tell' is a narrative technique that conveys a character's feelings through
  sensory details, actions &thoughts."""@en ;
  dcterms:modified "2026-06-07T15:30:29.419911Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6689-5
  a curric:KeyLearningPoint ;
  rdfs:label """Empathising with a character's emotions can help us develop our own examples of
  'show and tell'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.419915Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8134-1
  a curric:KeyLearningPoint ;
  rdfs:label "‘The Journey’ is a children’s picture book."@en ;
  dcterms:modified "2026-06-07T15:30:29.419919Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8134-2
  a curric:KeyLearningPoint ;
  rdfs:label """The story is about two girls and their mother who are fleeing their war-torn country
  to find a safe place to live."""@en ;
  dcterms:modified "2026-06-07T15:30:29.419923Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8134-3
  a curric:KeyLearningPoint ;
  rdfs:label """The girls face many obstacles and challenges along their perilous journey as they
  cross unwelcoming borders."""@en ;
  dcterms:modified "2026-06-07T15:30:29.419927Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8134-4
  a curric:KeyLearningPoint ;
  rdfs:label """The story ends with them getting closer to a safe home where they hope to arrive
  soon."""@en ;
  dcterms:modified "2026-06-07T15:30:29.419931Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8134-5
  a curric:KeyLearningPoint ;
  rdfs:label """Summarising the key events in a story helps us to build our understanding of the
  text and the meaning behind it."""@en ;
  dcterms:modified "2026-06-07T15:30:29.419935Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8080-1
  a curric:KeyLearningPoint ;
  rdfs:label """looking at picture books that deal with complex themes can develop an understanding
  of the wider world"""@en ;
  dcterms:modified "2026-06-07T15:30:29.420345Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8080-2
  a curric:KeyLearningPoint ;
  rdfs:label """a verse novel is a type of narrative poetry in which a novel length narrative is
  told through the medium of poetry"""@en ;
  dcterms:modified "2026-06-07T15:30:29.420349Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8080-3
  a curric:KeyLearningPoint ;
  rdfs:label """a picture book has meaning that can be constructed from text, image or an interplay
  between both"""@en ;
  dcterms:modified "2026-06-07T15:30:29.420356Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8080-4
  a curric:KeyLearningPoint ;
  rdfs:label """greater meaning can be elicited from a text by reflecting on the author or
  illustrator's specific choice of word/image"""@en ;
  dcterms:modified "2026-06-07T15:30:29.420360Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3447-1
  a curric:KeyLearningPoint ;
  rdfs:label "Any clause is a group of words that contains a verb."@en ;
  dcterms:modified "2026-06-07T15:30:29.420425Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3447-2
  a curric:KeyLearningPoint ;
  rdfs:label """Given that any clause contains a verb, it must contain an agent that does or is the
  verb."""@en ;
  dcterms:modified "2026-06-07T15:30:29.420431Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3447-3
  a curric:KeyLearningPoint ;
  rdfs:label "The noun, noun phrase or pronoun that does the verb is the subject."@en ;
  dcterms:modified "2026-06-07T15:30:29.420436Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3447-4
  a curric:KeyLearningPoint ;
  rdfs:label "Some sentences have the verb acting on another noun, noun phrase or pronoun."@en ;
  dcterms:modified "2026-06-07T15:30:29.420440Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3447-5
  a curric:KeyLearningPoint ;
  rdfs:label "The noun, noun phrase or pronoun that receives the action is the object."@en ;
  dcterms:modified "2026-06-07T15:30:29.420444Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2742-1
  a curric:KeyLearningPoint ;
  rdfs:label "The verb carries the tense of a sentence."@en ;
  dcterms:modified "2026-06-07T15:30:29.420448Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2742-2
  a curric:KeyLearningPoint ;
  rdfs:label "A modal verb is a type of auxiliary verb."@en ;
  dcterms:modified "2026-06-07T15:30:29.420452Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2742-3
  a curric:KeyLearningPoint ;
  rdfs:label "A modal verb is most often paired with the main verb of a clause."@en ;
  dcterms:modified "2026-06-07T15:30:29.420458Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2742-4
  a curric:KeyLearningPoint ;
  rdfs:label "A modal verb is not paired with the main verb if it appears in a question."@en ;
  dcterms:modified "2026-06-07T15:30:29.420463Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2742-5
  a curric:KeyLearningPoint ;
  rdfs:label """A modal verb expresses the degree of possibility, intent, ability or necessity of
  the clause."""@en ;
  dcterms:modified "2026-06-07T15:30:29.420484Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7839-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of a non-fiction text is to inform, explain, or provide factual
  information."""@en ;
  dcterms:modified "2026-06-07T15:30:29.420508Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7839-2
  a curric:KeyLearningPoint ;
  rdfs:label """The features of a non-fiction text are designed to help the reader navigate the text
  and find information easily."""@en ;
  dcterms:modified "2026-06-07T15:30:29.420514Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7839-3
  a curric:KeyLearningPoint ;
  rdfs:label """Contents, glossary and index pages are key features of a non-fiction text like
  'Rushing Rivers'"""@en ;
  dcterms:modified "2026-06-07T15:30:29.420519Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7839-4
  a curric:KeyLearningPoint ;
  rdfs:label "The layout of 'Rushing Rivers' is determined by its purpose and audience."@en ;
  dcterms:modified "2026-06-07T15:30:29.420523Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7839-5
  a curric:KeyLearningPoint ;
  rdfs:label "Headings, images and facts are key layout features of 'Rushing Rivers'."@en ;
  dcterms:modified "2026-06-07T15:30:29.420527Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8472-1
  a curric:KeyLearningPoint ;
  rdfs:label """In part one of the build-up, Hogarth encounters the Iron Man and tells his father,
  who goes out in search of the giant."""@en ;
  dcterms:modified "2026-06-07T15:30:29.420626Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8472-2
  a curric:KeyLearningPoint ;
  rdfs:label """The use of precise and ambitious vocabulary, including ‘show and tell’ language
  supports the building of suspense."""@en ;
  dcterms:modified "2026-06-07T15:30:29.420630Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8472-3
  a curric:KeyLearningPoint ;
  rdfs:label """Using a range of sentence types, including adverbial complex sentences, supports
  text flow."""@en ;
  dcterms:modified "2026-06-07T15:30:29.420634Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8472-4
  a curric:KeyLearningPoint ;
  rdfs:label "An adverbial clause begins with a subordinating conjunction."@en ;
  dcterms:modified "2026-06-07T15:30:29.420639Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8472-5
  a curric:KeyLearningPoint ;
  rdfs:label """An adverbial clause is joined with a main clause to form an adverbial complex
  sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.420643Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6375-1
  a curric:KeyLearningPoint ;
  rdfs:label """The build-up keeps the reader engaged, builds the tension of the plot and develops
  characters for the reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.420647Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6375-2
  a curric:KeyLearningPoint ;
  rdfs:label "Speech first and second sentences can be used to convey dialogue."@en ;
  dcterms:modified "2026-06-07T15:30:29.420651Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6375-3
  a curric:KeyLearningPoint ;
  rdfs:label """Additional information can be added to the reporting clause in the form of adverbial
  detail or subordination."""@en ;
  dcterms:modified "2026-06-07T15:30:29.420655Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6374-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the build-up is to keep the reader engaged, increase the tension of
  the plot and develop the characters."""@en ;
  dcterms:modified "2026-06-07T15:30:29.420659Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6374-2
  a curric:KeyLearningPoint ;
  rdfs:label "Dialogue is when two or more characters are speaking in a text."@en ;
  dcterms:modified "2026-06-07T15:30:29.420663Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6374-3
  a curric:KeyLearningPoint ;
  rdfs:label "Dialogue can be written in the form of speech first or speech second sentences."@en ;
  dcterms:modified "2026-06-07T15:30:29.420668Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6374-4
  a curric:KeyLearningPoint ;
  rdfs:label "Show-not-tell can be used to convey a character's thoughts or emotions."@en ;
  dcterms:modified "2026-06-07T15:30:29.420672Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8641-1
  a curric:KeyLearningPoint ;
  rdfs:label """In this section of the build-up, Arrietty explores the outside world and enjoys
  freedom and nature."""@en ;
  dcterms:modified "2026-06-07T15:30:29.420676Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8641-2
  a curric:KeyLearningPoint ;
  rdfs:label "The atmosphere shifts when Arrietty spots the eye of a human “bean”."@en ;
  dcterms:modified "2026-06-07T15:30:29.420680Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8641-3
  a curric:KeyLearningPoint ;
  rdfs:label """Arrietty forms a friendship with the human “bean” this eye belongs to whose name is
  “Boy”."""@en ;
  dcterms:modified "2026-06-07T15:30:29.420685Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8641-4
  a curric:KeyLearningPoint ;
  rdfs:label """The atmosphere and Arrietty’s emotions change over the course of her
  experiences."""@en ;
  dcterms:modified "2026-06-07T15:30:29.420691Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8641-5
  a curric:KeyLearningPoint ;
  rdfs:label """We can make inferences about a character’s emotions by analysing their actions,
  words and expressions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.420696Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28409-1
  a curric:KeyLearningPoint ;
  rdfs:label """A play is a written text that is intended to be read aloud and acted out by actors
  in a live performance."""@en ;
  dcterms:modified "2026-06-07T15:30:29.420700Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28409-2
  a curric:KeyLearningPoint ;
  rdfs:label "A play script is written by a playwright."@en ;
  dcterms:modified "2026-06-07T15:30:29.420704Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28409-3
  a curric:KeyLearningPoint ;
  rdfs:label "Plays are most often performed in theatres."@en ;
  dcterms:modified "2026-06-07T15:30:29.420709Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28409-4
  a curric:KeyLearningPoint ;
  rdfs:label """Actors read play scripts to bring them to life; directors tell actors how to speak,
  move and look when saying lines."""@en ;
  dcterms:modified "2026-06-07T15:30:29.420713Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28409-5
  a curric:KeyLearningPoint ;
  rdfs:label """There are certain conventions that are always written in play scripts that help the
  actors and the director."""@en ;
  dcterms:modified "2026-06-07T15:30:29.420717Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6190-1
  a curric:KeyLearningPoint ;
  rdfs:label "Because an essay is a non-fiction piece of writing, it must be based on facts."@en ;
  dcterms:modified "2026-06-07T15:30:29.420721Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6190-2
  a curric:KeyLearningPoint ;
  rdfs:label "Facts are obtained through research, using reliable sources."@en ;
  dcterms:modified "2026-06-07T15:30:29.420725Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6190-3
  a curric:KeyLearningPoint ;
  rdfs:label "Research can be collated using bullet points under different headings."@en ;
  dcterms:modified "2026-06-07T15:30:29.420729Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6190-4
  a curric:KeyLearningPoint ;
  rdfs:label """We can break an essay question down into smaller questions in order to structure our
  essay."""@en ;
  dcterms:modified "2026-06-07T15:30:29.420734Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6190-5
  a curric:KeyLearningPoint ;
  rdfs:label """These smaller questions create the flow of a logical argument that leads towards a
  conclusion."""@en ;
  dcterms:modified "2026-06-07T15:30:29.420740Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8174-1
  a curric:KeyLearningPoint ;
  rdfs:label "A letter is a piece of writing that someone sends to someone else."@en ;
  dcterms:modified "2026-06-07T15:30:29.420745Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8174-2
  a curric:KeyLearningPoint ;
  rdfs:label "There are many different reasons why a person may write and send a letter."@en ;
  dcterms:modified "2026-06-07T15:30:29.420749Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8174-3
  a curric:KeyLearningPoint ;
  rdfs:label "The sender is the person who wrote the letter and is sending it."@en ;
  dcterms:modified "2026-06-07T15:30:29.420785Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8174-4
  a curric:KeyLearningPoint ;
  rdfs:label "The recipient is the person who the letter is written to and is receiving it."@en ;
  dcterms:modified "2026-06-07T15:30:29.420791Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8174-5
  a curric:KeyLearningPoint ;
  rdfs:label "Letters follow a specific structure and layout."@en ;
  dcterms:modified "2026-06-07T15:30:29.420797Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5757-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of a conclusion is to summarise the information of the text for the
  reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.420803Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5757-2
  a curric:KeyLearningPoint ;
  rdfs:label """A summary sentence is one sentence that summarises key information from the
  text."""@en ;
  dcterms:modified "2026-06-07T15:30:29.420810Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5757-3
  a curric:KeyLearningPoint ;
  rdfs:label "A conclusion can begin with a formal fronted adverbial."@en ;
  dcterms:modified "2026-06-07T15:30:29.420814Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5757-4
  a curric:KeyLearningPoint ;
  rdfs:label """The conclusion is an opportunity for the reader to reflect upon their own
  actions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.420818Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5757-5
  a curric:KeyLearningPoint ;
  rdfs:label """A conclusion can finish with the writer advising the reader to do further research
  about the topic."""@en ;
  dcterms:modified "2026-06-07T15:30:29.420823Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3450-1
  a curric:KeyLearningPoint ;
  rdfs:label """Parenthesis can be achieved with a range of punctuation: brackets, dashes and
  commas."""@en ;
  dcterms:modified "2026-06-07T15:30:29.420827Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3450-2
  a curric:KeyLearningPoint ;
  rdfs:label """Any type of parenthesis is additional information that can be removed without
  compromising grammatical accuracy."""@en ;
  dcterms:modified "2026-06-07T15:30:29.420831Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3450-3
  a curric:KeyLearningPoint ;
  rdfs:label "Brackets are useful in non-fiction writing to add extra, factual information."@en ;
  dcterms:modified "2026-06-07T15:30:29.420835Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3450-4
  a curric:KeyLearningPoint ;
  rdfs:label "Dashes are useful in fiction writing for dramatic effect."@en ;
  dcterms:modified "2026-06-07T15:30:29.420839Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3450-5
  a curric:KeyLearningPoint ;
  rdfs:label "Commas are useful to drop information in to a clause."@en ;
  dcterms:modified "2026-06-07T15:30:29.420843Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8038-1
  a curric:KeyLearningPoint ;
  rdfs:label """Poems can be published with illustrations or art work to help the reader engage with
  the poetry further."""@en ;
  dcterms:modified "2026-06-07T15:30:29.420864Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8038-2
  a curric:KeyLearningPoint ;
  rdfs:label """Performing a poem requires the performer to use their voice to make the poem
  interesting to listen to."""@en ;
  dcterms:modified "2026-06-07T15:30:29.420868Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8038-3
  a curric:KeyLearningPoint ;
  rdfs:label """Performing a poem requires the performer to use facial expressions to bring the poem
  to life."""@en ;
  dcterms:modified "2026-06-07T15:30:29.420872Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8038-4
  a curric:KeyLearningPoint ;
  rdfs:label """Performing a poem requires the performer to use their body to make the performance
  exciting to watch."""@en ;
  dcterms:modified "2026-06-07T15:30:29.420877Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5760-1
  a curric:KeyLearningPoint ;
  rdfs:label "The closing is the final paragraph of a piece of writing."@en ;
  dcterms:modified "2026-06-07T15:30:29.420881Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5760-2
  a curric:KeyLearningPoint ;
  rdfs:label "Writers need to shift between past, present and future tense in the closing."@en ;
  dcterms:modified "2026-06-07T15:30:29.420887Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5760-3
  a curric:KeyLearningPoint ;
  rdfs:label """Using a range of linguistic features and sentence structures helps achieve text
  purpose and enhances cohesion."""@en ;
  dcterms:modified "2026-06-07T15:30:29.420891Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5760-4
  a curric:KeyLearningPoint ;
  rdfs:label "Using success criteria and a plan support the writer when writing."@en ;
  dcterms:modified "2026-06-07T15:30:29.420896Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1326-1
  a curric:KeyLearningPoint ;
  rdfs:label """Two or more words that almost sound the same but have different meanings and
  spellings are called near-homophones."""@en ;
  dcterms:modified "2026-06-07T15:30:29.420900Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1326-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Accept' and 'except' are near-homophones."@en ;
  dcterms:modified "2026-06-07T15:30:29.420904Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1326-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Wary' and 'weary' are near-homophones."@en ;
  dcterms:modified "2026-06-07T15:30:29.420908Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1326-4
  a curric:KeyLearningPoint ;
  rdfs:label "'Advice' and 'advise' and 'device' and 'devise' are near-homophones."@en ;
  dcterms:modified "2026-06-07T15:30:29.420912Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1326-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: recognise and category."@en ;
  dcterms:modified "2026-06-07T15:30:29.420919Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6556-1
  a curric:KeyLearningPoint ;
  rdfs:label "The conclusion is the final paragraph of a persuasive letter."@en ;
  dcterms:modified "2026-06-07T15:30:29.420924Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6556-2
  a curric:KeyLearningPoint ;
  rdfs:label "Information in the conclusion should be general."@en ;
  dcterms:modified "2026-06-07T15:30:29.420927Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6556-3
  a curric:KeyLearningPoint ;
  rdfs:label """Writers can use a range of cohesive devices to enhance text flow and keep the reader
  engaged."""@en ;
  dcterms:modified "2026-06-07T15:30:29.420931Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6556-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Yours faithfully' is an appropriate sign-off for a formal letter if the recipient
  is not known to the writer."""@en ;
  dcterms:modified "2026-06-07T15:30:29.420936Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6556-5
  a curric:KeyLearningPoint ;
  rdfs:label "Effective planning leads to successful writing outcomes."@en ;
  dcterms:modified "2026-06-07T15:30:29.420942Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5665-1
  a curric:KeyLearningPoint ;
  rdfs:label "Having defeated Grendel's mother, Beowulf returns to Heorot a hero."@en ;
  dcterms:modified "2026-06-07T15:30:29.420946Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5665-2
  a curric:KeyLearningPoint ;
  rdfs:label """Beowulf wants to return home to Geatland; King Hrothgar sadly lets him go, rewarding
  him once more."""@en ;
  dcterms:modified "2026-06-07T15:30:29.420950Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5665-3
  a curric:KeyLearningPoint ;
  rdfs:label """Heroes are common in mythology and epic poetry and they have certain typical
  attributes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.420954Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5665-4
  a curric:KeyLearningPoint ;
  rdfs:label """These attributes might include courage, determination, physical strength, compassion
  and leadership."""@en ;
  dcterms:modified "2026-06-07T15:30:29.420959Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5665-5
  a curric:KeyLearningPoint ;
  rdfs:label "Beowulf has demonstrated these attributes throughout his time in Denmark."@en ;
  dcterms:modified "2026-06-07T15:30:29.420963Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7351-1
  a curric:KeyLearningPoint ;
  rdfs:label """The first paragraph of the build-up gradually conveys an eerie atmosphere, building
  suspense for the reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.420969Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7351-2
  a curric:KeyLearningPoint ;
  rdfs:label """Precise vocabulary is used to describe sensory details and ‘show and tell’ conveys
  Scrooge’s emotions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.420973Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7351-3
  a curric:KeyLearningPoint ;
  rdfs:label "A range of sentence types supports text flow and the building of suspense."@en ;
  dcterms:modified "2026-06-07T15:30:29.420977Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7351-4
  a curric:KeyLearningPoint ;
  rdfs:label """Including a character’s internal thoughts communicates to the reader what a
  character is thinking and feeling."""@en ;
  dcterms:modified "2026-06-07T15:30:29.420982Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7674-1
  a curric:KeyLearningPoint ;
  rdfs:label "A subheading signals to the reader what the section is about."@en ;
  dcterms:modified "2026-06-07T15:30:29.421301Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7674-2
  a curric:KeyLearningPoint ;
  rdfs:label """Careful selection of nouns and pronouns ensures cohesion within sentences and across
  sections of the report."""@en ;
  dcterms:modified "2026-06-07T15:30:29.421305Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7674-3
  a curric:KeyLearningPoint ;
  rdfs:label """A section about one feature of the report's subject contains specific facts and
  information to keep the reader engaged."""@en ;
  dcterms:modified "2026-06-07T15:30:29.421309Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7674-4
  a curric:KeyLearningPoint ;
  rdfs:label """Writers choose varied fronted adverbials and different sentence types to ensure the
  text flows for the reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.421313Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7674-5
  a curric:KeyLearningPoint ;
  rdfs:label """Sentences should be said aloud before writing to ensure they make sense and read
  back once written to check for errors."""@en ;
  dcterms:modified "2026-06-07T15:30:29.421317Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1319-1
  a curric:KeyLearningPoint ;
  rdfs:label "A subheading signals to the reader what the section is about."@en ;
  dcterms:modified "2026-06-07T15:30:29.421321Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1319-2
  a curric:KeyLearningPoint ;
  rdfs:label """Careful selection of nouns and pronouns ensures cohesion within sentences and across
  sections of the report."""@en ;
  dcterms:modified "2026-06-07T15:30:29.421325Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1319-3
  a curric:KeyLearningPoint ;
  rdfs:label """A section about one feature of the report's subject contains specific facts and
  information to keep the reader engaged."""@en ;
  dcterms:modified "2026-06-07T15:30:29.421329Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1319-4
  a curric:KeyLearningPoint ;
  rdfs:label """Writers choose varied fronted adverbials and different sentence types to ensure the
  text flows for the reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.421334Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1319-5
  a curric:KeyLearningPoint ;
  rdfs:label """Sentences should be said aloud before writing to ensure they make sense and read
  back once written to check for errors."""@en ;
  dcterms:modified "2026-06-07T15:30:29.421338Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6159-1
  a curric:KeyLearningPoint ;
  rdfs:label """A journalistic report has a formal tone and combines factual statements with
  different perspectives on an event."""@en ;
  dcterms:modified "2026-06-07T15:30:29.421342Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6159-2
  a curric:KeyLearningPoint ;
  rdfs:label """The main paragraphs give different perspectives using both direct and reported
  speech."""@en ;
  dcterms:modified "2026-06-07T15:30:29.421346Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6159-3
  a curric:KeyLearningPoint ;
  rdfs:label "Throughout, a range of cohesive devices can be used to connect ideas together."@en ;
  dcterms:modified "2026-06-07T15:30:29.421350Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27626-1
  a curric:KeyLearningPoint ;
  rdfs:label "Thorough preparation is important for a debate."@en ;
  dcterms:modified "2026-06-07T15:30:29.421355Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27626-2
  a curric:KeyLearningPoint ;
  rdfs:label "Preparing for a debate includes generating points for your side of the argument."@en ;
  dcterms:modified "2026-06-07T15:30:29.421361Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27626-3
  a curric:KeyLearningPoint ;
  rdfs:label """Points can be ordered from strongest to weakest to ensure the most effective points
  are included."""@en ;
  dcterms:modified "2026-06-07T15:30:29.421367Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27626-4
  a curric:KeyLearningPoint ;
  rdfs:label "Liaising with your team while writing speeches helps to avoid repetition."@en ;
  dcterms:modified "2026-06-07T15:30:29.421373Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27626-5
  a curric:KeyLearningPoint ;
  rdfs:label "The PEPS structure stands for: point, explanation, proof, summary."@en ;
  dcterms:modified "2026-06-07T15:30:29.421378Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2730-1
  a curric:KeyLearningPoint ;
  rdfs:label "Any clause is a group of words that contains a verb."@en ;
  dcterms:modified "2026-06-07T15:30:29.421382Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2730-2
  a curric:KeyLearningPoint ;
  rdfs:label "A main clause is a group of words that contains a verb and makes complete sense."@en ;
  dcterms:modified "2026-06-07T15:30:29.421386Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2730-3
  a curric:KeyLearningPoint ;
  rdfs:label """A subordinate clause is a group of words that contains a verb that does not make
  complete sense."""@en ;
  dcterms:modified "2026-06-07T15:30:29.421390Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2730-4
  a curric:KeyLearningPoint ;
  rdfs:label "There are different types of subordinate clause."@en ;
  dcterms:modified "2026-06-07T15:30:29.421394Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2730-5
  a curric:KeyLearningPoint ;
  rdfs:label "Any type of subordinate clause must be joined to a main clause to make sense."@en ;
  dcterms:modified "2026-06-07T15:30:29.421398Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3466-1
  a curric:KeyLearningPoint ;
  rdfs:label """Precise vocabulary is used to accurately describe the complex process of making
  honey."""@en ;
  dcterms:modified "2026-06-07T15:30:29.421419Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3466-2
  a curric:KeyLearningPoint ;
  rdfs:label """Adjective choices are formal and technical in an explanation text rather than
  descriptive."""@en ;
  dcterms:modified "2026-06-07T15:30:29.421423Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3466-3
  a curric:KeyLearningPoint ;
  rdfs:label "Verb choices are precise to describe the bees’ movements accurately."@en ;
  dcterms:modified "2026-06-07T15:30:29.421427Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3466-4
  a curric:KeyLearningPoint ;
  rdfs:label """Synonyms can be used to refer to the nouns in different ways to avoid
  repetition."""@en ;
  dcterms:modified "2026-06-07T15:30:29.421431Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3466-5
  a curric:KeyLearningPoint ;
  rdfs:label "Adverbs are used to add extra detail to the verb."@en ;
  dcterms:modified "2026-06-07T15:30:29.421435Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8895-1
  a curric:KeyLearningPoint ;
  rdfs:label "Hiccup is not a typical hero character"@en ;
  dcterms:modified "2026-06-07T15:30:29.421440Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8895-2
  a curric:KeyLearningPoint ;
  rdfs:label "Stories may portray heroes in various ways"@en ;
  dcterms:modified "2026-06-07T15:30:29.421446Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8895-3
  a curric:KeyLearningPoint ;
  rdfs:label """There are some common character traits heroes have, such as courage and
  determination"""@en ;
  dcterms:modified "2026-06-07T15:30:29.421450Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8895-4
  a curric:KeyLearningPoint ;
  rdfs:label "Authors can appeal to the senses when describing settings"@en ;
  dcterms:modified "2026-06-07T15:30:29.421456Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8895-5
  a curric:KeyLearningPoint ;
  rdfs:label """Role on the wall is a reading activity that helps readers develop their
  understanding of a character"""@en ;
  dcterms:modified "2026-06-07T15:30:29.421461Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5629-1
  a curric:KeyLearningPoint ;
  rdfs:label """This paragraph recounts the boy’s encounters with characters in the forest and
  conveys how his emotions heighten."""@en ;
  dcterms:modified "2026-06-07T15:30:29.421465Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5629-2
  a curric:KeyLearningPoint ;
  rdfs:label """Diary entries should include specific linguistic features (past tense, first person
  perspective and informal language)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.421469Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5629-3
  a curric:KeyLearningPoint ;
  rdfs:label "Fronted adverbials of time help clearly sequence the encounters."@en ;
  dcterms:modified "2026-06-07T15:30:29.421473Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5629-4
  a curric:KeyLearningPoint ;
  rdfs:label """A relative complex sentence uses a relative pronoun (who or which) to provide
  greater detail about a noun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.421477Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5629-5
  a curric:KeyLearningPoint ;
  rdfs:label """A relative clause can follow the main clause in a relative complex sentence or be
  embedded within it."""@en ;
  dcterms:modified "2026-06-07T15:30:29.421482Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27777-1
  a curric:KeyLearningPoint ;
  rdfs:label "Speaking loudly and clearly is important when talking in front of an audience."@en ;
  dcterms:modified "2026-06-07T15:30:29.421486Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27777-2
  a curric:KeyLearningPoint ;
  rdfs:label """The main purpose of public speaking is to inform the audience about something or
  impact their thoughts/actions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.421490Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27777-3
  a curric:KeyLearningPoint ;
  rdfs:label """Strategies to reduce nerves during public speaking include practicing and calm
  breathing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.421494Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27777-4
  a curric:KeyLearningPoint ;
  rdfs:label """A good orator will engage their audience and deliver their speech in a charismatic
  and persuasive manner."""@en ;
  dcterms:modified "2026-06-07T15:30:29.421498Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8037-1
  a curric:KeyLearningPoint ;
  rdfs:label """'Free verse’ refers to a type of poetry that doesn’t follow a specific rhyme scheme
  or structure."""@en ;
  dcterms:modified "2026-06-07T15:30:29.421505Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8037-2
  a curric:KeyLearningPoint ;
  rdfs:label """The themes and tone of a poem can be inferred from the structure and language of the
  poem."""@en ;
  dcterms:modified "2026-06-07T15:30:29.421509Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8037-3
  a curric:KeyLearningPoint ;
  rdfs:label """Generating vocabulary and figurative language using the senses enables the poet to
  paint a vivid picture for the reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.421513Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8037-4
  a curric:KeyLearningPoint ;
  rdfs:label """Writing a free verse poem relies on the poet’s creativity rather than following
  rules of traditional poems."""@en ;
  dcterms:modified "2026-06-07T15:30:29.421517Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4885-1
  a curric:KeyLearningPoint ;
  rdfs:label "The steps in the mummification process are written in chronological order."@en ;
  dcterms:modified "2026-06-07T15:30:29.421521Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4885-2
  a curric:KeyLearningPoint ;
  rdfs:label "Ordering fronted adverbials indicate the order of the steps in a process."@en ;
  dcterms:modified "2026-06-07T15:30:29.421528Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4885-3
  a curric:KeyLearningPoint ;
  rdfs:label """Using the full range of sentence types (simple, compound and complex) improves text
  flow for the reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.421532Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4885-4
  a curric:KeyLearningPoint ;
  rdfs:label """Explanation texts include subject-specific vocabulary that is related to the subject
  of the text."""@en ;
  dcterms:modified "2026-06-07T15:30:29.421536Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4885-5
  a curric:KeyLearningPoint ;
  rdfs:label """Sentences should be said aloud before writing to ensure they make sense and read
  back once written to check for errors."""@en ;
  dcterms:modified "2026-06-07T15:30:29.421540Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9044-1
  a curric:KeyLearningPoint ;
  rdfs:label """Characterisation is the way an author and illustrator develop the personalities and
  traits of the characters in a story."""@en ;
  dcterms:modified "2026-06-07T15:30:29.421544Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9044-2
  a curric:KeyLearningPoint ;
  rdfs:label """Readers can tell lots about characters through their appearance, dialogue, their
  actions and how they are depicted."""@en ;
  dcterms:modified "2026-06-07T15:30:29.421548Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9044-3
  a curric:KeyLearningPoint ;
  rdfs:label """Through eye contact & body language we can infer how a character might be feeling &
  what this might convey to a reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.421552Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9044-4
  a curric:KeyLearningPoint ;
  rdfs:label """Having explored the characters in greater detail, readers can make predictions about
  what might happen next."""@en ;
  dcterms:modified "2026-06-07T15:30:29.421556Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3462-1
  a curric:KeyLearningPoint ;
  rdfs:label "Direct speech is the term used for a character speaking out loud in a text."@en ;
  dcterms:modified "2026-06-07T15:30:29.421560Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3462-2
  a curric:KeyLearningPoint ;
  rdfs:label "Inverted commas are the punctuation that signal direct speech to the reader."@en ;
  dcterms:modified "2026-06-07T15:30:29.421565Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3462-3
  a curric:KeyLearningPoint ;
  rdfs:label "A speech first sentence begins with a character's spoken words."@en ;
  dcterms:modified "2026-06-07T15:30:29.421569Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3462-4
  a curric:KeyLearningPoint ;
  rdfs:label """A speech second sentence begins with the reporting clause followed by a character's
  spoken words."""@en ;
  dcterms:modified "2026-06-07T15:30:29.421573Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3462-5
  a curric:KeyLearningPoint ;
  rdfs:label """A speech interrupted sentence begins with a character's spoken words and they are
  interrupted by the reporting clause."""@en ;
  dcterms:modified "2026-06-07T15:30:29.421577Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1081-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Irresistible' is an adjective which means gorgeous and inviting."@en ;
  dcterms:modified "2026-06-07T15:30:29.421581Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1081-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Tantalising' is an adjective which means tasty or delicious."@en ;
  dcterms:modified "2026-06-07T15:30:29.421585Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1081-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Scrumptious', 'mouthwatering', 'succulent' and 'moist' are other adjectives related
  to the word delicious."""@en ;
  dcterms:modified "2026-06-07T15:30:29.421589Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7629-1
  a curric:KeyLearningPoint ;
  rdfs:label "Editing is the process of making changes to improve our writing."@en ;
  dcterms:modified "2026-06-07T15:30:29.421593Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7629-2
  a curric:KeyLearningPoint ;
  rdfs:label "Editing can be done by oneself, with a peer or with a teacher."@en ;
  dcterms:modified "2026-06-07T15:30:29.421597Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7629-3
  a curric:KeyLearningPoint ;
  rdfs:label """When editing punctuation, missing or incorrectly used capital letters, full stops,
  inverted commas & commas are checked."""@en ;
  dcterms:modified "2026-06-07T15:30:29.421604Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7629-4
  a curric:KeyLearningPoint ;
  rdfs:label """When editing sentence structure, the way sentences are constructed is checked to
  improve and enhance text flow."""@en ;
  dcterms:modified "2026-06-07T15:30:29.421608Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7629-5
  a curric:KeyLearningPoint ;
  rdfs:label "When editing language, choices of words and phrases are carefully reviewed."@en ;
  dcterms:modified "2026-06-07T15:30:29.421612Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2725-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the build-up is to develop the characters’ emotions and build tension
  and suspense."""@en ;
  dcterms:modified "2026-06-07T15:30:29.421633Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2725-2
  a curric:KeyLearningPoint ;
  rdfs:label "Notes from a plan can be used to form full sentences."@en ;
  dcterms:modified "2026-06-07T15:30:29.421639Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2725-3
  a curric:KeyLearningPoint ;
  rdfs:label "A new paragraph signifies a new key moment."@en ;
  dcterms:modified "2026-06-07T15:30:29.421644Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2725-4
  a curric:KeyLearningPoint ;
  rdfs:label """A range of sentence types (simple, compound and complex) improves text flow for the
  reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.421648Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2725-5
  a curric:KeyLearningPoint ;
  rdfs:label """A relative complex sentence is formed of a main clause that can be interrupted by a
  relative clause."""@en ;
  dcterms:modified "2026-06-07T15:30:29.421654Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7828-1
  a curric:KeyLearningPoint ;
  rdfs:label """Skimming and scanning is a way to retrieve information accurately and quickly from a
  text."""@en ;
  dcterms:modified "2026-06-07T15:30:29.421659Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7828-2
  a curric:KeyLearningPoint ;
  rdfs:label "Reading between the lines to search for clues can help to infer meaning."@en ;
  dcterms:modified "2026-06-07T15:30:29.421663Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7828-3
  a curric:KeyLearningPoint ;
  rdfs:label """Having rich discussions improves our understanding and offers opportunities for
  hearing different perspectives."""@en ;
  dcterms:modified "2026-06-07T15:30:29.421667Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7828-4
  a curric:KeyLearningPoint ;
  rdfs:label """Drawing conclusions means using information from the text and personal experiences
  to deduce meaning."""@en ;
  dcterms:modified "2026-06-07T15:30:29.421673Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1067-1
  a curric:KeyLearningPoint ;
  rdfs:label "A subheading signals to the reader what the section is about."@en ;
  dcterms:modified "2026-06-07T15:30:29.421677Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1067-2
  a curric:KeyLearningPoint ;
  rdfs:label """A section about one feature of the report's subject contains specific facts and
  information to keep the reader engaged."""@en ;
  dcterms:modified "2026-06-07T15:30:29.421683Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1067-3
  a curric:KeyLearningPoint ;
  rdfs:label """Writers choose varied fronted adverbials and different sentence types to ensure the
  text flows for the reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.421690Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1067-4
  a curric:KeyLearningPoint ;
  rdfs:label "A section can be composed of one paragraph."@en ;
  dcterms:modified "2026-06-07T15:30:29.421694Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1067-5
  a curric:KeyLearningPoint ;
  rdfs:label """Sentences should be said aloud before writing to ensure they make sense and read
  back once written to check for errors."""@en ;
  dcterms:modified "2026-06-07T15:30:29.421698Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7660-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the opening is to engage the reader and introduce the setting and
  characters."""@en ;
  dcterms:modified "2026-06-07T15:30:29.421702Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7660-2
  a curric:KeyLearningPoint ;
  rdfs:label """The opening of the story introduces Paikea and her grandfather and their family
  context."""@en ;
  dcterms:modified "2026-06-07T15:30:29.421706Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7660-3
  a curric:KeyLearningPoint ;
  rdfs:label """Precise adjectives, verbs and adverbs are used to create a vivid picture for the
  reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.421710Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7660-4
  a curric:KeyLearningPoint ;
  rdfs:label "Precise and ambitious vocabulary is logged on a plan for future use."@en ;
  dcterms:modified "2026-06-07T15:30:29.421714Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7660-5
  a curric:KeyLearningPoint ;
  rdfs:label """Notes should not be written in full sentences and bullet points can be used to make
  notes clear."""@en ;
  dcterms:modified "2026-06-07T15:30:29.421719Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5470-1
  a curric:KeyLearningPoint ;
  rdfs:label "A fairytale is a children's story about magical and imaginary beings and lands."@en ;
  dcterms:modified "2026-06-07T15:30:29.422227Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5470-2
  a curric:KeyLearningPoint ;
  rdfs:label """Fairytales belong to the genre of folklore where oral stories are shared and passed
  down over time."""@en ;
  dcterms:modified "2026-06-07T15:30:29.422231Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5470-3
  a curric:KeyLearningPoint ;
  rdfs:label """Hansel and Gretel originated in Germany and was first recorded by the Brothers
  Grimm."""@en ;
  dcterms:modified "2026-06-07T15:30:29.422237Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5470-4
  a curric:KeyLearningPoint ;
  rdfs:label """Fairytales have specific features e.g. they involve magical elements and often
  include good vs evil."""@en ;
  dcterms:modified "2026-06-07T15:30:29.422241Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5470-5
  a curric:KeyLearningPoint ;
  rdfs:label """Anthony Browne wrote his own adaptation of 'Hansel and Gretel' and uses his
  illustrations to convey hidden messages."""@en ;
  dcterms:modified "2026-06-07T15:30:29.422245Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6158-1
  a curric:KeyLearningPoint ;
  rdfs:label """A journalistic report has a formal tone and it combines factual statements with
  different perspectives on an event."""@en ;
  dcterms:modified "2026-06-07T15:30:29.422309Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6158-2
  a curric:KeyLearningPoint ;
  rdfs:label """The introduction gives a summary of the event and the arguments and gives a
  description of the event."""@en ;
  dcterms:modified "2026-06-07T15:30:29.422313Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6158-3
  a curric:KeyLearningPoint ;
  rdfs:label """The main paragraphs give different perspectives using both direct and reported
  speech."""@en ;
  dcterms:modified "2026-06-07T15:30:29.422317Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6158-4
  a curric:KeyLearningPoint ;
  rdfs:label "Throughout, a range of cohesive devices can be used to connect ideas together."@en ;
  dcterms:modified "2026-06-07T15:30:29.422321Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1355-1
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: pronunciation, explanation and dictionary."@en ;
  dcterms:modified "2026-06-07T15:30:29.422424Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1355-2
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: disastrous, mischievous and marvellous."@en ;
  dcterms:modified "2026-06-07T15:30:29.422429Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1355-3
  a curric:KeyLearningPoint ;
  rdfs:label """How to spell the curriculum words: frequently, immediately, especially and
  sincerely."""@en ;
  dcterms:modified "2026-06-07T15:30:29.422433Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1355-4
  a curric:KeyLearningPoint ;
  rdfs:label "Spelling strategies help us to notice how words are spelled."@en ;
  dcterms:modified "2026-06-07T15:30:29.422439Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1355-5
  a curric:KeyLearningPoint ;
  rdfs:label """The practice spelling strategy you choose often depends on the spelling you are
  practising and what makes it difficult."""@en ;
  dcterms:modified "2026-06-07T15:30:29.422444Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6359-1
  a curric:KeyLearningPoint ;
  rdfs:label """The recount section of a journalistic report provides specific details about the
  news event in chronological order."""@en ;
  dcterms:modified "2026-06-07T15:30:29.422471Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6359-2
  a curric:KeyLearningPoint ;
  rdfs:label "Use of subject-specific vocabulary supports planning for a journalistic report."@en ;
  dcterms:modified "2026-06-07T15:30:29.422475Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6359-3
  a curric:KeyLearningPoint ;
  rdfs:label """Details of the timeline, people involved and action taken are crucial for reporting
  on a crime."""@en ;
  dcterms:modified "2026-06-07T15:30:29.422480Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6359-4
  a curric:KeyLearningPoint ;
  rdfs:label """A plan is written in note format, using bullet points to write the key facts in a
  few words."""@en ;
  dcterms:modified "2026-06-07T15:30:29.422484Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4883-1
  a curric:KeyLearningPoint ;
  rdfs:label "An explanation text needs a title to signify what the text is about."@en ;
  dcterms:modified "2026-06-07T15:30:29.422505Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4883-2
  a curric:KeyLearningPoint ;
  rdfs:label "The purpose of the introduction is to give general information to the reader."@en ;
  dcterms:modified "2026-06-07T15:30:29.422509Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4883-3
  a curric:KeyLearningPoint ;
  rdfs:label "The introduction outlines what the reader will learn from the explanation text."@en ;
  dcterms:modified "2026-06-07T15:30:29.422513Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4883-4
  a curric:KeyLearningPoint ;
  rdfs:label """The facts in the introduction are general about mummification; they become more
  specific in later paragraphs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.422519Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4883-5
  a curric:KeyLearningPoint ;
  rdfs:label "An introduction ends with a command to the reader to continue reading."@en ;
  dcterms:modified "2026-06-07T15:30:29.422525Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8078-1
  a curric:KeyLearningPoint ;
  rdfs:label """Texts can be adapted into a television series, feature-length film or for a theatre
  performance"""@en ;
  dcterms:modified "2026-06-07T15:30:29.422530Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8078-2
  a curric:KeyLearningPoint ;
  rdfs:label """A character can be imagined from a physical text, film, television adaptation or
  theatre performance"""@en ;
  dcterms:modified "2026-06-07T15:30:29.422534Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8078-3
  a curric:KeyLearningPoint ;
  rdfs:label """Subtext and themes can be explored via a character's thoughts, actions, dialogue and
  character development"""@en ;
  dcterms:modified "2026-06-07T15:30:29.422540Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6216-1
  a curric:KeyLearningPoint ;
  rdfs:label """Before we write an essay, we need to research the subject, making notes that include
  subject-specific vocabulary."""@en ;
  dcterms:modified "2026-06-07T15:30:29.422561Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6216-2
  a curric:KeyLearningPoint ;
  rdfs:label "The Amazon rainforest is a vast and special habitat with huge biodiversity."@en ;
  dcterms:modified "2026-06-07T15:30:29.422565Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6216-3
  a curric:KeyLearningPoint ;
  rdfs:label "The Amazon rainforest is being subject to deforestation driven by agriculture."@en ;
  dcterms:modified "2026-06-07T15:30:29.422569Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6216-4
  a curric:KeyLearningPoint ;
  rdfs:label """This deforestation contributes to climate change because trees are carbon
  stores."""@en ;
  dcterms:modified "2026-06-07T15:30:29.422573Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1409-1
  a curric:KeyLearningPoint ;
  rdfs:label "It is common to see a ‘c’ or a ‘t’ before the suffix -ial."@en ;
  dcterms:modified "2026-06-07T15:30:29.422640Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1409-2
  a curric:KeyLearningPoint ;
  rdfs:label "The /shul/ ending can be spelt -cial or -tial."@en ;
  dcterms:modified "2026-06-07T15:30:29.422644Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1409-3
  a curric:KeyLearningPoint ;
  rdfs:label "If the letter before the /shul/ ending is a consonant, -tial is usually used."@en ;
  dcterms:modified "2026-06-07T15:30:29.422648Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1409-4
  a curric:KeyLearningPoint ;
  rdfs:label "If the letter before the /shul/ ending is a vowel, -cial is usually used."@en ;
  dcterms:modified "2026-06-07T15:30:29.422652Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1409-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: separate, popular and opposite."@en ;
  dcterms:modified "2026-06-07T15:30:29.422656Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6108-1
  a curric:KeyLearningPoint ;
  rdfs:label "A non-chronological report is written out of time order."@en ;
  dcterms:modified "2026-06-07T15:30:29.422786Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6108-2
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of a non-chronological report is to inform and engage the reader about a
  particular subject or event."""@en ;
  dcterms:modified "2026-06-07T15:30:29.422790Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6108-3
  a curric:KeyLearningPoint ;
  rdfs:label """The intended reader of a non-chronological report is likely interested in the
  subject of the report."""@en ;
  dcterms:modified "2026-06-07T15:30:29.422794Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6108-4
  a curric:KeyLearningPoint ;
  rdfs:label """Subheadings are used to signal where each section of information is to the reader of
  a non-chronological report."""@en ;
  dcterms:modified "2026-06-07T15:30:29.422800Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6108-5
  a curric:KeyLearningPoint ;
  rdfs:label "Paragraphs are used within a subheading to organise information by theme."@en ;
  dcterms:modified "2026-06-07T15:30:29.422804Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1450-1
  a curric:KeyLearningPoint ;
  rdfs:label """A prefix is a letter or group of letters at the start of a word which creates
  another word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.422882Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1450-2
  a curric:KeyLearningPoint ;
  rdfs:label """The prefixes de-, re-, sub- and super- can be added without changing the spelling of
  the root word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.422886Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1450-3
  a curric:KeyLearningPoint ;
  rdfs:label "The prefixes de- can mean undo and re- can mean again."@en ;
  dcterms:modified "2026-06-07T15:30:29.422890Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1450-4
  a curric:KeyLearningPoint ;
  rdfs:label "The prefix sub- can mean under or nearly and super- can mean above or larger."@en ;
  dcterms:modified "2026-06-07T15:30:29.422894Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1450-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum word: guide."@en ;
  dcterms:modified "2026-06-07T15:30:29.422898Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2745-1
  a curric:KeyLearningPoint ;
  rdfs:label "Parenthesis can be achieved with a range of punctuation."@en ;
  dcterms:modified "2026-06-07T15:30:29.422936Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2745-2
  a curric:KeyLearningPoint ;
  rdfs:label """Brackets are a punctuation mark used to add extra, factual information in a
  clause."""@en ;
  dcterms:modified "2026-06-07T15:30:29.422941Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2745-3
  a curric:KeyLearningPoint ;
  rdfs:label "Brackets can be removed from a clause and it will still make sense."@en ;
  dcterms:modified "2026-06-07T15:30:29.422945Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2745-4
  a curric:KeyLearningPoint ;
  rdfs:label """Brackets can be used purposefully in non-fiction texts to increase the amount of
  facts given to the reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.422950Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1130-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Shrewd' is an adjective which means clever or sharp-witted."@en ;
  dcterms:modified "2026-06-07T15:30:29.423068Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1130-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Cunning' is an adjective which means sly or crafty."@en ;
  dcterms:modified "2026-06-07T15:30:29.423072Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1130-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Devious' is an adjective which means cheating or sly."@en ;
  dcterms:modified "2026-06-07T15:30:29.423076Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6697-1
  a curric:KeyLearningPoint ;
  rdfs:label "Direct speech is the term used for a person speaking out loud in a text ."@en ;
  dcterms:modified "2026-06-07T15:30:29.423080Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6697-2
  a curric:KeyLearningPoint ;
  rdfs:label """It is crucial to consider character perspective when developing ideas for direct
  speech."""@en ;
  dcterms:modified "2026-06-07T15:30:29.423084Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6697-3
  a curric:KeyLearningPoint ;
  rdfs:label "Direct speech between two characters forms a dialogue."@en ;
  dcterms:modified "2026-06-07T15:30:29.423088Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6697-4
  a curric:KeyLearningPoint ;
  rdfs:label """Inverted commas are used to demarcate speech and a piece of punctuation separates
  speech from the reporting clause."""@en ;
  dcterms:modified "2026-06-07T15:30:29.423092Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6697-5
  a curric:KeyLearningPoint ;
  rdfs:label """A range of synonyms for ‘said’ and use of adverbs can offer detail about how a
  character spoke and felt."""@en ;
  dcterms:modified "2026-06-07T15:30:29.423096Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1083-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Meagre' is an adjective which means limited, small or not enough."@en ;
  dcterms:modified "2026-06-07T15:30:29.423128Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1083-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Hearty' is an adjective which means filling or wholesome."@en ;
  dcterms:modified "2026-06-07T15:30:29.423132Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1083-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Wholesome', 'sumptuous', 'lavish' and 'humble' are other adjectives related to a
  meal."""@en ;
  dcterms:modified "2026-06-07T15:30:29.423139Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1082-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Crave' is a verb which means to long for or desire."@en ;
  dcterms:modified "2026-06-07T15:30:29.423360Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1082-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Insatiable' is an adjective which means greedy or impossible to satisfy."@en ;
  dcterms:modified "2026-06-07T15:30:29.423364Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1082-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Voracious', 'ravenous', 'parched', and 'famished' are other adjectives related to
  hunger and thirst."""@en ;
  dcterms:modified "2026-06-07T15:30:29.423368Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6221-1
  a curric:KeyLearningPoint ;
  rdfs:label """In our essay, the conclusion reflects the essay title, bringing the information from
  previous paragraphs together."""@en ;
  dcterms:modified "2026-06-07T15:30:29.423373Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6221-2
  a curric:KeyLearningPoint ;
  rdfs:label """The conclusion explains how reducing deforestation will help reduce the impacts of
  climate change."""@en ;
  dcterms:modified "2026-06-07T15:30:29.423377Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6221-3
  a curric:KeyLearningPoint ;
  rdfs:label "We will include subject-specific vocabulary and a range of linguistic features."@en ;
  dcterms:modified "2026-06-07T15:30:29.423381Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6221-4
  a curric:KeyLearningPoint ;
  rdfs:label """Because the conclusion looks at possible future actions and outcomes, we will often
  use modal verbs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.423385Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6221-5
  a curric:KeyLearningPoint ;
  rdfs:label "Modal verbs are auxiliary ('helping') verbs that are paired with a main verb."@en ;
  dcterms:modified "2026-06-07T15:30:29.423389Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6370-1
  a curric:KeyLearningPoint ;
  rdfs:label """Alfred Noyes uses figurative language and poetic devices to create imagery and
  describe events in stanza three."""@en ;
  dcterms:modified "2026-06-07T15:30:29.423394Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6370-2
  a curric:KeyLearningPoint ;
  rdfs:label """As this poem was set in the 18th century, some of the language choices may be
  unfamiliar."""@en ;
  dcterms:modified "2026-06-07T15:30:29.423398Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6370-3
  a curric:KeyLearningPoint ;
  rdfs:label """Understanding the meaning of all vocabulary in the poem enables us to analyse and
  understand each stanza fully."""@en ;
  dcterms:modified "2026-06-07T15:30:29.423404Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6698-1
  a curric:KeyLearningPoint ;
  rdfs:label "Direct speech between two characters in a narrative forms a dialogue."@en ;
  dcterms:modified "2026-06-07T15:30:29.423427Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6698-2
  a curric:KeyLearningPoint ;
  rdfs:label """Inverted commas are used to demarcate speech and a piece of punctuation separates
  speech from the reporting clause."""@en ;
  dcterms:modified "2026-06-07T15:30:29.423431Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6698-3
  a curric:KeyLearningPoint ;
  rdfs:label """Precise and ambitious vocabulary shows and tells the reader what happened and how
  characters are feeling."""@en ;
  dcterms:modified "2026-06-07T15:30:29.423437Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6698-4
  a curric:KeyLearningPoint ;
  rdfs:label "Using a range of sentence types improves text flow for the reader."@en ;
  dcterms:modified "2026-06-07T15:30:29.423441Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6698-5
  a curric:KeyLearningPoint ;
  rdfs:label """An adverbial complex sentence is a sentence formed of a main clause and an adverbial
  subordinate clause."""@en ;
  dcterms:modified "2026-06-07T15:30:29.423445Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8138-1
  a curric:KeyLearningPoint ;
  rdfs:label "Diary entries use informal language that reflect the character who is writing."@en ;
  dcterms:modified "2026-06-07T15:30:29.423517Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8138-2
  a curric:KeyLearningPoint ;
  rdfs:label "Writers switch between the present, past and future tenses in diary entries."@en ;
  dcterms:modified "2026-06-07T15:30:29.423521Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8138-3
  a curric:KeyLearningPoint ;
  rdfs:label """First person perspective is the point of view where the writer is the ‘I’
  character."""@en ;
  dcterms:modified "2026-06-07T15:30:29.423525Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8138-4
  a curric:KeyLearningPoint ;
  rdfs:label """A range of sentence types, including simple, compound and complex, improves text
  flow for the reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.423529Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8138-5
  a curric:KeyLearningPoint ;
  rdfs:label "Notes from a plan are used to help form full sentences."@en ;
  dcterms:modified "2026-06-07T15:30:29.423533Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7855-1
  a curric:KeyLearningPoint ;
  rdfs:label "A summary is the main ideas of a text, usually from more than one paragraph"@en ;
  dcterms:modified "2026-06-07T15:30:29.423537Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7855-2
  a curric:KeyLearningPoint ;
  rdfs:label """Examining an inspirational figure from history can have an impact on our
  understanding of events in present day"""@en ;
  dcterms:modified "2026-06-07T15:30:29.423544Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8046-1
  a curric:KeyLearningPoint ;
  rdfs:label """A cinquain is a five-line poem that follows a specific structure involving
  syllables."""@en ;
  dcterms:modified "2026-06-07T15:30:29.423705Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8046-2
  a curric:KeyLearningPoint ;
  rdfs:label """Cinquains often focus on creating vivid imagery through descriptive language and
  sensory details."""@en ;
  dcterms:modified "2026-06-07T15:30:29.423709Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8046-3
  a curric:KeyLearningPoint ;
  rdfs:label "An ode is a poem that celebrates a person, object or idea."@en ;
  dcterms:modified "2026-06-07T15:30:29.423713Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8046-4
  a curric:KeyLearningPoint ;
  rdfs:label "Poems can be written in many different forms and structures."@en ;
  dcterms:modified "2026-06-07T15:30:29.423717Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8046-5
  a curric:KeyLearningPoint ;
  rdfs:label """A poet may choose the form of poetry depending on the impression that they want to
  create."""@en ;
  dcterms:modified "2026-06-07T15:30:29.423722Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8136-1
  a curric:KeyLearningPoint ;
  rdfs:label "Diary entries use informal language that reflect the character who is writing."@en ;
  dcterms:modified "2026-06-07T15:30:29.423726Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8136-2
  a curric:KeyLearningPoint ;
  rdfs:label "Writers switch between the present tense and past tense in diary entries."@en ;
  dcterms:modified "2026-06-07T15:30:29.423730Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8136-3
  a curric:KeyLearningPoint ;
  rdfs:label """First person perspective is the point of view where the writer is the ‘I’
  character."""@en ;
  dcterms:modified "2026-06-07T15:30:29.423734Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8136-4
  a curric:KeyLearningPoint ;
  rdfs:label "Fronted adverbials of time recount the chronology of events."@en ;
  dcterms:modified "2026-06-07T15:30:29.423738Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8136-5
  a curric:KeyLearningPoint ;
  rdfs:label "Notes from a plan are used to help form full sentences."@en ;
  dcterms:modified "2026-06-07T15:30:29.423742Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5667-1
  a curric:KeyLearningPoint ;
  rdfs:label "After Beowulf's death, Wiglaf is furious at the warriors who deserted him."@en ;
  dcterms:modified "2026-06-07T15:30:29.424566Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5667-2
  a curric:KeyLearningPoint ;
  rdfs:label """Beowulf is given a hero's funeral; the Geats are concerned about their future
  without him."""@en ;
  dcterms:modified "2026-06-07T15:30:29.424570Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5667-3
  a curric:KeyLearningPoint ;
  rdfs:label """The Geats show that, just as Beowulf wanted, they will remember him after
  his death."""@en ;
  dcterms:modified "2026-06-07T15:30:29.424574Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5667-4
  a curric:KeyLearningPoint ;
  rdfs:label "We aim to read with fluency and expression; repeated reading supports fluency."@en ;
  dcterms:modified "2026-06-07T15:30:29.424578Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6003-1
  a curric:KeyLearningPoint ;
  rdfs:label """A soliloquy shows the audience how a character is feeling at a key point in the
  play."""@en ;
  dcterms:modified "2026-06-07T15:30:29.424582Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6003-2
  a curric:KeyLearningPoint ;
  rdfs:label """The way the character is feeling must be carefully thought about before a
  performance."""@en ;
  dcterms:modified "2026-06-07T15:30:29.424586Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6003-3
  a curric:KeyLearningPoint ;
  rdfs:label """Performing a soliloquy requires the performer to use clear diction and expression to
  bring the words to life."""@en ;
  dcterms:modified "2026-06-07T15:30:29.424590Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6003-4
  a curric:KeyLearningPoint ;
  rdfs:label """Performing requires the performer to use facial expressions and body movements to
  bring the soliloquy to life."""@en ;
  dcterms:modified "2026-06-07T15:30:29.424596Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4891-1
  a curric:KeyLearningPoint ;
  rdfs:label """Research into a subject improves the writing of a non-chronological report
  about it."""@en ;
  dcterms:modified "2026-06-07T15:30:29.424601Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4891-2
  a curric:KeyLearningPoint ;
  rdfs:label """Aye-ayes are nocturnal, highly-adapted mammals that live in the tropical rainforests
  of Madagascar, Africa."""@en ;
  dcterms:modified "2026-06-07T15:30:29.424605Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4891-3
  a curric:KeyLearningPoint ;
  rdfs:label """Adaptations are features that animals and plants have to help them survive in their
  environments."""@en ;
  dcterms:modified "2026-06-07T15:30:29.424609Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4891-4
  a curric:KeyLearningPoint ;
  rdfs:label "Aye-ayes’ adaptations enable them to find and eat food."@en ;
  dcterms:modified "2026-06-07T15:30:29.424614Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4891-5
  a curric:KeyLearningPoint ;
  rdfs:label "Aye-ayes’ diets consist of grubs, fruit, nectar and nuts."@en ;
  dcterms:modified "2026-06-07T15:30:29.424618Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7890-1
  a curric:KeyLearningPoint ;
  rdfs:label "Identifying the word class can support readers when interpreting new vocabluary"@en ;
  dcterms:modified "2026-06-07T15:30:29.424622Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7890-2
  a curric:KeyLearningPoint ;
  rdfs:label """Readers can use the context of the sentence to help with understanding the
  meaning"""@en ;
  dcterms:modified "2026-06-07T15:30:29.424626Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7890-3
  a curric:KeyLearningPoint ;
  rdfs:label "Skipping a new word can help infer its meaning"@en ;
  dcterms:modified "2026-06-07T15:30:29.424632Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7890-4
  a curric:KeyLearningPoint ;
  rdfs:label """Replacing an unknown word with a known word can support readers when interpreting
  new vocabluary"""@en ;
  dcterms:modified "2026-06-07T15:30:29.424637Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7943-1
  a curric:KeyLearningPoint ;
  rdfs:label """'The Miraculous Journey of Edward Tulane' is an illustrated chapter book, with black
  and white pencil sketch vignettes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.424641Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7943-2
  a curric:KeyLearningPoint ;
  rdfs:label "The protagonist is Edward, a china rabbit doll."@en ;
  dcterms:modified "2026-06-07T15:30:29.424645Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7943-3
  a curric:KeyLearningPoint ;
  rdfs:label """In 'The Miraculous Journey of Edward Tulane', themes of love, compassion and loss
  are explored."""@en ;
  dcterms:modified "2026-06-07T15:30:29.424649Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7887-1
  a curric:KeyLearningPoint ;
  rdfs:label "‘Front Desk’ is a fictional novel, inspired by the author’s childhood."@en ;
  dcterms:modified "2026-06-07T15:30:29.424763Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7887-2
  a curric:KeyLearningPoint ;
  rdfs:label "The text explores complex themes including racism, bullying, poverty and justice"@en ;
  dcterms:modified "2026-06-07T15:30:29.424768Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7887-3
  a curric:KeyLearningPoint ;
  rdfs:label "The text shares with readers the importance of tolerance and diversity."@en ;
  dcterms:modified "2026-06-07T15:30:29.424774Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7887-4
  a curric:KeyLearningPoint ;
  rdfs:label """Throughout the text, Mia notices how people are judged based on their race,
  ethnicity or social status."""@en ;
  dcterms:modified "2026-06-07T15:30:29.424778Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7858-1
  a curric:KeyLearningPoint ;
  rdfs:label "Arthur and the Golden Rope is a modern myth."@en ;
  dcterms:modified "2026-06-07T15:30:29.427079Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7858-2
  a curric:KeyLearningPoint ;
  rdfs:label "A modern myth incorporates elements from traditional myths."@en ;
  dcterms:modified "2026-06-07T15:30:29.427083Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7858-3
  a curric:KeyLearningPoint ;
  rdfs:label """Some features of a modern myth are mythical creatures, a quest, magical objects and
  gods and godesses."""@en ;
  dcterms:modified "2026-06-07T15:30:29.427089Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7858-4
  a curric:KeyLearningPoint ;
  rdfs:label "Brownstone's Mythical Collection is a collection of modern myths."@en ;
  dcterms:modified "2026-06-07T15:30:29.427094Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4707-1
  a curric:KeyLearningPoint ;
  rdfs:label "The PEPS structure stands for: point, explanation, proof, summary."@en ;
  dcterms:modified "2026-06-07T15:30:29.427220Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4707-2
  a curric:KeyLearningPoint ;
  rdfs:label "Adding proof to an argument will make it more convincing."@en ;
  dcterms:modified "2026-06-07T15:30:29.427224Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4707-3
  a curric:KeyLearningPoint ;
  rdfs:label "Summarising an argument will help the audience to remember the key parts."@en ;
  dcterms:modified "2026-06-07T15:30:29.427229Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4932-1
  a curric:KeyLearningPoint ;
  rdfs:label "Common spellings for the 'ay' phoneme are 'ay', 'a-e' and 'ai'."@en ;
  dcterms:modified "2026-06-07T15:30:29.427233Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4932-2
  a curric:KeyLearningPoint ;
  rdfs:label "Alternative and rare spellings for the 'ay' phoneme are 'a', 'eigh' and 'ey'."@en ;
  dcterms:modified "2026-06-07T15:30:29.427237Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4932-3
  a curric:KeyLearningPoint ;
  rdfs:label """Suffixes that have been added may change the spelling of a word, so finding the root
  word can be a useful strategy."""@en ;
  dcterms:modified "2026-06-07T15:30:29.427241Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4932-4
  a curric:KeyLearningPoint ;
  rdfs:label """Finding rhyming words helps to find the correct spelling, such as 'weigh' and
  'sleigh' and 'able' and 'stable'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.427247Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4932-5
  a curric:KeyLearningPoint ;
  rdfs:label "Words in word families often have similar spellings."@en ;
  dcterms:modified "2026-06-07T15:30:29.427252Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4933-1
  a curric:KeyLearningPoint ;
  rdfs:label "Common spellings for the 'ay' phoneme are 'ay', 'a-e' and 'ai'."@en ;
  dcterms:modified "2026-06-07T15:30:29.427284Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4933-2
  a curric:KeyLearningPoint ;
  rdfs:label """Alternative and rarer spellings for the 'ay' phoneme are 'ei', 'eigh', 'ea', 'a' and
  'ey'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.427291Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4933-3
  a curric:KeyLearningPoint ;
  rdfs:label "When exploring words including the same phoneme, you often find homophones."@en ;
  dcterms:modified "2026-06-07T15:30:29.427296Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4933-4
  a curric:KeyLearningPoint ;
  rdfs:label "Using the strategy 'big letters' is a useful practice strategy."@en ;
  dcterms:modified "2026-06-07T15:30:29.427300Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4933-5
  a curric:KeyLearningPoint ;
  rdfs:label "Words in word families often have similar spellings."@en ;
  dcterms:modified "2026-06-07T15:30:29.427304Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7348-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the opening is to set the scene and introduce the main
  characters."""@en ;
  dcterms:modified "2026-06-07T15:30:29.427841Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7348-2
  a curric:KeyLearningPoint ;
  rdfs:label """Ebenezer Scrooge is a miser who holds disdain for Christmas and this contrasts the
  general atmosphere in the setting."""@en ;
  dcterms:modified "2026-06-07T15:30:29.427845Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7348-3
  a curric:KeyLearningPoint ;
  rdfs:label """The use of precise and descriptive vocabulary ‘shows and tells’ the reader about
  Scrooge’s character."""@en ;
  dcterms:modified "2026-06-07T15:30:29.427852Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7348-4
  a curric:KeyLearningPoint ;
  rdfs:label "Direct speech is an effective way to convey a character’s thoughts and feelings."@en ;
  dcterms:modified "2026-06-07T15:30:29.427856Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7348-5
  a curric:KeyLearningPoint ;
  rdfs:label "An effective plan captures key vocabulary and is organised concisely."@en ;
  dcterms:modified "2026-06-07T15:30:29.427860Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7672-1
  a curric:KeyLearningPoint ;
  rdfs:label "An introduction's purpose is to give general facts to the reader."@en ;
  dcterms:modified "2026-06-07T15:30:29.427864Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7672-2
  a curric:KeyLearningPoint ;
  rdfs:label """The introduction gives general facts about the time period and origins of the
  Ancient Greeks."""@en ;
  dcterms:modified "2026-06-07T15:30:29.427904Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7672-3
  a curric:KeyLearningPoint ;
  rdfs:label """The introduction tells the reader what they will learn in the rest of the
  report."""@en ;
  dcterms:modified "2026-06-07T15:30:29.427909Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5661-1
  a curric:KeyLearningPoint ;
  rdfs:label """'Beowulf' is an epic poem set in Denmark and Sweden during the 500s CE and written
  in England in around 1000 CE."""@en ;
  dcterms:modified "2026-06-07T15:30:29.427914Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5661-2
  a curric:KeyLearningPoint ;
  rdfs:label """The story follows the heroic deeds of the warrior Beowulf. It was written in Old
  English by an unknown author."""@en ;
  dcterms:modified "2026-06-07T15:30:29.427920Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5661-3
  a curric:KeyLearningPoint ;
  rdfs:label """In translation, the text still includes archaic language due to its historical
  context."""@en ;
  dcterms:modified "2026-06-07T15:30:29.427925Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5661-4
  a curric:KeyLearningPoint ;
  rdfs:label """Beowulf, a Geat, volunteers to travel to Denmark to defeat Grendel, a monster who
  has been terrorising the Danes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.427931Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5661-5
  a curric:KeyLearningPoint ;
  rdfs:label """The author makes specific language choices in order to give us particular
  impressions of characters and events."""@en ;
  dcterms:modified "2026-06-07T15:30:29.427935Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4812-1
  a curric:KeyLearningPoint ;
  rdfs:label "Silent letters are letters that are not pronounced when the word is spoken."@en ;
  dcterms:modified "2026-06-07T15:30:29.427939Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4812-2
  a curric:KeyLearningPoint ;
  rdfs:label """Practising writing words with silent letters in cursive can improve your
  handwriting."""@en ;
  dcterms:modified "2026-06-07T15:30:29.427944Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4812-3
  a curric:KeyLearningPoint ;
  rdfs:label "The words start with a lead in and finish with a lead out."@en ;
  dcterms:modified "2026-06-07T15:30:29.427948Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4812-4
  a curric:KeyLearningPoint ;
  rdfs:label """There are four cursive joins; which is used depends on which letter is joining to
  which letter within a letter string."""@en ;
  dcterms:modified "2026-06-07T15:30:29.427952Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4812-5
  a curric:KeyLearningPoint ;
  rdfs:label "You do not lift your pencil when forming the joins."@en ;
  dcterms:modified "2026-06-07T15:30:29.427956Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4833-1
  a curric:KeyLearningPoint ;
  rdfs:label "Writing with emphasis involves making certain words or phrases stand out."@en ;
  dcterms:modified "2026-06-07T15:30:29.427960Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4833-2
  a curric:KeyLearningPoint ;
  rdfs:label """Writing with emphasis helps to show what’s most important or exciting in the
  writing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.427965Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4833-3
  a curric:KeyLearningPoint ;
  rdfs:label "There are different strategies to show emphasis in your writing."@en ;
  dcterms:modified "2026-06-07T15:30:29.427969Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4833-4
  a curric:KeyLearningPoint ;
  rdfs:label """Capital letters, underlining or repeating a word or phrase can emphasise importance
  or express excitement."""@en ;
  dcterms:modified "2026-06-07T15:30:29.427973Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4833-5
  a curric:KeyLearningPoint ;
  rdfs:label "Adding an exclamation mark can emphasise strong emotions to the reader."@en ;
  dcterms:modified "2026-06-07T15:30:29.427977Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1132-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Blundering' is an adjective which means goofy or clumsy."@en ;
  dcterms:modified "2026-06-07T15:30:29.427981Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1132-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Bumbling' is an adjective which means awkward, clumsy or useless."@en ;
  dcterms:modified "2026-06-07T15:30:29.427985Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1132-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Butterfingered' is an adjective which means clumsy or accident-prone."@en ;
  dcterms:modified "2026-06-07T15:30:29.427989Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8774-1
  a curric:KeyLearningPoint ;
  rdfs:label """The Anglerfish is a bioluminescent creature that uses its glow to lure prey, making
  it an expert predator."""@en ;
  dcterms:modified "2026-06-07T15:30:29.428074Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8774-2
  a curric:KeyLearningPoint ;
  rdfs:label """The Anglerfish lives in the deepest part of the ocean named the midnight zone, which
  is difficult for humans to visit."""@en ;
  dcterms:modified "2026-06-07T15:30:29.428078Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8774-3
  a curric:KeyLearningPoint ;
  rdfs:label """Navigating the layout of a non-fiction text can help you read and retrieve
  information on a specific topic."""@en ;
  dcterms:modified "2026-06-07T15:30:29.428082Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8774-4
  a curric:KeyLearningPoint ;
  rdfs:label """Skimming and scanning for keywords can help you accurately retrieve information from
  the text quickly."""@en ;
  dcterms:modified "2026-06-07T15:30:29.428086Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8774-5
  a curric:KeyLearningPoint ;
  rdfs:label """Summarising what has been read helps knowledge to stick and builds
  comprehension."""@en ;
  dcterms:modified "2026-06-07T15:30:29.428090Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1397-1
  a curric:KeyLearningPoint ;
  rdfs:label """A prefix is a letter or group of letters at the start of a word which changes its
  meaning."""@en ;
  dcterms:modified "2026-06-07T15:30:29.428110Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1397-2
  a curric:KeyLearningPoint ;
  rdfs:label "The prefix bi- means ‘two’ and the prefix trans- means ‘across’."@en ;
  dcterms:modified "2026-06-07T15:30:29.428115Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1397-3
  a curric:KeyLearningPoint ;
  rdfs:label "The prefix tele- means ‘distant’ and the prefix circum- means ‘around’."@en ;
  dcterms:modified "2026-06-07T15:30:29.428119Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1397-4
  a curric:KeyLearningPoint ;
  rdfs:label """Recognising prefixes can help us understand a word’s meaning and help us to spell
  it."""@en ;
  dcterms:modified "2026-06-07T15:30:29.428123Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1397-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: bicycle, naughty and enough."@en ;
  dcterms:modified "2026-06-07T15:30:29.428127Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5764-1
  a curric:KeyLearningPoint ;
  rdfs:label "Editing is a vital element of the writing process."@en ;
  dcterms:modified "2026-06-07T15:30:29.428186Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5764-2
  a curric:KeyLearningPoint ;
  rdfs:label "When editing, we must be selective about which parts of our writing to improve."@en ;
  dcterms:modified "2026-06-07T15:30:29.428190Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5764-3
  a curric:KeyLearningPoint ;
  rdfs:label """When editing, we can focus on punctuation, sentence structure, vocabulary and
  spelling."""@en ;
  dcterms:modified "2026-06-07T15:30:29.428194Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6362-1
  a curric:KeyLearningPoint ;
  rdfs:label """The quotes section of a journalistic report should begin with an introductory
  sentence about witnesses."""@en ;
  dcterms:modified "2026-06-07T15:30:29.428288Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6362-2
  a curric:KeyLearningPoint ;
  rdfs:label """The sentence preceding reported speech can introduce the witness and provide greater
  detail about them."""@en ;
  dcterms:modified "2026-06-07T15:30:29.428293Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6362-3
  a curric:KeyLearningPoint ;
  rdfs:label """The quote from the witness can be more informal in language and tone than the rest
  of the paragraph."""@en ;
  dcterms:modified "2026-06-07T15:30:29.428297Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6362-4
  a curric:KeyLearningPoint ;
  rdfs:label "A reporting clause can come before or after direct speech."@en ;
  dcterms:modified "2026-06-07T15:30:29.428301Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6362-5
  a curric:KeyLearningPoint ;
  rdfs:label """Inverted commas are used to demarcate speech and a piece of punctuation separates
  speech from the reporting clause."""@en ;
  dcterms:modified "2026-06-07T15:30:29.428305Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8082-1
  a curric:KeyLearningPoint ;
  rdfs:label """Imagery refers to the use of language that evokes vivid mental pictures in the
  reader's mind."""@en ;
  dcterms:modified "2026-06-07T15:30:29.428309Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8082-2
  a curric:KeyLearningPoint ;
  rdfs:label """In the poem 'London', William Blake uses sensory language to paint a vivid
  image."""@en ;
  dcterms:modified "2026-06-07T15:30:29.428313Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8082-3
  a curric:KeyLearningPoint ;
  rdfs:label """Sounds are important in the poem, such as the \"infant's cry of fear\" and the
  \"chimney-sweeper's cry\"."""@en ;
  dcterms:modified "2026-06-07T15:30:29.428317Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8082-4
  a curric:KeyLearningPoint ;
  rdfs:label """The use of negative sounds in the poem creates a noisy and unpleasant impression of
  the city."""@en ;
  dcterms:modified "2026-06-07T15:30:29.428321Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8082-5
  a curric:KeyLearningPoint ;
  rdfs:label "Different kinds of language have different effects."@en ;
  dcterms:modified "2026-06-07T15:30:29.428326Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6010-1
  a curric:KeyLearningPoint ;
  rdfs:label """A written argument tries to convince the reader of something using strong reasoning
  to support."""@en ;
  dcterms:modified "2026-06-07T15:30:29.428406Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6010-2
  a curric:KeyLearningPoint ;
  rdfs:label "The PEPS structure stands for: point, explanation, proof, summary."@en ;
  dcterms:modified "2026-06-07T15:30:29.428410Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6010-3
  a curric:KeyLearningPoint ;
  rdfs:label "When we write a plan, we use notes."@en ;
  dcterms:modified "2026-06-07T15:30:29.428414Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1045-1
  a curric:KeyLearningPoint ;
  rdfs:label "A comma is a punctuation mark with more than one purpose."@en ;
  dcterms:modified "2026-06-07T15:30:29.428539Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1045-2
  a curric:KeyLearningPoint ;
  rdfs:label "Commas are often used to demarcate clauses in a range of sentence types."@en ;
  dcterms:modified "2026-06-07T15:30:29.428543Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1045-3
  a curric:KeyLearningPoint ;
  rdfs:label """If the adverbial clause starts an adverbial complex sentence, it is followed by a
  comma then the main clause."""@en ;
  dcterms:modified "2026-06-07T15:30:29.428548Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1045-4
  a curric:KeyLearningPoint ;
  rdfs:label """A comma is used before \"but\" and \"or\" co-ordinating conjunctions when they join
  two main clauses in a compound sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.428552Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1045-5
  a curric:KeyLearningPoint ;
  rdfs:label """Grammatically accurate sentences start with capital letters and most often end with
  full stops."""@en ;
  dcterms:modified "2026-06-07T15:30:29.428556Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4713-1
  a curric:KeyLearningPoint ;
  rdfs:label """A speaker should introduce themselves and their speech title when they first start
  speaking."""@en ;
  dcterms:modified "2026-06-07T15:30:29.428560Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4713-2
  a curric:KeyLearningPoint ;
  rdfs:label "Using eye-contact helps to make a speech successful."@en ;
  dcterms:modified "2026-06-07T15:30:29.428564Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4713-3
  a curric:KeyLearningPoint ;
  rdfs:label "It is important not to speak too fast when delivering a speech."@en ;
  dcterms:modified "2026-06-07T15:30:29.428568Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4713-4
  a curric:KeyLearningPoint ;
  rdfs:label """Using body language and gestures will help to reinforce your purpose for
  speaking."""@en ;
  dcterms:modified "2026-06-07T15:30:29.428572Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1414-1
  a curric:KeyLearningPoint ;
  rdfs:label "The suffix -ary often turns words into nouns or adjectives."@en ;
  dcterms:modified "2026-06-07T15:30:29.428694Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1414-2
  a curric:KeyLearningPoint ;
  rdfs:label "Some words end in -ary with no clear root word."@en ;
  dcterms:modified "2026-06-07T15:30:29.428698Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1414-3
  a curric:KeyLearningPoint ;
  rdfs:label "Thinking about word families can help with understanding meanings and spelling."@en ;
  dcterms:modified "2026-06-07T15:30:29.428702Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1414-4
  a curric:KeyLearningPoint ;
  rdfs:label "When the root word ends in 'e', remove the 'e' and add the suffix -ary."@en ;
  dcterms:modified "2026-06-07T15:30:29.428708Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1414-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: believe, complete and guide."@en ;
  dcterms:modified "2026-06-07T15:30:29.428712Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4869-1
  a curric:KeyLearningPoint ;
  rdfs:label "The conclusion is the final paragraph of a non-chronological report."@en ;
  dcterms:modified "2026-06-07T15:30:29.428763Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4869-2
  a curric:KeyLearningPoint ;
  rdfs:label "Information in the conclusion should be general."@en ;
  dcterms:modified "2026-06-07T15:30:29.428767Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4869-3
  a curric:KeyLearningPoint ;
  rdfs:label """Writers can use a range of cohesive devices to enhance text flow and keep the reader
  engaged."""@en ;
  dcterms:modified "2026-06-07T15:30:29.428771Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4869-4
  a curric:KeyLearningPoint ;
  rdfs:label "Effective planning leads to successful writing outcomes."@en ;
  dcterms:modified "2026-06-07T15:30:29.428775Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8477-1
  a curric:KeyLearningPoint ;
  rdfs:label """In the resolution, the Iron Man finds a new home in a metal scrapyard and he no
  longer needs the farmers’ machinery."""@en ;
  dcterms:modified "2026-06-07T15:30:29.428827Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8477-2
  a curric:KeyLearningPoint ;
  rdfs:label """Exaggeration is a key part of conveying positive emotions in the resolution of a
  narrative."""@en ;
  dcterms:modified "2026-06-07T15:30:29.428833Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8477-3
  a curric:KeyLearningPoint ;
  rdfs:label """Superlative adjectives and similes are used to exaggerate and build imagery for the
  reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.428837Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8477-4
  a curric:KeyLearningPoint ;
  rdfs:label """Superlatives are used to compare one noun to an entire group of nouns, placing it at
  a higher degree."""@en ;
  dcterms:modified "2026-06-07T15:30:29.428841Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8477-5
  a curric:KeyLearningPoint ;
  rdfs:label """A simile is a linguistic device that compares two things using ‘like’ or ‘as’,
  highlighting similarities."""@en ;
  dcterms:modified "2026-06-07T15:30:29.428845Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5820-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the opening is to provide the reader with a detailed description of
  the setting and main character."""@en ;
  dcterms:modified "2026-06-07T15:30:29.428878Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5820-2
  a curric:KeyLearningPoint ;
  rdfs:label """Literary devices that create figurative language include metaphors, similes and
  personification."""@en ;
  dcterms:modified "2026-06-07T15:30:29.428882Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5820-3
  a curric:KeyLearningPoint ;
  rdfs:label """A metaphor is a type of figurative language that involves describing something as
  though it actually is something else."""@en ;
  dcterms:modified "2026-06-07T15:30:29.428887Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7356-1
  a curric:KeyLearningPoint ;
  rdfs:label "Retrieval involves identifying and extracting key information from the text."@en ;
  dcterms:modified "2026-06-07T15:30:29.430700Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7356-2
  a curric:KeyLearningPoint ;
  rdfs:label """Searching for keywords or specific types of words can support readers in answering
  retrieval questions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.430705Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7356-3
  a curric:KeyLearningPoint ;
  rdfs:label """When a reader infers, they use clues from the text and their own understanding to
  ‘read between the lines’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.430709Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7356-4
  a curric:KeyLearningPoint ;
  rdfs:label "Inferring helps readers establish an impression of a character."@en ;
  dcterms:modified "2026-06-07T15:30:29.430713Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7354-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the climax is to describe the main action and take the suspense to
  its highest point."""@en ;
  dcterms:modified "2026-06-07T15:30:29.430738Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7354-2
  a curric:KeyLearningPoint ;
  rdfs:label """The climax of ‘A Christmas Carol’ describes Scrooge’s encounter with the Ghost of
  Christmas Yet to Come (Future)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.430742Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7354-3
  a curric:KeyLearningPoint ;
  rdfs:label """Scrooge feels great regret and sorrow upon seeing the future visions and realises he
  must change his ways."""@en ;
  dcterms:modified "2026-06-07T15:30:29.430746Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7354-4
  a curric:KeyLearningPoint ;
  rdfs:label """Precise and descriptive vocabulary, including 'show and tell' is used to convey an
  ominous atmosphere."""@en ;
  dcterms:modified "2026-06-07T15:30:29.430750Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7354-5
  a curric:KeyLearningPoint ;
  rdfs:label """Direct speech and Scrooge’s inner thoughts are used to convey Scrooge’s fraught
  emotions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.430754Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7865-1
  a curric:KeyLearningPoint ;
  rdfs:label "Reading between the lines to search for clues can help to infer meaning"@en ;
  dcterms:modified "2026-06-07T15:30:29.430810Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7865-2
  a curric:KeyLearningPoint ;
  rdfs:label "Evidence from the text helps us to justify our inferences"@en ;
  dcterms:modified "2026-06-07T15:30:29.430814Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7865-3
  a curric:KeyLearningPoint ;
  rdfs:label """Cronus was overcome by the fear that his children would replace him as the ruler of
  the world"""@en ;
  dcterms:modified "2026-06-07T15:30:29.430818Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7865-4
  a curric:KeyLearningPoint ;
  rdfs:label "Rhea deceived Cronus and Zeus grew up with the bee-nymphs"@en ;
  dcterms:modified "2026-06-07T15:30:29.430823Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7865-5
  a curric:KeyLearningPoint ;
  rdfs:label """There was a war between Cronus and the Titans and Zeus and his brothers and
  sisters"""@en ;
  dcterms:modified "2026-06-07T15:30:29.430827Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7867-1
  a curric:KeyLearningPoint ;
  rdfs:label """A theme is a big idea, topic or message that recurs within a story and authors use
  these to convey deeper meaning"""@en ;
  dcterms:modified "2026-06-07T15:30:29.430833Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7867-2
  a curric:KeyLearningPoint ;
  rdfs:label """A text's epilogue and afterword can support readers in making connections within the
  text and to the wider world."""@en ;
  dcterms:modified "2026-06-07T15:30:29.430837Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7867-3
  a curric:KeyLearningPoint ;
  rdfs:label "A reader's reflection on a text is unique and personal."@en ;
  dcterms:modified "2026-06-07T15:30:29.430841Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7867-4
  a curric:KeyLearningPoint ;
  rdfs:label "Some themes can be conveyed across multiple myths."@en ;
  dcterms:modified "2026-06-07T15:30:29.430847Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6746-1
  a curric:KeyLearningPoint ;
  rdfs:label """In this lesson, we are writing a third person flashback and a first person
  perspective."""@en ;
  dcterms:modified "2026-06-07T15:30:29.430923Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6746-2
  a curric:KeyLearningPoint ;
  rdfs:label """Switching perspectives like this allows us to focus on different elements of the
  narrative at different points."""@en ;
  dcterms:modified "2026-06-07T15:30:29.430927Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6746-3
  a curric:KeyLearningPoint ;
  rdfs:label "Our flashback is likely to be more formal than the first person section."@en ;
  dcterms:modified "2026-06-07T15:30:29.430933Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6746-4
  a curric:KeyLearningPoint ;
  rdfs:label "Both sections should include a range of sentence structures and punctuation."@en ;
  dcterms:modified "2026-06-07T15:30:29.430938Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6746-5
  a curric:KeyLearningPoint ;
  rdfs:label "Orally rehearsing our writing allows us to write more confidently."@en ;
  dcterms:modified "2026-06-07T15:30:29.430942Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6731-1
  a curric:KeyLearningPoint ;
  rdfs:label "Writing is most successful when it is planned and rehearsed."@en ;
  dcterms:modified "2026-06-07T15:30:29.430946Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6731-2
  a curric:KeyLearningPoint ;
  rdfs:label """When we plan, we can use our text map as a basis, breaking it down into key
  scenes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.430950Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6731-3
  a curric:KeyLearningPoint ;
  rdfs:label """For each scene, we make notes about the actions, descriptions, dialogue and emotions
  we might include (where relevant)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.430956Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6731-4
  a curric:KeyLearningPoint ;
  rdfs:label """We also plan to include the rich vocabulary that we have generated in previous
  lessons."""@en ;
  dcterms:modified "2026-06-07T15:30:29.430960Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6153-1
  a curric:KeyLearningPoint ;
  rdfs:label """A journalistic report is a non-fiction text that informs the reader about an
  event."""@en ;
  dcterms:modified "2026-06-07T15:30:29.431057Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6153-2
  a curric:KeyLearningPoint ;
  rdfs:label """Organised in paragraphs, a journalistic report opens with an introduction and ends
  with a closing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.431062Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6153-3
  a curric:KeyLearningPoint ;
  rdfs:label "Generally, in a news report, the journalist does not include their own opinion."@en ;
  dcterms:modified "2026-06-07T15:30:29.431066Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6153-4
  a curric:KeyLearningPoint ;
  rdfs:label "The report will contain a mixture of factual claims and reported perspectives."@en ;
  dcterms:modified "2026-06-07T15:30:29.431070Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6153-5
  a curric:KeyLearningPoint ;
  rdfs:label "The perspectives may be shown using direct or reported speech."@en ;
  dcterms:modified "2026-06-07T15:30:29.431074Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8772-1
  a curric:KeyLearningPoint ;
  rdfs:label """Familiarising yourself with a text's layout helps you to navigate and
  understand it."""@en ;
  dcterms:modified "2026-06-07T15:30:29.431080Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8772-2
  a curric:KeyLearningPoint ;
  rdfs:label """Skimming and scanning is a way to retrieve information accurately and quickly from a
  text."""@en ;
  dcterms:modified "2026-06-07T15:30:29.431084Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8772-3
  a curric:KeyLearningPoint ;
  rdfs:label "Searching for key words helps you to find information you are looking for."@en ;
  dcterms:modified "2026-06-07T15:30:29.431088Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8772-4
  a curric:KeyLearningPoint ;
  rdfs:label """Bioluminescence and biofluorescence are two different ways in which creatures
  produce their glow."""@en ;
  dcterms:modified "2026-06-07T15:30:29.431094Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7857-1
  a curric:KeyLearningPoint ;
  rdfs:label """Cece has different relationships with characters within the text, including her
  family and friends."""@en ;
  dcterms:modified "2026-06-07T15:30:29.431134Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7857-2
  a curric:KeyLearningPoint ;
  rdfs:label """Characters within the text depict a range of emotions. Character traits can be
  understood from these."""@en ;
  dcterms:modified "2026-06-07T15:30:29.431138Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7857-3
  a curric:KeyLearningPoint ;
  rdfs:label """Character traits can be explored through the text’s illustrations or words used by
  the characters"""@en ;
  dcterms:modified "2026-06-07T15:30:29.431142Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7857-4
  a curric:KeyLearningPoint ;
  rdfs:label """Making connections and recommendations can significantly enhance the reading
  experience and broaden understanding."""@en ;
  dcterms:modified "2026-06-07T15:30:29.431146Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1332-1
  a curric:KeyLearningPoint ;
  rdfs:label "Adding -s or -es to a noun creates a plural."@en ;
  dcterms:modified "2026-06-07T15:30:29.431185Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1332-2
  a curric:KeyLearningPoint ;
  rdfs:label "If the word ends in a vowel (a, e, i, u) or consonant, just add -s."@en ;
  dcterms:modified "2026-06-07T15:30:29.431191Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1332-3
  a curric:KeyLearningPoint ;
  rdfs:label "If the word ends in 'y' preceded by a vowel, just add -s."@en ;
  dcterms:modified "2026-06-07T15:30:29.431197Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1332-4
  a curric:KeyLearningPoint ;
  rdfs:label "If the word ends in 'y' preceded by a consonant, remove the 'y' and add -ies."@en ;
  dcterms:modified "2026-06-07T15:30:29.431201Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1332-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: harass and recommend."@en ;
  dcterms:modified "2026-06-07T15:30:29.431205Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3469-1
  a curric:KeyLearningPoint ;
  rdfs:label "The steps in the honey-making process are written in chronological order."@en ;
  dcterms:modified "2026-06-07T15:30:29.431241Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3469-2
  a curric:KeyLearningPoint ;
  rdfs:label "Ordering fronted adverbials indicate the order of the steps in a process."@en ;
  dcterms:modified "2026-06-07T15:30:29.431245Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3469-3
  a curric:KeyLearningPoint ;
  rdfs:label """Using the full range of sentence types (simple, compound and complex) improves text
  flow for the reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.431249Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3469-4
  a curric:KeyLearningPoint ;
  rdfs:label """Explanation texts include subject-specific vocabulary that is related to the subject
  of the text."""@en ;
  dcterms:modified "2026-06-07T15:30:29.431253Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4865-1
  a curric:KeyLearningPoint ;
  rdfs:label "Editing is the process of making changes to improve our writing."@en ;
  dcterms:modified "2026-06-07T15:30:29.431270Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4865-2
  a curric:KeyLearningPoint ;
  rdfs:label "Editing can be done by oneself, with a peer or with a teacher."@en ;
  dcterms:modified "2026-06-07T15:30:29.431274Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4865-3
  a curric:KeyLearningPoint ;
  rdfs:label """When editing punctuation, missing or incorrectly used capital letters, full stops
  and commas are all checked."""@en ;
  dcterms:modified "2026-06-07T15:30:29.431278Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4865-4
  a curric:KeyLearningPoint ;
  rdfs:label """When editing sentence structure, the way sentences are constructed is checked to
  improve and enhance text flow."""@en ;
  dcterms:modified "2026-06-07T15:30:29.431282Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4865-5
  a curric:KeyLearningPoint ;
  rdfs:label "When editing language, choices of words and phrases are carefully reviewed."@en ;
  dcterms:modified "2026-06-07T15:30:29.431288Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1354-1
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: available, vegetable, physical and symbol."@en ;
  dcterms:modified "2026-06-07T15:30:29.431355Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1354-2
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: convenience, existence and conscience."@en ;
  dcterms:modified "2026-06-07T15:30:29.431359Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1354-3
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: equipped, attached and thorough."@en ;
  dcterms:modified "2026-06-07T15:30:29.431363Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1354-4
  a curric:KeyLearningPoint ;
  rdfs:label "Spelling strategies help us to notice how words are spelled."@en ;
  dcterms:modified "2026-06-07T15:30:29.431369Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1354-5
  a curric:KeyLearningPoint ;
  rdfs:label """The practice spelling strategy you choose often depends on the spelling you are
  practising and what makes it difficult."""@en ;
  dcterms:modified "2026-06-07T15:30:29.431374Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6355-1
  a curric:KeyLearningPoint ;
  rdfs:label """Little Red Riding Hood is a traditional tale which has been adapted and retold in
  different ways."""@en ;
  dcterms:modified "2026-06-07T15:30:29.431394Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6355-2
  a curric:KeyLearningPoint ;
  rdfs:label "Journalistic reports provide information about current events and news."@en ;
  dcterms:modified "2026-06-07T15:30:29.431398Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6355-3
  a curric:KeyLearningPoint ;
  rdfs:label """A newsworthy event is something that is interesting or important enough to warrant
  reporting to the public."""@en ;
  dcterms:modified "2026-06-07T15:30:29.431405Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6355-4
  a curric:KeyLearningPoint ;
  rdfs:label "The wolf's actions would be considered a crime and newsworthy."@en ;
  dcterms:modified "2026-06-07T15:30:29.431409Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6355-5
  a curric:KeyLearningPoint ;
  rdfs:label """The wolf would be considered the perpetrator and the grandmother and Little Red
  Riding Hood would be the victims."""@en ;
  dcterms:modified "2026-06-07T15:30:29.431413Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6363-1
  a curric:KeyLearningPoint ;
  rdfs:label """The closing paragraph of a journalistic report provides the reader with information
  about what is currently happening."""@en ;
  dcterms:modified "2026-06-07T15:30:29.431459Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6363-2
  a curric:KeyLearningPoint ;
  rdfs:label """A shift to present tense is a key linguistic feature of the closing of a
  journalistic report."""@en ;
  dcterms:modified "2026-06-07T15:30:29.431463Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6363-3
  a curric:KeyLearningPoint ;
  rdfs:label """Adverbial complex sentences can be used to tell the reader about two things
  happening at the same time."""@en ;
  dcterms:modified "2026-06-07T15:30:29.431467Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6363-4
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials of time support in communicating the tense shift to the reader
  and closing the report."""@en ;
  dcterms:modified "2026-06-07T15:30:29.431471Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6360-1
  a curric:KeyLearningPoint ;
  rdfs:label """The recount section of a journalistic report provides specific details about a news
  event in chronological order."""@en ;
  dcterms:modified "2026-06-07T15:30:29.431498Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6360-2
  a curric:KeyLearningPoint ;
  rdfs:label "The use of notes from a plan support in the writing process."@en ;
  dcterms:modified "2026-06-07T15:30:29.431502Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6360-3
  a curric:KeyLearningPoint ;
  rdfs:label """Formal journalistic language and subject-specific vocabulary is crucial for creating
  an objective and serious tone."""@en ;
  dcterms:modified "2026-06-07T15:30:29.431506Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6360-4
  a curric:KeyLearningPoint ;
  rdfs:label """The use of fronted adverbials of time supports in communicating the timeline of
  events to the reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.431510Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6360-5
  a curric:KeyLearningPoint ;
  rdfs:label """The use of adverbial and relative complex sentences supports in providing greater
  detail and facts for the reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.431514Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1459-1
  a curric:KeyLearningPoint ;
  rdfs:label """The pronunciation of a word helps to identify if it is spelt with -sure or
  -ture."""@en ;
  dcterms:modified "2026-06-07T15:30:29.431578Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1459-2
  a curric:KeyLearningPoint ;
  rdfs:label """The -ture ending to a word can be confused with a root word ending in '(t)ch+er',
  such as 'teacher' or 'richer'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.431583Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1459-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Colour blocking' is a useful practice strategy."@en ;
  dcterms:modified "2026-06-07T15:30:29.431587Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1459-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum word: grammar."@en ;
  dcterms:modified "2026-06-07T15:30:29.431591Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6008-1
  a curric:KeyLearningPoint ;
  rdfs:label """A written argument tries to convince the reader of something using strong reasoning
  to support."""@en ;
  dcterms:modified "2026-06-07T15:30:29.431643Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6008-2
  a curric:KeyLearningPoint ;
  rdfs:label "The PEPS structure stands for: point, explanation, proof, summary."@en ;
  dcterms:modified "2026-06-07T15:30:29.431647Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6008-3
  a curric:KeyLearningPoint ;
  rdfs:label "When we write a plan, we use notes."@en ;
  dcterms:modified "2026-06-07T15:30:29.431651Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1095-1
  a curric:KeyLearningPoint ;
  rdfs:label """'Picturesque' is an adjective which means attractive or scenic; like a village so
  pretty it could be on a postcard."""@en ;
  dcterms:modified "2026-06-07T15:30:29.431655Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1095-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Remote' is an adjective which means far away and alone; like an island where one
  person lives all by himself."""@en ;
  dcterms:modified "2026-06-07T15:30:29.431659Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1095-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Rural' is an adjective which means rustic or natural; like being in the
  countryside."""@en ;
  dcterms:modified "2026-06-07T15:30:29.431663Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1095-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Quaint', 'coastal' and 'bucolic' are other rich vocabulary associated with a
  village."""@en ;
  dcterms:modified "2026-06-07T15:30:29.431667Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4877-1
  a curric:KeyLearningPoint ;
  rdfs:label "Information in the adaptations section is specific for the reader."@en ;
  dcterms:modified "2026-06-07T15:30:29.431671Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4877-2
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials, subject-specific vocabulary, relative complex sentences and
  parenthesis enhance text cohesion."""@en ;
  dcterms:modified "2026-06-07T15:30:29.431675Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4877-3
  a curric:KeyLearningPoint ;
  rdfs:label """Parenthesis is additional information added to the sentence that can be demarcated
  using a pair of brackets."""@en ;
  dcterms:modified "2026-06-07T15:30:29.431680Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4877-4
  a curric:KeyLearningPoint ;
  rdfs:label "Plans should be used when writing to generate initial ideas and build upon them."@en ;
  dcterms:modified "2026-06-07T15:30:29.431686Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4877-5
  a curric:KeyLearningPoint ;
  rdfs:label "Success criteria help us understand what to include in our writing."@en ;
  dcterms:modified "2026-06-07T15:30:29.431691Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6696-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the climax is to describe the main action and take the suspense and
  excitement to its highest point."""@en ;
  dcterms:modified "2026-06-07T15:30:29.431721Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6696-2
  a curric:KeyLearningPoint ;
  rdfs:label """Precise and ambitious vocabulary create vivid images for the reader for each key
  moment of the climax."""@en ;
  dcterms:modified "2026-06-07T15:30:29.431726Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6696-3
  a curric:KeyLearningPoint ;
  rdfs:label "An effective plan has vocabulary organised concisely and neatly."@en ;
  dcterms:modified "2026-06-07T15:30:29.431730Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6696-4
  a curric:KeyLearningPoint ;
  rdfs:label """Careful verb and adverb selection can convey characters' feelings through ‘show and
  tell’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.431734Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6696-5
  a curric:KeyLearningPoint ;
  rdfs:label "Synonyms for ‘said’ are used to convey character emotion in speech."@en ;
  dcterms:modified "2026-06-07T15:30:29.431738Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1367-1
  a curric:KeyLearningPoint ;
  rdfs:label "The suffixes -ise and -ify often turn adjectives and nouns into verbs."@en ;
  dcterms:modified "2026-06-07T15:30:29.431743Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1367-2
  a curric:KeyLearningPoint ;
  rdfs:label "When the root word ends in a consonant, we often just add the suffix."@en ;
  dcterms:modified "2026-06-07T15:30:29.431747Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1367-3
  a curric:KeyLearningPoint ;
  rdfs:label "When the root word ends in a ‘y’, we remove the ‘y’ and add the suffix."@en ;
  dcterms:modified "2026-06-07T15:30:29.431751Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1367-4
  a curric:KeyLearningPoint ;
  rdfs:label """When the root word ends in a vowel, we remove the final vowel and add the
  suffix."""@en ;
  dcterms:modified "2026-06-07T15:30:29.431755Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1367-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: exercise, criticise and consider."@en ;
  dcterms:modified "2026-06-07T15:30:29.431762Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1312-1
  a curric:KeyLearningPoint ;
  rdfs:label "The suffix -ous often turns nouns into adjectives and often means 'full of'."@en ;
  dcterms:modified "2026-06-07T15:30:29.431768Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1312-2
  a curric:KeyLearningPoint ;
  rdfs:label "There are four key rules when adding the suffix -ous to a root word."@en ;
  dcterms:modified "2026-06-07T15:30:29.431773Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1312-3
  a curric:KeyLearningPoint ;
  rdfs:label """When you hear the ‘ee’ sound before -ous, the most likely spelling is an ‘i’, but it
  is sometimes an ‘e’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.431777Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1312-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: learn, group and earth."@en ;
  dcterms:modified "2026-06-07T15:30:29.431783Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1111-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Rustling' is an adjective which means crackling or swishing."@en ;
  dcterms:modified "2026-06-07T15:30:29.431787Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1111-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Serene' is an adjective which means peaceful or calm."@en ;
  dcterms:modified "2026-06-07T15:30:29.431793Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1111-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Tranquil' is an adjective which means peaceful or blissfully quiet."@en ;
  dcterms:modified "2026-06-07T15:30:29.431798Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5458-1
  a curric:KeyLearningPoint ;
  rdfs:label "Connections are ways in which you connect personally with a text."@en ;
  dcterms:modified "2026-06-07T15:30:29.433198Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5458-2
  a curric:KeyLearningPoint ;
  rdfs:label "Personal experiences impact the way that we interpret and connect to a text."@en ;
  dcterms:modified "2026-06-07T15:30:29.433202Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5458-3
  a curric:KeyLearningPoint ;
  rdfs:label "Connections can be from text-to-self, text-to-text or text-to-world."@en ;
  dcterms:modified "2026-06-07T15:30:29.433206Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5458-4
  a curric:KeyLearningPoint ;
  rdfs:label """We can draw comparisons between stories by considering character, setting, plot and
  themes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.433210Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5458-5
  a curric:KeyLearningPoint ;
  rdfs:label """‘The Moon Dragons’ can inspire us to draw comparisons with other stories that
  portray the female heroine, e.g. ‘Mulan’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.433214Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6378-1
  a curric:KeyLearningPoint ;
  rdfs:label """Direct speech can be written in the form of speech first or speech second
  sentences."""@en ;
  dcterms:modified "2026-06-07T15:30:29.433296Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6378-2
  a curric:KeyLearningPoint ;
  rdfs:label "Speech first and speech second sentences are punctuated differently."@en ;
  dcterms:modified "2026-06-07T15:30:29.433300Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6378-3
  a curric:KeyLearningPoint ;
  rdfs:label """The reporting clause in a speech sentence explains who spoke and how they
  said it."""@en ;
  dcterms:modified "2026-06-07T15:30:29.433337Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6378-4
  a curric:KeyLearningPoint ;
  rdfs:label "Additional information can be added to the reporting clause for the reader."@en ;
  dcterms:modified "2026-06-07T15:30:29.433345Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7186-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of a diary entry is to recount important experiences and express
  feelings."""@en ;
  dcterms:modified "2026-06-07T15:30:29.433349Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7186-2
  a curric:KeyLearningPoint ;
  rdfs:label """A diary entry follows a specific structure, it is written in the first person and it
  uses informal language."""@en ;
  dcterms:modified "2026-06-07T15:30:29.433353Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7186-3
  a curric:KeyLearningPoint ;
  rdfs:label """Simple past and progressive past tenses recount what the writer experienced and
  felt."""@en ;
  dcterms:modified "2026-06-07T15:30:29.433358Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7186-4
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials of time support in sequencing events in a recount
  chronologically."""@en ;
  dcterms:modified "2026-06-07T15:30:29.433364Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7186-5
  a curric:KeyLearningPoint ;
  rdfs:label """Present tense is used towards the end of a diary entry to show how the writer is
  feeling now."""@en ;
  dcterms:modified "2026-06-07T15:30:29.433371Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1079-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Overpowering' is an adjective which means overwhelming or unbearable."@en ;
  dcterms:modified "2026-06-07T15:30:29.433375Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1079-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Pungent' is an adjective which means having a strong smell or sharp taste."@en ;
  dcterms:modified "2026-06-07T15:30:29.433379Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1079-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Putrid' is an adjective which means rotten and decayed."@en ;
  dcterms:modified "2026-06-07T15:30:29.433383Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1079-4
  a curric:KeyLearningPoint ;
  rdfs:label "'Faint', 'musty' and 'toxic' are other adjectives related to smell."@en ;
  dcterms:modified "2026-06-07T15:30:29.433387Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2702-1
  a curric:KeyLearningPoint ;
  rdfs:label "A relative clause joined to a main clause forms a relative complex sentence."@en ;
  dcterms:modified "2026-06-07T15:30:29.433391Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2702-2
  a curric:KeyLearningPoint ;
  rdfs:label "The relative clause often interrupts the main clause."@en ;
  dcterms:modified "2026-06-07T15:30:29.433395Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2702-3
  a curric:KeyLearningPoint ;
  rdfs:label """A relative clause often interrupts after the subject of the main clause at the start
  of the sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.433399Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2702-4
  a curric:KeyLearningPoint ;
  rdfs:label """A pair of commas is used around the relative clause to demarcate it from the main
  clause."""@en ;
  dcterms:modified "2026-06-07T15:30:29.433403Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2700-1
  a curric:KeyLearningPoint ;
  rdfs:label """Any subordinate clause is a group of words that contains a verb and does not make
  complete sense."""@en ;
  dcterms:modified "2026-06-07T15:30:29.433407Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2700-2
  a curric:KeyLearningPoint ;
  rdfs:label "Any subordinate clause must join to a main clause to make sense."@en ;
  dcterms:modified "2026-06-07T15:30:29.433411Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2700-3
  a curric:KeyLearningPoint ;
  rdfs:label """A relative clause is a type of subordinate clause which starts with a relative
  pronoun."""@en ;
  dcterms:modified "2026-06-07T15:30:29.433416Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2700-4
  a curric:KeyLearningPoint ;
  rdfs:label """A previously-learnt type of subordinate clause is the adverbial clause that starts
  with a subordinating conjunction."""@en ;
  dcterms:modified "2026-06-07T15:30:29.433420Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5814-1
  a curric:KeyLearningPoint ;
  rdfs:label "We have planned the structure, content and vocabulary for our narrative."@en ;
  dcterms:modified "2026-06-07T15:30:29.433424Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5814-2
  a curric:KeyLearningPoint ;
  rdfs:label """When we write, we use cohesive devices to connect our plan notes together into
  coherent sentences."""@en ;
  dcterms:modified "2026-06-07T15:30:29.433428Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5814-3
  a curric:KeyLearningPoint ;
  rdfs:label "We can use fronted adverbials of time to add pace to our writing."@en ;
  dcterms:modified "2026-06-07T15:30:29.433432Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5814-4
  a curric:KeyLearningPoint ;
  rdfs:label """We should aim to include all the narrative elements of action, description, dialogue
  and emotions in our writing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.433436Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5814-5
  a curric:KeyLearningPoint ;
  rdfs:label "Oral rehearsal prior to writing helps us to write more easily."@en ;
  dcterms:modified "2026-06-07T15:30:29.433442Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2710-1
  a curric:KeyLearningPoint ;
  rdfs:label """Prepositions tell the reader where or when something is in relation to something
  else."""@en ;
  dcterms:modified "2026-06-07T15:30:29.433447Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2710-2
  a curric:KeyLearningPoint ;
  rdfs:label "Prepositions can indicate time, place or cause."@en ;
  dcterms:modified "2026-06-07T15:30:29.433453Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2710-3
  a curric:KeyLearningPoint ;
  rdfs:label "Prepositions can be single words or groups of words."@en ;
  dcterms:modified "2026-06-07T15:30:29.433457Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2710-4
  a curric:KeyLearningPoint ;
  rdfs:label "A phrase is a group of words with no verb."@en ;
  dcterms:modified "2026-06-07T15:30:29.433462Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8010-1
  a curric:KeyLearningPoint ;
  rdfs:label """Joseph Coelho’s poems are easy to read and engaging, with playful rhythms and
  subjects that young readers can relate to."""@en ;
  dcterms:modified "2026-06-07T15:30:29.433478Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8010-2
  a curric:KeyLearningPoint ;
  rdfs:label "Joseph Coelho often writes poems about his personal experiences."@en ;
  dcterms:modified "2026-06-07T15:30:29.433484Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8010-3
  a curric:KeyLearningPoint ;
  rdfs:label """The poem ‘Miss Flotsam’ is inspired by the teachers Coelho had when growing up and
  those he has met as an adult."""@en ;
  dcterms:modified "2026-06-07T15:30:29.433488Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8010-4
  a curric:KeyLearningPoint ;
  rdfs:label """The poem depicts ‘Miss Flotsam’ as a kind, understanding and caring teacher, who has
  an inclusive approach to teaching."""@en ;
  dcterms:modified "2026-06-07T15:30:29.433492Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8010-5
  a curric:KeyLearningPoint ;
  rdfs:label """Alliteration can be used to emphasise key themes and draw the reader’s attention to
  important parts of a poem."""@en ;
  dcterms:modified "2026-06-07T15:30:29.433496Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6593-1
  a curric:KeyLearningPoint ;
  rdfs:label """In the sections, writers share detailed, specific information about an aspect of the
  person's life with the reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.433645Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6593-2
  a curric:KeyLearningPoint ;
  rdfs:label """Section paragraphs can include a topic sentence, specific information and a linking
  sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.433649Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6593-3
  a curric:KeyLearningPoint ;
  rdfs:label """The introductory sentence indicates what the paragraph will be about and linking
  sentence links onto the next paragraph."""@en ;
  dcterms:modified "2026-06-07T15:30:29.433653Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6593-4
  a curric:KeyLearningPoint ;
  rdfs:label "When planning, we should record ideas in concise, bullet-pointed notes."@en ;
  dcterms:modified "2026-06-07T15:30:29.433657Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6557-1
  a curric:KeyLearningPoint ;
  rdfs:label "Speakers must speak audibly and fluently to communicate meaning clearly."@en ;
  dcterms:modified "2026-06-07T15:30:29.433694Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6557-2
  a curric:KeyLearningPoint ;
  rdfs:label "Speaking in an appropriate register enhances communication."@en ;
  dcterms:modified "2026-06-07T15:30:29.433698Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6557-3
  a curric:KeyLearningPoint ;
  rdfs:label """Text meaning and the reader's emotions can be shown through intonation, tone, volume
  and gestures."""@en ;
  dcterms:modified "2026-06-07T15:30:29.433702Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6557-4
  a curric:KeyLearningPoint ;
  rdfs:label "Facial expressions can be used to convey emotions."@en ;
  dcterms:modified "2026-06-07T15:30:29.433706Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4827-1
  a curric:KeyLearningPoint ;
  rdfs:label "Direct speech is signalled to the reader in text by inverted commas."@en ;
  dcterms:modified "2026-06-07T15:30:29.433852Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4827-2
  a curric:KeyLearningPoint ;
  rdfs:label """Direct speech can be written in a speech first sentence or a speech second
  sentence."""@en ;
  dcterms:modified "2026-06-07T15:30:29.433857Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4827-3
  a curric:KeyLearningPoint ;
  rdfs:label "Direct speech always starts with a capital letter."@en ;
  dcterms:modified "2026-06-07T15:30:29.433861Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4827-4
  a curric:KeyLearningPoint ;
  rdfs:label """After forming a capital letter, you need to lift your pencil to start the next part
  of the word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.433865Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4827-5
  a curric:KeyLearningPoint ;
  rdfs:label "The writing is legible and the letter sizing is consistent."@en ;
  dcterms:modified "2026-06-07T15:30:29.433869Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7676-1
  a curric:KeyLearningPoint ;
  rdfs:label "A subheading signals to the reader what the section is about."@en ;
  dcterms:modified "2026-06-07T15:30:29.433889Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7676-2
  a curric:KeyLearningPoint ;
  rdfs:label """Careful selection of nouns and pronouns ensures cohesion within sentences and across
  sections of the report."""@en ;
  dcterms:modified "2026-06-07T15:30:29.433893Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7676-3
  a curric:KeyLearningPoint ;
  rdfs:label """A section about one feature of the report's subject contains specific facts and
  information to keep the reader engaged."""@en ;
  dcterms:modified "2026-06-07T15:30:29.433897Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7676-4
  a curric:KeyLearningPoint ;
  rdfs:label """Writers choose varied fronted adverbials and different sentence types to ensure the
  text flows for the reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.433905Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7676-5
  a curric:KeyLearningPoint ;
  rdfs:label """Sentences should be said aloud before writing to ensure they make sense and read
  back once written to check for errors."""@en ;
  dcterms:modified "2026-06-07T15:30:29.433910Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3405-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of a conclusion is to summarise the key points in a text, providing
  closure to the subject."""@en ;
  dcterms:modified "2026-06-07T15:30:29.433932Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3405-2
  a curric:KeyLearningPoint ;
  rdfs:label """A summary sentence is the opening sentence of a conclusion and summarises the key
  points in a text."""@en ;
  dcterms:modified "2026-06-07T15:30:29.433936Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3405-3
  a curric:KeyLearningPoint ;
  rdfs:label "A conclusion begins with a formal fronted adverbial."@en ;
  dcterms:modified "2026-06-07T15:30:29.433940Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3405-4
  a curric:KeyLearningPoint ;
  rdfs:label "There are no new facts or information about the subject in the conclusion."@en ;
  dcterms:modified "2026-06-07T15:30:29.433944Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3405-5
  a curric:KeyLearningPoint ;
  rdfs:label """A conclusion finishes with the writer suggesting to the reader how to find out more
  about the subject."""@en ;
  dcterms:modified "2026-06-07T15:30:29.433948Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7866-1
  a curric:KeyLearningPoint ;
  rdfs:label "The Trojans were at war with the Greeks"@en ;
  dcterms:modified "2026-06-07T15:30:29.435342Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7866-2
  a curric:KeyLearningPoint ;
  rdfs:label "Odysseus concoted a plan"@en ;
  dcterms:modified "2026-06-07T15:30:29.435346Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7866-3
  a curric:KeyLearningPoint ;
  rdfs:label "The Greeks built a wooden horse and hid within it"@en ;
  dcterms:modified "2026-06-07T15:30:29.435349Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7866-4
  a curric:KeyLearningPoint ;
  rdfs:label "By the end, the city of Troy belonged to the Greeks"@en ;
  dcterms:modified "2026-06-07T15:30:29.435353Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7866-5
  a curric:KeyLearningPoint ;
  rdfs:label """Retelling a myth helps readers understand the story better, improving
  comprehension"""@en ;
  dcterms:modified "2026-06-07T15:30:29.435357Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1070-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Auspicious' is an adjective which means hopeful or encouraging."@en ;
  dcterms:modified "2026-06-07T15:30:29.435362Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1070-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Sanguine' is an adjective which means optimistic or cheery."@en ;
  dcterms:modified "2026-06-07T15:30:29.435366Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1070-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Idealistic', 'encouraging', 'promising' and 'optimistic' are other adjectives
  associated with hope."""@en ;
  dcterms:modified "2026-06-07T15:30:29.435372Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6546-1
  a curric:KeyLearningPoint ;
  rdfs:label """Understanding where and when a story is set enhances our understanding of characters
  and events."""@en ;
  dcterms:modified "2026-06-07T15:30:29.435377Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6546-2
  a curric:KeyLearningPoint ;
  rdfs:label """Understanding the authorial context enhances our understanding of why authorial
  choices are made."""@en ;
  dcterms:modified "2026-06-07T15:30:29.435381Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6546-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Front Desk' is a fictional story, but the plot of the narrative is based on real
  events from the author's childhood."""@en ;
  dcterms:modified "2026-06-07T15:30:29.435385Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6546-4
  a curric:KeyLearningPoint ;
  rdfs:label "Kelly Yang is the author of ’Front Desk’."@en ;
  dcterms:modified "2026-06-07T15:30:29.435389Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6546-5
  a curric:KeyLearningPoint ;
  rdfs:label "'Front Desk' was published in 2018 and it has won many book awards."@en ;
  dcterms:modified "2026-06-07T15:30:29.435395Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5759-1
  a curric:KeyLearningPoint ;
  rdfs:label """Understanding the context of a text enables readers to engage effectively with the
  content."""@en ;
  dcterms:modified "2026-06-07T15:30:29.435510Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5759-2
  a curric:KeyLearningPoint ;
  rdfs:label "The author is the person who wrote the text."@en ;
  dcterms:modified "2026-06-07T15:30:29.435514Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5759-3
  a curric:KeyLearningPoint ;
  rdfs:label "The illustrator is the person who illustrated the text."@en ;
  dcterms:modified "2026-06-07T15:30:29.435518Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5759-4
  a curric:KeyLearningPoint ;
  rdfs:label """Fiction is literature in the form of prose that describes imaginary events and
  people."""@en ;
  dcterms:modified "2026-06-07T15:30:29.435522Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3449-1
  a curric:KeyLearningPoint ;
  rdfs:label """A fronted adverbial is a sentence starter followed by a comma that expresses time,
  place, manner, cause or contrast."""@en ;
  dcterms:modified "2026-06-07T15:30:29.435589Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3449-2
  a curric:KeyLearningPoint ;
  rdfs:label "A fronted adverbial can be a single word, phrase or clause."@en ;
  dcterms:modified "2026-06-07T15:30:29.435593Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3449-3
  a curric:KeyLearningPoint ;
  rdfs:label "A clause is a group of words that contains a verb."@en ;
  dcterms:modified "2026-06-07T15:30:29.435597Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3449-4
  a curric:KeyLearningPoint ;
  rdfs:label "A phrase is a group of words with no verb."@en ;
  dcterms:modified "2026-06-07T15:30:29.435601Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3449-5
  a curric:KeyLearningPoint ;
  rdfs:label "Varied fronted adverbials are useful to achieve text cohesion."@en ;
  dcterms:modified "2026-06-07T15:30:29.435608Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5749-1
  a curric:KeyLearningPoint ;
  rdfs:label """A non-chronological report is a non-fiction text providing information about a
  particular subject."""@en ;
  dcterms:modified "2026-06-07T15:30:29.435715Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5749-2
  a curric:KeyLearningPoint ;
  rdfs:label """A non-chronological report can be organised into an introduction, paragraphs
  organised by theme and a conclusion."""@en ;
  dcterms:modified "2026-06-07T15:30:29.435720Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5749-3
  a curric:KeyLearningPoint ;
  rdfs:label """Vocabulary within a non-chronological report is subject-specific and factual; the
  language and tone is formal."""@en ;
  dcterms:modified "2026-06-07T15:30:29.435724Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5749-4
  a curric:KeyLearningPoint ;
  rdfs:label """Conjunctions are an important linguistic feature within non-chronological reports in
  order to ensure cohesion."""@en ;
  dcterms:modified "2026-06-07T15:30:29.435728Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5749-5
  a curric:KeyLearningPoint ;
  rdfs:label """A fronted adverbial of cause is a sentence starter that tells the reader the cause
  and effect of something."""@en ;
  dcterms:modified "2026-06-07T15:30:29.435732Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9045-1
  a curric:KeyLearningPoint ;
  rdfs:label """We can analyse a scene in a graphic novel by exploring the visual, narrative and
  contextual elements."""@en ;
  dcterms:modified "2026-06-07T15:30:29.435752Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9045-2
  a curric:KeyLearningPoint ;
  rdfs:label "We can ask questions about scenes to develop our understanding of the text."@en ;
  dcterms:modified "2026-06-07T15:30:29.435756Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9045-3
  a curric:KeyLearningPoint ;
  rdfs:label "One of the most prominent themes in the text is identity."@en ;
  dcterms:modified "2026-06-07T15:30:29.435761Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9045-4
  a curric:KeyLearningPoint ;
  rdfs:label """Marlene’s journey is about understanding and embracing her identity, accepting her
  natural hair as a part of who she is."""@en ;
  dcterms:modified "2026-06-07T15:30:29.435769Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9045-5
  a curric:KeyLearningPoint ;
  rdfs:label """Take-away ideas within a graphic novel may link to themes that are explored and
  developed in it."""@en ;
  dcterms:modified "2026-06-07T15:30:29.435773Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1382-1
  a curric:KeyLearningPoint ;
  rdfs:label """Two or more words that sound the same but have different meanings and spellings are
  called homophones."""@en ;
  dcterms:modified "2026-06-07T15:30:29.435821Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1382-2
  a curric:KeyLearningPoint ;
  rdfs:label """We can use the context of a sentence to figure out the spelling of the
  homophone."""@en ;
  dcterms:modified "2026-06-07T15:30:29.435825Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1382-3
  a curric:KeyLearningPoint ;
  rdfs:label "There are no spelling rules for homophones so we must learn them by sight."@en ;
  dcterms:modified "2026-06-07T15:30:29.435829Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1382-4
  a curric:KeyLearningPoint ;
  rdfs:label "We can look for naughty letters to help us to remember tricky spellings."@en ;
  dcterms:modified "2026-06-07T15:30:29.435833Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1382-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: century, breath and breathe."@en ;
  dcterms:modified "2026-06-07T15:30:29.435837Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8041-1
  a curric:KeyLearningPoint ;
  rdfs:label """Poetry comes in many different forms and can be written by a variety of different
  people."""@en ;
  dcterms:modified "2026-06-07T15:30:29.436196Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8041-2
  a curric:KeyLearningPoint ;
  rdfs:label """Grace Nichols, the author and poet, was born in Guyana in the Caribbean and moved to
  live in the UK in 1977."""@en ;
  dcterms:modified "2026-06-07T15:30:29.436200Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8041-3
  a curric:KeyLearningPoint ;
  rdfs:label "‘Cosmic Disco’ is linked to the science of the stars and the universe."@en ;
  dcterms:modified "2026-06-07T15:30:29.436204Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8041-4
  a curric:KeyLearningPoint ;
  rdfs:label "Poetry can communicate a sense of awe and wonder in the natural world."@en ;
  dcterms:modified "2026-06-07T15:30:29.436208Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8047-1
  a curric:KeyLearningPoint ;
  rdfs:label """A pantoum is a form of poetry, originating in Malaysia; they are characterised by
  their repeating lines."""@en ;
  dcterms:modified "2026-06-07T15:30:29.436212Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8047-2
  a curric:KeyLearningPoint ;
  rdfs:label """The second and fourth lines of one verse are included as the first and third lines
  of the next verse."""@en ;
  dcterms:modified "2026-06-07T15:30:29.436217Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8047-3
  a curric:KeyLearningPoint ;
  rdfs:label """Repeated lines in pantoums can gain new context and meaning as they are combined
  within different verses."""@en ;
  dcterms:modified "2026-06-07T15:30:29.436221Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8047-4
  a curric:KeyLearningPoint ;
  rdfs:label """The first and third lines of the first verse are mirrored in the final verse in the
  second and fourth lines."""@en ;
  dcterms:modified "2026-06-07T15:30:29.436225Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8047-5
  a curric:KeyLearningPoint ;
  rdfs:label "Pupils can make specific language choices to describe the intensity of the rain."@en ;
  dcterms:modified "2026-06-07T15:30:29.436229Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1448-1
  a curric:KeyLearningPoint ;
  rdfs:label """A prefix is a letter or group of letters at the start of a word which creates
  another word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.436437Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1448-2
  a curric:KeyLearningPoint ;
  rdfs:label """un-, non-, dis- and mis- can be added to the beginning of a word without changing
  the spelling of the root word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.436442Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1448-3
  a curric:KeyLearningPoint ;
  rdfs:label "The prefixes un-, non- and dis- usually mean not."@en ;
  dcterms:modified "2026-06-07T15:30:29.436446Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1448-4
  a curric:KeyLearningPoint ;
  rdfs:label "The prefix mis- usually means wrongly."@en ;
  dcterms:modified "2026-06-07T15:30:29.436450Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1448-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum word: question."@en ;
  dcterms:modified "2026-06-07T15:30:29.436454Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28410-1
  a curric:KeyLearningPoint ;
  rdfs:label "A play is a written text that is acted out by actors in a live performance."@en ;
  dcterms:modified "2026-06-07T15:30:29.436458Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28410-2
  a curric:KeyLearningPoint ;
  rdfs:label """Actors, directors and a stage crew work together to prepare and rehearse a play
  ready for performance."""@en ;
  dcterms:modified "2026-06-07T15:30:29.436464Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28410-3
  a curric:KeyLearningPoint ;
  rdfs:label """Play script conventions help the actors and the director bring the dialogue and
  action to life."""@en ;
  dcterms:modified "2026-06-07T15:30:29.436468Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28410-4
  a curric:KeyLearningPoint ;
  rdfs:label """Performance techniques that help actors connect with the audience can be learnt,
  practised and developed."""@en ;
  dcterms:modified "2026-06-07T15:30:29.436472Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27904-1
  a curric:KeyLearningPoint ;
  rdfs:label "Effective presentations are planned in advance."@en ;
  dcterms:modified "2026-06-07T15:30:29.436515Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27904-2
  a curric:KeyLearningPoint ;
  rdfs:label """Part of planning a presentation is organising what you are going to say and in what
  order."""@en ;
  dcterms:modified "2026-06-07T15:30:29.436519Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27904-3
  a curric:KeyLearningPoint ;
  rdfs:label """Vocabulary chosen must be suitable for the presentation's audience and its
  purpose."""@en ;
  dcterms:modified "2026-06-07T15:30:29.436523Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27904-4
  a curric:KeyLearningPoint ;
  rdfs:label "Engaging with an audience involves grabbing their attention and maintaining it."@en ;
  dcterms:modified "2026-06-07T15:30:29.436529Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27904-5
  a curric:KeyLearningPoint ;
  rdfs:label "Presentation skills can be learnt, developed and practised."@en ;
  dcterms:modified "2026-06-07T15:30:29.436534Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6143-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the opening is to engage the reader and introduce the setting and
  characters."""@en ;
  dcterms:modified "2026-06-07T15:30:29.436719Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6143-2
  a curric:KeyLearningPoint ;
  rdfs:label "Precise and ambitious vocabulary is logged on a plan for future use."@en ;
  dcterms:modified "2026-06-07T15:30:29.436723Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6143-3
  a curric:KeyLearningPoint ;
  rdfs:label """Notes should not be written in full sentences and bullet points can be used to make
  notes clear."""@en ;
  dcterms:modified "2026-06-07T15:30:29.436727Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6143-4
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials of time, place and manner indicate when, where and how action
  takes place."""@en ;
  dcterms:modified "2026-06-07T15:30:29.436731Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6143-5
  a curric:KeyLearningPoint ;
  rdfs:label """Ambitious and precise adverbs, adjectives and verbs are used to create a vivid
  picture for the reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.436735Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1066-1
  a curric:KeyLearningPoint ;
  rdfs:label """Notes should not be written in full sentences and bullet points can be used to
  organise notes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.436798Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1066-2
  a curric:KeyLearningPoint ;
  rdfs:label """Viewpoint fronted adverbials and formal fronted adverbials are used at the start of
  sentences for cohesion."""@en ;
  dcterms:modified "2026-06-07T15:30:29.436802Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1066-3
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the artefacts paragraph is to show what tools were made of and how
  they were used in the Stone Age."""@en ;
  dcterms:modified "2026-06-07T15:30:29.436806Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1066-4
  a curric:KeyLearningPoint ;
  rdfs:label "Flint was the stone used to make weapons and tools."@en ;
  dcterms:modified "2026-06-07T15:30:29.436811Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1066-5
  a curric:KeyLearningPoint ;
  rdfs:label """Pots were made of clay and dice, jewellery and combs were made from animal
  bones."""@en ;
  dcterms:modified "2026-06-07T15:30:29.436815Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4856-1
  a curric:KeyLearningPoint ;
  rdfs:label "The closing is the final paragraph of a journalistic report."@en ;
  dcterms:modified "2026-06-07T15:30:29.436948Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4856-2
  a curric:KeyLearningPoint ;
  rdfs:label "The closing summarises what is currently happening and what will happen next."@en ;
  dcterms:modified "2026-06-07T15:30:29.436952Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4856-3
  a curric:KeyLearningPoint ;
  rdfs:label """Reference to present and future events requires us to write correctly in present and
  future tense."""@en ;
  dcterms:modified "2026-06-07T15:30:29.436956Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4856-4
  a curric:KeyLearningPoint ;
  rdfs:label "Using a range of cohesive devices enhances text flow and helps achieve purpose."@en ;
  dcterms:modified "2026-06-07T15:30:29.436960Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4856-5
  a curric:KeyLearningPoint ;
  rdfs:label """Modal verbs are types of auxiliary verbs that show the likelihood of something
  happening."""@en ;
  dcterms:modified "2026-06-07T15:30:29.436965Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4850-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the recount section is to engage the reader and give them specific
  information about what happened."""@en ;
  dcterms:modified "2026-06-07T15:30:29.437047Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4850-2
  a curric:KeyLearningPoint ;
  rdfs:label "An introductory sentence explains what the paragraph is about."@en ;
  dcterms:modified "2026-06-07T15:30:29.437053Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4850-3
  a curric:KeyLearningPoint ;
  rdfs:label """Relative complex sentences and passive voice enable the writer to convey information
  in varied ways."""@en ;
  dcterms:modified "2026-06-07T15:30:29.437057Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4850-4
  a curric:KeyLearningPoint ;
  rdfs:label "Relative clauses begin with the relative pronouns ‘who’ or ‘which’."@en ;
  dcterms:modified "2026-06-07T15:30:29.437062Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4850-5
  a curric:KeyLearningPoint ;
  rdfs:label "Plans should include clear, concise notes."@en ;
  dcterms:modified "2026-06-07T15:30:29.437066Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7659-1
  a curric:KeyLearningPoint ;
  rdfs:label "Direct speech is the term used for a person speaking out loud in a text."@en ;
  dcterms:modified "2026-06-07T15:30:29.437091Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7659-2
  a curric:KeyLearningPoint ;
  rdfs:label """Speech first is punctuated with inverted commas and a comma, question mark or
  exclamation mark."""@en ;
  dcterms:modified "2026-06-07T15:30:29.437096Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7659-3
  a curric:KeyLearningPoint ;
  rdfs:label """Speech second is punctuated with inverted commas and a full stop, question mark or
  exclamation mark."""@en ;
  dcterms:modified "2026-06-07T15:30:29.437100Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7659-4
  a curric:KeyLearningPoint ;
  rdfs:label """Inverted commas are used to demarcate the direct speech from the reporting
  clause."""@en ;
  dcterms:modified "2026-06-07T15:30:29.437104Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7659-5
  a curric:KeyLearningPoint ;
  rdfs:label """A range of synonyms for ‘said’ and use of adverbs can offer detail about how a
  character spoke and felt."""@en ;
  dcterms:modified "2026-06-07T15:30:29.437108Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6724-1
  a curric:KeyLearningPoint ;
  rdfs:label "Beowulf was written by Anglo-Saxons in England about events in Scandinavia."@en ;
  dcterms:modified "2026-06-07T15:30:29.438412Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6724-2
  a curric:KeyLearningPoint ;
  rdfs:label "The story refers to some historical figures, but lots of the story is fictional."@en ;
  dcterms:modified "2026-06-07T15:30:29.438416Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6724-3
  a curric:KeyLearningPoint ;
  rdfs:label """In Anglo-Saxon society, warriors were highly respected. We can see evidence of this
  in 'Beowulf'."""@en ;
  dcterms:modified "2026-06-07T15:30:29.438419Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6724-4
  a curric:KeyLearningPoint ;
  rdfs:label "The overall story focuses on the 'problem' of Beowulf's quest for fame."@en ;
  dcterms:modified "2026-06-07T15:30:29.438424Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6724-5
  a curric:KeyLearningPoint ;
  rdfs:label "The story is made up of three mini-stories, each with their own story structure."@en ;
  dcterms:modified "2026-06-07T15:30:29.438428Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6723-1
  a curric:KeyLearningPoint ;
  rdfs:label "Presenting our ideas orally is a way of showing our understanding of a subject."@en ;
  dcterms:modified "2026-06-07T15:30:29.438432Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6723-2
  a curric:KeyLearningPoint ;
  rdfs:label """Speaking to a group can be stressful; making notes and rehearsing first makes it
  easier."""@en ;
  dcterms:modified "2026-06-07T15:30:29.438436Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6723-3
  a curric:KeyLearningPoint ;
  rdfs:label """We can use fronted adverbials of cause to show causal relationships between steps in
  an explanation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.438442Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6723-4
  a curric:KeyLearningPoint ;
  rdfs:label """When we present, we use clear diction, appropriate volume, positive body language
  and eye contact to engage an audience."""@en ;
  dcterms:modified "2026-06-07T15:30:29.438446Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6723-5
  a curric:KeyLearningPoint ;
  rdfs:label """Darwin's theory of evolution by natural selection can be applied to any animal
  adaptation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.438451Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5486-1
  a curric:KeyLearningPoint ;
  rdfs:label """Skimming and scanning are crucial skills when it comes to quickly retrieving
  information from texts."""@en ;
  dcterms:modified "2026-06-07T15:30:29.438455Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5486-2
  a curric:KeyLearningPoint ;
  rdfs:label "Readers can infer by using clues from within the text to draw conclusions."@en ;
  dcterms:modified "2026-06-07T15:30:29.438459Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5486-3
  a curric:KeyLearningPoint ;
  rdfs:label """Evidence from the text can be used to develop answers to questions and support
  reasoning."""@en ;
  dcterms:modified "2026-06-07T15:30:29.438463Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8897-1
  a curric:KeyLearningPoint ;
  rdfs:label """Characterisation is the way an author describes and develops the personalities and
  traits of the characters in a story"""@en ;
  dcterms:modified "2026-06-07T15:30:29.438467Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8897-2
  a curric:KeyLearningPoint ;
  rdfs:label """Characterisation can be understood by looking at actions, thoughts, dialogue and
  characters' interactions with others"""@en ;
  dcterms:modified "2026-06-07T15:30:29.438471Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8897-3
  a curric:KeyLearningPoint ;
  rdfs:label """Reader's Theatre is an activity where participants read aloud from a script to
  convey part of a story to an audience"""@en ;
  dcterms:modified "2026-06-07T15:30:29.438477Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8897-4
  a curric:KeyLearningPoint ;
  rdfs:label """Reader’s Theatre is a really enjoyable way to read a text aloud and can help develop
  fluency when reading"""@en ;
  dcterms:modified "2026-06-07T15:30:29.438482Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4703-1
  a curric:KeyLearningPoint ;
  rdfs:label "A point of information is a brief attempted interruption of someone’s speech."@en ;
  dcterms:modified "2026-06-07T15:30:29.438486Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4703-2
  a curric:KeyLearningPoint ;
  rdfs:label "A point of information is similar to a rebuttal."@en ;
  dcterms:modified "2026-06-07T15:30:29.438490Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6364-1
  a curric:KeyLearningPoint ;
  rdfs:label """Oral presentation is an important aspect of delivering journalistic reports and
  news."""@en ;
  dcterms:modified "2026-06-07T15:30:29.438494Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6364-2
  a curric:KeyLearningPoint ;
  rdfs:label """Projection, pace and diction are important for ensuring the audience can hear and
  understand you."""@en ;
  dcterms:modified "2026-06-07T15:30:29.438498Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6364-3
  a curric:KeyLearningPoint ;
  rdfs:label """Eye contact, body language and tone are important for connecting to the audience and
  conveying a topic appropriately"""@en ;
  dcterms:modified "2026-06-07T15:30:29.438502Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6364-4
  a curric:KeyLearningPoint ;
  rdfs:label """Reading over our writing and rehearsing it supports the successful delivery of an
  oral presentation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.438507Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7825-1
  a curric:KeyLearningPoint ;
  rdfs:label "Marcy and the Riddle of the Sphinx is a modern myth."@en ;
  dcterms:modified "2026-06-07T15:30:29.438511Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7825-2
  a curric:KeyLearningPoint ;
  rdfs:label "A modern myth incorporates elements from traditional myths."@en ;
  dcterms:modified "2026-06-07T15:30:29.438517Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7825-3
  a curric:KeyLearningPoint ;
  rdfs:label """Some features of a modern myth are mythical creatures, a quest, magical objects and
  gods and godesses."""@en ;
  dcterms:modified "2026-06-07T15:30:29.438523Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7825-4
  a curric:KeyLearningPoint ;
  rdfs:label "Brownstone's Mythical Collection is a collection of modern myths."@en ;
  dcterms:modified "2026-06-07T15:30:29.438528Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7825-5
  a curric:KeyLearningPoint ;
  rdfs:label "Marcy embarks on an adventure and has to overcome a challenge."@en ;
  dcterms:modified "2026-06-07T15:30:29.438532Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27609-1
  a curric:KeyLearningPoint ;
  rdfs:label """Doing rehearsals will help you to reflect on your performance and improve before
  delivering it to an audience."""@en ;
  dcterms:modified "2026-06-07T15:30:29.438536Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27609-2
  a curric:KeyLearningPoint ;
  rdfs:label """Changes in voice, facial expressions and body language are used to tell a story with
  charisma."""@en ;
  dcterms:modified "2026-06-07T15:30:29.438540Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27609-3
  a curric:KeyLearningPoint ;
  rdfs:label """There are general techniques used for any oral presentation to ensure the audience
  can hear you and is engaged."""@en ;
  dcterms:modified "2026-06-07T15:30:29.438546Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27609-4
  a curric:KeyLearningPoint ;
  rdfs:label """How you orally tell a story changes throughout the different sections of a story to
  meet the purpose."""@en ;
  dcterms:modified "2026-06-07T15:30:29.438551Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3459-1
  a curric:KeyLearningPoint ;
  rdfs:label "A colon is a piece of punctuation with more than one purpose."@en ;
  dcterms:modified "2026-06-07T15:30:29.438555Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3459-2
  a curric:KeyLearningPoint ;
  rdfs:label "A colon is always placed after a main clause."@en ;
  dcterms:modified "2026-06-07T15:30:29.438559Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3459-3
  a curric:KeyLearningPoint ;
  rdfs:label "A colon can introduce an explanation of the noun preceding it."@en ;
  dcterms:modified "2026-06-07T15:30:29.438563Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3459-4
  a curric:KeyLearningPoint ;
  rdfs:label "A colon can help to improve text cohesion."@en ;
  dcterms:modified "2026-06-07T15:30:29.438567Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1094-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Affluent' is an adjective which means rich or wealthy."@en ;
  dcterms:modified "2026-06-07T15:30:29.438571Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1094-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Diverse' is an adjective which means mixed or various."@en ;
  dcterms:modified "2026-06-07T15:30:29.438575Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1094-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Imposing' is an adjective which means grand or impressive."@en ;
  dcterms:modified "2026-06-07T15:30:29.438579Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1094-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Hectic', 'bustling' and 'polluted' are other rich vocabulary associated with the
  city."""@en ;
  dcterms:modified "2026-06-07T15:30:29.438583Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1053-1
  a curric:KeyLearningPoint ;
  rdfs:label "An apostrophe is an important piece of punctuation."@en ;
  dcterms:modified "2026-06-07T15:30:29.438587Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1053-2
  a curric:KeyLearningPoint ;
  rdfs:label "An apostrophe has more than one purpose."@en ;
  dcterms:modified "2026-06-07T15:30:29.438591Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1053-3
  a curric:KeyLearningPoint ;
  rdfs:label "An apostrophe can show if a noun belongs to another plural noun."@en ;
  dcterms:modified "2026-06-07T15:30:29.438596Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1053-4
  a curric:KeyLearningPoint ;
  rdfs:label "Apostrophes for plural possession are useful to make our meaning clear."@en ;
  dcterms:modified "2026-06-07T15:30:29.438602Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1053-5
  a curric:KeyLearningPoint ;
  rdfs:label "An apostrophe sits at the same height as the ascender of a letter."@en ;
  dcterms:modified "2026-06-07T15:30:29.438606Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6215-1
  a curric:KeyLearningPoint ;
  rdfs:label """Essays can either examine both sides of an issue in a balanced way, or they can
  argue persuasively on one side only."""@en ;
  dcterms:modified "2026-06-07T15:30:29.438610Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6215-2
  a curric:KeyLearningPoint ;
  rdfs:label "Essays include subject-specific language and they are written in formal tone."@en ;
  dcterms:modified "2026-06-07T15:30:29.438614Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6215-3
  a curric:KeyLearningPoint ;
  rdfs:label "A one-sided essay presents a logical argument that reveals a series of points."@en ;
  dcterms:modified "2026-06-07T15:30:29.438620Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6215-4
  a curric:KeyLearningPoint ;
  rdfs:label """Points made within essays must be explained and backed up by evidence in order to be
  effective."""@en ;
  dcterms:modified "2026-06-07T15:30:29.438625Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6215-5
  a curric:KeyLearningPoint ;
  rdfs:label """A range of fronted adverbials, sentence types and parenthesis in brackets are
  linguistic features of essays."""@en ;
  dcterms:modified "2026-06-07T15:30:29.438629Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1068-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of a conclusion is to summarise the information of the text for the
  reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.438633Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1068-2
  a curric:KeyLearningPoint ;
  rdfs:label "A summary sentence summarises the key information from the text."@en ;
  dcterms:modified "2026-06-07T15:30:29.438637Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1068-3
  a curric:KeyLearningPoint ;
  rdfs:label "A conclusion can begin with a formal fronted adverbial."@en ;
  dcterms:modified "2026-06-07T15:30:29.438641Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1068-4
  a curric:KeyLearningPoint ;
  rdfs:label "No new information about the subject is given to the reader in the conclusion."@en ;
  dcterms:modified "2026-06-07T15:30:29.438645Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1068-5
  a curric:KeyLearningPoint ;
  rdfs:label """A conclusion finishes with the writer suggesting to the reader how to find
  out more."""@en ;
  dcterms:modified "2026-06-07T15:30:29.438649Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5817-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘The Viewer’ is a narrative fiction story with elements of mystery and supernatural
  fantasy."""@en ;
  dcterms:modified "2026-06-07T15:30:29.438653Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5817-2
  a curric:KeyLearningPoint ;
  rdfs:label "The setting in the opening is a ‘dump’ in the city."@en ;
  dcterms:modified "2026-06-07T15:30:29.438660Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5817-3
  a curric:KeyLearningPoint ;
  rdfs:label "The story features a magical object that is found at the dump."@en ;
  dcterms:modified "2026-06-07T15:30:29.438664Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5817-4
  a curric:KeyLearningPoint ;
  rdfs:label "The distinctive illustrations play an important part in telling the story."@en ;
  dcterms:modified "2026-06-07T15:30:29.438668Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5817-5
  a curric:KeyLearningPoint ;
  rdfs:label "The story ends in an unusual and mysterious way."@en ;
  dcterms:modified "2026-06-07T15:30:29.438672Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1105-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Searing' is an adjective which means burning or scorching."@en ;
  dcterms:modified "2026-06-07T15:30:29.584389Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1105-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Stifling' is an adjective which means smothering or suffocating."@en ;
  dcterms:modified "2026-06-07T15:30:29.584394Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1105-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Sweltering' is an adjective which means very hot or baking."@en ;
  dcterms:modified "2026-06-07T15:30:29.584412Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7632-1
  a curric:KeyLearningPoint ;
  rdfs:label """A simile describes something by comparing it to something else to make the
  description more vivid."""@en ;
  dcterms:modified "2026-06-07T15:30:29.584418Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7632-2
  a curric:KeyLearningPoint ;
  rdfs:label "Personification gives human characteristics to something non-human."@en ;
  dcterms:modified "2026-06-07T15:30:29.584423Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7632-3
  a curric:KeyLearningPoint ;
  rdfs:label "Using a variety of sentence types in descriptive writing engages the reader."@en ;
  dcterms:modified "2026-06-07T15:30:29.584428Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1033-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the section is to inform the reader of a Portia spider's hunting
  style and diet."""@en ;
  dcterms:modified "2026-06-07T15:30:29.584433Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1033-2
  a curric:KeyLearningPoint ;
  rdfs:label """Portia spiders hunt in two ways: abseiling and attacking their prey and plucking the
  web to imitate a trapped spider."""@en ;
  dcterms:modified "2026-06-07T15:30:29.584438Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1033-3
  a curric:KeyLearningPoint ;
  rdfs:label """Precise, factual verbs are needed to accurately describe the way the spider hunts
  its prey."""@en ;
  dcterms:modified "2026-06-07T15:30:29.584443Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1033-4
  a curric:KeyLearningPoint ;
  rdfs:label """Notes are taken out of full sentences and they capture the most important facts for
  writing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.584448Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1033-5
  a curric:KeyLearningPoint ;
  rdfs:label "A subheading is useful to organise notes in a plan."@en ;
  dcterms:modified "2026-06-07T15:30:29.584453Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1029-1
  a curric:KeyLearningPoint ;
  rdfs:label "Linguistic features are structures of language that use words."@en ;
  dcterms:modified "2026-06-07T15:30:29.584458Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1029-2
  a curric:KeyLearningPoint ;
  rdfs:label "Subject-specific vocabulary is used in a non-chronological report."@en ;
  dcterms:modified "2026-06-07T15:30:29.584463Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1029-3
  a curric:KeyLearningPoint ;
  rdfs:label "Expanded noun phrases list two adjectives that describe a noun."@en ;
  dcterms:modified "2026-06-07T15:30:29.584468Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1029-4
  a curric:KeyLearningPoint ;
  rdfs:label """There are different types of fronted adverbials that do different things for the
  reader."""@en ;
  dcterms:modified "2026-06-07T15:30:29.584473Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1029-5
  a curric:KeyLearningPoint ;
  rdfs:label "Language in a non-chronological report is formal and factual."@en ;
  dcterms:modified "2026-06-07T15:30:29.584478Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8473-1
  a curric:KeyLearningPoint ;
  rdfs:label """In part two of the build-up, humanity responds angrily to the Iron Man by trapping
  and burying him."""@en ;
  dcterms:modified "2026-06-07T15:30:29.584483Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8473-2
  a curric:KeyLearningPoint ;
  rdfs:label """There is a contrast between how the farmers and Hogarth feel after the Iron Man is
  buried."""@en ;
  dcterms:modified "2026-06-07T15:30:29.584488Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8473-3
  a curric:KeyLearningPoint ;
  rdfs:label "The use of precise and ambitious vocabulary supports the building of suspense."@en ;
  dcterms:modified "2026-06-07T15:30:29.584493Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8473-4
  a curric:KeyLearningPoint ;
  rdfs:label """‘Show and tell’ can be used to convey emotions and how these intensify and
  shift."""@en ;
  dcterms:modified "2026-06-07T15:30:29.584501Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8473-5
  a curric:KeyLearningPoint ;
  rdfs:label """Using a range of sentence types supports text flow and helps achieve the text’s
  purpose."""@en ;
  dcterms:modified "2026-06-07T15:30:29.584510Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6353-1
  a curric:KeyLearningPoint ;
  rdfs:label "Writing is most successful when structure, content and vocabulary are planned."@en ;
  dcterms:modified "2026-06-07T15:30:29.584528Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6353-2
  a curric:KeyLearningPoint ;
  rdfs:label """The conclusion should use a range of persuasive techniques to drive home the point
  of the letter."""@en ;
  dcterms:modified "2026-06-07T15:30:29.584533Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6353-3
  a curric:KeyLearningPoint ;
  rdfs:label "Within the paragraph, ideas are connected using cohesive devices."@en ;
  dcterms:modified "2026-06-07T15:30:29.584540Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6353-4
  a curric:KeyLearningPoint ;
  rdfs:label "A formal letter finishes with a sign-off from the writer."@en ;
  dcterms:modified "2026-06-07T15:30:29.584546Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6007-1
  a curric:KeyLearningPoint ;
  rdfs:label "A formal letter should be written using a formal tone."@en ;
  dcterms:modified "2026-06-07T15:30:29.584572Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6007-2
  a curric:KeyLearningPoint ;
  rdfs:label "A formal letter has specific layout features."@en ;
  dcterms:modified "2026-06-07T15:30:29.584576Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6007-3
  a curric:KeyLearningPoint ;
  rdfs:label """An introduction contains three sentences: one introductory, one setting-up the
  argument & one sharing the purpose."""@en ;
  dcterms:modified "2026-06-07T15:30:29.584581Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8042-1
  a curric:KeyLearningPoint ;
  rdfs:label """Poets can use a range of poetic devices to enhance the meaning or impact of their
  poems."""@en ;
  dcterms:modified "2026-06-07T15:30:29.584617Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8042-2
  a curric:KeyLearningPoint ;
  rdfs:label "Personification is describing a non-living thing as if it is a person."@en ;
  dcterms:modified "2026-06-07T15:30:29.584622Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8042-3
  a curric:KeyLearningPoint ;
  rdfs:label """Imagery is the use of language to create a mental picture or sensory experience for
  the reader or listener."""@en ;
  dcterms:modified "2026-06-07T15:30:29.584627Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8042-4
  a curric:KeyLearningPoint ;
  rdfs:label """Alliteration is when words that begin with the same sound are placed close
  together."""@en ;
  dcterms:modified "2026-06-07T15:30:29.584632Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1338-1
  a curric:KeyLearningPoint ;
  rdfs:label "If the root word ends in 'tion', use the suffix -tious."@en ;
  dcterms:modified "2026-06-07T15:30:29.584637Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1338-2
  a curric:KeyLearningPoint ;
  rdfs:label "Exceptions or harder root words include: fictitious."@en ;
  dcterms:modified "2026-06-07T15:30:29.584642Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1338-3
  a curric:KeyLearningPoint ;
  rdfs:label "The suffix -tious generally turns a noun into an adjective."@en ;
  dcterms:modified "2026-06-07T15:30:29.584647Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1338-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: conscious and embarrass"@en ;
  dcterms:modified "2026-06-07T15:30:29.584652Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1325-1
  a curric:KeyLearningPoint ;
  rdfs:label """Two or more words that sound the same but have different meanings or spellings are
  called homophones."""@en ;
  dcterms:modified "2026-06-07T15:30:29.584657Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1325-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Whose' and 'who's' are homophones."@en ;
  dcterms:modified "2026-06-07T15:30:29.584662Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1325-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Stationary' and 'stationery' are homophones."@en ;
  dcterms:modified "2026-06-07T15:30:29.584667Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1325-4
  a curric:KeyLearningPoint ;
  rdfs:label "We can look for naughty letters to help us to remember tricky spellings."@en ;
  dcterms:modified "2026-06-07T15:30:29.584672Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1325-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: according and individual."@en ;
  dcterms:modified "2026-06-07T15:30:29.584677Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6760-1
  a curric:KeyLearningPoint ;
  rdfs:label "Information can be gathered from a range of different sources."@en ;
  dcterms:modified "2026-06-07T15:30:29.585162Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6760-2
  a curric:KeyLearningPoint ;
  rdfs:label "The Prophet Muhammad was the founding prophet of Islam."@en ;
  dcterms:modified "2026-06-07T15:30:29.585167Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6760-3
  a curric:KeyLearningPoint ;
  rdfs:label "Early Islamic civilisation emerged in the 7th century CE."@en ;
  dcterms:modified "2026-06-07T15:30:29.585172Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6760-4
  a curric:KeyLearningPoint ;
  rdfs:label """Early Islamic civilisation had and still has a profound effect on many areas of
  society across the world."""@en ;
  dcterms:modified "2026-06-07T15:30:29.585177Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6760-5
  a curric:KeyLearningPoint ;
  rdfs:label """Understanding the chronology of a time period enables us to understand it in greater
  depth."""@en ;
  dcterms:modified "2026-06-07T15:30:29.585182Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4832-1
  a curric:KeyLearningPoint ;
  rdfs:label "The quotation is demarcated with inverted commas."@en ;
  dcterms:modified "2026-06-07T15:30:29.585191Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4832-2
  a curric:KeyLearningPoint ;
  rdfs:label "The quotation starts with a capital letter."@en ;
  dcterms:modified "2026-06-07T15:30:29.585197Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4832-3
  a curric:KeyLearningPoint ;
  rdfs:label """After forming a capital letter, you need to lift your pencil to start the next part
  of the word."""@en ;
  dcterms:modified "2026-06-07T15:30:29.585202Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4832-4
  a curric:KeyLearningPoint ;
  rdfs:label "The letter spacing and letter sizing is consistent so the writing is legible."@en ;
  dcterms:modified "2026-06-07T15:30:29.585207Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4832-5
  a curric:KeyLearningPoint ;
  rdfs:label """A range of joins will be used depending on which letters are joining to which
  letters."""@en ;
  dcterms:modified "2026-06-07T15:30:29.585212Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1396-1
  a curric:KeyLearningPoint ;
  rdfs:label """A prefix is a letter or group of letters at the start of a word which changes its
  meaning."""@en ;
  dcterms:modified "2026-06-07T15:30:29.585327Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1396-2
  a curric:KeyLearningPoint ;
  rdfs:label "The prefix de- can mean ‘undo’ and re- can mean ‘again’."@en ;
  dcterms:modified "2026-06-07T15:30:29.585332Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1396-3
  a curric:KeyLearningPoint ;
  rdfs:label """The prefix sub- can mean ‘under’ or ‘nearly’ and super- can mean ‘above’ or
  ‘larger’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.585337Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1396-4
  a curric:KeyLearningPoint ;
  rdfs:label """The prefix inter- can mean ‘between’, anti- mean ‘against’ and auto- mean ‘self’ or
  ‘own’."""@en ;
  dcterms:modified "2026-06-07T15:30:29.585342Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1396-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: opposite, average, interrupt and lightning."@en ;
  dcterms:modified "2026-06-07T15:30:29.585347Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27891-1
  a curric:KeyLearningPoint ;
  rdfs:label "A debate is a structured argument between two teams."@en ;
  dcterms:modified "2026-06-07T15:30:29.585352Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27891-2
  a curric:KeyLearningPoint ;
  rdfs:label "An opinion is a view or belief that a person has."@en ;
  dcterms:modified "2026-06-07T15:30:29.585357Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27891-3
  a curric:KeyLearningPoint ;
  rdfs:label "An important aspect of debating is justifying opinions."@en ;
  dcterms:modified "2026-06-07T15:30:29.585365Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27891-4
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to speak in a loud, clear voice, make eye contact with the audience
  and stand up straight."""@en ;
  dcterms:modified "2026-06-07T15:30:29.585371Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8898-1
  a curric:KeyLearningPoint ;
  rdfs:label """Hiccup’s character goes on a transformation throughout the text; he begins the text
  as an unlikely hero"""@en ;
  dcterms:modified "2026-06-07T15:30:29.585376Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8898-2
  a curric:KeyLearningPoint ;
  rdfs:label """Hiccup’s characterisation does not remain fixed; by the end of the text he
  demonstrates many heroic qualities"""@en ;
  dcterms:modified "2026-06-07T15:30:29.585384Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8898-3
  a curric:KeyLearningPoint ;
  rdfs:label "A theme is a big idea, topic or message that recurs within a story"@en ;
  dcterms:modified "2026-06-07T15:30:29.585389Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8898-4
  a curric:KeyLearningPoint ;
  rdfs:label """Themes can leave us with ideas and questions that we reflect on after reading the
  text"""@en ;
  dcterms:modified "2026-06-07T15:30:29.585394Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1357-1
  a curric:KeyLearningPoint ;
  rdfs:label """A hyphen can be used to join a modifier to an adjective to make one adjective, e.g.
  well-dressed."""@en ;
  dcterms:modified "2026-06-07T15:30:29.585399Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1357-2
  a curric:KeyLearningPoint ;
  rdfs:label """A hyphen can be used to join two or more words that are functioning as one
  adjective."""@en ;
  dcterms:modified "2026-06-07T15:30:29.585404Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1357-3
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: familiar and opportunity."@en ;
  dcterms:modified "2026-06-07T15:30:29.585409Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3458-1
  a curric:KeyLearningPoint ;
  rdfs:label "A colon is a piece of punctuation with more than one purpose."@en ;
  dcterms:modified "2026-06-07T15:30:29.585424Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3458-2
  a curric:KeyLearningPoint ;
  rdfs:label "A colon is always placed after a main clause."@en ;
  dcterms:modified "2026-06-07T15:30:29.585429Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3458-3
  a curric:KeyLearningPoint ;
  rdfs:label "A colon can introduce a list or a question."@en ;
  dcterms:modified "2026-06-07T15:30:29.585434Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3458-4
  a curric:KeyLearningPoint ;
  rdfs:label "A colon can help to improve text cohesion."@en ;
  dcterms:modified "2026-06-07T15:30:29.585444Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6518-1
  a curric:KeyLearningPoint ;
  rdfs:label """The passengers of the Empire Windrush were seeking better job opportunities and a
  new life in Britain."""@en ;
  dcterms:modified "2026-06-07T15:30:29.585497Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6518-2
  a curric:KeyLearningPoint ;
  rdfs:label """Windrush passengers were mostly men, many of whom had served in the British Armed
  Forces during the Second World War."""@en ;
  dcterms:modified "2026-06-07T15:30:29.585502Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6518-3
  a curric:KeyLearningPoint ;
  rdfs:label """Some Britons welcomed the Windrush Generation as a much-needed source of labour
  while others opposed their arrival."""@en ;
  dcterms:modified "2026-06-07T15:30:29.585507Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6518-4
  a curric:KeyLearningPoint ;
  rdfs:label """The 1958 Notting Hill Race Riots damaged trust between the Afro-Caribbean community
  and the British establishment."""@en ;
  dcterms:modified "2026-06-07T15:30:29.585512Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6518-5
  a curric:KeyLearningPoint ;
  rdfs:label """Despite the significant challenges they faced, the Windrush Generation made
  extensive contributions to British society."""@en ;
  dcterms:modified "2026-06-07T15:30:29.585517Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3455-1
  a curric:KeyLearningPoint ;
  rdfs:label "There are different tenses and ways of forming verbs in English."@en ;
  dcterms:modified "2026-06-07T15:30:29.585522Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3455-2
  a curric:KeyLearningPoint ;
  rdfs:label "In the passive voice, the verb is 'done to' the subject."@en ;
  dcterms:modified "2026-06-07T15:30:29.585527Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3455-3
  a curric:KeyLearningPoint ;
  rdfs:label """The passive voice allows the speaker or writer to sound more detached from the
  sentence content than the active voice."""@en ;
  dcterms:modified "2026-06-07T15:30:29.585534Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3455-4
  a curric:KeyLearningPoint ;
  rdfs:label """The active voice is the most frequently heard, spoken and written voice in
  English."""@en ;
  dcterms:modified "2026-06-07T15:30:29.585539Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3455-5
  a curric:KeyLearningPoint ;
  rdfs:label """A clause in the passive voice contains two verbs: an auxiliary verb from the
  infinitive 'to be' and the past participle."""@en ;
  dcterms:modified "2026-06-07T15:30:29.585544Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1308-1
  a curric:KeyLearningPoint ;
  rdfs:label "The suffix -ify often turns adjectives and nouns into verbs."@en ;
  dcterms:modified "2026-06-07T15:30:29.585549Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1308-2
  a curric:KeyLearningPoint ;
  rdfs:label "When the root word ends in a consonant, we often just add the suffix."@en ;
  dcterms:modified "2026-06-07T15:30:29.585554Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1308-3
  a curric:KeyLearningPoint ;
  rdfs:label """When the root word ends in a vowel, we remove the final vowel and add the
  suffix."""@en ;
  dcterms:modified "2026-06-07T15:30:29.585559Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1308-4
  a curric:KeyLearningPoint ;
  rdfs:label "When the root word ends in a ‘y’, we remove the ‘y’ and add the suffix."@en ;
  dcterms:modified "2026-06-07T15:30:29.585564Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1308-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: mention, position and early."@en ;
  dcterms:modified "2026-06-07T15:30:29.585569Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1113-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Lashing' is an adjective which means thrashing or beating."@en ;
  dcterms:modified "2026-06-07T15:30:29.585576Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1113-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Tempestuous' is an adjective which means stormy, wild or violent."@en ;
  dcterms:modified "2026-06-07T15:30:29.585581Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1113-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Torrential' is an adjective which means falling heavily or forcefully."@en ;
  dcterms:modified "2026-06-07T15:30:29.585586Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7920-1
  a curric:KeyLearningPoint ;
  rdfs:label "'When the Sky Falls' is set in 1941, during the Second World War."@en ;
  dcterms:modified "2026-06-07T15:30:29.585591Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7920-2
  a curric:KeyLearningPoint ;
  rdfs:label "A 12-year-old boy, Joseph Palmer, is sent from rural Yorkshire to the city."@en ;
  dcterms:modified "2026-06-07T15:30:29.585596Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7920-3
  a curric:KeyLearningPoint ;
  rdfs:label "Joseph finds himself in the care of Margaret Farrelly (Mrs F)."@en ;
  dcterms:modified "2026-06-07T15:30:29.585601Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7920-4
  a curric:KeyLearningPoint ;
  rdfs:label """The narrative has historical details that are interwoven into the fictional
  narrative."""@en ;
  dcterms:modified "2026-06-07T15:30:29.585606Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7920-5
  a curric:KeyLearningPoint ;
  rdfs:label "Joseph and Mrs F are both characterised as hostile or cold initially."@en ;
  dcterms:modified "2026-06-07T15:30:29.585613Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7927-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Coming to England' is an autobiographical memoir, written by Floella Benjamin."@en ;
  dcterms:modified "2026-06-07T15:30:29.586339Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7927-2
  a curric:KeyLearningPoint ;
  rdfs:label """Floella writes about her early childhood in Trinidad in an overwhelmingly positive
  tone."""@en ;
  dcterms:modified "2026-06-07T15:30:29.586360Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7927-3
  a curric:KeyLearningPoint ;
  rdfs:label """Floella has good relationships with both her parents; she describes them through
  actions that they perform."""@en ;
  dcterms:modified "2026-06-07T15:30:29.586365Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7927-4
  a curric:KeyLearningPoint ;
  rdfs:label "Floella has five siblings: Sandra, Lester, Ellington, Roy and Cynthia."@en ;
  dcterms:modified "2026-06-07T15:30:29.586370Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4819-1
  a curric:KeyLearningPoint ;
  rdfs:label "The /shun/ suffix can be spelt -tion, -sion, -ssion or -cian."@en ;
  dcterms:modified "2026-06-07T15:30:29.586375Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4819-2
  a curric:KeyLearningPoint ;
  rdfs:label "The words start with a lead in on the line and finish with a lead out."@en ;
  dcterms:modified "2026-06-07T15:30:29.586379Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4819-3
  a curric:KeyLearningPoint ;
  rdfs:label "The cursive letter join used depends on which letter is joining to which letter."@en ;
  dcterms:modified "2026-06-07T15:30:29.586384Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4819-4
  a curric:KeyLearningPoint ;
  rdfs:label "You don't lift your pencil when forming the joins."@en ;
  dcterms:modified "2026-06-07T15:30:29.586389Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4819-5
  a curric:KeyLearningPoint ;
  rdfs:label """You only lift your pencil once the letter string is complete or there is a break
  letter within the letter string."""@en ;
  dcterms:modified "2026-06-07T15:30:29.586394Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7679-1
  a curric:KeyLearningPoint ;
  rdfs:label "Editing is the process of making changes to improve writing."@en ;
  dcterms:modified "2026-06-07T15:30:29.586401Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7679-2
  a curric:KeyLearningPoint ;
  rdfs:label """When editing punctuation, missing or incorrect punctuation, like capital letters,
  full stops and commas, is checked."""@en ;
  dcterms:modified "2026-06-07T15:30:29.586408Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7679-3
  a curric:KeyLearningPoint ;
  rdfs:label """When editing sentence structure, the flow of sentences and the variety of sentence
  types used are checked."""@en ;
  dcterms:modified "2026-06-07T15:30:29.586413Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7679-4
  a curric:KeyLearningPoint ;
  rdfs:label """When editing language, word and phrase choices are checked to ensure they meet the
  tone required."""@en ;
  dcterms:modified "2026-06-07T15:30:29.586418Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7352-1
  a curric:KeyLearningPoint ;
  rdfs:label """The second paragraph of the build-up heightens the suspense and reveals the Ghost of
  Jacob Marley."""@en ;
  dcterms:modified "2026-06-07T15:30:29.586423Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7352-2
  a curric:KeyLearningPoint ;
  rdfs:label """Precise vocabulary is used to describe sensory details and ‘show and tell’ conveys
  Scrooge’s emotions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.586427Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7352-3
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials of time, place and manner add greater detail to the main clause
  and support in building suspense."""@en ;
  dcterms:modified "2026-06-07T15:30:29.586432Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7352-4
  a curric:KeyLearningPoint ;
  rdfs:label """Marley informs Scrooge of the visits he will be paid by the Ghosts of Christmas
  Past, Present and Future."""@en ;
  dcterms:modified "2026-06-07T15:30:29.586437Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7352-5
  a curric:KeyLearningPoint ;
  rdfs:label """Reported speech is used to share the important messages Marley conveys without
  quoting him directly."""@en ;
  dcterms:modified "2026-06-07T15:30:29.586441Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8017-1
  a curric:KeyLearningPoint ;
  rdfs:label """Joseph Coelho’s poem 'I Am A Writer’ uses metaphors to compare the process of being
  a writer to many other things."""@en ;
  dcterms:modified "2026-06-07T15:30:29.586584Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8017-2
  a curric:KeyLearningPoint ;
  rdfs:label "The poem explores the themes of creativity, imagination and identity."@en ;
  dcterms:modified "2026-06-07T15:30:29.586590Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8017-3
  a curric:KeyLearningPoint ;
  rdfs:label """A metaphor is a way of describing and comparing something by saying that it is
  something else."""@en ;
  dcterms:modified "2026-06-07T15:30:29.586594Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8017-4
  a curric:KeyLearningPoint ;
  rdfs:label """Imagery is the use of language to create a mental picture or sensory experience for
  the reader or listener."""@en ;
  dcterms:modified "2026-06-07T15:30:29.586601Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8031-1
  a curric:KeyLearningPoint ;
  rdfs:label "John Lyons is an English painter, writer and award-winning poet."@en ;
  dcterms:modified "2026-06-07T15:30:29.586745Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8031-2
  a curric:KeyLearningPoint ;
  rdfs:label "John Lyons was born and brought up in Trinidad and Tobago."@en ;
  dcterms:modified "2026-06-07T15:30:29.586750Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8031-3
  a curric:KeyLearningPoint ;
  rdfs:label "A poet is the name for someone who writes poems."@en ;
  dcterms:modified "2026-06-07T15:30:29.586755Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8031-4
  a curric:KeyLearningPoint ;
  rdfs:label "John Lyons has published eight poetry collections."@en ;
  dcterms:modified "2026-06-07T15:30:29.586762Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8067-1
  a curric:KeyLearningPoint ;
  rdfs:label "‘You Are’ and ‘Mum Says She Loves Me’ are both poems written by Valerie Bloom."@en ;
  dcterms:modified "2026-06-07T15:30:29.593657Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8067-2
  a curric:KeyLearningPoint ;
  rdfs:label """Metaphors are used in the poem ‘You Are’; they are a way of comparing something by
  saying that it is something else."""@en ;
  dcterms:modified "2026-06-07T15:30:29.593661Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8067-3
  a curric:KeyLearningPoint ;
  rdfs:label """‘Mum Says She Loves Me’ is a poem that offers a different perspective on the theme
  of love."""@en ;
  dcterms:modified "2026-06-07T15:30:29.593665Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8067-4
  a curric:KeyLearningPoint ;
  rdfs:label """One way we can reflect on a poem and its themes is to think about our own personal
  response to it."""@en ;
  dcterms:modified "2026-06-07T15:30:29.593672Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8070-1
  a curric:KeyLearningPoint ;
  rdfs:label """'The Wall' uses symbolism - the use of objects, images, or actions that represent
  ideas beyond their literal meaning."""@en ;
  dcterms:modified "2026-06-07T15:30:29.602156Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8070-2
  a curric:KeyLearningPoint ;
  rdfs:label """The wall in the poem can represent a physical isolation as well as an
  emotional one."""@en ;
  dcterms:modified "2026-06-07T15:30:29.602161Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8070-3
  a curric:KeyLearningPoint ;
  rdfs:label """A poem can have several meanings and interpretations; each person’s response can be
  different and unique to them."""@en ;
  dcterms:modified "2026-06-07T15:30:29.602167Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8070-4
  a curric:KeyLearningPoint ;
  rdfs:label "We can respond to a poem by writing a personal response to it."@en ;
  dcterms:modified "2026-06-07T15:30:29.602171Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8068-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘My Heart is a Volcano’ is split into three verses with four lines in each; each
  verse follows an ABCB rhyme scheme."""@en ;
  dcterms:modified "2026-06-07T15:30:29.606548Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8068-2
  a curric:KeyLearningPoint ;
  rdfs:label """Through the use of metaphors, the poem conveys the atmosphere as it follows the
  speaker's emotional journey."""@en ;
  dcterms:modified "2026-06-07T15:30:29.606552Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8068-3
  a curric:KeyLearningPoint ;
  rdfs:label """Understanding a poem, its language, imagery and the impression it creates will help
  create an impactful performance."""@en ;
  dcterms:modified "2026-06-07T15:30:29.606557Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8068-4
  a curric:KeyLearningPoint ;
  rdfs:label """Performances can be improved by considering the rhythm and flow of the poem, use of
  voice, gestures and body language."""@en ;
  dcterms:modified "2026-06-07T15:30:29.606561Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8071-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Forest' and 'The Colours of My Dreams' both have themes of belonging and hope."@en ;
  dcterms:modified "2026-06-07T15:30:29.615826Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8071-2
  a curric:KeyLearningPoint ;
  rdfs:label """‘Forest’ is a winter poem which focuses on themes of hope and belonging for a group
  of travellers making a journey."""@en ;
  dcterms:modified "2026-06-07T15:30:29.615831Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8071-3
  a curric:KeyLearningPoint ;
  rdfs:label """The poem ‘The Colours of My Dreams’ includes vivid imagery linked to the five
  senses."""@en ;
  dcterms:modified "2026-06-07T15:30:29.615835Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8071-4
  a curric:KeyLearningPoint ;
  rdfs:label "Poetry is open to interpretation; it does not always offer answers."@en ;
  dcterms:modified "2026-06-07T15:30:29.615839Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8069-1
  a curric:KeyLearningPoint ;
  rdfs:label "‘I Opened the Door’ is inspired by another poem."@en ;
  dcterms:modified "2026-06-07T15:30:29.615880Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8069-2
  a curric:KeyLearningPoint ;
  rdfs:label """When a poem is heavily influenced by another poem, it's acknowledged with the word
  'after' and the original poet's name."""@en ;
  dcterms:modified "2026-06-07T15:30:29.615885Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8069-3
  a curric:KeyLearningPoint ;
  rdfs:label """The poem that inspired ‘I Opened the Door’ is called ‘A Poison Tree’, which was
  written by William Blake."""@en ;
  dcterms:modified "2026-06-07T15:30:29.615889Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8069-4
  a curric:KeyLearningPoint ;
  rdfs:label "We can compare and contrast poems based on many different aspects."@en ;
  dcterms:modified "2026-06-07T15:30:29.615897Z"^^xsd:dateTime .

# ----------------------------------------------------------------------
# Pupil Lesson Outcomes
# ----------------------------------------------------------------------

oakcurric:pupillessonoutcome-lesson-1306
  a curric:PupilLessonOutcome ;
  rdfs:label "I can turn adjectives and nouns into verbs using the suffix -ate."@en ;
  dcterms:modified "2026-06-07T15:30:41.063226Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-2726
  a curric:PupilLessonOutcome ;
  rdfs:label """I can edit my own and my peer's opening paragraph of a narrative based on
  ‘Jabberwocky'."""@en ;
  dcterms:modified "2026-06-07T15:30:41.063239Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-6380
  a curric:PupilLessonOutcome ;
  rdfs:label "I can edit the speech section of my narrative writing."@en ;
  dcterms:modified "2026-06-07T15:30:41.063243Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-8635
  a curric:PupilLessonOutcome ;
  rdfs:label "I can understand the setting and characters in ‘The Borrowers’."@en ;
  dcterms:modified "2026-06-07T15:30:41.063251Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-4901
  a curric:PupilLessonOutcome ;
  rdfs:label "I can present a non-chronological report about aye-ayes."@en ;
  dcterms:modified "2026-06-07T15:30:41.063256Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-4879
  a curric:PupilLessonOutcome ;
  rdfs:label "I can write the conclusion of a non-chronological report about tigers."@en ;
  dcterms:modified "2026-06-07T15:30:41.063261Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-2703
  a curric:PupilLessonOutcome ;
  rdfs:label """I can write a range of sentence types in the simple present, past or future
  tense."""@en ;
  dcterms:modified "2026-06-07T15:30:41.063265Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-1096
  a curric:PupilLessonOutcome ;
  rdfs:label """I can effectively use the words ‘idyllic’, ‘verdant’ and other rich vocabulary
  associated with the countryside."""@en ;
  dcterms:modified "2026-06-07T15:30:41.063278Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-6012
  a curric:PupilLessonOutcome ;
  rdfs:label "I can plan and write the conclusion of a persuasive letter about school uniform."@en ;
  dcterms:modified "2026-06-07T15:30:41.063282Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-5495
