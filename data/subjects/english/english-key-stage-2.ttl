  curric:isUnitOf
    natcurric:scheme-english-key-stage-2 ;
  curric:includesThread
    oakcurric:thread-developing-spelling-accuracy .

oakcurric:unit-912
  a curric:Unit ;
  rdfs:label "Poetry inspired by animals"@en ;
  curric:slug "poetry-inspired-by-animals-reading" ;
  rdfs:comment """In this unit, pupils read, respond to and perform classic and contemporary poetry
  about animals by a range of different poets. They explore form, structure and language,
  whilst developing personal responses. Finally, pupils use a range of strategies to support
  learning poetry by heart."""@en ;
  curric:whyThisWhyNow """This unit uses and builds on pupils' knowledge of poetic forms, language
  and structure from the Y4 unit, 'Poetry inspired by weather'. In this unit, pupils build on
  this knowledge by reading and analysing classic and contemporary poetry about animals, whilst
  developing personal responses. Pupils will develop their poetry performance skills and learn
  some poetry by heart. This unit prepares pupils for 'Poetry of place', where they will build
  on these experiences, reading and analysing classic and contemporary poetry that evokes a
  strong sense of place, before writing their own poems.""" ;
  curric:hasPriorKnowledgeRequirement
