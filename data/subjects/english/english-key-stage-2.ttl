  dcterms:modified "2026-02-12T08:59:21.718450Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1423-2
  a curric:KeyLearningPoint ;
  rdfs:label "Unlike other words we have investigated, there are no patterns for homophones."@en ;
  dcterms:modified "2026-02-12T08:59:21.718455Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1423-3
  a curric:KeyLearningPoint ;
  rdfs:label """The way a word is spelt and its place within a sentence will tell us its meaning."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718459Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1423-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: ordinary, grammar and women."@en ;
  dcterms:modified "2026-02-12T08:59:21.718464Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4893-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the introduction is to engage the reader and give them general information about the report's subject."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718469Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4893-2
  a curric:KeyLearningPoint ;
  rdfs:label "Aye-ayes can be referred to in the singular or plural throughout a report."@en ;
  dcterms:modified "2026-02-12T08:59:21.718473Z"^^xsd:dateTime .

