    oakcurric:priorknowledge-87-7 ,
    oakcurric:priorknowledge-87-8 ,
    oakcurric:priorknowledge-87-9 ,
    oakcurric:priorknowledge-87-10 ;
  curric:id "87"^^xsd:positiveInteger;
  dcterms:modified "2026-06-07T15:29:25.066596Z"^^xsd:dateTime ;
  curric:isUnitOf
    natcurric:scheme-english-key-stage-2 ;
  curric:includesThread
    oakcurric:thread-developing-grammatical-knowledge .

oakcurric:unit-704
  a curric:Unit ;
  rdfs:label "Early Islamic civilisation: essay writing"@en ;
  curric:slug "ancient-islamic-civilisation-essay-writing" ;
  rdfs:comment """In this unit, pupils research the Abbasid dynasty of early Islamic civilisation
  and why it is referred to by historians as a 'Golden Age'. They organise their knowledge
  into a clear essay structure with an introduction, paragraphs and a conclusion. They then
  write an essay that aims to inform."""@en ;
  curric:whyThisWhyNow """This unit uses and builds on pupils' knowledge of writing a single line of
  argument essay from the previous Year 6 unit, 'Polar regions: essay writing'. The question
  for this essay requires pupils to express and explain an array of researched information
  about an early civilisation. Pupils practise writing with credibility, using facts derived
  from research that are organised in a clear structure from introduction to themed paragraphs
  to conclusion, presented using the full range of sentence structures and cohesive devices.
  This unit prepares pupils for further analytical writing at KS3 level.""" ;
  curric:hasPriorKnowledgeRequirement
    oakcurric:priorknowledge-704-1 ,
    oakcurric:priorknowledge-704-2 ,
    oakcurric:priorknowledge-704-3 ,
