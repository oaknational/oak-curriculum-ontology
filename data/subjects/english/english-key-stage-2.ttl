oakcurric:keylearningpoint-lesson-4816-5
  a curric:KeyLearningPoint ;
  rdfs:label "You don't lift your pencil when forming the joins."@en ;
  dcterms:modified "2026-02-12T08:59:21.642692Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3399-1
  a curric:KeyLearningPoint ;
  rdfs:label """Subject-specific vocabulary, including numerical facts, is used in a non-chronological report."""@en ;
  dcterms:modified "2026-02-12T08:59:21.642697Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3399-2
  a curric:KeyLearningPoint ;
  rdfs:label """Fronted adverbials of cause are used to at the start of a sentence to explain a reason."""@en ;
  dcterms:modified "2026-02-12T08:59:21.642701Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3399-3
  a curric:KeyLearningPoint ;
  rdfs:label """Sentences can start with a range of fronted adverbials like formal and viewpoint fronted adverbials."""@en ;
  dcterms:modified "2026-02-12T08:59:21.642709Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6746-1
  a curric:KeyLearningPoint ;
  rdfs:label """In this lesson, we are writing a third person flashback and a first person perspective."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643006Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6746-2
  a curric:KeyLearningPoint ;
  rdfs:label """Switching perspectives like this allows us to focus on different elements of the narrative at different points."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643011Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6746-3
  a curric:KeyLearningPoint ;
  rdfs:label "Our flashback is likely to be more formal than the first person section."@en ;
  dcterms:modified "2026-02-12T08:59:21.643016Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6746-4
  a curric:KeyLearningPoint ;
  rdfs:label "Both sections should include a range of sentence structures and punctuation."@en ;
  dcterms:modified "2026-02-12T08:59:21.643023Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6746-5
  a curric:KeyLearningPoint ;
  rdfs:label "Orally rehearsing our writing allows us to write more confidently."@en ;
  dcterms:modified "2026-02-12T08:59:21.643028Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6731-1
  a curric:KeyLearningPoint ;
  rdfs:label "Writing is most successful when it is planned and rehearsed."@en ;
  dcterms:modified "2026-02-12T08:59:21.643033Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6731-2
  a curric:KeyLearningPoint ;
  rdfs:label """When we plan, we can use our text map as a basis, breaking it down into key scenes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643038Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6731-3
  a curric:KeyLearningPoint ;
  rdfs:label """For each scene, we make notes about the actions, descriptions, dialogue and emotions we might include (where relevant)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643043Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6731-4
  a curric:KeyLearningPoint ;
  rdfs:label """We also plan to include the rich vocabulary that we have generated in previous lessons."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643047Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6153-1
  a curric:KeyLearningPoint ;
  rdfs:label """A journalistic report is a non-fiction text that informs the reader about an event."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643066Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6153-2
  a curric:KeyLearningPoint ;
  rdfs:label """Organised in paragraphs, a journalistic report opens with an introduction and ends with a closing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643073Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6153-3
  a curric:KeyLearningPoint ;
  rdfs:label "Generally, in a news report, the journalist does not include their own opinion."@en ;
  dcterms:modified "2026-02-12T08:59:21.643078Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6153-4
  a curric:KeyLearningPoint ;
  rdfs:label "The report will contain a mixture of factual claims and reported perspectives."@en ;
  dcterms:modified "2026-02-12T08:59:21.643083Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6153-5
  a curric:KeyLearningPoint ;
  rdfs:label "The perspectives may be shown using direct or reported speech."@en ;
  dcterms:modified "2026-02-12T08:59:21.643088Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7857-1
  a curric:KeyLearningPoint ;
  rdfs:label """Cece has different relationships with characters within the text, including her family and friends."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643093Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7857-2
  a curric:KeyLearningPoint ;
  rdfs:label """Characters within the text depict a range of emotions. Character traits can be understood from these."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643098Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7857-3
  a curric:KeyLearningPoint ;
  rdfs:label """Character traits can be explored through the text’s illustrations or words used by the characters"""@en ;
  dcterms:modified "2026-02-12T08:59:21.643102Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7857-4
  a curric:KeyLearningPoint ;
  rdfs:label """Making connections and recommendations can significantly enhance the reading experience and broaden understanding."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643107Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3469-1
  a curric:KeyLearningPoint ;
  rdfs:label "The steps in the honey-making process are written in chronological order."@en ;
  dcterms:modified "2026-02-12T08:59:21.643115Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3469-2
  a curric:KeyLearningPoint ;
  rdfs:label "Ordering fronted adverbials indicate the order of the steps in a process."@en ;
  dcterms:modified "2026-02-12T08:59:21.643120Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3469-3
  a curric:KeyLearningPoint ;
  rdfs:label """Using the full range of sentence types (simple, compound and complex) improves text flow for the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643124Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3469-4
  a curric:KeyLearningPoint ;
  rdfs:label """Explanation texts include subject-specific vocabulary that is related to the subject of the text."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643129Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4865-1
  a curric:KeyLearningPoint ;
  rdfs:label "Editing is the process of making changes to improve our writing."@en ;
  dcterms:modified "2026-02-12T08:59:21.643134Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4865-2
  a curric:KeyLearningPoint ;
  rdfs:label "Editing can be done by oneself, with a peer or with a teacher."@en ;
  dcterms:modified "2026-02-12T08:59:21.643139Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4865-3
  a curric:KeyLearningPoint ;
  rdfs:label """When editing punctuation, missing or incorrectly used capital letters, full stops and commas are all checked."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643143Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4865-4
  a curric:KeyLearningPoint ;
  rdfs:label """When editing sentence structure, the way sentences are constructed is checked to improve and enhance text flow."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643148Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4865-5
  a curric:KeyLearningPoint ;
  rdfs:label "When editing language, choices of words and phrases are carefully reviewed."@en ;
  dcterms:modified "2026-02-12T08:59:21.643153Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8087-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘Richmond Park’ is a free verse poem; the poem offers contrasting views of the setting it describes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643157Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8087-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Richmond Park' is based on a place which is near to where the poet grew up."@en ;
  dcterms:modified "2026-02-12T08:59:21.643163Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8087-3
  a curric:KeyLearningPoint ;
  rdfs:label """‘The Old Farmer’s Song’ can be described as a fixed verse poem; it has a consistent rhyme scheme."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643167Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8087-4
  a curric:KeyLearningPoint ;
  rdfs:label "Both poems describe the harshness and beauty of rural life."@en ;
  dcterms:modified "2026-02-12T08:59:21.643175Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8087-5
  a curric:KeyLearningPoint ;
  rdfs:label """We can compare and contrast poems with similar themes or messages, noticing the impact that they have on us as readers."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643180Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7634-1
  a curric:KeyLearningPoint ;
  rdfs:label """Sentences should be said aloud before writing to ensure they make sense and read back once written to check for errors."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643470Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7634-2
  a curric:KeyLearningPoint ;
  rdfs:label """Ambitious vocabulary and figurative language create a vivid picture in the reader's mind."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643475Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7634-3
  a curric:KeyLearningPoint ;
  rdfs:label """Writers choose varied fronted adverbials and different sentence types to ensure the text flows for the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643484Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7634-4
  a curric:KeyLearningPoint ;
  rdfs:label """Careful selection of nouns and pronouns ensures cohesion within sentences and across sections of a written piece."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643489Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7634-5
  a curric:KeyLearningPoint ;
  rdfs:label """Past simple, progressive and perfect verb forms can be used to improve text cohesion."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643494Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1065-1
  a curric:KeyLearningPoint ;
  rdfs:label "A subheading signals to the reader what the section is about."@en ;
  dcterms:modified "2026-02-12T08:59:21.643499Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1065-2
  a curric:KeyLearningPoint ;
  rdfs:label """A section about one feature of the report's subject contains specific facts and information to keep the reader engaged."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643504Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1065-3
  a curric:KeyLearningPoint ;
  rdfs:label """Writers choose varied fronted adverbials and different sentence types to ensure the text flows for the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643508Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1065-4
  a curric:KeyLearningPoint ;
  rdfs:label "A section can be composed of one paragraph."@en ;
  dcterms:modified "2026-02-12T08:59:21.643513Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1065-5
  a curric:KeyLearningPoint ;
  rdfs:label """Sentences should be said aloud before writing to ensure they make sense and read back once written to check for errors."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643518Z"^^xsd:dateTime .

