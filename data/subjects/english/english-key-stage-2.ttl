  dcterms:modified "2026-02-12T08:59:21.738882Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1379-1
  a curric:KeyLearningPoint ;
  rdfs:label "The suffixes -ence and -ency can create abstract nouns."@en ;
  dcterms:modified "2026-02-12T08:59:21.738886Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1379-2
  a curric:KeyLearningPoint ;
  rdfs:label "The -ence or -ency spellings may be found after a ‘soft c’, ‘soft g’ or ‘qu’."@en ;
  dcterms:modified "2026-02-12T08:59:21.738890Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1379-3
  a curric:KeyLearningPoint ;
  rdfs:label """Words ending in -ence and -ency sometimes have related words where the ‘e’ vowel sound is clearer."""@en ;
  dcterms:modified "2026-02-12T08:59:21.738894Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1379-4
  a curric:KeyLearningPoint ;
  rdfs:label "Words in word families often have connected meaning and spelling."@en ;
  dcterms:modified "2026-02-12T08:59:21.738898Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1379-5
  a curric:KeyLearningPoint ;
  rdfs:label """How to spell the curriculum words: accident, accidentally, especially and actually."""@en ;
  dcterms:modified "2026-02-12T08:59:21.738904Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6011-1
  a curric:KeyLearningPoint ;
  rdfs:label """A written argument tries to convince the reader of something using strong reasoning to support."""@en ;
  dcterms:modified "2026-02-12T08:59:21.738910Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6011-2
  a curric:KeyLearningPoint ;
  rdfs:label "The PEPS structure stands for: point, explanation, proof, summary."@en ;
  dcterms:modified "2026-02-12T08:59:21.738915Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6011-3
  a curric:KeyLearningPoint ;
  rdfs:label """A conditional clause is a type of subordinate clause that expresses a degree of possibility that something might happen."""@en ;
  dcterms:modified "2026-02-12T08:59:21.738919Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6011-4
  a curric:KeyLearningPoint ;
  rdfs:label """A relative clause is a type of subordinate clause that starts with a relative pronoun."""@en ;
  dcterms:modified "2026-02-12T08:59:21.738923Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1309-1
  a curric:KeyLearningPoint ;
  rdfs:label "The suffix -ise often turns adjectives and nouns into verbs."@en ;
  dcterms:modified "2026-02-12T08:59:21.738926Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1309-2
  a curric:KeyLearningPoint ;
  rdfs:label "When the root word ends in a consonant, we often just add the suffix."@en ;
  dcterms:modified "2026-02-12T08:59:21.738930Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1309-3
  a curric:KeyLearningPoint ;
  rdfs:label "When the root word ends in a ‘y’, we remove the ‘y’ and add the suffix."@en ;
  dcterms:modified "2026-02-12T08:59:21.738934Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1309-4
  a curric:KeyLearningPoint ;
  rdfs:label """A suffix is a letter or group of letters at the end of a word which creates another word and can change the word class."""@en ;
  dcterms:modified "2026-02-12T08:59:21.738938Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1309-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: probably, occasion and occasionally."@en ;
  dcterms:modified "2026-02-12T08:59:21.738942Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1349-1
  a curric:KeyLearningPoint ;
  rdfs:label """The suffix -ible is common if a complete root word cannot be heard before it, e.g. legible, invincible."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739220Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1349-2
  a curric:KeyLearningPoint ;
  rdfs:label """If there is an obvious root, the suffix -ible usually follows stems ending in an 's' sound e.g. response - responsible."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739224Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1349-3
  a curric:KeyLearningPoint ;
  rdfs:label """Removing the -ible suffix does not usually leave a recognisable root word in English, e.g. visible - vis."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739228Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1349-4
  a curric:KeyLearningPoint ;
  rdfs:label """Adjectives ending in the suffix -ible and adverbs ending in the suffix -ibly are connected in spelling and meaning."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739232Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1349-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: definite and immediate."@en ;
  dcterms:modified "2026-02-12T08:59:21.739236Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6012-1
  a curric:KeyLearningPoint ;
  rdfs:label """The conclusion is the last paragraph that summarises the key information of the letter."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739239Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6012-2
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the conclusion is to thank the reader, encourage action and emphasise the purpose of the letter."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739244Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6012-3
  a curric:KeyLearningPoint ;
  rdfs:label "Veiled threats provide a threat that isn’t directly stated but is implied."@en ;
  dcterms:modified "2026-02-12T08:59:21.739249Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6012-4
  a curric:KeyLearningPoint ;
  rdfs:label """Presumption can make the reader feel like you already believe they’ll do what you are asking."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739256Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2703-1
  a curric:KeyLearningPoint ;
  rdfs:label "The verb carries the tense of a sentence."@en ;
  dcterms:modified "2026-02-12T08:59:21.739260Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2703-2
  a curric:KeyLearningPoint ;
  rdfs:label "Sentences can be formed in the first, second or third person."@en ;
  dcterms:modified "2026-02-12T08:59:21.739264Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2703-3
  a curric:KeyLearningPoint ;
  rdfs:label "The simple tense can denote present, past or future action."@en ;
  dcterms:modified "2026-02-12T08:59:21.739268Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2703-4
  a curric:KeyLearningPoint ;
  rdfs:label """The simple tense is a tense that does not make use of an auxiliary verb in addition to the main verb."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739272Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2703-5
  a curric:KeyLearningPoint ;
  rdfs:label "Tense is often maintained within sentences."@en ;
  dcterms:modified "2026-02-12T08:59:21.739276Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4879-1
  a curric:KeyLearningPoint ;
  rdfs:label "The conclusion is the final paragraph of a non-chronological report."@en ;
  dcterms:modified "2026-02-12T08:59:21.739280Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4879-2
  a curric:KeyLearningPoint ;
  rdfs:label "The purpose of the conclusion is to summarise the key information of the report."@en ;
  dcterms:modified "2026-02-12T08:59:21.739284Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4879-3
  a curric:KeyLearningPoint ;
  rdfs:label "Only general information is included in the conclusion."@en ;
  dcterms:modified "2026-02-12T08:59:21.739289Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4879-4
  a curric:KeyLearningPoint ;
  rdfs:label """Success criteria can be used to help a writer understand what to include in their writing to make it successful."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739294Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4901-1
  a curric:KeyLearningPoint ;
  rdfs:label "Presenting involves speaking in front of others and listening to others."@en ;
  dcterms:modified "2026-02-12T08:59:21.739298Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4901-2
  a curric:KeyLearningPoint ;
  rdfs:label """Presenting includes using voice projection, speaking with clear diction, making eye contact and strong body language."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739302Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4901-3
  a curric:KeyLearningPoint ;
  rdfs:label "Voice projection is not the same as shouting."@en ;
  dcterms:modified "2026-02-12T08:59:21.739308Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4901-4
  a curric:KeyLearningPoint ;
  rdfs:label "Practising pronouncing tricky words helps develop clear diction when presenting."@en ;
  dcterms:modified "2026-02-12T08:59:21.739312Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5459-1
  a curric:KeyLearningPoint ;
  rdfs:label """'The Pebble in my Pocket' is a narrative non-fiction based on the story of a pebble and its journey through time."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739316Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5459-2
  a curric:KeyLearningPoint ;
  rdfs:label """The story has two narrators, the girl who finds the pebble today and the narrator who tells its history."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739320Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5459-3
  a curric:KeyLearningPoint ;
  rdfs:label """The history of the pebble begins millions of years ago and is told in chronological order."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739324Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5459-4
  a curric:KeyLearningPoint ;
  rdfs:label """Everything that exists has a story to tell and can help us to build our understanding of the world."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739327Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1306-1
  a curric:KeyLearningPoint ;
  rdfs:label """A suffix is a letter or group of letters at the end of a word which creates another word and can change the word class."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739332Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1306-2
  a curric:KeyLearningPoint ;
  rdfs:label "The suffix -ate often turns adjectives and nouns into verbs."@en ;
  dcterms:modified "2026-02-12T08:59:21.739336Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1306-3
  a curric:KeyLearningPoint ;
  rdfs:label "When the root word ends in a consonant, we often just add the suffix."@en ;
  dcterms:modified "2026-02-12T08:59:21.739339Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1306-4
  a curric:KeyLearningPoint ;
  rdfs:label """When the root word ends in a vowel, we remove the final vowel and add the suffix."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739343Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1306-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: business, possession and answer."@en ;
  dcterms:modified "2026-02-12T08:59:21.739347Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6548-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of a persuasive letter is to persuade or convince the reader to change their mind or behaviour."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739605Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6548-2
  a curric:KeyLearningPoint ;
  rdfs:label "Persuasive letters are formal in tone."@en ;
  dcterms:modified "2026-02-12T08:59:21.739609Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6548-3
  a curric:KeyLearningPoint ;
  rdfs:label """Linguistic features are language features that help the text achieve its purpose."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739613Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6548-4
  a curric:KeyLearningPoint ;
  rdfs:label """Persuasive techniques are structures or devices used in writing to try to change someone’s mind or behaviour."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739617Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1445-1
  a curric:KeyLearningPoint ;
  rdfs:label "-er and -est are suffixes that can be used to change the meaning of a root word."@en ;
  dcterms:modified "2026-02-12T08:59:21.739621Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1445-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Colour blocks' is a useful practice strategy."@en ;
  dcterms:modified "2026-02-12T08:59:21.739625Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1445-3
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum word: difficult."@en ;
  dcterms:modified "2026-02-12T08:59:21.739629Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1456-1
  a curric:KeyLearningPoint ;
  rdfs:label "Compound words are words made up of two or more pre-existing words."@en ;
  dcterms:modified "2026-02-12T08:59:21.739633Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1456-2
  a curric:KeyLearningPoint ;
  rdfs:label """The spelling of both words remains the same when the words are combined together."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739637Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1456-3
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum word: forwards."@en ;
  dcterms:modified "2026-02-12T08:59:21.739641Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5806-1
  a curric:KeyLearningPoint ;
  rdfs:label "Shakespeare wrote 'Romeo and Juliet' as a play script."@en ;
  dcterms:modified "2026-02-12T08:59:21.739645Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5806-2
  a curric:KeyLearningPoint ;
  rdfs:label "Lines in the script give us clues for how characters feel and think."@en ;
  dcterms:modified "2026-02-12T08:59:21.739673Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5806-3
  a curric:KeyLearningPoint ;
  rdfs:label "Romeo and Juliet meet at a masked ball hosted by Lord Capulet."@en ;
  dcterms:modified "2026-02-12T08:59:21.739678Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5806-4
  a curric:KeyLearningPoint ;
  rdfs:label "Romeo falls instantly in love with Juliet upon first sight."@en ;
  dcterms:modified "2026-02-12T08:59:21.739682Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5806-5
  a curric:KeyLearningPoint ;
  rdfs:label """Romeo overhears Juliet professing her love for him later the same night from her balcony."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739686Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1413-1
  a curric:KeyLearningPoint ;
  rdfs:label "The suffix -ic often turns nouns into adjectives."@en ;
  dcterms:modified "2026-02-12T08:59:21.739689Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1413-2
  a curric:KeyLearningPoint ;
  rdfs:label "When the root word ends in 'e', remove the 'e' and add the suffix -ic."@en ;
  dcterms:modified "2026-02-12T08:59:21.739693Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1413-3
  a curric:KeyLearningPoint ;
  rdfs:label "When the root word ends in 'y', remove the 'y' and add the suffix -ic."@en ;
  dcterms:modified "2026-02-12T08:59:21.739700Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1413-4
  a curric:KeyLearningPoint ;
  rdfs:label "When the root word does not end in 'e' or 'y', just add the suffix -ic."@en ;
  dcterms:modified "2026-02-12T08:59:21.739704Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1413-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: bicycle, centre and recent."@en ;
  dcterms:modified "2026-02-12T08:59:21.739708Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1421-1
  a curric:KeyLearningPoint ;
  rdfs:label "A solid compound word has two or more words joined together to make one word."@en ;
  dcterms:modified "2026-02-12T08:59:21.739713Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1421-2
  a curric:KeyLearningPoint ;
  rdfs:label "A hyphenated compound word has a hyphen separating two words."@en ;
  dcterms:modified "2026-02-12T08:59:21.739718Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1421-3
  a curric:KeyLearningPoint ;
  rdfs:label """An open compound word has two words that are separated, but are still behaving as one noun."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739722Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1421-4
  a curric:KeyLearningPoint ;
  rdfs:label """A solid compound word is often the clearest way to combine two words to make a compound noun."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739726Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1421-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: natural, pressure and strange."@en ;
  dcterms:modified "2026-02-12T08:59:21.739729Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1368-1
  a curric:KeyLearningPoint ;
  rdfs:label "The suffixes -ity and -ness turns adjectives into abstract nouns."@en ;
  dcterms:modified "2026-02-12T08:59:21.739733Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1368-2
  a curric:KeyLearningPoint ;
  rdfs:label """When a word ends in a consonant, just add the suffix -ity; when it ends in ‘e’, remove the ‘e’, then add -ity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739739Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1368-3
  a curric:KeyLearningPoint ;
  rdfs:label "There are other patterns and irregular words, like ‘ability’ and ‘simplicity’."@en ;
  dcterms:modified "2026-02-12T08:59:21.739743Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1368-4
  a curric:KeyLearningPoint ;
  rdfs:label """For most words, just add the suffix -ness; when a word ends in ‘y’, replace the ‘y’ with ‘i’, then add the suffix -ness."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739747Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1368-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: business and opportunity."@en ;
  dcterms:modified "2026-02-12T08:59:21.739751Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27624-1
  a curric:KeyLearningPoint ;
  rdfs:label """A debate is a structured argument between two teams who either agree or disagree with a motion."""@en ;
  dcterms:modified "2026-02-12T08:59:21.740109Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27624-2
  a curric:KeyLearningPoint ;
  rdfs:label "The motion is the name for the belief or proposal that is being debated."@en ;
  dcterms:modified "2026-02-12T08:59:21.740113Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27624-3
  a curric:KeyLearningPoint ;
  rdfs:label """An opinion is a view or belief that a person has and robust reasoning supports an opinion."""@en ;
  dcterms:modified "2026-02-12T08:59:21.740116Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27624-4
  a curric:KeyLearningPoint ;
  rdfs:label "The PEPS structure stands for: point, explanation, proof, summary."@en ;
  dcterms:modified "2026-02-12T08:59:21.740120Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27893-1
  a curric:KeyLearningPoint ;
  rdfs:label "People can agree or disagree with other people's opinions."@en ;
  dcterms:modified "2026-02-12T08:59:21.740124Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27893-2
  a curric:KeyLearningPoint ;
  rdfs:label "A debate involves speakers disagreeing with each other."@en ;
  dcterms:modified "2026-02-12T08:59:21.740128Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27893-3
  a curric:KeyLearningPoint ;
  rdfs:label "Choosing a strong point is key to making a convincing argument."@en ;
  dcterms:modified "2026-02-12T08:59:21.740132Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27893-4
  a curric:KeyLearningPoint ;
  rdfs:label """A counter-argument is when you hear someone else's point and then respond with your own perspective and reasoning."""@en ;
  dcterms:modified "2026-02-12T08:59:21.740136Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6595-1
  a curric:KeyLearningPoint ;
  rdfs:label """The main body of a biography is split into paragraphs, which are organised by theme."""@en ;
  dcterms:modified "2026-02-12T08:59:21.740142Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6595-2
  a curric:KeyLearningPoint ;
  rdfs:label """Using a range of cohesive devices can enhance text flow and achieve text purpose."""@en ;
  dcterms:modified "2026-02-12T08:59:21.740148Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6595-3
  a curric:KeyLearningPoint ;
  rdfs:label "A complex sentence includes a main clause and any type of subordinate clause."@en ;
  dcterms:modified "2026-02-12T08:59:21.740152Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6595-4
  a curric:KeyLearningPoint ;
  rdfs:label """Adverbial complex, relative complex and non-finite complex sentences can all be used in biographies."""@en ;
  dcterms:modified "2026-02-12T08:59:21.740156Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6595-5
  a curric:KeyLearningPoint ;
  rdfs:label """In biographies, extra, factual information can be added to clauses using brackets."""@en ;
  dcterms:modified "2026-02-12T08:59:21.740161Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1347-1
  a curric:KeyLearningPoint ;
  rdfs:label "The -ent and -ence suffixes generally come after a soft 'c', soft 'g' and 'qu'."@en ;
  dcterms:modified "2026-02-12T08:59:21.740166Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1347-2
  a curric:KeyLearningPoint ;
  rdfs:label """Words ending in -ent sometimes have related words where the ‘e’ vowel sound is clearer, like resident - residential."""@en ;
  dcterms:modified "2026-02-12T08:59:21.740170Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1347-3
  a curric:KeyLearningPoint ;
  rdfs:label """Changing the suffix -ent to the suffix -ence or -ency can change the word from an adjective to an abstract noun."""@en ;
  dcterms:modified "2026-02-12T08:59:21.740173Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1347-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: hindrance, excellent and relevant."@en ;
  dcterms:modified "2026-02-12T08:59:21.740178Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1441-1
  a curric:KeyLearningPoint ;
  rdfs:label "The suffixes -ful and -less can be used to change the meaning of a root word."@en ;
  dcterms:modified "2026-02-12T08:59:21.740184Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1441-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Look, cover, write and check' is a useful practice strategy."@en ;
  dcterms:modified "2026-02-12T08:59:21.740188Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1441-3
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum word: famous."@en ;
  dcterms:modified "2026-02-12T08:59:21.740192Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1441-4
  a curric:KeyLearningPoint ;
  rdfs:label """The -less and -ful suffixes start with a consonant, so the root word usually doesn’t change when the suffix is added."""@en ;
  dcterms:modified "2026-02-12T08:59:21.740196Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1441-5
  a curric:KeyLearningPoint ;
  rdfs:label """If the root word has more than one syllable and ends in a consonant +y, then ‘y’ is replaced by ‘i’ before the suffix."""@en ;
  dcterms:modified "2026-02-12T08:59:21.740199Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1050-1
  a curric:KeyLearningPoint ;
  rdfs:label "Writers can use speech sentences to show a character speaking in a text."@en ;
  dcterms:modified "2026-02-12T08:59:21.740203Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1050-2
  a curric:KeyLearningPoint ;
  rdfs:label "If a character speaks, the writer must signal this with specific punctuation."@en ;
  dcterms:modified "2026-02-12T08:59:21.740207Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1050-3
  a curric:KeyLearningPoint ;
  rdfs:label """Inverted commas are the punctuation marks that signal direct speech to the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.740211Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1050-4
  a curric:KeyLearningPoint ;
  rdfs:label "Direct speech is the term used for a character speaking out loud in a text."@en ;
  dcterms:modified "2026-02-12T08:59:21.740215Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1050-5
  a curric:KeyLearningPoint ;
  rdfs:label "Direct speech helps us learn more about characters in a text."@en ;
  dcterms:modified "2026-02-12T08:59:21.740219Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4701-1
  a curric:KeyLearningPoint ;
  rdfs:label "It is important to structure your argument when debating."@en ;
  dcterms:modified "2026-02-12T08:59:21.740431Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4701-2
  a curric:KeyLearningPoint ;
  rdfs:label "The PEPS structure stands for: point, explanation, proof, summary."@en ;
  dcterms:modified "2026-02-12T08:59:21.740435Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4701-3
  a curric:KeyLearningPoint ;
  rdfs:label "Structuring your argument will make it more convincing."@en ;
  dcterms:modified "2026-02-12T08:59:21.740439Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1410-1
  a curric:KeyLearningPoint ;
  rdfs:label "The suffix -al often turns nouns into adjectives."@en ;
  dcterms:modified "2026-02-12T08:59:21.740442Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1410-2
  a curric:KeyLearningPoint ;
  rdfs:label "When the root word ends in ‘e’, remove the ‘e’ and add the suffix."@en ;
  dcterms:modified "2026-02-12T08:59:21.740446Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1410-3
  a curric:KeyLearningPoint ;
  rdfs:label """There are many ways to represent the ‘l’ sound in a word, including ‘l’, ‘ll’, ‘le’, ‘il’, ‘el’ and ‘al’."""@en ;
  dcterms:modified "2026-02-12T08:59:21.740450Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1410-4
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: possible, difficult and therefore."@en ;
  dcterms:modified "2026-02-12T08:59:21.740454Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3457-1
  a curric:KeyLearningPoint ;
  rdfs:label "A hyphen is a piece of punctuation with more than one purpose."@en ;
  dcterms:modified "2026-02-12T08:59:21.740458Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3457-2
  a curric:KeyLearningPoint ;
  rdfs:label "A hyphen can join two words to make a compound adjective."@en ;
  dcterms:modified "2026-02-12T08:59:21.740464Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3457-3
  a curric:KeyLearningPoint ;
  rdfs:label """A hyphen can join a prefix to a base word to avoid spelling or meaning ambiguity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.740468Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3457-4
  a curric:KeyLearningPoint ;
  rdfs:label "An ellipsis can be used to invite the reader to read on or to increase tension."@en ;
  dcterms:modified "2026-02-12T08:59:21.740472Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5808-1
  a curric:KeyLearningPoint ;
  rdfs:label "Writing is most successful when its content is planned."@en ;
  dcterms:modified "2026-02-12T08:59:21.740476Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5808-2
  a curric:KeyLearningPoint ;
  rdfs:label """A diary entry is most often written retrospectively, but it may contain both present and past tense sections."""@en ;
  dcterms:modified "2026-02-12T08:59:21.740480Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5808-3
  a curric:KeyLearningPoint ;
  rdfs:label """Juliet's diary is written as two entries - one on her return from the ball and one after the balcony scene."""@en ;
  dcterms:modified "2026-02-12T08:59:21.740484Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5808-4
  a curric:KeyLearningPoint ;
  rdfs:label """A diary entry should include both descriptions of the event(s) and details about the emotions that a character feels."""@en ;
  dcterms:modified "2026-02-12T08:59:21.740488Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5808-5
  a curric:KeyLearningPoint ;
  rdfs:label "We can use rich vocabulary and show-not-tell to describe events and emotions."@en ;
  dcterms:modified "2026-02-12T08:59:21.740492Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6151-1
  a curric:KeyLearningPoint ;
  rdfs:label "Editing is the process of making changes to improve our writing."@en ;
  dcterms:modified "2026-02-12T08:59:21.740496Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6151-2
  a curric:KeyLearningPoint ;
  rdfs:label "Editing can be done by oneself, with a peer or with a teacher."@en ;
  dcterms:modified "2026-02-12T08:59:21.740500Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6151-3
  a curric:KeyLearningPoint ;
  rdfs:label """To edit punctuation, missing or incorrectly used capital letters, full stops, inverted commas and commas are checked."""@en ;
  dcterms:modified "2026-02-12T08:59:21.740504Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6151-4
  a curric:KeyLearningPoint ;
  rdfs:label """When editing sentence structure, the way sentences are constructed is checked to improve and enhance text flow."""@en ;
  dcterms:modified "2026-02-12T08:59:21.740508Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6151-5
  a curric:KeyLearningPoint ;
  rdfs:label "When editing language, choices of words and phrases are carefully reviewed."@en ;
  dcterms:modified "2026-02-12T08:59:21.740512Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5998-1
  a curric:KeyLearningPoint ;
  rdfs:label """When rehearsing and planning for a persuasive letter, we do so in the first person from the character's perspective."""@en ;
  dcterms:modified "2026-02-12T08:59:21.740516Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5998-2
  a curric:KeyLearningPoint ;
  rdfs:label """A plan is written in note format using bullet points to capture the most important information."""@en ;
  dcterms:modified "2026-02-12T08:59:21.740519Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5998-3
  a curric:KeyLearningPoint ;
  rdfs:label """Persuasive letters have distinctive linguistic features in order to achieve their purpose."""@en ;
  dcterms:modified "2026-02-12T08:59:21.740523Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5998-4
  a curric:KeyLearningPoint ;
  rdfs:label """The subordinating conjunction 'because' is used to give a reason for why a character is feeling a certain way."""@en ;
  dcterms:modified "2026-02-12T08:59:21.740527Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5998-5
  a curric:KeyLearningPoint ;
  rdfs:label """First person perspective is the point of view where the writer is the 'I' character."""@en ;
  dcterms:modified "2026-02-12T08:59:21.740531Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4869-1
  a curric:KeyLearningPoint ;
  rdfs:label "The conclusion is the final paragraph of a non-chronological report."@en ;
  dcterms:modified "2026-02-12T08:59:21.741090Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4869-2
  a curric:KeyLearningPoint ;
  rdfs:label "Information in the conclusion should be general."@en ;
  dcterms:modified "2026-02-12T08:59:21.741094Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4869-3
  a curric:KeyLearningPoint ;
  rdfs:label """Writers can use a range of cohesive devices to enhance text flow and keep the reader engaged."""@en ;
  dcterms:modified "2026-02-12T08:59:21.741098Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4869-4
  a curric:KeyLearningPoint ;
  rdfs:label "Effective planning leads to successful writing outcomes."@en ;
  dcterms:modified "2026-02-12T08:59:21.741102Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1414-1
  a curric:KeyLearningPoint ;
  rdfs:label "The suffix -ary often turns words into nouns or adjectives."@en ;
  dcterms:modified "2026-02-12T08:59:21.741106Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1414-2
  a curric:KeyLearningPoint ;
  rdfs:label "Some words end in -ary with no clear root word."@en ;
  dcterms:modified "2026-02-12T08:59:21.741112Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1414-3
  a curric:KeyLearningPoint ;
  rdfs:label "Thinking about word families can help with understanding meanings and spelling."@en ;
  dcterms:modified "2026-02-12T08:59:21.741116Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1414-4
  a curric:KeyLearningPoint ;
  rdfs:label "When the root word ends in 'e', remove the 'e' and add the suffix -ary."@en ;
  dcterms:modified "2026-02-12T08:59:21.741120Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1414-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: believe, complete and guide."@en ;
  dcterms:modified "2026-02-12T08:59:21.741126Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4713-1
  a curric:KeyLearningPoint ;
  rdfs:label """A speaker should introduce themselves and their speech title when they first start speaking."""@en ;
  dcterms:modified "2026-02-12T08:59:21.741130Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4713-2
  a curric:KeyLearningPoint ;
  rdfs:label "Using eye-contact helps to make a speech successful."@en ;
  dcterms:modified "2026-02-12T08:59:21.741134Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4713-3
  a curric:KeyLearningPoint ;
  rdfs:label "It is important not to speak too fast when delivering a speech."@en ;
  dcterms:modified "2026-02-12T08:59:21.741138Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-4713-4
  a curric:KeyLearningPoint ;
  rdfs:label """Using body language and gestures will help to reinforce your purpose for speaking."""@en ;
  dcterms:modified "2026-02-12T08:59:21.741142Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1045-1
  a curric:KeyLearningPoint ;
  rdfs:label "A comma is a punctuation mark with more than one purpose."@en ;
  dcterms:modified "2026-02-12T08:59:21.741146Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1045-2
  a curric:KeyLearningPoint ;
  rdfs:label "Commas are often used to demarcate clauses in a range of sentence types."@en ;
  dcterms:modified "2026-02-12T08:59:21.741150Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1045-3
  a curric:KeyLearningPoint ;
  rdfs:label """If the adverbial clause starts an adverbial complex sentence, it is followed by a comma then the main clause."""@en ;
  dcterms:modified "2026-02-12T08:59:21.741154Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1045-4
  a curric:KeyLearningPoint ;
  rdfs:label """A comma is used before "but" and "or" co-ordinating conjunctions when they join two main clauses in a compound sentence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.741157Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1045-5
  a curric:KeyLearningPoint ;
  rdfs:label """Grammatically accurate sentences start with capital letters and most often end with full stops."""@en ;
  dcterms:modified "2026-02-12T08:59:21.741161Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6010-1
  a curric:KeyLearningPoint ;
  rdfs:label """A written argument tries to convince the reader of something using strong reasoning to support."""@en ;
  dcterms:modified "2026-02-12T08:59:21.741165Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6010-2
  a curric:KeyLearningPoint ;
  rdfs:label "The PEPS structure stands for: point, explanation, proof, summary."@en ;
  dcterms:modified "2026-02-12T08:59:21.741169Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6010-3
  a curric:KeyLearningPoint ;
  rdfs:label "When we write a plan, we use notes."@en ;
  dcterms:modified "2026-02-12T08:59:21.741173Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6362-1
  a curric:KeyLearningPoint ;
  rdfs:label """The quotes section of a journalistic report should begin with an introductory sentence about witnesses."""@en ;
  dcterms:modified "2026-02-12T08:59:21.741177Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6362-2
  a curric:KeyLearningPoint ;
  rdfs:label """The sentence preceding reported speech can introduce the witness and provide greater detail about them."""@en ;
  dcterms:modified "2026-02-12T08:59:21.741181Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6362-3
  a curric:KeyLearningPoint ;
  rdfs:label """The quote from the witness can be more informal in language and tone than the rest of the paragraph."""@en ;
  dcterms:modified "2026-02-12T08:59:21.741186Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6362-4
  a curric:KeyLearningPoint ;
  rdfs:label "A reporting clause can come before or after direct speech."@en ;
  dcterms:modified "2026-02-12T08:59:21.741191Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6362-5
  a curric:KeyLearningPoint ;
  rdfs:label """Inverted commas are used to demarcate speech and a piece of punctuation separates speech from the reporting clause."""@en ;
  dcterms:modified "2026-02-12T08:59:21.741195Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5764-1
  a curric:KeyLearningPoint ;
  rdfs:label "Editing is a vital element of the writing process."@en ;
  dcterms:modified "2026-02-12T08:59:21.741199Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5764-2
  a curric:KeyLearningPoint ;
  rdfs:label "When editing, we must be selective about which parts of our writing to improve."@en ;
  dcterms:modified "2026-02-12T08:59:21.741203Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5764-3
  a curric:KeyLearningPoint ;
  rdfs:label """When editing, we can focus on punctuation, sentence structure, vocabulary and spelling."""@en ;
  dcterms:modified "2026-02-12T08:59:21.741206Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1397-1
  a curric:KeyLearningPoint ;
  rdfs:label """A prefix is a letter or group of letters at the start of a word which changes its meaning."""@en ;
  dcterms:modified "2026-02-12T08:59:21.741212Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1397-2
  a curric:KeyLearningPoint ;
  rdfs:label "The prefix bi- means ‘two’ and the prefix trans- means ‘across’."@en ;
  dcterms:modified "2026-02-12T08:59:21.741216Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1397-3
  a curric:KeyLearningPoint ;
  rdfs:label "The prefix tele- means ‘distant’ and the prefix circum- means ‘around’."@en ;
  dcterms:modified "2026-02-12T08:59:21.741220Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1397-4
  a curric:KeyLearningPoint ;
  rdfs:label """Recognising prefixes can help us understand a word’s meaning and help us to spell it."""@en ;
  dcterms:modified "2026-02-12T08:59:21.741224Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1397-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: bicycle, naughty and enough."@en ;
  dcterms:modified "2026-02-12T08:59:21.741228Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7348-1
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of the opening is to set the scene and introduce the main characters."""@en ;
  dcterms:modified "2026-02-12T08:59:21.741232Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7348-2
  a curric:KeyLearningPoint ;
  rdfs:label """Ebenezer Scrooge is a miser who holds disdain for Christmas and this contrasts the general atmosphere in the setting."""@en ;
  dcterms:modified "2026-02-12T08:59:21.741236Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7348-3
  a curric:KeyLearningPoint ;
  rdfs:label """The use of precise and descriptive vocabulary ‘shows and tells’ the reader about Scrooge’s character."""@en ;
  dcterms:modified "2026-02-12T08:59:21.741240Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7348-4
  a curric:KeyLearningPoint ;
  rdfs:label "Direct speech is an effective way to convey a character’s thoughts and feelings."@en ;
  dcterms:modified "2026-02-12T08:59:21.741244Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7348-5
  a curric:KeyLearningPoint ;
  rdfs:label "An effective plan captures key vocabulary and is organised concisely."@en ;
  dcterms:modified "2026-02-12T08:59:21.741248Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1396-1
  a curric:KeyLearningPoint ;
  rdfs:label """A prefix is a letter or group of letters at the start of a word which changes its meaning."""@en ;
  dcterms:modified "2026-02-12T08:59:21.741300Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1396-2
  a curric:KeyLearningPoint ;
  rdfs:label "The prefix de- can mean ‘undo’ and re- can mean ‘again’."@en ;
  dcterms:modified "2026-02-12T08:59:21.741304Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1396-3
  a curric:KeyLearningPoint ;
  rdfs:label """The prefix sub- can mean ‘under’ or ‘nearly’ and super- can mean ‘above’ or ‘larger’."""@en ;
  dcterms:modified "2026-02-12T08:59:21.741307Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1396-4
  a curric:KeyLearningPoint ;
  rdfs:label """The prefix inter- can mean ‘between’, anti- mean ‘against’ and auto- mean ‘self’ or ‘own’."""@en ;
  dcterms:modified "2026-02-12T08:59:21.741311Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1396-5
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: opposite, average, interrupt and lightning."@en ;
  dcterms:modified "2026-02-12T08:59:21.741315Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1357-1
  a curric:KeyLearningPoint ;
  rdfs:label """A hyphen can be used to join a modifier to an adjective to make one adjective, e.g. well-dressed."""@en ;
  dcterms:modified "2026-02-12T08:59:21.741319Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1357-2
  a curric:KeyLearningPoint ;
  rdfs:label """A hyphen can be used to join two or more words that are functioning as one adjective."""@en ;
  dcterms:modified "2026-02-12T08:59:21.741323Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1357-3
  a curric:KeyLearningPoint ;
  rdfs:label "How to spell the curriculum words: familiar and opportunity."@en ;
  dcterms:modified "2026-02-12T08:59:21.741327Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3458-1
  a curric:KeyLearningPoint ;
  rdfs:label "A colon is a piece of punctuation with more than one purpose."@en ;
  dcterms:modified "2026-02-12T08:59:21.741331Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3458-2
  a curric:KeyLearningPoint ;
  rdfs:label "A colon is always placed after a main clause."@en ;
  dcterms:modified "2026-02-12T08:59:21.741335Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3458-3
  a curric:KeyLearningPoint ;
  rdfs:label "A colon can introduce a list or a question."@en ;
  dcterms:modified "2026-02-12T08:59:21.741341Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-3458-4
  a curric:KeyLearningPoint ;
  rdfs:label "A colon can help to improve text cohesion."@en ;
  dcterms:modified "2026-02-12T08:59:21.741346Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1308-1
  a curric:KeyLearningPoint ;
  rdfs:label "The suffix -ify often turns adjectives and nouns into verbs."@en ;
  dcterms:modified "2026-02-12T08:59:21.741350Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1308-2
  a curric:KeyLearningPoint ;
  rdfs:label "When the root word ends in a consonant, we often just add the suffix."@en ;
  dcterms:modified "2026-02-12T08:59:21.741354Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1308-3
  a curric:KeyLearningPoint ;
  rdfs:label """When the root word ends in a vowel, we remove the final vowel and add the suffix."""@en ;
  dcterms:modified "2026-02-12T08:59:21.741358Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1308-4
  a curric:KeyLearningPoint ;
