  dcterms:modified "2026-06-07T15:29:25.403855Z"^^xsd:dateTime .

oakcurric:priorknowledge-911-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Knowledge of text types, including fiction, non-fiction and poetry."@en ;
  dcterms:modified "2026-06-07T15:29:25.405988Z"^^xsd:dateTime .

oakcurric:priorknowledge-911-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "We read to get information and we read for pleasure."@en ;
  dcterms:modified "2026-06-07T15:29:25.406001Z"^^xsd:dateTime .

oakcurric:priorknowledge-911-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "People read for different purposes."@en ;
  dcterms:modified "2026-06-07T15:29:25.406007Z"^^xsd:dateTime .

oakcurric:priorknowledge-911-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Reading develops imagination and curiosity"@en ;
  dcterms:modified "2026-06-07T15:29:25.406012Z"^^xsd:dateTime .

oakcurric:priorknowledge-911-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Sharing texts aloud with others increases reading for pleasure."@en ;
  dcterms:modified "2026-06-07T15:29:25.406018Z"^^xsd:dateTime .

oakcurric:priorknowledge-911-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Recommending texts through informal book talk develops our awareness of
  other texts."""@en ;
  dcterms:modified "2026-06-07T15:29:25.406023Z"^^xsd:dateTime .

oakcurric:priorknowledge-911-7
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Where, when and how we read is an important part of our unique reader identity."@en ;
  dcterms:modified "2026-06-07T15:29:25.406028Z"^^xsd:dateTime .

oakcurric:priorknowledge-911-8
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Reading for pleasure develops our motivation and desire to read."@en ;
  dcterms:modified "2026-06-07T15:29:25.406033Z"^^xsd:dateTime .

oakcurric:priorknowledge-474-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """The purpose of an explanation text to explain the process of how or why something
  happens."""@en ;
  dcterms:modified "2026-06-07T15:29:25.423873Z"^^xsd:dateTime .

oakcurric:priorknowledge-474-2
  a curric:PriorKnowledgeRequirement ;
