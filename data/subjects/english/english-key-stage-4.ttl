    oakcurric:priorknowledge-150-8 ,
    oakcurric:priorknowledge-150-9 ,
    oakcurric:priorknowledge-150-10 ;
  curric:id "150"^^xsd:positiveInteger;
  dcterms:modified "2026-06-07T15:29:23.431263Z"^^xsd:dateTime ;
  curric:isUnitOf
    natcurric:scheme-english-key-stage-4 ;
