# ----------------------------------------------------------------------
# Keywords
# ----------------------------------------------------------------------

oakcurric:keyword-caricatures
  a curric:Keyword ;
  schema:name "caricatures"@en ;
  schema:description """exaggerated or distorted representations of people or things, often used for
  humour"""@en ;
  dcterms:modified "2026-06-07T15:30:02.347226Z"^^xsd:dateTime .

oakcurric:keyword-prejudice
  a curric:Keyword ;
  schema:name "prejudice"@en ;
  schema:description """preconceived opinions or attitudes towards a person or group, often based on
  stereotypes"""@en ;
  dcterms:modified "2026-06-07T15:30:02.347231Z"^^xsd:dateTime .

oakcurric:keyword-compelling
  a curric:Keyword ;
  schema:name "compelling"@en ;
  schema:description "persuasive, convincing"@en ;
  dcterms:modified "2026-06-07T15:30:02.347236Z"^^xsd:dateTime .

oakcurric:keyword-colloquial
  a curric:Keyword ;
  schema:name "colloquial"@en ;
  schema:description """language commonly used in everyday speech, often specific to a particular
  region or social group"""@en ;
  dcterms:modified "2026-06-07T15:30:02.347241Z"^^xsd:dateTime .

oakcurric:keyword-rhyming-couplets
  a curric:Keyword ;
  schema:name "rhyming couplets"@en ;
  schema:description """a pair of successive lines of verse, typically rhyming and of the same
  length"""@en ;
  dcterms:modified "2026-06-07T15:30:02.347246Z"^^xsd:dateTime .

oakcurric:keyword-alias
  a curric:Keyword ;
  schema:name "alias"@en ;
  schema:description "a false name used to conceal one's identity; an assumed name"@en ;
  dcterms:modified "2026-06-07T15:30:02.347312Z"^^xsd:dateTime .

oakcurric:keyword-untrustworthy
  a curric:Keyword ;
  schema:name "untrustworthy"@en ;
  schema:description "not able to be relied on as honest or truthful"@en ;
  dcterms:modified "2026-06-07T15:30:02.347317Z"^^xsd:dateTime .

oakcurric:keyword-dehumanise
  a curric:Keyword ;
  schema:name "dehumanise"@en ;
  schema:description """to remove from a person the special human qualities of independent thought,
  feeling for other people, etc."""@en ;
  dcterms:modified "2026-06-07T15:30:02.347321Z"^^xsd:dateTime .

oakcurric:keyword-disconcerting
  a curric:Keyword ;
  schema:name "disconcerting"@en ;
  schema:description "making someone feel uncertain and uncomfortable or worried"@en ;
  dcterms:modified "2026-06-07T15:30:02.347326Z"^^xsd:dateTime .

oakcurric:keyword-conflicting
  a curric:Keyword ;
  schema:name "conflicting"@en ;
  schema:description "being in conflict or disagreement; not compatible"@en ;
  dcterms:modified "2026-06-07T15:30:02.347330Z"^^xsd:dateTime .

oakcurric:keyword-harmony
  a curric:Keyword ;
  schema:name "harmony"@en ;
  schema:description "how different notes and chords work together"@en ;
  dcterms:modified "2026-06-07T15:30:02.347358Z"^^xsd:dateTime .

oakcurric:keyword-subtle
  a curric:Keyword ;
  schema:name "subtle"@en ;
  schema:description "less obvious; nuanced; complex or understated"@en ;
  dcterms:modified "2026-06-07T15:30:02.347380Z"^^xsd:dateTime .

oakcurric:keyword-feature-spotting
  a curric:Keyword ;
  schema:name "feature-spotting"@en ;
  schema:description """leading an analytical paragraph by identifying methods or techniques used by
  a writer"""@en ;
  dcterms:modified "2026-06-07T15:30:02.347385Z"^^xsd:dateTime .

oakcurric:keyword-tentative-language
  a curric:Keyword ;
  schema:name "tentative language"@en ;
  schema:description "language which indicates a suggestion or idea (as opposed to a fact)"@en ;
  dcterms:modified "2026-06-07T15:30:02.347395Z"^^xsd:dateTime .

oakcurric:keyword-discourse-markers
  a curric:Keyword ;
  schema:name "discourse markers"@en ;
  schema:description """language used to signpost different parts of a text (e.g., 'In conclusion,
  ...')"""@en ;
  dcterms:modified "2026-06-07T15:30:02.347400Z"^^xsd:dateTime .

oakcurric:keyword-redraft
  a curric:Keyword ;
  schema:name "redraft"@en ;
  schema:description """rewriting parts of your work to include missing elements or upgrade the
  quality of your response"""@en ;
  dcterms:modified "2026-06-07T15:30:02.347404Z"^^xsd:dateTime .

oakcurric:keyword-dominant
  a curric:Keyword ;
  schema:name "dominant"@en ;
  schema:description "the fifth note in a scale, or the chord based on that note (chord V)"@en ;
  dcterms:modified "2026-06-07T15:30:02.347419Z"^^xsd:dateTime .

oakcurric:keyword-modal-verb
  a curric:Keyword ;
  schema:name "modal verb"@en ;
  schema:description """verb of necessity or possibility used with a 2nd verb in infinitive e.g.
  must, can, want"""@en ;
  dcterms:modified "2026-06-07T15:30:02.347445Z"^^xsd:dateTime .

oakcurric:keyword-idiom
  a curric:Keyword ;
  schema:name "idiom"@en ;
  schema:description """a phrase or expression whose meaning we don't translate word-for-word, e.g.
  'it's raining cats and dogs'"""@en ;
  dcterms:modified "2026-06-07T15:30:02.347478Z"^^xsd:dateTime .

oakcurric:keyword-agency
  a curric:Keyword ;
  schema:name "agency"@en ;
  schema:description """the capacity of an individual to act independently from others and to make
  their own free choices"""@en ;
  dcterms:modified "2026-06-07T15:30:02.347483Z"^^xsd:dateTime .

oakcurric:keyword-passive
  a curric:Keyword ;
  schema:name "passive"@en ;
  schema:description """not acting to influence or change a situation; allowing other people to be
  in control"""@en ;
  dcterms:modified "2026-06-07T15:30:02.347491Z"^^xsd:dateTime .

oakcurric:keyword-dictating
  a curric:Keyword ;
  schema:name "dictating"@en ;
  schema:description "to give orders, or tell someone exactly what they must do"@en ;
  dcterms:modified "2026-06-07T15:30:02.347496Z"^^xsd:dateTime .

oakcurric:keyword-sonnet
  a curric:Keyword ;
  schema:name "sonnet"@en ;
  schema:description """a poetic form consisting of 14 lines, written in iambic pentameter,
  typically on the topic of love"""@en ;
  dcterms:modified "2026-06-07T15:30:02.347521Z"^^xsd:dateTime .

oakcurric:keyword-foreshadow
  a curric:Keyword ;
  schema:name "foreshadow"@en ;
  schema:description "a sign of something that will happen in the future"@en ;
  dcterms:modified "2026-06-07T15:30:02.347526Z"^^xsd:dateTime .

oakcurric:keyword-symbolism
  a curric:Keyword ;
  schema:name "symbolism"@en ;
  schema:description """figurative language where something is used to represent something other
  than its literal meaning"""@en ;
  dcterms:modified "2026-06-07T15:30:02.347530Z"^^xsd:dateTime .

oakcurric:keyword-tragedy
  a curric:Keyword ;
  schema:name "tragedy"@en ;
  schema:description "a play dealing with tragic events and often ends with a death"@en ;
  dcterms:modified "2026-06-07T15:30:02.347535Z"^^xsd:dateTime .

oakcurric:keyword-plosive
  a curric:Keyword ;
  schema:name "plosive"@en ;
  schema:description """sounds articulated with an abrupt release of air like ‘d’, ‘p’, ‘b’,
  or ‘t’"""@en ;
  dcterms:modified "2026-06-07T15:30:02.347540Z"^^xsd:dateTime .

oakcurric:keyword-machiavellian
  a curric:Keyword ;
  schema:name "Machiavellian"@en ;
  schema:description """Machiavellian is an adjective. It describes someone who gets what they want
  in cunning, ruthless and immoral ways."""@en ;
  dcterms:modified "2026-06-07T15:30:02.347544Z"^^xsd:dateTime .

oakcurric:keyword-thesis
  a curric:Keyword ;
  schema:name "Thesis"@en ;
  schema:description """A thesis is an argument, a powerful idea that you state at the beginning of
  an essay and prove throughout your essay."""@en ;
  dcterms:modified "2026-06-07T15:30:02.347552Z"^^xsd:dateTime .

oakcurric:keyword-embedded-quotation
  a curric:Keyword ;
  schema:name "Embedded quotation"@en ;
  schema:description """An embedded quotation puts a quotation inside your own sentence. For
  example: Lady Macbeth wants to be filled with ‘direst cruelty’."""@en ;
  dcterms:modified "2026-06-07T15:30:02.347559Z"^^xsd:dateTime .

oakcurric:keyword-methods
  a curric:Keyword ;
  schema:name "Methods"@en ;
  schema:description """Methods are techniques a writer uses. These encompass everything: language,
  form, structure and characterisation."""@en ;
  dcterms:modified "2026-06-07T15:30:02.347566Z"^^xsd:dateTime .

oakcurric:keyword-context
  a curric:Keyword ;
  schema:name "Context"@en ;
  schema:description """Context concerns the circumstances in which a text was written; context
  helps us to understand the writer’s intentions further."""@en ;
  dcterms:modified "2026-06-07T15:30:02.347571Z"^^xsd:dateTime .

oakcurric:keyword-unethical
  a curric:Keyword ;
  schema:name "unethical"@en ;
  schema:description "acting against moral principles or accepted standards of conduct"@en ;
  dcterms:modified "2026-06-07T15:30:02.347575Z"^^xsd:dateTime .

oakcurric:keyword-archetype
  a curric:Keyword ;
  schema:name "archetype"@en ;
  schema:description """typical example or original model of a character, theme or pattern in
  literature and art"""@en ;
  dcterms:modified "2026-06-07T15:30:02.347580Z"^^xsd:dateTime .

oakcurric:keyword-transcend
  a curric:Keyword ;
  schema:name "transcend"@en ;
  schema:description """rise above or go beyond limits, often in terms of understanding or
  experience"""@en ;
  dcterms:modified "2026-06-07T15:30:02.347585Z"^^xsd:dateTime .

oakcurric:keyword-unchecked
  a curric:Keyword ;
  schema:name "unchecked"@en ;
  schema:description "not restrained, controlled, or regulated"@en ;
  dcterms:modified "2026-06-07T15:30:02.347590Z"^^xsd:dateTime .

oakcurric:keyword-succumb
  a curric:Keyword ;
  schema:name "succumb"@en ;
  schema:description "give in to pressure, temptation or weakness; to yield or surrender"@en ;
  dcterms:modified "2026-06-07T15:30:02.347597Z"^^xsd:dateTime .

oakcurric:keyword-literal
  a curric:Keyword ;
  schema:name "literal"@en ;
  schema:description "factual, exact"@en ;
  dcterms:modified "2026-06-07T15:30:02.347601Z"^^xsd:dateTime .

oakcurric:keyword-figurative-language
  a curric:Keyword ;
  schema:name "figurative language"@en ;
  schema:description "non-literal words and phrases which develop a writer’s meaning"@en ;
  dcterms:modified "2026-06-07T15:30:02.347606Z"^^xsd:dateTime .

oakcurric:keyword-celestial
  a curric:Keyword ;
  schema:name "celestial"@en ;
  schema:description "belonging or relating to heaven"@en ;
  dcterms:modified "2026-06-07T15:30:02.347611Z"^^xsd:dateTime .

oakcurric:keyword-manna
  a curric:Keyword ;
  schema:name "manna"@en ;
  schema:description """in the Bible, this was food that God provided to the Israelites to sustain
  them during 40 years in the wilderness"""@en ;
  dcterms:modified "2026-06-07T15:30:02.347616Z"^^xsd:dateTime .

oakcurric:keyword-ambrosia
  a curric:Keyword ;
  schema:name "ambrosia"@en ;
  schema:description "food of the Greek and Roman gods"@en ;
  dcterms:modified "2026-06-07T15:30:02.347621Z"^^xsd:dateTime .

oakcurric:keyword-open-letter
  a curric:Keyword ;
  schema:name "open letter"@en ;
  schema:description """a letter written to a particular person or group but which is published in a
  newspaper or journal so the public can read it"""@en ;
  dcterms:modified "2026-06-07T15:30:02.347625Z"^^xsd:dateTime .

oakcurric:keyword-tenacious
  a curric:Keyword ;
  schema:name "tenacious"@en ;
  schema:description "to not give up easily"@en ;
  dcterms:modified "2026-06-07T15:30:02.347630Z"^^xsd:dateTime .

oakcurric:keyword-credible
  a curric:Keyword ;
  schema:name "credible"@en ;
  schema:description "convincing, trustworthy, reliable"@en ;
  dcterms:modified "2026-06-07T15:30:02.347637Z"^^xsd:dateTime .

oakcurric:keyword-meticulously
  a curric:Keyword ;
  schema:name "meticulously"@en ;
  schema:description "thoroughly, with attention to every detail"@en ;
  dcterms:modified "2026-06-07T15:30:02.347642Z"^^xsd:dateTime .

oakcurric:keyword-hoax
  a curric:Keyword ;
  schema:name "hoax"@en ;
  schema:description "a plan to deceive someone"@en ;
  dcterms:modified "2026-06-07T15:30:02.347647Z"^^xsd:dateTime .

oakcurric:keyword-anecdote
  a curric:Keyword ;
  schema:name "anecdote"@en ;
  schema:description "a short, often funny story, especially about something someone has done"@en ;
  dcterms:modified "2026-06-07T15:30:02.347651Z"^^xsd:dateTime .

oakcurric:keyword-parody
  a curric:Keyword ;
  schema:name "parody"@en ;
  schema:description """work that imitates and humorously exaggerates the style of something
  famous"""@en ;
  dcterms:modified "2026-06-07T15:30:02.347658Z"^^xsd:dateTime .

oakcurric:keyword-counterargument
  a curric:Keyword ;
  schema:name "counterargument"@en ;
  schema:description "an argument against another argument, idea, or suggestion"@en ;
  dcterms:modified "2026-06-07T15:30:02.347663Z"^^xsd:dateTime .

oakcurric:keyword-call-to-action
  a curric:Keyword ;
  schema:name "call to action"@en ;
  schema:description "writing that asks or encourages people to take action about a problem"@en ;
  dcterms:modified "2026-06-07T15:30:02.347668Z"^^xsd:dateTime .

oakcurric:keyword-motif
  a curric:Keyword ;
  schema:name "motif"@en ;
  schema:description "a short melodic idea that recurs throughout a piece of music"@en ;
  dcterms:modified "2026-06-07T15:30:02.347684Z"^^xsd:dateTime .

oakcurric:keyword-romanticism
  a curric:Keyword ;
  schema:name "Romanticism"@en ;
  schema:description """an artistic and intellectual movement that originated in Europe towards the
  end of the 18th century"""@en ;
  dcterms:modified "2026-06-07T15:30:02.347699Z"^^xsd:dateTime .

oakcurric:keyword-innocence
  a curric:Keyword ;
  schema:name "innocence"@en ;
  schema:description """the state of being inexperienced, naive, or free from guilt or
  wrongdoing"""@en ;
  dcterms:modified "2026-06-07T15:30:02.347703Z"^^xsd:dateTime .

oakcurric:keyword-institution
  a curric:Keyword ;
  schema:name "institution"@en ;
  schema:description "a large and important organisation"@en ;
  dcterms:modified "2026-06-07T15:30:02.347708Z"^^xsd:dateTime .

oakcurric:keyword-restrictions
  a curric:Keyword ;
  schema:name "restrictions"@en ;
  schema:description "the limitation or control of someone or something"@en ;
  dcterms:modified "2026-06-07T15:30:02.347713Z"^^xsd:dateTime .

oakcurric:keyword-oppression
  a curric:Keyword ;
  schema:name "oppression"@en ;
  schema:description "prolonged cruel or unjust treatment or exercise of authority"@en ;
  dcterms:modified "2026-06-07T15:30:02.347720Z"^^xsd:dateTime .

oakcurric:keyword-unsanitary
  a curric:Keyword ;
  schema:name "unsanitary"@en ;
  schema:description "dirty or unhealthy and therefore likely to cause disease"@en ;
  dcterms:modified "2026-06-07T15:30:02.347760Z"^^xsd:dateTime .

oakcurric:keyword-recede
  a curric:Keyword ;
  schema:name "recede"@en ;
  schema:description """go or move back or further away from a previous position; gradually
  diminish"""@en ;
  dcterms:modified "2026-06-07T15:30:02.347870Z"^^xsd:dateTime .

oakcurric:keyword-ambiguous
  a curric:Keyword ;
  schema:name "ambiguous"@en ;
  schema:description "open to more than one interpretation; not having one obvious meaning"@en ;
  dcterms:modified "2026-06-07T15:30:02.347877Z"^^xsd:dateTime .

oakcurric:keyword-elude
  a curric:Keyword ;
  schema:name "elude"@en ;
  schema:description "(of an achievement or something desired) fail to be achieve by someone"@en ;
  dcterms:modified "2026-06-07T15:30:02.347883Z"^^xsd:dateTime .

oakcurric:keyword-resolution
  a curric:Keyword ;
  schema:name "resolution"@en ;
  schema:description "the process of solving or ending a problem or disagreement"@en ;
  dcterms:modified "2026-06-07T15:30:02.347888Z"^^xsd:dateTime .

oakcurric:keyword-paradox
  a curric:Keyword ;
  schema:name "paradox"@en ;
  schema:description """a statement that seems self-contradictory or absurd but in reality expresses
  a possible truth"""@en ;
