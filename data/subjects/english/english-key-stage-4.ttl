# ----------------------------------------------------------------------
# Key Learning Points
# ----------------------------------------------------------------------

oakcurric:keylearningpoint-lesson-2316-1
  a curric:KeyLearningPoint ;
  rdfs:label "Antrobus’ use of colour imagery suggests nature is full of life and energy."@en ;
  dcterms:modified "2026-02-12T08:59:21.484672Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2316-2
  a curric:KeyLearningPoint ;
  rdfs:label """Antrobus’ use of personification implies nature is able to form connections while man-made objects are not."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484676Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2316-3
  a curric:KeyLearningPoint ;
  rdfs:label """The use of fragmented couplets could suggest that the speaker has yet to form a connection but that they desire one."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484680Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2316-4
  a curric:KeyLearningPoint ;
  rdfs:label """The cyclical structure could show how the speaker’s journey has transformed the way they think about nature and mankind."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484684Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2316-5
  a curric:KeyLearningPoint ;
  rdfs:label """The final line could be a critique of how humans perceive their relationship with nature."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484688Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29496-1
  a curric:KeyLearningPoint ;
  rdfs:label "Armitage says personal writing must convey a specific emotion."@en ;
  dcterms:modified "2026-02-12T08:59:21.486646Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29496-2
  a curric:KeyLearningPoint ;
  rdfs:label """He describes the poem as a "rite of passage" that explores the uncertainty of life transitions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486650Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29496-3
  a curric:KeyLearningPoint ;
  rdfs:label """Armitage identifies "Kite. Anchor" as the most significant part, highlighting its effective ambiguity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486654Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29496-4
  a curric:KeyLearningPoint ;
  rdfs:label """Armitage states that the "space imagery" is "generational", placing the poem in a particular time period."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486658Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29496-5
  a curric:KeyLearningPoint ;
  rdfs:label "Armitage's ideas can help develop interpretations of the poem."@en ;
  dcterms:modified "2026-02-12T08:59:21.486662Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29495-1
  a curric:KeyLearningPoint ;
  rdfs:label """Armitage uses personal perspective, colloquial and vernacular language to ensure accuracy and authenticity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.488231Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29495-2
  a curric:KeyLearningPoint ;
  rdfs:label "He says the most important moment in Remains is the \"blood-shadow\"."@en ;
  dcterms:modified "2026-02-12T08:59:21.488235Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29495-3
  a curric:KeyLearningPoint ;
  rdfs:label """Armitage reveals a tension between the poet and the speaker, emphasising the themes of power and conflict."""@en ;
  dcterms:modified "2026-02-12T08:59:21.488239Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29495-4
  a curric:KeyLearningPoint ;
  rdfs:label """He describes the final lines as "naked" and "vulnerable" illuminating their emotional impact."""@en ;
  dcterms:modified "2026-02-12T08:59:21.488243Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29495-5
  a curric:KeyLearningPoint ;
  rdfs:label "Armitage's ideas can help develop interpretations of the poem."@en ;
  dcterms:modified "2026-02-12T08:59:21.488247Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29494-1
  a curric:KeyLearningPoint ;
  rdfs:label "Armitage highlights the power of writing from a personal perspective."@en ;
  dcterms:modified "2026-02-12T08:59:21.609974Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29494-2
  a curric:KeyLearningPoint ;
  rdfs:label "Armitage believes art should provoke specific emotions."@en ;
  dcterms:modified "2026-02-12T08:59:21.609981Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29494-3
  a curric:KeyLearningPoint ;
  rdfs:label "The structure and form of ‘The Manhunt’ reflect its content."@en ;
  dcterms:modified "2026-02-12T08:59:21.609988Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29494-4
  a curric:KeyLearningPoint ;
  rdfs:label """Armitage identifies the “dark irony” of the foetus metaphor as the most significant part of the poem."""@en ;
  dcterms:modified "2026-02-12T08:59:21.609996Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29494-5
  a curric:KeyLearningPoint ;
  rdfs:label "Armitage’s ideas can help develop interpretations of the poem."@en ;
  dcterms:modified "2026-02-12T08:59:21.610003Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28624-1
  a curric:KeyLearningPoint ;
  rdfs:label "Feeling scared and nervous about public speaking is a shared concern."@en ;
  dcterms:modified "2026-02-12T08:59:21.612671Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28624-2
  a curric:KeyLearningPoint ;
  rdfs:label "Using open body language and an effective posture can help to manage nerves."@en ;
  dcterms:modified "2026-02-12T08:59:21.612678Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28624-3
  a curric:KeyLearningPoint ;
  rdfs:label """Setting your posture before you speak is a good way to prepare and can help you to control your voice and your body."""@en ;
  dcterms:modified "2026-02-12T08:59:21.612685Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28624-4
  a curric:KeyLearningPoint ;
  rdfs:label "Nervousness and excitement share similar traits."@en ;
  dcterms:modified "2026-02-12T08:59:21.612692Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28624-5
  a curric:KeyLearningPoint ;
  rdfs:label "Breathing exercises can help alleviate the physical side of nerves."@en ;
  dcterms:modified "2026-02-12T08:59:21.612699Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6228-1
  a curric:KeyLearningPoint ;
  rdfs:label """When looking for quotations useful for analysis, we need to ensure our evidence is relevant and meaningful."""@en ;
  dcterms:modified "2026-02-12T08:59:21.626151Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6228-2
  a curric:KeyLearningPoint ;
  rdfs:label """Meaningful evidence is language with powerful connotations that you can dig deeper into."""@en ;
  dcterms:modified "2026-02-12T08:59:21.626156Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6228-3
  a curric:KeyLearningPoint ;
  rdfs:label """We can make our language analysis more effective by linking evidence together to support our ideas."""@en ;
  dcterms:modified "2026-02-12T08:59:21.626161Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6228-4
  a curric:KeyLearningPoint ;
  rdfs:label "Actively search for patterns in language to strengthen your language analysis."@en ;
  dcterms:modified "2026-02-12T08:59:21.626166Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1648-1
  a curric:KeyLearningPoint ;
  rdfs:label "Hamartia is a fatal flaw"@en ;
  dcterms:modified "2026-02-12T08:59:21.626171Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1648-2
  a curric:KeyLearningPoint ;
  rdfs:label """You could argue that the hamartia of both Lady Macbeth and her husband is that they are overly ambitious"""@en ;
  dcterms:modified "2026-02-12T08:59:21.626176Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1648-3
  a curric:KeyLearningPoint ;
  rdfs:label "Some will argue that Lady Macbeth's manipulation led to Macbeth's downfall"@en ;
  dcterms:modified "2026-02-12T08:59:21.626185Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1648-4
  a curric:KeyLearningPoint ;
  rdfs:label "Hubris means excessive pride or self-confidence"@en ;
  dcterms:modified "2026-02-12T08:59:21.626191Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1648-5
  a curric:KeyLearningPoint ;
  rdfs:label "Some will argue that Macbeth's hubris leads to his own downfall"@en ;
  dcterms:modified "2026-02-12T08:59:21.626199Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1673-1
  a curric:KeyLearningPoint ;
  rdfs:label """Whilst Jekyll is clearly culpable for the creation of Hyde, arguably others are complicit in his crimes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.626204Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1673-2
  a curric:KeyLearningPoint ;
  rdfs:label "Dr. Lanyon learns the truth but chooses not to expose Jekyll."@en ;
  dcterms:modified "2026-02-12T08:59:21.626209Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1673-3
  a curric:KeyLearningPoint ;
  rdfs:label """Utterson fails to take opportunities to unearth the truth, instead choosing to keep secrets sealed away."""@en ;
  dcterms:modified "2026-02-12T08:59:21.626214Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1673-4
  a curric:KeyLearningPoint ;
  rdfs:label """Through Enfield, and other characters, Stevenson is critical of the hypocrisy of the upper-middle classes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.626219Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2342-1
  a curric:KeyLearningPoint ;
  rdfs:label """The poem explores the conflict between the speaker and society's expectations of her as a woman."""@en ;
  dcterms:modified "2026-02-12T08:59:21.626224Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2342-2
  a curric:KeyLearningPoint ;
  rdfs:label "Victorian women had higher moral expectations placed on them than men."@en ;
  dcterms:modified "2026-02-12T08:59:21.626229Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2342-3
  a curric:KeyLearningPoint ;
  rdfs:label """The speaker in the poem has been caught having sexual relations outside of marriage."""@en ;
  dcterms:modified "2026-02-12T08:59:21.626234Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2342-4
  a curric:KeyLearningPoint ;
  rdfs:label """Women were often considered the property of men at the time the poem was written."""@en ;
  dcterms:modified "2026-02-12T08:59:21.626240Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2342-5
  a curric:KeyLearningPoint ;
  rdfs:label """Rossetti explores Victorian gender roles in the poem, reflecting on the inequality of a patriarchal society."""@en ;
  dcterms:modified "2026-02-12T08:59:21.626247Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2132-1
  a curric:KeyLearningPoint ;
  rdfs:label "Consider using paragraphs to zoom in and out of key details, in your description"@en ;
  dcterms:modified "2026-02-12T08:59:21.626327Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2132-2
  a curric:KeyLearningPoint ;
  rdfs:label "Imagery can be used to link your paragraphs, including semantic fields."@en ;
  dcterms:modified "2026-02-12T08:59:21.626332Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2132-3
  a curric:KeyLearningPoint ;
  rdfs:label """A shift in tone at the end of your description can be used to leave the reader with a sense of foreboding"""@en ;
  dcterms:modified "2026-02-12T08:59:21.626337Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1477-1
  a curric:KeyLearningPoint ;
  rdfs:label """A semantic field is a group of words related in some way. They can be related by meaning or in a more abstract way."""@en ;
  dcterms:modified "2026-02-12T08:59:21.626342Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1477-2
  a curric:KeyLearningPoint ;
  rdfs:label """Writers deliberately use semantic fields to develop their characters in certain ways."""@en ;
  dcterms:modified "2026-02-12T08:59:21.626347Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1477-3
  a curric:KeyLearningPoint ;
  rdfs:label """Writers deliberately use semantic fields to keep an idea present in a reader’s head."""@en ;
  dcterms:modified "2026-02-12T08:59:21.626352Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1477-4
  a curric:KeyLearningPoint ;
  rdfs:label """Effective semantic fields will include a variety of word types including: nouns, adjectives and verbs."""@en ;
  dcterms:modified "2026-02-12T08:59:21.626357Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28644-1
  a curric:KeyLearningPoint ;
  rdfs:label """Stereotypically, night/darkness represents fear and mystery while day/light represents hope and truth."""@en ;
  dcterms:modified "2026-02-12T08:59:21.626362Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28644-2
  a curric:KeyLearningPoint ;
  rdfs:label "However, for Romeo and Juliet, night/darkness represents protection and safety."@en ;
  dcterms:modified "2026-02-12T08:59:21.626367Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28644-3
  a curric:KeyLearningPoint ;
  rdfs:label """Because of this, Shakespeare may be highlighting the transgressive nature of their relationship."""@en ;
  dcterms:modified "2026-02-12T08:59:21.626375Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28644-4
  a curric:KeyLearningPoint ;
  rdfs:label """The image of the “lark” may symbolise that Romeo and Juliet are trapped by circumstances and fate."""@en ;
  dcterms:modified "2026-02-12T08:59:21.626381Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28644-5
  a curric:KeyLearningPoint ;
  rdfs:label "Juliet’s prophetic vision may reveal the inescapable nature of their fate."@en ;
  dcterms:modified "2026-02-12T08:59:21.626386Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28486-1
  a curric:KeyLearningPoint ;
  rdfs:label "Using expert views can add to the credibility of your persuasive writing."@en ;
  dcterms:modified "2026-02-12T08:59:21.626391Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28486-2
  a curric:KeyLearningPoint ;
  rdfs:label """To create a credible expert view, you need to use a recent date for the quotation for relevance."""@en ;
  dcterms:modified "2026-02-12T08:59:21.626399Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28486-3
  a curric:KeyLearningPoint ;
  rdfs:label """To add to the credibility, you also want to use a name of the expert and a job title that is relevant to the topic."""@en ;
  dcterms:modified "2026-02-12T08:59:21.626404Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29090-1
  a curric:KeyLearningPoint ;
  rdfs:label """One way to help you organise poems in an anthology is to sort them into ‘mini-clusters’ by theme."""@en ;
  dcterms:modified "2026-02-12T08:59:21.626409Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29090-2
  a curric:KeyLearningPoint ;
  rdfs:label """When you’re approaching a comparative question, begin by identifying the key theme."""@en ;
  dcterms:modified "2026-02-12T08:59:21.626414Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29090-3
  a curric:KeyLearningPoint ;
  rdfs:label """Once you’ve established the key theme, consider how the named poem responds to the theme."""@en ;
  dcterms:modified "2026-02-12T08:59:21.626419Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29090-4
  a curric:KeyLearningPoint ;
  rdfs:label """To choose a comparative poem, ensure you choose one with an overall similarity but nuanced differences."""@en ;
  dcterms:modified "2026-02-12T08:59:21.626424Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29090-5
  a curric:KeyLearningPoint ;
  rdfs:label "One way to plan your answer is to create a multi-paragraph outline."@en ;
  dcterms:modified "2026-02-12T08:59:21.626429Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1475-1
  a curric:KeyLearningPoint ;
  rdfs:label """Accurate basic punctuation improves clarity; more advanced punctuation can heighten the impact of word choices."""@en ;
  dcterms:modified "2026-02-12T08:59:21.626578Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1475-2
  a curric:KeyLearningPoint ;
  rdfs:label """Advanced punctuation (semi-colons, exclamation marks, ellipses) should be used sparingly for clear effect."""@en ;
  dcterms:modified "2026-02-12T08:59:21.626583Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1475-3
  a curric:KeyLearningPoint ;
  rdfs:label "Proof-reading will help to avoid SPaG errors."@en ;
  dcterms:modified "2026-02-12T08:59:21.626588Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1661-1
  a curric:KeyLearningPoint ;
  rdfs:label "This chapter marks a shift in narrative perspective to first person."@en ;
  dcterms:modified "2026-02-12T08:59:21.626594Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1661-2
  a curric:KeyLearningPoint ;
  rdfs:label "This chapter is written in epistolary form."@en ;
  dcterms:modified "2026-02-12T08:59:21.626599Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1661-3
  a curric:KeyLearningPoint ;
  rdfs:label """Lanyon reveals that he succumbed to his curiosity, tempted by the promise of knowledge."""@en ;
  dcterms:modified "2026-02-12T08:59:21.626604Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1661-4
  a curric:KeyLearningPoint ;
  rdfs:label """At the end of the chapter, the reader learns that Lanyon’s visitor is Hyde, who transforms into Jekyll."""@en ;
  dcterms:modified "2026-02-12T08:59:21.626609Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1664-1
  a curric:KeyLearningPoint ;
  rdfs:label """Gothic fiction is fascinated by strange places, yet Stevenson sets his story in London."""@en ;
  dcterms:modified "2026-02-12T08:59:21.626654Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1664-2
  a curric:KeyLearningPoint ;
  rdfs:label "The figure of Hyde allows Stevenson to explore violent differences in power."@en ;
  dcterms:modified "2026-02-12T08:59:21.626659Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1664-3
  a curric:KeyLearningPoint ;
  rdfs:label """Gothic writing often focuses on irrational or illicit desires; Stevenson conforms to this."""@en ;
  dcterms:modified "2026-02-12T08:59:21.626664Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1664-4
  a curric:KeyLearningPoint ;
  rdfs:label """The uncanny is a key idea within the Gothic and links to duality, but also the human/ inhuman appearance of Hyde."""@en ;
  dcterms:modified "2026-02-12T08:59:21.626671Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1664-5
  a curric:KeyLearningPoint ;
  rdfs:label """Hyde seems to have supernatural powers and strength, conforming to the conventions of the gothic villain."""@en ;
  dcterms:modified "2026-02-12T08:59:21.626677Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2036-1
  a curric:KeyLearningPoint ;
  rdfs:label """Identifying nuances in theme and perspective will construct a purposeful comparison."""@en ;
  dcterms:modified "2026-02-12T08:59:21.626682Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2036-2
  a curric:KeyLearningPoint ;
  rdfs:label """Gather ideas for both texts before planning so you know which evidence you can use."""@en ;
  dcterms:modified "2026-02-12T08:59:21.626687Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2036-3
  a curric:KeyLearningPoint ;
  rdfs:label """Ensure your thesis statement summarises both poems, links to the question and focuses on the entirety of both texts."""@en ;
  dcterms:modified "2026-02-12T08:59:21.626692Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2036-4
  a curric:KeyLearningPoint ;
  rdfs:label "Topic sentences should be specific, precise and express duality."@en ;
  dcterms:modified "2026-02-12T08:59:21.626697Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2036-5
  a curric:KeyLearningPoint ;
  rdfs:label "Evidence should be embedded into analytical paragraphs."@en ;
  dcterms:modified "2026-02-12T08:59:21.626702Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6264-1
  a curric:KeyLearningPoint ;
  rdfs:label "An excellent introduction should start with a general statement about the text."@en ;
  dcterms:modified "2026-02-12T08:59:21.626707Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6264-2
  a curric:KeyLearningPoint ;
  rdfs:label """An introduction should then have a more specific statement about the focus of the question, followed by a thesis."""@en ;
  dcterms:modified "2026-02-12T08:59:21.626712Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6264-3
  a curric:KeyLearningPoint ;
  rdfs:label "Topic sentences need to be clear and linked to the question."@en ;
  dcterms:modified "2026-02-12T08:59:21.626717Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6264-4
  a curric:KeyLearningPoint ;
  rdfs:label """Your analytical paragraphs should contain one main idea and offer supporting detail from your analysis."""@en ;
  dcterms:modified "2026-02-12T08:59:21.626723Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6264-5
  a curric:KeyLearningPoint ;
  rdfs:label """Your conclusion should summarise the argument and perhaps gesture towards wider ideas."""@en ;
  dcterms:modified "2026-02-12T08:59:21.626728Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2434-1
  a curric:KeyLearningPoint ;
  rdfs:label """Mundair uses powerful verbs to describe the experience of isolation felt by the speaker."""@en ;
  dcterms:modified "2026-02-12T08:59:21.626733Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2434-2
  a curric:KeyLearningPoint ;
  rdfs:label """Mundair may use the metaphor “woven tapestries” to refer to how our identities are created by ‘threads’ of life."""@en ;
  dcterms:modified "2026-02-12T08:59:21.626738Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2434-3
  a curric:KeyLearningPoint ;
  rdfs:label """Mundair uses a variation of the ghazal form to, arguably, connect to Indian heritage and thematic links."""@en ;
  dcterms:modified "2026-02-12T08:59:21.626746Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2434-4
  a curric:KeyLearningPoint ;
  rdfs:label """Mundair may have varied the ghazal form to comment on ideas of identity, heritage and belonging."""@en ;
  dcterms:modified "2026-02-12T08:59:21.626751Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2039-1
  a curric:KeyLearningPoint ;
  rdfs:label "Sub-text is the implicit meaning, rather than the explicit meaning."@en ;
  dcterms:modified "2026-02-12T08:59:21.626781Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2039-2
  a curric:KeyLearningPoint ;
  rdfs:label """Understanding what symbols represent can help you to understand the deeper meaning of the poem."""@en ;
  dcterms:modified "2026-02-12T08:59:21.626786Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2039-3
  a curric:KeyLearningPoint ;
  rdfs:label """Personal possessions of loved ones can be used as symbols that represent the person."""@en ;
  dcterms:modified "2026-02-12T08:59:21.626792Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2039-4
  a curric:KeyLearningPoint ;
  rdfs:label """Understanding extended metaphors can help you to understand the sub-text of the poem."""@en ;
  dcterms:modified "2026-02-12T08:59:21.626797Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28976-1
  a curric:KeyLearningPoint ;
  rdfs:label "‘Romeo and Juliet’ opens and ends with acts of violence."@en ;
  dcterms:modified "2026-02-12T08:59:21.626802Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28976-2
  a curric:KeyLearningPoint ;
  rdfs:label "Exposure to violence would have been a reality in Elizabethan England."@en ;
  dcterms:modified "2026-02-12T08:59:21.626807Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28976-3
  a curric:KeyLearningPoint ;
  rdfs:label """By staging the fights in daylight, Shakespeare implies violence was acceptable in society."""@en ;
  dcterms:modified "2026-02-12T08:59:21.626812Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28976-4
  a curric:KeyLearningPoint ;
  rdfs:label "Honour was a central aspect of men’s identities in Elizabethan England."@en ;
  dcterms:modified "2026-02-12T08:59:21.626817Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28976-5
  a curric:KeyLearningPoint ;
  rdfs:label "Arguably, we might see honour as something that must be proven in public."@en ;
  dcterms:modified "2026-02-12T08:59:21.626822Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28636-1
  a curric:KeyLearningPoint ;
  rdfs:label """Our first impressions of Benvolio imply that he will play the role of the peace-maker in the play."""@en ;
  dcterms:modified "2026-02-12T08:59:21.626827Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28636-2
  a curric:KeyLearningPoint ;
  rdfs:label """Our first impressions of Mercutio suggest that he will be a character who provides comic relief."""@en ;
  dcterms:modified "2026-02-12T08:59:21.626832Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28636-3
  a curric:KeyLearningPoint ;
  rdfs:label """Benvolio and Mercutio’s advice to Romeo suggests that they don’t see love as emotional whereas Romeo does."""@en ;
  dcterms:modified "2026-02-12T08:59:21.626837Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28636-4
  a curric:KeyLearningPoint ;
  rdfs:label "Mercutio’s ‘Queen Mab’ speech suggests that dreams are merely wish-fulfillment."@en ;
  dcterms:modified "2026-02-12T08:59:21.626843Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28636-5
  a curric:KeyLearningPoint ;
  rdfs:label "Romeo’s prophetic dream suggests that we cannot escape our fate."@en ;
  dcterms:modified "2026-02-12T08:59:21.626848Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29028-1
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, the male characters conform to Edwardian ideals of masculinity, emphasising strength, control, and dominance."""@en ;
  dcterms:modified "2026-02-12T08:59:21.626853Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29028-2
  a curric:KeyLearningPoint ;
  rdfs:label """Authority is asserted by male characters, often over women and lower-class individuals, reflecting societal norms."""@en ;
  dcterms:modified "2026-02-12T08:59:21.626858Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29028-3
  a curric:KeyLearningPoint ;
  rdfs:label """Gender roles in the play highlight power imbalances and reinforce Priestley’s critique of Edwardian societal norms."""@en ;
  dcterms:modified "2026-02-12T08:59:21.626865Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29028-4
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, male characters struggle with societal expectations, revealing internal conflicts and complex motivations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.626870Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2448-1
  a curric:KeyLearningPoint ;
  rdfs:label "Scrooge is portrayed as a miser"@en ;
  dcterms:modified "2026-02-12T08:59:21.626892Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2448-2
  a curric:KeyLearningPoint ;
  rdfs:label """Dickens experienced poverty firsthand and dedicated his life to campaigning for better legislation to support the poor"""@en ;
  dcterms:modified "2026-02-12T08:59:21.626897Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2448-3
  a curric:KeyLearningPoint ;
  rdfs:label "Dickens uses the setting of Scrooge's lodgings to reflect his miserly nature"@en ;
  dcterms:modified "2026-02-12T08:59:21.626905Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2448-4
  a curric:KeyLearningPoint ;
  rdfs:label "Dickens is critical towards those who lack compassion for the poor, like Scrooge"@en ;
  dcterms:modified "2026-02-12T08:59:21.626910Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2448-5
  a curric:KeyLearningPoint ;
  rdfs:label """Scrooge represents selfish and greedy upper-middle class Victorian citizens, who showed little empathy for the poor"""@en ;
  dcterms:modified "2026-02-12T08:59:21.626917Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2307-1
  a curric:KeyLearningPoint ;
  rdfs:label """Viv’s relationship with the formal education system changes over the course of the play."""@en ;
  dcterms:modified "2026-02-12T08:59:21.626925Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2307-2
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, Brod acts as a catalyst for Viv’s questioning of what she is being taught in school."""@en ;
  dcterms:modified "2026-02-12T08:59:21.626931Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2307-3
  a curric:KeyLearningPoint ;
  rdfs:label "Viv quotes from Shakespeare and Rupert Brooke in Scene Two."@en ;
  dcterms:modified "2026-02-12T08:59:21.626936Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2307-4
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, through Viv’s quotations, Pinnock is asking us to consider the Eurocentric nature of Viv’s schooling."""@en ;
  dcterms:modified "2026-02-12T08:59:21.626941Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2307-5
  a curric:KeyLearningPoint ;
  rdfs:label """Viv’s studying Black Studies at uni could suggest she will find the next step of her formal education more fulfilling."""@en ;
  dcterms:modified "2026-02-12T08:59:21.626946Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2105-1
  a curric:KeyLearningPoint ;
  rdfs:label "Writers use dialogue for a number of purposes."@en ;
  dcterms:modified "2026-02-12T08:59:21.626951Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2105-2
  a curric:KeyLearningPoint ;
  rdfs:label """Dialogue can reveal the motivations, feelings and the relationship between characters."""@en ;
  dcterms:modified "2026-02-12T08:59:21.626957Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2105-3
  a curric:KeyLearningPoint ;
  rdfs:label "Dialogue can also move the plot forward, build tension and illustrate the theme."@en ;
  dcterms:modified "2026-02-12T08:59:21.626962Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2105-4
  a curric:KeyLearningPoint ;
  rdfs:label "Using questions as prompts can help generate ideas for your writing."@en ;
  dcterms:modified "2026-02-12T08:59:21.626969Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2055-1
  a curric:KeyLearningPoint ;
  rdfs:label """A comparative introduction should use correlatives and comparatives in order to create links between ideas."""@en ;
  dcterms:modified "2026-02-12T08:59:21.626990Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2055-2
  a curric:KeyLearningPoint ;
  rdfs:label """A comparative introduction might offer smaller variations in a wider similarity between poems."""@en ;
  dcterms:modified "2026-02-12T08:59:21.626995Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2055-3
  a curric:KeyLearningPoint ;
  rdfs:label "A comparative introduction might offer nuanced differences between poems."@en ;
  dcterms:modified "2026-02-12T08:59:21.627000Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2055-4
  a curric:KeyLearningPoint ;
  rdfs:label """Effective analytical writing may include: active voice, tentative language, and explanation of ideas."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627005Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2055-5
  a curric:KeyLearningPoint ;
  rdfs:label "Less successful analytical writing may include passive voice and repetition."@en ;
  dcterms:modified "2026-02-12T08:59:21.627010Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2090-1
  a curric:KeyLearningPoint ;
  rdfs:label """Stories might have an impact on someone's life by changing their perspective, or revealing something about humanity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627195Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2090-2
  a curric:KeyLearningPoint ;
  rdfs:label """All stories are composed of five different elements: exposition, rising action, climax, falling action and denouement."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627199Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2090-3
  a curric:KeyLearningPoint ;
  rdfs:label """In order to write an effective opening, we need to know the rest of the narrative to set up the atmosphere."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627205Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1649-1
  a curric:KeyLearningPoint ;
  rdfs:label "Shakespeare's presentation of Lady Macbeth could appear revolutionary"@en ;
  dcterms:modified "2026-02-12T08:59:21.627210Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1649-2
  a curric:KeyLearningPoint ;
  rdfs:label """However, the play could also serve to warn women not to disobey the social order and the patriarchy"""@en ;
  dcterms:modified "2026-02-12T08:59:21.627215Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1649-3
  a curric:KeyLearningPoint ;
  rdfs:label "Interpretations which regard Lady Macbeth as evil can be rooted in misogyny"@en ;
  dcterms:modified "2026-02-12T08:59:21.627220Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1460-1
  a curric:KeyLearningPoint ;
  rdfs:label """Using predictive reading skills before you read a text can help you understand more complex texts."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627225Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1460-2
  a curric:KeyLearningPoint ;
  rdfs:label """When reading a text for the first time, you won’t necessarily understand every word and idea."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627230Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1460-3
  a curric:KeyLearningPoint ;
  rdfs:label """Making short annotations as you read can help you develop an understanding of a text."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627235Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1460-4
  a curric:KeyLearningPoint ;
  rdfs:label "When comparing two texts, using words like ‘more’ or ‘less’ can be helpful."@en ;
  dcterms:modified "2026-02-12T08:59:21.627240Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1693-1
  a curric:KeyLearningPoint ;
  rdfs:label """The poem is written in dactylic dimeter which echoes the forceful sound of horses galloping."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627245Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1693-2
  a curric:KeyLearningPoint ;
  rdfs:label """The ballad contains a refrain, which could highlight the inevitability or scale of the tragedy."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627250Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1693-3
  a curric:KeyLearningPoint ;
  rdfs:label """Tennyson personifies death to create a sense of foreboding, emphasising the vicious attack the soldiers faced."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627255Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1693-4
  a curric:KeyLearningPoint ;
  rdfs:label """Tennyson alludes to Psalm 23, perhaps to criticise those in power who did not fulfil their duty to protect."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627260Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1693-5
  a curric:KeyLearningPoint ;
  rdfs:label """The semantic field changes from that of danger and death to that of honour, bravery and heroism in the final stanza."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627265Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1692-1
  a curric:KeyLearningPoint ;
  rdfs:label """The poem documents the lightly armed British cavalry receiving a "blunder'd" order and charging into enemy fire."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627270Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1692-2
  a curric:KeyLearningPoint ;
  rdfs:label """Tennyson urges remembrance of the soldiers' actions, but also highlights the oversight that led to their deaths."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627280Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1692-3
  a curric:KeyLearningPoint ;
  rdfs:label """Poet Laureate was an appointment made by the monarch and Tennyson was appointed to this position in 1850."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627288Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1692-4
  a curric:KeyLearningPoint ;
  rdfs:label """Tennyson’s role as Poet Laureate may have affected how he would have written about the Battle of Balaclava."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627293Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1692-5
  a curric:KeyLearningPoint ;
  rdfs:label """Tennyson's glorification of their bravery and use of euphemisms may have reflected his national duty."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627298Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2483-1
  a curric:KeyLearningPoint ;
  rdfs:label """Barrett Browning uses an extended metaphor of vines to convey how separation in a relationship can be corruptive."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627303Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2483-2
  a curric:KeyLearningPoint ;
  rdfs:label """She uses natural imagery to reveal how reunification can be rejuvenating in a relationship."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627308Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2483-3
  a curric:KeyLearningPoint ;
  rdfs:label """She uses declaratives and imperatives to convey her urgency to be reunified with her lover."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627313Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2483-4
  a curric:KeyLearningPoint ;
  rdfs:label """She uses exclamatory sentences to suggest the speaker finds the intensity of her thoughts emotionally overwhelming."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627318Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2483-5
  a curric:KeyLearningPoint ;
  rdfs:label "She uses euphemistic language to convey her sexual and physical desire."@en ;
  dcterms:modified "2026-02-12T08:59:21.627324Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2476-1
  a curric:KeyLearningPoint ;
  rdfs:label "Hardy recalls a devastating moment of separation in a romantic relationship."@en ;
  dcterms:modified "2026-02-12T08:59:21.627329Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2476-2
  a curric:KeyLearningPoint ;
  rdfs:label "The desolate setting reflects the speakers despairing and hopeless emotions."@en ;
  dcterms:modified "2026-02-12T08:59:21.627334Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2476-3
  a curric:KeyLearningPoint ;
  rdfs:label """The speaker's love for the subject seems to have been unrequited at the end of their relationship."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627339Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2476-4
  a curric:KeyLearningPoint ;
  rdfs:label """At the end of the poem the speaker shifts to the present tense to reflect the enduring impact of the separation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627344Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2476-5
  a curric:KeyLearningPoint ;
  rdfs:label """The poem could reflect Hardy's unconventional and pessimistic view of romantic love."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627352Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29027-1
  a curric:KeyLearningPoint ;
  rdfs:label "Priestley initially presents Sheila as naive and entitled."@en ;
  dcterms:modified "2026-02-12T08:59:21.627358Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29027-2
  a curric:KeyLearningPoint ;
  rdfs:label "Other characters infantilise Sheila and try to protect her from the truth"@en ;
  dcterms:modified "2026-02-12T08:59:21.627363Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29027-3
  a curric:KeyLearningPoint ;
  rdfs:label """The treatment of Sheila conforms to the gender expectations of Edwardian society."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627368Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29027-4
  a curric:KeyLearningPoint ;
  rdfs:label """Sheila's journey in the play leads her to challenge and defy societal expectations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627373Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29027-5
  a curric:KeyLearningPoint ;
  rdfs:label """Sheila arguably begins to subvert the traditional expectations of class and gender by the end of the play."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627381Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2381-1
  a curric:KeyLearningPoint ;
  rdfs:label "‘A Christmas Carol’ can be considered a hopeful tale about redemption."@en ;
  dcterms:modified "2026-02-12T08:59:21.627455Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2381-2
  a curric:KeyLearningPoint ;
  rdfs:label """The novella teaches us about the importance of social responsibility, empathy, generosity and charity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627481Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2381-3
  a curric:KeyLearningPoint ;
  rdfs:label """Dickens outlines the key virtues and values required to create a fairer and more equal society."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627486Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2381-4
  a curric:KeyLearningPoint ;
  rdfs:label "A detailed essay constantly links back to the writer’s methods and intentions."@en ;
  dcterms:modified "2026-02-12T08:59:21.627491Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2381-5
  a curric:KeyLearningPoint ;
  rdfs:label "A coherent, conceptualised response follows the same line of argument."@en ;
  dcterms:modified "2026-02-12T08:59:21.627498Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2548-1
  a curric:KeyLearningPoint ;
  rdfs:label "Poems can be linked by theme e.g. nostalgia."@en ;
  dcterms:modified "2026-02-12T08:59:21.627503Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2548-2
  a curric:KeyLearningPoint ;
  rdfs:label """Poems can be linked by attitude, considering how the poets feel about the subject they are addressing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627508Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2548-3
  a curric:KeyLearningPoint ;
  rdfs:label """Poems can be connected by how poets use similar imagery or techniques to address different issues."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627513Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2548-4
  a curric:KeyLearningPoint ;
  rdfs:label """Correlative and comparative conjunctions are useful for signposting the similarities and differences between poems."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627518Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6227-1
  a curric:KeyLearningPoint ;
  rdfs:label "We can use context to help us make predictions about the text."@en ;
  dcterms:modified "2026-02-12T08:59:21.627523Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6227-2
  a curric:KeyLearningPoint ;
  rdfs:label """We can use other words in the sentence to help us clarify meaning of words or sentences you do not understand."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627528Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6227-3
  a curric:KeyLearningPoint ;
  rdfs:label """Considering the questions that arise as we read and looking for hints at the answers, deepens our understanding."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627533Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6227-4
  a curric:KeyLearningPoint ;
  rdfs:label """To demonstrate our comprehension, we need to be able to summarise what we have read."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627538Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6227-5
  a curric:KeyLearningPoint ;
  rdfs:label "Picking out relevant quotes can demonstrate our comprehension of a text."@en ;
  dcterms:modified "2026-02-12T08:59:21.627543Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28645-1
  a curric:KeyLearningPoint ;
  rdfs:label """Initially, Lord Capulet appears to subvert patriarchal norms through suggesting he wants Juliet’s “consent” to marry."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627548Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28645-2
  a curric:KeyLearningPoint ;
  rdfs:label "However, this is undermined through Juliet’s absence and lack of knowledge."@en ;
  dcterms:modified "2026-02-12T08:59:21.627553Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28645-3
  a curric:KeyLearningPoint ;
  rdfs:label """Lord Capulet’s response to Juliet in Act 3, Scene 5 implies that daughters were supposed to obey their fathers."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627558Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28645-4
  a curric:KeyLearningPoint ;
  rdfs:label """Juliet, Lady Capulet and the Nurse’s response in Act 3, Scene 5 convey the powerlessness of women."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627562Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2319-1
  a curric:KeyLearningPoint ;
  rdfs:label """Each of the ghosts’ entrances is symbolic of the stage Scrooge is at in his transformation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627708Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2319-2
  a curric:KeyLearningPoint ;
  rdfs:label """The earlier ghosts (Marley’s Ghost and The Ghost of Christmas Past) have to enter Scrooge’s world forcefully."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627713Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2319-3
  a curric:KeyLearningPoint ;
  rdfs:label """The earlier ghosts' forced entrances are necessary because Scrooge wouldn’t help himself - he needs this intervention."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627720Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2319-4
  a curric:KeyLearningPoint ;
  rdfs:label """The later ghosts are sought out by Scrooge, which shows his newfound willingness to learn and be introspective."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627725Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2319-5
  a curric:KeyLearningPoint ;
  rdfs:label """The ghosts’ exits are also very significant - they reflect the purposes and the characters of the ghosts."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627730Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1470-1
  a curric:KeyLearningPoint ;
  rdfs:label "Considering structural features is an important part of the writing process."@en ;
  dcterms:modified "2026-02-12T08:59:21.627782Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1470-2
  a curric:KeyLearningPoint ;
  rdfs:label "Openings should be impactful and can include declarative sentences and similes."@en ;
  dcterms:modified "2026-02-12T08:59:21.627787Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1470-3
  a curric:KeyLearningPoint ;
  rdfs:label "Mirroring can be used to create an effective closing."@en ;
  dcterms:modified "2026-02-12T08:59:21.627792Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1470-4
  a curric:KeyLearningPoint ;
  rdfs:label "Using a motif can engage a reader and emphasise the viewpoint in your writing."@en ;
  dcterms:modified "2026-02-12T08:59:21.627797Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2123-1
  a curric:KeyLearningPoint ;
  rdfs:label "Inverted sentence structures add variety to your writing."@en ;
  dcterms:modified "2026-02-12T08:59:21.627875Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2123-2
  a curric:KeyLearningPoint ;
  rdfs:label "Inverted sentence structures also draw attention to moments or ideas."@en ;
  dcterms:modified "2026-02-12T08:59:21.627880Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2123-3
  a curric:KeyLearningPoint ;
  rdfs:label "Chiasmus is an X-shaped sentence structure."@en ;
  dcterms:modified "2026-02-12T08:59:21.627888Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2123-4
  a curric:KeyLearningPoint ;
  rdfs:label """Chiasmus takes the clause from the first half of a sentence and repeats and reverses it in the second one."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627893Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2123-5
  a curric:KeyLearningPoint ;
  rdfs:label "Chiasmus creates a sense of completion and is often euphonious."@en ;
  dcterms:modified "2026-02-12T08:59:21.627897Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9256-1
  a curric:KeyLearningPoint ;
  rdfs:label """Perhaps Dickinson uses light imagery in her poem to represent hope within the darkness of grief."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627905Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9256-2
  a curric:KeyLearningPoint ;
  rdfs:label """The cyclical nature of her poem illustrates that life, and grief, come and go - a natural process."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627910Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9256-3
  a curric:KeyLearningPoint ;
  rdfs:label """Dickinson uses a regular rhythm to represent the predictability of the passing of time."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627915Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9256-4
  a curric:KeyLearningPoint ;
  rdfs:label """Subtle shifts in rhythm and near rhyme could represent the imperceptibility of time passing and healing from grieving."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627920Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2392-1
  a curric:KeyLearningPoint ;
  rdfs:label "Single paragraph outlines can be used to create effective plans."@en ;
  dcterms:modified "2026-02-12T08:59:21.627925Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2392-2
  a curric:KeyLearningPoint ;
  rdfs:label """Topic and concluding sentences should use rhetorical devices carefully for greatest impact."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627930Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2392-3
  a curric:KeyLearningPoint ;
  rdfs:label """Concluding sentences should link to topic sentences and create links between sections."""@en ;
  dcterms:modified "2026-02-12T08:59:21.627937Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2392-4
  a curric:KeyLearningPoint ;
  rdfs:label "Introductions and conclusions should be engaging and impactful."@en ;
  dcterms:modified "2026-02-12T08:59:21.627942Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1481-1
  a curric:KeyLearningPoint ;
  rdfs:label "Use a variety of strategies to vary how you start sentences."@en ;
  dcterms:modified "2026-02-12T08:59:21.628394Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1481-2
  a curric:KeyLearningPoint ;
  rdfs:label "You can create sophisticated semantic fields based on abstract nouns."@en ;
  dcterms:modified "2026-02-12T08:59:21.628399Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1481-3
  a curric:KeyLearningPoint ;
  rdfs:label """You can add emphasis, change pace or heighten emotion by using advanced punctuation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628404Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2011-1
  a curric:KeyLearningPoint ;
  rdfs:label "Shakespeare’s tragedies often focus on the fall of noblemen"@en ;
  dcterms:modified "2026-02-12T08:59:21.628409Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2011-2
  a curric:KeyLearningPoint ;
  rdfs:label """Shakespearean tragic heroes such as Macbeth, often fall victim to external pressures"""@en ;
  dcterms:modified "2026-02-12T08:59:21.628414Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2011-3
  a curric:KeyLearningPoint ;
  rdfs:label "Some audiences may feel catharsis by Macbeth’s downfall"@en ;
  dcterms:modified "2026-02-12T08:59:21.628419Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2011-4
  a curric:KeyLearningPoint ;
  rdfs:label """Tragedies tend to stress the consequences of disobeying the accepted order of things"""@en ;
  dcterms:modified "2026-02-12T08:59:21.628424Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2011-5
  a curric:KeyLearningPoint ;
  rdfs:label "Freytag's pyramid is a useful tool in discussing the structure of Macbeth"@en ;
  dcterms:modified "2026-02-12T08:59:21.628428Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2009-1
  a curric:KeyLearningPoint ;
  rdfs:label """Many different leaders have leadership qualities, although not all use them for good."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628433Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2009-2
  a curric:KeyLearningPoint ;
  rdfs:label "Using textual and real life examples can challenge and develop arguments."@en ;
  dcterms:modified "2026-02-12T08:59:21.628438Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2009-3
  a curric:KeyLearningPoint ;
  rdfs:label """Using critical quotations is an effective way to develop and elevate an argument."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628443Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2009-4
  a curric:KeyLearningPoint ;
  rdfs:label "Critical quotations should be used sparingly."@en ;
  dcterms:modified "2026-02-12T08:59:21.628448Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2009-5
  a curric:KeyLearningPoint ;
  rdfs:label """Orwell does not present "good" and "bad" leaders, rather he explores the relationship between leadership and power."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628453Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2320-1
  a curric:KeyLearningPoint ;
  rdfs:label """Dickens uses Gothic conventions as a way to greater explore immoral behaviour in society."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628458Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2320-2
  a curric:KeyLearningPoint ;
  rdfs:label """Scrooge could be viewed as a typical Gothic protagonist: isolated and egotistical."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628463Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2320-3
  a curric:KeyLearningPoint ;
  rdfs:label """Scrooge can be said to be in a liminal state of his metamorphosis for much of the novella."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628470Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2320-4
  a curric:KeyLearningPoint ;
  rdfs:label """There are many examples of battles between good and evil (or moral and immoral) in the text."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628478Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2320-5
  a curric:KeyLearningPoint ;
  rdfs:label """The gothic genre gives Dickens a great backdrop within which to frame his message of social responsibility."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628483Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2324-1
  a curric:KeyLearningPoint ;
  rdfs:label """When given a question that asks you ‘how’ something is done, your primary aim is to examine the writer’s use of methods."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628644Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2324-2
  a curric:KeyLearningPoint ;
  rdfs:label """You should always link your ideas back to the question focus and explain how your ideas support your argument."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628649Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2324-3
  a curric:KeyLearningPoint ;
  rdfs:label """Your analysis should be explorative - you should explain the effects of the writer’s methods - not just identify them."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628656Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2324-4
  a curric:KeyLearningPoint ;
  rdfs:label "Your essay should be precise and specific."@en ;
  dcterms:modified "2026-02-12T08:59:21.628662Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2324-5
  a curric:KeyLearningPoint ;
  rdfs:label """Using subject terminology and key vocabulary can help make your writing clearer and more specific."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628667Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2462-1
  a curric:KeyLearningPoint ;
  rdfs:label """Dickens uses colour symbolism and extended metaphors to characterise Scrooge and Fred as opposite characters."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628701Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2462-2
  a curric:KeyLearningPoint ;
  rdfs:label """Scrooge is likened to the cold, whereas Fred is described as ‘ruddy’, ‘handsome’ and warm."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628706Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2462-3
  a curric:KeyLearningPoint ;
  rdfs:label "Fred exemplifies Christmas spirit, empathy and goodwill."@en ;
  dcterms:modified "2026-02-12T08:59:21.628711Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2462-4
  a curric:KeyLearningPoint ;
  rdfs:label """Through showing us Scrooge through the eyes of Fred, we learn the importance of humour and empathy."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628716Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2462-5
  a curric:KeyLearningPoint ;
  rdfs:label """Seeing Fred's Christmas party causes Scrooge to 'soften', showing his moral progress."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628720Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6245-1
  a curric:KeyLearningPoint ;
  rdfs:label """The pilot’s national duty, reflected by the patriotic imagery and rigid stanzas, is to complete a sacrificial mission."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628781Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6245-2
  a curric:KeyLearningPoint ;
  rdfs:label """The pilot chooses to abide by his personal duty to experience the beauty of life in the present moment."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628786Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6245-3
  a curric:KeyLearningPoint ;
  rdfs:label """The use of perspective and pronouns reflects society’s attitudes to the pilot’s decision to turn back."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628791Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6245-4
  a curric:KeyLearningPoint ;
  rdfs:label "Abundant natural imagery reflects the allure and power of nature."@en ;
  dcterms:modified "2026-02-12T08:59:21.628796Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6245-5
  a curric:KeyLearningPoint ;
  rdfs:label """Nature is shown to have a more powerful grip on the pilot than the incantations of propaganda."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628801Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6230-1
  a curric:KeyLearningPoint ;
  rdfs:label """Using an omniscient perspective allows the reader to be more immersed in a scene description."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628806Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6230-2
  a curric:KeyLearningPoint ;
  rdfs:label """An unusual choice of narrative perspective can make your omniscient perspective more engaging."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628811Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6230-3
  a curric:KeyLearningPoint ;
  rdfs:label "An extended metaphor is an opportunity to add detail and depth to writing."@en ;
  dcterms:modified "2026-02-12T08:59:21.628815Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6230-4
  a curric:KeyLearningPoint ;
  rdfs:label """An extended metaphor is most effective, when explored in multiple layers, e.g. using comparison and personification."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628820Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1644-1
  a curric:KeyLearningPoint ;
  rdfs:label """In Act 2, Scene 2, the audience might interpret some aspects of Lady Macbeth's characterisation as vulnerable"""@en ;
  dcterms:modified "2026-02-12T08:59:21.628825Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1644-2
  a curric:KeyLearningPoint ;
  rdfs:label """The exploration of Lady Macbeth's guilt in this scene foreshadows her demise in Act 5"""@en ;
  dcterms:modified "2026-02-12T08:59:21.628830Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1644-3
  a curric:KeyLearningPoint ;
  rdfs:label """Act 5, Scene 1 is her final appearance in the play and in it, she is consumed by guilt"""@en ;
  dcterms:modified "2026-02-12T08:59:21.628835Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2007-1
  a curric:KeyLearningPoint ;
  rdfs:label "It is important to write with clarity in order to articulate your ideas."@en ;
  dcterms:modified "2026-02-12T08:59:21.628842Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2007-2
  a curric:KeyLearningPoint ;
  rdfs:label "Using subordinating conjunctions is a good way to explore nuance and complexity."@en ;
  dcterms:modified "2026-02-12T08:59:21.628850Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2007-3
  a curric:KeyLearningPoint ;
  rdfs:label """Using correlative and comparative conjunctions is a good way to explore nuanced similarities and differences."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628855Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2007-4
  a curric:KeyLearningPoint ;
  rdfs:label """The phrase 'more precisely’ allows you to add further detail in a concise manner."""@en ;
  dcterms:modified "2026-02-12T08:59:21.628891Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2343-1
  a curric:KeyLearningPoint ;
  rdfs:label "The poem takes the form of a dramatic monologue."@en ;
  dcterms:modified "2026-02-12T08:59:21.629163Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2343-2
  a curric:KeyLearningPoint ;
  rdfs:label "It also uses many traditional ballad conventions."@en ;
  dcterms:modified "2026-02-12T08:59:21.629169Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2343-3
  a curric:KeyLearningPoint ;
  rdfs:label "Juxtaposition may have been used to create tension in the poem."@en ;
  dcterms:modified "2026-02-12T08:59:21.629174Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2343-4
  a curric:KeyLearningPoint ;
  rdfs:label """Rhetorical questions may have been used to convey confusion about the conflict women faced in society."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629178Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2343-5
  a curric:KeyLearningPoint ;
  rdfs:label "Rhyme is used to emphasise and link meanings in the poem."@en ;
  dcterms:modified "2026-02-12T08:59:21.629183Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2351-1
  a curric:KeyLearningPoint ;
  rdfs:label """'Kumukanda' and 'Jamaican British' both explore the struggle in finding belonging when the speaker is of dual heritage."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629188Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2351-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Kumukanda' and 'The Émigrée' both use the power of memory to create a sense of belonging."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629193Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2351-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Kumukanda' and 'The Émigrée' both explore permanent severance whereas 'Jamaican British' explores a partial separation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629198Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2351-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Kumukanda' and 'I Remember, I Remember' explore grief and sadness through idealised memories."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629205Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2351-5
  a curric:KeyLearningPoint ;
  rdfs:label "'Kumukanda' and 'I Remember, I Remember' mourn the loss of childhood innocence."@en ;
  dcterms:modified "2026-02-12T08:59:21.629210Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2352-1
  a curric:KeyLearningPoint ;
  rdfs:label """Dharker was born in Lahore, Pakistan before moving to Glasgow, Scotland before her first birthday."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629215Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2352-2
  a curric:KeyLearningPoint ;
  rdfs:label """Dharker's poems are testaments to her experience: intercultural identities and global living."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629220Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2352-3
  a curric:KeyLearningPoint ;
  rdfs:label """Dharker's poetry explores the longing of youth - when you desire to be anyone more exciting than who you currently are."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629225Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2352-4
  a curric:KeyLearningPoint ;
  rdfs:label """Dharker's poetry reminds the reader that people often look elsewhere to create a sense of belonging."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629230Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2514-1
  a curric:KeyLearningPoint ;
  rdfs:label "Levertov was active in protesting against the Vietnam War."@en ;
  dcterms:modified "2026-02-12T08:59:21.629330Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2514-2
  a curric:KeyLearningPoint ;
  rdfs:label "The poem was written before the withdrawal of American troops in 1973."@en ;
  dcterms:modified "2026-02-12T08:59:21.629335Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2514-3
  a curric:KeyLearningPoint ;
  rdfs:label "The Vietnam War was about defeating communism."@en ;
  dcterms:modified "2026-02-12T08:59:21.629340Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2514-4
  a curric:KeyLearningPoint ;
  rdfs:label "The US used napalm, a particularly harrowing weapon, against civilians."@en ;
  dcterms:modified "2026-02-12T08:59:21.629344Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2514-5
  a curric:KeyLearningPoint ;
  rdfs:label """This poem explores what may have happened if the US and anti-communist forces had won the war."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629352Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2553-1
  a curric:KeyLearningPoint ;
  rdfs:label "Antrobus has a British mother and a Jamaican father."@en ;
  dcterms:modified "2026-02-12T08:59:21.629357Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2553-2
  a curric:KeyLearningPoint ;
  rdfs:label "The poem explores what it means to have dual heritage."@en ;
  dcterms:modified "2026-02-12T08:59:21.629362Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2553-3
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, the poem suggests that having dual heritage or identity leads to internal and external conflict."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629367Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2553-4
  a curric:KeyLearningPoint ;
  rdfs:label "We might argue that our identities are never singular but always multifaceted."@en ;
  dcterms:modified "2026-02-12T08:59:21.629374Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2130-1
  a curric:KeyLearningPoint ;
  rdfs:label "Excellent writing will have a consistent tone of voice"@en ;
  dcterms:modified "2026-02-12T08:59:21.629381Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2130-2
  a curric:KeyLearningPoint ;
  rdfs:label """Excellent functional writing will include figurative language and use semantic fields, to extend imagery throughout"""@en ;
  dcterms:modified "2026-02-12T08:59:21.629387Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2130-3
  a curric:KeyLearningPoint ;
  rdfs:label "Excellent writing will make use of structural devices for effect"@en ;
  dcterms:modified "2026-02-12T08:59:21.629392Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2130-4
  a curric:KeyLearningPoint ;
  rdfs:label "Excellent writing will have a focused viewpoint throughout"@en ;
  dcterms:modified "2026-02-12T08:59:21.629397Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2130-5
  a curric:KeyLearningPoint ;
  rdfs:label """Excellent writing will contain high-level spelling, punctuation and grammar, including nominalised sentences"""@en ;
  dcterms:modified "2026-02-12T08:59:21.629402Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2322-1
  a curric:KeyLearningPoint ;
  rdfs:label """Before the spirits’ visits, Scrooge viewed time as a resource that he could use to make money."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629471Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2322-2
  a curric:KeyLearningPoint ;
  rdfs:label """Scrooge learns that time is a privilege and a gift that many in society are not blessed with."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629476Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2322-3
  a curric:KeyLearningPoint ;
  rdfs:label """Scrooge learns that time's fluid and that all aspects of time interact with one another to inform a person's experience."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629481Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2322-4
  a curric:KeyLearningPoint ;
  rdfs:label "The spirits’ visits defy time, but all occur within the course of one evening."@en ;
  dcterms:modified "2026-02-12T08:59:21.629486Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2322-5
  a curric:KeyLearningPoint ;
  rdfs:label """Dickens illustrates how one person's drastic change in a short space of time can vastly improve the lives of others."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629490Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2450-1
  a curric:KeyLearningPoint ;
  rdfs:label "Dickens uses an extended metaphor to associate Scrooge with the cold"@en ;
  dcterms:modified "2026-02-12T08:59:21.629612Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2450-2
  a curric:KeyLearningPoint ;
  rdfs:label """Scrooge is a solitary character who feels no sense of community or responsibility for others"""@en ;
  dcterms:modified "2026-02-12T08:59:21.629617Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2450-3
  a curric:KeyLearningPoint ;
  rdfs:label """Scrooge’s appearance is economic to reflect his miserly nature- nothing about his features is generous"""@en ;
  dcterms:modified "2026-02-12T08:59:21.629621Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2450-4
  a curric:KeyLearningPoint ;
  rdfs:label """Scrooge is a callous character who treats those close to him (his nephew and his clerk) with disdain"""@en ;
  dcterms:modified "2026-02-12T08:59:21.629626Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2450-5
  a curric:KeyLearningPoint ;
  rdfs:label "Scrooge is uncharitable and harbours great contempt for the poor"@en ;
  dcterms:modified "2026-02-12T08:59:21.629630Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2460-1
  a curric:KeyLearningPoint ;
  rdfs:label "The Ghost of Christmas Present embodies Christmas spirit"@en ;
  dcterms:modified "2026-02-12T08:59:21.629685Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2460-2
  a curric:KeyLearningPoint ;
  rdfs:label """Scrooge is shown different scenes of Christmas being celebrated around the world, especially in isolated communities"""@en ;
  dcterms:modified "2026-02-12T08:59:21.629689Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2460-3
  a curric:KeyLearningPoint ;
  rdfs:label """Scrooge observes the Christmas spirit they all demonstrate and the regard they hold for family and human connection"""@en ;
  dcterms:modified "2026-02-12T08:59:21.629694Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2460-4
  a curric:KeyLearningPoint ;
  rdfs:label """Though there may not be an abundance of wealth, there is an abundance of joy and merriment"""@en ;
  dcterms:modified "2026-02-12T08:59:21.629699Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2460-5
  a curric:KeyLearningPoint ;
  rdfs:label "Dickens emphasises the importance of community in this section of the novella"@en ;
  dcterms:modified "2026-02-12T08:59:21.629703Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2466-1
  a curric:KeyLearningPoint ;
  rdfs:label "In Stave 4, Scrooge meets the Ghost of Christmas Yet to Come, who shows Scrooge the shadows of things that \"may be\""@en ;
  dcterms:modified "2026-02-12T08:59:21.629711Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2466-2
  a curric:KeyLearningPoint ;
  rdfs:label """Dickens refers to this ghost as a "phantom" rather than a spirit, characterising it as distinct from the others"""@en ;
  dcterms:modified "2026-02-12T08:59:21.629718Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2466-3
  a curric:KeyLearningPoint ;
  rdfs:label """Dickens' description of the phantom's "draped and hooded" appearance is reminiscent of the Grim Reaper"""@en ;
  dcterms:modified "2026-02-12T08:59:21.629725Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2466-4
  a curric:KeyLearningPoint ;
  rdfs:label """The phantom forces Scrooge to interpret the visions for himself and understand independently how he can change his fate"""@en ;
  dcterms:modified "2026-02-12T08:59:21.629730Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2466-5
  a curric:KeyLearningPoint ;
  rdfs:label """Dickens places the responsibility to change on the individual, highlighting the impact of one person’s actions on others"""@en ;
  dcterms:modified "2026-02-12T08:59:21.629735Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2375-1
  a curric:KeyLearningPoint ;
  rdfs:label """Dickens felt that people should live life adhering to Christian virtues, especially in relation to social justice."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629743Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2375-2
  a curric:KeyLearningPoint ;
  rdfs:label """Dickens was very familiar with the Bible - he regarded it as his ‘unfailing guide to life’."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629747Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2375-3
  a curric:KeyLearningPoint ;
  rdfs:label """Dickens' message is perhaps not entirely theological, but focuses on living out Christian morals to better society."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629752Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2375-4
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, Dickens emulated the parable structure to teach his readers the importance of adhering to Christian virtues."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629757Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2375-5
  a curric:KeyLearningPoint ;
  rdfs:label """‘A Christmas Carol’ can arguably be viewed as one large parable, or several smaller parables."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629762Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1469-1
  a curric:KeyLearningPoint ;
  rdfs:label """Using knowledge of a writer and reading the title can help you make predictions about a text."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629766Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1469-2
  a curric:KeyLearningPoint ;
  rdfs:label "Brooker uses irony and sarcasm to address a serious topic."@en ;
  dcterms:modified "2026-02-12T08:59:21.629771Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1469-3
  a curric:KeyLearningPoint ;
  rdfs:label "Rhetorical questions can be effective as long as they are not overused."@en ;
  dcterms:modified "2026-02-12T08:59:21.629776Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1469-4
  a curric:KeyLearningPoint ;
  rdfs:label """Rhetorical questions should be relevant to the topic and not rely on direct address or 'you'."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629780Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2393-1
  a curric:KeyLearningPoint ;
  rdfs:label """Proof-reading is an active process, that enables us to spot and correct errors in written work."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629861Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2393-2
  a curric:KeyLearningPoint ;
  rdfs:label """Reading your work aloud can help you spot errors and ensure your writing is correctly punctuated."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629865Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2393-3
  a curric:KeyLearningPoint ;
  rdfs:label "You should spell check any homophones and words you are unsure of."@en ;
  dcterms:modified "2026-02-12T08:59:21.629870Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2393-4
  a curric:KeyLearningPoint ;
  rdfs:label """Find opportunities to expand your ideas and sentences by using opinion conjunctions and phrases like 'more precisely'."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629876Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2393-5
  a curric:KeyLearningPoint ;
  rdfs:label "The overall structure of a speech should be varied and engaging."@en ;
  dcterms:modified "2026-02-12T08:59:21.629881Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2049-1
  a curric:KeyLearningPoint ;
  rdfs:label """When considering sounds in an unseen poem, you might ask what emotion the sound makes you feel."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629886Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2049-2
  a curric:KeyLearningPoint ;
  rdfs:label """You also might ask whether the poet has used techniques such as onomatopoeia or sibilance."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629891Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2049-3
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, onomatopoeia immerses the reader in the poem and makes them feel as if they are experiencing it."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629895Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2049-4
  a curric:KeyLearningPoint ;
  rdfs:label """Duffy may be using sounds in order to create a warm environment where the reader feels at home."""@en ;
  dcterms:modified "2026-02-12T08:59:21.629900Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2031-1
  a curric:KeyLearningPoint ;
  rdfs:label """Both  ‘The Émigrée’ and ‘Checking Out Me History’ explore big ideas of oppression, power and identity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.630357Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2031-2
  a curric:KeyLearningPoint ;
  rdfs:label """Both poems criticise oppressive systems due to the detrimental effect they can have on identity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.630361Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2031-3
  a curric:KeyLearningPoint ;
  rdfs:label """Both poets reconnect with their heritage: Rumens personifying her country and Agard telling stories in his dialect."""@en ;
  dcterms:modified "2026-02-12T08:59:21.630366Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2031-4
  a curric:KeyLearningPoint ;
  rdfs:label "Both poems use the motif of light to show the power of personal identity."@en ;
  dcterms:modified "2026-02-12T08:59:21.630371Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2031-5
  a curric:KeyLearningPoint ;
  rdfs:label "Both poets ultimately reveal how one can reclaim their sense of identity."@en ;
  dcterms:modified "2026-02-12T08:59:21.630375Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28797-1
  a curric:KeyLearningPoint ;
  rdfs:label "An introduction and conclusion could follow a three part structure."@en ;
  dcterms:modified "2026-02-12T08:59:21.630437Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28797-2
  a curric:KeyLearningPoint ;
  rdfs:label "An excellent introduction could start with a general statement about the text."@en ;
  dcterms:modified "2026-02-12T08:59:21.630442Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28797-3
  a curric:KeyLearningPoint ;
  rdfs:label """An introduction could then have a more specific statement about the focus of the question, followed by a thesis."""@en ;
  dcterms:modified "2026-02-12T08:59:21.630446Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28797-4
  a curric:KeyLearningPoint ;
  rdfs:label "A conclusion could consider the timeless nature of the text."@en ;
  dcterms:modified "2026-02-12T08:59:21.630451Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1658-1
  a curric:KeyLearningPoint ;
  rdfs:label "Lanyon's narrative is concealed within a sealed envelope inside his will."@en ;
  dcterms:modified "2026-02-12T08:59:21.630479Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1658-2
  a curric:KeyLearningPoint ;
  rdfs:label """The sealed envelope in the safe is another clue within the detective plot, yet the reader is denied access to it."""@en ;
  dcterms:modified "2026-02-12T08:59:21.630483Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1658-3
  a curric:KeyLearningPoint ;
  rdfs:label """Utterson is able to repress his natural curiosity, locking and concealing the envelope in the safe."""@en ;
  dcterms:modified "2026-02-12T08:59:21.630488Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1658-4
  a curric:KeyLearningPoint ;
  rdfs:label """The safely secured letter symbolises the link between concealment and the protection of reputation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.630493Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1676-1
  a curric:KeyLearningPoint ;
  rdfs:label "A successful essay will have a clear overarching argument."@en ;
  dcterms:modified "2026-02-12T08:59:21.630515Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1676-2
  a curric:KeyLearningPoint ;
  rdfs:label """Select main quotations and supporting quotations to support your overarching argument."""@en ;
  dcterms:modified "2026-02-12T08:59:21.630520Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1676-3
  a curric:KeyLearningPoint ;
  rdfs:label """Main quotations should be analysed; supporting quotations don’t need to be analysed."""@en ;
  dcterms:modified "2026-02-12T08:59:21.630524Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6235-1
  a curric:KeyLearningPoint ;
  rdfs:label """You can use aural imagery to help the reader to imagine the sounds of a scene clearly."""@en ;
  dcterms:modified "2026-02-12T08:59:21.630529Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6235-2
  a curric:KeyLearningPoint ;
  rdfs:label """Onomatopoeia needs precise, interesting vocabulary, in order to make it sound sophisticated rather than clichéd."""@en ;
  dcterms:modified "2026-02-12T08:59:21.630534Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6235-3
  a curric:KeyLearningPoint ;
  rdfs:label """You can describe sounds using adjectives or a simile to help create interesting aural imagery."""@en ;
  dcterms:modified "2026-02-12T08:59:21.630539Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6235-4
  a curric:KeyLearningPoint ;
  rdfs:label """Sounds have names (e.g. plosive, sibilant, nasal) and each one can be used to create different effects."""@en ;
  dcterms:modified "2026-02-12T08:59:21.630543Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6235-5
  a curric:KeyLearningPoint ;
  rdfs:label """Describing the development of sound can make your scene description more convincing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.630551Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2016-1
  a curric:KeyLearningPoint ;
  rdfs:label "Some may argue that Macbeth shows remorse before his death"@en ;
  dcterms:modified "2026-02-12T08:59:21.630579Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2016-2
  a curric:KeyLearningPoint ;
  rdfs:label "Others may argue Macbeth’s death is a consequence of his hubris"@en ;
  dcterms:modified "2026-02-12T08:59:21.630584Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2016-3
  a curric:KeyLearningPoint ;
  rdfs:label "Audiences may feel differently about Macbeth’s death"@en ;
  dcterms:modified "2026-02-12T08:59:21.630591Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2016-4
  a curric:KeyLearningPoint ;
  rdfs:label "Tracking ideas across a text help create a more thorough analysis"@en ;
  dcterms:modified "2026-02-12T08:59:21.630596Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2016-5
  a curric:KeyLearningPoint ;
  rdfs:label "Discourse markers are useful when tracking ideas"@en ;
  dcterms:modified "2026-02-12T08:59:21.630601Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2468-1
  a curric:KeyLearningPoint ;
  rdfs:label """Scrooge’s reactions to the first two deaths in the novella are callous - he represses his emotions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.630650Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2468-2
  a curric:KeyLearningPoint ;
  rdfs:label """Over the course of the novella, Scrooge learns the value of individual human life, so is more affected by the deaths."""@en ;
  dcterms:modified "2026-02-12T08:59:21.630657Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2468-3
  a curric:KeyLearningPoint ;
  rdfs:label """Through Tiny Tim’s death, Scrooge recognises that the "surplus population" are, in fact, human beings worthy of life."""@en ;
  dcterms:modified "2026-02-12T08:59:21.630663Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2468-4
  a curric:KeyLearningPoint ;
  rdfs:label """Scrooge recognises the importance of living a fulfilling life and contributing positively to the welfare of others."""@en ;
  dcterms:modified "2026-02-12T08:59:21.630668Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2468-5
  a curric:KeyLearningPoint ;
  rdfs:label """Dickens emphasises that having a positive impact on others doesn’t always require money, it requires compassion/empathy."""@en ;
  dcterms:modified "2026-02-12T08:59:21.630672Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2072-1
  a curric:KeyLearningPoint ;
  rdfs:label "Jekyll is a typical gothic protagonist: egotistical and isolated."@en ;
  dcterms:modified "2026-02-12T08:59:21.630677Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2072-2
  a curric:KeyLearningPoint ;
  rdfs:label """The story dramatises Jekyll's inner struggle between good and evil and the same duality within society."""@en ;
  dcterms:modified "2026-02-12T08:59:21.630684Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2072-3
  a curric:KeyLearningPoint ;
  rdfs:label """Liminal and altered states are a gothic convention that is central to this story."""@en ;
  dcterms:modified "2026-02-12T08:59:21.630690Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2072-4
  a curric:KeyLearningPoint ;
  rdfs:label """Drawing on gothic conventions allows Stevenson to explore transgressive behaviour and illicit desires."""@en ;
  dcterms:modified "2026-02-12T08:59:21.630694Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2072-5
  a curric:KeyLearningPoint ;
  rdfs:label """Using multiple narrators is a gothic trope that plays with ideas of verisimilitude, linking to science vs. supernatural."""@en ;
  dcterms:modified "2026-02-12T08:59:21.630699Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2379-1
  a curric:KeyLearningPoint ;
  rdfs:label """Dickens uses the motif of light and dark throughout the novella to symbolise hope and faith."""@en ;
  dcterms:modified "2026-02-12T08:59:21.630704Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2379-2
  a curric:KeyLearningPoint ;
  rdfs:label """The cold and dark repeatedly associated with Scrooge at the start shows that he needs to change."""@en ;
  dcterms:modified "2026-02-12T08:59:21.630708Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2379-3
  a curric:KeyLearningPoint ;
  rdfs:label """The darkness could reflect Scrooge’s immorality, loss of childhood innocence, or loss of faith."""@en ;
  dcterms:modified "2026-02-12T08:59:21.630715Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2379-4
  a curric:KeyLearningPoint ;
  rdfs:label """The spirits enlighten Scrooge as to the error of his ways and guide him towards a more moral future."""@en ;
  dcterms:modified "2026-02-12T08:59:21.630720Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2379-5
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, the spirits guide Scrooge into the light (the light of God and Christianity)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.630727Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2383-1
  a curric:KeyLearningPoint ;
  rdfs:label """Key information can be used to make predictions and draw conclusions before you read a text."""@en ;
  dcterms:modified "2026-02-12T08:59:21.630732Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2383-2
  a curric:KeyLearningPoint ;
  rdfs:label """Skimming and scanning can be a useful strategy for finding the key points, particularly when reading archaic texts."""@en ;
  dcterms:modified "2026-02-12T08:59:21.630737Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2383-3
  a curric:KeyLearningPoint ;
  rdfs:label """Understanding the gist of a text means being able to succinctly explain what it is about."""@en ;
  dcterms:modified "2026-02-12T08:59:21.630783Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2383-4
  a curric:KeyLearningPoint ;
  rdfs:label """inference is about looking at texts and coming up with interpretations using clues or evidence"""@en ;
  dcterms:modified "2026-02-12T08:59:21.630797Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2390-1
  a curric:KeyLearningPoint ;
  rdfs:label """Rhetorical questions and statistics are the most used persuasive devices, they need to be crafted carefully."""@en ;
  dcterms:modified "2026-02-12T08:59:21.630804Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2390-2
  a curric:KeyLearningPoint ;
  rdfs:label """Statistics and facts need to be realistic and probable in order to add credibility to your writing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.630809Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2390-3
  a curric:KeyLearningPoint ;
  rdfs:label "Rhetorical questions should be used sparingly and not in succession."@en ;
  dcterms:modified "2026-02-12T08:59:21.630814Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2390-4
  a curric:KeyLearningPoint ;
  rdfs:label "Rhetorical questions should avoid overusing the pronoun “you”."@en ;
  dcterms:modified "2026-02-12T08:59:21.630819Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2390-5
  a curric:KeyLearningPoint ;
  rdfs:label """A realistic fact or statistic can be combined with a rhetorical question to make it even more impactful."""@en ;
  dcterms:modified "2026-02-12T08:59:21.630824Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2128-1
  a curric:KeyLearningPoint ;
  rdfs:label """Viewpoint does not need to be established in the first sentence but should become apparent quickly"""@en ;
  dcterms:modified "2026-02-12T08:59:21.630842Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2128-2
  a curric:KeyLearningPoint ;
  rdfs:label "Mirroring of start and ending is an effective way to create cohesion in writing"@en ;
  dcterms:modified "2026-02-12T08:59:21.630848Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2128-3
  a curric:KeyLearningPoint ;
  rdfs:label "Refer back to previous anecdotes, examples or ideas to connect paragraphs"@en ;
  dcterms:modified "2026-02-12T08:59:21.630852Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2335-1
  a curric:KeyLearningPoint ;
  rdfs:label "Context must be precise and avoid generalisations."@en ;
  dcterms:modified "2026-02-12T08:59:21.631110Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2335-2
  a curric:KeyLearningPoint ;
  rdfs:label """Victorian society disempowered women but many disagreed with their subordinate position in society (e.g. the Brownings)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.631119Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2335-3
  a curric:KeyLearningPoint ;
  rdfs:label """Contextual references should be judiciously chosen and rooted in our argument about the text."""@en ;
  dcterms:modified "2026-02-12T08:59:21.631125Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2335-4
  a curric:KeyLearningPoint ;
  rdfs:label """An understanding of specific Victorian context deepens our interpretation of Victorian poetry."""@en ;
  dcterms:modified "2026-02-12T08:59:21.631130Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29864-1
  a curric:KeyLearningPoint ;
  rdfs:label """Pinnock explains how her upbringing in London and Jamaican heritage shaped her ideas about identity and belonging."""@en ;
  dcterms:modified "2026-02-12T08:59:21.631134Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29864-2
  a curric:KeyLearningPoint ;
  rdfs:label """Pinnock describes how her love of theatre and working with others at the Royal Court inspired her as a playwright."""@en ;
  dcterms:modified "2026-02-12T08:59:21.631139Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29864-3
  a curric:KeyLearningPoint ;
  rdfs:label """Pinnock shows that writing a play involves research, observation, mentoring, and learning the craft."""@en ;
  dcterms:modified "2026-02-12T08:59:21.631144Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29864-4
  a curric:KeyLearningPoint ;
  rdfs:label """Pinnock demonstrates that passion and authenticity in a play, whether classic or new, engage the audience."""@en ;
  dcterms:modified "2026-02-12T08:59:21.631149Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29864-5
  a curric:KeyLearningPoint ;
  rdfs:label """'Leave Taking' continues to be read and perhaps better understood decades later, showing the lasting impact of her work."""@en ;
  dcterms:modified "2026-02-12T08:59:21.631153Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6229-1
  a curric:KeyLearningPoint ;
  rdfs:label "A semantic field is a group of words linked together via their meaning."@en ;
  dcterms:modified "2026-02-12T08:59:21.631218Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6229-2
  a curric:KeyLearningPoint ;
  rdfs:label "Semantic fields can help to create extended metaphors."@en ;
  dcterms:modified "2026-02-12T08:59:21.631223Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6229-3
  a curric:KeyLearningPoint ;
  rdfs:label "Murakami uses the semantic field of biology in the opening of 'After Dark'."@en ;
  dcterms:modified "2026-02-12T08:59:21.631228Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6229-4
  a curric:KeyLearningPoint ;
  rdfs:label """Murakami uses the semantic field of biology to characterise the city as a living organism via extended metaphor."""@en ;
  dcterms:modified "2026-02-12T08:59:21.631232Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6229-5
  a curric:KeyLearningPoint ;
  rdfs:label "Murakami emphasises the dynamic, interconnected nature of the city."@en ;
  dcterms:modified "2026-02-12T08:59:21.631239Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1480-1
  a curric:KeyLearningPoint ;
  rdfs:label """Proofreading is an active process that enables us to spot and correct errors in written work."""@en ;
  dcterms:modified "2026-02-12T08:59:21.631244Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1480-2
  a curric:KeyLearningPoint ;
  rdfs:label """Changing your verbs and nouns to ones that work together can create a semantic field or overall atmosphere."""@en ;
  dcterms:modified "2026-02-12T08:59:21.631249Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1480-3
  a curric:KeyLearningPoint ;
  rdfs:label "You can link two closely related sentences with a semi-colon."@en ;
  dcterms:modified "2026-02-12T08:59:21.631254Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1480-4
  a curric:KeyLearningPoint ;
  rdfs:label """Add a sentence that starts with a present participle to transport the reader into a scene."""@en ;
  dcterms:modified "2026-02-12T08:59:21.631259Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28643-1
  a curric:KeyLearningPoint ;
  rdfs:label """Shakespeare presents the relationship between the Nurse and Juliet as a close relationship."""@en ;
  dcterms:modified "2026-02-12T08:59:21.631266Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28643-2
  a curric:KeyLearningPoint ;
  rdfs:label """Shakespeare implies that the Nurse is protective of Juliet and that Juliet in turn trusts the Nurse."""@en ;
  dcterms:modified "2026-02-12T08:59:21.631271Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28643-3
  a curric:KeyLearningPoint ;
  rdfs:label "Arguably, the Nurse’s use of malapropisms presents her as uneducated."@en ;
  dcterms:modified "2026-02-12T08:59:21.631276Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28643-4
  a curric:KeyLearningPoint ;
  rdfs:label """Shakespeare’s use of bawdy humour might have been a way of appealing to the lower classes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.631281Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28643-5
  a curric:KeyLearningPoint ;
  rdfs:label """Alternatively, Shakespeare’s use of bawdy humour might emphasise the youthfulness of the characters."""@en ;
  dcterms:modified "2026-02-12T08:59:21.631286Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2318-1
  a curric:KeyLearningPoint ;
  rdfs:label """Dickens was influential in establishing the ghost story as a popular genre in the Victorian period."""@en ;
  dcterms:modified "2026-02-12T08:59:21.631290Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2318-2
  a curric:KeyLearningPoint ;
  rdfs:label """Dickens capitalised on the popularity of this genre to spread his social message: he wanted this to be a best seller."""@en ;
  dcterms:modified "2026-02-12T08:59:21.631295Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2318-3
  a curric:KeyLearningPoint ;
  rdfs:label """Unlike the ghosts of early Gothic fiction, Dickens made the supernatural a natural extension of the real world."""@en ;
  dcterms:modified "2026-02-12T08:59:21.631302Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2318-4
  a curric:KeyLearningPoint ;
  rdfs:label """Dickens uses the ghosts as a literary device that enables him to explore moral and social issues."""@en ;
  dcterms:modified "2026-02-12T08:59:21.631307Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2318-5
  a curric:KeyLearningPoint ;
  rdfs:label """The apparitions structure the narrative and move it towards Stave 5, where we see Scrooge’s impressive transformation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.631312Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1666-1
  a curric:KeyLearningPoint ;
  rdfs:label """Stevenson initially introduces Hyde through anecdotes and dream sequences - creating a sense of mystery."""@en ;
  dcterms:modified "2026-02-12T08:59:21.631317Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1666-2
  a curric:KeyLearningPoint ;
  rdfs:label """Through Hyde’s actions and Stevenson’s description of him, Hyde could be described as the embodiment of evil."""@en ;
  dcterms:modified "2026-02-12T08:59:21.631321Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1666-3
  a curric:KeyLearningPoint ;
  rdfs:label "When selecting quotations, they should be analysable and adaptable."@en ;
  dcterms:modified "2026-02-12T08:59:21.631326Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1666-4
  a curric:KeyLearningPoint ;
  rdfs:label """Select quotations that include interesting words, devices, connotations or give opportunities to explore symbolism."""@en ;
  dcterms:modified "2026-02-12T08:59:21.631331Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1464-1
  a curric:KeyLearningPoint ;
  rdfs:label """Using predictive reading skills before you read a text can help you understand more complex texts."""@en ;
  dcterms:modified "2026-02-12T08:59:21.631359Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1464-2
  a curric:KeyLearningPoint ;
  rdfs:label """When reading a text for the first time, you won’t necessarily understand every word and idea."""@en ;
  dcterms:modified "2026-02-12T08:59:21.631364Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1464-3
  a curric:KeyLearningPoint ;
  rdfs:label """Making short annotations as you read can help you develop an understanding of a text."""@en ;
  dcterms:modified "2026-02-12T08:59:21.631369Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1464-4
  a curric:KeyLearningPoint ;
  rdfs:label """Summarising a text after reading it for the first time can help you feel secure in your understanding of its main ideas."""@en ;
  dcterms:modified "2026-02-12T08:59:21.631373Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1464-5
  a curric:KeyLearningPoint ;
  rdfs:label """Comparing writers’ perspectives involves exploring their point of view and feelings as expressed in the text."""@en ;
  dcterms:modified "2026-02-12T08:59:21.631378Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2348-1
  a curric:KeyLearningPoint ;
  rdfs:label "An excellent introduction could start with a brief summary of each poem."@en ;
  dcterms:modified "2026-02-12T08:59:21.631383Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2348-2
  a curric:KeyLearningPoint ;
  rdfs:label """An introduction should then have a more specific statement about the focus of the question, followed by a thesis."""@en ;
  dcterms:modified "2026-02-12T08:59:21.631389Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2348-3
  a curric:KeyLearningPoint ;
  rdfs:label "Topic sentences need to be clear, comparative and linked to the question."@en ;
  dcterms:modified "2026-02-12T08:59:21.631394Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2348-4
  a curric:KeyLearningPoint ;
  rdfs:label """Comparative conjunctions should be used to compare language, form and structure of poems."""@en ;
  dcterms:modified "2026-02-12T08:59:21.631432Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2348-5
  a curric:KeyLearningPoint ;
  rdfs:label "Context can be used to develop arguments."@en ;
  dcterms:modified "2026-02-12T08:59:21.631438Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2541-1
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, Wordsworth uses sibilance, assonance, and euphony to contribute to the idea that nature is idyllic."""@en ;
  dcterms:modified "2026-02-12T08:59:21.631443Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2541-2
  a curric:KeyLearningPoint ;
  rdfs:label "Wordsworth may use asyndetic listing to show nature as enveloping."@en ;
  dcterms:modified "2026-02-12T08:59:21.631448Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2541-3
  a curric:KeyLearningPoint ;
  rdfs:label """Wordsworth arguably implies that nature appeals to our rational "minds" as well as our emotions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.631453Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2541-4
  a curric:KeyLearningPoint ;
  rdfs:label """The regularity of the rhyme scheme could also contribute to the image of nature as idyllic."""@en ;
  dcterms:modified "2026-02-12T08:59:21.631460Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2029-1
  a curric:KeyLearningPoint ;
  rdfs:label """The title of the poem allows the poem to relate to the general experience of all that emigrate."""@en ;
  dcterms:modified "2026-02-12T08:59:21.631465Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2029-2
  a curric:KeyLearningPoint ;
  rdfs:label "There are feelings of nostalgia, regret and fear within the poem."@en ;
  dcterms:modified "2026-02-12T08:59:21.631472Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2029-3
  a curric:KeyLearningPoint ;
  rdfs:label """Rumens explores the displaced feelings of people driven from their home country and the enduring impact of tyranny."""@en ;
  dcterms:modified "2026-02-12T08:59:21.631477Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2029-4
  a curric:KeyLearningPoint ;
  rdfs:label "The poem explores the big ideas of identity, memory and power of place."@en ;
  dcterms:modified "2026-02-12T08:59:21.631482Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2388-1
  a curric:KeyLearningPoint ;
  rdfs:label """Malala’s Nobel speech demonstrates that texts can have multiple purposes in order to engage an audience."""@en ;
  dcterms:modified "2026-02-12T08:59:21.631487Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2388-2
  a curric:KeyLearningPoint ;
  rdfs:label """Malala demonstrates an effective use of humour alongside her important messages of education and peace."""@en ;
  dcterms:modified "2026-02-12T08:59:21.631492Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2388-3
  a curric:KeyLearningPoint ;
  rdfs:label """Like Malala, successful speeches engage their audiences, through a range of rhetorical devices."""@en ;
  dcterms:modified "2026-02-12T08:59:21.631496Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2388-4
  a curric:KeyLearningPoint ;
  rdfs:label """Logos, ethos and pathos give writers different ways of speaking to their readers."""@en ;
  dcterms:modified "2026-02-12T08:59:21.631501Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2133-1
  a curric:KeyLearningPoint ;
  rdfs:label """Excellent descriptions and narratives will focus on describing details, rather than trying to write too much."""@en ;
  dcterms:modified "2026-02-12T08:59:21.631534Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2133-2
  a curric:KeyLearningPoint ;
  rdfs:label "Figurative language can be used to create vivid imagery."@en ;
  dcterms:modified "2026-02-12T08:59:21.631539Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2133-3
  a curric:KeyLearningPoint ;
  rdfs:label """Using semantic fields as part of your description can help characterise the setting."""@en ;
  dcterms:modified "2026-02-12T08:59:21.631544Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2133-4
  a curric:KeyLearningPoint ;
  rdfs:label """Describing the features of something rather than its overall impression (showing not telling) makes description vivid."""@en ;
  dcterms:modified "2026-02-12T08:59:21.631549Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29083-1
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, we might see Duffy’s poem as a critique of the viewer and their response to suffering in art."""@en ;
  dcterms:modified "2026-02-12T08:59:21.631554Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29083-2
  a curric:KeyLearningPoint ;
  rdfs:label "We might see Ghose’s poem as a critique of humanity and the artist."@en ;
  dcterms:modified "2026-02-12T08:59:21.631559Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29083-3
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, we might see Duffy demonstrating the futility of using art to inspire action against suffering."""@en ;
  dcterms:modified "2026-02-12T08:59:21.631563Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29083-4
  a curric:KeyLearningPoint ;
  rdfs:label """Potentially, we might see Ghose suggesting the futility of trying to capture human suffering through art."""@en ;
  dcterms:modified "2026-02-12T08:59:21.631568Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28793-1
  a curric:KeyLearningPoint ;
  rdfs:label """Eric is established as a moral voice at the start of the play, but lacks the ability to be assertive."""@en ;
  dcterms:modified "2026-02-12T08:59:21.631597Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28793-2
  a curric:KeyLearningPoint ;
  rdfs:label "Priestley uses emotive language to portray the impact the Inspector has on Eric."@en ;
  dcterms:modified "2026-02-12T08:59:21.631602Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28793-3
  a curric:KeyLearningPoint ;
  rdfs:label "The Inspector appears to be more lenient with Eric and acts as a moral guide."@en ;
  dcterms:modified "2026-02-12T08:59:21.631607Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28793-4
  a curric:KeyLearningPoint ;
  rdfs:label """It could be argued that Eric is an unreliable narrator when explaining his involvement with Eva."""@en ;
  dcterms:modified "2026-02-12T08:59:21.631614Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28793-5
  a curric:KeyLearningPoint ;
  rdfs:label """Tentative language can be used to explore and develop alternative interpretations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.631619Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1628-1
  a curric:KeyLearningPoint ;
  rdfs:label "The play is set in a patriarchal society"@en ;
  dcterms:modified "2026-02-12T08:59:21.631817Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1628-2
  a curric:KeyLearningPoint ;
  rdfs:label "Lady Macbeth hears about the prophecies and wants to commit regicide"@en ;
  dcterms:modified "2026-02-12T08:59:21.631824Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1628-3
  a curric:KeyLearningPoint ;
  rdfs:label "Lady Macbeth is worried that Macbeth is too kind to kill Duncan"@en ;
  dcterms:modified "2026-02-12T08:59:21.631829Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1628-4
  a curric:KeyLearningPoint ;
  rdfs:label "Lady Macbeth summons demonic spirits to make her strong and act less feminine"@en ;
  dcterms:modified "2026-02-12T08:59:21.631834Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1628-5
  a curric:KeyLearningPoint ;
  rdfs:label """Lady Macbeth goads Macbeth into killing Duncan by questioning his masculinity and loyalty to her"""@en ;
  dcterms:modified "2026-02-12T08:59:21.631838Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2459-1
  a curric:KeyLearningPoint ;
  rdfs:label """Scrooge meets the Ghost of Christmas Present, a jolly figure who closely resembles the Victorian Father Christmas"""@en ;
  dcterms:modified "2026-02-12T08:59:21.631843Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2459-2
  a curric:KeyLearningPoint ;
  rdfs:label """Scrooge is frightened of the spirit, but is receptive to his teachings, as he ‘obeys’ his commands"""@en ;
  dcterms:modified "2026-02-12T08:59:21.631848Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2459-3
  a curric:KeyLearningPoint ;
  rdfs:label "The spirit shows Scrooge different festive scenes from around the world"@en ;
  dcterms:modified "2026-02-12T08:59:21.631852Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2459-4
  a curric:KeyLearningPoint ;
  rdfs:label "The spirit represents generosity and abundance"@en ;
  dcterms:modified "2026-02-12T08:59:21.631857Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2459-5
  a curric:KeyLearningPoint ;
  rdfs:label """The spirit is a direct criticism of Malthusian concerns about food supply shortages"""@en ;
  dcterms:modified "2026-02-12T08:59:21.631862Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1471-1
  a curric:KeyLearningPoint ;
  rdfs:label """Revising and editing written work is a great way to improve our writing skills overall."""@en ;
  dcterms:modified "2026-02-12T08:59:21.631867Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1471-2
  a curric:KeyLearningPoint ;
  rdfs:label """Improving vocabulary choices and language devices can help inform future decisions in your writing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.631871Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1471-3
  a curric:KeyLearningPoint ;
  rdfs:label """Structural features and sentences can be improved to make your writing more cohesive and varied."""@en ;
  dcterms:modified "2026-02-12T08:59:21.631876Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1471-4
  a curric:KeyLearningPoint ;
  rdfs:label "Using a success criteria can help you to create specific feedback."@en ;
  dcterms:modified "2026-02-12T08:59:21.631881Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2100-1
  a curric:KeyLearningPoint ;
  rdfs:label "When we satirise something, we use humour to criticise it."@en ;
  dcterms:modified "2026-02-12T08:59:21.631885Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2100-2
  a curric:KeyLearningPoint ;
  rdfs:label "Humorous writing involves carefully deploying specific writing techniques."@en ;
  dcterms:modified "2026-02-12T08:59:21.631890Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2100-3
  a curric:KeyLearningPoint ;
  rdfs:label "Techniques for humorous writing include irony, parody, bathos and hyperbole."@en ;
  dcterms:modified "2026-02-12T08:59:21.631895Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2100-4
  a curric:KeyLearningPoint ;
  rdfs:label """A how to article can be structured in the form of a list or a step-by-step guide."""@en ;
  dcterms:modified "2026-02-12T08:59:21.631902Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2100-5
  a curric:KeyLearningPoint ;
  rdfs:label """When planning your humorous writing, it is important to identify the techniques you will use as well as the ideas."""@en ;
  dcterms:modified "2026-02-12T08:59:21.631907Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2442-1
  a curric:KeyLearningPoint ;
  rdfs:label """Wordsworth expresses the idea of harmony in nature through ‘Lines Written in Early Spring’."""@en ;
  dcterms:modified "2026-02-12T08:59:21.631912Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2442-2
  a curric:KeyLearningPoint ;
  rdfs:label """The speaker’s appreciation of nature is pierced by his lament for the actions of mankind."""@en ;
  dcterms:modified "2026-02-12T08:59:21.631917Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2442-3
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, the poem expresses a disconnect and lack of understanding between mankind and nature."""@en ;
  dcterms:modified "2026-02-12T08:59:21.631922Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2442-4
  a curric:KeyLearningPoint ;
  rdfs:label "Wordsworth was a Romantic poet."@en ;
  dcterms:modified "2026-02-12T08:59:21.631926Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2442-5
  a curric:KeyLearningPoint ;
  rdfs:label """The poem could also be lamenting the move away from agriculture that came with the Industrial Revolution."""@en ;
  dcterms:modified "2026-02-12T08:59:21.631931Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2489-1
  a curric:KeyLearningPoint ;
  rdfs:label "Participle phrases can make topic sentences more specific and precise."@en ;
  dcterms:modified "2026-02-12T08:59:21.631962Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2489-2
  a curric:KeyLearningPoint ;
  rdfs:label """Comparative conjunctions should be used to show the relationship between the two texts."""@en ;
  dcterms:modified "2026-02-12T08:59:21.631967Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2489-3
  a curric:KeyLearningPoint ;
  rdfs:label "Analysis should be detailed, tentative and nuanced, referencing poetic methods."@en ;
  dcterms:modified "2026-02-12T08:59:21.631971Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2045-1
  a curric:KeyLearningPoint ;
  rdfs:label """To form a personal response, you might start by asking how the poem makes you feel."""@en ;
  dcterms:modified "2026-02-12T08:59:21.631976Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2045-2
  a curric:KeyLearningPoint ;
  rdfs:label """You might then consider ideas of which word(s) or phrases stand out to you and which you don't understand."""@en ;
  dcterms:modified "2026-02-12T08:59:21.631981Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2045-3
  a curric:KeyLearningPoint ;
  rdfs:label "To develop your personal response, you might consider reframing your ideas."@en ;
  dcterms:modified "2026-02-12T08:59:21.631985Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2045-4
  a curric:KeyLearningPoint ;
  rdfs:label """When reframing, you might talk about what is evocative, pertinent or ambiguous in the poem."""@en ;
  dcterms:modified "2026-02-12T08:59:21.631993Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1670-1
  a curric:KeyLearningPoint ;
  rdfs:label """The duality of human nature - that all humans are capable of good and evil - is a central idea in the novella."""@en ;
  dcterms:modified "2026-02-12T08:59:21.631998Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1670-2
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, Stevenson embraces his own duality but is critical of those whose dual nature leads to hypocritical decisions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632002Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1670-3
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, Stevenson's choice of narrative structure is representative of duality."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632007Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1670-4
  a curric:KeyLearningPoint ;
  rdfs:label """The multiple narrators could reflect the fact there are always multiple ways of looking at situations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632012Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2530-1
  a curric:KeyLearningPoint ;
  rdfs:label """The poem is written in a deliberately colloquial manner to reflect the pride in Casey's roots."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632016Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2530-2
  a curric:KeyLearningPoint ;
  rdfs:label """Rhetorical questions are used to force the reader to challenge their own prejudices."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632024Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2530-3
  a curric:KeyLearningPoint ;
  rdfs:label """Contrasting images are used throughout the poem to contrast the differences between the social classes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632029Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2530-4
  a curric:KeyLearningPoint ;
  rdfs:label """The rhyming couplets used create a teasing tone and Casey does not take herself too seriously."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632033Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2530-5
  a curric:KeyLearningPoint ;
  rdfs:label "Humour is used to soften the sense of conflict."@en ;
  dcterms:modified "2026-02-12T08:59:21.632038Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2535-1
  a curric:KeyLearningPoint ;
  rdfs:label "Like other Romantics, Clare highlights the beauty of nature in his poem."@en ;
  dcterms:modified "2026-02-12T08:59:21.632043Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2535-2
  a curric:KeyLearningPoint ;
  rdfs:label "The tone of 'Sunday Dip' is idyllic."@en ;
  dcterms:modified "2026-02-12T08:59:21.632048Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2535-3
  a curric:KeyLearningPoint ;
  rdfs:label "‘Sunday Dip' is a poem which which reflects the joy of spending time in nature."@en ;
  dcterms:modified "2026-02-12T08:59:21.632053Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2535-4
  a curric:KeyLearningPoint ;
  rdfs:label """As well as the beauty of nature, Clare also reflects the simplicity of rural living in ‘Sunday Dip’."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632057Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6231-1
  a curric:KeyLearningPoint ;
  rdfs:label "Structure refers to the way a text has been organised."@en ;
  dcterms:modified "2026-02-12T08:59:21.632062Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6231-2
  a curric:KeyLearningPoint ;
  rdfs:label "Different structural features can have different effects on the reader."@en ;
  dcterms:modified "2026-02-12T08:59:21.632069Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6231-3
  a curric:KeyLearningPoint ;
  rdfs:label """Interesting structural features in 'After Dark' are the perspective choice, repetition and the creation of suspense."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632074Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6231-4
  a curric:KeyLearningPoint ;
  rdfs:label """After identifying a structural feature in a text, it is important to discuss its effect."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632079Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29004-1
  a curric:KeyLearningPoint ;
  rdfs:label """In a patriarchal society, women’s choices were restricted and they were expected to marry and bear children."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632086Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29004-2
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, Shakespeare’s structuring of ‘Romeo and Juliet’ conforms to the notion that men had precedence over women."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632091Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29004-3
  a curric:KeyLearningPoint ;
  rdfs:label """Furthermore, Juliet’s interactions with her surroundings could represent the restricted nature of women’s lives."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632096Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29004-4
  a curric:KeyLearningPoint ;
  rdfs:label """Our first and last impression of Juliet is around her marriage which could imply that women were defined by marriage."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632101Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29004-5
  a curric:KeyLearningPoint ;
  rdfs:label """Considering agency is important because it allows us to consider the power dynamics in society."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632105Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2013-1
  a curric:KeyLearningPoint ;
  rdfs:label """In Act 1, Scene 3, Macbeth is presented as being more interested in the witches’ prophecies than Banquo"""@en ;
  dcterms:modified "2026-02-12T08:59:21.632110Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2013-2
  a curric:KeyLearningPoint ;
  rdfs:label """Act 1, Scene 3 can be used as evidence that Lady Macbeth cannot be solely blamed for manipulating her husband"""@en ;
  dcterms:modified "2026-02-12T08:59:21.632115Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2013-3
  a curric:KeyLearningPoint ;
  rdfs:label """Whilst Macbeth is clearly conflicted early in the play, it is clear the witches’ prophecies excite him"""@en ;
  dcterms:modified "2026-02-12T08:59:21.632120Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1637-1
  a curric:KeyLearningPoint ;
  rdfs:label "The witches could be interpreted as being presented as genderless"@en ;
  dcterms:modified "2026-02-12T08:59:21.632127Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1637-2
  a curric:KeyLearningPoint ;
  rdfs:label "The witches' non-conformity to gender roles seems to confuse Macbeth and Banquo"@en ;
  dcterms:modified "2026-02-12T08:59:21.632132Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1637-3
  a curric:KeyLearningPoint ;
  rdfs:label "The witches could be interpreted as unnatural, threatening outsiders"@en ;
  dcterms:modified "2026-02-12T08:59:21.632136Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1637-4
  a curric:KeyLearningPoint ;
  rdfs:label """The witches' behaviour would subvert a Jacobean audience's expectations of femininity"""@en ;
  dcterms:modified "2026-02-12T08:59:21.632144Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1637-5
  a curric:KeyLearningPoint ;
  rdfs:label "The theme of the unnatural is first introduced"@en ;
  dcterms:modified "2026-02-12T08:59:21.632149Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29081-1
  a curric:KeyLearningPoint ;
  rdfs:label """The speaker describes a picture of an old beggar in the streets and they initially think of it as art."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632154Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29081-2
  a curric:KeyLearningPoint ;
  rdfs:label """At the end of the poem, the speaker reflects on their presumption to create art out of suffering."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632158Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29081-3
  a curric:KeyLearningPoint ;
  rdfs:label "Arguably, the poem represents the dehumanisation of homeless people."@en ;
  dcterms:modified "2026-02-12T08:59:21.632163Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29081-4
  a curric:KeyLearningPoint ;
  rdfs:label """Furthermore, the poem represents the apathy that society feels towards homeless people."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632168Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29081-5
  a curric:KeyLearningPoint ;
  rdfs:label """Potentially, Ghose could be suggesting that creating art out of human suffering contributes to their dehumanisation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632172Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29074-1
  a curric:KeyLearningPoint ;
  rdfs:label """Ewing uses a declarative tone and possessive pronouns to assert ownership and highlight personal identity and memory."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632180Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29074-2
  a curric:KeyLearningPoint ;
  rdfs:label "The comparisons of love to a “comic book” could represent the fragility of love."@en ;
  dcterms:modified "2026-02-12T08:59:21.632185Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29074-3
  a curric:KeyLearningPoint ;
  rdfs:label """Vignettes are used throughout to capture vivid, personal moments and deepen emotional connection."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632189Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29074-4
  a curric:KeyLearningPoint ;
  rdfs:label """Ewing’s use of free verse and minimal punctuation reflect the natural, flowing nature of memory and personal stories."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632194Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29074-5
  a curric:KeyLearningPoint ;
  rdfs:label """The use of anaphora emphasises the shared experiences of the poet’s parents and the importance to her own identity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632199Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28489-1
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, Atwood crafts an untrustworthy voice for the narrator of ‘Alias Grace’."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632303Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28489-2
  a curric:KeyLearningPoint ;
  rdfs:label """To emulate Atwood’s use of an untrustworthy voice, we might attach a disconcerting label to the character."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632308Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28489-3
  a curric:KeyLearningPoint ;
  rdfs:label """We might then demonstrate how the character has conflicting feelings towards this label."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632313Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28489-4
  a curric:KeyLearningPoint ;
  rdfs:label """We may then compare the label to something fashionable that may enhance the character’s appearance."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632317Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28489-5
  a curric:KeyLearningPoint ;
  rdfs:label """The character might also be dehumanised in someway to imply that they don’t have the same human emotions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632322Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1494-1
  a curric:KeyLearningPoint ;
  rdfs:label "The writer's attitude is the way that they feel towards a subject."@en ;
  dcterms:modified "2026-02-12T08:59:21.632329Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1494-2
  a curric:KeyLearningPoint ;
  rdfs:label """We might make predictions about a writer's attitude by considering contextual information around the text."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632334Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1494-3
  a curric:KeyLearningPoint ;
  rdfs:label """We might analyse the writer's attitude by considering the connotations of their word choices."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632339Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1494-4
  a curric:KeyLearningPoint ;
  rdfs:label """We also might analyse the writer's attitude by considering language techniques such as semantic fields."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632344Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1462-1
  a curric:KeyLearningPoint ;
  rdfs:label """A statistic is a piece of factual data gathered from a large quantity of numerical data."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632348Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1462-2
  a curric:KeyLearningPoint ;
  rdfs:label """Statistics can make a writer’s arguments seem credible because their opinion is backed up with factual data."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632353Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1462-3
  a curric:KeyLearningPoint ;
  rdfs:label """Writers show that their statistics are credible by including things like the source and date of the data they refer to."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632360Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1462-4
  a curric:KeyLearningPoint ;
  rdfs:label """You can invent your own credible statistics in pieces of writing where you are not expected to conduct research."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632365Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2430-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘A century later’ explores the fight that many women have faced across the world for education and equality."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632413Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2430-2
  a curric:KeyLearningPoint ;
  rdfs:label """Dharker references Wilfred Owen's 'Anthem for Doomed Youth' which lamented the loss of the youth during the war."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632417Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2430-3
  a curric:KeyLearningPoint ;
  rdfs:label """Dharker references activist Malala Yousafzai, who was shot in the head by the Taliban in Pakistan."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632422Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6247-1
  a curric:KeyLearningPoint ;
  rdfs:label """All three poets reflect on the fluid and changing dynamics of parental relationships."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632427Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6247-2
  a curric:KeyLearningPoint ;
  rdfs:label """All three poems explore the lasting effect ephemeral moments can have on a person."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632431Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6247-3
  a curric:KeyLearningPoint ;
  rdfs:label """Armitage and Heaney use the child's perspective whereas Day-Lewis uses the parent's perspective."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632436Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6247-4
  a curric:KeyLearningPoint ;
  rdfs:label """Armitage and Day-Lewis focus on a moment of separation whereas Heaney incorporates a reversal of roles."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632441Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6247-5
  a curric:KeyLearningPoint ;
  rdfs:label """‘Walking Away’ and ‘Follower’ reminisce on an important moment from the speaker’s past."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632450Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2486-1
  a curric:KeyLearningPoint ;
  rdfs:label """The speaker is enriched and comforted by her long-distance correspondence with a friend."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632458Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2486-2
  a curric:KeyLearningPoint ;
  rdfs:label """Although their relationship is distanced, the speaker treasures it and looks forward to the man's letters."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632463Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2486-3
  a curric:KeyLearningPoint ;
  rdfs:label """Dooley spent time living in the countryside so this could be a reflection of her longing to return to a natural setting."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632470Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2486-4
  a curric:KeyLearningPoint ;
  rdfs:label """Dooley seems to depict an ambiguous relationship which could be platonic, romantic or familial."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632475Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2486-5
  a curric:KeyLearningPoint ;
  rdfs:label """The speaker's admiration for her friend/relative causes her to question her own life choices."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632480Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6234-1
  a curric:KeyLearningPoint ;
  rdfs:label "An inverted sentence reverses the natural order of a sentence."@en ;
  dcterms:modified "2026-02-12T08:59:21.632484Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6234-2
  a curric:KeyLearningPoint ;
  rdfs:label """Using an inverted sentence structure is a good way to vary syntax to make your writing more engaging."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632489Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6234-3
  a curric:KeyLearningPoint ;
  rdfs:label """Asyndeton uses a list with no conjunctions whilst polysyndeton uses a list with a repeated conjunction."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632494Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6234-4
  a curric:KeyLearningPoint ;
  rdfs:label "Asyndeton creates a fast pace whereas polysyndeton creates a slower pace."@en ;
  dcterms:modified "2026-02-12T08:59:21.632498Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6234-5
  a curric:KeyLearningPoint ;
  rdfs:label """You can create interesting sentence structures by adding a climactic structure to your writing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632503Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6240-1
  a curric:KeyLearningPoint ;
  rdfs:label """In order to evaluate, we should form a personal and critical response to the text."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632508Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6240-2
  a curric:KeyLearningPoint ;
  rdfs:label """To form a personal response, we can reflect on how a text made us feel, what stood out and what we like/dislike."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632513Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6240-3
  a curric:KeyLearningPoint ;
  rdfs:label "Each reader can form a different opinion on the same part of a text."@en ;
  dcterms:modified "2026-02-12T08:59:21.632517Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6240-4
  a curric:KeyLearningPoint ;
  rdfs:label "We can use superlatives to help us express our judgements on a text."@en ;
  dcterms:modified "2026-02-12T08:59:21.632522Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6240-5
  a curric:KeyLearningPoint ;
  rdfs:label "We can use tentative language to express that our opinions are ideas, not facts."@en ;
  dcterms:modified "2026-02-12T08:59:21.632527Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28980-1
  a curric:KeyLearningPoint ;
  rdfs:label """The implication that Juliet’s refusal makes her dishonourable suggests that women’s honour came from obedience."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632531Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28980-2
  a curric:KeyLearningPoint ;
  rdfs:label "Lord Capulet implies that Juliet’s refusal is specifically dishonourable to him."@en ;
  dcterms:modified "2026-02-12T08:59:21.632536Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28980-3
  a curric:KeyLearningPoint ;
  rdfs:label """Through that, Shakespeare may be suggesting that a man’s honour comes from his ability to control his family."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632543Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28980-4
  a curric:KeyLearningPoint ;
  rdfs:label """Lord Capulet’s violent response to Juliet’s refusal could suggest that men saw violence as a solution."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632548Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1634-1
  a curric:KeyLearningPoint ;
  rdfs:label "In Act 5, Scene 1, Lady Macbeth is presented as consumed by guilt."@en ;
  dcterms:modified "2026-02-12T08:59:21.632553Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1634-2
  a curric:KeyLearningPoint ;
  rdfs:label "Her inability to sleep could symbolise her feelings of guilt."@en ;
  dcterms:modified "2026-02-12T08:59:21.632558Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1634-3
  a curric:KeyLearningPoint ;
  rdfs:label "Her desire to continually wash her hands could symbolise her guilt."@en ;
  dcterms:modified "2026-02-12T08:59:21.632563Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1634-4
  a curric:KeyLearningPoint ;
  rdfs:label "Macbeth prepares for battle but is very isolated."@en ;
  dcterms:modified "2026-02-12T08:59:21.632567Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1634-5
  a curric:KeyLearningPoint ;
  rdfs:label """The English army use branches from Birnam wood as camouflage so they can approach Macbeth’s castle."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632572Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2020-1
  a curric:KeyLearningPoint ;
  rdfs:label """In Chapter 4, there is smog, bound up with pollution to create an artificial twilight that links to liminality"""@en ;
  dcterms:modified "2026-02-12T08:59:21.632577Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2020-2
  a curric:KeyLearningPoint ;
  rdfs:label "The dirt of the fog implies the pollution and corruption of London"@en ;
  dcterms:modified "2026-02-12T08:59:21.632582Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2020-3
  a curric:KeyLearningPoint ;
  rdfs:label """In Soho (Ch4) there is smog, bound up with pollution to create an artificial twilight that links to liminality and Ch7"""@en ;
  dcterms:modified "2026-02-12T08:59:21.632589Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2020-4
  a curric:KeyLearningPoint ;
  rdfs:label "The fog and the mystery is heightened in Chapter 5"@en ;
  dcterms:modified "2026-02-12T08:59:21.632595Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2020-5
  a curric:KeyLearningPoint ;
  rdfs:label "It is important to trace motifs throughout a text"@en ;
  dcterms:modified "2026-02-12T08:59:21.632599Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1669-1
  a curric:KeyLearningPoint ;
  rdfs:label """Introductions are made up of three parts, moving from the general to the specific."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632604Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1669-2
  a curric:KeyLearningPoint ;
  rdfs:label """Conclusions move the opposite way, from the specific to the 'impact of the text today'."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632611Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1669-3
  a curric:KeyLearningPoint ;
  rdfs:label """In the final sentence of your introduction, you must focus on the writer's intention; this is your thesis statement."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632616Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1669-4
  a curric:KeyLearningPoint ;
  rdfs:label "A conclusion could consider the timeless nature of the text."@en ;
  dcterms:modified "2026-02-12T08:59:21.632621Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1669-5
  a curric:KeyLearningPoint ;
  rdfs:label "Your introduction and conclusion should be linked to form a coherent argument."@en ;
  dcterms:modified "2026-02-12T08:59:21.632626Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2451-1
  a curric:KeyLearningPoint ;
  rdfs:label """Thomas Malthus was an economist who raised concerns about the sustainability of the growing Victorian population."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632630Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2451-2
  a curric:KeyLearningPoint ;
  rdfs:label """Dickens fundamentally disagreed with the dismissive and callous attitudes of the wealthy towards the poor."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632638Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2451-3
  a curric:KeyLearningPoint ;
  rdfs:label """Scrooge is an embodiment (and criticism) of the Malthusian ideology that pervaded Victorian society."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632643Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2451-4
  a curric:KeyLearningPoint ;
  rdfs:label """The Poor Law in 1834 reduced the amount of individual charity the wealthy were willing to contribute."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632679Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2451-5
  a curric:KeyLearningPoint ;
  rdfs:label """Scrooge exemplifies the quintessential misanthropic Victorian employer in his treatment of Bob Cratchit."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632684Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1465-1
  a curric:KeyLearningPoint ;
  rdfs:label """An open letter is written to a particular person or group but published so that the public can read it."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632689Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1465-2
  a curric:KeyLearningPoint ;
  rdfs:label "A summary captures the main ideas of a text in a short and clear format."@en ;
  dcterms:modified "2026-02-12T08:59:21.632694Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1465-3
  a curric:KeyLearningPoint ;
  rdfs:label "When writing a summary of a text, it can be helpful to include short quotations."@en ;
  dcterms:modified "2026-02-12T08:59:21.632698Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1465-4
  a curric:KeyLearningPoint ;
  rdfs:label """You can develop your summary by including inferences; inferences explore a text’s suggested ideas."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632703Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1465-5
  a curric:KeyLearningPoint ;
  rdfs:label """Direct address sees a writer directly address their audience, often using pronouns like “you”, “we”, or “us”."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632708Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2122-1
  a curric:KeyLearningPoint ;
  rdfs:label "A key characteristic of concise writing is specific and precise word choices."@en ;
  dcterms:modified "2026-02-12T08:59:21.632713Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2122-2
  a curric:KeyLearningPoint ;
  rdfs:label "Adjectives can be used to add detail to your writing."@en ;
  dcterms:modified "2026-02-12T08:59:21.632717Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2122-3
  a curric:KeyLearningPoint ;
  rdfs:label """Repetition should be avoided unless it is intentional and for a deliberate effect."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632722Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2122-4
  a curric:KeyLearningPoint ;
  rdfs:label "Developed writing tracks the movement and change of ideas and feelings."@en ;
  dcterms:modified "2026-02-12T08:59:21.632727Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2122-5
  a curric:KeyLearningPoint ;
  rdfs:label """A useful way to think of developing an answer is in terms of establish, build and end."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632732Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2080-1
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, an effective ending either offers a resolution or ends in ambiguity with unanswered questions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632737Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2080-2
  a curric:KeyLearningPoint ;
  rdfs:label """The ending of 'The Great Gatsby' shows us that Gatsby's dream of his life and future wasn't reached."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632741Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2080-3
  a curric:KeyLearningPoint ;
  rdfs:label """We might interpret the ending of 'The Great Gatsby' as suggesting that we are all striving for something we can't reach."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632746Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2080-4
  a curric:KeyLearningPoint ;
  rdfs:label """Fitzgerald's use of repeated sounds might reflect the idea that we are trying to move forward with no progression."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632751Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2080-5
  a curric:KeyLearningPoint ;
  rdfs:label """The symbolism of the morning might depict the idea of a new beginning that is cut off."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632758Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2069-1
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, Macbeth's presentation as a brave warrior is a façade for his own insecurities."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632791Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2069-2
  a curric:KeyLearningPoint ;
  rdfs:label "Macbeth's insecurities are a result of a patriarchal society."@en ;
  dcterms:modified "2026-02-12T08:59:21.632796Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2069-3
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, both Macbeth and Lady Macbeth are victims of the society that they live in."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632803Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2069-4
  a curric:KeyLearningPoint ;
  rdfs:label """Macbeth's hamartia could be the insecurities he feels regarding his lack of patrilineal line"""@en ;
  dcterms:modified "2026-02-12T08:59:21.632808Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2069-5
  a curric:KeyLearningPoint ;
  rdfs:label """Macbeth's hubris, his bloodlust and his susceptability to manipulation are all parts of his hamartia."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632813Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28634-1
  a curric:KeyLearningPoint ;
  rdfs:label """At the beginning of ‘Romeo and Juliet’, Romeo is in love with Rosaline but it is unrequited."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632820Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28634-2
  a curric:KeyLearningPoint ;
  rdfs:label """Romeo is melancholic at the beginning of the play - he is isolating himself and uncertain."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632825Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28634-3
  a curric:KeyLearningPoint ;
  rdfs:label """Romeo’s depiction of Rosaline implies that his love for her is more lust than love."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632830Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28634-4
  a curric:KeyLearningPoint ;
  rdfs:label """The oxymorons within Romeo’s speech could represent his unrequited love for Rosaline."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632835Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28634-5
  a curric:KeyLearningPoint ;
  rdfs:label """The oxymorons could also foreshadow the inescapable connection between love and violence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632839Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2321-1
  a curric:KeyLearningPoint ;
  rdfs:label """Dickens uses the ghosts’ appearances to allude to other figures in popular Victorian culture."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632844Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2321-2
  a curric:KeyLearningPoint ;
  rdfs:label """Dickens alludes to the German 'Christkindl' through the Ghost of Christmas Past’s appearance."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632851Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2321-3
  a curric:KeyLearningPoint ;
  rdfs:label """Dickens alludes to the Grim Reaper through the Ghost of Christmas Yet to Come to symbolise Scrooge’s spiritual death."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632856Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2321-4
  a curric:KeyLearningPoint ;
  rdfs:label """The Ghost of Christmas Present carries a bountiful torch, which symbolises abundance and generosity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632861Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2321-5
  a curric:KeyLearningPoint ;
  rdfs:label """The Ghost of Christmas Past carries a sprig of holly to symbolise hope, new life and resilience."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632866Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2455-1
  a curric:KeyLearningPoint ;
  rdfs:label """Dickens believed that children who faced injustice would grow up to become resentful adults"""@en ;
  dcterms:modified "2026-02-12T08:59:21.632870Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2455-2
  a curric:KeyLearningPoint ;
  rdfs:label """Sympathy is created for the isolated young Scrooge, so that we are able to understand his miserly behaviour in stave one"""@en ;
  dcterms:modified "2026-02-12T08:59:21.632875Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2455-3
  a curric:KeyLearningPoint ;
  rdfs:label """Fezziwig is opposite to Scrooge in every way, except that they are both wealthy employers"""@en ;
  dcterms:modified "2026-02-12T08:59:21.632880Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2455-4
  a curric:KeyLearningPoint ;
  rdfs:label """Whilst Scrooge is a misanthropic employer, Fezziwig is a benevolent employer who spends his money philanthropically"""@en ;
  dcterms:modified "2026-02-12T08:59:21.632886Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2455-5
  a curric:KeyLearningPoint ;
  rdfs:label """Through Fezziwig, Dickens illustrates the transformative power of money, if used philanthropically and generously"""@en ;
  dcterms:modified "2026-02-12T08:59:21.632892Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2454-1
  a curric:KeyLearningPoint ;
  rdfs:label """The Ghost of Christmas Past’s appearance reflects his role (to enlighten Scrooge)"""@en ;
  dcterms:modified "2026-02-12T08:59:21.632897Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2454-2
  a curric:KeyLearningPoint ;
  rdfs:label """This ghost shows how Scrooge has been shaped and embittered by his own past experiences"""@en ;
  dcterms:modified "2026-02-12T08:59:21.632902Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2454-3
  a curric:KeyLearningPoint ;
  rdfs:label """The spirit is a physical manifestation of our memories, which shift and change over time"""@en ;
  dcterms:modified "2026-02-12T08:59:21.632906Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2454-4
  a curric:KeyLearningPoint ;
  rdfs:label """The spirit’s light makes him resemble a candle, which could show that he represents guidance and hope for Scrooge"""@en ;
  dcterms:modified "2026-02-12T08:59:21.632911Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2454-5
  a curric:KeyLearningPoint ;
  rdfs:label """The ghost's revelations about Scrooge's past make the reader more sympathetic towards the old miser"""@en ;
  dcterms:modified "2026-02-12T08:59:21.632915Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2378-1
  a curric:KeyLearningPoint ;
  rdfs:label """Dickens describes Scrooge’s fireplace as very ornate and decorative by comparison to the rest of his lodgings."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632920Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2378-2
  a curric:KeyLearningPoint ;
  rdfs:label """Dickens uses the fireplace to allude to various stories from the Scriptures, such as the Queen of Sheba and Belshazzar."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632928Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2378-3
  a curric:KeyLearningPoint ;
  rdfs:label """Dickens draws parallels between Marley’s Ghost and the Pharaoh's daughter because they both save a soul."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632933Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2378-4
  a curric:KeyLearningPoint ;
  rdfs:label "Dickens highlights Marley’s sins by comparing him to Cain in the Bible."@en ;
  dcterms:modified "2026-02-12T08:59:21.632937Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2378-5
  a curric:KeyLearningPoint ;
  rdfs:label """Dickens uses allusion to draw comparisons between Belshazzar and Scrooge, both of whom worship false idols."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632944Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29065-1
  a curric:KeyLearningPoint ;
  rdfs:label """Kay’s poem traces the thoughts and feelings of someone waiting for a call from a lover."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632975Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29065-2
  a curric:KeyLearningPoint ;
  rdfs:label """We might suggest that the poem captures the uncertainty and obsessive nature of love."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632980Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29065-3
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, it is this uncertainty of love that makes the speaker feel trapped and frightened rather than happy."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632985Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2079-1
  a curric:KeyLearningPoint ;
  rdfs:label """Writers will make deliberate choices in their writing to achieve specific effects - this is known as writer's craft."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633057Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2079-2
  a curric:KeyLearningPoint ;
  rdfs:label """Writers will employ different word choices and language devices to create engaging characters and settings."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633062Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2079-3
  a curric:KeyLearningPoint ;
  rdfs:label "Personal responses to texts will take into account the writer's craft."@en ;
  dcterms:modified "2026-02-12T08:59:21.633066Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6238-1
  a curric:KeyLearningPoint ;
  rdfs:label "The theme of hope permeates the opening of 'The Cellist of Sarajevo'."@en ;
  dcterms:modified "2026-02-12T08:59:21.633121Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6238-2
  a curric:KeyLearningPoint ;
  rdfs:label "Galloway uses powerful verbs to describe the weapon's destruction."@en ;
  dcterms:modified "2026-02-12T08:59:21.633128Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6238-3
  a curric:KeyLearningPoint ;
  rdfs:label """Galloway structures the opening paragraph of his novel to mirror the way in which the weapon falls."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633133Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6238-4
  a curric:KeyLearningPoint ;
  rdfs:label """Galloway may have purposely omitted details in his opening to universalise his message."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633140Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6238-5
  a curric:KeyLearningPoint ;
  rdfs:label """When we analyse a text, we must consider why a writer chose to make a particular decision."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633148Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6241-1
  a curric:KeyLearningPoint ;
  rdfs:label "In narratives, objects can symbolise key themes or ideas."@en ;
  dcterms:modified "2026-02-12T08:59:21.633153Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6241-2
  a curric:KeyLearningPoint ;
  rdfs:label "Galloway's key symbol is the cello which could represent hope, joy or defiance."@en ;
  dcterms:modified "2026-02-12T08:59:21.633158Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6241-3
  a curric:KeyLearningPoint ;
  rdfs:label """You can craft a symbol in your own narrative through the use of an important object, colour, weather or event."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633162Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6241-4
  a curric:KeyLearningPoint ;
  rdfs:label """Using adjectives to describe the object can help the symbol take on its intended meaning."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633167Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6241-5
  a curric:KeyLearningPoint ;
  rdfs:label """The way in which a character treats or interacts with an object can help bring the meaning of your symbol to life."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633172Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28641-1
  a curric:KeyLearningPoint ;
  rdfs:label "The climax of Shakespeare’s ‘Romeo and Juliet’ is Act 3, Scene 1."@en ;
  dcterms:modified "2026-02-12T08:59:21.633196Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28641-2
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, the climactic Act 3, Scene 1 conveys the central role of violence and honour in society."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633200Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28641-3
  a curric:KeyLearningPoint ;
  rdfs:label """Romeo’s language in Act 3, Scene 1 implies that expressing love and emotions makes men weak."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633205Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28641-4
  a curric:KeyLearningPoint ;
  rdfs:label """Mercutio curses the Montagues and Capulets - this could show how someone else controls their lives."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633210Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28641-5
  a curric:KeyLearningPoint ;
  rdfs:label """Romeo acknowledges that fate is controlling his life and his actions in Act 3, Scene 1."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633217Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1642-1
  a curric:KeyLearningPoint ;
  rdfs:label "Macbeth has a powerful reputation as a brave and noble warrior"@en ;
  dcterms:modified "2026-02-12T08:59:21.633246Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1642-2
  a curric:KeyLearningPoint ;
  rdfs:label "Macbeth values the chivalric code"@en ;
  dcterms:modified "2026-02-12T08:59:21.633251Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1642-3
  a curric:KeyLearningPoint ;
  rdfs:label "Lady Macbeth weaponises the chivalric code to get what she wants"@en ;
  dcterms:modified "2026-02-12T08:59:21.633255Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1642-4
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, her emasculation leads to Macbeth committing regicide, perhaps to defend his courage and masculinity"""@en ;
  dcterms:modified "2026-02-12T08:59:21.633260Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2463-1
  a curric:KeyLearningPoint ;
  rdfs:label """Dickens believed that the key to a moral and upstanding society, was a carefree and innocent childhood"""@en ;
  dcterms:modified "2026-02-12T08:59:21.633265Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2463-2
  a curric:KeyLearningPoint ;
  rdfs:label """The children in the novella either depend on themselves or are depended on by others and therefore are not carefree"""@en ;
  dcterms:modified "2026-02-12T08:59:21.633269Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2463-3
  a curric:KeyLearningPoint ;
  rdfs:label """Ignorance and Want represent society - they have been shaped and moulded by the cruelty and injustice of inequality"""@en ;
  dcterms:modified "2026-02-12T08:59:21.633274Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2463-4
  a curric:KeyLearningPoint ;
  rdfs:label """Dickens describes Ignorance and Want as animalistic and feral to reflect the neglect and cruelty they have faced"""@en ;
  dcterms:modified "2026-02-12T08:59:21.633279Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2463-5
  a curric:KeyLearningPoint ;
  rdfs:label """Dickens uses these two characters to highlight our moral necessity to protect children from misery and ‘Want’"""@en ;
  dcterms:modified "2026-02-12T08:59:21.633286Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2469-1
  a curric:KeyLearningPoint ;
  rdfs:label """Scrooge's Stave 1 behaviour is arguably motivated by his fear of abandonment; fear of poverty and fear of vulnerability"""@en ;
  dcterms:modified "2026-02-12T08:59:21.633290Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2469-2
  a curric:KeyLearningPoint ;
  rdfs:label """Scrooge’s fears and the behaviour that these fears have encouraged exemplify Dickens’ fears for society"""@en ;
  dcterms:modified "2026-02-12T08:59:21.633295Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2469-3
  a curric:KeyLearningPoint ;
  rdfs:label """Through Scrooge’s fear of poverty, we see how punishing life was for impoverished Victorian citizens"""@en ;
  dcterms:modified "2026-02-12T08:59:21.633300Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2469-4
  a curric:KeyLearningPoint ;
  rdfs:label """Dickens criticises Victorian stoicism, suggesting that it led to a lack of empathy for others, which exacerbates poverty"""@en ;
  dcterms:modified "2026-02-12T08:59:21.633307Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2469-5
  a curric:KeyLearningPoint ;
  rdfs:label """By the end of Stave 4, Scrooge’s greatest fear is the lack of legacy he will leave behind him, showing his change"""@en ;
  dcterms:modified "2026-02-12T08:59:21.633312Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2098-1
  a curric:KeyLearningPoint ;
  rdfs:label """Open letters are letters with intended recipients but made publicly available for anyone to read."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633317Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2098-2
  a curric:KeyLearningPoint ;
  rdfs:label """Open letters may be written to raise awareness on topics or galvanise the public."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633321Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2098-3
  a curric:KeyLearningPoint ;
  rdfs:label "Open letters can be written by anyone to any person, group or indeed thing."@en ;
  dcterms:modified "2026-02-12T08:59:21.633326Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2098-4
  a curric:KeyLearningPoint ;
  rdfs:label """Open letters have various purposes such as: entertain, complain, encourage, provide hope."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633330Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2098-5
  a curric:KeyLearningPoint ;
  rdfs:label """Open letters are usually inspired by a topic that the writer feels strong positive or negative emotions towards."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633335Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28487-1
  a curric:KeyLearningPoint ;
  rdfs:label "Broadly speaking, irony is a contrast between expectations and reality."@en ;
  dcterms:modified "2026-02-12T08:59:21.633340Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28487-2
  a curric:KeyLearningPoint ;
  rdfs:label "There are three main types of irony: verbal, situational, and dramatic."@en ;
  dcterms:modified "2026-02-12T08:59:21.633344Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28487-3
  a curric:KeyLearningPoint ;
  rdfs:label """Irony might be used to critique preconceptions or expectations or to create humour."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633353Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28487-4
  a curric:KeyLearningPoint ;
  rdfs:label "Dramatic irony might also affect our opinion of a character."@en ;
  dcterms:modified "2026-02-12T08:59:21.633358Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28487-5
  a curric:KeyLearningPoint ;
  rdfs:label """In persuasive writing, irony might be used to subvert the readers’ expectations and challenge their ideas."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633362Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2488-1
  a curric:KeyLearningPoint ;
  rdfs:label """Shelley, Barrett-Browning and Dooley use natural imagery in their poems to depict an idealistic view of love and desire."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633367Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2488-2
  a curric:KeyLearningPoint ;
  rdfs:label """Shelley, Barrett-Browning and Dooley convey an element of distance in the speaker’s relationship in their poems."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633372Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2488-3
  a curric:KeyLearningPoint ;
  rdfs:label """Both Shelley and Barrett-Browning convey sexual desire within romantic relationships through natural imagery."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633376Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2488-4
  a curric:KeyLearningPoint ;
  rdfs:label """Dooley is the only poet to depict an ambiguous and seemingly platonic relationship."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633381Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2488-5
  a curric:KeyLearningPoint ;
  rdfs:label """Both Shelley and Dooley indicate that their speaker’s desire remains unfulfilled by the end of their poems."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633385Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2474-1
  a curric:KeyLearningPoint ;
  rdfs:label """Sheers depicts a relationship which is initially fragmented as the couple are physically and emotionally separated."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633418Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2474-2
  a curric:KeyLearningPoint ;
  rdfs:label """By the end of the poem the couple have salvaged their relationship and are reunified."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633423Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2474-3
  a curric:KeyLearningPoint ;
  rdfs:label """The inconsistent form followed by a final couplet could mirror the changing status of the relationship."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633427Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2474-4
  a curric:KeyLearningPoint ;
  rdfs:label """The setting at the start of the poem reflects the couples despairing and hopeless emotions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633432Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2474-5
  a curric:KeyLearningPoint ;
  rdfs:label """The poem is from a wider collection entitled 'Skirrid Hill' which means 'shattered mountain'."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633437Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2559-1
  a curric:KeyLearningPoint ;
  rdfs:label """The language around the upheaval implies that refugees lose their sense of belonging and purpose."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633441Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2559-2
  a curric:KeyLearningPoint ;
  rdfs:label """Potentially, Hardi may have focused on mundane objects to show how refugees create homes for themselves."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633448Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2559-3
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, the structure of the poem may reflect the constant upheaval of the refugees lives."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633453Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2559-4
  a curric:KeyLearningPoint ;
  rdfs:label """We might read the "trees" in the poem as a metaphor for the speaker's heritage and family traditions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633458Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2559-5
  a curric:KeyLearningPoint ;
  rdfs:label """The final line may suggest that the upheaval has caused the speaker to lose their connection to their heritage."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633462Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2037-1
  a curric:KeyLearningPoint ;
  rdfs:label """The poem's title can be used to clarify the meaning of the poem in terms of themes and subject matter."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633470Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2037-2
  a curric:KeyLearningPoint ;
  rdfs:label "You can analyse the title of the poem alongside your analysis of the quotes."@en ;
  dcterms:modified "2026-02-12T08:59:21.633475Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2037-3
  a curric:KeyLearningPoint ;
  rdfs:label "A poem's title often gives an indication of the atmosphere and tone."@en ;
  dcterms:modified "2026-02-12T08:59:21.633480Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1479-1
  a curric:KeyLearningPoint ;
  rdfs:label """When we talk about how a text is structured, we mean what does the writer focus our attention on in each part and why."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633539Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1479-2
  a curric:KeyLearningPoint ;
  rdfs:label "Writers make deliberate structural choices to create precise effects."@en ;
  dcterms:modified "2026-02-12T08:59:21.633543Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1479-3
  a curric:KeyLearningPoint ;
  rdfs:label """Don't comment on word choices or devices – instead consider the effect of shifts in focus or narrative perspective."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633548Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2366-1
  a curric:KeyLearningPoint ;
  rdfs:label "Context refers to historical, social, literary and biographical information."@en ;
  dcterms:modified "2026-02-12T08:59:21.633552Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2366-2
  a curric:KeyLearningPoint ;
  rdfs:label "Weaving context in your thesis can be a powerful way to start an essay."@en ;
  dcterms:modified "2026-02-12T08:59:21.633557Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2366-3
  a curric:KeyLearningPoint ;
  rdfs:label "Context should be woven throughout your essay."@en ;
  dcterms:modified "2026-02-12T08:59:21.633562Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2366-4
  a curric:KeyLearningPoint ;
  rdfs:label "Context can be used to add depth to your analysis."@en ;
  dcterms:modified "2026-02-12T08:59:21.633566Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29033-1
  a curric:KeyLearningPoint ;
  rdfs:label """Priestley reimagines the maverick detective to expose moral corruption, not solve a crime."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633571Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29033-2
  a curric:KeyLearningPoint ;
  rdfs:label """The Inspector embodies the rogue archetype—committed to justice beyond the law and unafraid to challenge authority."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633578Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29033-3
  a curric:KeyLearningPoint ;
  rdfs:label """Priestley reshapes this archetype to serve his political message on class and responsibility."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633583Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29033-4
  a curric:KeyLearningPoint ;
  rdfs:label """Using archetypes doesn’t limit originality but helps explore universal themes in new ways."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633587Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29033-5
  a curric:KeyLearningPoint ;
  rdfs:label """The Inspector's interrogation style reflects the maverick archetype in its authoritative and relentless style."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633592Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1668-1
  a curric:KeyLearningPoint ;
  rdfs:label """Topic sentences should have a clear focus and use discourse markers to contextualise the section of the novella."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633596Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1668-2
  a curric:KeyLearningPoint ;
  rdfs:label """Clear discourse markers should be used to link between different sections of the novella."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633601Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1668-3
  a curric:KeyLearningPoint ;
  rdfs:label "Quotations should be embedded into sentences."@en ;
  dcterms:modified "2026-02-12T08:59:21.633608Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1668-4
  a curric:KeyLearningPoint ;
  rdfs:label """Always ask yourself ‘why’ when analysing - this will help you keep focused on the writer’s intention."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633613Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1668-5
  a curric:KeyLearningPoint ;
  rdfs:label "Noun appositives can help keep your work succinct."@en ;
  dcterms:modified "2026-02-12T08:59:21.633618Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1488-1
  a curric:KeyLearningPoint ;
  rdfs:label """A comparison is a consideration or evaluation of the similarities or differences between two things or people."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633623Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1488-2
  a curric:KeyLearningPoint ;
  rdfs:label """It might be helpful to think of the writers as in conversation with one another when comparing texts."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633627Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1488-3
  a curric:KeyLearningPoint ;
  rdfs:label "You should start a comparative paragraph with a comparative topic sentence."@en ;
  dcterms:modified "2026-02-12T08:59:21.633632Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1488-4
  a curric:KeyLearningPoint ;
  rdfs:label """You should use discourse markers and comparative and correlative conjunctions to compare throughout the paragraph."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633637Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9254-1
  a curric:KeyLearningPoint ;
  rdfs:label """Wordsworth conveys a sense of childlike innocence and naivety in his poem by portraying his younger self as mischievous."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633642Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9254-2
  a curric:KeyLearningPoint ;
  rdfs:label """Wordsworth uses figurative language to convey the euphoria and excitement of the group as they skate."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633647Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9254-3
  a curric:KeyLearningPoint ;
  rdfs:label """The Sublime is the meeting of our internal emotions, with the external, natural world."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633653Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9254-4
  a curric:KeyLearningPoint ;
  rdfs:label """Wordsworth successfully portrays the beauty, magnitude and superiority of nature in the poem."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633659Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9254-5
  a curric:KeyLearningPoint ;
  rdfs:label """Wordsworth ends the poem with a foreboding tone, perhaps to represent the darkness that would imminently enter his life."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633663Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9250-1
  a curric:KeyLearningPoint ;
  rdfs:label "A good analytical response begins with a clear and concise thesis statement."@en ;
  dcterms:modified "2026-02-12T08:59:21.633670Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9250-2
  a curric:KeyLearningPoint ;
  rdfs:label """Comparative connectives can be used to link ideas together and explore connections between poems."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633675Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9250-3
  a curric:KeyLearningPoint ;
  rdfs:label """Quotations can be signposted with where they appear in the poem e.g. ‘in the final stanza’."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633680Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9250-4
  a curric:KeyLearningPoint ;
  rdfs:label "Analysis can focus on 'bigger' methods and then the effects of these methods."@en ;
  dcterms:modified "2026-02-12T08:59:21.633685Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9250-5
  a curric:KeyLearningPoint ;
  rdfs:label "Context should be used to support your argument."@en ;
  dcterms:modified "2026-02-12T08:59:21.633690Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2084-1
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, Brontë conveys the concept of exclusion through the descriptions of the windows in 'Wuthering Heights'."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633846Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2084-2
  a curric:KeyLearningPoint ;
  rdfs:label """Brontë uses the physical description of the window to show this idea of exclusion to the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633854Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2084-3
  a curric:KeyLearningPoint ;
  rdfs:label """Brontë also considers how the character interacts with the window in order to create that sense of exclusion."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633859Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2084-4
  a curric:KeyLearningPoint ;
  rdfs:label """To craft your own motifs, you might begin by asking what emotion or concept it is you want to portray."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633894Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28490-1
  a curric:KeyLearningPoint ;
  rdfs:label """The narrator of Ishiguro’s ‘Klara and the Sun’ is an artificial intelligence companion for children."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633899Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28490-2
  a curric:KeyLearningPoint ;
  rdfs:label """In order to emulate Ishiguro’s use of an artificial voice, we might describe the character in mechanical terms."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633904Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28490-3
  a curric:KeyLearningPoint ;
  rdfs:label """They might offer a description of their surroundings that focuses on spatiality  rather than sensory language."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633909Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28490-4
  a curric:KeyLearningPoint ;
  rdfs:label """You could also show how the character doesn’t fully comprehend social situations or interactions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633914Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2021-1
  a curric:KeyLearningPoint ;
  rdfs:label "Dr. Jekyll is hiding away in his laboratory when Utterson goes to visit him."@en ;
  dcterms:modified "2026-02-12T08:59:21.633919Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2021-2
  a curric:KeyLearningPoint ;
  rdfs:label """The long route through Jekyll’s house mirrors the tortuous journey of Utterson and the reader to reach the truth."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633923Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2021-3
  a curric:KeyLearningPoint ;
  rdfs:label """The dingy confining setting of Jekyll’s laboratory hints at the way Jekyll is becoming a prisoner of his own actions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633928Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2021-4
  a curric:KeyLearningPoint ;
  rdfs:label """Utterson’s home by comparison is warm and welcoming, highlighting the contrast with his friend."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633932Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2323-1
  a curric:KeyLearningPoint ;
  rdfs:label """When first given an essay question, use the question to brainstorm all the possible ideas you could include."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633961Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2323-2
  a curric:KeyLearningPoint ;
  rdfs:label "It is important to be judicious about which evidence and ideas you will include."@en ;
  dcterms:modified "2026-02-12T08:59:21.633966Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2323-3
  a curric:KeyLearningPoint ;
  rdfs:label """Ideally, you want to include a range of moments from across the text that all support your thesis statement."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633971Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2323-4
  a curric:KeyLearningPoint ;
  rdfs:label """Try to include a personal response to the text, to show your reader your engagement with it,  and understanding of it."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633978Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2323-5
  a curric:KeyLearningPoint ;
  rdfs:label "Paragraph outlines are useful when planning your response."@en ;
  dcterms:modified "2026-02-12T08:59:21.633983Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1703-1
  a curric:KeyLearningPoint ;
  rdfs:label """’Poppies’ is from the poetry collection 'Exit Wounds’ which explores lesser-recognised experiences of war"""@en ;
  dcterms:modified "2026-02-12T08:59:21.633988Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1703-2
  a curric:KeyLearningPoint ;
  rdfs:label """Written from the perspective of a mother, Weir presents the quiet trauma of those who lose close relatives at war"""@en ;
  dcterms:modified "2026-02-12T08:59:21.633992Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1703-3
  a curric:KeyLearningPoint ;
  rdfs:label """Weir's poem struck a nerve with many mothers who had lost their children during conflict"""@en ;
  dcterms:modified "2026-02-12T08:59:21.633997Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1703-4
  a curric:KeyLearningPoint ;
  rdfs:label """Weir is a textile designer and applied the technique of felt making to this poem to explore the deep process of grief"""@en ;
  dcterms:modified "2026-02-12T08:59:21.634001Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6237-1
  a curric:KeyLearningPoint ;
  rdfs:label """Evaluation requires you to critically examine something, thus it is more complex than understanding and analysis."""@en ;
  dcterms:modified "2026-02-12T08:59:21.634006Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6237-2
  a curric:KeyLearningPoint ;
  rdfs:label "Using evaluative adverbs and adjectives is good way to signpost your evaluation."@en ;
  dcterms:modified "2026-02-12T08:59:21.634011Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6237-3
  a curric:KeyLearningPoint ;
  rdfs:label """Evaluative adverbs show you are able to comment on how well a writer does something."""@en ;
  dcterms:modified "2026-02-12T08:59:21.634015Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6237-4
  a curric:KeyLearningPoint ;
  rdfs:label "You should use evidence from the text to support your evaluative comments."@en ;
  dcterms:modified "2026-02-12T08:59:21.634020Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2012-1
  a curric:KeyLearningPoint ;
  rdfs:label """Hubris, hamartia, stubornnesss and self-discovery are all characteristics of a tragic hero"""@en ;
  dcterms:modified "2026-02-12T08:59:21.634024Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2012-2
  a curric:KeyLearningPoint ;
  rdfs:label "Macbeth displays hubris by disregarding the natural order"@en ;
  dcterms:modified "2026-02-12T08:59:21.634029Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2012-3
  a curric:KeyLearningPoint ;
  rdfs:label "Some people argue that Macbeth’s hamartia is his overly ambitious nature"@en ;
  dcterms:modified "2026-02-12T08:59:21.634034Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2012-4
  a curric:KeyLearningPoint ;
  rdfs:label """Macbeth feels guilt throughout the play, although it is arguable whether he learns a moral lesson"""@en ;
  dcterms:modified "2026-02-12T08:59:21.634038Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1645-1
  a curric:KeyLearningPoint ;
  rdfs:label """Dramatically, Act 3, Scene 2 mirrors Act 1, Scene 5, with a murder being plotted."""@en ;
  dcterms:modified "2026-02-12T08:59:21.634043Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1645-2
  a curric:KeyLearningPoint ;
  rdfs:label """However, roles have been reversed and Macbeth seems to be in control in this scene."""@en ;
  dcterms:modified "2026-02-12T08:59:21.634048Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1645-3
  a curric:KeyLearningPoint ;
  rdfs:label """Both characters appear uneasy during this scene; power and status have not led to happiness."""@en ;
  dcterms:modified "2026-02-12T08:59:21.634053Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1645-4
  a curric:KeyLearningPoint ;
  rdfs:label """Mirroring Lady Macbeth's "unsex me here", Macbeth seems to want to rid himself of "his bond" with humanity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.634057Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1495-1
  a curric:KeyLearningPoint ;
  rdfs:label """Analysing methods helps us to consider the effect the writer is trying to have on the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.634065Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1495-2
  a curric:KeyLearningPoint ;
  rdfs:label """Comparing the methods used helps us understand the writers' craft and how it relates to meaning."""@en ;
  dcterms:modified "2026-02-12T08:59:21.634069Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1495-3
  a curric:KeyLearningPoint ;
  rdfs:label """Both Dickens and Day use "crammed"; however Day uses juxtaposition to lessen the chaotic atmosphere."""@en ;
  dcterms:modified "2026-02-12T08:59:21.634074Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1495-4
  a curric:KeyLearningPoint ;
  rdfs:label "Dickens enhances the overwhelming atmosphere through listing and onomatopoeia."@en ;
  dcterms:modified "2026-02-12T08:59:21.634079Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1495-5
  a curric:KeyLearningPoint ;
  rdfs:label "Day creates a calmer atmosphere by avoiding the use of listing and onomatopoeia."@en ;
  dcterms:modified "2026-02-12T08:59:21.634083Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2526-1
  a curric:KeyLearningPoint ;
  rdfs:label "There are many different types of conflict presented in the anthology."@en ;
  dcterms:modified "2026-02-12T08:59:21.634088Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2526-2
  a curric:KeyLearningPoint ;
  rdfs:label "Many of the poems explore multiple types of conflict."@en ;
  dcterms:modified "2026-02-12T08:59:21.634093Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2526-3
  a curric:KeyLearningPoint ;
  rdfs:label "Conflict can be internal, focused on emotions, rather than external."@en ;
  dcterms:modified "2026-02-12T08:59:21.634097Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2526-4
  a curric:KeyLearningPoint ;
  rdfs:label """Creative comparisons between poems may avoid focusing on obvious similarities between types of conflict."""@en ;
  dcterms:modified "2026-02-12T08:59:21.634102Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2526-5
  a curric:KeyLearningPoint ;
  rdfs:label "Conflict often links to change/progress, injustice and a power imbalance."@en ;
  dcterms:modified "2026-02-12T08:59:21.634106Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2539-1
  a curric:KeyLearningPoint ;
  rdfs:label "Arguably, both poets present childhood in an idealised way."@en ;
  dcterms:modified "2026-02-12T08:59:21.634111Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2539-2
  a curric:KeyLearningPoint ;
  rdfs:label "Both poets use language to depict childhood as a place of safety and protection."@en ;
  dcterms:modified "2026-02-12T08:59:21.634118Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2539-3
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, Clare creates an excited, joyful tone while Brontë creates a reflective, joyful tone."""@en ;
  dcterms:modified "2026-02-12T08:59:21.634123Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2539-4
  a curric:KeyLearningPoint ;
  rdfs:label """The use of regularity and enjambment in both poems could reflect the continual joy of childhood."""@en ;
  dcterms:modified "2026-02-12T08:59:21.634128Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2539-5
  a curric:KeyLearningPoint ;
  rdfs:label "Romantics revered childhood and presented it in an idealised way."@en ;
  dcterms:modified "2026-02-12T08:59:21.634133Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2394-1
  a curric:KeyLearningPoint ;
  rdfs:label """Paralanguage is important: the pitch, tempo, loudness or tone of voice that is used in speeches can enhance the content."""@en ;
  dcterms:modified "2026-02-12T08:59:21.634156Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2394-2
  a curric:KeyLearningPoint ;
  rdfs:label """Kinesics - gesture and posture - can be used to engage the audience and to add emphasis to important points."""@en ;
  dcterms:modified "2026-02-12T08:59:21.634161Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2394-3
  a curric:KeyLearningPoint ;
  rdfs:label "Spoken language often needs to be slower than feels natural."@en ;
  dcterms:modified "2026-02-12T08:59:21.634166Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2394-4
  a curric:KeyLearningPoint ;
  rdfs:label """Pupils need to consider their spatial behaviour- too much movement can be distracting but too little can be wooden."""@en ;
  dcterms:modified "2026-02-12T08:59:21.634171Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2117-1
  a curric:KeyLearningPoint ;
  rdfs:label "We do not have to get to the resolution of a plot in a short story."@en ;
  dcterms:modified "2026-02-12T08:59:21.634176Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2117-2
  a curric:KeyLearningPoint ;
  rdfs:label "We can manipulate time in our narrative to give it an interesting structure."@en ;
  dcterms:modified "2026-02-12T08:59:21.634180Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2117-3
  a curric:KeyLearningPoint ;
  rdfs:label """When we manipulate time, we need to ensure we set up for the rest of the narrative to follow."""@en ;
  dcterms:modified "2026-02-12T08:59:21.634185Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2117-4
  a curric:KeyLearningPoint ;
  rdfs:label "We must maintain a consistent narrative voice throughout our work."@en ;
  dcterms:modified "2026-02-12T08:59:21.634190Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2117-5
  a curric:KeyLearningPoint ;
  rdfs:label """Interspersing the plot with a narrator’s inner monologue can be a clever way to build tension."""@en ;
  dcterms:modified "2026-02-12T08:59:21.634195Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28978-1
  a curric:KeyLearningPoint ;
  rdfs:label "Shakespeare presents Tybalt as seeing violence as a solution to problems."@en ;
  dcterms:modified "2026-02-12T08:59:21.634201Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28978-2
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, Tybalt’s use of rhyming words could indicate he feels in control when committing violent acts."""@en ;
  dcterms:modified "2026-02-12T08:59:21.634207Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28978-3
  a curric:KeyLearningPoint ;
  rdfs:label """Tybalt's repeated reference to Romeo as a “villain” suggests he sees Romeo’s actions as dishonourable."""@en ;
  dcterms:modified "2026-02-12T08:59:21.634212Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28978-4
  a curric:KeyLearningPoint ;
  rdfs:label """Potentially, the fricative sounds in Tybalt’s speech could suggest he’s consumed by his views on honour."""@en ;
  dcterms:modified "2026-02-12T08:59:21.634216Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28978-5
  a curric:KeyLearningPoint ;
  rdfs:label """Lord Capulet establishes his dominance and authority over Tybalt in Act 1, Scene 5."""@en ;
  dcterms:modified "2026-02-12T08:59:21.634221Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2464-1
  a curric:KeyLearningPoint ;
  rdfs:label "Dickens uses the weather throughout the text to symbolise Scrooge’s redemption."@en ;
  dcterms:modified "2026-02-12T08:59:21.634250Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2464-2
  a curric:KeyLearningPoint ;
  rdfs:label """The fog in Stave 1 symbolises Scrooge’s wilful ignorance to the suffering of others."""@en ;
  dcterms:modified "2026-02-12T08:59:21.634255Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2464-3
  a curric:KeyLearningPoint ;
  rdfs:label """Dickens uses bells in the novella to symbolise judgement and as a call to moral awakening."""@en ;
  dcterms:modified "2026-02-12T08:59:21.634260Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2464-4
  a curric:KeyLearningPoint ;
  rdfs:label "Dickens uses music throughout the novella to symbolise unity and equality ."@en ;
  dcterms:modified "2026-02-12T08:59:21.634264Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2464-5
  a curric:KeyLearningPoint ;
  rdfs:label """The novella’s title is symbolic of Dickens’ hope for his message to be passed down from generation to generation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.634269Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29059-1
  a curric:KeyLearningPoint ;
  rdfs:label "Wilfred Owen is widely considered to be one of the most important WW1 poets."@en ;
  dcterms:modified "2026-02-12T08:59:21.634274Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29059-2
  a curric:KeyLearningPoint ;
  rdfs:label "Arguably, Owen’s poetry reveals the horror and futility of war."@en ;
  dcterms:modified "2026-02-12T08:59:21.634278Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29059-3
  a curric:KeyLearningPoint ;
  rdfs:label "‘Disabled’ focuses on an injured soldier in the aftermath of WW1."@en ;
  dcterms:modified "2026-02-12T08:59:21.634286Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29059-4
  a curric:KeyLearningPoint ;
  rdfs:label """We might read ‘Disabled’ as demonstrating how the young men who enlisted did not know what they were signing up for."""@en ;
  dcterms:modified "2026-02-12T08:59:21.634291Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29059-5
  a curric:KeyLearningPoint ;
  rdfs:label """We might see ‘Disabled’ as exploring the loss of identity and isolation of soldiers in the aftermath of war."""@en ;
  dcterms:modified "2026-02-12T08:59:21.634295Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29079-1
  a curric:KeyLearningPoint ;
  rdfs:label """Before writing, you should consider why you have picked your chosen poem for comparison."""@en ;
  dcterms:modified "2026-02-12T08:59:21.634300Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29079-2
  a curric:KeyLearningPoint ;
  rdfs:label "A planning grid with single paragraph outlines can be a useful planning tool."@en ;
  dcterms:modified "2026-02-12T08:59:21.634305Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29079-3
  a curric:KeyLearningPoint ;
  rdfs:label """Considering the success criteria before writing helps you remember what to include for a successful essay."""@en ;
  dcterms:modified "2026-02-12T08:59:21.634310Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2382-1
  a curric:KeyLearningPoint ;
  rdfs:label "Language is empowering and enables us to enact social or political changes."@en ;
  dcterms:modified "2026-02-12T08:59:21.634315Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2382-2
  a curric:KeyLearningPoint ;
  rdfs:label """Having a consistent method will help to make sure your annotations are efficient and easy to understand."""@en ;
  dcterms:modified "2026-02-12T08:59:21.634319Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2382-3
  a curric:KeyLearningPoint ;
  rdfs:label """Effective discussions will take turns, develop ideas, use evidence and respond to the other speaker."""@en ;
  dcterms:modified "2026-02-12T08:59:21.634324Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2382-4
  a curric:KeyLearningPoint ;
  rdfs:label """Adverbs such as 'arguably' and 'undeniably', can be used to show the extent to which we agree with an idea or statement."""@en ;
  dcterms:modified "2026-02-12T08:59:21.634329Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2052-1
  a curric:KeyLearningPoint ;
  rdfs:label """To compare the structure, you may ask questions about the layout, use of structural techniques and journey of the poems."""@en ;
  dcterms:modified "2026-02-12T08:59:21.634333Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2052-2
  a curric:KeyLearningPoint ;
  rdfs:label """To compare the voice, you might ask questions about narrative voice and perspective."""@en ;
  dcterms:modified "2026-02-12T08:59:21.634341Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2052-3
  a curric:KeyLearningPoint ;
  rdfs:label """To compare the language, you might ask questions about words and images in the poems."""@en ;
  dcterms:modified "2026-02-12T08:59:21.634346Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2052-4
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, both Laskey and Robertson use structure, voice and language to consider ideas of transience in their poems."""@en ;
  dcterms:modified "2026-02-12T08:59:21.634351Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28790-1
  a curric:KeyLearningPoint ;
  rdfs:label "Sheila’s journey in the play can be described as transformative."@en ;
  dcterms:modified "2026-02-12T08:59:21.634422Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28790-2
  a curric:KeyLearningPoint ;
  rdfs:label """The Inspector emotionally impacts Sheila and acknowledges she is “impressionable”."""@en ;
  dcterms:modified "2026-02-12T08:59:21.634429Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28790-3
  a curric:KeyLearningPoint ;
  rdfs:label "Sheila aligns herself with the Inspector’s purpose and moral messages."@en ;
  dcterms:modified "2026-02-12T08:59:21.634434Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28790-4
  a curric:KeyLearningPoint ;
  rdfs:label """The younger generation being seen as a symbol of change and hope is a timeless idea."""@en ;
  dcterms:modified "2026-02-12T08:59:21.634439Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28790-5
  a curric:KeyLearningPoint ;
  rdfs:label """Priestley uses Sheila, a member of the younger generation, to explore ideas around hope and optimism."""@en ;
  dcterms:modified "2026-02-12T08:59:21.634446Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2304-1
  a curric:KeyLearningPoint ;
  rdfs:label "Enid values education."@en ;
  dcterms:modified "2026-02-12T08:59:21.634795Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2304-2
  a curric:KeyLearningPoint ;
  rdfs:label "Enid believes education is a way to escape the rural poverty she experienced."@en ;
  dcterms:modified "2026-02-12T08:59:21.634803Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2304-3
  a curric:KeyLearningPoint ;
  rdfs:label "Enid believes that education can't be taken away from someone."@en ;
  dcterms:modified "2026-02-12T08:59:21.634808Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2304-4
  a curric:KeyLearningPoint ;
  rdfs:label "Pinnock says her parents received a colonialist education."@en ;
  dcterms:modified "2026-02-12T08:59:21.634813Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2304-5
  a curric:KeyLearningPoint ;
  rdfs:label """Pinnock uses the character of Brod to explore the narrow focus of the British education system in the 1980s."""@en ;
  dcterms:modified "2026-02-12T08:59:21.634817Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2485-1
  a curric:KeyLearningPoint ;
  rdfs:label """Shelley uses natural imagery to create an idyllic and idealised natural landscape."""@en ;
  dcterms:modified "2026-02-12T08:59:21.634822Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2485-2
  a curric:KeyLearningPoint ;
  rdfs:label "Shelley uses religious imagery to suggest that natural symmetry is divine."@en ;
  dcterms:modified "2026-02-12T08:59:21.634827Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2485-3
  a curric:KeyLearningPoint ;
  rdfs:label """Shelley uses sensual verbs to convey his desire for physical intimacy with his partner."""@en ;
  dcterms:modified "2026-02-12T08:59:21.634832Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2485-4
  a curric:KeyLearningPoint ;
  rdfs:label """Shelley uses rhetorical questions to suggest his frustration in his failure to woo his lover."""@en ;
  dcterms:modified "2026-02-12T08:59:21.634836Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2485-5
  a curric:KeyLearningPoint ;
  rdfs:label "Shelley uses form and structure to subtly reinforce the importance of coupling."@en ;
  dcterms:modified "2026-02-12T08:59:21.634841Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2082-1
  a curric:KeyLearningPoint ;
  rdfs:label """In order to emulate the opening of Orwell's '1984', you might start with a small detail that doesn't fit with reality."""@en ;
  dcterms:modified "2026-02-12T08:59:21.634846Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2082-2
  a curric:KeyLearningPoint ;
  rdfs:label "Using a semantic field of unpleasantness can create an unsettling atmosphere."@en ;
  dcterms:modified "2026-02-12T08:59:21.634851Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2082-3
  a curric:KeyLearningPoint ;
  rdfs:label "You might create the sensation of physical discomfort."@en ;
  dcterms:modified "2026-02-12T08:59:21.634855Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2082-4
  a curric:KeyLearningPoint ;
  rdfs:label "You might progress ideas so that the level of discomfort builds in the reader."@en ;
  dcterms:modified "2026-02-12T08:59:21.634860Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2082-5
  a curric:KeyLearningPoint ;
  rdfs:label "Releasing details about a dystopia slowly can build an unsettling sensation."@en ;
  dcterms:modified "2026-02-12T08:59:21.634865Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2109-1
  a curric:KeyLearningPoint ;
  rdfs:label "Voice is the language a writer uses to convey a perspective or tell a story."@en ;
  dcterms:modified "2026-02-12T08:59:21.634925Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2109-2
  a curric:KeyLearningPoint ;
  rdfs:label "Voice affects how we connect to and interpret the text."@en ;
  dcterms:modified "2026-02-12T08:59:21.634931Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2109-3
  a curric:KeyLearningPoint ;
  rdfs:label "Voice can be crafted through syntax, punctuation, repetition and word choice."@en ;
  dcterms:modified "2026-02-12T08:59:21.634936Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2109-4
  a curric:KeyLearningPoint ;
  rdfs:label """Voice can help shape a character's age, social class, mood, gender and the time period in which they are from in a text."""@en ;
  dcterms:modified "2026-02-12T08:59:21.634941Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2109-5
  a curric:KeyLearningPoint ;
  rdfs:label """Writers can craft a distinct voice to reveal people's differing reactions to the same scenario or event."""@en ;
  dcterms:modified "2026-02-12T08:59:21.634946Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6239-1
  a curric:KeyLearningPoint ;
  rdfs:label """You can experiment with time to create an interesting structure to your narrative."""@en ;
  dcterms:modified "2026-02-12T08:59:21.634950Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6239-2
  a curric:KeyLearningPoint ;
  rdfs:label """The use of flashback is powerful in 'The Cellist of Sarajevo' to help the reader connect to the character."""@en ;
  dcterms:modified "2026-02-12T08:59:21.634955Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6239-3
  a curric:KeyLearningPoint ;
  rdfs:label """The use of flashforward adds a sense of inevitability and a poignant tone to writing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.634960Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6239-4
  a curric:KeyLearningPoint ;
  rdfs:label "Flashbacks are powerful when they contrast to the present moment in some way."@en ;
  dcterms:modified "2026-02-12T08:59:21.634965Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6239-5
  a curric:KeyLearningPoint ;
  rdfs:label """Using certain phrases before your time shifts can help to create seamless transitions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.634969Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29007-1
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, Paris’ use of imperative language suggests that men stereotypically dictated women’s life choices."""@en ;
  dcterms:modified "2026-02-12T08:59:21.634974Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29007-2
  a curric:KeyLearningPoint ;
  rdfs:label """Paris’ claim “thy face is mine” could reveal how women were not considered in control of their bodies."""@en ;
  dcterms:modified "2026-02-12T08:59:21.634981Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29007-3
  a curric:KeyLearningPoint ;
  rdfs:label "We might see Juliet’s desire to die as a way of taking control of her life."@en ;
  dcterms:modified "2026-02-12T08:59:21.634988Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29007-4
  a curric:KeyLearningPoint ;
  rdfs:label """However, this might be undermined since her desire to die comes from her wish to remain “unstained” for Romeo."""@en ;
  dcterms:modified "2026-02-12T08:59:21.634993Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29007-5
  a curric:KeyLearningPoint ;
  rdfs:label """We might see Juliet’s use of imperatives as subverting contemporary stereotypes of women."""@en ;
  dcterms:modified "2026-02-12T08:59:21.634998Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29868-1
  a curric:KeyLearningPoint ;
  rdfs:label """Pinnock describes Enid as strict but protective, trying to prepare her daughters for a harsh world."""@en ;
  dcterms:modified "2026-02-12T08:59:21.635003Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29868-2
  a curric:KeyLearningPoint ;
  rdfs:label """Del and Viv are complex characters inspired by Pinnock’s love of strong female roles."""@en ;
  dcterms:modified "2026-02-12T08:59:21.635007Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29868-3
  a curric:KeyLearningPoint ;
  rdfs:label """Pinnock explains that characters sometimes act against expectations to support each other."""@en ;
  dcterms:modified "2026-02-12T08:59:21.635012Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29868-4
  a curric:KeyLearningPoint ;
  rdfs:label """Pinnock says Brod and Mai show how the community supports and guides the younger generation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.635017Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29868-5
  a curric:KeyLearningPoint ;
  rdfs:label """Del reading Enid’s palm and embracing Obeah shows her empathy and continuation of tradition."""@en ;
  dcterms:modified "2026-02-12T08:59:21.635022Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2467-1
  a curric:KeyLearningPoint ;
  rdfs:label """Dickens characterises the businessmen as physically grotesque to reflect their "monstrous" morals and attitudes"""@en ;
  dcterms:modified "2026-02-12T08:59:21.635027Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2467-2
  a curric:KeyLearningPoint ;
  rdfs:label """During Stave 4, Scrooge expects to see himself in the scenes because he has already resolved to change"""@en ;
  dcterms:modified "2026-02-12T08:59:21.635031Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2467-3
  a curric:KeyLearningPoint ;
  rdfs:label """The ‘criminal classes’ were people who were drawn to committing crimes by a misguided sense of morality"""@en ;
  dcterms:modified "2026-02-12T08:59:21.635036Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2467-4
  a curric:KeyLearningPoint ;
  rdfs:label """Through Mrs. Dilber, Dickens illustrates that those neglected by society have no choice but to turn to criminality"""@en ;
  dcterms:modified "2026-02-12T08:59:21.635040Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2467-5
  a curric:KeyLearningPoint ;
  rdfs:label "Dickens viewed criminality as the symptom of a failing society"@en ;
  dcterms:modified "2026-02-12T08:59:21.635045Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29076-1
  a curric:KeyLearningPoint ;
  rdfs:label """Both 'Catrin' and 'Origin Story' explore the complexities of relationships and the impact of different types of love."""@en ;
  dcterms:modified "2026-02-12T08:59:21.635134Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29076-2
  a curric:KeyLearningPoint ;
  rdfs:label """Clarke presents love as intense and restrictive, whereas Ewing suggests that love is fragile but enduring."""@en ;
  dcterms:modified "2026-02-12T08:59:21.635141Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29076-3
  a curric:KeyLearningPoint ;
  rdfs:label """Both Clarke and Ewing write using a first-person perspective which shapes how their experiences are presented."""@en ;
  dcterms:modified "2026-02-12T08:59:21.635146Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29076-4
  a curric:KeyLearningPoint ;
  rdfs:label """Both poems use metaphor and symbolism to represent different aspects of love and perspective."""@en ;
  dcterms:modified "2026-02-12T08:59:21.635153Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29076-5
  a curric:KeyLearningPoint ;
  rdfs:label """The poets use structure to emphasise the different sides or stages of love and identity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.635158Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28789-1
  a curric:KeyLearningPoint ;
  rdfs:label """Mrs. Birling could reflect stereotypical attitudes of upper class Edwardian society."""@en ;
  dcterms:modified "2026-02-12T08:59:21.635339Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28789-2
  a curric:KeyLearningPoint ;
  rdfs:label "Priestley uses the older generation of Birlings to critique Edwardian attitudes."@en ;
  dcterms:modified "2026-02-12T08:59:21.635344Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28789-3
  a curric:KeyLearningPoint ;
  rdfs:label """Mrs Birling’s interrogation reveals her attitude towards the working class and social responsibility."""@en ;
  dcterms:modified "2026-02-12T08:59:21.635349Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28789-4
  a curric:KeyLearningPoint ;
  rdfs:label """When writing about a character it can be useful to consider how they are presented throughout the play."""@en ;
  dcterms:modified "2026-02-12T08:59:21.635353Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28783-1
  a curric:KeyLearningPoint ;
  rdfs:label """Contextual information can help to deepen an understanding of a writer’s intentions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.635358Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28783-2
  a curric:KeyLearningPoint ;
  rdfs:label "It is a good idea to be tentative with assertions."@en ;
  dcterms:modified "2026-02-12T08:59:21.635363Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28783-3
  a curric:KeyLearningPoint ;
  rdfs:label "Biographical information can give us clues about a writer’s influences."@en ;
  dcterms:modified "2026-02-12T08:59:21.635368Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28783-4
  a curric:KeyLearningPoint ;
  rdfs:label """Although writing in 1945, Priestley was influenced by the attitudes and values of Edwardian society."""@en ;
  dcterms:modified "2026-02-12T08:59:21.635373Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28783-5
  a curric:KeyLearningPoint ;
  rdfs:label "Priestley uses the backdrop of 1912 to warn of the dangers of repeating history."@en ;
  dcterms:modified "2026-02-12T08:59:21.635380Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1681-1
  a curric:KeyLearningPoint ;
  rdfs:label """Breaking the sonnet form reflects the way that human power and man-made structures can be disrupted and destroyed."""@en ;
  dcterms:modified "2026-02-12T08:59:21.635385Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1681-2
  a curric:KeyLearningPoint ;
  rdfs:label """Shelley uses symbolic adjectives to emphasise the temporary nature of political and human power and achievements."""@en ;
  dcterms:modified "2026-02-12T08:59:21.635390Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1681-3
  a curric:KeyLearningPoint ;
  rdfs:label """The alliterative final imagery reinforces the insignificance of rulers compared with the desert sands."""@en ;
  dcterms:modified "2026-02-12T08:59:21.635394Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1681-4
  a curric:KeyLearningPoint ;
  rdfs:label """The ironic quoting of Ozymandias’ words demonstrates the meaninglessness of his legacy and his weakness."""@en ;
  dcterms:modified "2026-02-12T08:59:21.635399Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29005-1
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, the stage directions in Act 1, Scene 5 show Romeo taking control of the exchange with Juliet."""@en ;
  dcterms:modified "2026-02-12T08:59:21.635404Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29005-2
  a curric:KeyLearningPoint ;
  rdfs:label """Potentially, we might see Juliet as taking both a passive and active role in Act 1, Scene 5."""@en ;
  dcterms:modified "2026-02-12T08:59:21.635409Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29005-3
  a curric:KeyLearningPoint ;
  rdfs:label """Juliet’s language in Act 2, Scene 2 arguably shows her dictating the terms of her relationship with Romeo."""@en ;
  dcterms:modified "2026-02-12T08:59:21.635413Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29005-4
  a curric:KeyLearningPoint ;
  rdfs:label """By bringing up the subject of marriage, Juliet is arguably showing agency in the relationship."""@en ;
  dcterms:modified "2026-02-12T08:59:21.635418Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29005-5
  a curric:KeyLearningPoint ;
  rdfs:label """Stage directions can affect how we perceive power dynamics and relationships between characters."""@en ;
  dcterms:modified "2026-02-12T08:59:21.635423Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28637-1
  a curric:KeyLearningPoint ;
  rdfs:label """Romeo’s use of light imagery suggests that Juliet brings hope and positivity to his life."""@en ;
  dcterms:modified "2026-02-12T08:59:21.635427Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28637-2
  a curric:KeyLearningPoint ;
  rdfs:label "Arguably, Romeo’s language could also be seen as foreshadowing their tragic end."@en ;
  dcterms:modified "2026-02-12T08:59:21.635432Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28637-3
  a curric:KeyLearningPoint ;
  rdfs:label """The religious imagery implies that their love should be respected and that Juliet is Romeo’s destiny."""@en ;
  dcterms:modified "2026-02-12T08:59:21.635437Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28637-4
  a curric:KeyLearningPoint ;
  rdfs:label "Romeo and Juliet’s first conversation creates a shared sonnet."@en ;
  dcterms:modified "2026-02-12T08:59:21.635444Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28637-5
  a curric:KeyLearningPoint ;
  rdfs:label "The shared sonnet form arguably conveys how aligned their love is."@en ;
  dcterms:modified "2026-02-12T08:59:21.635449Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1651-1
  a curric:KeyLearningPoint ;
  rdfs:label "An introduction can start with a general statement about the text"@en ;
  dcterms:modified "2026-02-12T08:59:21.635454Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1651-2
  a curric:KeyLearningPoint ;
  rdfs:label """This can be followed by a more specific statement about the focus of the question, and finally your thesis"""@en ;
  dcterms:modified "2026-02-12T08:59:21.635458Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1651-3
  a curric:KeyLearningPoint ;
  rdfs:label """A conclusion can move from a specific statement about the text to a more general statement at its continued relevance"""@en ;
  dcterms:modified "2026-02-12T08:59:21.635463Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1651-4
  a curric:KeyLearningPoint ;
  rdfs:label "Analysis of writer’s methods and/or context helps develop a paragraph"@en ;
  dcterms:modified "2026-02-12T08:59:21.635472Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1463-1
  a curric:KeyLearningPoint ;
  rdfs:label """Figurative language sees writers use non-literal words and phrases to develop complex ideas about something, or someone."""@en ;
  dcterms:modified "2026-02-12T08:59:21.635477Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1463-2
  a curric:KeyLearningPoint ;
  rdfs:label """De Quincey uses figurative language in his autobiography to develop complex ideas about opium and the chemist."""@en ;
  dcterms:modified "2026-02-12T08:59:21.635482Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1463-3
  a curric:KeyLearningPoint ;
  rdfs:label """When writing figuratively, you should consider the ideas you are trying to convey and use words which develop this idea."""@en ;
  dcterms:modified "2026-02-12T08:59:21.635487Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1466-1
  a curric:KeyLearningPoint ;
  rdfs:label """An open letter is written to a particular person or group but published so that the public can read it."""@en ;
  dcterms:modified "2026-02-12T08:59:21.635491Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1466-2
  a curric:KeyLearningPoint ;
  rdfs:label """Using single paragraph outlines is a good way to plan each paragraph in an extended piece of writing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.635496Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1466-3
  a curric:KeyLearningPoint ;
  rdfs:label """Single paragraph outlines include a topic and concluding sentence written in full, and supporting detail in note form."""@en ;
  dcterms:modified "2026-02-12T08:59:21.635501Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1466-4
  a curric:KeyLearningPoint ;
  rdfs:label """When planning a piece of extended writing, you should consider which methods are most appropriate to convey your ideas."""@en ;
  dcterms:modified "2026-02-12T08:59:21.635505Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2101-1
  a curric:KeyLearningPoint ;
  rdfs:label """When writing an article, you should use a range of literary devices to engage the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.635510Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2101-2
  a curric:KeyLearningPoint ;
  rdfs:label """Some examples of literary devices are anecdote, hyperbole, rhetorical questions, imagery, parody and juxtaposition."""@en ;
  dcterms:modified "2026-02-12T08:59:21.635515Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2101-3
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to use literary devices carefully. Eg: too many rhetorical devices means they lose their effectiveness."""@en ;
  dcterms:modified "2026-02-12T08:59:21.635519Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2101-4
  a curric:KeyLearningPoint ;
  rdfs:label "An anecdote can be an effective way of beginning your article."@en ;
  dcterms:modified "2026-02-12T08:59:21.635524Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9239-1
  a curric:KeyLearningPoint ;
  rdfs:label """Hardy wrote 'A Wife in London' two months after the start of the Second Boer War."""@en ;
  dcterms:modified "2026-02-12T08:59:21.635531Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9239-2
  a curric:KeyLearningPoint ;
  rdfs:label "Hardy was strongly opposed to war - he viewed it as a monumental waste of life."@en ;
  dcterms:modified "2026-02-12T08:59:21.635537Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9239-3
  a curric:KeyLearningPoint ;
  rdfs:label """The poem sees a wife receive a telegram informing her of the death of her husband."""@en ;
  dcterms:modified "2026-02-12T08:59:21.635541Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9239-4
  a curric:KeyLearningPoint ;
  rdfs:label """The wife then receives a letter from her husband before he died, detailing his hopes for their future together."""@en ;
  dcterms:modified "2026-02-12T08:59:21.635546Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9239-5
  a curric:KeyLearningPoint ;
  rdfs:label """The poem contrasts the hope of a returning soldier with the devastating loss of the wife who has been left behind."""@en ;
  dcterms:modified "2026-02-12T08:59:21.635551Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2340-1
  a curric:KeyLearningPoint ;
  rdfs:label """'Catrin' is a personal poem reflecting Clarke's own relationship with her daughter."""@en ;
  dcterms:modified "2026-02-12T08:59:21.635584Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2340-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Catrin' reflects the internal conflict parents face as their children grow."@en ;
  dcterms:modified "2026-02-12T08:59:21.635589Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2340-3
  a curric:KeyLearningPoint ;
  rdfs:label """Clear comparisons can be made to 'Poppies' as both poems focus on parental conflicts."""@en ;
  dcterms:modified "2026-02-12T08:59:21.635593Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2340-4
  a curric:KeyLearningPoint ;
  rdfs:label """Whilst 'Catrin' focuses on one conflict between parent and child, the message is a timeless one."""@en ;
  dcterms:modified "2026-02-12T08:59:21.635598Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2116-1
  a curric:KeyLearningPoint ;
  rdfs:label "When writing a short story, we can condense the traditional narrative arc."@en ;
  dcterms:modified "2026-02-12T08:59:21.635855Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2116-2
  a curric:KeyLearningPoint ;
  rdfs:label "We need to craft for a believable unfolding of events for a short story."@en ;
  dcterms:modified "2026-02-12T08:59:21.635859Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2116-3
  a curric:KeyLearningPoint ;
  rdfs:label """In short stories, we may need to plant seeds of conflict from the very beginning."""@en ;
  dcterms:modified "2026-02-12T08:59:21.635864Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2116-4
  a curric:KeyLearningPoint ;
  rdfs:label "We can also manipulate time in a short story to hook the reader,"@en ;
  dcterms:modified "2026-02-12T08:59:21.635869Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2116-5
  a curric:KeyLearningPoint ;
  rdfs:label """We can begin our story with the climax, a flashback or a moment after the events of the narrative have taken place."""@en ;
  dcterms:modified "2026-02-12T08:59:21.635874Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2064-1
  a curric:KeyLearningPoint ;
  rdfs:label """The motif of nature is used to create a nurturing relationship between Duncan and Macbeth."""@en ;
  dcterms:modified "2026-02-12T08:59:21.635879Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2064-2
  a curric:KeyLearningPoint ;
  rdfs:label "A good leader nurtures and grows others."@en ;
  dcterms:modified "2026-02-12T08:59:21.635883Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2064-3
  a curric:KeyLearningPoint ;
  rdfs:label "Malcolm is the rightful heir to the throne."@en ;
  dcterms:modified "2026-02-12T08:59:21.635888Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2064-4
  a curric:KeyLearningPoint ;
  rdfs:label "Duncan is used as a foil to Macbeth."@en ;
  dcterms:modified "2026-02-12T08:59:21.635893Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2064-5
  a curric:KeyLearningPoint ;
  rdfs:label """Duncan, and his narrative arc, is used as a warning against defying the natural order."""@en ;
  dcterms:modified "2026-02-12T08:59:21.635897Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1631-1
  a curric:KeyLearningPoint ;
  rdfs:label "The witches prophesied that Banquo's children would be kings in Act 1, Scene 3"@en ;
  dcterms:modified "2026-02-12T08:59:21.635902Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1631-2
  a curric:KeyLearningPoint ;
  rdfs:label "Macbeth, now King of Scotland, is paranoid about Banquo and his son, Fleance"@en ;
  dcterms:modified "2026-02-12T08:59:21.635907Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1631-3
  a curric:KeyLearningPoint ;
  rdfs:label "Macbeth arranges to have Banquo and Fleance murdered"@en ;
  dcterms:modified "2026-02-12T08:59:21.635912Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1631-4
  a curric:KeyLearningPoint ;
  rdfs:label "The murderers kill Banquo, but Fleance, his son, escapes"@en ;
  dcterms:modified "2026-02-12T08:59:21.635916Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1631-5
  a curric:KeyLearningPoint ;
  rdfs:label "Neither Macbeth nor Lady Macbeth seem to enjoy their status as monarchs"@en ;
  dcterms:modified "2026-02-12T08:59:21.635921Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1672-1
  a curric:KeyLearningPoint ;
  rdfs:label """Jekyll makes it clear in his final statement that he was repressed by society and driven to create Hyde."""@en ;
  dcterms:modified "2026-02-12T08:59:21.635926Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1672-2
  a curric:KeyLearningPoint ;
  rdfs:label """Some readers may argue that Jekyll shows remorse in his statement, others may disagree."""@en ;
  dcterms:modified "2026-02-12T08:59:21.635935Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1672-3
  a curric:KeyLearningPoint ;
  rdfs:label """It can be argued that repression and remorse do not absolve Jekyll of culpability."""@en ;
  dcterms:modified "2026-02-12T08:59:21.635940Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1672-4
  a curric:KeyLearningPoint ;
  rdfs:label "Nuanced arguments should acknowledge, and critically dismiss, different ideas."@en ;
  dcterms:modified "2026-02-12T08:59:21.635945Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1672-5
  a curric:KeyLearningPoint ;
  rdfs:label "Tentative language is useful for expressing nuanced ideas."@en ;
  dcterms:modified "2026-02-12T08:59:21.635950Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2076-1
  a curric:KeyLearningPoint ;
  rdfs:label """Lanyon may seem like a foil to Jekyll, but ultimately he also succumbs to his curiosity"""@en ;
  dcterms:modified "2026-02-12T08:59:21.635973Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2076-2
  a curric:KeyLearningPoint ;
  rdfs:label """Lanyon and Jekyll have opposing scientific views: Lanyon more conventional, whereas Jekyll pushes boundaries"""@en ;
  dcterms:modified "2026-02-12T08:59:21.635977Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2076-3
  a curric:KeyLearningPoint ;
  rdfs:label """By including their two first person narratives at the end of the novella, Stevenson invites comparison between the men"""@en ;
  dcterms:modified "2026-02-12T08:59:21.635982Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2076-4
  a curric:KeyLearningPoint ;
  rdfs:label """Despite the tension between them, Lanyon continues to protect Jekyll's reputation until after his death"""@en ;
  dcterms:modified "2026-02-12T08:59:21.635987Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2076-5
  a curric:KeyLearningPoint ;
  rdfs:label """Lanyon makes an active choice to witness Hyde's transformation, suggesting that he shares in the blame for his death"""@en ;
  dcterms:modified "2026-02-12T08:59:21.635991Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1492-1
  a curric:KeyLearningPoint ;
  rdfs:label """In a sentence with a colon, one side of the colon makes sense; the other side provides detail or clarification."""@en ;
  dcterms:modified "2026-02-12T08:59:21.635996Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1492-2
  a curric:KeyLearningPoint ;
  rdfs:label """Semicolons link or contrast two independent clauses that each make sense on their own."""@en ;
  dcterms:modified "2026-02-12T08:59:21.636001Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1492-3
  a curric:KeyLearningPoint ;
  rdfs:label "A pair of dashes can be used in place of commas to enhance readability."@en ;
  dcterms:modified "2026-02-12T08:59:21.636008Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1492-4
  a curric:KeyLearningPoint ;
  rdfs:label """Dashes are always more emphatic than commas (they express a point more forcibly and create a longer pause)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.636013Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1496-1
  a curric:KeyLearningPoint ;
  rdfs:label """We can use contextual information to make predictions about what we expect to see in a text."""@en ;
  dcterms:modified "2026-02-12T08:59:21.636017Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1496-2
  a curric:KeyLearningPoint ;
  rdfs:label """Forming a personal response to a text involves considering how the writer's attitude changes as a text progresses."""@en ;
  dcterms:modified "2026-02-12T08:59:21.636025Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1496-3
  a curric:KeyLearningPoint ;
  rdfs:label "Hyperbole is when writers exaggerate for dramatic effect."@en ;
  dcterms:modified "2026-02-12T08:59:21.636030Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1496-4
  a curric:KeyLearningPoint ;
  rdfs:label "Hyperbole can help readers to empathise with and relate to a writer."@en ;
  dcterms:modified "2026-02-12T08:59:21.636034Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1496-5
  a curric:KeyLearningPoint ;
  rdfs:label "It can also help to build suspense and maintain ready engagement."@en ;
  dcterms:modified "2026-02-12T08:59:21.636039Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2104-1
  a curric:KeyLearningPoint ;
  rdfs:label """Withholding information is a powerful narrative technique for increasing reader engagement."""@en ;
  dcterms:modified "2026-02-12T08:59:21.636044Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2104-2
  a curric:KeyLearningPoint ;
  rdfs:label """You can withhold information about the who, what, where, when and how of a story."""@en ;
  dcterms:modified "2026-02-12T08:59:21.636048Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2104-3
  a curric:KeyLearningPoint ;
  rdfs:label "Readers can respond in different ways to the withholding of information."@en ;
  dcterms:modified "2026-02-12T08:59:21.636053Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2104-4
  a curric:KeyLearningPoint ;
  rdfs:label """Timing the revelation of the full information affects how your reader responds to the story."""@en ;
  dcterms:modified "2026-02-12T08:59:21.636060Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2097-1
  a curric:KeyLearningPoint ;
  rdfs:label """A memoir is an opportunity for someone to write about formative moments in their life."""@en ;
  dcterms:modified "2026-02-12T08:59:21.636066Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2097-2
  a curric:KeyLearningPoint ;
  rdfs:label "There are three main parts of Keller's childhood account."@en ;
  dcterms:modified "2026-02-12T08:59:21.636070Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2097-3
  a curric:KeyLearningPoint ;
  rdfs:label "Keller uses contrast to show the formative impact of her childhood illness."@en ;
  dcterms:modified "2026-02-12T08:59:21.636075Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2097-4
  a curric:KeyLearningPoint ;
  rdfs:label """Keller uses foreshadowing to build intrigue and signpost a change in the tone of her account."""@en ;
  dcterms:modified "2026-02-12T08:59:21.636080Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2317-1
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, Robinson’s use of sensory language creates a sense of comfort while Antrobus creates a sense of discomfort."""@en ;
  dcterms:modified "2026-02-12T08:59:21.636107Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2317-2
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, both Nichols and Antrobus subvert poetic forms in order to critique humanity’s relationship with nature."""@en ;
  dcterms:modified "2026-02-12T08:59:21.636111Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2317-3
  a curric:KeyLearningPoint ;
  rdfs:label """Nichols’ use of irregularity may reflect the uncertainty of the planet’s future due to anthropogenic climate change."""@en ;
  dcterms:modified "2026-02-12T08:59:21.636118Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2317-4
  a curric:KeyLearningPoint ;
  rdfs:label """In contrast, Robinson’s use of irregularity may reflect the sense of freedom from daily life that “paradise” brings."""@en ;
  dcterms:modified "2026-02-12T08:59:21.636123Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2386-1
  a curric:KeyLearningPoint ;
  rdfs:label """Evaluating model responses with a specific checklist can help improve your own responses."""@en ;
  dcterms:modified "2026-02-12T08:59:21.636130Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2386-2
  a curric:KeyLearningPoint ;
  rdfs:label "You can use comparative conjunctions to make clear links between the texts."@en ;
  dcterms:modified "2026-02-12T08:59:21.636135Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2386-3
  a curric:KeyLearningPoint ;
  rdfs:label """Your paragraph must focus on both texts in equal detail, with evidence from both."""@en ;
  dcterms:modified "2026-02-12T08:59:21.636140Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2386-4
  a curric:KeyLearningPoint ;
  rdfs:label "You must ensure that the focus of your comparison links to the question."@en ;
  dcterms:modified "2026-02-12T08:59:21.636145Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2386-5
  a curric:KeyLearningPoint ;
  rdfs:label """You need to compare the writers' methods and their tone, as well as their overall attitudes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.636149Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28795-1
  a curric:KeyLearningPoint ;
  rdfs:label "A successful essay will have a clear overarching argument."@en ;
  dcterms:modified "2026-02-12T08:59:21.636896Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28795-2
  a curric:KeyLearningPoint ;
  rdfs:label """Select main quotations and supporting quotations to support your overarching argument."""@en ;
  dcterms:modified "2026-02-12T08:59:21.636900Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28795-3
  a curric:KeyLearningPoint ;
  rdfs:label """Main quotations should be analysed; supporting quotations don’t need to be analysed."""@en ;
  dcterms:modified "2026-02-12T08:59:21.636905Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28798-1
  a curric:KeyLearningPoint ;
  rdfs:label "Use the essay question as a planning tool by annotating its keywords."@en ;
  dcterms:modified "2026-02-12T08:59:21.636910Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28798-2
  a curric:KeyLearningPoint ;
  rdfs:label """It's helpful to create a detailed plan which includes a clear thesis and focused topic sentences."""@en ;
  dcterms:modified "2026-02-12T08:59:21.636917Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28798-3
  a curric:KeyLearningPoint ;
  rdfs:label "A thesis is your overarching argument."@en ;
  dcterms:modified "2026-02-12T08:59:21.636922Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28798-4
  a curric:KeyLearningPoint ;
  rdfs:label "A topic sentence states the paragraph’s main idea."@en ;
  dcterms:modified "2026-02-12T08:59:21.636927Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28798-5
  a curric:KeyLearningPoint ;
  rdfs:label """Essays should follow a structure: introduction, main body paragraphs, conclusion."""@en ;
  dcterms:modified "2026-02-12T08:59:21.636932Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2081-1
  a curric:KeyLearningPoint ;
  rdfs:label "Orwell's '1984' is a dystopian novel with a vision of an authoritarian future."@en ;
  dcterms:modified "2026-02-12T08:59:21.636936Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2081-2
  a curric:KeyLearningPoint ;
  rdfs:label """Orwell creates an effective opening by beginning with unsettling details to show the reader something is wrong."""@en ;
  dcterms:modified "2026-02-12T08:59:21.636942Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2081-3
  a curric:KeyLearningPoint ;
  rdfs:label """By feeding the information to the reader slowly, Orwell builds up the feelings of discomfort in the reading."""@en ;
  dcterms:modified "2026-02-12T08:59:21.636947Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29029-1
  a curric:KeyLearningPoint ;
  rdfs:label """Eva represents working-class women, symbolising their struggles with class, gender, and inequality in Edwardian society."""@en ;
  dcterms:modified "2026-02-12T08:59:21.636961Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29029-2
  a curric:KeyLearningPoint ;
  rdfs:label """Eva Smith’s 'absent presence' emphasises her dual role as a powerless victim and a symbolic critique of society."""@en ;
  dcterms:modified "2026-02-12T08:59:21.636966Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29029-3
  a curric:KeyLearningPoint ;
  rdfs:label """Priestley constructs Eva’s character through the attitudes and language of others."""@en ;
  dcterms:modified "2026-02-12T08:59:21.636970Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29029-4
  a curric:KeyLearningPoint ;
  rdfs:label "Eva is constructed as a victim of societal expectations."@en ;
  dcterms:modified "2026-02-12T08:59:21.636975Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29029-5
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, Priestley constructs Eva as a sympathetic character to evoke a response from the audience"""@en ;
  dcterms:modified "2026-02-12T08:59:21.636980Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1678-1
  a curric:KeyLearningPoint ;
  rdfs:label """Reading the question and picking out key words is useful in order to understand its expectations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.636984Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1678-2
  a curric:KeyLearningPoint ;
  rdfs:label "Planning key points helps to create an overarching argument."@en ;
  dcterms:modified "2026-02-12T08:59:21.636989Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1678-3
  a curric:KeyLearningPoint ;
  rdfs:label """Single paragraph outlines are useful in creating a detailed plan for the main body of an essay."""@en ;
  dcterms:modified "2026-02-12T08:59:21.636994Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1678-4
  a curric:KeyLearningPoint ;
  rdfs:label "Using success criteria is an effective way to help write an essay."@en ;
  dcterms:modified "2026-02-12T08:59:21.636998Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2042-1
  a curric:KeyLearningPoint ;
  rdfs:label "Analysing comparative imagery can offer a rich textual analysis."@en ;
  dcterms:modified "2026-02-12T08:59:21.637007Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2042-2
  a curric:KeyLearningPoint ;
  rdfs:label "Arguably, similes and metaphors are conceptually different."@en ;
  dcterms:modified "2026-02-12T08:59:21.637015Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2042-3
  a curric:KeyLearningPoint ;
  rdfs:label """The comparative imagery throughout ‘Mother, Diving’ could show how the mother has found freedom."""@en ;
  dcterms:modified "2026-02-12T08:59:21.637020Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2042-4
  a curric:KeyLearningPoint ;
  rdfs:label """The comparative imagery could also represent the mother subverting maternal stereotypes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.637025Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2362-1
  a curric:KeyLearningPoint ;
  rdfs:label """'Leave Taking' could be interpreted as social commentary on 1980s Britain, particularly racist and classist attitudes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.637030Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2362-2
  a curric:KeyLearningPoint ;
  rdfs:label """It could be argued that difficulties the characters face are based on the colour of their skin and their social class."""@en ;
  dcterms:modified "2026-02-12T08:59:21.637034Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2362-3
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, Enid places so much value on education as she believes it is a way of escaping their social class"""@en ;
  dcterms:modified "2026-02-12T08:59:21.637039Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2362-4
  a curric:KeyLearningPoint ;
  rdfs:label """Pinnock includes two minor, off stage characters to develop her social commentary."""@en ;
  dcterms:modified "2026-02-12T08:59:21.637044Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2362-5
  a curric:KeyLearningPoint ;
  rdfs:label """Pinnock’s exploration of racism could reference racial tensions felt in Britain after increased migration following WW2."""@en ;
  dcterms:modified "2026-02-12T08:59:21.637048Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1694-1
  a curric:KeyLearningPoint ;
  rdfs:label """Recruitment posters in World War One led to a belief that to fight in war symbolised honour and bravery."""@en ;
  dcterms:modified "2026-02-12T08:59:21.637193Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1694-2
  a curric:KeyLearningPoint ;
  rdfs:label """Owen enlisted in 1915 as he wanted to fight for his country. His horrific experiences changed his perspective."""@en ;
  dcterms:modified "2026-02-12T08:59:21.637198Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1694-3
  a curric:KeyLearningPoint ;
  rdfs:label """He wrote ’Exposure’ reflecting on a letter he wrote to his mother describing the conditions of the trenches in 1917."""@en ;
  dcterms:modified "2026-02-12T08:59:21.637205Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1694-4
  a curric:KeyLearningPoint ;
  rdfs:label """Owen suggests that nature is a more brutal enemy than the opposition, subverting many expectations about war."""@en ;
  dcterms:modified "2026-02-12T08:59:21.637210Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1694-5
  a curric:KeyLearningPoint ;
  rdfs:label """The poem may convey Owen’s critique against the government as soldiers were dying from trench and weather conditions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.637215Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29068-1
  a curric:KeyLearningPoint ;
  rdfs:label """Blake contrasts childhood freedom with the restrictions imposed by formal education."""@en ;
  dcterms:modified "2026-02-12T08:59:21.637220Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29068-2
  a curric:KeyLearningPoint ;
  rdfs:label """The speaker is a young boy who feels conflicted between the freedom of nature and the oppressive structure of school."""@en ;
  dcterms:modified "2026-02-12T08:59:21.637225Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29068-3
  a curric:KeyLearningPoint ;
  rdfs:label """Blake presents school as an oppressive institution that stifles creativity and natural joy."""@en ;
  dcterms:modified "2026-02-12T08:59:21.637230Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29068-4
  a curric:KeyLearningPoint ;
  rdfs:label """The poem emphasises Romantic themes such as reverence for nature, emotion, and opposition to oppressive institutions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.637234Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29869-1
  a curric:KeyLearningPoint ;
  rdfs:label """Pinnock explains that many Caribbean immigrants believed Britain was their “mother country.”"""@en ;
  dcterms:modified "2026-02-12T08:59:21.637355Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29869-2
  a curric:KeyLearningPoint ;
  rdfs:label """Pinnock suggests that Enid’s daughters feel torn between being British and being Caribbean."""@en ;
  dcterms:modified "2026-02-12T08:59:21.637359Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29869-3
  a curric:KeyLearningPoint ;
  rdfs:label """Pinnock says Enid is strict because she fears how Black youth were treated in Britain."""@en ;
  dcterms:modified "2026-02-12T08:59:21.637364Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29869-4
  a curric:KeyLearningPoint ;
  rdfs:label """Pinnock says we should look underneath the characters’ words and notice the subtext, what they really want or feel."""@en ;
  dcterms:modified "2026-02-12T08:59:21.637368Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29869-5
  a curric:KeyLearningPoint ;
  rdfs:label """Pinnock says the play invites us to think about the world today and make connections with the characters’ experiences."""@en ;
  dcterms:modified "2026-02-12T08:59:21.637376Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6244-1
  a curric:KeyLearningPoint ;
  rdfs:label """We need to plan our creative writing to ensure it is clear, cohesive and engaging."""@en ;
  dcterms:modified "2026-02-12T08:59:21.637498Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6244-2
  a curric:KeyLearningPoint ;
  rdfs:label "We can use a range of language and structural techniques to craft our writing."@en ;
  dcterms:modified "2026-02-12T08:59:21.637503Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6244-3
  a curric:KeyLearningPoint ;
  rdfs:label """Single paragraph outlines can be used to plan your ideas before you begin writing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.637508Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6244-4
  a curric:KeyLearningPoint ;
  rdfs:label """Proofreading is an active process that enables us to spot and correct errors in written work."""@en ;
  dcterms:modified "2026-02-12T08:59:21.637512Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29038-1
  a curric:KeyLearningPoint ;
  rdfs:label """Priestley critiques legal justice as biased, showing how wealth and status protect the powerful from consequences."""@en ;
  dcterms:modified "2026-02-12T08:59:21.637517Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29038-2
  a curric:KeyLearningPoint ;
  rdfs:label """The play highlights moral punishment, as guilt and reflection shape true justice rather than legal penalties."""@en ;
  dcterms:modified "2026-02-12T08:59:21.637522Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29038-3
  a curric:KeyLearningPoint ;
  rdfs:label """The Inspector enforces psychological punishment, forcing characters to confront their moral failures."""@en ;
  dcterms:modified "2026-02-12T08:59:21.637531Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29038-4
  a curric:KeyLearningPoint ;
  rdfs:label """Priestley presents justice as social responsibility, urging collective change over punitive measures."""@en ;
  dcterms:modified "2026-02-12T08:59:21.637536Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29038-5
  a curric:KeyLearningPoint ;
  rdfs:label """Priestley suggests justice involves personal growth and moral reckoning, not just legal retribution."""@en ;
  dcterms:modified "2026-02-12T08:59:21.637541Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2093-1
  a curric:KeyLearningPoint ;
  rdfs:label "When comparing,  look for similarities and differences."@en ;
  dcterms:modified "2026-02-12T08:59:21.637572Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2093-2
  a curric:KeyLearningPoint ;
  rdfs:label """Look for subtle differences, where there is a clear similarity, but subtle variations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.637577Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2093-3
  a curric:KeyLearningPoint ;
  rdfs:label "To express differences, use a correlative and comparative conjunctions."@en ;
  dcterms:modified "2026-02-12T08:59:21.637582Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2093-4
  a curric:KeyLearningPoint ;
  rdfs:label """Recapping the context of a text can help you to understand why the advice or attitude of each writer is different."""@en ;
  dcterms:modified "2026-02-12T08:59:21.637587Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2093-5
  a curric:KeyLearningPoint ;
  rdfs:label """Circumstances may be similar, but being a man or a woman or living in different centuries will make a difference."""@en ;
  dcterms:modified "2026-02-12T08:59:21.637591Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2106-1
  a curric:KeyLearningPoint ;
  rdfs:label """An opinion article is an article where writers present their perspective on a topic."""@en ;
  dcterms:modified "2026-02-12T08:59:21.637596Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2106-2
  a curric:KeyLearningPoint ;
  rdfs:label """You should aim to choose a topic that you are familiar with and can make multiple points about."""@en ;
  dcterms:modified "2026-02-12T08:59:21.637601Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2106-3
  a curric:KeyLearningPoint ;
  rdfs:label """The form of an article consists of a headline, a strapline, and subheadings for each paragraph."""@en ;
  dcterms:modified "2026-02-12T08:59:21.637605Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2106-4
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of a headline is to grab the reader's attention and you might use alliteration or rhetorical questions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.637610Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2106-5
  a curric:KeyLearningPoint ;
  rdfs:label "The purpose of a strapline is to summarise the main argument of the article."@en ;
  dcterms:modified "2026-02-12T08:59:21.637615Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2443-1
  a curric:KeyLearningPoint ;
  rdfs:label """Wordsworth presents nature as beautiful and harmonious through vocabulary and euphonic sounds."""@en ;
  dcterms:modified "2026-02-12T08:59:21.637638Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2443-2
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, Wordsworth presents nature as beautiful and harmonious to suggest we should have reverence for nature."""@en ;
  dcterms:modified "2026-02-12T08:59:21.637645Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2443-3
  a curric:KeyLearningPoint ;
  rdfs:label """On the other hand, Wordsworth may present nature as beautiful to emphasise the chaos of mankind."""@en ;
  dcterms:modified "2026-02-12T08:59:21.637650Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2443-4
  a curric:KeyLearningPoint ;
  rdfs:label """Wordsworth breaking the regular rhyme and rhythm could represent the imperfections of mankind."""@en ;
  dcterms:modified "2026-02-12T08:59:21.637657Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2384-1
  a curric:KeyLearningPoint ;
  rdfs:label "When comparing articles, look for points of similarity and difference."@en ;
  dcterms:modified "2026-02-12T08:59:21.637662Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2384-2
  a curric:KeyLearningPoint ;
  rdfs:label """A comparative sentence needs to make the link between the texts clear, for example through a comparative conjunction."""@en ;
  dcterms:modified "2026-02-12T08:59:21.637667Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2384-3
  a curric:KeyLearningPoint ;
  rdfs:label "Correlative conjunctions can be used to create close comparisons."@en ;
  dcterms:modified "2026-02-12T08:59:21.637672Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2384-4
  a curric:KeyLearningPoint ;
  rdfs:label """Within a comparison, the quotations chosen from each text must be linked by a point of similarity or contrast."""@en ;
  dcterms:modified "2026-02-12T08:59:21.637676Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2384-5
  a curric:KeyLearningPoint ;
  rdfs:label """Use precise and embedded evidence to support each idea and elevate your summaries."""@en ;
  dcterms:modified "2026-02-12T08:59:21.637681Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2449-1
  a curric:KeyLearningPoint ;
  rdfs:label """Marley’s ghost visits Scrooge and warns him of his impending damnation if he does not change his ways"""@en ;
  dcterms:modified "2026-02-12T08:59:21.637686Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2449-2
  a curric:KeyLearningPoint ;
  rdfs:label "Dickens uses Marley's ghost to convey Christian ideas of penance and remorse"@en ;
  dcterms:modified "2026-02-12T08:59:21.637690Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2449-3
  a curric:KeyLearningPoint ;
  rdfs:label """The chains and cash boxes that Marley's ghost wears show that he wasted his life in pursuit of solely material gain"""@en ;
  dcterms:modified "2026-02-12T08:59:21.637695Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2449-4
  a curric:KeyLearningPoint ;
  rdfs:label """Marley's ghost verbalises Dickens' message about the importance of being charitable and socially responsible"""@en ;
  dcterms:modified "2026-02-12T08:59:21.637700Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2449-5
  a curric:KeyLearningPoint ;
  rdfs:label """Marley's ghost's visit could be said to be a catalyst in Scrooge's transformation"""@en ;
  dcterms:modified "2026-02-12T08:59:21.637705Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2118-1
  a curric:KeyLearningPoint ;
  rdfs:label "People travel for a range of reasons including enjoyment and health."@en ;
  dcterms:modified "2026-02-12T08:59:21.637709Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2118-2
  a curric:KeyLearningPoint ;
  rdfs:label "Writers are often keen to record observations from their travels."@en ;
  dcterms:modified "2026-02-12T08:59:21.637714Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2118-3
  a curric:KeyLearningPoint ;
  rdfs:label "The observations become a way of remembering and recalling the journeys."@en ;
  dcterms:modified "2026-02-12T08:59:21.637719Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2118-4
  a curric:KeyLearningPoint ;
  rdfs:label "We read travel writing in order to share in the writers’ experiences."@en ;
  dcterms:modified "2026-02-12T08:59:21.637724Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2118-5
  a curric:KeyLearningPoint ;
  rdfs:label "When reading a new text, it is useful to make predictions from the title."@en ;
  dcterms:modified "2026-02-12T08:59:21.637729Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1695-1
  a curric:KeyLearningPoint ;
  rdfs:label "Owen personifies nature as a more brutal enemy than the opposition."@en ;
  dcterms:modified "2026-02-12T08:59:21.637738Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1695-2
  a curric:KeyLearningPoint ;
  rdfs:label """Distorted syntax and imagery is used to reflect the disorientating effects of hypothermia and suffering."""@en ;
  dcterms:modified "2026-02-12T08:59:21.637743Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1695-3
  a curric:KeyLearningPoint ;
  rdfs:label """Owen uses the first person collective plurals to show that he is reflecting on the experiences of many soldiers."""@en ;
  dcterms:modified "2026-02-12T08:59:21.637748Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1695-4
  a curric:KeyLearningPoint ;
  rdfs:label "Owen subverts seasonal imagery to express hopelessness and nihilism."@en ;
  dcterms:modified "2026-02-12T08:59:21.637753Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1695-5
  a curric:KeyLearningPoint ;
  rdfs:label """Owen emphasises nature's power and criticises the power of those in powerful positions who idealise war."""@en ;
  dcterms:modified "2026-02-12T08:59:21.637758Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2509-1
  a curric:KeyLearningPoint ;
  rdfs:label "Owen's authentic poem presents a first hand experience of war."@en ;
  dcterms:modified "2026-02-12T08:59:21.637762Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2509-2
  a curric:KeyLearningPoint ;
  rdfs:label "Often first hand experiences create more harrowing poetry."@en ;
  dcterms:modified "2026-02-12T08:59:21.637767Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2509-3
  a curric:KeyLearningPoint ;
  rdfs:label "Both poems use sensory descriptions to create a vivid impression of warzones."@en ;
  dcterms:modified "2026-02-12T08:59:21.637772Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2509-4
  a curric:KeyLearningPoint ;
  rdfs:label "Both poets explore the atrocities of war."@en ;
  dcterms:modified "2026-02-12T08:59:21.637776Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2509-5
  a curric:KeyLearningPoint ;
  rdfs:label """Comparative adjectives can be used to evaluate the subtle differences between the poets’ attitudes and methods."""@en ;
  dcterms:modified "2026-02-12T08:59:21.637783Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2531-1
  a curric:KeyLearningPoint ;
  rdfs:label "Zephaniah was born in Birmingham, and grew up during the 1960s and 1970s."@en ;
  dcterms:modified "2026-02-12T08:59:21.637789Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2531-2
  a curric:KeyLearningPoint ;
  rdfs:label "Growing up, Zephaniah suffered racial abuse."@en ;
  dcterms:modified "2026-02-12T08:59:21.637793Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2531-3
  a curric:KeyLearningPoint ;
  rdfs:label """'No Problem' is based on Zephaniah's own experiences; he is the speaker in the poem."""@en ;
  dcterms:modified "2026-02-12T08:59:21.637798Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2531-4
  a curric:KeyLearningPoint ;
  rdfs:label """The poem is about Zephaniah's self worth, growing up in a society which did not value him."""@en ;
  dcterms:modified "2026-02-12T08:59:21.637803Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2531-5
  a curric:KeyLearningPoint ;
  rdfs:label "Zephaniah was a dub poet who mostly performed his poetry with reggae music."@en ;
  dcterms:modified "2026-02-12T08:59:21.637808Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2091-1
  a curric:KeyLearningPoint ;
  rdfs:label "To create atmosphere, you might use similes, dialogue and motifs."@en ;
  dcterms:modified "2026-02-12T08:59:21.637812Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2091-2
  a curric:KeyLearningPoint ;
  rdfs:label """To avoid clichés, you might think about how you can add extra detail and sensory aspects to similes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.637820Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2091-3
  a curric:KeyLearningPoint ;
  rdfs:label """To write effective dialogue, you might consider how you present body language and the balance of the lines."""@en ;
  dcterms:modified "2026-02-12T08:59:21.637824Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2091-4
  a curric:KeyLearningPoint ;
  rdfs:label """To create motifs that represent emotions, you might think about what colours or objects symbolise that emotions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.637832Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29009-1
  a curric:KeyLearningPoint ;
  rdfs:label """Potentially, we might see Friar Lawrence’s offer of a nunnery as representing how limited women’s choices were."""@en ;
  dcterms:modified "2026-02-12T08:59:21.637837Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29009-2
  a curric:KeyLearningPoint ;
  rdfs:label "Arguably, Juliet asking permission to die undermines her agency in the scene."@en ;
  dcterms:modified "2026-02-12T08:59:21.637841Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29009-3
  a curric:KeyLearningPoint ;
  rdfs:label """We might see Juliet’s death as fulfilling her destiny which could contradict her agency."""@en ;
  dcterms:modified "2026-02-12T08:59:21.637846Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29009-4
  a curric:KeyLearningPoint ;
  rdfs:label "Arguably, Juliet’s posthumous presentation is decided by men."@en ;
  dcterms:modified "2026-02-12T08:59:21.637851Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29009-5
  a curric:KeyLearningPoint ;
  rdfs:label "This might reveal how ultimately women’s agency is undermined by men."@en ;
  dcterms:modified "2026-02-12T08:59:21.637857Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1630-1
  a curric:KeyLearningPoint ;
  rdfs:label """Act 2, Scene 3 starts with a drunk porter who pretends to be the gatekeeper to hell"""@en ;
  dcterms:modified "2026-02-12T08:59:21.637862Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1630-2
  a curric:KeyLearningPoint ;
  rdfs:label """References to regicide and equivocation were topical for Jacobeans because of The Gunpowder Plot"""@en ;
  dcterms:modified "2026-02-12T08:59:21.637867Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1630-3
  a curric:KeyLearningPoint ;
  rdfs:label "King Duncan’s murder is revealed in Act 2, Scene 3"@en ;
  dcterms:modified "2026-02-12T08:59:21.637872Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1630-4
  a curric:KeyLearningPoint ;
  rdfs:label "King Duncan’s sons flee Scotland"@en ;
  dcterms:modified "2026-02-12T08:59:21.637877Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1630-5
  a curric:KeyLearningPoint ;
  rdfs:label "The unnatural events in Scotland suggest that Macbeth’s reign is illegitimate"@en ;
  dcterms:modified "2026-02-12T08:59:21.637882Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1659-1
  a curric:KeyLearningPoint ;
  rdfs:label "Twilight marks the transition between day and night; it is a liminal time."@en ;
  dcterms:modified "2026-02-12T08:59:21.637886Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1659-2
  a curric:KeyLearningPoint ;
  rdfs:label "Windows are often important symbols or liminal spaces in gothic fiction."@en ;
  dcterms:modified "2026-02-12T08:59:21.637891Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1659-3
  a curric:KeyLearningPoint ;
  rdfs:label """Jekyll is in the middle window, which is half way up, suggesting a state of transition."""@en ;
  dcterms:modified "2026-02-12T08:59:21.637896Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1659-4
  a curric:KeyLearningPoint ;
  rdfs:label "This court is located by the \"blistered and disdained\" door of Chapter 1."@en ;
  dcterms:modified "2026-02-12T08:59:21.637900Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1659-5
  a curric:KeyLearningPoint ;
  rdfs:label """Utterson and Enfield choose to protect Jekyll's reputation over his wellbeing and walk away with a vow of silence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.637905Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1656-1
  a curric:KeyLearningPoint ;
  rdfs:label "Concealment is a key theme of both chapters"@en ;
  dcterms:modified "2026-02-12T08:59:21.637910Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1656-2
  a curric:KeyLearningPoint ;
  rdfs:label """Utterson's refusal to challenge Jekyll shows the code of secrecy, allowing gentlemen to protect their reputations"""@en ;
  dcterms:modified "2026-02-12T08:59:21.637914Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1656-3
  a curric:KeyLearningPoint ;
  rdfs:label """The will and the letter carried by Carew show that letters and documents hold secrets"""@en ;
  dcterms:modified "2026-02-12T08:59:21.637922Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1656-4
  a curric:KeyLearningPoint ;
  rdfs:label "Carew's death is treated with alarm due to his social class and status"@en ;
  dcterms:modified "2026-02-12T08:59:21.637957Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1656-5
  a curric:KeyLearningPoint ;
  rdfs:label """The walking stick is an important clue which links to the form of detective fiction"""@en ;
  dcterms:modified "2026-02-12T08:59:21.637963Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2074-1
  a curric:KeyLearningPoint ;
  rdfs:label """The first 8 chapters are focalised through Utterson, highlighting the tension between his curiosity and wilful ignorance"""@en ;
  dcterms:modified "2026-02-12T08:59:21.637968Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2074-2
  a curric:KeyLearningPoint ;
  rdfs:label """The word 'Case' in the title links to Utterson's legal profession, yet he is more concerned with reputation than justice"""@en ;
  dcterms:modified "2026-02-12T08:59:21.637972Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2074-3
  a curric:KeyLearningPoint ;
  rdfs:label """Stevenson makes us question whether Utterson remains friends with 'downgoing' men out of loyalty or repressed desires"""@en ;
  dcterms:modified "2026-02-12T08:59:21.637977Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2074-4
  a curric:KeyLearningPoint ;
  rdfs:label """Chapter 2 is key to understanding Utterson, as he is driven by curiosity to pursue Hyde as 'Mr Seek'"""@en ;
  dcterms:modified "2026-02-12T08:59:21.637982Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2074-5
  a curric:KeyLearningPoint ;
  rdfs:label """Chapters 1 and 7 are significant as Utterson chooses to ignore the signs of Jekyll's distress to protect his reputation"""@en ;
  dcterms:modified "2026-02-12T08:59:21.637987Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2120-1
  a curric:KeyLearningPoint ;
  rdfs:label "Perspective refers to literal viewpoint and an opinion."@en ;
  dcterms:modified "2026-02-12T08:59:21.637991Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2120-2
  a curric:KeyLearningPoint ;
  rdfs:label "Examples of perspective include: in media res, panoramic, external and internal."@en ;
  dcterms:modified "2026-02-12T08:59:21.637996Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2120-3
  a curric:KeyLearningPoint ;
  rdfs:label "Words for explaining perspectives include: focus, zoom, trace, notice."@en ;
  dcterms:modified "2026-02-12T08:59:21.638001Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2120-4
  a curric:KeyLearningPoint ;
  rdfs:label """When planning to write about a scene, the first decision is where to position the narrator."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638005Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2120-5
  a curric:KeyLearningPoint ;
  rdfs:label """When describing a scene, focus on three key points and include words and phrases."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638013Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9255-1
  a curric:KeyLearningPoint ;
  rdfs:label """In Dickinson’s poem, the speaker discusses the transition between summer and autumn."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638018Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9255-2
  a curric:KeyLearningPoint ;
  rdfs:label "The speaker says this transition is imperceptible, like grief."@en ;
  dcterms:modified "2026-02-12T08:59:21.638023Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9255-3
  a curric:KeyLearningPoint ;
  rdfs:label """The poem can be read as a metaphor for the passing of time and grief, which can often be imperceptible"""@en ;
  dcterms:modified "2026-02-12T08:59:21.638028Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9255-4
  a curric:KeyLearningPoint ;
  rdfs:label """There is a reflective, yet hopeful tone, encouraging the reader to not fear the passing of time."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638032Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9251-1
  a curric:KeyLearningPoint ;
  rdfs:label """Keats’ poem is an ode ‘To Autumn’ - a celebration of the penultimate season of the year."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638063Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9251-2
  a curric:KeyLearningPoint ;
  rdfs:label """The poem celebrates the bountiful and fruitful nature of the season of the harvest."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638068Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9251-3
  a curric:KeyLearningPoint ;
  rdfs:label "Arguably, the poem is a metaphor for human mortality."@en ;
  dcterms:modified "2026-02-12T08:59:21.638075Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9251-4
  a curric:KeyLearningPoint ;
  rdfs:label """In the poem, autumn could represent the later years of a person’s life - when their life begins to wane."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638080Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9251-5
  a curric:KeyLearningPoint ;
  rdfs:label """Keats wrote this poem perhaps as a way of coming to terms with his imminent death."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638085Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29066-1
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, the use of sentence fragments and language such as “assault” create a sense of intensity in the poem."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638103Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29066-2
  a curric:KeyLearningPoint ;
  rdfs:label """We might interpret the personification of the phone as the speaker desperately seeking human contact."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638121Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29066-3
  a curric:KeyLearningPoint ;
  rdfs:label """Potentially, we might see the use of multiple metaphors as suggesting a sense of uncertainty."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638126Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29066-4
  a curric:KeyLearningPoint ;
  rdfs:label """Furthermore, the structure of the poem might also be seen as creating a sense of uncertainty."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638131Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2044-1
  a curric:KeyLearningPoint ;
  rdfs:label """Comparing poems means we're finding the similarities and differences in how the texts approach certain ideas or themes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638136Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2044-2
  a curric:KeyLearningPoint ;
  rdfs:label """You might imagine two poets are in conversation about an idea to help with your comparison."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638140Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2044-3
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, both Forster and Sheers demonstrate a shift in dynamic in mother/child relationships."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638148Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2044-4
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, both Forster and Sheers comment on maternal stereotypes within their poems."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638153Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29071-1
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, Heaney’s sensory language is evocative and emotive, capturing childhood joy and inevitable loss."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638208Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29071-2
  a curric:KeyLearningPoint ;
  rdfs:label """Heaney uses metaphor and simile to emphasise childhood joy's intensity and the loss of innocence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638216Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29071-3
  a curric:KeyLearningPoint ;
  rdfs:label """The allusion to ‘Bluebeard’ may highlight indulgence’s danger and guilt, reflecting lost innocence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638221Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29071-4
  a curric:KeyLearningPoint ;
  rdfs:label """Heaney contrasts stanzas to show the shift from youthful joy to adulthood’s harsh reality."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638228Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29071-5
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, Heaney uses caesura to mark the speaker’s realisations, and enjambment to reflect the flow of childhood."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638233Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9216-1
  a curric:KeyLearningPoint ;
  rdfs:label """Blake’s poem ‘London’ is a condemnation of the inequality and oppression that pervaded society in 18th century London."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638238Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9216-2
  a curric:KeyLearningPoint ;
  rdfs:label """'London' is taken from Blake's‘ Songs of Innocence and Experience’, which investigates how society corrupts innocence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638245Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9216-3
  a curric:KeyLearningPoint ;
  rdfs:label """Blake was critical of social inequality created by institutions: the Church, Government and the Monarchy."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638250Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9216-4
  a curric:KeyLearningPoint ;
  rdfs:label """In the poem, Blake highlights the effects of the inaction of greedy and selfish leaders on the vulnerable."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638255Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9216-5
  a curric:KeyLearningPoint ;
  rdfs:label """Blake was a radical, inspired by the French Revolution to warn about the restrictions on freedom and imagination."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638259Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2073-1
  a curric:KeyLearningPoint ;
  rdfs:label "Context must be precise and avoid generalisations."@en ;
  dcterms:modified "2026-02-12T08:59:21.638288Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2073-2
  a curric:KeyLearningPoint ;
  rdfs:label "Context needs to be anchored to the text by linking it to quotations."@en ;
  dcterms:modified "2026-02-12T08:59:21.638293Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2073-3
  a curric:KeyLearningPoint ;
  rdfs:label "Context needs to be interwoven with analysis and used to develop inferences."@en ;
  dcterms:modified "2026-02-12T08:59:21.638298Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2073-4
  a curric:KeyLearningPoint ;
  rdfs:label """Context needs to focus on key themes and concepts and not on isolated historical facts."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638303Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2073-5
  a curric:KeyLearningPoint ;
  rdfs:label """Context can be used to explain the writer's intention and support the overarching argument of the essay."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638308Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2473-1
  a curric:KeyLearningPoint ;
  rdfs:label """If given an extract in your question, at least one of your ideas needs to come from the extract."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638312Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2473-2
  a curric:KeyLearningPoint ;
  rdfs:label """When responding to a text, you should consider a range of evidence from across the whole text."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638317Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2473-3
  a curric:KeyLearningPoint ;
  rdfs:label """Your argument can build in complexity from foundational knowledge to a personal interpretation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638322Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2473-4
  a curric:KeyLearningPoint ;
  rdfs:label """Discourse markers are useful in structuring your response and showing links between ideas."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638326Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2473-5
  a curric:KeyLearningPoint ;
  rdfs:label "Your analysis of the text should be rich, with context integrated to support."@en ;
  dcterms:modified "2026-02-12T08:59:21.638333Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2465-1
  a curric:KeyLearningPoint ;
  rdfs:label "Writers layer methods upon methods to create a literary text."@en ;
  dcterms:modified "2026-02-12T08:59:21.638367Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2465-2
  a curric:KeyLearningPoint ;
  rdfs:label "When analysing the text, you can analyse the layers of meaning."@en ;
  dcterms:modified "2026-02-12T08:59:21.638372Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2465-3
  a curric:KeyLearningPoint ;
  rdfs:label """The writer's method is any conscious choice the writer makes -the smallest method a writer uses is the individual word."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638377Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2465-4
  a curric:KeyLearningPoint ;
  rdfs:label """You can analyse a quotation by starting with an overarching impression and then drilling down into the methods."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638382Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2465-5
  a curric:KeyLearningPoint ;
  rdfs:label "Discourse markers can be used to link layers of analysis together."@en ;
  dcterms:modified "2026-02-12T08:59:21.638387Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2019-1
  a curric:KeyLearningPoint ;
  rdfs:label "Stevenson uses times of day to convey his ideas about secrecy and truth."@en ;
  dcterms:modified "2026-02-12T08:59:21.638391Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2019-2
  a curric:KeyLearningPoint ;
  rdfs:label "The motif of weather is deployed to reflect the characters' inner selves."@en ;
  dcterms:modified "2026-02-12T08:59:21.638396Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2019-3
  a curric:KeyLearningPoint ;
  rdfs:label "It is important to use a range of quotations to trace patterns across a text."@en ;
  dcterms:modified "2026-02-12T08:59:21.638401Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2019-4
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to consider the writer’s purpose and think about how Stevenson’s methods link to his ideas."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638406Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2066-1
  a curric:KeyLearningPoint ;
  rdfs:label """Both Jacobean and 11th Century Gaelic societies were patriarchal and based on hereditary power."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638452Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2066-2
  a curric:KeyLearningPoint ;
  rdfs:label "Macbeth is surrounded by men who have male heirs."@en ;
  dcterms:modified "2026-02-12T08:59:21.638457Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2066-3
  a curric:KeyLearningPoint ;
  rdfs:label """Macbeth's lack of patrilineage could have resulted in insecurities around his masculinity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638461Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2066-4
  a curric:KeyLearningPoint ;
  rdfs:label "His insecurities could fuel his ambitious nature."@en ;
  dcterms:modified "2026-02-12T08:59:21.638466Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2066-5
  a curric:KeyLearningPoint ;
  rdfs:label """The witches' prophecies about Banquo highlight the finite nature of Macbeth's power."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638471Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2543-1
  a curric:KeyLearningPoint ;
  rdfs:label "Landon uses euphony and symbolism to create an idyllic view of childhood."@en ;
  dcterms:modified "2026-02-12T08:59:21.638476Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2543-2
  a curric:KeyLearningPoint ;
  rdfs:label """Structurally, the regular rhyme scheme could contribute to ideas of harmony and unity in childhood."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638481Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2543-3
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, there is a tonal shift in the sixth stanza where childhood is left behind."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638485Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2543-4
  a curric:KeyLearningPoint ;
  rdfs:label """However, we might also interpret the light imagery in prior stanzas as foreboding."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638490Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2543-5
  a curric:KeyLearningPoint ;
  rdfs:label """The destruction of the garden could be a metaphor for the breakdown of Landon’s relationship with her brother."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638495Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2452-1
  a curric:KeyLearningPoint ;
  rdfs:label """Single paragraph outlines are useful for organising your ideas into a coherent structure"""@en ;
  dcterms:modified "2026-02-12T08:59:21.638500Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2452-2
  a curric:KeyLearningPoint ;
  rdfs:label """Single paragraph outlines contain a topic sentence, supporting detail and a closing sentence"""@en ;
  dcterms:modified "2026-02-12T08:59:21.638504Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2452-3
  a curric:KeyLearningPoint ;
  rdfs:label """The supporting details should contain quotations you will use, along with methods, key vocabulary and context"""@en ;
  dcterms:modified "2026-02-12T08:59:21.638511Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2452-4
  a curric:KeyLearningPoint ;
  rdfs:label """A single paragraph outline should be planned for each section of your response (it might be more than one paragraph)"""@en ;
  dcterms:modified "2026-02-12T08:59:21.638519Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2452-5
  a curric:KeyLearningPoint ;
  rdfs:label "Context should be used as evidence for your argument and not as an afterthought"@en ;
  dcterms:modified "2026-02-12T08:59:21.638524Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2024-1
  a curric:KeyLearningPoint ;
  rdfs:label "Mr. Utterson’s dream is full of images of evil and violence."@en ;
  dcterms:modified "2026-02-12T08:59:21.638528Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2024-2
  a curric:KeyLearningPoint ;
  rdfs:label """Stevenson writes the dream sequence in quick moving prose to mimic the shifting nature of dreams."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638533Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2024-3
  a curric:KeyLearningPoint ;
  rdfs:label """In his dream, Mr. Utterson sees many children being crushed by Hyde, suggesting that evil is ubiquitous."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638538Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2024-4
  a curric:KeyLearningPoint ;
  rdfs:label "Mr. Utterson’s dream shows him Dr. Jekyll under the power of another person."@en ;
  dcterms:modified "2026-02-12T08:59:21.638543Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2024-5
  a curric:KeyLearningPoint ;
  rdfs:label """Using a thesis statement, topic sentences, supporting details and conclusions help us to plan our writing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638550Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29039-1
  a curric:KeyLearningPoint ;
  rdfs:label """A nuanced response means going beyond surface-level analysis and considering multiple layers of meaning in the text."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638555Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29039-2
  a curric:KeyLearningPoint ;
  rdfs:label "When planning a response, your thesis should present a clear argument."@en ;
  dcterms:modified "2026-02-12T08:59:21.638560Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29039-3
  a curric:KeyLearningPoint ;
  rdfs:label "Topic sentences should focus on individual paragraph points."@en ;
  dcterms:modified "2026-02-12T08:59:21.638564Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29039-4
  a curric:KeyLearningPoint ;
  rdfs:label """Supporting details should include relevant text references and analysis of methods."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638569Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29039-5
  a curric:KeyLearningPoint ;
  rdfs:label "All comments in an essay should link tightly to your overarching argument."@en ;
  dcterms:modified "2026-02-12T08:59:21.638574Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2114-1
  a curric:KeyLearningPoint ;
  rdfs:label "Ambiguous novel openings can be disconcerting for the reader."@en ;
  dcterms:modified "2026-02-12T08:59:21.638578Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2114-2
  a curric:KeyLearningPoint ;
  rdfs:label """Kathy's narrative voice is full of contradictions, which may also be disconcerting for the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638583Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2114-3
  a curric:KeyLearningPoint ;
  rdfs:label "The disconcerting voice of 'Never Let Me Go' may add to the dystopian feel."@en ;
  dcterms:modified "2026-02-12T08:59:21.638588Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2114-4
  a curric:KeyLearningPoint ;
  rdfs:label """Kathy and Klara, two of Ishiguro's narrators, are perhaps not traditional dystopian voices."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638592Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2114-5
  a curric:KeyLearningPoint ;
  rdfs:label "Kathy and Klara both reflect dehumanised worlds."@en ;
  dcterms:modified "2026-02-12T08:59:21.638597Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2129-1
  a curric:KeyLearningPoint ;
  rdfs:label "Open writing with a hook - this could be anecdotes or rhetorical questions"@en ;
  dcterms:modified "2026-02-12T08:59:21.638602Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2129-2
  a curric:KeyLearningPoint ;
  rdfs:label "Ensure viewpoint, purpose and audience is established early on"@en ;
  dcterms:modified "2026-02-12T08:59:21.638609Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2129-3
  a curric:KeyLearningPoint ;
  rdfs:label """Have at least three clear points that you will address, each supported with rhetorical devices"""@en ;
  dcterms:modified "2026-02-12T08:59:21.638617Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2129-4
  a curric:KeyLearningPoint ;
  rdfs:label """Ensure that you have a clear closing - it could reference the opening of the text"""@en ;
  dcterms:modified "2026-02-12T08:59:21.638622Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2050-1
  a curric:KeyLearningPoint ;
  rdfs:label """You might begin to form a comparative response by considering which poem you have a greater emotional reaction to."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638627Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2050-2
  a curric:KeyLearningPoint ;
  rdfs:label """Then, you might develop your comparison by considering which one you find more provocative, pertinent, or ambiguous."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638631Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2050-3
  a curric:KeyLearningPoint ;
  rdfs:label """Comparing your personal responses can help you to understand how poets have created meaning."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638636Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2050-4
  a curric:KeyLearningPoint ;
  rdfs:label """Interrogating why you react differently to poems can help you understand the world around you and yourself."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638641Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2480-1
  a curric:KeyLearningPoint ;
  rdfs:label """The poets initially use barren and inhospitable settings to reflect despairing and hopeless emotions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638667Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2480-2
  a curric:KeyLearningPoint ;
  rdfs:label """The poets initially show fragmented relationships but these progress in different ways throughout each poem."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638672Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2480-3
  a curric:KeyLearningPoint ;
  rdfs:label """Sheers is the only poet to shift to a more hopeful tone when the couple are eventually unified."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638679Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2480-4
  a curric:KeyLearningPoint ;
  rdfs:label """Comparison questions require you to focus firstly on key ideas and then explore how the writers convey these ideas."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638684Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2480-5
  a curric:KeyLearningPoint ;
  rdfs:label """A single paragraph outline is an effective way to structure a comparative analysis paragraph."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638688Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2328-1
  a curric:KeyLearningPoint ;
  rdfs:label "Mew uses a simile to convey the fear the wife feels towards her husband."@en ;
  dcterms:modified "2026-02-12T08:59:21.638693Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2328-2
  a curric:KeyLearningPoint ;
  rdfs:label """Mew uses a semantic field of natural imagery to reveal how the husband infantilises and others his wife."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638698Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2328-3
  a curric:KeyLearningPoint ;
  rdfs:label "Mew uses a collective pronoun to show how the wife is forced into submission."@en ;
  dcterms:modified "2026-02-12T08:59:21.638705Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2328-4
  a curric:KeyLearningPoint ;
  rdfs:label "Mew uses natural imagery to convey the wife's growing emotional distance."@en ;
  dcterms:modified "2026-02-12T08:59:21.638710Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2328-5
  a curric:KeyLearningPoint ;
  rdfs:label """Mew uses exclamation in the resolution to suggest the husband continues to fantasise about his wife."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638715Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2453-1
  a curric:KeyLearningPoint ;
  rdfs:label """Introductions are made up of three parts, moving from the general to the specific"""@en ;
  dcterms:modified "2026-02-12T08:59:21.638719Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2453-2
  a curric:KeyLearningPoint ;
  rdfs:label """The introduction can contain the name of the text, the writer's name and the sections of text you will focus on"""@en ;
  dcterms:modified "2026-02-12T08:59:21.638724Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2453-3
  a curric:KeyLearningPoint ;
  rdfs:label "The thesis statement summarises the overarching argument from your introduction"@en ;
  dcterms:modified "2026-02-12T08:59:21.638729Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2453-4
  a curric:KeyLearningPoint ;
  rdfs:label """The thesis statement can contain your argument about the text and how this influences our understanding of society"""@en ;
  dcterms:modified "2026-02-12T08:59:21.638733Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2453-5
  a curric:KeyLearningPoint ;
  rdfs:label """Embedded quotations, discourse markers and well-chosen and specific vocabulary can all be used to strengthen a response"""@en ;
  dcterms:modified "2026-02-12T08:59:21.638738Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2471-1
  a curric:KeyLearningPoint ;
  rdfs:label """Scrooge’s transformative journey follows that of the ‘redemptive hero’ narrative that we see in many stories."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638743Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2471-2
  a curric:KeyLearningPoint ;
  rdfs:label """The redeemed hero narrative roughly follows the hero, who looks for something they have lost, with the help of a guide."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638748Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2471-3
  a curric:KeyLearningPoint ;
  rdfs:label """Scrooge is presented as a hero who overcomes challenges to become a better person."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638753Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2471-4
  a curric:KeyLearningPoint ;
  rdfs:label """Scrooge is presented as an inspirational figure, whose transformation is intended to be an example to many."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638757Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2471-5
  a curric:KeyLearningPoint ;
  rdfs:label """'A Christmas Carol' is a timeless classic because its moral message will always apply to an unfair and unequal society."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638762Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29026-1
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, Priestley uses the characters to critique the flaws of gender and class structures in Edwardian societies."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638767Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29026-2
  a curric:KeyLearningPoint ;
  rdfs:label """Mrs Birling embodies traditional Edwardian norms of gender and class, reinforcing societal hierarchies."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638771Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29026-3
  a curric:KeyLearningPoint ;
  rdfs:label """It could be suggested that Mrs Birling’s response reflects her internalised patriarchal views."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638776Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29026-4
  a curric:KeyLearningPoint ;
  rdfs:label """Mrs Birling's treatment of Eva Smith could show the prejudice of the upper class against working-class women."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638781Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29026-5
  a curric:KeyLearningPoint ;
  rdfs:label "Single paragraph outlines are a useful planning tool for analytical writing."@en ;
  dcterms:modified "2026-02-12T08:59:21.638786Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29031-1
  a curric:KeyLearningPoint ;
  rdfs:label "A thesis statement is a clear, overarching argument."@en ;
  dcterms:modified "2026-02-12T08:59:21.638793Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29031-2
  a curric:KeyLearningPoint ;
  rdfs:label "Topic sentences give focus to individual paragraphs."@en ;
  dcterms:modified "2026-02-12T08:59:21.638798Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29031-3
  a curric:KeyLearningPoint ;
  rdfs:label "The planning of supporting details needs to be concise."@en ;
  dcterms:modified "2026-02-12T08:59:21.638803Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29031-4
  a curric:KeyLearningPoint ;
  rdfs:label """Supporting details should identify keywords, methods, both supporting and main quotations from across the play."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638807Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29031-5
  a curric:KeyLearningPoint ;
  rdfs:label """Concluding sentences can focus on a writer’s intention and draw your paragraph to a close."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638812Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2015-1
  a curric:KeyLearningPoint ;
  rdfs:label """Act 3 is an important scene as it signifies a shift in Macbeth’s behaviour and his relationship with his wife"""@en ;
  dcterms:modified "2026-02-12T08:59:21.638817Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2015-2
  a curric:KeyLearningPoint ;
  rdfs:label """Tormented by guilt and fear, he plots Banquo’s murder without informing Lady Macbeth"""@en ;
  dcterms:modified "2026-02-12T08:59:21.638821Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2015-3
  a curric:KeyLearningPoint ;
  rdfs:label """The relationship between Macbeth and his wife becomes particularly estranged during Act 3, Scene 4"""@en ;
  dcterms:modified "2026-02-12T08:59:21.638826Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2015-4
  a curric:KeyLearningPoint ;
  rdfs:label "Arguably, Macbeth is in conflict with both himself and his wife in Act 3"@en ;
  dcterms:modified "2026-02-12T08:59:21.638831Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2015-5
  a curric:KeyLearningPoint ;
  rdfs:label "Thesis statements should present an overarching argument"@en ;
  dcterms:modified "2026-02-12T08:59:21.638838Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2089-1
  a curric:KeyLearningPoint ;
  rdfs:label "Stories have existed throughout human history."@en ;
  dcterms:modified "2026-02-12T08:59:21.638843Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2089-2
  a curric:KeyLearningPoint ;
  rdfs:label """Potentially, we might tell stories as a way of creating social bonds and relationships between people."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638848Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2089-3
  a curric:KeyLearningPoint ;
  rdfs:label "We might also tell stories as a way of understanding the world around us."@en ;
  dcterms:modified "2026-02-12T08:59:21.638853Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2089-4
  a curric:KeyLearningPoint ;
  rdfs:label """Stories might change people's worlds by offering them a sense of connection with others."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638857Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2089-5
  a curric:KeyLearningPoint ;
  rdfs:label """They also might inspire people to see the world in a different way and change their perspective."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638862Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29036-1
  a curric:KeyLearningPoint ;
  rdfs:label """Priestley presents the Inspector as a multifaceted figure of justice, encompassing legal, moral, and divine elements."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639133Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29036-2
  a curric:KeyLearningPoint ;
  rdfs:label """Analysis of quotations should be layered considering methods and multiple interpretations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639138Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29036-3
  a curric:KeyLearningPoint ;
  rdfs:label """Complexity in analysis involves acknowledging alternative interpretations and considering multiple meanings."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639142Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29036-4
  a curric:KeyLearningPoint ;
  rdfs:label """A strong topic sentence presents your perspective while introducing different viewpoints or interpretations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639147Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2023-1
  a curric:KeyLearningPoint ;
  rdfs:label """Analysing an extract means considering its position in the text, word choices, sentence structure and context."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639210Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2023-2
  a curric:KeyLearningPoint ;
  rdfs:label """An analytical introduction should start with a general statement about the text and then move to the specific."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639214Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2023-3
  a curric:KeyLearningPoint ;
  rdfs:label """Mr. Utterson and Mr. Enfield are appalled at what they have seen in Dr. Jekyll’s face."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639219Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2023-4
  a curric:KeyLearningPoint ;
  rdfs:label """Their decision to keep quiet is to protect Dr. Jekyll’s reputation and is a sign of their hypocrisy."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639224Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1662-1
  a curric:KeyLearningPoint ;
  rdfs:label """Jekyll frames this final narrative as a confession, yet he seems remorseless at times."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639231Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1662-2
  a curric:KeyLearningPoint ;
  rdfs:label """Jekyll discusses the challenges of the conflict between human desires and societies expectations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639236Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1662-3
  a curric:KeyLearningPoint ;
  rdfs:label "Jekyll argues that good and evil coexist in all humans - except Hyde."@en ;
  dcterms:modified "2026-02-12T08:59:21.639241Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1662-4
  a curric:KeyLearningPoint ;
  rdfs:label "Hyde’s existence allowed Jekyll to purge his inherent evil."@en ;
  dcterms:modified "2026-02-12T08:59:21.639245Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29006-1
  a curric:KeyLearningPoint ;
  rdfs:label "Female sexual desire was frowned upon in Elizabethan England."@en ;
  dcterms:modified "2026-02-12T08:59:21.639250Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29006-2
  a curric:KeyLearningPoint ;
  rdfs:label """Juliet’s language around sex implies that she anticipates pleasure and wants to take an active role."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639255Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29006-3
  a curric:KeyLearningPoint ;
  rdfs:label """However, Juliet’s comparison to a child at the end of her speech about sex may undermine her agency."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639260Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29006-4
  a curric:KeyLearningPoint ;
  rdfs:label """After finding out Romeo killed Tybalt, Juliet’s initial reaction is one of anger."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639265Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29006-5
  a curric:KeyLearningPoint ;
  rdfs:label """We may see Juliet's forgiveness as her exerting agency or bowing to societal pressure to forgive her husband."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639269Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28977-1
  a curric:KeyLearningPoint ;
  rdfs:label """By opening with men bearing swords, Shakespeare implies that we should connect men and violence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639274Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28977-2
  a curric:KeyLearningPoint ;
  rdfs:label "Violence is presented as part of masculinity."@en ;
  dcterms:modified "2026-02-12T08:59:21.639282Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28977-3
  a curric:KeyLearningPoint ;
  rdfs:label """The links between violence and sex could suggest that men were supposed to be sexually dominant."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639287Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28977-4
  a curric:KeyLearningPoint ;
  rdfs:label """The Prince implies that the Montagues and Capulets are corrupting themselves and society through violence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639291Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28977-5
  a curric:KeyLearningPoint ;
  rdfs:label """However, the Prince’s threats could be acknowledging that violence is necessary to keep society together."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639296Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28638-1
  a curric:KeyLearningPoint ;
  rdfs:label """Romeo and Juliet’s comparative imagery shows the depth and importance of their feelings."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639360Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28638-2
  a curric:KeyLearningPoint ;
  rdfs:label """Potentially, Shakespeare uses so much comparative imagery to show them trying to understand their feelings."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639364Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28638-3
  a curric:KeyLearningPoint ;
  rdfs:label "Romeo and Juliet both appear to embrace the impulsiveness of their love."@en ;
  dcterms:modified "2026-02-12T08:59:21.639371Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28638-4
  a curric:KeyLearningPoint ;
  rdfs:label "Romeo’s hamartia is often said to be his impulsive nature."@en ;
  dcterms:modified "2026-02-12T08:59:21.639376Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28638-5
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, the intensity of Romeo and Juliet’s language may foreshadow their tragic end."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639381Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2523-1
  a curric:KeyLearningPoint ;
  rdfs:label """The regular rhyming couplets could reflect the rigidity of the army, or could be used as a dramatic storytelling device."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639409Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2523-2
  a curric:KeyLearningPoint ;
  rdfs:label "Byron’s use of sibilance arguably illustrates the power of the Assyrian army."@en ;
  dcterms:modified "2026-02-12T08:59:21.639416Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2523-3
  a curric:KeyLearningPoint ;
  rdfs:label """The biblical image of the wolf attacking sheep connotes the battle between good and evil."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639421Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2523-4
  a curric:KeyLearningPoint ;
  rdfs:label "Anapestic tetrameter could echo the sound of the forces advancing."@en ;
  dcterms:modified "2026-02-12T08:59:21.639426Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2523-5
  a curric:KeyLearningPoint ;
  rdfs:label """Byron uses an extended metaphor, comparing the Assyrians to the sea, which could emphasise how the mighty army fell."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639430Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2054-1
  a curric:KeyLearningPoint ;
  rdfs:label """You might begin gathering ideas by highlighting word(s) or images that relate to the theme of the question."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639435Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2054-2
  a curric:KeyLearningPoint ;
  rdfs:label "Then, you might annotate the connotations of those word(s) and images."@en ;
  dcterms:modified "2026-02-12T08:59:21.639440Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2054-3
  a curric:KeyLearningPoint ;
  rdfs:label """Next, you might consider how the structural elements relate to the theme of the question."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639445Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2054-4
  a curric:KeyLearningPoint ;
  rdfs:label """Then, you might organise your ideas by theme in order to find common themes across both poems."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639449Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1476-1
  a curric:KeyLearningPoint ;
  rdfs:label "Sensory language can be used to enhance the atmosphere of a description."@en ;
  dcterms:modified "2026-02-12T08:59:21.639454Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1476-2
  a curric:KeyLearningPoint ;
  rdfs:label """Effective sensory language uses a variety of senses rather than focusing predominantly on just one."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639461Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1476-3
  a curric:KeyLearningPoint ;
  rdfs:label """Effective sensory language might also use precise vocabulary in order to evoke an atmosphere."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639466Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1476-4
  a curric:KeyLearningPoint ;
  rdfs:label """Using language devices such as personification and onomatopoeia can also enhance sensory language."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639471Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28640-1
  a curric:KeyLearningPoint ;
  rdfs:label "In Elizabethan England, religion played a central role in people’s lives."@en ;
  dcterms:modified "2026-02-12T08:59:21.639476Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28640-2
  a curric:KeyLearningPoint ;
  rdfs:label """Friar Lawrence’s role as an advisor to Romeo and Juliet arguably represents the importance of religion."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639480Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28640-3
  a curric:KeyLearningPoint ;
  rdfs:label """Friar Lawrence’s speech in Act 2, Scene 3 indicates his knowledge of human nature and emotions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639485Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28640-4
  a curric:KeyLearningPoint ;
  rdfs:label """Shakespeare arguably presents Friar Lawrence and Romeo as having a very close relationship."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639490Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1629-1
  a curric:KeyLearningPoint ;
  rdfs:label """The Divine Right of Kings is the belief that a monarch is chosen by God; that a monarch is God’s representative on Earth"""@en ;
  dcterms:modified "2026-02-12T08:59:21.639495Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1629-2
  a curric:KeyLearningPoint ;
  rdfs:label "Macbeth hallucinates a dagger before he commits regicide"@en ;
  dcterms:modified "2026-02-12T08:59:21.639499Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1629-3
  a curric:KeyLearningPoint ;
  rdfs:label "After the regicide, Macbeth worries he will no longer be able to pray or sleep"@en ;
  dcterms:modified "2026-02-12T08:59:21.639504Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1629-4
  a curric:KeyLearningPoint ;
  rdfs:label "Whilst Macbeth is preoccupied with the blood on his hands, Lady Macbeth is not"@en ;
  dcterms:modified "2026-02-12T08:59:21.639511Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1629-5
  a curric:KeyLearningPoint ;
  rdfs:label "Blood is a symbol for feelings of guilt in ‘Macbeth’"@en ;
  dcterms:modified "2026-02-12T08:59:21.639516Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1646-1
  a curric:KeyLearningPoint ;
  rdfs:label "Act 3, Scene 4 sees the Macbeths hold an important feast"@en ;
  dcterms:modified "2026-02-12T08:59:21.639521Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1646-2
  a curric:KeyLearningPoint ;
  rdfs:label "Macbeth sees Banquo's Ghost"@en ;
  dcterms:modified "2026-02-12T08:59:21.639526Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1646-3
  a curric:KeyLearningPoint ;
  rdfs:label """As in earlier scenes, Lady Macbeth could be interpreted as trying to emasculate her husband"""@en ;
  dcterms:modified "2026-02-12T08:59:21.639530Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1646-4
  a curric:KeyLearningPoint ;
  rdfs:label "However, Macbeth appears less susceptible to her emasculation"@en ;
  dcterms:modified "2026-02-12T08:59:21.639535Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1646-5
  a curric:KeyLearningPoint ;
  rdfs:label "Lady Macbeth appears to lose control over her husband"@en ;
  dcterms:modified "2026-02-12T08:59:21.639543Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1677-1
  a curric:KeyLearningPoint ;
  rdfs:label "Annotate an essay question so you know its focus."@en ;
  dcterms:modified "2026-02-12T08:59:21.639547Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1677-2
  a curric:KeyLearningPoint ;
  rdfs:label "A successful plan follows a clear structure."@en ;
  dcterms:modified "2026-02-12T08:59:21.639556Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1677-3
  a curric:KeyLearningPoint ;
  rdfs:label "A thesis is a clear overarching argument supported by the whole text."@en ;
  dcterms:modified "2026-02-12T08:59:21.639561Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1677-4
  a curric:KeyLearningPoint ;
  rdfs:label "Topic sentences state a paragraph’s main idea."@en ;
  dcterms:modified "2026-02-12T08:59:21.639566Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1677-5
  a curric:KeyLearningPoint ;
  rdfs:label """Concluding sentences focus on the writer’s intentions and link to your topic sentence, without repeating it."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639571Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2457-1
  a curric:KeyLearningPoint ;
  rdfs:label """Context should be integrated into your argument to support your ideas and opinions about the writer’s intentions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639576Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2457-2
  a curric:KeyLearningPoint ;
  rdfs:label """An essay should have a strong central argument. Use an evaluative or critical thesis to “hang” your essay on."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639580Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2457-3
  a curric:KeyLearningPoint ;
  rdfs:label "Support your argument with clear topic sentences and clear closing sentences."@en ;
  dcterms:modified "2026-02-12T08:59:21.639585Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2457-4
  a curric:KeyLearningPoint ;
  rdfs:label """Analysis of language, form and structure should be interwoven and used to support each other."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639590Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2457-5
  a curric:KeyLearningPoint ;
  rdfs:label """Essays should focus on the writer’s message. The conclusion is an opportunity to summarise this."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639594Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1487-1
  a curric:KeyLearningPoint ;
  rdfs:label """A speech is different to other types of writing since it is designed to be delivered aloud."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639613Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1487-2
  a curric:KeyLearningPoint ;
  rdfs:label """Speech writers should aim for a conversational tone that is clear, concise and engaging for the audience."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639617Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1487-3
  a curric:KeyLearningPoint ;
  rdfs:label """Direct address can make the audience feel included in a speech and increase engagement."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639622Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1487-4
  a curric:KeyLearningPoint ;
  rdfs:label """Personal pronouns help to forge a connection between the speaker and the audience."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639627Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1487-5
  a curric:KeyLearningPoint ;
  rdfs:label """Effective speech openings begin by grabbing the audience’s attention and end by summarising why the issue is important."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639631Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1468-1
  a curric:KeyLearningPoint ;
  rdfs:label "Planning is an important part of the writing process."@en ;
  dcterms:modified "2026-02-12T08:59:21.639636Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1468-2
  a curric:KeyLearningPoint ;
  rdfs:label """Single paragraph outlines should include hooks, topic sentences, supporting detail and concluding statements."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639643Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1468-3
  a curric:KeyLearningPoint ;
  rdfs:label """Textual detail should be in note form; this should outline your main ideas and include rhetorical devices."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639648Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1468-4
  a curric:KeyLearningPoint ;
  rdfs:label """When writing copy for a website, organisational devices such as subheadings and bullet points can be included."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639652Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1468-5
  a curric:KeyLearningPoint ;
  rdfs:label """Using a range of rhetorical devices can effectively engage and inform your reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639657Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9223-1
  a curric:KeyLearningPoint ;
  rdfs:label """The poem describes Byron's first sighting of a beautiful woman at a London party."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639760Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9223-2
  a curric:KeyLearningPoint ;
  rdfs:label """The speaker initially describes her physical appearance, before speculating about her inner beauty."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639764Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9223-3
  a curric:KeyLearningPoint ;
  rdfs:label """Byron was famed for his very public private life, including his many affairs with women."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639769Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9223-4
  a curric:KeyLearningPoint ;
  rdfs:label """Byron remains one of the most famous Romantic poets of all time - the poem adheres to Romantic conventions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639774Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9223-5
  a curric:KeyLearningPoint ;
  rdfs:label """The poem barely mentions love, so this could be interpreted as a more surface level attraction."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639778Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9257-1
  a curric:KeyLearningPoint ;
  rdfs:label """Seamus Heaney's 'Death of a Naturalist' tells the story of a young child who frequents a flax-dam to observe the nature."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639783Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9257-2
  a curric:KeyLearningPoint ;
  rdfs:label """The naturalist is the young speaker, whose enthusiasm and love of nature "dies" in the poem."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639787Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9257-3
  a curric:KeyLearningPoint ;
  rdfs:label """The speaker's intrigue and excitement for nature is replaced by a fear of nature."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639792Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9257-4
  a curric:KeyLearningPoint ;
  rdfs:label """The poem could be a metaphor for growing older and becoming more disillusioned with the world around you."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639797Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9257-5
  a curric:KeyLearningPoint ;
  rdfs:label "Arguably, the adult frogs could represent the ugliness of the adult world."@en ;
  dcterms:modified "2026-02-12T08:59:21.639802Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2562-1
  a curric:KeyLearningPoint ;
  rdfs:label """Rumens, Zephaniah and Hardi all explore the impact of displacement on refugees and their sense of belonging."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639806Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2562-2
  a curric:KeyLearningPoint ;
  rdfs:label """Zephaniah and Rumens may use language to reflect the hostile environment that refugees experience."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639811Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2562-3
  a curric:KeyLearningPoint ;
  rdfs:label """In contrast, Hardi may be focusing on the upheaval and lack of purpose that displacement causes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639816Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2562-4
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, all three poems imply that displacement affects the refugees' connection to their heritage."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639823Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2527-1
  a curric:KeyLearningPoint ;
  rdfs:label "John Agard was born in Guyana to a Caribbean father and Portuguese mother."@en ;
  dcterms:modified "2026-02-12T08:59:21.639830Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2527-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Half-caste' was a term which was used to describe mixed race people."@en ;
  dcterms:modified "2026-02-12T08:59:21.639836Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2527-3
  a curric:KeyLearningPoint ;
  rdfs:label """Agard objects to the term 'half-caste' as it implies mixed race people are only half a person."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639840Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2527-4
  a curric:KeyLearningPoint ;
  rdfs:label """He uses a facetious tone in the poem to explore the derogatory meanings linked to the term 'half-caste'."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639845Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2527-5
  a curric:KeyLearningPoint ;
  rdfs:label "Agard embraces the joy that having mixed identities can bring."@en ;
  dcterms:modified "2026-02-12T08:59:21.639850Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2519-1
  a curric:KeyLearningPoint ;
  rdfs:label """The Romantic period prioritises imagination and self expression over regulation and institutional power."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639854Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2519-2
  a curric:KeyLearningPoint ;
  rdfs:label "Many Romantic poets loved and worshipped the natural world."@en ;
  dcterms:modified "2026-02-12T08:59:21.639859Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2519-3
  a curric:KeyLearningPoint ;
  rdfs:label "Many Romantic-era writers rejected traditional religious beliefs."@en ;
  dcterms:modified "2026-02-12T08:59:21.639864Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2519-4
  a curric:KeyLearningPoint ;
  rdfs:label "The 'sublime', a feeling of overwhelming awe, is often used in Romantic poetry."@en ;
  dcterms:modified "2026-02-12T08:59:21.639871Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2519-5
  a curric:KeyLearningPoint ;
  rdfs:label """There are four Romantic poets in the Edexcel ‘Conflict’ Anthology: Wordsworth, Byron, Blake and Tennyson."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639876Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2511-1
  a curric:KeyLearningPoint ;
  rdfs:label "The poem takes the form of a dramatic monologue."@en ;
  dcterms:modified "2026-02-12T08:59:21.639881Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2511-2
  a curric:KeyLearningPoint ;
  rdfs:label "Regular meter creates an informal tone as the speaker explains his actions."@en ;
  dcterms:modified "2026-02-12T08:59:21.639886Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2511-3
  a curric:KeyLearningPoint ;
  rdfs:label "The equal stanzas could represent the commonality of experiences of war."@en ;
  dcterms:modified "2026-02-12T08:59:21.639891Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2511-4
  a curric:KeyLearningPoint ;
  rdfs:label """Repetition and mirrored language illustrate a connection between the speaker and the man he killed."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639896Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2511-5
  a curric:KeyLearningPoint ;
  rdfs:label """Hardy uses informal language to characterise the speaker as a regular and relatable person."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639900Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2359-1
  a curric:KeyLearningPoint ;
  rdfs:label "It's a good idea to find thematic connections between the poems."@en ;
  dcterms:modified "2026-02-12T08:59:21.639905Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2359-2
  a curric:KeyLearningPoint ;
  rdfs:label """Theoretically, you can compare any of the anthology poems but it's useful to choose two which complement each other."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639910Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2359-3
  a curric:KeyLearningPoint ;
  rdfs:label """Thinking about why you chose to compare two poems can help you build a thesis statement."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639917Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2359-4
  a curric:KeyLearningPoint ;
  rdfs:label """Expanding your thesis statement into 'mini-arguments' can help you to build topic sentences."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639922Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2359-5
  a curric:KeyLearningPoint ;
  rdfs:label """A great way to build a concluding sentence is to make the opposite connections to your topic sentence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.639927Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2391-1
  a curric:KeyLearningPoint ;
  rdfs:label """Speeches should be impressive, which means presenting complex ideas clearly and using sophisticated vocabulary."""@en ;
  dcterms:modified "2026-02-12T08:59:21.640013Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2391-2
  a curric:KeyLearningPoint ;
  rdfs:label "You need to consider the purpose, audience and form of your speech."@en ;
  dcterms:modified "2026-02-12T08:59:21.640018Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2391-3
  a curric:KeyLearningPoint ;
  rdfs:label """Speech topics should be appropriate and enable you to present a speech with layers of complexity and interest."""@en ;
  dcterms:modified "2026-02-12T08:59:21.640022Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2391-4
  a curric:KeyLearningPoint ;
  rdfs:label """Topic sentences should include a range of sentence structures and rhetorical devices."""@en ;
  dcterms:modified "2026-02-12T08:59:21.640027Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2391-5
  a curric:KeyLearningPoint ;
  rdfs:label """It is useful to consider the order of your topic sentences to make sure they are impactful."""@en ;
  dcterms:modified "2026-02-12T08:59:21.640032Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2334-1
  a curric:KeyLearningPoint ;
  rdfs:label "Victorian society viewed women as passive and confined them to domestic roles."@en ;
  dcterms:modified "2026-02-12T08:59:21.640060Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2334-2
  a curric:KeyLearningPoint ;
  rdfs:label "Victorian society had a stigma surrounding sexual freedom and liberation."@en ;
  dcterms:modified "2026-02-12T08:59:21.640064Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2334-3
  a curric:KeyLearningPoint ;
  rdfs:label """The Brownings were a couple whose marriage challenged Victorian attitudes towards love and relationships."""@en ;
  dcterms:modified "2026-02-12T08:59:21.640069Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2334-4
  a curric:KeyLearningPoint ;
  rdfs:label """Both 'Sonnet 29' and 'Porphyria's Lover' challenge typical attitudes of the Victorian era towards love and marriage."""@en ;
  dcterms:modified "2026-02-12T08:59:21.640074Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2034-1
  a curric:KeyLearningPoint ;
  rdfs:label "There are several overlapping themes in the ‘Power and Conflict’ anthology."@en ;
  dcterms:modified "2026-02-12T08:59:21.640079Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2034-2
  a curric:KeyLearningPoint ;
  rdfs:label """A message is an important idea in a text that the writer wants to tell people about."""@en ;
  dcterms:modified "2026-02-12T08:59:21.640084Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2034-3
  a curric:KeyLearningPoint ;
  rdfs:label "A poet’s intent is the reason they have for writing a text."@en ;
  dcterms:modified "2026-02-12T08:59:21.640088Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2034-4
  a curric:KeyLearningPoint ;
  rdfs:label """Using evaluative verbs can help you make meaningful comments about a writer’s intent."""@en ;
  dcterms:modified "2026-02-12T08:59:21.640093Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2071-1
  a curric:KeyLearningPoint ;
  rdfs:label """The power of human curiosity is key theme shown through the detective form and final narratives of Lanyon and Jekyll."""@en ;
  dcterms:modified "2026-02-12T08:59:21.640100Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2071-2
  a curric:KeyLearningPoint ;
  rdfs:label """Concealment is a key theme shown through the motif of letters and the detective form."""@en ;
  dcterms:modified "2026-02-12T08:59:21.640105Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2071-3
  a curric:KeyLearningPoint ;
  rdfs:label "False appearances is a key theme shown through the motif of the mask."@en ;
  dcterms:modified "2026-02-12T08:59:21.640109Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2071-4
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably the novella's climax is the breaking down of the door to Jekyll's cabinet, linking to secrecy and concealment."""@en ;
  dcterms:modified "2026-02-12T08:59:21.640114Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2071-5
  a curric:KeyLearningPoint ;
  rdfs:label """Jekyll offers a "full statement" in the denouement, yet we don't see Utterson's response or the consequences of this."""@en ;
  dcterms:modified "2026-02-12T08:59:21.640118Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1632-1
  a curric:KeyLearningPoint ;
  rdfs:label "Act 3 sees Shakespeare explore Macbeth’s illegitimate reign over Scotland"@en ;
  dcterms:modified "2026-02-12T08:59:21.640237Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1632-2
  a curric:KeyLearningPoint ;
  rdfs:label "At a public feast, Macbeth hallucinates Banquo’s ghost"@en ;
  dcterms:modified "2026-02-12T08:59:21.640242Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1632-3
  a curric:KeyLearningPoint ;
  rdfs:label "Macbeth reveals that he spies on his Thanes"@en ;
  dcterms:modified "2026-02-12T08:59:21.640247Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1632-4
  a curric:KeyLearningPoint ;
  rdfs:label "Macbeth decides to go and see the three witches again"@en ;
  dcterms:modified "2026-02-12T08:59:21.640252Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1632-5
  a curric:KeyLearningPoint ;
  rdfs:label """Macduff, a Scottish Thane, goes to England to try and raise an army against Macbeth"""@en ;
  dcterms:modified "2026-02-12T08:59:21.640256Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2310-1
  a curric:KeyLearningPoint ;
  rdfs:label "A thesis statement is a clear, overarching argument."@en ;
  dcterms:modified "2026-02-12T08:59:21.640261Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2310-2
  a curric:KeyLearningPoint ;
  rdfs:label "Topic sentences give focus to individual paragraphs."@en ;
  dcterms:modified "2026-02-12T08:59:21.640266Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2310-3
  a curric:KeyLearningPoint ;
  rdfs:label "Select main quotations and supporting quotations to include in an essay."@en ;
  dcterms:modified "2026-02-12T08:59:21.640270Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2310-4
  a curric:KeyLearningPoint ;
  rdfs:label """Main quotations should be analysed; supporting quotations don’t need to be analysed."""@en ;
  dcterms:modified "2026-02-12T08:59:21.640275Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2310-5
  a curric:KeyLearningPoint ;
  rdfs:label """Concluding sentences can focus on a writer’s intention and draw your paragraph to a close."""@en ;
  dcterms:modified "2026-02-12T08:59:21.640282Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2018-1
  a curric:KeyLearningPoint ;
  rdfs:label """Stevenson takes the conventions of the Gothic genre and subverts them to make his fictional world seem even stranger"""@en ;
  dcterms:modified "2026-02-12T08:59:21.640287Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2018-2
  a curric:KeyLearningPoint ;
  rdfs:label "The key settings are Jekyll’s home, his laboratory and Hyde’s house."@en ;
  dcterms:modified "2026-02-12T08:59:21.640292Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2018-3
  a curric:KeyLearningPoint ;
  rdfs:label "The key settings contrast with each other which relates to the theme of duality."@en ;
  dcterms:modified "2026-02-12T08:59:21.640296Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2018-4
  a curric:KeyLearningPoint ;
  rdfs:label "The city of London is as divided as Jekyll himself."@en ;
  dcterms:modified "2026-02-12T08:59:21.640301Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1498-1
  a curric:KeyLearningPoint ;
  rdfs:label """Take a clear stance for or against the statement - alternative arguments should be refuted at least once in the piece."""@en ;
  dcterms:modified "2026-02-12T08:59:21.640306Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1498-2
  a curric:KeyLearningPoint ;
  rdfs:label """Contrast creates a robust sense of a writer's perspective, by demonstrating feeling towards all angles of an argument."""@en ;
  dcterms:modified "2026-02-12T08:59:21.640313Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1498-3
  a curric:KeyLearningPoint ;
  rdfs:label """Use rhetorical questions, direct address and hyperbole to expose the flaws of the opposition in an emotive way."""@en ;
  dcterms:modified "2026-02-12T08:59:21.640318Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1498-4
  a curric:KeyLearningPoint ;
  rdfs:label """Carefully sequence and vary subtle and dramatic shifts in tone, to draw reactions from the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.640323Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1467-1
  a curric:KeyLearningPoint ;
  rdfs:label """Headings, subheadings and bullet points can all be identified as the conventions of a website layout."""@en ;
  dcterms:modified "2026-02-12T08:59:21.640328Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1467-2
  a curric:KeyLearningPoint ;
  rdfs:label "Language should be adapted to conform to the conventions of website copy."@en ;
  dcterms:modified "2026-02-12T08:59:21.640332Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1467-3
  a curric:KeyLearningPoint ;
  rdfs:label """Rhetorical devices can be used to make website copy interesting and hook the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.640337Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1467-4
  a curric:KeyLearningPoint ;
  rdfs:label """Structural devices such as anaphora and motif can be used to emphasise key information and make website copy engaging."""@en ;
  dcterms:modified "2026-02-12T08:59:21.640342Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2096-1
  a curric:KeyLearningPoint ;
  rdfs:label """Memoirs are historical accounts or biographies written from personal experience or knowledge."""@en ;
  dcterms:modified "2026-02-12T08:59:21.640346Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2096-2
  a curric:KeyLearningPoint ;
  rdfs:label """Helen Keller's memoir describes an idyllic childhood juxtaposed with description of the illness that changed her life."""@en ;
  dcterms:modified "2026-02-12T08:59:21.640351Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2096-3
  a curric:KeyLearningPoint ;
  rdfs:label """Keller uses sensory language and juxtaposition to make her childhood account more vivid."""@en ;
  dcterms:modified "2026-02-12T08:59:21.640356Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2096-4
  a curric:KeyLearningPoint ;
  rdfs:label """Sensory language can be made more vivid if we add adjectives and embedded clauses."""@en ;
  dcterms:modified "2026-02-12T08:59:21.640361Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2096-5
  a curric:KeyLearningPoint ;
  rdfs:label """Contrasting sets of words and phrases highlight the differing feelings attached to memories."""@en ;
  dcterms:modified "2026-02-12T08:59:21.640365Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1685-1
  a curric:KeyLearningPoint ;
  rdfs:label """This is an autobiographical poem, subtitled ‘The Growth of the Poet’s Mind’, documenting his formative experiences."""@en ;
  dcterms:modified "2026-02-12T08:59:21.640373Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1685-2
  a curric:KeyLearningPoint ;
  rdfs:label """In ‘Extract from the Prelude’ the narrator, a young Wordsworth, goes on a literal and spiritual journey."""@en ;
  dcterms:modified "2026-02-12T08:59:21.640408Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1685-3
  a curric:KeyLearningPoint ;
  rdfs:label "The sublime is the mixed feelings of awe and terror in response to a phenomenon."@en ;
  dcterms:modified "2026-02-12T08:59:21.640413Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1685-4
  a curric:KeyLearningPoint ;
  rdfs:label """His transition from initial arrogance to humbled retreat suggests that man should respect nature’s supremacy."""@en ;
  dcterms:modified "2026-02-12T08:59:21.640418Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2427-1
  a curric:KeyLearningPoint ;
  rdfs:label """When comparing poems it’s useful to think of the poets as in conversation with each other."""@en ;
  dcterms:modified "2026-02-12T08:59:21.640423Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2427-2
  a curric:KeyLearningPoint ;
  rdfs:label """Both khan and Parker express the idea that objects we create are intrinsically connected to our identities."""@en ;
  dcterms:modified "2026-02-12T08:59:21.640428Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2427-3
  a curric:KeyLearningPoint ;
  rdfs:label """In ‘pot’ and ‘Homing’, both khan and Berry explore ideas around constraints on identity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.640433Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2427-4
  a curric:KeyLearningPoint ;
  rdfs:label """Both ‘The Jewellery Maker’ and ‘Homing’ imply that your identity can be created through place."""@en ;
  dcterms:modified "2026-02-12T08:59:21.640441Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2481-1
  a curric:KeyLearningPoint ;
  rdfs:label "Correlative conjunctions can be used to show the relationship between two ideas."@en ;
  dcterms:modified "2026-02-12T08:59:21.640446Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2481-2
  a curric:KeyLearningPoint ;
  rdfs:label "Textual references must be precise, accurate and judiciously chosen."@en ;
  dcterms:modified "2026-02-12T08:59:21.640451Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2481-3
  a curric:KeyLearningPoint ;
  rdfs:label """Responses should be led by the key ideas in both poems, supported by an analysis of the writers’ use of methods."""@en ;
  dcterms:modified "2026-02-12T08:59:21.640455Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2038-1
  a curric:KeyLearningPoint ;
  rdfs:label "The structure of a poem affects our journey, as the reader, through the poem."@en ;
  dcterms:modified "2026-02-12T08:59:21.640460Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2038-2
  a curric:KeyLearningPoint ;
  rdfs:label """The structure gives us our first and last impression of the poem and therefore affects the tone."""@en ;
  dcterms:modified "2026-02-12T08:59:21.640465Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2038-3
  a curric:KeyLearningPoint ;
  rdfs:label """You can make inferences based on the length of the stanza or the length of each line in a poem."""@en ;
  dcterms:modified "2026-02-12T08:59:21.640469Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2038-4
  a curric:KeyLearningPoint ;
  rdfs:label "Enjambment and caesuras affect the pace of the poem."@en ;
  dcterms:modified "2026-02-12T08:59:21.640474Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2038-5
  a curric:KeyLearningPoint ;
  rdfs:label "A break in the rhyme scheme can affect the meaning of the poem."@en ;
  dcterms:modified "2026-02-12T08:59:21.640481Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2458-1
  a curric:KeyLearningPoint ;
  rdfs:label """The thesis statement, topic sentences and summary sentences offer structure to the argument"""@en ;
  dcterms:modified "2026-02-12T08:59:21.640510Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2458-2
  a curric:KeyLearningPoint ;
  rdfs:label "Textual evidence should be used to support your argument and embedded"@en ;
  dcterms:modified "2026-02-12T08:59:21.640515Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2458-3
  a curric:KeyLearningPoint ;
  rdfs:label "We should use a range of embedded quotations from across the text"@en ;
  dcterms:modified "2026-02-12T08:59:21.640520Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2458-4
  a curric:KeyLearningPoint ;
  rdfs:label "You should examine layers of meaning within the text"@en ;
  dcterms:modified "2026-02-12T08:59:21.640525Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2458-5
  a curric:KeyLearningPoint ;
  rdfs:label "Redrafting is a very important part of the writing process"@en ;
  dcterms:modified "2026-02-12T08:59:21.640529Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2077-1
  a curric:KeyLearningPoint ;
  rdfs:label """Dr. Jekyll is hypocritical because he conceals his wicked other self under a facade of respectability."""@en ;
  dcterms:modified "2026-02-12T08:59:21.640534Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2077-2
  a curric:KeyLearningPoint ;
  rdfs:label "Mr. Utterson is discreet and careful to respect the privacy of others."@en ;
  dcterms:modified "2026-02-12T08:59:21.640539Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2077-3
  a curric:KeyLearningPoint ;
  rdfs:label "Dr. Lanyon keeps secrets and thereby allows Dr. Jekyll’s hypocrisy to flourish."@en ;
  dcterms:modified "2026-02-12T08:59:21.640544Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2077-4
  a curric:KeyLearningPoint ;
  rdfs:label """Stevenson is careful to draw a distinction between hypocrisy, discretion and privacy- although they all involve secrets."""@en ;
  dcterms:modified "2026-02-12T08:59:21.640548Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1490-1
  a curric:KeyLearningPoint ;
  rdfs:label """Anaphora is the repetition of words that come at the beginning of a sentence, designed to grab the listener’s attention."""@en ;
  dcterms:modified "2026-02-12T08:59:21.640555Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1490-2
  a curric:KeyLearningPoint ;
  rdfs:label "A refrain is a repeated idea or phrase that occurs throughout a speech."@en ;
  dcterms:modified "2026-02-12T08:59:21.640560Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1490-3
  a curric:KeyLearningPoint ;
  rdfs:label """Repetitious methods like anaphora and refrains help to engage the audience and reinforce central ideas."""@en ;
  dcterms:modified "2026-02-12T08:59:21.640565Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1490-4
  a curric:KeyLearningPoint ;
  rdfs:label """In both cases, the repeated ideas should be important words/phrases that are key to the main argument of your speech."""@en ;
  dcterms:modified "2026-02-12T08:59:21.640570Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1486-1
  a curric:KeyLearningPoint ;
  rdfs:label """A simile might be useful in non-fiction writing to explain an idea to the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.640574Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1486-2
  a curric:KeyLearningPoint ;
  rdfs:label """Reedy's use of similes highlights the level of scrutiny and unwanted attention she endures."""@en ;
  dcterms:modified "2026-02-12T08:59:21.640579Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1486-3
  a curric:KeyLearningPoint ;
  rdfs:label """To create a simile, we might start with deciding on what idea we want to communicate."""@en ;
  dcterms:modified "2026-02-12T08:59:21.640584Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1486-4
  a curric:KeyLearningPoint ;
  rdfs:label """Then we might decide on a comparative image which has connotations that match our idea."""@en ;
  dcterms:modified "2026-02-12T08:59:21.640610Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1486-5
  a curric:KeyLearningPoint ;
  rdfs:label "Finally, we might add extra details to enhance the reader’s understanding."@en ;
  dcterms:modified "2026-02-12T08:59:21.640615Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2047-1
  a curric:KeyLearningPoint ;
  rdfs:label """When approaching an unseen poem, you might ask questions about the voice, perspective, structure and imagery."""@en ;
  dcterms:modified "2026-02-12T08:59:21.640620Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2047-2
  a curric:KeyLearningPoint ;
  rdfs:label """In order to build on that initial response, you might use discussions in order to build on your ideas."""@en ;
  dcterms:modified "2026-02-12T08:59:21.640625Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2047-3
  a curric:KeyLearningPoint ;
  rdfs:label """Dunmore's 'Next Door' may be interpreted as the speaker being judgemental of their neighbours."""@en ;
  dcterms:modified "2026-02-12T08:59:21.640629Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2047-4
  a curric:KeyLearningPoint ;
  rdfs:label """On the other hand, it may be interpreted as an exploration of how we are all reflections of each other."""@en ;
  dcterms:modified "2026-02-12T08:59:21.640634Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28632-1
  a curric:KeyLearningPoint ;
  rdfs:label "A tragedy is a play dealing with tragic events and often ends with a death."@en ;
  dcterms:modified "2026-02-12T08:59:21.640639Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28632-2
  a curric:KeyLearningPoint ;
  rdfs:label "Shakespearean tragedies conventionally involve a tragic hero with a hamartia."@en ;
  dcterms:modified "2026-02-12T08:59:21.640644Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28632-3
  a curric:KeyLearningPoint ;
  rdfs:label """Conventionally, Shakespearean tragedies involve supernatural elements and fate which can add discomfort."""@en ;
  dcterms:modified "2026-02-12T08:59:21.640648Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28632-4
  a curric:KeyLearningPoint ;
  rdfs:label """Shakespearean tragedies also involve internal and external conflict as well as a battle of good vs. evil."""@en ;
  dcterms:modified "2026-02-12T08:59:21.640653Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28632-5
  a curric:KeyLearningPoint ;
  rdfs:label """At the end of a tragedy the audience experiences a release of pent up emotions called catharsis."""@en ;
  dcterms:modified "2026-02-12T08:59:21.640657Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2380-1
  a curric:KeyLearningPoint ;
  rdfs:label """Some might argue that Scrooge raising Bob’s wage is not an act of charity, but an act of employer responsibility."""@en ;
  dcterms:modified "2026-02-12T08:59:21.640662Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2380-2
  a curric:KeyLearningPoint ;
  rdfs:label """Sabbatarianism is the belief that all shops and businesses should be closed on the holy day (Sunday)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.640667Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2380-3
  a curric:KeyLearningPoint ;
  rdfs:label "Dickens seems to be criticising Sabbatarianism in Stave 3 of the novella."@en ;
  dcterms:modified "2026-02-12T08:59:21.640672Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2380-4
  a curric:KeyLearningPoint ;
  rdfs:label """Dickens highlights the hypocrisy of those who claim to be religious, but seek to undermine others’ charitable efforts."""@en ;
  dcterms:modified "2026-02-12T08:59:21.640676Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2380-5
  a curric:KeyLearningPoint ;
  rdfs:label "Dickens places emphasis on the importance of individual charity."@en ;
  dcterms:modified "2026-02-12T08:59:21.640681Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1497-1
  a curric:KeyLearningPoint ;
  rdfs:label """A great comparison analyses how the writers convey their ideas and perspectives of the events they are describing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.640688Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1497-2
  a curric:KeyLearningPoint ;
  rdfs:label """It may use comparatives and superlatives to evaluate the texts against one another."""@en ;
  dcterms:modified "2026-02-12T08:59:21.640693Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1497-3
  a curric:KeyLearningPoint ;
  rdfs:label """Comparatives use either a 'more' prefix or '-er' suffix to directly compare two texts or ideas."""@en ;
  dcterms:modified "2026-02-12T08:59:21.640700Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1497-4
  a curric:KeyLearningPoint ;
  rdfs:label """Superlatives use a 'most' prefix or 'est' suffix to form conclusions about a text in comparison to others."""@en ;
  dcterms:modified "2026-02-12T08:59:21.640705Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1497-5
  a curric:KeyLearningPoint ;
  rdfs:label """Comparatives and superlatives let us explore the relationship between the texts instead of analysing each in isolation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.640710Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2341-1
  a curric:KeyLearningPoint ;
  rdfs:label """Clarke uses the semantic field of motherhood to explore the duality of parental relationships."""@en ;
  dcterms:modified "2026-02-12T08:59:21.640738Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2341-2
  a curric:KeyLearningPoint ;
  rdfs:label "The semantic field of conflict is used to represent motherhood as a battle."@en ;
  dcterms:modified "2026-02-12T08:59:21.640742Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2341-3
  a curric:KeyLearningPoint ;
  rdfs:label """The change in tense between stanzas reflects how this conflict is an ongoing one."""@en ;
  dcterms:modified "2026-02-12T08:59:21.640782Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2341-4
  a curric:KeyLearningPoint ;
  rdfs:label """Repetition of the first line implies this is an authentic account of a personal conflict."""@en ;
  dcterms:modified "2026-02-12T08:59:21.640795Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2341-5
  a curric:KeyLearningPoint ;
  rdfs:label """The use of abstract imagery in lines 9-16 can interpreted both physically and emotionally symbolic"""@en ;
  dcterms:modified "2026-02-12T08:59:21.640801Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1647-1
  a curric:KeyLearningPoint ;
  rdfs:label """Lady Macbeth appears to be suffering from a psychological disorder that causes her to sleep-walk"""@en ;
  dcterms:modified "2026-02-12T08:59:21.640836Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1647-2
  a curric:KeyLearningPoint ;
  rdfs:label "This psychological disorder could be interpreted as a result of her guilt"@en ;
  dcterms:modified "2026-02-12T08:59:21.640841Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1647-3
  a curric:KeyLearningPoint ;
  rdfs:label "Lady Macbeth's language echoes that of her husband in earlier scenes"@en ;
  dcterms:modified "2026-02-12T08:59:21.640846Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1647-4
  a curric:KeyLearningPoint ;
  rdfs:label """Lady Macbeth's language might be suggesting that there is no salvation for the crimes that she has committed"""@en ;
  dcterms:modified "2026-02-12T08:59:21.640850Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6232-1
  a curric:KeyLearningPoint ;
  rdfs:label """Considering the ordering of ideas is important when analysing the structure of a text."""@en ;
  dcterms:modified "2026-02-12T08:59:21.640855Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6232-2
  a curric:KeyLearningPoint ;
  rdfs:label """Saramago purposely withholds information in 'Blindness' to build suspense and intrigue."""@en ;
  dcterms:modified "2026-02-12T08:59:21.640860Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6232-3
  a curric:KeyLearningPoint ;
  rdfs:label """We must always ask ourselves why a writer chose to structure their writing in the way they did."""@en ;
  dcterms:modified "2026-02-12T08:59:21.640865Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6232-4
  a curric:KeyLearningPoint ;
  rdfs:label "Time conjunctions can help us to write effective structural analysis."@en ;
  dcterms:modified "2026-02-12T08:59:21.640870Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29067-1
  a curric:KeyLearningPoint ;
  rdfs:label """Browning, Rossetti and Kay all arguably depict an obsessive, all-consuming idea of love."""@en ;
  dcterms:modified "2026-02-12T08:59:21.641060Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29067-2
  a curric:KeyLearningPoint ;
  rdfs:label """Browning, Rossetti and Kay all potentially suggest how women’s lives are influenced by their relationships."""@en ;
  dcterms:modified "2026-02-12T08:59:21.641065Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29067-3
  a curric:KeyLearningPoint ;
  rdfs:label """However, the way in which the women’s lives are influenced by their relationships differs in each poem."""@en ;
  dcterms:modified "2026-02-12T08:59:21.641072Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29067-4
  a curric:KeyLearningPoint ;
  rdfs:label "Arguably, Browning’s ‘Sonnet 29’ presents love as natural and desired."@en ;
  dcterms:modified "2026-02-12T08:59:21.641077Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29067-5
  a curric:KeyLearningPoint ;
  rdfs:label """In contrast, Rossetti arguably depicts how shame is associated with sex and Kay implies a lack of intimacy in sex."""@en ;
  dcterms:modified "2026-02-12T08:59:21.641082Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28982-1
  a curric:KeyLearningPoint ;
  rdfs:label "Always remember to select the most relevant quotation to your point."@en ;
  dcterms:modified "2026-02-12T08:59:21.641236Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28982-2
  a curric:KeyLearningPoint ;
  rdfs:label """Try to choose quotations that will allow you the best opportunity to develop nuanced ideas."""@en ;
  dcterms:modified "2026-02-12T08:59:21.641240Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28982-3
  a curric:KeyLearningPoint ;
  rdfs:label "Try to avoid generalisations when talking about context."@en ;
  dcterms:modified "2026-02-12T08:59:21.641245Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28982-4
  a curric:KeyLearningPoint ;
  rdfs:label "Ensure that the contextual information develops the point you are making."@en ;
  dcterms:modified "2026-02-12T08:59:21.641250Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28982-5
  a curric:KeyLearningPoint ;
  rdfs:label """An effective answer considers how the context helps us to better understand the ideas in the text."""@en ;
  dcterms:modified "2026-02-12T08:59:21.641254Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2040-1
  a curric:KeyLearningPoint ;
  rdfs:label "The speaker is different to the poet."@en ;
  dcterms:modified "2026-02-12T08:59:21.641259Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2040-2
  a curric:KeyLearningPoint ;
  rdfs:label """A poet sometimes writes from the perspective of a speaker, rather than only from their own experiences."""@en ;
  dcterms:modified "2026-02-12T08:59:21.641266Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2040-3
  a curric:KeyLearningPoint ;
  rdfs:label "You can make inferences based on the speaker and voice of a poem."@en ;
  dcterms:modified "2026-02-12T08:59:21.641271Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2040-4
  a curric:KeyLearningPoint ;
  rdfs:label """Some poems have a conversational tone, which helps to develop a personal connection with the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.641276Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2345-1
  a curric:KeyLearningPoint ;
  rdfs:label "Poems can be linked by theme e.g. war, parental conflict."@en ;
  dcterms:modified "2026-02-12T08:59:21.641281Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2345-2
  a curric:KeyLearningPoint ;
  rdfs:label """Poems can be linked by attitude, considering how the poet's feel about the subject they are addressing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.641285Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2345-3
  a curric:KeyLearningPoint ;
  rdfs:label """Poems can be connected by how poets use similar imagery or techniques to address different issues."""@en ;
  dcterms:modified "2026-02-12T08:59:21.641290Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2345-4
  a curric:KeyLearningPoint ;
  rdfs:label """Correlative and comparative conjunctions are useful for signposting the similarities and differences between both texts."""@en ;
  dcterms:modified "2026-02-12T08:59:21.641303Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2345-5
  a curric:KeyLearningPoint ;
  rdfs:label """Superlatives can be used to evaluate the differences between attitudes or key ideas."""@en ;
  dcterms:modified "2026-02-12T08:59:21.641308Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2555-1
  a curric:KeyLearningPoint ;
  rdfs:label """When comparing poems it's useful to think of the poets as in conversation with each other."""@en ;
  dcterms:modified "2026-02-12T08:59:21.641313Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2555-2
  a curric:KeyLearningPoint ;
  rdfs:label """Blakemore presents a community that is stronger due to different cultures in 'Peckham Rye Lane'."""@en ;
  dcterms:modified "2026-02-12T08:59:21.641318Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2555-3
  a curric:KeyLearningPoint ;
  rdfs:label """In contrast, Antrobus depicts his struggle to gain a sense of belonging in 'Jamaican British'."""@en ;
  dcterms:modified "2026-02-12T08:59:21.641323Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2555-4
  a curric:KeyLearningPoint ;
  rdfs:label """Nichols presents a character who longs to be more in touch with his cultural heritage in 'Island Man'."""@en ;
  dcterms:modified "2026-02-12T08:59:21.641327Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2308-1
  a curric:KeyLearningPoint ;
  rdfs:label "The power of education is a central theme in ‘Leave Taking’."@en ;
  dcterms:modified "2026-02-12T08:59:21.641353Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2308-2
  a curric:KeyLearningPoint ;
  rdfs:label """Pinnock examines the idea that there is a hierarchy of knowledge in the formal education system."""@en ;
  dcterms:modified "2026-02-12T08:59:21.641358Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2308-3
  a curric:KeyLearningPoint ;
  rdfs:label """Pinnock challenges her audiences to widen their view of what is valued in education."""@en ;
  dcterms:modified "2026-02-12T08:59:21.641363Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2308-4
  a curric:KeyLearningPoint ;
  rdfs:label """When writing an essay on ‘Leave Taking’, you should identify and explore Pinnock’s intentions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.641368Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29084-1
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, the speaker associates their home with beauty, joy, and a sense of being carefree."""@en ;
  dcterms:modified "2026-02-12T08:59:21.641403Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29084-2
  a curric:KeyLearningPoint ;
  rdfs:label "Conversely, the speaker presents their current situation as bringing them pain."@en ;
  dcterms:modified "2026-02-12T08:59:21.641408Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29084-3
  a curric:KeyLearningPoint ;
  rdfs:label """Potentially, we might also suggest the speaker feels as if they must hide their heritage in their current situation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.641413Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29084-4
  a curric:KeyLearningPoint ;
  rdfs:label """McKay arguably suggests that returning home will relieve the speaker of this pain."""@en ;
  dcterms:modified "2026-02-12T08:59:21.641417Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29084-5
  a curric:KeyLearningPoint ;
  rdfs:label """We might suggest that we can see an idealised view of rural, peasant life in ‘I Shall Return’."""@en ;
  dcterms:modified "2026-02-12T08:59:21.641422Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9241-1
  a curric:KeyLearningPoint ;
  rdfs:label "‘Cozy Apologia’ is dedicated to Dove’s husband Fred, whom she married in 1979."@en ;
  dcterms:modified "2026-02-12T08:59:21.641427Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9241-2
  a curric:KeyLearningPoint ;
  rdfs:label """Dove contrasts the safety of her love with her husband with the danger of the approaching hurricane."""@en ;
  dcterms:modified "2026-02-12T08:59:21.641432Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9241-3
  a curric:KeyLearningPoint ;
  rdfs:label """Whilst the relationship does not appear exciting, the speaker clearly feels safe and loved with her partner."""@en ;
  dcterms:modified "2026-02-12T08:59:21.641436Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9241-4
  a curric:KeyLearningPoint ;
  rdfs:label "Arguably, Dove is grateful for the mundanity of her life with her husband."@en ;
  dcterms:modified "2026-02-12T08:59:21.641441Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29078-1
  a curric:KeyLearningPoint ;
  rdfs:label """The poems that you choose to compare should both be linked to the focus and nuances of the question you are asked."""@en ;
  dcterms:modified "2026-02-12T08:59:21.641446Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29078-2
  a curric:KeyLearningPoint ;
  rdfs:label """It is useful to consider the similarities between poems and then consider any subtle differences between them."""@en ;
  dcterms:modified "2026-02-12T08:59:21.641451Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29078-3
  a curric:KeyLearningPoint ;
  rdfs:label """Thesis statements help you to refine your argument and give you a point of reference to return to as you write."""@en ;
  dcterms:modified "2026-02-12T08:59:21.641455Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29078-4
  a curric:KeyLearningPoint ;
  rdfs:label """Evidence should be selected judiciously - it is important to choose the quotation that best supports your argument."""@en ;
  dcterms:modified "2026-02-12T08:59:21.641460Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28794-1
  a curric:KeyLearningPoint ;
  rdfs:label """Gerald is established as an “attractive” and “well-bred” man, emphasising his social status."""@en ;
  dcterms:modified "2026-02-12T08:59:21.641510Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28794-2
  a curric:KeyLearningPoint ;
  rdfs:label """Gerald presents himself as the hero of his narrative, but this can be challenged."""@en ;
  dcterms:modified "2026-02-12T08:59:21.641515Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28794-3
  a curric:KeyLearningPoint ;
  rdfs:label """Priestley uses the character of Eva Smith to represent the working classes as a whole."""@en ;
  dcterms:modified "2026-02-12T08:59:21.641520Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28794-4
  a curric:KeyLearningPoint ;
  rdfs:label "Priestley’s choice of name reflects the importance of Eva’s character."@en ;
  dcterms:modified "2026-02-12T08:59:21.641524Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28794-5
  a curric:KeyLearningPoint ;
  rdfs:label """Eva and Gerald could be seen as foils to each other to represent the stark differences in their experiences."""@en ;
  dcterms:modified "2026-02-12T08:59:21.641529Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1484-1
  a curric:KeyLearningPoint ;
  rdfs:label """Inferences rely on things that haven’t been explicitly stated but hinted at or suggested."""@en ;
  dcterms:modified "2026-02-12T08:59:21.641605Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1484-2
  a curric:KeyLearningPoint ;
  rdfs:label "Embedded quotations should be part of the sentence, short and relevant."@en ;
  dcterms:modified "2026-02-12T08:59:21.641609Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1484-3
  a curric:KeyLearningPoint ;
  rdfs:label "Using synonyms of ‘suggests’ and ‘shows’ can help create an effective summary."@en ;
  dcterms:modified "2026-02-12T08:59:21.641614Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1484-4
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, an effective summary relies on inferences and embedded evidence for the inferences."""@en ;
  dcterms:modified "2026-02-12T08:59:21.641619Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2305-1
  a curric:KeyLearningPoint ;
  rdfs:label "Del's experiences with formal education were mainly negative."@en ;
  dcterms:modified "2026-02-12T08:59:21.641623Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2305-2
  a curric:KeyLearningPoint ;
  rdfs:label """Del understands the value of formal education, hence her anger at Viv for skipping one of her A Level exams."""@en ;
  dcterms:modified "2026-02-12T08:59:21.641628Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2305-3
  a curric:KeyLearningPoint ;
  rdfs:label "Del finds a sense of peace and fulfilment via her informal education with Mai."@en ;
  dcterms:modified "2026-02-12T08:59:21.641633Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2305-4
  a curric:KeyLearningPoint ;
  rdfs:label "Despite her academic success, Viv doesn't connect to her school curriculum."@en ;
  dcterms:modified "2026-02-12T08:59:21.641638Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2305-5
  a curric:KeyLearningPoint ;
  rdfs:label """At the end of the play, Viv pursues Black Studies at uni, perhaps suggesting she will enjoy a more fulfilling education."""@en ;
  dcterms:modified "2026-02-12T08:59:21.641642Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28635-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘Romeo and Juliet’ was written when society was patriarchal - men were in control."""@en ;
  dcterms:modified "2026-02-12T08:59:21.641647Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28635-2
  a curric:KeyLearningPoint ;
  rdfs:label """Women would have been expected to obey their parents’ wishes in terms of their marriage."""@en ;
  dcterms:modified "2026-02-12T08:59:21.641651Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28635-3
  a curric:KeyLearningPoint ;
  rdfs:label """Lady Capulet and the Nurse suggest that motherhood is an expected part of marriage."""@en ;
  dcterms:modified "2026-02-12T08:59:21.641656Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28635-4
  a curric:KeyLearningPoint ;
  rdfs:label """Lady Capulet’s metaphor of women as a “cover” suggests that women’s role in marriage is limited to outward appearance."""@en ;
  dcterms:modified "2026-02-12T08:59:21.641661Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28635-5
  a curric:KeyLearningPoint ;
  rdfs:label """Juliet appears to suggest that she will be obedient to her parents’ wishes in terms of her marriage."""@en ;
  dcterms:modified "2026-02-12T08:59:21.641668Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2014-1
  a curric:KeyLearningPoint ;
  rdfs:label """Act 2, Scene 1 is could be seen as crucial in creating the idea that Macbeth is influenced by the supernatural and evil"""@en ;
  dcterms:modified "2026-02-12T08:59:21.641704Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2014-2
  a curric:KeyLearningPoint ;
  rdfs:label """Macbeth does recognise the dagger as a hallucination - counter evidence that he is being influenced by the supernatural"""@en ;
  dcterms:modified "2026-02-12T08:59:21.641710Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2014-3
  a curric:KeyLearningPoint ;
  rdfs:label "Macbeth uses the hallucination as justification for killing Duncan"@en ;
  dcterms:modified "2026-02-12T08:59:21.641715Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2014-4
  a curric:KeyLearningPoint ;
  rdfs:label "A dagger is symbolic of treachery - representing betrayal at close range"@en ;
  dcterms:modified "2026-02-12T08:59:21.641719Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2067-1
  a curric:KeyLearningPoint ;
  rdfs:label """Macbeth's lack of a male heir makes him susceptible to Lady Macbeth's manipulations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.641724Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2067-2
  a curric:KeyLearningPoint ;
  rdfs:label "Lady Macbeth uses Macbeth's insecurities to emasculate him."@en ;
  dcterms:modified "2026-02-12T08:59:21.641729Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2067-3
  a curric:KeyLearningPoint ;
  rdfs:label """Macbeth is more likely to believe the witches' prophecies due to his insecurities."""@en ;
  dcterms:modified "2026-02-12T08:59:21.641733Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2067-4
  a curric:KeyLearningPoint ;
  rdfs:label "Macbeth's lack of a male heir makes him more likely to betray Banquo and Duncan."@en ;
  dcterms:modified "2026-02-12T08:59:21.641741Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2067-5
  a curric:KeyLearningPoint ;
  rdfs:label """Shakespeare upholds the status quo by punishing characters who do not conform to conventional gender roles."""@en ;
  dcterms:modified "2026-02-12T08:59:21.641746Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2113-1
  a curric:KeyLearningPoint ;
  rdfs:label """Ishiguro crafts Klara as an ambiguous narrator, leaving us to decipher her true nature."""@en ;
  dcterms:modified "2026-02-12T08:59:21.641750Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2113-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Klara and the Sun' is set in a futuristic dystopia."@en ;
  dcterms:modified "2026-02-12T08:59:21.641755Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2113-3
  a curric:KeyLearningPoint ;
  rdfs:label "Klara is an AI companion for children."@en ;
  dcterms:modified "2026-02-12T08:59:21.641760Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2113-4
  a curric:KeyLearningPoint ;
  rdfs:label "Ishiguro blurs the line between robot and human in his crafting of Klara."@en ;
  dcterms:modified "2026-02-12T08:59:21.641765Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2113-5
  a curric:KeyLearningPoint ;
  rdfs:label """Ishiguro crafts Klara as the future voice of AI, perhaps subverting our traditional expectations about AI."""@en ;
  dcterms:modified "2026-02-12T08:59:21.641769Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28786-1
  a curric:KeyLearningPoint ;
  rdfs:label """The cliffhanger at the end of the play gives the play an ambiguous and unresolved ending."""@en ;
  dcterms:modified "2026-02-12T08:59:21.641898Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28786-2
  a curric:KeyLearningPoint ;
  rdfs:label "Priestley uses cliffhangers to create suspense and tension throughout the play."@en ;
  dcterms:modified "2026-02-12T08:59:21.641905Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28786-3
  a curric:KeyLearningPoint ;
  rdfs:label """Priestley uses a cyclical structure to impact the audience and provoke reflection."""@en ;
  dcterms:modified "2026-02-12T08:59:21.641910Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28786-4
  a curric:KeyLearningPoint ;
  rdfs:label """The cyclical structure of the play links to the themes of social responsibility, class and societal change."""@en ;
  dcterms:modified "2026-02-12T08:59:21.641915Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28792-1
  a curric:KeyLearningPoint ;
  rdfs:label "Context refers to historical, social, literary and biographical information."@en ;
  dcterms:modified "2026-02-12T08:59:21.641919Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28792-2
  a curric:KeyLearningPoint ;
  rdfs:label "Context should not be presented as isolated facts."@en ;
  dcterms:modified "2026-02-12T08:59:21.641924Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28792-3
  a curric:KeyLearningPoint ;
  rdfs:label "Context should be relevant to the analysis and woven throughout the response."@en ;
  dcterms:modified "2026-02-12T08:59:21.641929Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28792-4
  a curric:KeyLearningPoint ;
  rdfs:label """Context should develop your ideas and give an insight into the writer’s purpose and intention."""@en ;
  dcterms:modified "2026-02-12T08:59:21.641934Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9259-1
  a curric:KeyLearningPoint ;
  rdfs:label """Some of the poems’ subject is nature, others use nature as a vehicle for the exploration of human emotion."""@en ;
  dcterms:modified "2026-02-12T08:59:21.641939Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9259-2
  a curric:KeyLearningPoint ;
  rdfs:label """Comparing poems that explore the same theme in a different way can make for an interesting comparison."""@en ;
  dcterms:modified "2026-02-12T08:59:21.641943Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9259-3
  a curric:KeyLearningPoint ;
  rdfs:label """Comparative conjunctions should be used to compare language, form and structure of poems."""@en ;
  dcterms:modified "2026-02-12T08:59:21.641948Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9259-4
  a curric:KeyLearningPoint ;
  rdfs:label """Your comparison can explore the similar methods that poets use to convey their perspectives or ideas."""@en ;
  dcterms:modified "2026-02-12T08:59:21.641955Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9259-5
  a curric:KeyLearningPoint ;
  rdfs:label """For example, some of the poets on the anthology use seasonal transitions as a metaphor for human emotion."""@en ;
  dcterms:modified "2026-02-12T08:59:21.641960Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2477-1
  a curric:KeyLearningPoint ;
  rdfs:label "Hardy uses colour imagery to create a bleak and barren emotional landscape."@en ;
  dcterms:modified "2026-02-12T08:59:21.641982Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2477-2
  a curric:KeyLearningPoint ;
  rdfs:label """Hardy uses an oxymoron to convey the hostile and hopeless nature of the relationship."""@en ;
  dcterms:modified "2026-02-12T08:59:21.641986Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2477-3
  a curric:KeyLearningPoint ;
  rdfs:label "Hardy uses personification to suggest how he feels misled by love."@en ;
  dcterms:modified "2026-02-12T08:59:21.641991Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2477-4
  a curric:KeyLearningPoint ;
  rdfs:label "Hardy uses ominous imagery to show how the relationship was ill-fated."@en ;
  dcterms:modified "2026-02-12T08:59:21.641996Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2477-5
  a curric:KeyLearningPoint ;
  rdfs:label """Analytical paragraphs should consider a writer’s meaning, use of language and purpose."""@en ;
  dcterms:modified "2026-02-12T08:59:21.642001Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29035-1
  a curric:KeyLearningPoint ;
  rdfs:label "'An Inspector Calls' could be interpreted as a religious allegory."@en ;
  dcterms:modified "2026-02-12T08:59:21.642238Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29035-2
  a curric:KeyLearningPoint ;
  rdfs:label """The seven deadly sins are reflected in the characters' actions and their moral failings."""@en ;
  dcterms:modified "2026-02-12T08:59:21.642245Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29035-3
  a curric:KeyLearningPoint ;
  rdfs:label """The themes of purgatory and judgment are explored through the characters' unresolved guilt."""@en ;
  dcterms:modified "2026-02-12T08:59:21.642250Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29035-4
  a curric:KeyLearningPoint ;
  rdfs:label """The Inspector embodies biblical justice, revealing truth, prompting confessions, and warning of consequences."""@en ;
  dcterms:modified "2026-02-12T08:59:21.642255Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29035-5
  a curric:KeyLearningPoint ;
  rdfs:label """Priestley critiques the law, suggesting moral accountability is more important than legal justice."""@en ;
  dcterms:modified "2026-02-12T08:59:21.642259Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1667-1
  a curric:KeyLearningPoint ;
  rdfs:label "At different times in the novella, Hyde is presented as being an unknown entity."@en ;
  dcterms:modified "2026-02-12T08:59:21.642264Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1667-2
  a curric:KeyLearningPoint ;
  rdfs:label """At other times, Hyde is presented as being a dangerous assailant, particularly during the murder of Carew."""@en ;
  dcterms:modified "2026-02-12T08:59:21.642272Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1667-3
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, Hyde acts as a cautionary warning against limitless scientific development."""@en ;
  dcterms:modified "2026-02-12T08:59:21.642286Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1667-4
  a curric:KeyLearningPoint ;
  rdfs:label """When selecting quotations, consider the overarching idea, any larger methods used and which words are ripe for analysis."""@en ;
  dcterms:modified "2026-02-12T08:59:21.642292Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2470-1
  a curric:KeyLearningPoint ;
  rdfs:label "In Stave 5, we see Scrooge brimming with positivity and newfound moral purpose."@en ;
  dcterms:modified "2026-02-12T08:59:21.642297Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2470-2
  a curric:KeyLearningPoint ;
  rdfs:label """Scrooge makes several redemptive gestures of goodwill, showing that he is a transformed character."""@en ;
  dcterms:modified "2026-02-12T08:59:21.642301Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2470-3
  a curric:KeyLearningPoint ;
  rdfs:label """In Stave 5, we see Scrooge as liberated from his emotional repression and overwhelmed with newfound positive emotions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.642306Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2470-4
  a curric:KeyLearningPoint ;
  rdfs:label """Dickens juxtaposes his use of similes in Staves 1 and 5 to show Scrooge's positive character development."""@en ;
  dcterms:modified "2026-02-12T08:59:21.642311Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2470-5
  a curric:KeyLearningPoint ;
  rdfs:label """Scrooge has gone from being the object of disdain and fear in society, to being the pillar of his local community."""@en ;
  dcterms:modified "2026-02-12T08:59:21.642316Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2376-1
  a curric:KeyLearningPoint ;
  rdfs:label "Marley's Ghost represents the Christian ideas of repentance and redemption."@en ;
  dcterms:modified "2026-02-12T08:59:21.642335Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2376-2
  a curric:KeyLearningPoint ;
  rdfs:label """Marley expresses regret at his own immoral behaviour: ’and never raise [his eyes] to that blessed Star’."""@en ;
  dcterms:modified "2026-02-12T08:59:21.642339Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2376-3
  a curric:KeyLearningPoint ;
  rdfs:label """The line  ’[...] Marley had no bowels’ links these being the seat of compassion, referred to in the New Testament."""@en ;
  dcterms:modified "2026-02-12T08:59:21.642347Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2376-4
  a curric:KeyLearningPoint ;
  rdfs:label """Dickens also uses Marley to allude to the parable of the rich man and Lazarus, showing us the consequences of greed."""@en ;
  dcterms:modified "2026-02-12T08:59:21.642352Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2376-5
  a curric:KeyLearningPoint ;
  rdfs:label """Dickens draws parallels between Marley and Cain to show that Marley’s eternal ‘wandering’ is punishment for his sins."""@en ;
  dcterms:modified "2026-02-12T08:59:21.642357Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2121-1
  a curric:KeyLearningPoint ;
  rdfs:label """Writers convey their meaning through explicit statements and implicit suggestion."""@en ;
  dcterms:modified "2026-02-12T08:59:21.642361Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2121-2
  a curric:KeyLearningPoint ;
  rdfs:label "The reader makes inferences in order to discover the more nuanced meanings."@en ;
  dcterms:modified "2026-02-12T08:59:21.642366Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2121-3
  a curric:KeyLearningPoint ;
  rdfs:label "Inference involves zooming in on the connotations of chosen words."@en ;
  dcterms:modified "2026-02-12T08:59:21.642371Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2121-4
  a curric:KeyLearningPoint ;
  rdfs:label "Font styles can also be a subtle way of communicating ideas."@en ;
  dcterms:modified "2026-02-12T08:59:21.642376Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2025-1
  a curric:KeyLearningPoint ;
  rdfs:label "When comparing poems, pay attention to the specific theme within the question."@en ;
  dcterms:modified "2026-02-12T08:59:21.642450Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2025-2
  a curric:KeyLearningPoint ;
  rdfs:label """Be open to comparing poems across different eras, movements, styles and content areas."""@en ;
  dcterms:modified "2026-02-12T08:59:21.642455Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2025-3
  a curric:KeyLearningPoint ;
  rdfs:label "Memory is a key theme across many of the ‘Power and Conflict’ poems."@en ;
  dcterms:modified "2026-02-12T08:59:21.642460Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2025-4
  a curric:KeyLearningPoint ;
  rdfs:label """Poets from the anthology often explore the damaging effect of pride, the power of nature and harrowing inner conflicts."""@en ;
  dcterms:modified "2026-02-12T08:59:21.642464Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1690-1
  a curric:KeyLearningPoint ;
  rdfs:label "Browning uses art to symbolise the Duke’s craving for power and control."@en ;
  dcterms:modified "2026-02-12T08:59:21.642469Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1690-2
  a curric:KeyLearningPoint ;
  rdfs:label """By using the form of a dramatic monologue and rhyming couplets, Browning reflects the Duke’s desire for total control."""@en ;
  dcterms:modified "2026-02-12T08:59:21.642474Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1690-3
  a curric:KeyLearningPoint ;
  rdfs:label """Enjambment reveals a single person’s capacity to be carried away by passions and anger, subtly revealing instability."""@en ;
  dcterms:modified "2026-02-12T08:59:21.642479Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1690-4
  a curric:KeyLearningPoint ;
  rdfs:label """Ironically, through his craving for control and power, the Duke reveals himself to be powerless."""@en ;
  dcterms:modified "2026-02-12T08:59:21.642483Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1690-5
  a curric:KeyLearningPoint ;
  rdfs:label """Browning exposing the Duke as powerless and insecure may reflect his critique of patriarchal Victorian society."""@en ;
  dcterms:modified "2026-02-12T08:59:21.642488Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2046-1
  a curric:KeyLearningPoint ;
  rdfs:label """To organise your thoughts chronologically, you might consider what happens at the beginning, middle and end of the poem."""@en ;
  dcterms:modified "2026-02-12T08:59:21.642508Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2046-2
  a curric:KeyLearningPoint ;
  rdfs:label """By organising your thoughts chronologically, you can consider the progression of ideas through the poem."""@en ;
  dcterms:modified "2026-02-12T08:59:21.642512Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2046-3
  a curric:KeyLearningPoint ;
  rdfs:label """To organise your thoughts thematically, you might consider where the distinctions are between your ideas."""@en ;
  dcterms:modified "2026-02-12T08:59:21.642517Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2046-4
  a curric:KeyLearningPoint ;
  rdfs:label """By organising your thoughts thematically, you might consider which ideas have more evidence than others."""@en ;
  dcterms:modified "2026-02-12T08:59:21.642522Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2545-1
  a curric:KeyLearningPoint ;
  rdfs:label """Personification also helps to create a connection between the poet and the river - creates a sense of belonging."""@en ;
  dcterms:modified "2026-02-12T08:59:21.642529Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2545-2
  a curric:KeyLearningPoint ;
  rdfs:label "The use of onomatopoeia arguably creates an immersive, meditative atmosphere."@en ;
  dcterms:modified "2026-02-12T08:59:21.642534Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2545-3
  a curric:KeyLearningPoint ;
  rdfs:label """Bridges' use of sibilance could mimic the flow of water to create a calm atmosphere."""@en ;
  dcterms:modified "2026-02-12T08:59:21.642539Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2545-4
  a curric:KeyLearningPoint ;
  rdfs:label "The cyclical structure may mimic the speaker's continual return to the stream."@en ;
  dcterms:modified "2026-02-12T08:59:21.642544Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2545-5
  a curric:KeyLearningPoint ;
  rdfs:label """The regular rhyme might represent the unity and harmony between the speaker and nature."""@en ;
  dcterms:modified "2026-02-12T08:59:21.642548Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9262-1
  a curric:KeyLearningPoint ;
  rdfs:label "An excellent analytical response is clear, nuanced and concise."@en ;
  dcterms:modified "2026-02-12T08:59:21.642716Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9262-2
  a curric:KeyLearningPoint ;
  rdfs:label """A nuanced response acknowledges and explores the shades of meaning within the text."""@en ;
  dcterms:modified "2026-02-12T08:59:21.642724Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9262-3
  a curric:KeyLearningPoint ;
  rdfs:label """Comparative connectives can be used to link ideas together and explore connections between poems."""@en ;
  dcterms:modified "2026-02-12T08:59:21.642729Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9262-4
  a curric:KeyLearningPoint ;
  rdfs:label """Asking yourself 'why' can be a useful exercise when writing an analytical response."""@en ;
  dcterms:modified "2026-02-12T08:59:21.642734Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9262-5
  a curric:KeyLearningPoint ;
  rdfs:label "You can use context to inform your comparison of the poets' perspectives."@en ;
  dcterms:modified "2026-02-12T08:59:21.642739Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2558-1
  a curric:KeyLearningPoint ;
  rdfs:label """In the poem Hardi speaks of her mother's possessions, the ones she has collected (and lost) fleeing war."""@en ;
  dcterms:modified "2026-02-12T08:59:21.642826Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2558-2
  a curric:KeyLearningPoint ;
  rdfs:label """Hardi's poem addresses belonging through the eyes of a refugee, forced to move many times for safety."""@en ;
  dcterms:modified "2026-02-12T08:59:21.642831Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2558-3
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, the poem implies the displacement means refugees never have a chance to belong anywhere."""@en ;
  dcterms:modified "2026-02-12T08:59:21.642836Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6257-1
  a curric:KeyLearningPoint ;
  rdfs:label """The anthology poems all arguably consider feelings of belonging and the impact on the people who experience them."""@en ;
  dcterms:modified "2026-02-12T08:59:21.642840Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6257-2
  a curric:KeyLearningPoint ;
  rdfs:label """The poems that you choose to compare should both be linked to the focus and nuances of the question you are asked."""@en ;
  dcterms:modified "2026-02-12T08:59:21.642845Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6257-3
  a curric:KeyLearningPoint ;
  rdfs:label """It is useful to consider the similarities between poems and then consider any subtle differences between them."""@en ;
  dcterms:modified "2026-02-12T08:59:21.642850Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6257-4
  a curric:KeyLearningPoint ;
  rdfs:label "Concluding sentences should have a sharp focus on the writer's intention."@en ;
  dcterms:modified "2026-02-12T08:59:21.642854Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1707-1
  a curric:KeyLearningPoint ;
  rdfs:label """For your ‘Power and Conflict’ essay, you will be given one poem and you have to choose one to compare it with."""@en ;
  dcterms:modified "2026-02-12T08:59:21.642873Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1707-2
  a curric:KeyLearningPoint ;
  rdfs:label """‘Poppies’ could compare well with ‘Remains’, ‘Kamikaze’ or Duffy's ‘War Photographer’."""@en ;
  dcterms:modified "2026-02-12T08:59:21.642881Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1707-3
  a curric:KeyLearningPoint ;
  rdfs:label """‘Poppies’ and ‘Kamikaze’ explore less-recognised perspectives of war and show that these are nonetheless painful."""@en ;
  dcterms:modified "2026-02-12T08:59:21.642886Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1707-4
  a curric:KeyLearningPoint ;
  rdfs:label """Duffy's ‘War Photographer’ and ‘Poppies’ explore powerful memories that are connected to their difficult experiences."""@en ;
  dcterms:modified "2026-02-12T08:59:21.642890Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1707-5
  a curric:KeyLearningPoint ;
  rdfs:label """‘Poppies’ ends with a sombre but peaceful tone, Duffy's ‘War Photographer’ ends with a caustic and restless tone."""@en ;
  dcterms:modified "2026-02-12T08:59:21.642897Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2361-1
  a curric:KeyLearningPoint ;
  rdfs:label """Enid’s experiences of oppression and marginalisation are somewhat based on Pinnock’s own mother’s experiences."""@en ;
  dcterms:modified "2026-02-12T08:59:21.642958Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2361-2
  a curric:KeyLearningPoint ;
  rdfs:label """Scene Two explores Del and Enid’s differing experiences of oppression and marginalisation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.642968Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2361-3
  a curric:KeyLearningPoint ;
  rdfs:label "Intersectionality is a term coined by Kimberlé Crenshaw."@en ;
  dcterms:modified "2026-02-12T08:59:21.642973Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2361-4
  a curric:KeyLearningPoint ;
  rdfs:label """It recognises that oppressions faced by different marginalised groups intersect and create specific experiences."""@en ;
  dcterms:modified "2026-02-12T08:59:21.642978Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2361-5
  a curric:KeyLearningPoint ;
  rdfs:label """The universal themes and characters in the play must be balanced by the specific experiences of Pinnock’s characters."""@en ;
  dcterms:modified "2026-02-12T08:59:21.642983Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2062-1
  a curric:KeyLearningPoint ;
  rdfs:label "The pigs prioritise their personal greed over the values outlined by Old Major."@en ;
  dcterms:modified "2026-02-12T08:59:21.643199Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2062-2
  a curric:KeyLearningPoint ;
  rdfs:label "The apple could represent the parable of Adam and Eve and the fall from grace."@en ;
  dcterms:modified "2026-02-12T08:59:21.643206Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2062-3
  a curric:KeyLearningPoint ;
  rdfs:label "Food symbolises more than just greed, it symbolises hypocrisy."@en ;
  dcterms:modified "2026-02-12T08:59:21.643211Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2062-4
  a curric:KeyLearningPoint ;
  rdfs:label "The food the pigs take builds from the basics to luxuries, such as whisky."@en ;
  dcterms:modified "2026-02-12T08:59:21.643216Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2062-5
  a curric:KeyLearningPoint ;
  rdfs:label "Tracing motifs is an effective way to develop your essays."@en ;
  dcterms:modified "2026-02-12T08:59:21.643223Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2057-1
  a curric:KeyLearningPoint ;
  rdfs:label "Deception is a key theme in ‘Animal Farm’."@en ;
  dcterms:modified "2026-02-12T08:59:21.643228Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2057-2
  a curric:KeyLearningPoint ;
  rdfs:label """Orwell was cynical about religion and used the character of Moses to explore this theme."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643233Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2057-3
  a curric:KeyLearningPoint ;
  rdfs:label """Discourse markers and time conjunctions can help contextualise quotes and and present your ideas logically."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643240Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2057-4
  a curric:KeyLearningPoint ;
  rdfs:label """Methods of deception include the use of: euphemism, jargon, hyperbole, subversion and obfuscation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643245Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2325-1
  a curric:KeyLearningPoint ;
  rdfs:label """The speaker works in his fathers' shop and lives with his wife and parents above the shop."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643250Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2325-2
  a curric:KeyLearningPoint ;
  rdfs:label """The speaker often neglects his work in the shop and receives complaints from customers."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643254Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2325-3
  a curric:KeyLearningPoint ;
  rdfs:label """The wife is unconventional and has an acrimonious relationship with her husband's parents."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643259Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2325-4
  a curric:KeyLearningPoint ;
  rdfs:label "The speaker and wife have a very close, loving and intimate relationship."@en ;
  dcterms:modified "2026-02-12T08:59:21.643264Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2325-5
  a curric:KeyLearningPoint ;
  rdfs:label """Although the poem is not autobiographical it does echo some aspects of Nagra's own life."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643268Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2492-1
  a curric:KeyLearningPoint ;
  rdfs:label """The speaker of the poem is reminiscing about a childhood memory of climbing their grandfather’s body."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643312Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2492-2
  a curric:KeyLearningPoint ;
  rdfs:label """The speaker initially feels safe and secure when reminiscing about his grandfather."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643317Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2492-3
  a curric:KeyLearningPoint ;
  rdfs:label """The climb, and act of remembering, becomes increasingly difficult, risky and even dangerous."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643321Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2492-4
  a curric:KeyLearningPoint ;
  rdfs:label """The grandfather is presented as an ambiguous figure, both comforting yet also mysterious."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643326Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2492-5
  a curric:KeyLearningPoint ;
  rdfs:label "Waterhouse often wrote about the natural world and family relationships."@en ;
  dcterms:modified "2026-02-12T08:59:21.643331Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2349-1
  a curric:KeyLearningPoint ;
  rdfs:label """'Kumukanda' was written by Kayo Chingonyi, a Zambian poet who moved to the UK when he was six."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643354Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2349-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Kumukanda' means initiation, referring to a ceremony marking the transition from boy to man in the Luvale tribe."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643359Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2349-3
  a curric:KeyLearningPoint ;
  rdfs:label """The speaker (seemingly Chingonyi) didn’t take part in this initiation so would be considered "unfinished" by his tribe."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643364Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2349-4
  a curric:KeyLearningPoint ;
  rdfs:label """The speaker reflects on how he grew up in other ways, particularly caring for his dying mother."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643369Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2349-5
  a curric:KeyLearningPoint ;
  rdfs:label """Stanza three sees the speaker think about feelings of connection and disconnection to his Zambian roots and ancestors."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643373Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2552-1
  a curric:KeyLearningPoint ;
  rdfs:label """The repeated imagery of the "sea" implies that the Island Man feels a sense of freedom and peace in his dreams."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643378Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2552-2
  a curric:KeyLearningPoint ;
  rdfs:label """The use of free verse could reflect the freedom the Island Man feels when connected to the Caribbean."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643383Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2552-3
  a curric:KeyLearningPoint ;
  rdfs:label """The use of free verse could also suggest that the Island Man feels out of place in London."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643390Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2552-4
  a curric:KeyLearningPoint ;
  rdfs:label """The repetition could connect a sense of monotony and unhappiness to the Island Man's life in London."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643395Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2552-5
  a curric:KeyLearningPoint ;
  rdfs:label "The lack of punctuation could also show a lack of emotion and sense of monotony."@en ;
  dcterms:modified "2026-02-12T08:59:21.643402Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2367-1
  a curric:KeyLearningPoint ;
  rdfs:label "A thesis statement is a clear, overarching argument."@en ;
  dcterms:modified "2026-02-12T08:59:21.643745Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2367-2
  a curric:KeyLearningPoint ;
  rdfs:label "Topic sentences give focus to individual paragraphs."@en ;
  dcterms:modified "2026-02-12T08:59:21.643750Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2367-3
  a curric:KeyLearningPoint ;
  rdfs:label "Select main quotations and supporting quotations to include in an essay."@en ;
  dcterms:modified "2026-02-12T08:59:21.643755Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2367-4
  a curric:KeyLearningPoint ;
  rdfs:label """Main quotations should be analysed; supporting quotations don’t need to be analysed."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643762Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2367-5
  a curric:KeyLearningPoint ;
  rdfs:label """Concluding sentences can focus on a writer’s intention and draw your paragraph to a close."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643767Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2536-1
  a curric:KeyLearningPoint ;
  rdfs:label """The use of natural imagery could represent the simplicity of nature and the contentment found within it."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643772Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2536-2
  a curric:KeyLearningPoint ;
  rdfs:label """Clare’s use of the sonnet form could represent the Romantic feelings about nature."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643777Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2536-3
  a curric:KeyLearningPoint ;
  rdfs:label """Clare’s use of heroic couplets could further enhance the sense of connection between humanity and nature."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643781Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2536-4
  a curric:KeyLearningPoint ;
  rdfs:label """Clare’s use of a regular pattern to the structure could represent the peace and contentment found in nature."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643786Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2353-1
  a curric:KeyLearningPoint ;
  rdfs:label """Dharker's use of direct address creates an intimate tone, one where we are hearing Dharker's inner most thoughts."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643815Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2353-2
  a curric:KeyLearningPoint ;
  rdfs:label """Dharker's use of questions encourages the reader to reflect on their own sense of belonging."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643820Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2353-3
  a curric:KeyLearningPoint ;
  rdfs:label """Dharker uses people or places that seem exotic and exciting, in contrast to the places where she grew up."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643824Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2353-4
  a curric:KeyLearningPoint ;
  rdfs:label """Dharker uses archetypal descriptions to encourage readers to relate to the speaker’s yearning to live a different life."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643829Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2353-5
  a curric:KeyLearningPoint ;
  rdfs:label """Dharker’s speaker assumes that all teenagers dream of living somewhere ‘more exciting'."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643834Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28791-1
  a curric:KeyLearningPoint ;
  rdfs:label """A thesis statement is an overarching argument and should refer to the writer’s intent."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643839Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28791-2
  a curric:KeyLearningPoint ;
  rdfs:label """The thesis statement is also an opportunity to show how your argument relates to the ‘bigger picture’."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643843Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28791-3
  a curric:KeyLearningPoint ;
  rdfs:label "A topic sentence explains the main focus of your paragraph."@en ;
  dcterms:modified "2026-02-12T08:59:21.643850Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28791-4
  a curric:KeyLearningPoint ;
  rdfs:label """An effective analytical essay includes topic sentences, supporting detail, and concluding sentences."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643855Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28791-5
  a curric:KeyLearningPoint ;
  rdfs:label """Priestley uses Mr. and Mrs. Birling to represent the older generation and their attitudes towards social responsibility."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643860Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2446-1
  a curric:KeyLearningPoint ;
  rdfs:label """Both poets use language to display a reverence for nature and attribute omniscience to it."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643865Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2446-2
  a curric:KeyLearningPoint ;
  rdfs:label """However, Brontë is more explicit in the suggestion that nature is specifically trying to soothe and comfort the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643870Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2446-3
  a curric:KeyLearningPoint ;
  rdfs:label "Both poets personify nature; however, Brontë gives nature a voice."@en ;
  dcterms:modified "2026-02-12T08:59:21.643875Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2446-4
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, both poets are critiquing the societal shift brought about by the Industrial Revolution."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643879Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2446-5
  a curric:KeyLearningPoint ;
  rdfs:label "Both poets display Romantic characteristics in their writing."@en ;
  dcterms:modified "2026-02-12T08:59:21.643886Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6263-1
  a curric:KeyLearningPoint ;
  rdfs:label """A comparative introduction should use correlatives and comparatives in order to create links between ideas."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644045Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6263-2
  a curric:KeyLearningPoint ;
  rdfs:label """A comparative introduction might offer smaller variations in a wider similarity between poems."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644055Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6263-3
  a curric:KeyLearningPoint ;
  rdfs:label "A comparative introduction might offer nuanced differences between poems."@en ;
  dcterms:modified "2026-02-12T08:59:21.644060Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6263-4
  a curric:KeyLearningPoint ;
  rdfs:label """You should try to develop your ideas by using discourse markers and extending your analysis."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644065Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6263-5
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of your analytical writing is to convince the reader of your argument."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644070Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1689-1
  a curric:KeyLearningPoint ;
  rdfs:label "The poem depicts a Duke showing an envoy a painting of his late wife."@en ;
  dcterms:modified "2026-02-12T08:59:21.644074Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1689-2
  a curric:KeyLearningPoint ;
  rdfs:label """The poem was written during the Victorian period, marked for its strict morality and patriarchal society."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644080Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1689-3
  a curric:KeyLearningPoint ;
  rdfs:label """Browning uses the poem as an attack on the biased, overbearing views of Victorian society and archaic hierarchy."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644084Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1689-4
  a curric:KeyLearningPoint ;
  rdfs:label """Browning sets the poem in the Italian Renaissance, perhaps to disguise his social criticism of Victorian society."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644089Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2424-1
  a curric:KeyLearningPoint ;
  rdfs:label """The title 'The Jewellery Maker' conveys an importance onto the maker that could be considered ironic."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644094Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2424-2
  a curric:KeyLearningPoint ;
  rdfs:label "The natural imagery in the poem creates a god-like impression of the maker."@en ;
  dcterms:modified "2026-02-12T08:59:21.644099Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2424-3
  a curric:KeyLearningPoint ;
  rdfs:label "The figurative language in the poem creates a tense tone in the poem."@en ;
  dcterms:modified "2026-02-12T08:59:21.644103Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2424-4
  a curric:KeyLearningPoint ;
  rdfs:label """The heat imagery in the poem could represent both the warmth and anger of the maker."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644108Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2424-5
  a curric:KeyLearningPoint ;
  rdfs:label """The irregularity of the poem could refer to the creativity of the maker or his conflicting emotions around his work."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644113Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2478-1
  a curric:KeyLearningPoint ;
  rdfs:label "Byron reminisces on a past, illicit love affair."@en ;
  dcterms:modified "2026-02-12T08:59:21.644117Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2478-2
  a curric:KeyLearningPoint ;
  rdfs:label "Byron was a celebrated Georgian poet who found fame almost overnight."@en ;
  dcterms:modified "2026-02-12T08:59:21.644122Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2478-3
  a curric:KeyLearningPoint ;
  rdfs:label """Despite the relationship breaking down years ago, Byron still feels mournful and bitter."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644130Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2478-4
  a curric:KeyLearningPoint ;
  rdfs:label """The fact that the affair and therefore the breakup were secretive adds to Byron's anguish."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644164Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2478-5
  a curric:KeyLearningPoint ;
  rdfs:label """The poem is autobiographical, regarding Byron's affair with the married Lady Frances Webster."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644170Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2008-1
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, the pigs taking the milk and apples is the turning point of the novella."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644175Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2008-2
  a curric:KeyLearningPoint ;
  rdfs:label "The fable form is used to illustrate there are (many) morals to this story."@en ;
  dcterms:modified "2026-02-12T08:59:21.644180Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2008-3
  a curric:KeyLearningPoint ;
  rdfs:label "Orwell uses the simplistic form of a fable to help put forward his messages."@en ;
  dcterms:modified "2026-02-12T08:59:21.644184Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2008-4
  a curric:KeyLearningPoint ;
  rdfs:label "The main motifs are food and the military."@en ;
  dcterms:modified "2026-02-12T08:59:21.644189Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2004-1
  a curric:KeyLearningPoint ;
  rdfs:label "Arguably, Mr. Jones is a more sympathetic character than Napoleon."@en ;
  dcterms:modified "2026-02-12T08:59:21.644194Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2004-2
  a curric:KeyLearningPoint ;
  rdfs:label """Through the pigs’ behaviour, the spirit of Mr. Jones is always present on the farm."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644199Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2004-3
  a curric:KeyLearningPoint ;
  rdfs:label "Napoleon uses rations of food to differentiate himself from Mr. Jones."@en ;
  dcterms:modified "2026-02-12T08:59:21.644203Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2004-4
  a curric:KeyLearningPoint ;
  rdfs:label "Orwell offers a nuanced perspective on leadership and power."@en ;
  dcterms:modified "2026-02-12T08:59:21.644208Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2522-1
  a curric:KeyLearningPoint ;
  rdfs:label """The poem is based on a biblical depiction of how King Sennacherib and the Assyrian army attempted to invade Jerusalem."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644232Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2522-2
  a curric:KeyLearningPoint ;
  rdfs:label "The Assyrian king was defeated by a divine intervention from God."@en ;
  dcterms:modified "2026-02-12T08:59:21.644237Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2522-3
  a curric:KeyLearningPoint ;
  rdfs:label "War was a significant concern in Europe at the time Lord Byron wrote the poem."@en ;
  dcterms:modified "2026-02-12T08:59:21.644244Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2522-4
  a curric:KeyLearningPoint ;
  rdfs:label """Poems which saw God intervene to help the 'good' forces during war were popular during this era."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644252Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9244-1
  a curric:KeyLearningPoint ;
  rdfs:label """Larkin presents the young couples as having lost their youthfulness as a result of having children."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644280Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9244-2
  a curric:KeyLearningPoint ;
  rdfs:label """Larkin arguably presents the responsibility of having a child as burdensome in the poem."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644285Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9244-3
  a curric:KeyLearningPoint ;
  rdfs:label """The title could reflect that these couples are in the 'afternoon' of their lives, creating a pitiful tone."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644290Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9244-4
  a curric:KeyLearningPoint ;
  rdfs:label """Larkin uses contrasting tones in the first stanza, perhaps to reflect the expectation vs the reality of having a child."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644296Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9244-5
  a curric:KeyLearningPoint ;
  rdfs:label """Larkin’s ominous and, at times, foreboding tone could represent time creeping up on the young couples."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644304Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9221-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘Sonnet 43’ is one of Barrett Browning’s 44 sonnets that she wrote for her (then) future husband - Robert Browning."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644332Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9221-2
  a curric:KeyLearningPoint ;
  rdfs:label "The poem follows the conventions of a Petrarchan sonnet."@en ;
  dcterms:modified "2026-02-12T08:59:21.644337Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9221-3
  a curric:KeyLearningPoint ;
  rdfs:label """The poem explores the transcendental and bountiful love the poet and her future husband share."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644344Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9221-4
  a curric:KeyLearningPoint ;
  rdfs:label """Barrett Browning eloped with Robert Browning, and was disinherited by her father."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644349Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9221-5
  a curric:KeyLearningPoint ;
  rdfs:label """Barrett Browning struggled with chronic illness, which may explain why the poem has spiritual/religious undertones."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644353Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29080-1
  a curric:KeyLearningPoint ;
  rdfs:label """When writing an essay you should aim to write in a formal style as it can help to elevate your ideas."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644382Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29080-2
  a curric:KeyLearningPoint ;
  rdfs:label "Your essay should have a clear line of argument and be well structured."@en ;
  dcterms:modified "2026-02-12T08:59:21.644386Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29080-3
  a curric:KeyLearningPoint ;
  rdfs:label """An effective introduction will be focused, offer a clear thesis and link to main ideas in the question."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644391Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29080-4
  a curric:KeyLearningPoint ;
  rdfs:label """A strong comparative paragraph will clearly compare two poems using precise vocabulary and discourse markers."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644396Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29080-5
  a curric:KeyLearningPoint ;
  rdfs:label """A strong response will embed quotations smoothly and analyse language and structure, explaining their effects clearly."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644403Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29037-1
  a curric:KeyLearningPoint ;
  rdfs:label "Priestley explores both legal and moral crimes."@en ;
  dcterms:modified "2026-02-12T08:59:21.644933Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29037-2
  a curric:KeyLearningPoint ;
  rdfs:label """Characters face moral reckoning, not legal consequences, highlighting self-awareness as punishment."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644938Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29037-3
  a curric:KeyLearningPoint ;
  rdfs:label """Eric’s character could suggest that moral accountability is more important than legal punishment for Priestley."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644946Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29037-4
  a curric:KeyLearningPoint ;
  rdfs:label "The play reveals how class affects perceptions of crime."@en ;
  dcterms:modified "2026-02-12T08:59:21.644950Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29037-5
  a curric:KeyLearningPoint ;
  rdfs:label """Priestley critiques the legal system and advocates for social justice over legal frameworks."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644957Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2022-1
  a curric:KeyLearningPoint ;
  rdfs:label """Windows and doors are  motifs in ‘Jekyll and Hyde’, linking to themes of liminality, duality and secrecy."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644963Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2022-2
  a curric:KeyLearningPoint ;
  rdfs:label """The door used by Hyde is “blistered” which suggests the degradation and corruption that character represents."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644968Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2022-3
  a curric:KeyLearningPoint ;
  rdfs:label """The door to Jekyll’s home is opened by a well dressed servant in keeping with his role as a proper Victorian gentleman."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644972Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2022-4
  a curric:KeyLearningPoint ;
  rdfs:label """Windows provide an ambiguous motif in that they look transparent, but they can be made into a barrier."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644977Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2022-5
  a curric:KeyLearningPoint ;
  rdfs:label """The door to Jekyll’s room has to be forced open showing how hard it is to arrive at the  truth."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644982Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2102-1
  a curric:KeyLearningPoint ;
  rdfs:label "A dramatic account is likely to be full of emotion, danger and conflict."@en ;
  dcterms:modified "2026-02-12T08:59:21.644989Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2102-2
  a curric:KeyLearningPoint ;
  rdfs:label "We expect an account of an event to be fact based and significant."@en ;
  dcterms:modified "2026-02-12T08:59:21.644994Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2102-3
  a curric:KeyLearningPoint ;
  rdfs:label """When talking about our response to a text, it is important to reference details and explain how it affected us."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644999Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2102-4
  a curric:KeyLearningPoint ;
  rdfs:label "Analysing language means looking at what it suggests."@en ;
  dcterms:modified "2026-02-12T08:59:21.645004Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2102-5
  a curric:KeyLearningPoint ;
  rdfs:label "We an also link the writer’s choices to the wider themes and ideas."@en ;
  dcterms:modified "2026-02-12T08:59:21.645009Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2344-1
  a curric:KeyLearningPoint ;
  rdfs:label """The role of 'mother' and the role of 'lover' both create conflict in a patriarchal society."""@en ;
  dcterms:modified "2026-02-12T08:59:21.645013Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2344-2
  a curric:KeyLearningPoint ;
  rdfs:label """Society's expectations of women have changed over time as people have become more progressive."""@en ;
  dcterms:modified "2026-02-12T08:59:21.645018Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2344-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Cousin Kate' is useful for comparing conflicts thrust on women due to society's expectations of them."""@en ;
  dcterms:modified "2026-02-12T08:59:21.645023Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2344-4
  a curric:KeyLearningPoint ;
  rdfs:label """'Catrin' is useful for exploring the complexities of the mother-child relationship."""@en ;
  dcterms:modified "2026-02-12T08:59:21.645028Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2344-5
  a curric:KeyLearningPoint ;
  rdfs:label """'Poppies' arguably presents a more traditional depiction of motherhood whereas 'Catrin' challenges this view."""@en ;
  dcterms:modified "2026-02-12T08:59:21.645032Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2554-1
  a curric:KeyLearningPoint ;
  rdfs:label """The repetition of “Jamaican British” could suggest the speaker having to constantly define themselves."""@en ;
  dcterms:modified "2026-02-12T08:59:21.645037Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2554-2
  a curric:KeyLearningPoint ;
  rdfs:label """The use of “half”in the poem could mean that they don’t feel as if they fully belong somewhere."""@en ;
  dcterms:modified "2026-02-12T08:59:21.645041Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2554-3
  a curric:KeyLearningPoint ;
  rdfs:label """The use of shifting pronouns in the poem could reinforce the idea of feeling out of place."""@en ;
  dcterms:modified "2026-02-12T08:59:21.645046Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2554-4
  a curric:KeyLearningPoint ;
  rdfs:label "However, there are also moments of acceptance within the poem."@en ;
  dcterms:modified "2026-02-12T08:59:21.645053Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2554-5
  a curric:KeyLearningPoint ;
  rdfs:label """The final phrase “Jamaican British” could signal that the speaker has accepted their dual heritage and identity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.645058Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2546-1
  a curric:KeyLearningPoint ;
  rdfs:label """Hood's poetry reflects some Romantic ideals - nature and the innocence of childhood."""@en ;
  dcterms:modified "2026-02-12T08:59:21.645063Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2546-2
  a curric:KeyLearningPoint ;
  rdfs:label "Hood's poetry also reflects the more realist ideas of Victorian poetry."@en ;
  dcterms:modified "2026-02-12T08:59:21.645068Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2546-3
  a curric:KeyLearningPoint ;
  rdfs:label """Hood's adult life was plagued with illness, perhaps why he is so wistful for his childhood."""@en ;
  dcterms:modified "2026-02-12T08:59:21.645073Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2546-4
  a curric:KeyLearningPoint ;
  rdfs:label "Hood's poem is nostalgic, remembering his happy times as a child."@en ;
  dcterms:modified "2026-02-12T08:59:21.645079Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2546-5
  a curric:KeyLearningPoint ;
  rdfs:label """There is also a mournful tone to Hood's poetry; he is melancholic that he will not feel that joy again."""@en ;
  dcterms:modified "2026-02-12T08:59:21.645087Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2065-1
  a curric:KeyLearningPoint ;
  rdfs:label "Banquo acts a foil to Macbeth because his loyalty outweighs his ambition."@en ;
  dcterms:modified "2026-02-12T08:59:21.645092Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2065-2
  a curric:KeyLearningPoint ;
  rdfs:label "Banquo's son, Fleance, acts as a stark reminder of Macbeth's own lack of heir."@en ;
  dcterms:modified "2026-02-12T08:59:21.645097Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2065-3
  a curric:KeyLearningPoint ;
  rdfs:label "King James I was believed to be a direct ancestor of the real Banquo."@en ;
  dcterms:modified "2026-02-12T08:59:21.645101Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2065-4
  a curric:KeyLearningPoint ;
  rdfs:label """Shakespeare uses Macbeth's relationship with Banquo to warn against disobeying the natural order."""@en ;
  dcterms:modified "2026-02-12T08:59:21.645106Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2065-5
  a curric:KeyLearningPoint ;
  rdfs:label "Fleance's survival can be viewed as a reward for Banquo's loyalty."@en ;
  dcterms:modified "2026-02-12T08:59:21.645111Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1652-1
  a curric:KeyLearningPoint ;
  rdfs:label "Topic sentences need to be clear and linked to the question"@en ;
  dcterms:modified "2026-02-12T08:59:21.645116Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1652-2
  a curric:KeyLearningPoint ;
  rdfs:label "Judicious quotations from the text are used to create compelling arguments"@en ;
  dcterms:modified "2026-02-12T08:59:21.645120Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1652-3
  a curric:KeyLearningPoint ;
  rdfs:label """Writer’s methods should be explored without always relying on single word analysis"""@en ;
  dcterms:modified "2026-02-12T08:59:21.645125Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1652-4
  a curric:KeyLearningPoint ;
  rdfs:label "Context can be used to develop arguments"@en ;
  dcterms:modified "2026-02-12T08:59:21.645130Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29034-1
  a curric:KeyLearningPoint ;
  rdfs:label """The Inspector’s supernatural traits suggest he operates beyond conventional reality, elevating his role."""@en ;
  dcterms:modified "2026-02-12T08:59:21.645135Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29034-2
  a curric:KeyLearningPoint ;
  rdfs:label """His eerie knowledge and prophetic understanding hint at an otherworldly presence creating tension and unease."""@en ;
  dcterms:modified "2026-02-12T08:59:21.645140Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29034-3
  a curric:KeyLearningPoint ;
  rdfs:label """The Inspector's mysterious arrival and departure imply a figure beyond human law enforcement."""@en ;
  dcterms:modified "2026-02-12T08:59:21.645145Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29034-4
  a curric:KeyLearningPoint ;
  rdfs:label """His true identity remains unclear, leading the audience to question his divine or ghostly nature."""@en ;
  dcterms:modified "2026-02-12T08:59:21.645149Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29034-5
  a curric:KeyLearningPoint ;
  rdfs:label """Priestley uses the supernatural to elevate the moral and social themes including crime, punishment and justice."""@en ;
  dcterms:modified "2026-02-12T08:59:21.645154Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1655-1
  a curric:KeyLearningPoint ;
  rdfs:label "Hyde first appears to Utterson in a dream, linking to the supernatural"@en ;
  dcterms:modified "2026-02-12T08:59:21.645159Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1655-2
  a curric:KeyLearningPoint ;
  rdfs:label "Hyde is consistently dehumanised in the description"@en ;
  dcterms:modified "2026-02-12T08:59:21.645163Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1655-3
  a curric:KeyLearningPoint ;
  rdfs:label """When he imagines Hyde, London itself becomes unfamiliar and disorientating to Utterson"""@en ;
  dcterms:modified "2026-02-12T08:59:21.645171Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1655-4
  a curric:KeyLearningPoint ;
  rdfs:label "Utterson is disgusted by Hyde, but also deeply curious about him"@en ;
  dcterms:modified "2026-02-12T08:59:21.645176Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1655-5
  a curric:KeyLearningPoint ;
  rdfs:label """The oxymoron 'human juggernaut' suggests that Hyde is human, yet also has supernatural powers"""@en ;
  dcterms:modified "2026-02-12T08:59:21.645180Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2385-1
  a curric:KeyLearningPoint ;
  rdfs:label "Looking for patterns within the language makes analysis more perceptive."@en ;
  dcterms:modified "2026-02-12T08:59:21.645185Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2385-2
  a curric:KeyLearningPoint ;
  rdfs:label "Having an awareness of the text as a whole enables a more detailed analysis."@en ;
  dcterms:modified "2026-02-12T08:59:21.645190Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2385-3
  a curric:KeyLearningPoint ;
  rdfs:label """Analytical paragraphs must begin with a point that focuses on the writer's intention, rather than a single feature."""@en ;
  dcterms:modified "2026-02-12T08:59:21.645195Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2385-4
  a curric:KeyLearningPoint ;
  rdfs:label "Offering alternative or additional interpretations can develop an analysis."@en ;
  dcterms:modified "2026-02-12T08:59:21.645199Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2135-1
  a curric:KeyLearningPoint ;
  rdfs:label "Narratives that try to tell too much story are often unsuccessful"@en ;
  dcterms:modified "2026-02-12T08:59:21.645204Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2135-2
  a curric:KeyLearningPoint ;
  rdfs:label """Using an emotion-led narrative will help keep your plot manageable so you don't try and say too much"""@en ;
  dcterms:modified "2026-02-12T08:59:21.645209Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2135-3
  a curric:KeyLearningPoint ;
  rdfs:label "Single paragraph outlines can be used to plan each section of your narrative"@en ;
  dcterms:modified "2026-02-12T08:59:21.645216Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2135-4
  a curric:KeyLearningPoint ;
  rdfs:label """Figurative language can be used to make the descriptions within your narrative more vivid"""@en ;
  dcterms:modified "2026-02-12T08:59:21.645221Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2070-1
  a curric:KeyLearningPoint ;
  rdfs:label "An evaluative thesis should be used to centre your argument."@en ;
  dcterms:modified "2026-02-12T08:59:21.645326Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2070-2
  a curric:KeyLearningPoint ;
  rdfs:label "Topic sentences should be used to support your thesis."@en ;
  dcterms:modified "2026-02-12T08:59:21.645331Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2070-3
  a curric:KeyLearningPoint ;
  rdfs:label """Word classes, semantic fields or language device analysis are required to analyse Shakespeare’s purpose, in detail."""@en ;
  dcterms:modified "2026-02-12T08:59:21.645338Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2070-4
  a curric:KeyLearningPoint ;
  rdfs:label "Context should be interwoven and selected to support your argument."@en ;
  dcterms:modified "2026-02-12T08:59:21.645343Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2070-5
  a curric:KeyLearningPoint ;
  rdfs:label "Conclusions should have a razor sharp focus on the writer's message."@en ;
  dcterms:modified "2026-02-12T08:59:21.645348Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2309-1
  a curric:KeyLearningPoint ;
  rdfs:label "Topic sentences should link to the question."@en ;
  dcterms:modified "2026-02-12T08:59:21.645355Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2309-2
  a curric:KeyLearningPoint ;
  rdfs:label """References to the text should link to your topic sentence, come from across the play, and be rich in methods."""@en ;
  dcterms:modified "2026-02-12T08:59:21.645389Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2309-3
  a curric:KeyLearningPoint ;
  rdfs:label """Writer’s methods should be explored without always relying on single word analysis."""@en ;
  dcterms:modified "2026-02-12T08:59:21.645395Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2309-4
  a curric:KeyLearningPoint ;
  rdfs:label "Context should be woven into analysis, not bolted on to the end of a paragraph."@en ;
  dcterms:modified "2026-02-12T08:59:21.645400Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1674-1
  a curric:KeyLearningPoint ;
  rdfs:label """Stevenson uses conventions of epistolary fiction to foreground the importance of letters and documents."""@en ;
  dcterms:modified "2026-02-12T08:59:21.645405Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1674-2
  a curric:KeyLearningPoint ;
  rdfs:label """Letters provide clues as part of the detective plot, but also link to the theme of concealment."""@en ;
  dcterms:modified "2026-02-12T08:59:21.645414Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1674-3
  a curric:KeyLearningPoint ;
  rdfs:label """The secrecy created by the epistolary form could represent the upper classes attempts to conceal unsavoury behaviour."""@en ;
  dcterms:modified "2026-02-12T08:59:21.645420Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1674-4
  a curric:KeyLearningPoint ;
  rdfs:label """The majority of the novella is told in the third person limited, focalised through Utterson."""@en ;
  dcterms:modified "2026-02-12T08:59:21.645425Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1674-5
  a curric:KeyLearningPoint ;
  rdfs:label """A sense of mistrust is created through unreliable narrators and a non-linear narrative."""@en ;
  dcterms:modified "2026-02-12T08:59:21.645429Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2456-1
  a curric:KeyLearningPoint ;
  rdfs:label """Belle ended her relationship with Scrooge because she recognised that he valued money over human connection"""@en ;
  dcterms:modified "2026-02-12T08:59:21.645434Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2456-2
  a curric:KeyLearningPoint ;
  rdfs:label """Dickens presents greed as corruptive, suggesting that it spreads misery and unhappiness"""@en ;
  dcterms:modified "2026-02-12T08:59:21.645439Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2456-3
  a curric:KeyLearningPoint ;
  rdfs:label """The breakdown of the engagement is the point at which Scrooge turns his back on society entirely"""@en ;
  dcterms:modified "2026-02-12T08:59:21.645444Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2456-4
  a curric:KeyLearningPoint ;
  rdfs:label """Through Belle, we see Scrooge’s capacity for love and hope that he might find it within himself to love again"""@en ;
  dcterms:modified "2026-02-12T08:59:21.645449Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2456-5
  a curric:KeyLearningPoint ;
  rdfs:label """Dickens presents Belle as a content mother and wife to illustrate that money is not what brings happiness"""@en ;
  dcterms:modified "2026-02-12T08:59:21.645454Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1483-1
  a curric:KeyLearningPoint ;
  rdfs:label "A writer’s attitude is how they feel about a subject."@en ;
  dcterms:modified "2026-02-12T08:59:21.645459Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1483-2
  a curric:KeyLearningPoint ;
  rdfs:label """We might identify and analyse their attitude by considering connotations of words and semantic fields."""@en ;
  dcterms:modified "2026-02-12T08:59:21.645464Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1483-3
  a curric:KeyLearningPoint ;
  rdfs:label """A writer’s attitude is important because it helps us to understand what their intentions were."""@en ;
  dcterms:modified "2026-02-12T08:59:21.645468Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1483-4
  a curric:KeyLearningPoint ;
  rdfs:label """A writer’s attitude can also influence the perception of the reader and how they see the writer and subject."""@en ;
  dcterms:modified "2026-02-12T08:59:21.645473Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1461-1
  a curric:KeyLearningPoint ;
  rdfs:label "A summary captures the main ideas of a text in a short and clear format."@en ;
  dcterms:modified "2026-02-12T08:59:21.645480Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1461-2
  a curric:KeyLearningPoint ;
  rdfs:label "When writing a summary of a text, it can be helpful to include short quotations."@en ;
  dcterms:modified "2026-02-12T08:59:21.645485Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1461-3
  a curric:KeyLearningPoint ;
  rdfs:label "You can develop your summary by including inferences."@en ;
  dcterms:modified "2026-02-12T08:59:21.645490Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1461-4
  a curric:KeyLearningPoint ;
  rdfs:label "Inferences explore a text’s suggested ideas."@en ;
  dcterms:modified "2026-02-12T08:59:21.645495Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1461-5
  a curric:KeyLearningPoint ;
  rdfs:label "Inferences should not include analysis of language or structure."@en ;
  dcterms:modified "2026-02-12T08:59:21.645500Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2436-1
  a curric:KeyLearningPoint ;
  rdfs:label """The speaker anthropomorphises the pot which creates an emotional connection to the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.645505Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2436-2
  a curric:KeyLearningPoint ;
  rdfs:label """The poem arguably metaphorically considers the fears around identity of those with a migrant heritage."""@en ;
  dcterms:modified "2026-02-12T08:59:21.645510Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2436-3
  a curric:KeyLearningPoint ;
  rdfs:label """The irregular, fragmented structure of the poem could link to the pot’s feelings of displacement."""@en ;
  dcterms:modified "2026-02-12T08:59:21.645515Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2436-4
  a curric:KeyLearningPoint ;
  rdfs:label """khan arguably links the poem to colonial narratives of ignoring indigenous stories."""@en ;
  dcterms:modified "2026-02-12T08:59:21.645519Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2484-1
  a curric:KeyLearningPoint ;
  rdfs:label """Romantic literature often deals with powerful, spiritual ideas and dramatic themes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.645524Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2484-2
  a curric:KeyLearningPoint ;
  rdfs:label """Shelley was a Romantic poet who was known for his controversial views about societal issues."""@en ;
  dcterms:modified "2026-02-12T08:59:21.645529Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2484-3
  a curric:KeyLearningPoint ;
  rdfs:label """‘Love’s Philosophy’ focuses on the links between love, nature and the connectedness of all things in the natural world."""@en ;
  dcterms:modified "2026-02-12T08:59:21.645533Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2484-4
  a curric:KeyLearningPoint ;
  rdfs:label """The poem could be read as a passionate argument of the power of love and the importance of human connectedness."""@en ;
  dcterms:modified "2026-02-12T08:59:21.645538Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2484-5
  a curric:KeyLearningPoint ;
  rdfs:label """The poem could also be read as the speaker’s expression of their overwhelming desire for another."""@en ;
  dcterms:modified "2026-02-12T08:59:21.645543Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2395-1
  a curric:KeyLearningPoint ;
  rdfs:label """Reading from a script, or memorising a speech word for word, can lead to a less engaging delivery."""@en ;
  dcterms:modified "2026-02-12T08:59:21.645548Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2395-2
  a curric:KeyLearningPoint ;
  rdfs:label """If you take questions at the end, you should respond with new content rather than repeating parts of the speech."""@en ;
  dcterms:modified "2026-02-12T08:59:21.645553Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2395-3
  a curric:KeyLearningPoint ;
  rdfs:label "Asking open questions can invite developed responses."@en ;
  dcterms:modified "2026-02-12T08:59:21.645558Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2395-4
  a curric:KeyLearningPoint ;
  rdfs:label "Body language and eye contact support the successful delivery of a speech."@en ;
  dcterms:modified "2026-02-12T08:59:21.645562Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2395-5
  a curric:KeyLearningPoint ;
  rdfs:label "It's okay to feel nervous, find the strategies that work for you."@en ;
  dcterms:modified "2026-02-12T08:59:21.645569Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2078-1
  a curric:KeyLearningPoint ;
  rdfs:label "An opinion is a view or judgement formed on something, not based on fact."@en ;
  dcterms:modified "2026-02-12T08:59:21.645577Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2078-2
  a curric:KeyLearningPoint ;
  rdfs:label "In order to add credibility to our opinions, we must be able to justify them."@en ;
  dcterms:modified "2026-02-12T08:59:21.645582Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2078-3
  a curric:KeyLearningPoint ;
  rdfs:label """Themes like the 'American Dream' and wealth are central to understanding 'The Great Gatsby'."""@en ;
  dcterms:modified "2026-02-12T08:59:21.645587Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2078-4
  a curric:KeyLearningPoint ;
  rdfs:label """Using textual evidence supports interpretations and inferences about characters in a text."""@en ;
  dcterms:modified "2026-02-12T08:59:21.645591Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2110-1
  a curric:KeyLearningPoint ;
  rdfs:label "Register and tone are important parts of establishing voice in a narrative."@en ;
  dcterms:modified "2026-02-12T08:59:21.645596Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2110-2
  a curric:KeyLearningPoint ;
  rdfs:label "Register is the formality of language whilst tone is the mood of a text."@en ;
  dcterms:modified "2026-02-12T08:59:21.645601Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2110-3
  a curric:KeyLearningPoint ;
  rdfs:label """'The Lovely Bones' has a unique perspective, tone and register, making the narrative voice engaging."""@en ;
  dcterms:modified "2026-02-12T08:59:21.645606Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2110-4
  a curric:KeyLearningPoint ;
  rdfs:label """Unique perspectives might include writing from the perspective of an inanimate object, an animal or an abstract idea."""@en ;
  dcterms:modified "2026-02-12T08:59:21.645610Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2110-5
  a curric:KeyLearningPoint ;
  rdfs:label """We can adapt our perspective, register and tone to create unique voices in our own creative writing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.645615Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6233-1
  a curric:KeyLearningPoint ;
  rdfs:label """You can utilise elements from a traditional story arc to help you create an interesting narrative opening."""@en ;
  dcterms:modified "2026-02-12T08:59:21.645620Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6233-2
  a curric:KeyLearningPoint ;
  rdfs:label "A mundane setting offers an opportunity for an interesting shift in tone."@en ;
  dcterms:modified "2026-02-12T08:59:21.645624Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6233-3
  a curric:KeyLearningPoint ;
  rdfs:label """Shifting from a wider setting to a close focus on a specific thing or person demonstrates control of focus."""@en ;
  dcterms:modified "2026-02-12T08:59:21.645631Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6233-4
  a curric:KeyLearningPoint ;
  rdfs:label """Saramago crafts a shift in tone with the conjunction 'but', a list and the manipulation of sentence length."""@en ;
  dcterms:modified "2026-02-12T08:59:21.645638Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6233-5
  a curric:KeyLearningPoint ;
  rdfs:label """You can build suspense in a narrative by making the reader wait longer for a climax."""@en ;
  dcterms:modified "2026-02-12T08:59:21.645644Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2043-1
  a curric:KeyLearningPoint ;
  rdfs:label """When selecting judicious quotations, you might ask which are the most evocative to you."""@en ;
  dcterms:modified "2026-02-12T08:59:21.645648Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2043-2
  a curric:KeyLearningPoint ;
  rdfs:label "You also might ask which quotations create a sense of tone and mood."@en ;
  dcterms:modified "2026-02-12T08:59:21.645653Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2043-3
  a curric:KeyLearningPoint ;
  rdfs:label "When using quotations, you might ask which word(s) you'd zoom in on."@en ;
  dcterms:modified "2026-02-12T08:59:21.645658Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2043-4
  a curric:KeyLearningPoint ;
  rdfs:label "You then might explore the connotations of those word(s) and make inferences."@en ;
  dcterms:modified "2026-02-12T08:59:21.645666Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2111-1
  a curric:KeyLearningPoint ;
  rdfs:label """A first person narrator can often give the reader a unique insight into their personality, relationships and lifestyle."""@en ;
  dcterms:modified "2026-02-12T08:59:21.645671Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2111-2
  a curric:KeyLearningPoint ;
  rdfs:label "The narrator in 'The Yellow Wallpaper' is presented as silenced and powerless."@en ;
  dcterms:modified "2026-02-12T08:59:21.645676Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2111-3
  a curric:KeyLearningPoint ;
  rdfs:label "The narrator exposes her husband as oppressive."@en ;
  dcterms:modified "2026-02-12T08:59:21.645680Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2111-4
  a curric:KeyLearningPoint ;
  rdfs:label "Perkins Gilman employs many techniques to show the narrator's lack of agency."@en ;
  dcterms:modified "2026-02-12T08:59:21.645685Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2111-5
  a curric:KeyLearningPoint ;
  rdfs:label """It could be argued that that narrator has agency since everything we learn is filtered through her consciousness."""@en ;
  dcterms:modified "2026-02-12T08:59:21.645690Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2363-1
  a curric:KeyLearningPoint ;
  rdfs:label "‘Leave Taking’ is dedicated to Pinnock’s mother."@en ;
  dcterms:modified "2026-02-12T08:59:21.645695Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2363-2
  a curric:KeyLearningPoint ;
  rdfs:label "‘Leave Taking’ starts with two epigraphs from two feminist critics."@en ;
  dcterms:modified "2026-02-12T08:59:21.645699Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2363-3
  a curric:KeyLearningPoint ;
  rdfs:label "Enid, Mai, Mooma and Del are all presented as strong matriarchs."@en ;
  dcterms:modified "2026-02-12T08:59:21.645704Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2363-4
  a curric:KeyLearningPoint ;
  rdfs:label """Enid, Mai, Mooma and Del’s experiences could reflect the expectations of strength placed on Caribbean matriarchs."""@en ;
  dcterms:modified "2026-02-12T08:59:21.645709Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2363-5
  a curric:KeyLearningPoint ;
  rdfs:label """‘Leave Taking’ could be interpreted as social commentary on the experiences of women."""@en ;
  dcterms:modified "2026-02-12T08:59:21.645713Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1489-1
  a curric:KeyLearningPoint ;
  rdfs:label """Rhetorical questions engage the reader by encouraging them to consider their own opinions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.645718Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1489-2
  a curric:KeyLearningPoint ;
  rdfs:label "They are structured in the same way as a normal question."@en ;
  dcterms:modified "2026-02-12T08:59:21.645723Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1489-3
  a curric:KeyLearningPoint ;
  rdfs:label """They can be answered by the writer or left unanswered - both create different effects."""@en ;
  dcterms:modified "2026-02-12T08:59:21.645727Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1489-4
  a curric:KeyLearningPoint ;
  rdfs:label """They can be combined with direct address to effectively grab the reader’s attention."""@en ;
  dcterms:modified "2026-02-12T08:59:21.645735Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2103-1
  a curric:KeyLearningPoint ;
  rdfs:label "Using structural methods effectively can make your writing dramatic."@en ;
  dcterms:modified "2026-02-12T08:59:21.645740Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2103-2
  a curric:KeyLearningPoint ;
  rdfs:label """Examples of effective structural methods are in medias res, repetition and cliffhangers."""@en ;
  dcterms:modified "2026-02-12T08:59:21.645744Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2103-3
  a curric:KeyLearningPoint ;
  rdfs:label "Varying how an idea is repeated can indicate escalation."@en ;
  dcterms:modified "2026-02-12T08:59:21.645749Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2103-4
  a curric:KeyLearningPoint ;
  rdfs:label """When planning a piece of writing, it can be helpful to think about now, before and later."""@en ;
  dcterms:modified "2026-02-12T08:59:21.645756Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2103-5
  a curric:KeyLearningPoint ;
  rdfs:label "A cliffhanger leaves a reader with a question to be answered."@en ;
  dcterms:modified "2026-02-12T08:59:21.645761Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29069-1
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, Blake uses metaphors of seasonal change to represent childhood passing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.645766Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29069-2
  a curric:KeyLearningPoint ;
  rdfs:label """Blake uses the language of imprisonment and restriction to critique oppressive institutions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.645771Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29069-3
  a curric:KeyLearningPoint ;
  rdfs:label """The language of “cage” and “nip’d” could represent how institutional education creates restrictions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.645775Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29069-4
  a curric:KeyLearningPoint ;
  rdfs:label """The alternating use of “I” and “the child” could represent how institutional education removes individuality."""@en ;
  dcterms:modified "2026-02-12T08:59:21.645780Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29069-5
  a curric:KeyLearningPoint ;
  rdfs:label """The regularity of the poem could reflect how monotonous Blake felt institutional education was."""@en ;
  dcterms:modified "2026-02-12T08:59:21.645785Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28981-1
  a curric:KeyLearningPoint ;
  rdfs:label """Potentially, Paris’ defense of Juliet’s honour may show that men’s honour was affected by the women in their life."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646083Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28981-2
  a curric:KeyLearningPoint ;
  rdfs:label "Arguably, both Paris and Romeo show a reluctance to engage in violence."@en ;
  dcterms:modified "2026-02-12T08:59:21.646088Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28981-3
  a curric:KeyLearningPoint ;
  rdfs:label """Through their reluctance, perhaps Shakespeare is criticising societal expectations on men."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646093Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28981-4
  a curric:KeyLearningPoint ;
  rdfs:label """Throughout ‘Romeo and Juliet’, it’s been suggested that male honour comes from defending it through violence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646098Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28981-5
  a curric:KeyLearningPoint ;
  rdfs:label """However, at the end of the play, Lord Capulet and Lord Montague’s actions suggest that honour now comes from civility."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646102Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28647-1
  a curric:KeyLearningPoint ;
  rdfs:label "An introduction might start with a general statement about the text."@en ;
  dcterms:modified "2026-02-12T08:59:21.646107Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28647-2
  a curric:KeyLearningPoint ;
  rdfs:label """This can be followed by a more specific statement about the focus of the question, and finally your thesis."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646112Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28647-3
  a curric:KeyLearningPoint ;
  rdfs:label """A conclusion can move from a specific statement about the text to a more general statement about its relevance."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646117Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28647-4
  a curric:KeyLearningPoint ;
  rdfs:label """An analytical paragraph should contain discourse markers, embedded quotations and an analysis of methods."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646124Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1640-1
  a curric:KeyLearningPoint ;
  rdfs:label "At the start of Act 1, Scene 7, Macbeth is arguably conflicted"@en ;
  dcterms:modified "2026-02-12T08:59:21.646129Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1640-2
  a curric:KeyLearningPoint ;
  rdfs:label "Lady Macbeth goads Macbeth into killing Duncan - arguably by emasculating him"@en ;
  dcterms:modified "2026-02-12T08:59:21.646134Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1640-3
  a curric:KeyLearningPoint ;
  rdfs:label "Lady Macbeth emotionally blackmails her husband"@en ;
  dcterms:modified "2026-02-12T08:59:21.646139Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1640-4
  a curric:KeyLearningPoint ;
  rdfs:label """This scene could be interpreted as a turning point in the play. Macbeth's decision is made"""@en ;
  dcterms:modified "2026-02-12T08:59:21.646144Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1671-1
  a curric:KeyLearningPoint ;
  rdfs:label "Topic sentences should focus on intention, not methods."@en ;
  dcterms:modified "2026-02-12T08:59:21.646148Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1671-2
  a curric:KeyLearningPoint ;
  rdfs:label """Judicious quotations from across the text can be used to create compelling arguments."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646153Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1671-3
  a curric:KeyLearningPoint ;
  rdfs:label """Using an adjective to introduce a writer’s method allows for succinct evaluation of the effect."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646160Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1671-4
  a curric:KeyLearningPoint ;
  rdfs:label """Tentative language should be used to evaluate different interpretations of a text."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646165Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2099-1
  a curric:KeyLearningPoint ;
  rdfs:label """Open letters are letter written to a particular person or group but which are made publicly available for all to read."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646170Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2099-2
  a curric:KeyLearningPoint ;
  rdfs:label """Siegfried Sassoon uses antithesis, emotive language and personal pronouns to make his open letter a powerful protest."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646175Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2099-3
  a curric:KeyLearningPoint ;
  rdfs:label """The methods used in an open letter will differ depending on the purpose of writing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646180Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2099-4
  a curric:KeyLearningPoint ;
  rdfs:label """Satire can also be used in open letters to criticise a person or idea in an amusing way."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646184Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2099-5
  a curric:KeyLearningPoint ;
  rdfs:label """Successful satire usually involves any of the following: a clear target, humour, exaggeration, irony and parody."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646189Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2312-1
  a curric:KeyLearningPoint ;
  rdfs:label """Robinson uses sibilant and plosive sounds to reflect the seemingly inescapable adversity the speaker faces."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646215Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2312-2
  a curric:KeyLearningPoint ;
  rdfs:label """The colour and sensory imagery around the speaker’s “paradise” implies that it brings hope and peace to the speaker."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646220Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2312-3
  a curric:KeyLearningPoint ;
  rdfs:label "The voice of the grandmother arguably reflects the impact of family on identity."@en ;
  dcterms:modified "2026-02-12T08:59:21.646227Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2312-4
  a curric:KeyLearningPoint ;
  rdfs:label """The structure of the poem reflects the continual presence of the speaker’s heritage."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646232Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2086-1
  a curric:KeyLearningPoint ;
  rdfs:label """Dostoevsky uses facial expressions, body language, structure and punctuation to create effective dialogue."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646236Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2086-2
  a curric:KeyLearningPoint ;
  rdfs:label """To emulate Dostoevsky, we might begin by asking what emotion our characters feel."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646241Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2086-3
  a curric:KeyLearningPoint ;
  rdfs:label """Then we might consider how we can show those emotions through body language, structure and punctuation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646246Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2086-4
  a curric:KeyLearningPoint ;
  rdfs:label """When writing dialogue, often less is more when it comes to the actual exchange of words between characters."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646251Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29030-1
  a curric:KeyLearningPoint ;
  rdfs:label "A successful essay will have a clear overarching argument."@en ;
  dcterms:modified "2026-02-12T08:59:21.646256Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29030-2
  a curric:KeyLearningPoint ;
  rdfs:label """References to the text should link to your topic sentence, and come from across the play."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646260Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29030-3
  a curric:KeyLearningPoint ;
  rdfs:label """Select main quotations and supporting quotations to support your overarching argument."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646265Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29030-4
  a curric:KeyLearningPoint ;
  rdfs:label """Main quotations should be analysed; supporting quotations don’t need to be analysed."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646270Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29030-5
  a curric:KeyLearningPoint ;
  rdfs:label "Context should be embedded, relevant and can include a range of different types."@en ;
  dcterms:modified "2026-02-12T08:59:21.646275Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1660-1
  a curric:KeyLearningPoint ;
  rdfs:label """The breaking of the laboratory door is symbolic of the secrets that are about to be revealed."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646316Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1660-2
  a curric:KeyLearningPoint ;
  rdfs:label "Utterson finds Hyde, who has died by suicide, wearing Dr. Jekyll’s clothes."@en ;
  dcterms:modified "2026-02-12T08:59:21.646321Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1660-3
  a curric:KeyLearningPoint ;
  rdfs:label """Dr. Jekyll’s disappearance from the locked laboratory is the final mystery in the ‘case’."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646326Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1660-4
  a curric:KeyLearningPoint ;
  rdfs:label "Utterson receives one final sealed letter - the final symbol of concealment."@en ;
  dcterms:modified "2026-02-12T08:59:21.646331Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1491-1
  a curric:KeyLearningPoint ;
  rdfs:label """Alliteration and onomatopoeia are both types of aural devices because they link to the sounds in a speech."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646336Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1491-2
  a curric:KeyLearningPoint ;
  rdfs:label """Alliteration involves repeating the same consonant sounds in adjacent or connected words to emphasise key ideas."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646341Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1491-3
  a curric:KeyLearningPoint ;
  rdfs:label """Onomatopoeia is using words that closely resemble the sounds they represent in order to grab the audience’s attention."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646345Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1491-4
  a curric:KeyLearningPoint ;
  rdfs:label """These devices are useful in speeches because they allow you to draw attention to key ideas/central messages."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646350Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2350-1
  a curric:KeyLearningPoint ;
  rdfs:label """The river in the poem could symbolise rebirth and the loss of childhood innocence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646369Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2350-2
  a curric:KeyLearningPoint ;
  rdfs:label """The story of looking after his ill mother becomes the coming of age initiation he missed out on by moving to the UK."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646374Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2350-3
  a curric:KeyLearningPoint ;
  rdfs:label """In the final stanza, Chingonyi reflects on what his life would have been like if he had not left Zambia."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646379Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2350-4
  a curric:KeyLearningPoint ;
  rdfs:label """In the final stanza, the idea of language is used to underline his lack of belonging."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646384Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2350-5
  a curric:KeyLearningPoint ;
  rdfs:label """Enjambment is used in the poem which could also link to the river, arguably symbolising separation and distance."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646391Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2532-1
  a curric:KeyLearningPoint ;
  rdfs:label "The poem is a dub poem - a form of performance poetry of Jamaican origin."@en ;
  dcterms:modified "2026-02-12T08:59:21.646396Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2532-2
  a curric:KeyLearningPoint ;
  rdfs:label "Dialect is used throughout to illustrate Zephaniah's pride in his identity."@en ;
  dcterms:modified "2026-02-12T08:59:21.646401Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2532-3
  a curric:KeyLearningPoint ;
  rdfs:label "The repetition of the refrain highlights how racism is the problem in society."@en ;
  dcterms:modified "2026-02-12T08:59:21.646408Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2532-4
  a curric:KeyLearningPoint ;
  rdfs:label "The alliteration of plosive sounds could illustrate Zephaniah's anger."@en ;
  dcterms:modified "2026-02-12T08:59:21.646413Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2532-5
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, Zephaniah uses stereotypes to mock the prejudicial views of some in society."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646418Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2529-1
  a curric:KeyLearningPoint ;
  rdfs:label "Casey shows pride in her working class roots."@en ;
  dcterms:modified "2026-02-12T08:59:21.646425Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2529-2
  a curric:KeyLearningPoint ;
  rdfs:label "The poem was written when Margaret Thatcher came to power as UK Prime Minister."@en ;
  dcterms:modified "2026-02-12T08:59:21.646430Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2529-3
  a curric:KeyLearningPoint ;
  rdfs:label "Some people argue Thatcher waged a 'class war' against the working classes."@en ;
  dcterms:modified "2026-02-12T08:59:21.646435Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2529-4
  a curric:KeyLearningPoint ;
  rdfs:label "Casey's poem reflects the way some people looked down on the working class."@en ;
  dcterms:modified "2026-02-12T08:59:21.646441Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2563-1
  a curric:KeyLearningPoint ;
  rdfs:label "Topic sentences need to be clear, comparative and linked to the question."@en ;
  dcterms:modified "2026-02-12T08:59:21.646445Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2563-2
  a curric:KeyLearningPoint ;
  rdfs:label "Relevant quotations from the text are used to justify arguments."@en ;
  dcterms:modified "2026-02-12T08:59:21.646450Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2563-3
  a curric:KeyLearningPoint ;
  rdfs:label "Relevant contextual information can be used to develop arguments."@en ;
  dcterms:modified "2026-02-12T08:59:21.646455Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2563-4
  a curric:KeyLearningPoint ;
  rdfs:label """Responses should focus on the intention of the writer to avoid re-telling the story of the poem."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646460Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2563-5
  a curric:KeyLearningPoint ;
  rdfs:label """Comparative conjunctions should be used to compare key ideas as well as language, form and structure."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646464Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2051-1
  a curric:KeyLearningPoint ;
  rdfs:label "The transience of life is an idea that impacts us all."@en ;
  dcterms:modified "2026-02-12T08:59:21.646469Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2051-2
  a curric:KeyLearningPoint ;
  rdfs:label """The idea of transience is explored across literature, including many different poems."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646474Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2051-3
  a curric:KeyLearningPoint ;
  rdfs:label "Arguably, both Laskey and Robertson consider ideas of transience in their poems."@en ;
  dcterms:modified "2026-02-12T08:59:21.646479Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2051-4
  a curric:KeyLearningPoint ;
  rdfs:label """Laskey's 'Nobody' could relate to how we need to take opportunities in life when we have the chance."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646484Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2051-5
  a curric:KeyLearningPoint ;
  rdfs:label """Robertson's 'Donegal' may relate to how our relationships with others are always growing and changing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646488Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29008-1
  a curric:KeyLearningPoint ;
  rdfs:label """Potentially, we might see Juliet’s resolve as strengthening as her speech progresses."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646493Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29008-2
  a curric:KeyLearningPoint ;
  rdfs:label """However, the increasing desperate language might seem contradictory to this and could undermine her agency."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646500Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29008-3
  a curric:KeyLearningPoint ;
  rdfs:label """Speaking in regular iambic pentameter arguably indicates calm emotions since it reflects a steady heartbeat."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646505Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29008-4
  a curric:KeyLearningPoint ;
  rdfs:label """Juliet speaks in iambic pentameter when talking about her death which suggests she feels in control"""@en ;
  dcterms:modified "2026-02-12T08:59:21.646510Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29008-5
  a curric:KeyLearningPoint ;
  rdfs:label """However, her final line is the most far removed from iambic pentameter and could undermine her agency."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646514Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1643-1
  a curric:KeyLearningPoint ;
  rdfs:label "In Jacobean England, women had very little power"@en ;
  dcterms:modified "2026-02-12T08:59:21.646519Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1643-2
  a curric:KeyLearningPoint ;
  rdfs:label """The female characters in Act 1 of 'Macbeth' can seem unconventional in their behaviour"""@en ;
  dcterms:modified "2026-02-12T08:59:21.646524Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1643-3
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, this unconventional behaviour doesn't prevent them from reinforcing the status quo"""@en ;
  dcterms:modified "2026-02-12T08:59:21.646529Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1643-4
  a curric:KeyLearningPoint ;
  rdfs:label "Lady Macbeth could be interpreted as a dutiful wife"@en ;
  dcterms:modified "2026-02-12T08:59:21.646534Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2107-1
  a curric:KeyLearningPoint ;
  rdfs:label """In order to write a convincing argument, you might include techniques such as anecdotes, hyperbole and statistics."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646538Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2107-2
  a curric:KeyLearningPoint ;
  rdfs:label """Anecdotes make the issue seem relevant to the real world and elicit an emotional reaction from the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646543Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2107-3
  a curric:KeyLearningPoint ;
  rdfs:label "Hyperbole makes the issue seem urgent and important."@en ;
  dcterms:modified "2026-02-12T08:59:21.646548Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2107-4
  a curric:KeyLearningPoint ;
  rdfs:label """To make a statistic credible, you might state the organisation it came from, date, and a believable figure."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646555Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2107-5
  a curric:KeyLearningPoint ;
  rdfs:label "The article form includes a headline, strapline, subheadings and paragraphs."@en ;
  dcterms:modified "2026-02-12T08:59:21.646560Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29091-1
  a curric:KeyLearningPoint ;
  rdfs:label """A comparative introduction might offer smaller variations within a wider similarity between poems."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646565Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29091-2
  a curric:KeyLearningPoint ;
  rdfs:label "A comparative introduction might offer nuanced differences between poems."@en ;
  dcterms:modified "2026-02-12T08:59:21.646569Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29091-3
  a curric:KeyLearningPoint ;
  rdfs:label """You could try to develop your ideas by using discourse markers and alternative interpretations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646574Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29091-4
  a curric:KeyLearningPoint ;
  rdfs:label """The purpose of your analytical writing is to convince the reader of your argument."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646579Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2389-1
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to consider how the tone of a speech opening will engage the audience."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646584Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2389-2
  a curric:KeyLearningPoint ;
  rdfs:label "An introduction should hook your audience in, regardless of the topic."@en ;
  dcterms:modified "2026-02-12T08:59:21.646591Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2389-3
  a curric:KeyLearningPoint ;
  rdfs:label """The ending of your persuasive speech presents the last opportunity to influence your audience."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646625Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2389-4
  a curric:KeyLearningPoint ;
  rdfs:label """At the end of your persuasive speech, your audience should know exactly how to help or what to think or feel."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646631Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2389-5
  a curric:KeyLearningPoint ;
  rdfs:label "Using rhetorical devices can elevate your opening and closing paragraphs."@en ;
  dcterms:modified "2026-02-12T08:59:21.646635Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2131-1
  a curric:KeyLearningPoint ;
  rdfs:label """Excellent descriptions and narratives will focus on describing details, rather than trying to write too much"""@en ;
  dcterms:modified "2026-02-12T08:59:21.646640Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2131-2
  a curric:KeyLearningPoint ;
  rdfs:label """Figurative language should be used to create vivid images of what is being described"""@en ;
  dcterms:modified "2026-02-12T08:59:21.646645Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2131-3
  a curric:KeyLearningPoint ;
  rdfs:label """Adding detailed description is often more valuable than plot points, in creating tension"""@en ;
  dcterms:modified "2026-02-12T08:59:21.646651Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2131-4
  a curric:KeyLearningPoint ;
  rdfs:label """Using semantic fields and extended metaphors can add cohesion to creative writing"""@en ;
  dcterms:modified "2026-02-12T08:59:21.646657Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1474-1
  a curric:KeyLearningPoint ;
  rdfs:label "Making predictions can help you to comprehend a new text better."@en ;
  dcterms:modified "2026-02-12T08:59:21.646946Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1474-2
  a curric:KeyLearningPoint ;
  rdfs:label "Dashes can be used to add a greater pause for dramatic effect."@en ;
  dcterms:modified "2026-02-12T08:59:21.646950Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1474-3
  a curric:KeyLearningPoint ;
  rdfs:label """Colons are used to separate two main clauses and can introduce lists, explanations and quotes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646955Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1474-4
  a curric:KeyLearningPoint ;
  rdfs:label """Writers use sentence structures and punctuation for emphasis, to change pace and convey emotion."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646960Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1474-5
  a curric:KeyLearningPoint ;
  rdfs:label """Use precise quotations to support your analysis of punctuation and sentence structure."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646964Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28979-1
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, Shakespeare opens Act 3, Scene 1 with the expectation of violence through the pathetic fallacy “hot”."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646971Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28979-2
  a curric:KeyLearningPoint ;
  rdfs:label """By connecting blood and violence, Shakespeare may be suggesting that violence is integral to men."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646978Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28979-3
  a curric:KeyLearningPoint ;
  rdfs:label """Throughout Act 3, Scene 1, Shakespeare might be implying that men saw violence as a way to satisfy their honour."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646984Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28979-4
  a curric:KeyLearningPoint ;
  rdfs:label """Mercutio’s connection of submission and dishonour may indicate that men were supposed to be violent and dominant."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646991Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28979-5
  a curric:KeyLearningPoint ;
  rdfs:label """We could see Mercutio’s challenge as implying that men’s honour was also affected by those in their social circle."""@en ;
  dcterms:modified "2026-02-12T08:59:21.646996Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28642-1
  a curric:KeyLearningPoint ;
  rdfs:label """A thesis statement is an overarching argument and should refer to the writer’s intent."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647020Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28642-2
  a curric:KeyLearningPoint ;
  rdfs:label """The thesis statement is also an opportunity to show how your argument relates to the ‘bigger picture’."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647025Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28642-3
  a curric:KeyLearningPoint ;
  rdfs:label "A topic sentence explains the main focus of your paragraph."@en ;
  dcterms:modified "2026-02-12T08:59:21.647030Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28642-4
  a curric:KeyLearningPoint ;
  rdfs:label """An effective analytical essay includes topic sentences, supporting detail, and concluding sentences."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647034Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1650-1
  a curric:KeyLearningPoint ;
  rdfs:label """Machiavellian is an adjective. It describes someone who gets what they want in cunning, ruthless and immoral ways."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647063Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1650-2
  a curric:KeyLearningPoint ;
  rdfs:label "A thesis statement is a clear, overarching argument"@en ;
  dcterms:modified "2026-02-12T08:59:21.647070Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1650-3
  a curric:KeyLearningPoint ;
  rdfs:label "Topic sentences give focus to individual paragraphs"@en ;
  dcterms:modified "2026-02-12T08:59:21.647075Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1650-4
  a curric:KeyLearningPoint ;
  rdfs:label "Topic sentences should support the overarching thesis"@en ;
  dcterms:modified "2026-02-12T08:59:21.647082Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1650-5
  a curric:KeyLearningPoint ;
  rdfs:label """Identifying judicious supporting detail to include in each paragraph supports planning"""@en ;
  dcterms:modified "2026-02-12T08:59:21.647087Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1638-1
  a curric:KeyLearningPoint ;
  rdfs:label "Jacobean men believed that women had a duty or obligation to them"@en ;
  dcterms:modified "2026-02-12T08:59:21.647092Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1638-2
  a curric:KeyLearningPoint ;
  rdfs:label "Jacobean society was intensely hierarchical"@en ;
  dcterms:modified "2026-02-12T08:59:21.647097Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1638-3
  a curric:KeyLearningPoint ;
  rdfs:label """The witches' masculine appearance could suggest that they can manipulate the natural order of the world"""@en ;
  dcterms:modified "2026-02-12T08:59:21.647101Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1638-4
  a curric:KeyLearningPoint ;
  rdfs:label """A single paragraph outline could contain a topic sentence, a concluding sentence and bullet pointed supporting detail"""@en ;
  dcterms:modified "2026-02-12T08:59:21.647106Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2422-1
  a curric:KeyLearningPoint ;
  rdfs:label """An anthology is a collection of artistic works that have a similar form or subject."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647130Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2422-2
  a curric:KeyLearningPoint ;
  rdfs:label "Each poetry anthology is chosen with overall themes and ‘big ideas’ in mind."@en ;
  dcterms:modified "2026-02-12T08:59:21.647134Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2422-3
  a curric:KeyLearningPoint ;
  rdfs:label """Exploring titles and quotations from poems can help you see potential connections between them."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647139Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2422-4
  a curric:KeyLearningPoint ;
  rdfs:label "Our personal response to a poem is important."@en ;
  dcterms:modified "2026-02-12T08:59:21.647144Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2085-1
  a curric:KeyLearningPoint ;
  rdfs:label """Dialogue might be hard to construct in writing because it relies heavily on body language."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647148Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2085-2
  a curric:KeyLearningPoint ;
  rdfs:label """Dialogue is important because it not only reveals information about the characters but also wider ideas of connection."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647153Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2085-3
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, Dostoevsky structures the dialogue to immediately create a sense of tension."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647158Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2085-4
  a curric:KeyLearningPoint ;
  rdfs:label """Potentially, the use of punctuation and division of dialogue show Raskolnikov's impoverished status."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647162Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2085-5
  a curric:KeyLearningPoint ;
  rdfs:label "The use of body language demonstrates Raskolnikov's tension and anxiety."@en ;
  dcterms:modified "2026-02-12T08:59:21.647170Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2112-1
  a curric:KeyLearningPoint ;
  rdfs:label """In 'The Yellow Wallpaper', Perkins Gilman may have wanted to reveal more about John than the narrator herself."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647175Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2112-2
  a curric:KeyLearningPoint ;
  rdfs:label """'The Yellow Wallpaper' may be a critique of the patriarchal systems in place in the 1800s."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647180Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2112-3
  a curric:KeyLearningPoint ;
  rdfs:label """The narrator's husband seems to come across as controlling, dismissive, patronising and authoritative."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647187Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2112-4
  a curric:KeyLearningPoint ;
  rdfs:label """We can craft the narrator's husband voice using a range of methods such as imperatives, tag questions and modal verbs."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647191Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6236-1
  a curric:KeyLearningPoint ;
  rdfs:label """You can begin to form a personal response to a text by asking yourself what feelings the text evoked in you."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647196Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6236-2
  a curric:KeyLearningPoint ;
  rdfs:label "Opinions are personal, so each person may have a different opinion on a text."@en ;
  dcterms:modified "2026-02-12T08:59:21.647201Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6236-3
  a curric:KeyLearningPoint ;
  rdfs:label "In order to make your opinion more credible, you should justify it."@en ;
  dcterms:modified "2026-02-12T08:59:21.647206Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6236-4
  a curric:KeyLearningPoint ;
  rdfs:label "Appropriate justification comes in the form of evidence from the text."@en ;
  dcterms:modified "2026-02-12T08:59:21.647210Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1478-1
  a curric:KeyLearningPoint ;
  rdfs:label "Synonyms can be used to avoid repeating a subject e.g. 'The trees'."@en ;
  dcterms:modified "2026-02-12T08:59:21.647215Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1478-2
  a curric:KeyLearningPoint ;
  rdfs:label "Supporting details should be used to describe the paragraph focus in detail."@en ;
  dcterms:modified "2026-02-12T08:59:21.647220Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1478-3
  a curric:KeyLearningPoint ;
  rdfs:label "Concluding sentences draw paragraphs together, creating cohesion."@en ;
  dcterms:modified "2026-02-12T08:59:21.647225Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1478-4
  a curric:KeyLearningPoint ;
  rdfs:label "Expanded noun phrases can be effective at focusing on details within a scene."@en ;
  dcterms:modified "2026-02-12T08:59:21.647232Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2068-1
  a curric:KeyLearningPoint ;
  rdfs:label """King Duncan is based on a historical figure, although Shakespeare made his Duncan a more sympathetic figure."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647239Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2068-2
  a curric:KeyLearningPoint ;
  rdfs:label """Shakespeare uses Duncan as a construct, acting as a poignant warning against regicide."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647244Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2068-3
  a curric:KeyLearningPoint ;
  rdfs:label """Embedded quotations and noun appositives support make writing clear and succinct."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647250Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2068-4
  a curric:KeyLearningPoint ;
  rdfs:label """Modal verbs and tentative adverbs indicate that not all inferences are commonly held."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647254Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2059-1
  a curric:KeyLearningPoint ;
  rdfs:label "When analysing characters it is important to acknowledge they are a construct."@en ;
  dcterms:modified "2026-02-12T08:59:21.647259Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2059-2
  a curric:KeyLearningPoint ;
  rdfs:label """Commenting on characterisation with reference to methods and themes is an effective analytical strategy."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647266Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2059-3
  a curric:KeyLearningPoint ;
  rdfs:label "Commenting on the progression of a character can help develop analysis."@en ;
  dcterms:modified "2026-02-12T08:59:21.647271Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2059-4
  a curric:KeyLearningPoint ;
  rdfs:label "Linking to structure, form and style will elevate your analysis."@en ;
  dcterms:modified "2026-02-12T08:59:21.647276Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1482-1
  a curric:KeyLearningPoint ;
  rdfs:label """Asking questions about the writer and time of publication can help us understand the perspective of the writer."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647281Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1482-2
  a curric:KeyLearningPoint ;
  rdfs:label """Asking questions about the genre, audience and publication can help understand the writer’s intentions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647285Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1482-3
  a curric:KeyLearningPoint ;
  rdfs:label """Analysing non-fiction is important because it helps us understand why information is being offered to us in that way."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647290Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1482-4
  a curric:KeyLearningPoint ;
  rdfs:label """Developing a personal response is important because it helps us to see how the text fits with our world view."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647295Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2125-1
  a curric:KeyLearningPoint ;
  rdfs:label "Any topic can be interesting if the account is well written."@en ;
  dcterms:modified "2026-02-12T08:59:21.647299Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2125-2
  a curric:KeyLearningPoint ;
  rdfs:label """Compelling writing is irresistible often because of its emotional power or theme."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647306Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2125-3
  a curric:KeyLearningPoint ;
  rdfs:label "Examples of wordplay are assonance and alliteration and inverted syntax."@en ;
  dcterms:modified "2026-02-12T08:59:21.647311Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2125-4
  a curric:KeyLearningPoint ;
  rdfs:label "A good plan has an overall structure and details about tone, ideas and feelings."@en ;
  dcterms:modified "2026-02-12T08:59:21.647316Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2053-1
  a curric:KeyLearningPoint ;
  rdfs:label """Analysing model answers allows us to explore how we might frame ideas and how to avoid misconceptions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647321Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2053-2
  a curric:KeyLearningPoint ;
  rdfs:label """To effectively analyse quotations, we need to explain how we have reached our conclusions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647326Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2053-3
  a curric:KeyLearningPoint ;
  rdfs:label """An effective conclusion summarises the argument and gestures to what it might say about society."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647330Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2053-4
  a curric:KeyLearningPoint ;
  rdfs:label """A personal response may reflect on how the meaning of the poem relates to the reader and wider society."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647335Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2087-1
  a curric:KeyLearningPoint ;
  rdfs:label """Writers may use similes in order to create emphatic, evocative images for the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647340Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2087-2
  a curric:KeyLearningPoint ;
  rdfs:label """Chandler compares Anna Halsey’s appearance to "suet" and her desk to "Napoleon’s tomb"."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647344Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2087-3
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, the comparison of her appearance to "suet" may imply that she has a hard exterior."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647349Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2087-4
  a curric:KeyLearningPoint ;
  rdfs:label """Furthermore, the comparison of her desk to "Napoleon’s tomb" may imply she’s cold in business."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647356Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1627-1
  a curric:KeyLearningPoint ;
  rdfs:label "The supernatural is a key theme of the play"@en ;
  dcterms:modified "2026-02-12T08:59:21.647361Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1627-2
  a curric:KeyLearningPoint ;
  rdfs:label "At the start of the play, Macbeth is presented as a brave warrior"@en ;
  dcterms:modified "2026-02-12T08:59:21.647366Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1627-3
  a curric:KeyLearningPoint ;
  rdfs:label "The current Thane of Cawdor is plotting to betray King Duncan"@en ;
  dcterms:modified "2026-02-12T08:59:21.647371Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1627-4
  a curric:KeyLearningPoint ;
  rdfs:label "The witches prophecy that Macbeth will become Thane of Cawdor and then King"@en ;
  dcterms:modified "2026-02-12T08:59:21.647376Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1627-5
  a curric:KeyLearningPoint ;
  rdfs:label "The witches prophecy that Banquo's sons will become kings"@en ;
  dcterms:modified "2026-02-12T08:59:21.647380Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2365-1
  a curric:KeyLearningPoint ;
  rdfs:label "Pinnock wrote 'Leave Taking’ to share the “distinct” Black British experience."@en ;
  dcterms:modified "2026-02-12T08:59:21.647385Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2365-2
  a curric:KeyLearningPoint ;
  rdfs:label """The character of Enid speaks to the complex history and relationship Jamaica and Britain share."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647390Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2365-3
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, both Viv and Del struggle in different ways with being a second generation Black British immigrant."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647397Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2365-4
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, both Viv and Del struggle with being second generation immigrants and Black British citizens."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647402Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2365-5
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, the ending of the play is ambiguous but hopeful for both the Del and Viv."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647407Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2094-1
  a curric:KeyLearningPoint ;
  rdfs:label """The role of the teenager was first established around the 1940s and the term has gradually evolved over time."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647412Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2094-2
  a curric:KeyLearningPoint ;
  rdfs:label """Media can give us insight into issues and topics concerning teenagers across different decades."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647417Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2094-3
  a curric:KeyLearningPoint ;
  rdfs:label """Article titles give us a snapshot of an issue and insight into the stance of a writer."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647421Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2094-4
  a curric:KeyLearningPoint ;
  rdfs:label "Article titles should be crafted in an engaging way to hook the reader."@en ;
  dcterms:modified "2026-02-12T08:59:21.647426Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2048-1
  a curric:KeyLearningPoint ;
  rdfs:label """The tone of a literary work expresses the writer's attitude toward or feelings about the subject matter."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647431Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2048-2
  a curric:KeyLearningPoint ;
  rdfs:label """In order to determine the tone, we might ask questions about how the poem would sound if read aloud."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647436Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2048-3
  a curric:KeyLearningPoint ;
  rdfs:label """We also might ask questions about the use of punctuation, structure and language in order to determine the tone."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647441Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2048-4
  a curric:KeyLearningPoint ;
  rdfs:label """We might interpret Fainlight’s ‘Borrowed Time’ as having a reflective or desperate tone."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647448Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2056-1
  a curric:KeyLearningPoint ;
  rdfs:label """Reflecting on your work is an important part of understanding what went well and what you could improve on."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647453Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2056-2
  a curric:KeyLearningPoint ;
  rdfs:label "Rewriting your work is a chance to improve it based on your reflections."@en ;
  dcterms:modified "2026-02-12T08:59:21.647458Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2056-3
  a curric:KeyLearningPoint ;
  rdfs:label """When writing comparatively, you want to explore the similarities and differences in how the poets create meaning."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647463Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2056-4
  a curric:KeyLearningPoint ;
  rdfs:label """When considering a personal response, you may ask yourself what questions the poems cause you to ask."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647467Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28788-1
  a curric:KeyLearningPoint ;
  rdfs:label """Priestley uses dramatic irony to establish the character of Mr. Birling as foolish."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647472Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28788-2
  a curric:KeyLearningPoint ;
  rdfs:label """Priestley uses both monologues and dramatic irony to emphasise Mr. Birling’s arrogance."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647477Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28788-3
  a curric:KeyLearningPoint ;
  rdfs:label """Priestley uses Mr. Birling to critique the upper class attitudes towards social responsibility, class and power."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647482Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28788-4
  a curric:KeyLearningPoint ;
  rdfs:label """The end of the play emphasises the generational conflict between the younger and older Birlings."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647487Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2108-1
  a curric:KeyLearningPoint ;
  rdfs:label """Making an inference means coming to a conclusion, based on evidence and reasoning."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647627Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2108-2
  a curric:KeyLearningPoint ;
  rdfs:label "A variety of synonyms of 'suggests' should be used to express inferences."@en ;
  dcterms:modified "2026-02-12T08:59:21.647637Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2108-3
  a curric:KeyLearningPoint ;
  rdfs:label "You can make inferences based on single words."@en ;
  dcterms:modified "2026-02-12T08:59:21.647642Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2108-4
  a curric:KeyLearningPoint ;
  rdfs:label "Inferences should always be justified with evidence from the text."@en ;
  dcterms:modified "2026-02-12T08:59:21.647647Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2108-5
  a curric:KeyLearningPoint ;
  rdfs:label "Making inferences can help you form opinions on characters."@en ;
  dcterms:modified "2026-02-12T08:59:21.647651Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1493-1
  a curric:KeyLearningPoint ;
  rdfs:label """In responding to a personal essay, we might ask what it is the writer wants us to understand about their lives."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647656Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1493-2
  a curric:KeyLearningPoint ;
  rdfs:label """Potentially, writers might use anecdotes in personal essays to creates an emotional reaction in the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647661Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1493-3
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, Reedy's use of anecdotes elicits a sympathetic response from the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647666Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1493-4
  a curric:KeyLearningPoint ;
  rdfs:label """We might analyse anecdotes by considering the writer's use of specific words and methods."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647670Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2346-1
  a curric:KeyLearningPoint ;
  rdfs:label "Topic sentences need to be clear, comparative and linked to the question."@en ;
  dcterms:modified "2026-02-12T08:59:21.647675Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2346-2
  a curric:KeyLearningPoint ;
  rdfs:label "Relevant quotations from the text are used to justify arguments."@en ;
  dcterms:modified "2026-02-12T08:59:21.647680Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2346-3
  a curric:KeyLearningPoint ;
  rdfs:label """Context can be used to develop arguments and shape our interpretations of a text."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647685Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2346-4
  a curric:KeyLearningPoint ;
  rdfs:label """Responses should focus on the intention of the author to avoid re-telling the story of the poem."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647690Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2346-5
  a curric:KeyLearningPoint ;
  rdfs:label """Comparative vocabulary should be used to compare the language, form and structure of poems."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647694Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2041-1
  a curric:KeyLearningPoint ;
  rdfs:label "A semantic field is a group of words that all link to the same theme or idea."@en ;
  dcterms:modified "2026-02-12T08:59:21.647699Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2041-2
  a curric:KeyLearningPoint ;
  rdfs:label """Before exploring the wider effects, explain the different connotations of individual words in the poem."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647704Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2041-3
  a curric:KeyLearningPoint ;
  rdfs:label """Exploring methods such as similes or euphony can help develop your analysis of the effects of word choices."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647709Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2134-1
  a curric:KeyLearningPoint ;
  rdfs:label "Narratives that try to tell too much story are often unsuccessful"@en ;
  dcterms:modified "2026-02-12T08:59:21.647714Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2134-2
  a curric:KeyLearningPoint ;
  rdfs:label """Instead,you can use an emotion-led narrative, which will help keep your plot manageable so you don't try to say too much"""@en ;
  dcterms:modified "2026-02-12T08:59:21.647721Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2134-3
  a curric:KeyLearningPoint ;
  rdfs:label """Use skills from descriptive writing to elevate your narratives, especially when describing emotions"""@en ;
  dcterms:modified "2026-02-12T08:59:21.647728Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2134-4
  a curric:KeyLearningPoint ;
  rdfs:label "Use figurative language to make your narrative descriptions more vivid"@en ;
  dcterms:modified "2026-02-12T08:59:21.647733Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2134-5
  a curric:KeyLearningPoint ;
  rdfs:label """It is better to describe your character's physical symptoms of emotion rather than just stating what the emotion is"""@en ;
  dcterms:modified "2026-02-12T08:59:21.647738Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2115-1
  a curric:KeyLearningPoint ;
  rdfs:label "Prompts can help spark ideas for interesting narratives."@en ;
  dcterms:modified "2026-02-12T08:59:21.647743Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2115-2
  a curric:KeyLearningPoint ;
  rdfs:label "Authorial and narrative voice are different things."@en ;
  dcterms:modified "2026-02-12T08:59:21.647748Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2115-3
  a curric:KeyLearningPoint ;
  rdfs:label "Narrative voice is often distinct to our own, with endless possibilities"@en ;
  dcterms:modified "2026-02-12T08:59:21.647753Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2115-4
  a curric:KeyLearningPoint ;
  rdfs:label """To shape a compelling voice we should hint at a character's personality, background and thoughts"""@en ;
  dcterms:modified "2026-02-12T08:59:21.647759Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2115-5
  a curric:KeyLearningPoint ;
  rdfs:label """Planning a complete profile for a character can help us adhere to a compelling, consistent voice in our narrative"""@en ;
  dcterms:modified "2026-02-12T08:59:21.647764Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6243-1
  a curric:KeyLearningPoint ;
  rdfs:label """Paragraphs are the building blocks of creative writing, allowing our writing to take on an interesting structure."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647769Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6243-2
  a curric:KeyLearningPoint ;
  rdfs:label """We should plan an interesting paragraph structure before we begin creative writing to engage the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647774Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6243-3
  a curric:KeyLearningPoint ;
  rdfs:label """We can begin with a wide perspective, narrow into a scene and end with a moment of tension."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647778Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6243-4
  a curric:KeyLearningPoint ;
  rdfs:label "Prepositional phrases help us transition from one paragraph to another."@en ;
  dcterms:modified "2026-02-12T08:59:21.647783Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1472-1
  a curric:KeyLearningPoint ;
  rdfs:label """Writers vary the position of subordinate clauses in a sentence, to alter pace, tension and emphasis"""@en ;
  dcterms:modified "2026-02-12T08:59:21.647788Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1472-2
  a curric:KeyLearningPoint ;
  rdfs:label """Writers vary the types of sentence used (interrogative, exclamatory, declarative and imperative) to convey emotion"""@en ;
  dcterms:modified "2026-02-12T08:59:21.647793Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1472-3
  a curric:KeyLearningPoint ;
  rdfs:label "When analysing sentences, give precise examples from the text"@en ;
  dcterms:modified "2026-02-12T08:59:21.647797Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1472-4
  a curric:KeyLearningPoint ;
  rdfs:label """When analysing sentences, break down the effect of different sentence structures in detail"""@en ;
  dcterms:modified "2026-02-12T08:59:21.647802Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28639-1
  a curric:KeyLearningPoint ;
  rdfs:label "Romeo’s language implies that he values Juliet for herself."@en ;
  dcterms:modified "2026-02-12T08:59:21.647807Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28639-2
  a curric:KeyLearningPoint ;
  rdfs:label """In contrast, Romeo’s language suggests that he valued the chase for Rosaline rather than her."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647812Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28639-3
  a curric:KeyLearningPoint ;
  rdfs:label """Romeo’s use of oxymorons suggests that he sees his love for Rosaline as something uncertain and conflicting."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647819Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28639-4
  a curric:KeyLearningPoint ;
  rdfs:label """However, he describes his love for Juliet in physical terms which suggests it is more substantial."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647853Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28639-5
  a curric:KeyLearningPoint ;
  rdfs:label """Romeo suggests that, while he is losing himself, his love for Juliet means he’s joining something greater than himself."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647859Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1636-1
  a curric:KeyLearningPoint ;
  rdfs:label "The opening scene is used to foreshadow events later in the play"@en ;
  dcterms:modified "2026-02-12T08:59:21.647864Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1636-2
  a curric:KeyLearningPoint ;
  rdfs:label "The supernatural is an important theme in the play"@en ;
  dcterms:modified "2026-02-12T08:59:21.647869Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1636-3
  a curric:KeyLearningPoint ;
  rdfs:label "The witches being in the opening scene illustrates their importance to the plot"@en ;
  dcterms:modified "2026-02-12T08:59:21.647873Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2095-1
  a curric:KeyLearningPoint ;
  rdfs:label """Attitudes and perspectives on love have changed significantly since the 16th century."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647878Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2095-2
  a curric:KeyLearningPoint ;
  rdfs:label """Marriages in the 16th century were largely based on the choice of a woman's father, not love."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647883Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2095-3
  a curric:KeyLearningPoint ;
  rdfs:label """Over time, women have had more freedom in matters of love, although marrying for advantages was still important."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647887Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2095-4
  a curric:KeyLearningPoint ;
  rdfs:label """Love nowadays often involves digital declarations and generally more freedom in romantic relationships."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647892Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2092-1
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to be clear about the form, purpose and audience of a non fiction text."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647897Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2092-2
  a curric:KeyLearningPoint ;
  rdfs:label """We can use the title and context to determine a text’s form, purpose and audience."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647902Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2092-3
  a curric:KeyLearningPoint ;
  rdfs:label """Identifying the language used in the opening of the text can also help us identify the form, purpose and audience."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647906Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2092-4
  a curric:KeyLearningPoint ;
  rdfs:label """We should look to see if the language used is formal or informal and identify the tone being used."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647914Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2126-1
  a curric:KeyLearningPoint ;
  rdfs:label "Excellent writing will have a consistent tone of voice."@en ;
  dcterms:modified "2026-02-12T08:59:21.647919Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2126-2
  a curric:KeyLearningPoint ;
  rdfs:label """Excellent functional writing will include figurative language and extend imagery throughout."""@en ;
  dcterms:modified "2026-02-12T08:59:21.647923Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2126-3
  a curric:KeyLearningPoint ;
  rdfs:label "Excellent writing will make use of structural devices for effect."@en ;
  dcterms:modified "2026-02-12T08:59:21.647928Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2126-4
  a curric:KeyLearningPoint ;
  rdfs:label "Excellent writing will have a focused viewpoint throughout."@en ;
  dcterms:modified "2026-02-12T08:59:21.647933Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2126-5
  a curric:KeyLearningPoint ;
  rdfs:label "Excellent writing will contain high-level spelling, punctuation and grammar."@en ;
  dcterms:modified "2026-02-12T08:59:21.647940Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1633-1
  a curric:KeyLearningPoint ;
  rdfs:label "Scotland is unstable under Macbeth’s leadership"@en ;
  dcterms:modified "2026-02-12T08:59:21.648143Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1633-2
  a curric:KeyLearningPoint ;
  rdfs:label "In Act 4, Scene 1, the witches give Macbeth further prophecies"@en ;
  dcterms:modified "2026-02-12T08:59:21.648148Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1633-3
  a curric:KeyLearningPoint ;
  rdfs:label "Macduff is a loyal Scottish Thane whose family is killed by Macbeth"@en ;
  dcterms:modified "2026-02-12T08:59:21.648153Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1633-4
  a curric:KeyLearningPoint ;
  rdfs:label "Macbeth feels the witches’ prophecies make him invincible"@en ;
  dcterms:modified "2026-02-12T08:59:21.648158Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1633-5
  a curric:KeyLearningPoint ;
  rdfs:label """Malcolm and Macduff prepare to go to war with Macbeth in order to restore Scotland to strength and stability"""@en ;
  dcterms:modified "2026-02-12T08:59:21.648162Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28785-1
  a curric:KeyLearningPoint ;
  rdfs:label """Priestley uses the setting to establish the Birlings' wealth and upper-class lifestyle."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648167Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28785-2
  a curric:KeyLearningPoint ;
  rdfs:label """The setting reveals the importance of status and appearance and how this is challenged by the Inspector."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648172Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28785-3
  a curric:KeyLearningPoint ;
  rdfs:label """Priestley uses specific and detailed stage directions to develop characterisation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648177Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28785-4
  a curric:KeyLearningPoint ;
  rdfs:label """When reading a play, the stage directions can help develop our understanding of a character and their internal states."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648181Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28785-5
  a curric:KeyLearningPoint ;
  rdfs:label "The play could be presented in naturalistic or theatrical way."@en ;
  dcterms:modified "2026-02-12T08:59:21.648186Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2063-1
  a curric:KeyLearningPoint ;
  rdfs:label "Annotate the key theme or character from the question with the writer's message."@en ;
  dcterms:modified "2026-02-12T08:59:21.648209Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2063-2
  a curric:KeyLearningPoint ;
  rdfs:label "A successful plan follows a clear structure."@en ;
  dcterms:modified "2026-02-12T08:59:21.648216Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2063-3
  a curric:KeyLearningPoint ;
  rdfs:label "A thesis is a clear overarching argument supported by the whole text."@en ;
  dcterms:modified "2026-02-12T08:59:21.648221Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2063-4
  a curric:KeyLearningPoint ;
  rdfs:label "Topic sentences state a paragraph's main idea."@en ;
  dcterms:modified "2026-02-12T08:59:21.648226Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2063-5
  a curric:KeyLearningPoint ;
  rdfs:label """Concluding sentences focus on the writer’s intentions and link to your topic sentence, without repeating it."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648231Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2360-1
  a curric:KeyLearningPoint ;
  rdfs:label "An excellent introduction could start with a brief summary of each poem."@en ;
  dcterms:modified "2026-02-12T08:59:21.648263Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2360-2
  a curric:KeyLearningPoint ;
  rdfs:label """An introduction should then have a more specific statement about the focus of the question, followed by a thesis."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648268Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2360-3
  a curric:KeyLearningPoint ;
  rdfs:label "Topic sentences need to be clear, comparative and linked to the question."@en ;
  dcterms:modified "2026-02-12T08:59:21.648272Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2360-4
  a curric:KeyLearningPoint ;
  rdfs:label """Comparative conjunctions should be used to compare language, form and structure of poems."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648277Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2360-5
  a curric:KeyLearningPoint ;
  rdfs:label "Context can be used to develop arguments."@en ;
  dcterms:modified "2026-02-12T08:59:21.648282Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2518-1
  a curric:KeyLearningPoint ;
  rdfs:label "Enjambment and caesura are used to create a chaotic atmosphere."@en ;
  dcterms:modified "2026-02-12T08:59:21.648287Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2518-2
  a curric:KeyLearningPoint ;
  rdfs:label "Rhetorical questions are used to represent the speaker's inner conflict."@en ;
  dcterms:modified "2026-02-12T08:59:21.648291Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2518-3
  a curric:KeyLearningPoint ;
  rdfs:label """The speaker's struggle to speak may represent the lack of voice civilians have in conflict."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648296Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2518-4
  a curric:KeyLearningPoint ;
  rdfs:label """The street names link to soldiers and battles from the Crimean War, illustrating that The Troubles were a 'war' too."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648301Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2518-5
  a curric:KeyLearningPoint ;
  rdfs:label """Carson uses lots of words linked to speed and urgency to convey a sense of fear and chaos."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648308Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2520-1
  a curric:KeyLearningPoint ;
  rdfs:label """Taken from Blake's 'Songs of Experience', the poem helps children understand the negative world they live in."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648317Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2520-2
  a curric:KeyLearningPoint ;
  rdfs:label "'A Poison Tree' explores the internal conflict of the speaker."@en ;
  dcterms:modified "2026-02-12T08:59:21.648322Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2520-3
  a curric:KeyLearningPoint ;
  rdfs:label "The poem arguably explores the dangers of repressing emotions, such as anger."@en ;
  dcterms:modified "2026-02-12T08:59:21.648327Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2520-4
  a curric:KeyLearningPoint ;
  rdfs:label "Blake uses natural imagery, a staple of the Romantic Era."@en ;
  dcterms:modified "2026-02-12T08:59:21.648332Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28787-1
  a curric:KeyLearningPoint ;
  rdfs:label """Priestley establishes the Inspector as an ominous and imposing presence in Act 1."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648337Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28787-2
  a curric:KeyLearningPoint ;
  rdfs:label """Priestley reveals that the Inspector is not intimidated by class or societal power."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648341Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28787-3
  a curric:KeyLearningPoint ;
  rdfs:label "The Inspector’s interrogation style could be considered unorthodox."@en ;
  dcterms:modified "2026-02-12T08:59:21.648346Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28787-4
  a curric:KeyLearningPoint ;
  rdfs:label """The Inspector uses emotive and shocking language to provoke strong emotional reactions from the characters and audience."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648351Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28787-5
  a curric:KeyLearningPoint ;
  rdfs:label "There are multiple interpretations to explain the role of the Inspector."@en ;
  dcterms:modified "2026-02-12T08:59:21.648356Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2017-1
  a curric:KeyLearningPoint ;
  rdfs:label "An introduction could move from the general to the specific"@en ;
  dcterms:modified "2026-02-12T08:59:21.648651Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2017-2
  a curric:KeyLearningPoint ;
  rdfs:label "A conclusion will move from the specific to the general"@en ;
  dcterms:modified "2026-02-12T08:59:21.648656Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2017-3
  a curric:KeyLearningPoint ;
  rdfs:label """Topic sentences and discourse markers are useful for organising your ideas clearly"""@en ;
  dcterms:modified "2026-02-12T08:59:21.648661Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2017-4
  a curric:KeyLearningPoint ;
  rdfs:label "Paragraph outlines can be a useful tool for planning essays"@en ;
  dcterms:modified "2026-02-12T08:59:21.648665Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1639-1
  a curric:KeyLearningPoint ;
  rdfs:label "Lady Macbeth's behaviour subverts expectations of Jacobean women"@en ;
  dcterms:modified "2026-02-12T08:59:21.648670Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1639-2
  a curric:KeyLearningPoint ;
  rdfs:label """Lady Macbeth summons demonic spirits to 'unsex her’ and allow her to become powerful"""@en ;
  dcterms:modified "2026-02-12T08:59:21.648677Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1639-3
  a curric:KeyLearningPoint ;
  rdfs:label "Lady Macbeth doubts Macbeth's abilities"@en ;
  dcterms:modified "2026-02-12T08:59:21.648683Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1639-4
  a curric:KeyLearningPoint ;
  rdfs:label "Lady Macbeth is willing to go to extremes for what she wants"@en ;
  dcterms:modified "2026-02-12T08:59:21.648688Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1639-5
  a curric:KeyLearningPoint ;
  rdfs:label "Lady Macbeth wants Macbeth to be deceptive in his quest to become King"@en ;
  dcterms:modified "2026-02-12T08:59:21.648692Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1665-1
  a curric:KeyLearningPoint ;
  rdfs:label "Arguably, Stevenson is critical of trangressive scientists."@en ;
  dcterms:modified "2026-02-12T08:59:21.648697Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1665-2
  a curric:KeyLearningPoint ;
  rdfs:label """Stevenson plays on the real fears of scientific development and Darwinism in his novella."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648702Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1665-3
  a curric:KeyLearningPoint ;
  rdfs:label "Stevenson, raised a strict Calvinist, rejected his faith."@en ;
  dcterms:modified "2026-02-12T08:59:21.648706Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1665-4
  a curric:KeyLearningPoint ;
  rdfs:label "Calvinism was an evangelical branch of Christianity."@en ;
  dcterms:modified "2026-02-12T08:59:21.648711Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1665-5
  a curric:KeyLearningPoint ;
  rdfs:label """Stevenson is arguably very critical of the role Christianity played in the moral and political aspects of society."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648716Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2447-1
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, Eliot wrote under a pseudonym because she wanted to be seen as saying something important about society."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648721Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2447-2
  a curric:KeyLearningPoint ;
  rdfs:label """Eliot often wrote about rural life and the disparity between the poor and the rich."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648728Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2447-3
  a curric:KeyLearningPoint ;
  rdfs:label """Eliot would likely have critiqued the Industrial Revolution for the shift away from nature and the working conditions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648733Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2447-4
  a curric:KeyLearningPoint ;
  rdfs:label """The perspective of the poem could be a critique of the upper classes during the Industrial Revolution."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648737Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2447-5
  a curric:KeyLearningPoint ;
  rdfs:label """The poem suggests that the Industrial Revolution harmed nature and lead to oppression."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648742Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2127-1
  a curric:KeyLearningPoint ;
  rdfs:label "Purpose and audience will help you establish tone of voice"@en ;
  dcterms:modified "2026-02-12T08:59:21.648747Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2127-2
  a curric:KeyLearningPoint ;
  rdfs:label "Students do not need to write from their own perspective"@en ;
  dcterms:modified "2026-02-12T08:59:21.648751Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2127-3
  a curric:KeyLearningPoint ;
  rdfs:label "Inventing a character can help their work stand out from others"@en ;
  dcterms:modified "2026-02-12T08:59:21.648756Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2127-4
  a curric:KeyLearningPoint ;
  rdfs:label "Sarcasm and humour, when used well, can be effective in creating tone of voice"@en ;
  dcterms:modified "2026-02-12T08:59:21.648761Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2127-5
  a curric:KeyLearningPoint ;
  rdfs:label """Deciding a viewpoint and sticking to it is more effective than creating a balanced viewpoint"""@en ;
  dcterms:modified "2026-02-12T08:59:21.648768Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2357-1
  a curric:KeyLearningPoint ;
  rdfs:label "Poems can be linked by theme e.g. identity, belonging."@en ;
  dcterms:modified "2026-02-12T08:59:21.648773Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2357-2
  a curric:KeyLearningPoint ;
  rdfs:label """Poems can be linked by attitude, considering how the poet's feel about the subject they are addressing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648778Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2357-3
  a curric:KeyLearningPoint ;
  rdfs:label """Poems can be connected by how poets use similar imagery or techniques to address different issues."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648782Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2357-4
  a curric:KeyLearningPoint ;
  rdfs:label """Correlative and comparative conjunctions are useful for signposting the similarities and differences between both texts."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648787Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2357-5
  a curric:KeyLearningPoint ;
  rdfs:label """Comparatives can be used to evaluate the differences between attitudes or key ideas."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648792Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6258-1
  a curric:KeyLearningPoint ;
  rdfs:label "Topic sentences must be comparative when comparing texts."@en ;
  dcterms:modified "2026-02-12T08:59:21.648797Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6258-2
  a curric:KeyLearningPoint ;
  rdfs:label "Comparisons should be made between ideas, intentions, themes and messages."@en ;
  dcterms:modified "2026-02-12T08:59:21.648801Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6258-3
  a curric:KeyLearningPoint ;
  rdfs:label """Correlative and comparative conjunctions are a good way to signpost your comparative writing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648806Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6258-4
  a curric:KeyLearningPoint ;
  rdfs:label """Within paragraphs, evidence can move back and forth between the two poems and be linked with connectives."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648811Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6258-5
  a curric:KeyLearningPoint ;
  rdfs:label """Drawing a direct comparison of quotations should take place at least once across the essay."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648816Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29061-1
  a curric:KeyLearningPoint ;
  rdfs:label "Both Owen and Garland suggest that war can mean the loss of one’s identity."@en ;
  dcterms:modified "2026-02-12T08:59:21.648820Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29061-2
  a curric:KeyLearningPoint ;
  rdfs:label """Both Owen and Garland consider that returning from war can create a sense of isolation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648827Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29061-3
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, neither Owen nor Garland present the soldiers’ sacrifices as worthwhile."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648832Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29061-4
  a curric:KeyLearningPoint ;
  rdfs:label """Owen explores how physical changes can be associated with this loss of identity and feelings of isolation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648837Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29061-5
  a curric:KeyLearningPoint ;
  rdfs:label """Garland explores how ideological changes can be associated with this loss of identity and feelings of isolation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648842Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2339-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Poppies' can be compared to many of the other war poems in the anthology."@en ;
  dcterms:modified "2026-02-12T08:59:21.649094Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2339-2
  a curric:KeyLearningPoint ;
  rdfs:label """Unlike other war poems, 'Poppies' focuses on the relatives of soldiers who go off to war."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649098Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2339-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Poppies' could be compared with poems that explore inner conflict and themes of loss."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649103Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2339-4
  a curric:KeyLearningPoint ;
  rdfs:label """It's important to choose poems that complement each other and avoid tenuous links."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649108Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2339-5
  a curric:KeyLearningPoint ;
  rdfs:label """Comparative language enables us to signpost the similarities and differences between two poems."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649113Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2516-1
  a curric:KeyLearningPoint ;
  rdfs:label "Although not all poems describe the same wars, most poets are critical of war."@en ;
  dcterms:modified "2026-02-12T08:59:21.649120Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2516-2
  a curric:KeyLearningPoint ;
  rdfs:label "The poems explore the impact on soldiers, civilians and bystanders of war."@en ;
  dcterms:modified "2026-02-12T08:59:21.649125Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2516-3
  a curric:KeyLearningPoint ;
  rdfs:label """Comparative conjunctions can be used to compare themes, language, structure or form."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649130Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2516-4
  a curric:KeyLearningPoint ;
  rdfs:label "Superlatives can be used to evaluate the differences between attitudes."@en ;
  dcterms:modified "2026-02-12T08:59:21.649135Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29088-1
  a curric:KeyLearningPoint ;
  rdfs:label "The regularity of the rhyme may link to ideas of contentment in nature."@en ;
  dcterms:modified "2026-02-12T08:59:21.649159Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29088-2
  a curric:KeyLearningPoint ;
  rdfs:label """Alternatively, the irregularity in the rhythm may suggest a sense of being overwhelmed by nature."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649166Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29088-3
  a curric:KeyLearningPoint ;
  rdfs:label """The personification may create a sense of emotional connection between humanity and nature."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649172Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29088-4
  a curric:KeyLearningPoint ;
  rdfs:label """Alternatively, the personification may link to the Romantic sublime through the sentience of nature."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649176Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29088-5
  a curric:KeyLearningPoint ;
  rdfs:label """Using a simile to describe nature may create the impression of nature as unfamiliar and incomprehensible."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649181Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29089-1
  a curric:KeyLearningPoint ;
  rdfs:label """Both Wordsworth and McKay arguably suggest that a sense of belonging comes from an external source."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649186Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29089-2
  a curric:KeyLearningPoint ;
  rdfs:label """While both poets associate nature with belonging, McKay may also suggest a connection to one’s heritage is necessary."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649191Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29089-3
  a curric:KeyLearningPoint ;
  rdfs:label """We might suggest that Wordsworth implies that you just have to imagine the external source to feel happiness."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649195Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29089-4
  a curric:KeyLearningPoint ;
  rdfs:label """However, McKay arguably suggests that you have to physically be in that space to feel belonging."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649200Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29089-5
  a curric:KeyLearningPoint ;
  rdfs:label "We might see both poets as adhering to Romantic conventions."@en ;
  dcterms:modified "2026-02-12T08:59:21.649205Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2006-1
  a curric:KeyLearningPoint ;
  rdfs:label "Introductions and conclusions should follow a three part structure."@en ;
  dcterms:modified "2026-02-12T08:59:21.649490Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2006-2
  a curric:KeyLearningPoint ;
  rdfs:label "An excellent introduction should start with a general statement about the text."@en ;
  dcterms:modified "2026-02-12T08:59:21.649495Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2006-3
  a curric:KeyLearningPoint ;
  rdfs:label """An introduction should then have a more specific statement about the focus of the question, followed by a thesis."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649500Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2006-4
  a curric:KeyLearningPoint ;
  rdfs:label """A conclusion should include an evaluation of the effectiveness of the text in exploring the writer's purpose."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649504Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2429-1
  a curric:KeyLearningPoint ;
  rdfs:label """Shelley may have used figurative language to expose the parasitic nature of the monarchy."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649509Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2429-2
  a curric:KeyLearningPoint ;
  rdfs:label """Shelley could have used plosive sounds throughout the poem to emphasise the suffering of ordinary people."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649514Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2429-3
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, Shelley’s use of enjambment references the continuation of the people’s suffering."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649518Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2429-4
  a curric:KeyLearningPoint ;
  rdfs:label """Shelley’s non-conformity to the sonnet form may link to his revolutionary call for change."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649523Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29063-1
  a curric:KeyLearningPoint ;
  rdfs:label "Potentially, Hardy’s use of “they” could represent how war dehumanises people."@en ;
  dcterms:modified "2026-02-12T08:59:21.649530Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29063-2
  a curric:KeyLearningPoint ;
  rdfs:label "Arguably, the use of plosive consonants may depict the brutality of war."@en ;
  dcterms:modified "2026-02-12T08:59:21.649536Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29063-3
  a curric:KeyLearningPoint ;
  rdfs:label """The imagery of stars and regular rhyme may represent the inevitability of death in war."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649540Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29063-4
  a curric:KeyLearningPoint ;
  rdfs:label """Potentially, Hardy’s depiction of Drummer Hodge’s body becoming part of the land may relate to ideas of colonialism."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649545Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29063-5
  a curric:KeyLearningPoint ;
  rdfs:label """We might interpret ‘Drummer Hodge’ as a criticism of how colonialism comes at the cost of young men’s lives."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649550Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2433-1
  a curric:KeyLearningPoint ;
  rdfs:label """Mundair evokes the Hindu deities of Rama and Sita - possibly to emphasise the themes of isolation and mistrust."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649763Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2433-2
  a curric:KeyLearningPoint ;
  rdfs:label """Mundair implies that heritage is inseparable from the concept of self and identity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649767Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2433-3
  a curric:KeyLearningPoint ;
  rdfs:label """Mundair suggests that language is a physical part of who we are that nourishes and sustains us."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649772Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2433-4
  a curric:KeyLearningPoint ;
  rdfs:label """‘Name Journeys’ implies that the speaker felt their language was forcibly removed when they arrived in the UK."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649777Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2433-5
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, the ending of the poem implies that minority voices and their heritage are drowned out in the UK."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649781Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9253-1
  a curric:KeyLearningPoint ;
  rdfs:label """The Prelude is a semi-autobiographical poem which was published after Wordsworth's death."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649872Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9253-2
  a curric:KeyLearningPoint ;
  rdfs:label """Written in the first person, this nostalgic poem reflects on a moment when Wordsworth was ice-skating as a child."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649877Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9253-3
  a curric:KeyLearningPoint ;
  rdfs:label """Wordsworth had a deep appreciation for nature and spent much of his time outdoors."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649884Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9253-4
  a curric:KeyLearningPoint ;
  rdfs:label """The intense feelings of innocence and joy felt by Wordsworth as a child, is matched by the intense beauty of nature."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649889Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9253-5
  a curric:KeyLearningPoint ;
  rdfs:label """Wordsworth was one of the most influential Romantic poets, exploring the human experience in his poetry."""@en ;
  dcterms:modified "2026-02-12T08:59:21.649898Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6259-1
  a curric:KeyLearningPoint ;
  rdfs:label """Structurally, irregularity runs through the anthology and could reflect the unpredictable nature of life."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650178Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6259-2
  a curric:KeyLearningPoint ;
  rdfs:label """The lack of adherence to traditional forms could reflect how we need to move away from traditional ideas."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650183Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6259-3
  a curric:KeyLearningPoint ;
  rdfs:label """The presence of other voices and perspectives across the poems could reflect the connected nature of the world."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650188Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6259-4
  a curric:KeyLearningPoint ;
  rdfs:label """Connections of ‘big ideas’ that span centuries could reflect the nature of humanity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650192Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2500-1
  a curric:KeyLearningPoint ;
  rdfs:label """The speaker, a father, reminisces on the moment their child left to go to school after his first football match."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650197Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2500-2
  a curric:KeyLearningPoint ;
  rdfs:label """The speaker feels apprehensive about this parting, worrying the son is not ready."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650201Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2500-3
  a curric:KeyLearningPoint ;
  rdfs:label """The moment of separation was not the worst the speaker has experienced, but was the most impactful."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650209Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2500-4
  a curric:KeyLearningPoint ;
  rdfs:label """The speaker acknowledges and accepts that letting a child experience independence is a crucial part of parenting."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650214Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2500-5
  a curric:KeyLearningPoint ;
  rdfs:label """The poem is semi-autobiographical and Day-Lewis originally dedicated it to his eldest son, Sean."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650219Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2010-1
  a curric:KeyLearningPoint ;
  rdfs:label "‘Hard working’ describes quotes which are analytically rich."@en ;
  dcterms:modified "2026-02-12T08:59:21.650293Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2010-2
  a curric:KeyLearningPoint ;
  rdfs:label """Specific word classes, semantic fields or language device analysis can be used to analyse author's intention."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650299Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2010-3
  a curric:KeyLearningPoint ;
  rdfs:label "Time conjunctions allow you to contextualise quotes."@en ;
  dcterms:modified "2026-02-12T08:59:21.650304Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2010-4
  a curric:KeyLearningPoint ;
  rdfs:label "Conjunctions can be used to develop analytical comments."@en ;
  dcterms:modified "2026-02-12T08:59:21.650312Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2504-1
  a curric:KeyLearningPoint ;
  rdfs:label "Poets have been writing about wars for hundreds of years."@en ;
  dcterms:modified "2026-02-12T08:59:21.650316Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2504-2
  a curric:KeyLearningPoint ;
  rdfs:label "Sometimes poets sensationalise dying for your country as a form of propaganda."@en ;
  dcterms:modified "2026-02-12T08:59:21.650323Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2504-3
  a curric:KeyLearningPoint ;
  rdfs:label """Poets who have first hand experience of combat often depict the brutal reality of war."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650329Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2504-4
  a curric:KeyLearningPoint ;
  rdfs:label """Some of the poems in the Edexcel ‘Conflict’ anthology reflect on experiences of particular wars in history."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650334Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2517-1
  a curric:KeyLearningPoint ;
  rdfs:label "Carson lived in Belfast during the height of The Troubles."@en ;
  dcterms:modified "2026-02-12T08:59:21.650338Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2517-2
  a curric:KeyLearningPoint ;
  rdfs:label "The Troubles was a 30-year conflict between Nationalists and Unionists."@en ;
  dcterms:modified "2026-02-12T08:59:21.650343Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2517-3
  a curric:KeyLearningPoint ;
  rdfs:label "Belfast Confetti was the slang name given to homemade bombs."@en ;
  dcterms:modified "2026-02-12T08:59:21.650348Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2517-4
  a curric:KeyLearningPoint ;
  rdfs:label "The poem discusses the impact of the The Troubles on people living in Belfast."@en ;
  dcterms:modified "2026-02-12T08:59:21.650353Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2517-5
  a curric:KeyLearningPoint ;
  rdfs:label """Carson uses different punctuation symbols to explore the overwhelming emotions we associate with war."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650357Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29073-1
  a curric:KeyLearningPoint ;
  rdfs:label """The speaker of the poem is most likely Ewing herself, sharing her own personal experience."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650383Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29073-2
  a curric:KeyLearningPoint ;
  rdfs:label """The poem explores different types of love: romantic, familial, and love linked to self-identity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650388Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29073-3
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably the poem subverts the conventions of a love poem, offering a realistic presentation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650393Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29073-4
  a curric:KeyLearningPoint ;
  rdfs:label """The title foregrounds the importance of placing value on Black lived experiences and reimagining narratives."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650400Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29073-5
  a curric:KeyLearningPoint ;
  rdfs:label "Ewing has said that her work falls under the genre of Afrofuturism."@en ;
  dcterms:modified "2026-02-12T08:59:21.650405Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29070-1
  a curric:KeyLearningPoint ;
  rdfs:label """'Blackberry picking’ depicts a nostalgic childhood memory of picking blackberries in the summer."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650410Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29070-2
  a curric:KeyLearningPoint ;
  rdfs:label """We might interpret ‘Blackberry picking’ as an extended metaphor for growing up and losing childhood innocence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650414Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29070-3
  a curric:KeyLearningPoint ;
  rdfs:label """Heaney emphasises the shift from childhood innocence to a more unsettling understanding of the world."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650419Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29070-4
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably the poem is autobiographical and drawn from Heaney’s own experiences of growing up."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650424Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29070-5
  a curric:KeyLearningPoint ;
  rdfs:label """The poem emphasises neo-romantic themes such as personal experience, nature and the sublime."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650428Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2005-1
  a curric:KeyLearningPoint ;
  rdfs:label "Those who are uneducated are at the mercy of their leaders."@en ;
  dcterms:modified "2026-02-12T08:59:21.650554Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2005-2
  a curric:KeyLearningPoint ;
  rdfs:label "'Animal Farm' is Orwell's treatise on the power and importance of language."@en ;
  dcterms:modified "2026-02-12T08:59:21.650559Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2005-3
  a curric:KeyLearningPoint ;
  rdfs:label "Orwell shows those who are uneducated are prevented from being leaders."@en ;
  dcterms:modified "2026-02-12T08:59:21.650563Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2005-4
  a curric:KeyLearningPoint ;
  rdfs:label "Boxer is the most useful character to explore when discussing education."@en ;
  dcterms:modified "2026-02-12T08:59:21.650568Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2540-1
  a curric:KeyLearningPoint ;
  rdfs:label "The poem is set in spring and depicts nature as calm and peaceful."@en ;
  dcterms:modified "2026-02-12T08:59:21.650594Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2540-2
  a curric:KeyLearningPoint ;
  rdfs:label """Wordsworth implies that nature can offer an escape from life and a chance to simply relax."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650601Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2540-3
  a curric:KeyLearningPoint ;
  rdfs:label "The poem was written during a time of violent, political upheaval."@en ;
  dcterms:modified "2026-02-12T08:59:21.650605Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2540-4
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, Wordsworth may have depicted nature as calm as a contrast to the divisions in humanity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650610Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2437-1
  a curric:KeyLearningPoint ;
  rdfs:label """The image of the train in the title could symbolise ideas of journeys, growth, and progress."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650801Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2437-2
  a curric:KeyLearningPoint ;
  rdfs:label """The specific use of a Quaker to make an ignorant mistake could be Berry’s way of saying we all make mistakes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650805Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2437-3
  a curric:KeyLearningPoint ;
  rdfs:label """Potentially, the title could symbolise how we are all ultimately journeying around the same place: Earth."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650810Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2437-4
  a curric:KeyLearningPoint ;
  rdfs:label "Berry’s work often explores the experiences of Caribbean migrants."@en ;
  dcterms:modified "2026-02-12T08:59:21.650814Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2510-1
  a curric:KeyLearningPoint ;
  rdfs:label "The poem was written during the Boer War."@en ;
  dcterms:modified "2026-02-12T08:59:21.650881Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2510-2
  a curric:KeyLearningPoint ;
  rdfs:label "Hardy was very critical of this war and the British Empire’s military tactics."@en ;
  dcterms:modified "2026-02-12T08:59:21.650886Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2510-3
  a curric:KeyLearningPoint ;
  rdfs:label """Hardy was suspicious that the British Empire wanted to exploit South Africa’s natural resources."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650890Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2510-4
  a curric:KeyLearningPoint ;
  rdfs:label "In the poem, Hardy explores the similarities between two ‘enemy’ soldiers."@en ;
  dcterms:modified "2026-02-12T08:59:21.650895Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2510-5
  a curric:KeyLearningPoint ;
  rdfs:label """He implies that perceiving war as simply a battle between good and evil dehumanises the people fighting,"""@en ;
  dcterms:modified "2026-02-12T08:59:21.650899Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2551-1
  a curric:KeyLearningPoint ;
  rdfs:label "Grace Nichols was born in Guyana before immigrating to Britain as an adult."@en ;
  dcterms:modified "2026-02-12T08:59:21.650904Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2551-2
  a curric:KeyLearningPoint ;
  rdfs:label """Nichol's poetry is often characterised by Caribbean rhythms and culture and influenced by Guyanese folklore."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650911Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2551-3
  a curric:KeyLearningPoint ;
  rdfs:label """The poem's title 'Island Man' could reflect both the idyllic Caribbean island of his birth and Great Britain."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650916Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2551-4
  a curric:KeyLearningPoint ;
  rdfs:label "The poem explores the life of a Caribbean born man, living in London."@en ;
  dcterms:modified "2026-02-12T08:59:21.650920Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2551-5
  a curric:KeyLearningPoint ;
  rdfs:label "Each night, Island Man dreams of his idyllic island home."@en ;
  dcterms:modified "2026-02-12T08:59:21.650925Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29082-1
  a curric:KeyLearningPoint ;
  rdfs:label """The use of iambic pentameter may represent how homelessness is a regular occurrence in society."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650930Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29082-2
  a curric:KeyLearningPoint ;
  rdfs:label """The enjambment may represent how society and people continue without stopping to help."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650934Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29082-3
  a curric:KeyLearningPoint ;
  rdfs:label """The metaphorical imagery of decomposition could represent the dehumanisation of the beggar."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650939Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29082-4
  a curric:KeyLearningPoint ;
  rdfs:label "The final word “solitude” could represent how alone the old man is in society."@en ;
  dcterms:modified "2026-02-12T08:59:21.650943Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29082-5
  a curric:KeyLearningPoint ;
  rdfs:label """The flippant language such as “thrown aside” arguably shows how dehumanised the beggar is."""@en ;
  dcterms:modified "2026-02-12T08:59:21.650948Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28048-1
  a curric:KeyLearningPoint ;
  rdfs:label "Context refers to historical, social, literary and biographical information."@en ;
  dcterms:modified "2026-02-12T08:59:21.651044Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28048-2
  a curric:KeyLearningPoint ;
  rdfs:label """Literary context is often overlooked, but can be an effective way to elevate responses."""@en ;
  dcterms:modified "2026-02-12T08:59:21.651049Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28048-3
  a curric:KeyLearningPoint ;
  rdfs:label "Context should be woven throughout your essay."@en ;
  dcterms:modified "2026-02-12T08:59:21.651053Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28048-4
  a curric:KeyLearningPoint ;
  rdfs:label "Weaving context into your thesis can be a powerful way to start an essay."@en ;
  dcterms:modified "2026-02-12T08:59:21.651058Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28784-1
  a curric:KeyLearningPoint ;
  rdfs:label "A theme is the main idea or message in a text."@en ;
  dcterms:modified "2026-02-12T08:59:21.651174Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28784-2
  a curric:KeyLearningPoint ;
  rdfs:label "Priestley explores the themes of social responsibility, age, class and power."@en ;
  dcterms:modified "2026-02-12T08:59:21.651179Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28784-3
  a curric:KeyLearningPoint ;
  rdfs:label "Some themes can be considered timeless and universal."@en ;
  dcterms:modified "2026-02-12T08:59:21.651184Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28784-4
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, themes in ‘An Inspector Calls’ are still relevant today which is why it's considered an important text."""@en ;
  dcterms:modified "2026-02-12T08:59:21.651188Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2060-1
  a curric:KeyLearningPoint ;
  rdfs:label "Context refers to historical, social, literary and biographical information."@en ;
  dcterms:modified "2026-02-12T08:59:21.651438Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2060-2
  a curric:KeyLearningPoint ;
  rdfs:label "Context should not be presented as isolated facts."@en ;
  dcterms:modified "2026-02-12T08:59:21.651442Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2060-3
  a curric:KeyLearningPoint ;
  rdfs:label "Context should be relevant to the analysis and woven in the response."@en ;
  dcterms:modified "2026-02-12T08:59:21.651447Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2060-4
  a curric:KeyLearningPoint ;
  rdfs:label """Context should develop your ideas and give an insight into the writer’s purpose and intention."""@en ;
  dcterms:modified "2026-02-12T08:59:21.651451Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2515-1
  a curric:KeyLearningPoint ;
  rdfs:label "There are many juxtaposed images of beauty and destruction in the poem."@en ;
  dcterms:modified "2026-02-12T08:59:21.651475Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2515-2
  a curric:KeyLearningPoint ;
  rdfs:label "The past tense highlights what is lost in war."@en ;
  dcterms:modified "2026-02-12T08:59:21.651479Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2515-3
  a curric:KeyLearningPoint ;
  rdfs:label "The poem ends in the present tense, creating a sense of continued loss."@en ;
  dcterms:modified "2026-02-12T08:59:21.651484Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2515-4
  a curric:KeyLearningPoint ;
  rdfs:label """The poem is written in free verse which could represent the lack of harmony and peace war brings."""@en ;
  dcterms:modified "2026-02-12T08:59:21.651491Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2515-5
  a curric:KeyLearningPoint ;
  rdfs:label """Levertov uses symbolism and repetition to emphasise the contrast between life before and after the war."""@en ;
  dcterms:modified "2026-02-12T08:59:21.651918Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29086-1
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, the use of the sonnet form associates the speaker’s home with ideas of love."""@en ;
  dcterms:modified "2026-02-12T08:59:21.651923Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29086-2
  a curric:KeyLearningPoint ;
  rdfs:label """Specifically, the use of a regular rhyme could point to ideas of peace and contentment."""@en ;
  dcterms:modified "2026-02-12T08:59:21.651928Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29086-3
  a curric:KeyLearningPoint ;
  rdfs:label """Furthermore, the use of euphony associates ideas of peace and harmony with the speaker’s home."""@en ;
  dcterms:modified "2026-02-12T08:59:21.651933Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29086-4
  a curric:KeyLearningPoint ;
  rdfs:label """The word “delicious” might suggest that the speaker’s home and hertiage sustain them."""@en ;
  dcterms:modified "2026-02-12T08:59:21.651937Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29086-5
  a curric:KeyLearningPoint ;
  rdfs:label """However, the references to discontent might represent how the speaker is not physically where they feel at home."""@en ;
  dcterms:modified "2026-02-12T08:59:21.651942Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1708-1
  a curric:KeyLearningPoint ;
  rdfs:label """The poem is based on Kamikaze pilots in WW2 who sacrificed their lives whilst attacking enemy ships."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652062Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1708-2
  a curric:KeyLearningPoint ;
  rdfs:label "Garland explores national vs personal duty in the poem."@en ;
  dcterms:modified "2026-02-12T08:59:21.652066Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1708-3
  a curric:KeyLearningPoint ;
  rdfs:label """In the poem, thoughts of nature and family seem to make the pilot turn back on his mission."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652070Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1708-4
  a curric:KeyLearningPoint ;
  rdfs:label "The Kamikaze pilot is shunned upon returning home."@en ;
  dcterms:modified "2026-02-12T08:59:21.652075Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1708-5
  a curric:KeyLearningPoint ;
  rdfs:label "Garland explores the importance placed upon honour and national duty."@en ;
  dcterms:modified "2026-02-12T08:59:21.652080Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1682-1
  a curric:KeyLearningPoint ;
  rdfs:label """Blake explores the tensions between the human passions and the repressive nature of social and political conventions"""@en ;
  dcterms:modified "2026-02-12T08:59:21.652085Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1682-2
  a curric:KeyLearningPoint ;
  rdfs:label "‘Songs of Innocence and Experience’ investigates how society corrupts innocence"@en ;
  dcterms:modified "2026-02-12T08:59:21.652091Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1682-3
  a curric:KeyLearningPoint ;
  rdfs:label """Blake was critical of social inequality created by institutions: the Church, Government, the monarchy"""@en ;
  dcterms:modified "2026-02-12T08:59:21.652096Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1682-4
  a curric:KeyLearningPoint ;
  rdfs:label """Across ‘Songs of Innocence and Experience’ he highlights the effect of the inaction of callous leaders on the vulnerable"""@en ;
  dcterms:modified "2026-02-12T08:59:21.652100Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1682-5
  a curric:KeyLearningPoint ;
  rdfs:label """Blake was a radical, inspired by Rousseau and the French Revolution, to warn about the restrictions on freedom"""@en ;
  dcterms:modified "2026-02-12T08:59:21.652105Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6262-1
  a curric:KeyLearningPoint ;
  rdfs:label "It's important to highlight the key theme within the question."@en ;
  dcterms:modified "2026-02-12T08:59:21.652553Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6262-2
  a curric:KeyLearningPoint ;
  rdfs:label """It's important to understand how the poems you choose to compare link to the theme."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652558Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6262-3
  a curric:KeyLearningPoint ;
  rdfs:label "Ideally, your analytical essay will have at least three analytical paragraphs."@en ;
  dcterms:modified "2026-02-12T08:59:21.652562Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6262-4
  a curric:KeyLearningPoint ;
  rdfs:label "Each analytical paragraph needs a topic sentence and supporting detail."@en ;
  dcterms:modified "2026-02-12T08:59:21.652567Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6262-5
  a curric:KeyLearningPoint ;
  rdfs:label "Single paragraph outlines can help you create effective plans."@en ;
  dcterms:modified "2026-02-12T08:59:21.652571Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2035-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘Tissue’ and ‘London’ explore the futility of hierarchy and systemic control in society."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652649Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2035-2
  a curric:KeyLearningPoint ;
  rdfs:label """Both ‘Tissue’ and ‘Extract from The Prelude’ show the triumph of nature over human pride."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652654Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2035-3
  a curric:KeyLearningPoint ;
  rdfs:label "‘Tissue’ and ‘Ozymandias’ explore the ephemerality of human power."@en ;
  dcterms:modified "2026-02-12T08:59:21.652660Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2035-4
  a curric:KeyLearningPoint ;
  rdfs:label """‘Tissue’ and ‘Ozymandias’ explore the failed attempts of man to immortalise their power through man made structures."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652667Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1683-1
  a curric:KeyLearningPoint ;
  rdfs:label """Rigid structure of four quatrains written in octosyllabic lines mirrors the idea that people have no freedom in the city"""@en ;
  dcterms:modified "2026-02-12T08:59:21.652672Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1683-2
  a curric:KeyLearningPoint ;
  rdfs:label """Blake conveys his social commentary through the dramatic monologue of a first person narrator"""@en ;
  dcterms:modified "2026-02-12T08:59:21.652677Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1683-3
  a curric:KeyLearningPoint ;
  rdfs:label """Blake uses lots of repetition in the poem to show how deeply rooted the social issues that he describes are"""@en ;
  dcterms:modified "2026-02-12T08:59:21.652682Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1683-4
  a curric:KeyLearningPoint ;
  rdfs:label "Blake uses juxtaposition to illustrate how easily innocence is lost in the city"@en ;
  dcterms:modified "2026-02-12T08:59:21.652686Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1683-5
  a curric:KeyLearningPoint ;
  rdfs:label """Blake uses metaphors to highlight the effect of the inaction of leaders and powerful institutions on the vulnerable"""@en ;
  dcterms:modified "2026-02-12T08:59:21.652691Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1684-1
  a curric:KeyLearningPoint ;
  rdfs:label """A comparative introduction should give a broad similarity in theme and nuanced differences within that similarity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652695Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1684-2
  a curric:KeyLearningPoint ;
  rdfs:label """A purposeful thesis should refer to the poets’ intentions or messages behind the common theme."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652700Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1684-3
  a curric:KeyLearningPoint ;
  rdfs:label """Use comparative and correlative conjunctions to structure introductions and topic sentences."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652707Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1684-4
  a curric:KeyLearningPoint ;
  rdfs:label "Topic sentences should lead with big ideas not the poets’ methods."@en ;
  dcterms:modified "2026-02-12T08:59:21.652712Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6249-1
  a curric:KeyLearningPoint ;
  rdfs:label "Eliot arguably creates a pessimistic tone through the bleak and dreary imagery."@en ;
  dcterms:modified "2026-02-12T08:59:21.652737Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6249-2
  a curric:KeyLearningPoint ;
  rdfs:label """We might interpret the rhythm and enjambment in the poem as enhancing this unrelenting sense of hopelessness."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652742Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6249-3
  a curric:KeyLearningPoint ;
  rdfs:label "Eliot arguably creates an oppressive atmosphere through the punitive imagery."@en ;
  dcterms:modified "2026-02-12T08:59:21.652747Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6249-4
  a curric:KeyLearningPoint ;
  rdfs:label """The single stanza structure could be interpreted as showing how confined the people are."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652751Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6249-5
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, Eliot is attributing this pessimism and oppression to the Industrial Revolution."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652756Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2444-1
  a curric:KeyLearningPoint ;
  rdfs:label "The speaker of ‘Shall earth no more inspire me’ is arguably nature itself."@en ;
  dcterms:modified "2026-02-12T08:59:21.652760Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2444-2
  a curric:KeyLearningPoint ;
  rdfs:label "The speaker is talking directly to someone who has stopped appreciating nature."@en ;
  dcterms:modified "2026-02-12T08:59:21.652765Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2444-3
  a curric:KeyLearningPoint ;
  rdfs:label "The speaker is trying to convince the listener to return to nature."@en ;
  dcterms:modified "2026-02-12T08:59:21.652769Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2444-4
  a curric:KeyLearningPoint ;
  rdfs:label """Nature is portrayed as both comforting and powerful which feeds into Romantic ideas of the sublime."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652774Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2358-1
  a curric:KeyLearningPoint ;
  rdfs:label "Topic sentences need to be clear, comparative and linked to the question."@en ;
  dcterms:modified "2026-02-12T08:59:21.652823Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2358-2
  a curric:KeyLearningPoint ;
  rdfs:label "Relevant quotations from the text are used to justify arguments."@en ;
  dcterms:modified "2026-02-12T08:59:21.652828Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2358-3
  a curric:KeyLearningPoint ;
  rdfs:label """Context can be used to develop arguments and shape our interpretations of a text."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652832Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2358-4
  a curric:KeyLearningPoint ;
  rdfs:label """Responses should focus on the intention of the author to avoid re-telling the story of the poem."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652837Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2358-5
  a curric:KeyLearningPoint ;
  rdfs:label """Comparative conjunctions should be used to compare language, form and structure of poems."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652841Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2356-1
  a curric:KeyLearningPoint ;
  rdfs:label """Chingonyi, Dharker and Kunial's poetry all appear to show a yearning for a sense of belonging."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652846Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2356-2
  a curric:KeyLearningPoint ;
  rdfs:label """They also explore the links between belonging, dislocation and individual identity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652851Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2356-3
  a curric:KeyLearningPoint ;
  rdfs:label """Dharker's speaker yearns to escape her current life by becoming someone else who is more confident and 'cool'."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652855Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2356-4
  a curric:KeyLearningPoint ;
  rdfs:label """Chingonyi's poem feels more reflective, considering how different life may have been if the speaker had not left Zambia."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652860Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2356-5
  a curric:KeyLearningPoint ;
  rdfs:label """Kunial takes a philosophical approach to thinking about identity and belonging, exploring the fine line between them."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652867Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28796-1
  a curric:KeyLearningPoint ;
  rdfs:label """Essays are extended pieces of writing in which you establish and explain your own ideas."""@en ;
  dcterms:modified "2026-02-12T08:59:21.652997Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28796-2
  a curric:KeyLearningPoint ;
  rdfs:label """Underlining keywords and annotating an essay question helps direct your thinking."""@en ;
  dcterms:modified "2026-02-12T08:59:21.653002Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28796-3
  a curric:KeyLearningPoint ;
  rdfs:label "It is useful to connect keywords to plot points and themes."@en ;
  dcterms:modified "2026-02-12T08:59:21.653007Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28796-4
  a curric:KeyLearningPoint ;
  rdfs:label "Essays begin with a thesis."@en ;
  dcterms:modified "2026-02-12T08:59:21.653012Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28796-5
  a curric:KeyLearningPoint ;
  rdfs:label "A thesis is an idea supported by the whole text."@en ;
  dcterms:modified "2026-02-12T08:59:21.653016Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2330-1
  a curric:KeyLearningPoint ;
  rdfs:label """Browning uses pathetic fallacy to reflect the emotional turmoil the speaker initially feels."""@en ;
  dcterms:modified "2026-02-12T08:59:21.659851Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2330-2
  a curric:KeyLearningPoint ;
  rdfs:label """Browning uses symbolism to convey the taboo nature of Porphyria's sexuality and the illicit relationship."""@en ;
  dcterms:modified "2026-02-12T08:59:21.659855Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2330-3
  a curric:KeyLearningPoint ;
  rdfs:label """Browning reveals the speaker's desire to exert total control over Porphyria by killing her."""@en ;
  dcterms:modified "2026-02-12T08:59:21.659860Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2330-4
  a curric:KeyLearningPoint ;
  rdfs:label """In the resolution, Browning conveys the speaker's psychotic lack of remorse for his gruesome murder."""@en ;
  dcterms:modified "2026-02-12T08:59:21.659864Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2330-5
  a curric:KeyLearningPoint ;
  rdfs:label """Browning uses the form of a dramatic monologue to explore the motivations and psyche of a murderer."""@en ;
  dcterms:modified "2026-02-12T08:59:21.659869Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2445-1
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, Brontë personifies nature in order to encourage the reader to form a connection with nature."""@en ;
  dcterms:modified "2026-02-12T08:59:21.659876Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2445-2
  a curric:KeyLearningPoint ;
  rdfs:label """Brontë largely uses a regular rhyme of ABAB which may reflect the calm voice of the speaker."""@en ;
  dcterms:modified "2026-02-12T08:59:21.659881Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2445-3
  a curric:KeyLearningPoint ;
  rdfs:label """The deviation to AAAA in the final stanza could signify that the speaker and listener are connecting."""@en ;
  dcterms:modified "2026-02-12T08:59:21.659885Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2445-4
  a curric:KeyLearningPoint ;
  rdfs:label """The extra unstressed syllable on the first and third lines could add to the soothing nature of the speaker."""@en ;
  dcterms:modified "2026-02-12T08:59:21.659892Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28049-1
  a curric:KeyLearningPoint ;
  rdfs:label "Morality plays personify virtues and vices to teach moral lessons."@en ;
  dcterms:modified "2026-02-12T08:59:21.660021Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28049-2
  a curric:KeyLearningPoint ;
  rdfs:label "Priestley uses the Inspector as the embodiment of virtue."@en ;
  dcterms:modified "2026-02-12T08:59:21.660025Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28049-3
  a curric:KeyLearningPoint ;
  rdfs:label "Eva Smith represents social injustice, subverting the ‘everyman’ protagonist."@en ;
  dcterms:modified "2026-02-12T08:59:21.660030Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28049-4
  a curric:KeyLearningPoint ;
  rdfs:label """The Birlings act as vice characters, highlighting moral failings of the upper class."""@en ;
  dcterms:modified "2026-02-12T08:59:21.660034Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28049-5
  a curric:KeyLearningPoint ;
  rdfs:label """The play’s structure mirrors a morality play, leading to judgment and reflection."""@en ;
  dcterms:modified "2026-02-12T08:59:21.660039Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2061-1
  a curric:KeyLearningPoint ;
  rdfs:label """At first the windmill signifies the battle for power between Snowball and Napoleon."""@en ;
  dcterms:modified "2026-02-12T08:59:21.662502Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2061-2
  a curric:KeyLearningPoint ;
  rdfs:label """The windmill becomes a symbol of hope when it is viewed as the key to a 'three day week'."""@en ;
  dcterms:modified "2026-02-12T08:59:21.662507Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2061-3
  a curric:KeyLearningPoint ;
  rdfs:label """The windmill becomes a symbol of corruption as the animals work harder than ever to rebuild it."""@en ;
  dcterms:modified "2026-02-12T08:59:21.662511Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2061-4
  a curric:KeyLearningPoint ;
  rdfs:label "The windmill physically represents the cyclical nature of the novella."@en ;
  dcterms:modified "2026-02-12T08:59:21.662516Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28067-1
  a curric:KeyLearningPoint ;
  rdfs:label """Victorian London was noisy, overcrowded, and diverse, with people from various cultural backgrounds and social classes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.663244Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28067-2
  a curric:KeyLearningPoint ;
  rdfs:label """The Industrial Revolution transformed London, causing pollution, a huge class divide and feelings of alienation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.663248Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28067-3
  a curric:KeyLearningPoint ;
  rdfs:label """The novella explores human duality in Victorian society, reflecting conflict between progress and primal instincts."""@en ;
  dcterms:modified "2026-02-12T08:59:21.663253Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28067-4
  a curric:KeyLearningPoint ;
  rdfs:label """Stevenson's descriptions of setting create an ominous atmosphere, perhaps implying Hyde is an evil, immoral character."""@en ;
  dcterms:modified "2026-02-12T08:59:21.663257Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28067-5
  a curric:KeyLearningPoint ;
  rdfs:label """Descriptions of the fog suggest the progress of the Industrial Revolution obscured a darker side of Victorian society."""@en ;
  dcterms:modified "2026-02-12T08:59:21.663262Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1686-1
  a curric:KeyLearningPoint ;
  rdfs:label """Initially, Wordsworth presents himself as a hero, later nature is presented as an extraordinary presence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.664531Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1686-2
  a curric:KeyLearningPoint ;
  rdfs:label """Imagery of man’s arrogant efforts to dominate nature are repeated across the poem, warning of his inferiority to nature."""@en ;
  dcterms:modified "2026-02-12T08:59:21.664536Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1686-3
  a curric:KeyLearningPoint ;
  rdfs:label """Pretty aural and visual imagery early in the poem contrasts with cacophony after the volta."""@en ;
  dcterms:modified "2026-02-12T08:59:21.664540Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1686-4
  a curric:KeyLearningPoint ;
  rdfs:label """The monosyllabic description of the mountain shows how nature transcends the world of man."""@en ;
  dcterms:modified "2026-02-12T08:59:21.664545Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1686-5
  a curric:KeyLearningPoint ;
  rdfs:label """The poem explores both power and conflict: man's conflict with himself after learning the true power of nature."""@en ;
  dcterms:modified "2026-02-12T08:59:21.664549Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2542-1
  a curric:KeyLearningPoint ;
  rdfs:label """Landon's poem is a nostalgic memory of her time spent playing with her brother in their garden."""@en ;
  dcterms:modified "2026-02-12T08:59:21.664682Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2542-2
  a curric:KeyLearningPoint ;
  rdfs:label """The use of "we" and the semantic field of happiness arguably represents Landon's happy childhood with her brother."""@en ;
  dcterms:modified "2026-02-12T08:59:21.664686Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2542-3
  a curric:KeyLearningPoint ;
  rdfs:label """However, the "mourn[ing]" at the end of the poem could represent their distance as adults."""@en ;
  dcterms:modified "2026-02-12T08:59:21.664691Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2542-4
  a curric:KeyLearningPoint ;
  rdfs:label """Landon's poem may be read as a reminder than childhood is temporary and relationships can change."""@en ;
  dcterms:modified "2026-02-12T08:59:21.664696Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2364-1
  a curric:KeyLearningPoint ;
  rdfs:label "Arguably, Pinnock centres women’s voices in ‘Leave Taking’."@en ;
  dcterms:modified "2026-02-12T08:59:21.667630Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2364-2
  a curric:KeyLearningPoint ;
  rdfs:label "The character of Brod is the only onstage male character."@en ;
  dcterms:modified "2026-02-12T08:59:21.667634Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2364-3
  a curric:KeyLearningPoint ;
  rdfs:label "Brod serves many important dramatic functions."@en ;
  dcterms:modified "2026-02-12T08:59:21.667639Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2364-4
  a curric:KeyLearningPoint ;
  rdfs:label "Enid’s husband is an important off stage character."@en ;
  dcterms:modified "2026-02-12T08:59:21.667644Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2364-5
  a curric:KeyLearningPoint ;
  rdfs:label """References to Enid’s husband help audiences understand the character of Enid and aspects of 1980s Britain."""@en ;
  dcterms:modified "2026-02-12T08:59:21.667648Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9232-1
  a curric:KeyLearningPoint ;
  rdfs:label "Wilfred Owen was a soldier who fought and died in WWI."@en ;
  dcterms:modified "2026-02-12T08:59:21.667918Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9232-2
  a curric:KeyLearningPoint ;
  rdfs:label """There was a huge disparity in the glorified perception of war, versus the bleak reality of it."""@en ;
  dcterms:modified "2026-02-12T08:59:21.667924Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9232-3
  a curric:KeyLearningPoint ;
  rdfs:label """The poem dismantles and condemns the perception of war being promoted by propaganda."""@en ;
  dcterms:modified "2026-02-12T08:59:21.667929Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9232-4
  a curric:KeyLearningPoint ;
  rdfs:label "The poem paints a graphic image of soldiers who are caught in a gas attack."@en ;
  dcterms:modified "2026-02-12T08:59:21.667936Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9232-5
  a curric:KeyLearningPoint ;
  rdfs:label "Owen used his poetry as a means of exposing the true futility and horror of war."@en ;
  dcterms:modified "2026-02-12T08:59:21.667941Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2331-1
  a curric:KeyLearningPoint ;
  rdfs:label """Mew and Browning describe dysfunctional relationships whilst Nagra describes an unconventional yet loving relationship."""@en ;
  dcterms:modified "2026-02-12T08:59:21.673549Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2331-2
  a curric:KeyLearningPoint ;
  rdfs:label """Both Nagra and Browning describe female characters who are sexually liberated and defy societal expectations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.673553Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2331-3
  a curric:KeyLearningPoint ;
  rdfs:label """Mew and Browning depict dramatic monologues where speakers have dangerously misogynistic mindsets."""@en ;
  dcterms:modified "2026-02-12T08:59:21.673557Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2331-4
  a curric:KeyLearningPoint ;
  rdfs:label "Mew and Browning both use natural imagery to represent the speaker's emotions."@en ;
  dcterms:modified "2026-02-12T08:59:21.673562Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2331-5
  a curric:KeyLearningPoint ;
  rdfs:label "Nagra is the only poet who describes a genuinely romantic relationship."@en ;
  dcterms:modified "2026-02-12T08:59:21.673566Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2428-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘England in 1819’ is arguably a criticism of powerful institutions who are blind to the suffering of ordinary folk."""@en ;
  dcterms:modified "2026-02-12T08:59:21.673571Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2428-2
  a curric:KeyLearningPoint ;
  rdfs:label "The Peterloo Massacre happened in England in 1819."@en ;
  dcterms:modified "2026-02-12T08:59:21.673578Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2428-3
  a curric:KeyLearningPoint ;
  rdfs:label """The Peterloo Massacre happened at a protest demanding the reform of parliamentary representation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.673583Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2428-4
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, Shelley criticises the monarchy, the Church and parliament for not acting in the people’s best interests."""@en ;
  dcterms:modified "2026-02-12T08:59:21.673587Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2435-1
  a curric:KeyLearningPoint ;
  rdfs:label """The poem 'pot' expresses frustration at how artefacts are stolen from cultures globally and housed in Western museums."""@en ;
  dcterms:modified "2026-02-12T08:59:21.673592Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2435-2
  a curric:KeyLearningPoint ;
  rdfs:label """Objects are valuable artefacts because they tell us about how people lived and what they valued artistically."""@en ;
  dcterms:modified "2026-02-12T08:59:21.673598Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2435-3
  a curric:KeyLearningPoint ;
  rdfs:label """'pot' reminds the reader that these artefacts represent the identities of other cultures and do not belong in museums."""@en ;
  dcterms:modified "2026-02-12T08:59:21.673603Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2495-1
  a curric:KeyLearningPoint ;
  rdfs:label """Duffy opens the poem with a vignette of the mother as glamorous and admirable in her youth before the speaker is born."""@en ;
  dcterms:modified "2026-02-12T08:59:21.676150Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2495-2
  a curric:KeyLearningPoint ;
  rdfs:label """Duffy uses imagery to convey the sense of awe and wonder felt towards a parental figure."""@en ;
  dcterms:modified "2026-02-12T08:59:21.676155Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2495-3
  a curric:KeyLearningPoint ;
  rdfs:label """Duffy uses a rhetorical question to suggest the guilt the speaker feels at curtailing the mother's glamorous life."""@en ;
  dcterms:modified "2026-02-12T08:59:21.676159Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2495-4
  a curric:KeyLearningPoint ;
  rdfs:label """Duffy uses imagery to suggest the consolation a close maternal bond can bring to both mother and child."""@en ;
  dcterms:modified "2026-02-12T08:59:21.676163Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2495-5
  a curric:KeyLearningPoint ;
  rdfs:label """Duffy uses enjambment and caesuras to convey the speaker’s guilt about the effect she had on her mother’s life."""@en ;
  dcterms:modified "2026-02-12T08:59:21.676168Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1704-1
  a curric:KeyLearningPoint ;
  rdfs:label """The title could be suggestive of remembrance, the many grieving mothers of war or the outward display of deeper grief."""@en ;
  dcterms:modified "2026-02-12T08:59:21.676697Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1704-2
  a curric:KeyLearningPoint ;
  rdfs:label """Bird imagery may reflect the mother letting go of her son or the way in which she represses her grief."""@en ;
  dcterms:modified "2026-02-12T08:59:21.676701Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1704-3
  a curric:KeyLearningPoint ;
  rdfs:label """Two sestets either side of two longer stanzas may suggest the mother trying hard to contain her emotions for her son."""@en ;
  dcterms:modified "2026-02-12T08:59:21.676709Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1704-4
  a curric:KeyLearningPoint ;
  rdfs:label """The domestic and textile imagery may also show the mother’s containment of grief."""@en ;
  dcterms:modified "2026-02-12T08:59:21.676714Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1704-5
  a curric:KeyLearningPoint ;
  rdfs:label """Textile imagery also suggests the limitations of the mother’s ability to protect her son outside of the home."""@en ;
  dcterms:modified "2026-02-12T08:59:21.676721Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2547-1
  a curric:KeyLearningPoint ;
  rdfs:label """The personification of the sun in Hood's childhood creates a joyous image of happy memories."""@en ;
  dcterms:modified "2026-02-12T08:59:21.676726Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2547-2
  a curric:KeyLearningPoint ;
  rdfs:label """There is a contrast to the way Hood personifies the nighttime, perhaps reflecting his ill health in adulthood."""@en ;
  dcterms:modified "2026-02-12T08:59:21.676730Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2547-3
  a curric:KeyLearningPoint ;
  rdfs:label """The personification of nature may suggest an emotional connection to nature that links to the theme of belonging."""@en ;
  dcterms:modified "2026-02-12T08:59:21.676735Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2547-4
  a curric:KeyLearningPoint ;
  rdfs:label """The use of colour imagery could represent the idealistic view of the speaker’s childhood."""@en ;
  dcterms:modified "2026-02-12T08:59:21.676739Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2547-5
  a curric:KeyLearningPoint ;
  rdfs:label """The use of punctuation could reflect both their childhood joy and the lack of joy in their adult life."""@en ;
  dcterms:modified "2026-02-12T08:59:21.676744Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2411-1
  a curric:KeyLearningPoint ;
  rdfs:label """A dramatic function is the purpose of the character: how they help the playwright develop ideas they want to explore."""@en ;
  dcterms:modified "2026-02-12T08:59:21.678064Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2411-2
  a curric:KeyLearningPoint ;
  rdfs:label "Pinnock could have cut the character of Brod, but chose not to."@en ;
  dcterms:modified "2026-02-12T08:59:21.678068Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2411-3
  a curric:KeyLearningPoint ;
  rdfs:label "Brod offers insight into Enid's past."@en ;
  dcterms:modified "2026-02-12T08:59:21.678075Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2411-4
  a curric:KeyLearningPoint ;
  rdfs:label "Brod voices political and social criticisms."@en ;
  dcterms:modified "2026-02-12T08:59:21.678083Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9224-1
  a curric:KeyLearningPoint ;
  rdfs:label """The title raises questions about what beauty truly is - is it something we have within us, or something external to us?"""@en ;
  dcterms:modified "2026-02-12T08:59:21.679677Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9224-2
  a curric:KeyLearningPoint ;
  rdfs:label """The anonymous “she” represents that the woman was a stranger to Byron; it also gives her an ethereal quality."""@en ;
  dcterms:modified "2026-02-12T08:59:21.679681Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9224-3
  a curric:KeyLearningPoint ;
  rdfs:label """Byron contrasts dark and light imagery throughout the poem - possibly to illustrate the rarity of the woman’s beauty."""@en ;
  dcterms:modified "2026-02-12T08:59:21.679688Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9224-4
  a curric:KeyLearningPoint ;
  rdfs:label """The woman’s hair is described as “raven”, arguably to show the mysterious nature of the woman and her alluring presence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.679693Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29072-1
  a curric:KeyLearningPoint ;
  rdfs:label "Both poems explore childhood innocence and the inevitable loss of joy."@en ;
  dcterms:modified "2026-02-12T08:59:21.680061Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29072-2
  a curric:KeyLearningPoint ;
  rdfs:label """Blake's rhyme scheme reflects societal constraints, whilst Heaney's rhyme scheme captures nostalgia"""@en ;
  dcterms:modified "2026-02-12T08:59:21.680066Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29072-3
  a curric:KeyLearningPoint ;
  rdfs:label "The first-person perspective shapes how youth and nature are portrayed."@en ;
  dcterms:modified "2026-02-12T08:59:21.680070Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29072-4
  a curric:KeyLearningPoint ;
  rdfs:label """Comparative thesis statements should highlight both similarities and differences."""@en ;
  dcterms:modified "2026-02-12T08:59:21.680075Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29072-5
  a curric:KeyLearningPoint ;
  rdfs:label """Comparative conjunctions help compare ideas, likewise correlative conjunctions can create balanced comparisons."""@en ;
  dcterms:modified "2026-02-12T08:59:21.680080Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29058-1
  a curric:KeyLearningPoint ;
  rdfs:label """An anthology is a collection of artistic works that have a similar form or subject."""@en ;
  dcterms:modified "2026-02-12T08:59:21.680103Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29058-2
  a curric:KeyLearningPoint ;
  rdfs:label """Exploring titles and first words are a useful way of thinking about the mood and theme of poems."""@en ;
  dcterms:modified "2026-02-12T08:59:21.680107Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29058-3
  a curric:KeyLearningPoint ;
  rdfs:label """Exploring those themes can help you to make connections between the individual poems."""@en ;
  dcterms:modified "2026-02-12T08:59:21.680114Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29058-4
  a curric:KeyLearningPoint ;
  rdfs:label "Our personal response to a poem is important."@en ;
  dcterms:modified "2026-02-12T08:59:21.680119Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28625-1
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to consider and present an appropriate tone for the topic of your speech."""@en ;
  dcterms:modified "2026-02-12T08:59:21.681418Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28625-2
  a curric:KeyLearningPoint ;
  rdfs:label """Tone is conveyed differently in spoken language, using facial expressions, body language and voice."""@en ;
  dcterms:modified "2026-02-12T08:59:21.681426Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28625-3
  a curric:KeyLearningPoint ;
  rdfs:label "Spoken language should feel slower and slightly louder than everyday speech."@en ;
  dcterms:modified "2026-02-12T08:59:21.681431Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28625-4
  a curric:KeyLearningPoint ;
  rdfs:label "Meaningful pauses can help with pace and emphasise important parts."@en ;
  dcterms:modified "2026-02-12T08:59:21.681436Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28068-1
  a curric:KeyLearningPoint ;
  rdfs:label """Victorian morality emphasised strict social codes, outward respectability, and repression of personal desires."""@en ;
  dcterms:modified "2026-02-12T08:59:21.681532Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28068-2
  a curric:KeyLearningPoint ;
  rdfs:label """Public and private personas were vital: people publicly adhered to societal norms and hid immoral behaviour."""@en ;
  dcterms:modified "2026-02-12T08:59:21.681537Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28068-3
  a curric:KeyLearningPoint ;
  rdfs:label """Jekyll is portrayed as well-liked and respected, whereas Hyde is presented as primitive, violent, and feared."""@en ;
  dcterms:modified "2026-02-12T08:59:21.681542Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28068-4
  a curric:KeyLearningPoint ;
  rdfs:label """Contrasting language depicts them, reflecting Victorian anxieties about morality and the dark side of human nature."""@en ;
  dcterms:modified "2026-02-12T08:59:21.681546Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28068-5
  a curric:KeyLearningPoint ;
  rdfs:label """There are subtle similarities between both Jekyll and Hyde, foreshadowing that they are two sides of the same person."""@en ;
  dcterms:modified "2026-02-12T08:59:21.681599Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28069-1
  a curric:KeyLearningPoint ;
  rdfs:label """Vice was common in Victorian society; the wealthy could hide it, while the poor faced harsher judgement."""@en ;
  dcterms:modified "2026-02-12T08:59:21.681610Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28069-2
  a curric:KeyLearningPoint ;
  rdfs:label """Poorer people often turned to drinking, violence or crime, while the rich indulged in debauchery and illicit affairs."""@en ;
  dcterms:modified "2026-02-12T08:59:21.681615Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28069-3
  a curric:KeyLearningPoint ;
  rdfs:label """The philanthropic Victorian gentleman often served as a façade to cover up the wealthy’s moral corruption."""@en ;
  dcterms:modified "2026-02-12T08:59:21.681620Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28069-4
  a curric:KeyLearningPoint ;
  rdfs:label """Hyde symbolises Victorian moral decay, embodying Jekyll's darker impulses; he is cruel, wild and aggressive."""@en ;
  dcterms:modified "2026-02-12T08:59:21.681625Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28069-5
  a curric:KeyLearningPoint ;
  rdfs:label """Utterson's refusal to confront Jekyll about Hyde can also be seen as an example of moral decay."""@en ;
  dcterms:modified "2026-02-12T08:59:21.681630Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1610-1
  a curric:KeyLearningPoint ;
  rdfs:label "The animals' lives on the farm are no better than under Jones"@en ;
  dcterms:modified "2026-02-12T08:59:21.681692Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1610-2
  a curric:KeyLearningPoint ;
  rdfs:label "Rations are reduced but not for the pigs or dogs"@en ;
  dcterms:modified "2026-02-12T08:59:21.681696Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1610-3
  a curric:KeyLearningPoint ;
  rdfs:label "Boxer dies and is sent to the glue factory"@en ;
  dcterms:modified "2026-02-12T08:59:21.681701Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1610-4
  a curric:KeyLearningPoint ;
  rdfs:label """Boxer is unaware of the power he has in his physical strength and the respect he commands from the other animals"""@en ;
  dcterms:modified "2026-02-12T08:59:21.681710Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1610-5
  a curric:KeyLearningPoint ;
  rdfs:label "Boxer is an allegory for Alexei Stakhanov"@en ;
  dcterms:modified "2026-02-12T08:59:21.681715Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1612-1
  a curric:KeyLearningPoint ;
  rdfs:label """Animal Farm is an allegory for the Russian Revolution which Orwell uses to present his key messages"""@en ;
  dcterms:modified "2026-02-12T08:59:21.681738Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1612-2
  a curric:KeyLearningPoint ;
  rdfs:label """Orwell is using the events of the Russian Revolution to comment on political power and totalitarian regimes"""@en ;
  dcterms:modified "2026-02-12T08:59:21.681742Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1612-3
  a curric:KeyLearningPoint ;
  rdfs:label "Some characters represent historical figures"@en ;
  dcterms:modified "2026-02-12T08:59:21.681747Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1612-4
  a curric:KeyLearningPoint ;
  rdfs:label "Some characters represent social classes or wider ideas"@en ;
  dcterms:modified "2026-02-12T08:59:21.681754Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28066-1
  a curric:KeyLearningPoint ;
  rdfs:label """The Industrial Revolution led to advantages and disadvantages for society such as economic growth and urban poverty."""@en ;
  dcterms:modified "2026-02-12T08:59:21.682134Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28066-2
  a curric:KeyLearningPoint ;
  rdfs:label """Major concerns during the Industrial Revolution included fears of dehumanisation and loss of autonomy."""@en ;
  dcterms:modified "2026-02-12T08:59:21.682139Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28066-3
  a curric:KeyLearningPoint ;
  rdfs:label """In 'Jekyll and Hyde', scientific progress is linked to dehumanisation, moral degradation and loss of control."""@en ;
  dcterms:modified "2026-02-12T08:59:21.682143Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28066-4
  a curric:KeyLearningPoint ;
  rdfs:label """Hyde represents the primal, base desires of Jekyll, which come to the surface when moral control is lost."""@en ;
  dcterms:modified "2026-02-12T08:59:21.682148Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28066-5
  a curric:KeyLearningPoint ;
  rdfs:label """The novella warns readers about the ethical risks of technological advancements and loss of traditional values."""@en ;
  dcterms:modified "2026-02-12T08:59:21.682152Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1622-1
  a curric:KeyLearningPoint ;
  rdfs:label "An introduction and conclusion should follow a three part structure."@en ;
  dcterms:modified "2026-02-12T08:59:21.682277Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1622-2
  a curric:KeyLearningPoint ;
  rdfs:label "An excellent introduction should start with a general statement about the text."@en ;
  dcterms:modified "2026-02-12T08:59:21.682284Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1622-3
  a curric:KeyLearningPoint ;
  rdfs:label """An introduction should have a more specific statement about the focus of the question, followed by a thesis."""@en ;
  dcterms:modified "2026-02-12T08:59:21.682288Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1622-4
  a curric:KeyLearningPoint ;
  rdfs:label """A thesis statement should include a clear, overarching argument referring to the writer's purpose."""@en ;
  dcterms:modified "2026-02-12T08:59:21.682293Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1622-5
  a curric:KeyLearningPoint ;
  rdfs:label """A conclusion should summarise, evaluate and consider the timeless nature of the text."""@en ;
  dcterms:modified "2026-02-12T08:59:21.682298Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1619-1
  a curric:KeyLearningPoint ;
  rdfs:label "Orwell uses a simple and detached style to get his message across."@en ;
  dcterms:modified "2026-02-12T08:59:21.682302Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1619-2
  a curric:KeyLearningPoint ;
  rdfs:label "Orwell uses and subverts the conventions of a fairy tale."@en ;
  dcterms:modified "2026-02-12T08:59:21.682307Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1619-3
  a curric:KeyLearningPoint ;
  rdfs:label "Old Major’s speech foreshadows the events of the novel."@en ;
  dcterms:modified "2026-02-12T08:59:21.682311Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1619-4
  a curric:KeyLearningPoint ;
  rdfs:label """Orwell uses the seasons to show the passing of time and the deterioration of the animals’ living conditions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.682316Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1619-5
  a curric:KeyLearningPoint ;
  rdfs:label """'Animal Farm' has a cyclical structure to reflect the cycle of oppression and the inevitability of hierarchy."""@en ;
  dcterms:modified "2026-02-12T08:59:21.682320Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1603-1
  a curric:KeyLearningPoint ;
  rdfs:label """Napoleon, Snowball and Squealer are emerging as the most powerful animals on the farm"""@en ;
  dcterms:modified "2026-02-12T08:59:21.682325Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1603-2
  a curric:KeyLearningPoint ;
  rdfs:label "The three pigs all have different leadership qualities"@en ;
  dcterms:modified "2026-02-12T08:59:21.682332Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1603-3
  a curric:KeyLearningPoint ;
  rdfs:label "Propaganda is used to gain and maintain power structures"@en ;
  dcterms:modified "2026-02-12T08:59:21.682336Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1603-4
  a curric:KeyLearningPoint ;
  rdfs:label "The three pigs are an allusion to Stalin, Trotsky and Molotov/propaganda"@en ;
  dcterms:modified "2026-02-12T08:59:21.682341Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1603-5
  a curric:KeyLearningPoint ;
  rdfs:label """Orwell uses language to present Napoleon as controlling and foreshadow future events"""@en ;
  dcterms:modified "2026-02-12T08:59:21.682346Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6261-1
  a curric:KeyLearningPoint ;
  rdfs:label """Analysing model answers allows us to explore how we might frame ideas and how to avoid misconceptions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.686477Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6261-2
  a curric:KeyLearningPoint ;
  rdfs:label """An effective introduction should clearly set out the argument of the essay in relation to the question."""@en ;
  dcterms:modified "2026-02-12T08:59:21.686483Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6261-3
  a curric:KeyLearningPoint ;
  rdfs:label """An effective conclusion summarises the argument and gestures to what it might say about society."""@en ;
  dcterms:modified "2026-02-12T08:59:21.686488Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6261-4
  a curric:KeyLearningPoint ;
  rdfs:label """One misconception is to interweave quotations from both poems but not effectively analyse them."""@en ;
  dcterms:modified "2026-02-12T08:59:21.686493Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6261-5
  a curric:KeyLearningPoint ;
  rdfs:label """Another misconception is to point out differences between the poems but not effectively analyse them."""@en ;
  dcterms:modified "2026-02-12T08:59:21.686499Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2333-1
  a curric:KeyLearningPoint ;
  rdfs:label "Romanticism arose from a conflicted time for society."@en ;
  dcterms:modified "2026-02-12T08:59:21.686568Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2333-2
  a curric:KeyLearningPoint ;
  rdfs:label "Romanticism prioritised ideas of revolution, inspired by France."@en ;
  dcterms:modified "2026-02-12T08:59:21.686572Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2333-3
  a curric:KeyLearningPoint ;
  rdfs:label "Romanticism focuses on subjective individual experiences."@en ;
  dcterms:modified "2026-02-12T08:59:21.686577Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2333-4
  a curric:KeyLearningPoint ;
  rdfs:label "Romanticism displays affinity with or appreciation of nature."@en ;
  dcterms:modified "2026-02-12T08:59:21.686581Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1687-1
  a curric:KeyLearningPoint ;
  rdfs:label "Topic sentences must be comparative when comparing texts."@en ;
  dcterms:modified "2026-02-12T08:59:21.686818Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1687-2
  a curric:KeyLearningPoint ;
  rdfs:label "Comparisons should be made between ideas, intentions, themes, and messages."@en ;
  dcterms:modified "2026-02-12T08:59:21.686823Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1687-3
  a curric:KeyLearningPoint ;
  rdfs:label """Correlative and comparative conjunctions are a good way to signpost your comparative writing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.686827Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1687-4
  a curric:KeyLearningPoint ;
  rdfs:label """Within paragraphs, evidence can move back and forth between the two poems and be linked with connectives."""@en ;
  dcterms:modified "2026-02-12T08:59:21.686832Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1687-5
  a curric:KeyLearningPoint ;
  rdfs:label """Drawing a direct comparison of quotations should take place at least once across the essay."""@en ;
  dcterms:modified "2026-02-12T08:59:21.686836Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6256-1
  a curric:KeyLearningPoint ;
  rdfs:label "Topic sentences must be comparative when comparing texts."@en ;
  dcterms:modified "2026-02-12T08:59:21.686899Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6256-2
  a curric:KeyLearningPoint ;
  rdfs:label "Comparisons should be made between ideas, intentions, themes and messages."@en ;
  dcterms:modified "2026-02-12T08:59:21.686904Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6256-3
  a curric:KeyLearningPoint ;
  rdfs:label """Correlative and comparative conjunctions are a good way to signpost your comparative writing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.686908Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6256-4
  a curric:KeyLearningPoint ;
  rdfs:label """Within paragraphs, evidence can move back and forth between the two poems and be linked with connectives."""@en ;
  dcterms:modified "2026-02-12T08:59:21.686913Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6256-5
  a curric:KeyLearningPoint ;
  rdfs:label """Drawing a direct comparison of quotations should take place at least once across the essay."""@en ;
  dcterms:modified "2026-02-12T08:59:21.686917Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2412-1
  a curric:KeyLearningPoint ;
  rdfs:label "Pinnock describes Mai as an “enigmatic” character."@en ;
  dcterms:modified "2026-02-12T08:59:21.687108Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2412-2
  a curric:KeyLearningPoint ;
  rdfs:label """Pinnock says Mai has a “powerful influence” on all the characters in ‘Leave Taking’."""@en ;
  dcterms:modified "2026-02-12T08:59:21.687115Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2412-3
  a curric:KeyLearningPoint ;
  rdfs:label "Arguably, Mai has the most powerful influence on Del."@en ;
  dcterms:modified "2026-02-12T08:59:21.687119Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2412-4
  a curric:KeyLearningPoint ;
  rdfs:label "Mai argues people need to “invest in their own healing”."@en ;
  dcterms:modified "2026-02-12T08:59:21.687124Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2412-5
  a curric:KeyLearningPoint ;
  rdfs:label "Arguably Mai helps Del “invest” in herself."@en ;
  dcterms:modified "2026-02-12T08:59:21.687128Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2408-1
  a curric:KeyLearningPoint ;
  rdfs:label """The death of Enid’s mother is a catalyst for Enid confronting her feelings of shame and guilt."""@en ;
  dcterms:modified "2026-02-12T08:59:21.687435Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2408-2
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, Enid is presented as feeling ashamed of her upbringing in rural poverty."""@en ;
  dcterms:modified "2026-02-12T08:59:21.687440Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2408-3
  a curric:KeyLearningPoint ;
  rdfs:label """Dramatic methods are the tools a playwright uses to create drama. Examples are setting, stage directions and dialogue."""@en ;
  dcterms:modified "2026-02-12T08:59:21.687444Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1653-1
  a curric:KeyLearningPoint ;
  rdfs:label """In this opening chapter of his novella, Stevenson uses a third person narrator, focalised through Utterson"""@en ;
  dcterms:modified "2026-02-12T08:59:21.687766Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1653-2
  a curric:KeyLearningPoint ;
  rdfs:label """Utterson is portrayed as a dull but reliable character who  seems to live vicariously through others"""@en ;
  dcterms:modified "2026-02-12T08:59:21.687771Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1653-3
  a curric:KeyLearningPoint ;
  rdfs:label """Stevenson draws attention to Utterson's profession, which proves that he is middle class"""@en ;
  dcterms:modified "2026-02-12T08:59:21.687775Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1653-4
  a curric:KeyLearningPoint ;
  rdfs:label """The idea of social hierarchy is immediately introduced as Utterson is described as a 'gentleman'"""@en ;
  dcterms:modified "2026-02-12T08:59:21.687780Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1653-5
  a curric:KeyLearningPoint ;
  rdfs:label """Utterson prides himself on his tact and despite his respectability, is a friend to 'downgoing' men"""@en ;
  dcterms:modified "2026-02-12T08:59:21.687787Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2419-1
  a curric:KeyLearningPoint ;
  rdfs:label "Topic sentences state a paragraph's main idea."@en ;
  dcterms:modified "2026-02-12T08:59:21.687925Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2419-2
  a curric:KeyLearningPoint ;
  rdfs:label "Select main quotations and supporting quotations to include in an essay."@en ;
  dcterms:modified "2026-02-12T08:59:21.687929Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2419-3
  a curric:KeyLearningPoint ;
  rdfs:label """Main quotations should be analysed; supporting quotations don't need to be analysed."""@en ;
  dcterms:modified "2026-02-12T08:59:21.687934Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9229-1
  a curric:KeyLearningPoint ;
  rdfs:label """In ‘To Autumn’ and ‘The Prelude’,  Keats and Wordsworth depict human beings interacting with nature."""@en ;
  dcterms:modified "2026-02-12T08:59:21.688803Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9229-2
  a curric:KeyLearningPoint ;
  rdfs:label """Keats’ poem celebrates autumn's beauty and bounty whereas Wordsworth recalls happy childhood memories of ice skating."""@en ;
  dcterms:modified "2026-02-12T08:59:21.688808Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9229-3
  a curric:KeyLearningPoint ;
  rdfs:label """Both Elizabeth Barrett Browning and Keats wrote formal poetry to express their love for a beloved."""@en ;
  dcterms:modified "2026-02-12T08:59:21.688812Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9229-4
  a curric:KeyLearningPoint ;
  rdfs:label """Elizabeth Barrett Browning addressed her sonnet to her husband and Keats addressed his ode to the season of autumn."""@en ;
  dcterms:modified "2026-02-12T08:59:21.688817Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9229-5
  a curric:KeyLearningPoint ;
  rdfs:label """The dominant tone of ‘Sonnet 43’ is intense passion whereas Wordsworth’s poem is filled with nostalgia."""@en ;
  dcterms:modified "2026-02-12T08:59:21.688821Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9222-1
  a curric:KeyLearningPoint ;
  rdfs:label """Barrett Browning wrote this poem to her future husband to express her deep love for him."""@en ;
  dcterms:modified "2026-02-12T08:59:21.688874Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9222-2
  a curric:KeyLearningPoint ;
  rdfs:label """Barrett Browning begins the poem by expressing her love in a more abstract and unquantifiable way."""@en ;
  dcterms:modified "2026-02-12T08:59:21.688881Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9222-3
  a curric:KeyLearningPoint ;
  rdfs:label """In the sestet, Barrett Browning finds more personal and specific ways to express (and measure) her love."""@en ;
  dcterms:modified "2026-02-12T08:59:21.688885Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9222-4
  a curric:KeyLearningPoint ;
  rdfs:label """The image of a sun arguably represents the idea that her lover brings warmth, light, sustenance and purpose to her life."""@en ;
  dcterms:modified "2026-02-12T08:59:21.688890Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9222-5
  a curric:KeyLearningPoint ;
  rdfs:label """Barrett Browning’s use of imagery conveys her admiration for, and adoration of her future husband."""@en ;
  dcterms:modified "2026-02-12T08:59:21.688894Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2401-1
  a curric:KeyLearningPoint ;
  rdfs:label "Scene Four explores Enid’s immediate reaction to her mother’s death."@en ;
  dcterms:modified "2026-02-12T08:59:21.689711Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2401-2
  a curric:KeyLearningPoint ;
  rdfs:label "Enid tells Viv about her impoverished upbringing."@en ;
  dcterms:modified "2026-02-12T08:59:21.689716Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2401-3
  a curric:KeyLearningPoint ;
  rdfs:label "Enid explains how her uncle migrating had a huge effect on her."@en ;
  dcterms:modified "2026-02-12T08:59:21.689720Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2401-4
  a curric:KeyLearningPoint ;
  rdfs:label """Enid gives Viv a cheque so that she can be financially stable when she goes to university."""@en ;
  dcterms:modified "2026-02-12T08:59:21.689727Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2401-5
  a curric:KeyLearningPoint ;
  rdfs:label "The scene ends with Enid stating that she wants to \"go home\"."@en ;
  dcterms:modified "2026-02-12T08:59:21.689731Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1616-1
  a curric:KeyLearningPoint ;
  rdfs:label """A cult of personality is the result of a carefully constructed persona, spread through propaganda and other means"""@en ;
  dcterms:modified "2026-02-12T08:59:21.689977Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1616-2
  a curric:KeyLearningPoint ;
  rdfs:label "Napoleon reflects Stalin’s use of propaganda and methods of control"@en ;
  dcterms:modified "2026-02-12T08:59:21.689982Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1616-3
  a curric:KeyLearningPoint ;
  rdfs:label """Orwell explores how leaders gain power through created personas, language and education"""@en ;
  dcterms:modified "2026-02-12T08:59:21.689987Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1616-4
  a curric:KeyLearningPoint ;
  rdfs:label """Orwell emphasises the dangers of an uneducated working class in the maintaining of power and hierarchy"""@en ;
  dcterms:modified "2026-02-12T08:59:21.689991Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2404-1
  a curric:KeyLearningPoint ;
  rdfs:label "Enid comes to visit Mai."@en ;
  dcterms:modified "2026-02-12T08:59:21.689996Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2404-2
  a curric:KeyLearningPoint ;
  rdfs:label "Enid has not seen Del for weeks and is very worried about her."@en ;
  dcterms:modified "2026-02-12T08:59:21.690002Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2404-3
  a curric:KeyLearningPoint ;
  rdfs:label """Enid expresses how she feels about Del, and her mother, through a ‘howl of pain’."""@en ;
  dcterms:modified "2026-02-12T08:59:21.690007Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2404-4
  a curric:KeyLearningPoint ;
  rdfs:label """Mai believes many Jamaicans feel a sense of dislocation owing to the history of the transatlantic slave trade."""@en ;
  dcterms:modified "2026-02-12T08:59:21.690012Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2404-5
  a curric:KeyLearningPoint ;
  rdfs:label "Mai describes home as a feeling of \"peace\" with yourself."@en ;
  dcterms:modified "2026-02-12T08:59:21.690016Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2420-1
  a curric:KeyLearningPoint ;
  rdfs:label "Use the essay question as a planning tool by annotating its keywords."@en ;
  dcterms:modified "2026-02-12T08:59:21.690021Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2420-2
  a curric:KeyLearningPoint ;
  rdfs:label """Create a detailed plan which includes a clear thesis, and focused topic sentences."""@en ;
  dcterms:modified "2026-02-12T08:59:21.690025Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2420-3
  a curric:KeyLearningPoint ;
  rdfs:label "A thesis is your overarching argument."@en ;
  dcterms:modified "2026-02-12T08:59:21.690030Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2420-4
  a curric:KeyLearningPoint ;
  rdfs:label "A topic sentence states the paragraph’s main idea."@en ;
  dcterms:modified "2026-02-12T08:59:21.690034Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2420-5
  a curric:KeyLearningPoint ;
  rdfs:label """Essays should follow a structure: introduction, main body paragraphs, conclusion."""@en ;
  dcterms:modified "2026-02-12T08:59:21.690039Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1654-1
  a curric:KeyLearningPoint ;
  rdfs:label "Both the door and the lack of window links to concealment and mystery"@en ;
  dcterms:modified "2026-02-12T08:59:21.690043Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1654-2
  a curric:KeyLearningPoint ;
  rdfs:label "The door is a threshold, linking to the gothic trope of liminality"@en ;
  dcterms:modified "2026-02-12T08:59:21.690050Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1654-3
  a curric:KeyLearningPoint ;
  rdfs:label """The appearance of the door suggests disregard for the facade of respectability expected in gentile Victorian society"""@en ;
  dcterms:modified "2026-02-12T08:59:21.690055Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1654-4
  a curric:KeyLearningPoint ;
  rdfs:label """The door is an important threshold to starting the mystery that novella looks to solve"""@en ;
  dcterms:modified "2026-02-12T08:59:21.690060Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2413-1
  a curric:KeyLearningPoint ;
  rdfs:label """Pinnock describes Enid as “reaching out” for a different kind of life away from Jamaica."""@en ;
  dcterms:modified "2026-02-12T08:59:21.690859Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2413-2
  a curric:KeyLearningPoint ;
  rdfs:label "Pinnock describes Enid as “haunted\" by her past memories."@en ;
  dcterms:modified "2026-02-12T08:59:21.690864Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2413-3
  a curric:KeyLearningPoint ;
  rdfs:label "Enid’s inner conflict is felt most keenly after her mother’s death."@en ;
  dcterms:modified "2026-02-12T08:59:21.690868Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2413-4
  a curric:KeyLearningPoint ;
  rdfs:label "Britain colonised Jamaica in 1655. Jamaica achieved independence in 1962."@en ;
  dcterms:modified "2026-02-12T08:59:21.690873Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2413-5
  a curric:KeyLearningPoint ;
  rdfs:label "The impact of this colonisation is still felt."@en ;
  dcterms:modified "2026-02-12T08:59:21.690877Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2416-1
  a curric:KeyLearningPoint ;
  rdfs:label "Context refers to historical, social, literary and biographical information."@en ;
  dcterms:modified "2026-02-12T08:59:21.690882Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2416-2
  a curric:KeyLearningPoint ;
  rdfs:label "Context should not be presented as isolated facts."@en ;
  dcterms:modified "2026-02-12T08:59:21.690886Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2416-3
  a curric:KeyLearningPoint ;
  rdfs:label "Context should be relevant to the analysis and woven in the response."@en ;
  dcterms:modified "2026-02-12T08:59:21.690891Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2416-4
  a curric:KeyLearningPoint ;
  rdfs:label """Context should develop your ideas and give an insight into the writer’s purpose and intention."""@en ;
  dcterms:modified "2026-02-12T08:59:21.690895Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2402-1
  a curric:KeyLearningPoint ;
  rdfs:label "Del has moved in with Mai."@en ;
  dcterms:modified "2026-02-12T08:59:21.690900Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2402-2
  a curric:KeyLearningPoint ;
  rdfs:label "Del seems increasingly interested in obeah."@en ;
  dcterms:modified "2026-02-12T08:59:21.690904Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2402-3
  a curric:KeyLearningPoint ;
  rdfs:label "Scene One foreshadows the development of Del and Mai’s relationship."@en ;
  dcterms:modified "2026-02-12T08:59:21.690908Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2402-4
  a curric:KeyLearningPoint ;
  rdfs:label """Del did not enjoy school, perhaps because she was not offered the support she needed with reading."""@en ;
  dcterms:modified "2026-02-12T08:59:21.690914Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2398-1
  a curric:KeyLearningPoint ;
  rdfs:label """Scene Two of ‘Leave Taking’ explores examples of racism present in 1980s Britain."""@en ;
  dcterms:modified "2026-02-12T08:59:21.690918Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2398-2
  a curric:KeyLearningPoint ;
  rdfs:label """Some examples of racism explored are presented as systemic (for example the Eurocentric education system)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.690926Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2398-3
  a curric:KeyLearningPoint ;
  rdfs:label "Other examples of racial discrimination are explored on an individual basis."@en ;
  dcterms:modified "2026-02-12T08:59:21.690933Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2398-4
  a curric:KeyLearningPoint ;
  rdfs:label "Brod, Enid and Del react to the discrimination they face differently."@en ;
  dcterms:modified "2026-02-12T08:59:21.690937Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2398-5
  a curric:KeyLearningPoint ;
  rdfs:label "Despite their conflict, Enid and Del share some common characteristics."@en ;
  dcterms:modified "2026-02-12T08:59:21.690942Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1617-1
  a curric:KeyLearningPoint ;
  rdfs:label "Orwell uses key plot points in the novella to present his themes."@en ;
  dcterms:modified "2026-02-12T08:59:21.693863Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1617-2
  a curric:KeyLearningPoint ;
  rdfs:label "Freytag’s pyramid is a useful tool to plot character arcs and key moments."@en ;
  dcterms:modified "2026-02-12T08:59:21.693868Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1617-3
  a curric:KeyLearningPoint ;
  rdfs:label """The characters in 'Animal Farm' show the impact and development of totalitarian regimes and individuals’ involvement."""@en ;
  dcterms:modified "2026-02-12T08:59:21.693873Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2409-1
  a curric:KeyLearningPoint ;
  rdfs:label """At the start of the play, Del appears uninterested in obeah and her cultural roots."""@en ;
  dcterms:modified "2026-02-12T08:59:21.693877Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2409-2
  a curric:KeyLearningPoint ;
  rdfs:label "At the start of the play, Del’s relationship with Enid is full of conflict."@en ;
  dcterms:modified "2026-02-12T08:59:21.693882Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2409-3
  a curric:KeyLearningPoint ;
  rdfs:label "Del develops over the course of the play."@en ;
  dcterms:modified "2026-02-12T08:59:21.693886Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2409-4
  a curric:KeyLearningPoint ;
  rdfs:label """Pinnock links Del’s development to Mai, obeah and Del’s new found understanding of her mother."""@en ;
  dcterms:modified "2026-02-12T08:59:21.693891Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2409-5
  a curric:KeyLearningPoint ;
  rdfs:label "The closing stage directions establish the depth of Del’s development."@en ;
  dcterms:modified "2026-02-12T08:59:21.693895Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2475-1
  a curric:KeyLearningPoint ;
  rdfs:label """Sheers uses personification of the surroundings to present a fractured emotional landscape."""@en ;
  dcterms:modified "2026-02-12T08:59:21.694340Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2475-2
  a curric:KeyLearningPoint ;
  rdfs:label """Sheers uses pathetic fallacy to subtly imply that the couple are facing trouble in their relationship."""@en ;
  dcterms:modified "2026-02-12T08:59:21.694345Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2475-3
  a curric:KeyLearningPoint ;
  rdfs:label """Sheers uses a contrast in colour imagery to signify the hope that emerges from despair."""@en ;
  dcterms:modified "2026-02-12T08:59:21.694349Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2475-4
  a curric:KeyLearningPoint ;
  rdfs:label """Sheers uses a simile in the resolution of the poem to convey how the couple are reunified."""@en ;
  dcterms:modified "2026-02-12T08:59:21.694353Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2475-5
  a curric:KeyLearningPoint ;
  rdfs:label """Sheers uses the symbolism of the swans to mark a turning point in the tone of the poem - from despair to hope."""@en ;
  dcterms:modified "2026-02-12T08:59:21.694358Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28042-1
  a curric:KeyLearningPoint ;
  rdfs:label "Temporal ellipsis emphasises the aftermath of key events in drama."@en ;
  dcterms:modified "2026-02-12T08:59:21.695052Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28042-2
  a curric:KeyLearningPoint ;
  rdfs:label """Off-stage events can influence character emotions and relationships significantly."""@en ;
  dcterms:modified "2026-02-12T08:59:21.695057Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28042-3
  a curric:KeyLearningPoint ;
  rdfs:label "The audience engages more deeply by imagining missing moments."@en ;
  dcterms:modified "2026-02-12T08:59:21.695061Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28042-4
  a curric:KeyLearningPoint ;
  rdfs:label "Pinnock uses ellipsis to enhance themes of grief and conflict."@en ;
  dcterms:modified "2026-02-12T08:59:21.695065Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28042-5
  a curric:KeyLearningPoint ;
  rdfs:label """Both surface level understanding and deeper analysis can be used when analysing temporal ellipsis"""@en ;
  dcterms:modified "2026-02-12T08:59:21.695070Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28075-1
  a curric:KeyLearningPoint ;
  rdfs:label """Many Victorians embodied the personal values of individualism, self-reliance and a ‘Protestant' work ethic."""@en ;
  dcterms:modified "2026-02-12T08:59:21.695099Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28075-2
  a curric:KeyLearningPoint ;
  rdfs:label """Scrooge embodies these values in Stave 1; he is depicted as “tight-fisted”, refusing to help Bob or donate to charity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.695104Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28075-3
  a curric:KeyLearningPoint ;
  rdfs:label """Dickens critiques these values when he describes Scrooge as a “sinner”, suggesting ruthless frugality is immoral."""@en ;
  dcterms:modified "2026-02-12T08:59:21.695110Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28075-4
  a curric:KeyLearningPoint ;
  rdfs:label """In Stave 5, Scrooge embodies the opposite values: compassion, generosity, humility and integrity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.695115Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28075-5
  a curric:KeyLearningPoint ;
  rdfs:label """Dickens uses parallels between Stave 1 and 5 to emphasise the scale of Scrooge’s redemption."""@en ;
  dcterms:modified "2026-02-12T08:59:21.695119Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2550-1
  a curric:KeyLearningPoint ;
  rdfs:label "The metaphor of a hair brush suggests community together, all in place."@en ;
  dcterms:modified "2026-02-12T08:59:21.695442Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2550-2
  a curric:KeyLearningPoint ;
  rdfs:label """The juxtaposition of inclusive and uncomfortable images and words could suggest multiculturalism isn’t fully accepted."""@en ;
  dcterms:modified "2026-02-12T08:59:21.695446Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2550-3
  a curric:KeyLearningPoint ;
  rdfs:label """The free verse nature of the poem could link to the idea that people are free to be who they want to be."""@en ;
  dcterms:modified "2026-02-12T08:59:21.695451Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2550-4
  a curric:KeyLearningPoint ;
  rdfs:label """The use of rhymes, half-rhymes and no rhyme could link to ideas of multiculturalism."""@en ;
  dcterms:modified "2026-02-12T08:59:21.695455Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29087-1
  a curric:KeyLearningPoint ;
  rdfs:label "Wordsworth was a leading Romantic poet who revered ideas of nature and emotion."@en ;
  dcterms:modified "2026-02-12T08:59:21.695462Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29087-2
  a curric:KeyLearningPoint ;
  rdfs:label """Throughout the poem, Wordsworth implies that nature brings joy and happiness to the speaker’s previous “lonely” life."""@en ;
  dcterms:modified "2026-02-12T08:59:21.695467Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29087-3
  a curric:KeyLearningPoint ;
  rdfs:label """Potentially, we might see Wordsworth as suggesting that humanity can find a sense of belonging in nature."""@en ;
  dcterms:modified "2026-02-12T08:59:21.695471Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29087-4
  a curric:KeyLearningPoint ;
  rdfs:label """However, we might also interpret Wordsworth as connecting nature to the Romantic sublime in the poem."""@en ;
  dcterms:modified "2026-02-12T08:59:21.695476Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29087-5
  a curric:KeyLearningPoint ;
  rdfs:label """This connection of nature to the Romantic sublime might undermine our understanding of belonging."""@en ;
  dcterms:modified "2026-02-12T08:59:21.695480Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28633-1
  a curric:KeyLearningPoint ;
  rdfs:label """In Elizabethan England, most people believed that their lives were controlled by fate."""@en ;
  dcterms:modified "2026-02-12T08:59:21.695485Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28633-2
  a curric:KeyLearningPoint ;
  rdfs:label "Romeo and Juliet’s fate is revealed to us in the prologue."@en ;
  dcterms:modified "2026-02-12T08:59:21.695489Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28633-3
  a curric:KeyLearningPoint ;
  rdfs:label """The image of “star-crossed lovers” shows that Romeo and Juliet’s love will have a tragic end."""@en ;
  dcterms:modified "2026-02-12T08:59:21.695494Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28633-4
  a curric:KeyLearningPoint ;
  rdfs:label """The use of “fatal loins” implies that Romeo and Juliet’s fate was sealed before they were born."""@en ;
  dcterms:modified "2026-02-12T08:59:21.695501Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28633-5
  a curric:KeyLearningPoint ;
  rdfs:label """The use of the sonnet form implies that Romeo and Juliet are trapped within their destinies."""@en ;
  dcterms:modified "2026-02-12T08:59:21.695506Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1635-1
  a curric:KeyLearningPoint ;
  rdfs:label "Macduff tells Macbeth that he was born by c-section."@en ;
  dcterms:modified "2026-02-12T08:59:21.695510Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1635-2
  a curric:KeyLearningPoint ;
  rdfs:label "Macbeth realises the witches’ prophecies won’t protect him."@en ;
  dcterms:modified "2026-02-12T08:59:21.695515Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1635-3
  a curric:KeyLearningPoint ;
  rdfs:label "Macduff kills Macbeth."@en ;
  dcterms:modified "2026-02-12T08:59:21.695519Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1635-4
  a curric:KeyLearningPoint ;
  rdfs:label "Malcolm is crowned King of Scotland and thus order is restored to the country."@en ;
  dcterms:modified "2026-02-12T08:59:21.695524Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1635-5
  a curric:KeyLearningPoint ;
  rdfs:label "Themes are a text’s main ideas."@en ;
  dcterms:modified "2026-02-12T08:59:21.695528Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6246-1
  a curric:KeyLearningPoint ;
  rdfs:label """The anthology's war poems can be grouped via their exploration of who war effects."""@en ;
  dcterms:modified "2026-02-12T08:59:21.695533Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6246-2
  a curric:KeyLearningPoint ;
  rdfs:label """The anthology's war poems can be grouped via their exploration of the effect of war during and after the conflict."""@en ;
  dcterms:modified "2026-02-12T08:59:21.695537Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6246-3
  a curric:KeyLearningPoint ;
  rdfs:label """The poems that you choose to compare should both be linked to the focus and nuances of the question you are asked."""@en ;
  dcterms:modified "2026-02-12T08:59:21.695542Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6246-4
  a curric:KeyLearningPoint ;
  rdfs:label """It is useful to consider the similarities between poems and then consider any subtle differences between them."""@en ;
  dcterms:modified "2026-02-12T08:59:21.695548Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6246-5
  a curric:KeyLearningPoint ;
  rdfs:label "Concluding sentences should have a sharp focus on the writer’s intention."@en ;
  dcterms:modified "2026-02-12T08:59:21.695553Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2058-1
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, Squealer's manipulation of language makes him the most the treacherous pig."""@en ;
  dcterms:modified "2026-02-12T08:59:21.695558Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2058-2
  a curric:KeyLearningPoint ;
  rdfs:label "Judiciously chosen quotes should be used in essays."@en ;
  dcterms:modified "2026-02-12T08:59:21.695562Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2058-3
  a curric:KeyLearningPoint ;
  rdfs:label "Tracking a character is an effective way to structure an essay."@en ;
  dcterms:modified "2026-02-12T08:59:21.695569Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2058-4
  a curric:KeyLearningPoint ;
  rdfs:label """Snowball could be described as one of the 'unconsciously power-hungry people’ who blight revolutionary causes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.695574Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2058-5
  a curric:KeyLearningPoint ;
  rdfs:label "Arguably, Squealer’s name is an example of nominative determinism."@en ;
  dcterms:modified "2026-02-12T08:59:21.695579Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9220-1
  a curric:KeyLearningPoint ;
  rdfs:label "Both poets critiqued the power held by institutions in society."@en ;
  dcterms:modified "2026-02-12T08:59:21.695583Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9220-2
  a curric:KeyLearningPoint ;
  rdfs:label """Shelley focuses on the oppressor - King Ozymandias - and the tyrannical way he rules over his subjects."""@en ;
  dcterms:modified "2026-02-12T08:59:21.695588Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9220-3
  a curric:KeyLearningPoint ;
  rdfs:label """Blake focuses on the oppressed, exploring how corrupt institutions left people to suffer in abject poverty."""@en ;
  dcterms:modified "2026-02-12T08:59:21.695592Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9220-4
  a curric:KeyLearningPoint ;
  rdfs:label """Both Shelley and Blake were Romantic poets; their work critiques society while focusing on individual experiences."""@en ;
  dcterms:modified "2026-02-12T08:59:21.695597Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9220-5
  a curric:KeyLearningPoint ;
  rdfs:label """Both poets explore how power can be abused and advocate for an end to oppressive power."""@en ;
  dcterms:modified "2026-02-12T08:59:21.695601Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9260-1
  a curric:KeyLearningPoint ;
  rdfs:label "Analysing a poem in detail means looking at how the poem has been put together."@en ;
  dcterms:modified "2026-02-12T08:59:21.696265Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9260-2
  a curric:KeyLearningPoint ;
  rdfs:label """This may include examining the poem’s structure, as well as the poet’s layering of methods."""@en ;
  dcterms:modified "2026-02-12T08:59:21.696269Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9260-3
  a curric:KeyLearningPoint ;
  rdfs:label "It may be useful to consider what the poet establishes, builds on and ends with."@en ;
  dcterms:modified "2026-02-12T08:59:21.696274Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9260-4
  a curric:KeyLearningPoint ;
  rdfs:label """It might be useful to analyse the poem chronologically, to help you analyse structure."""@en ;
  dcterms:modified "2026-02-12T08:59:21.696278Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9240-1
  a curric:KeyLearningPoint ;
  rdfs:label """Hardy uses figurative language in Stanza one to create a foreboding atmosphere and foreshadow the devastating news."""@en ;
  dcterms:modified "2026-02-12T08:59:21.696285Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9240-2
  a curric:KeyLearningPoint ;
  rdfs:label """Hardy uses pathetic fallacy and symbolism across the poem to reflect the wife’s isolation, confusion and loneliness."""@en ;
  dcterms:modified "2026-02-12T08:59:21.696290Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9240-3
  a curric:KeyLearningPoint ;
  rdfs:label """The use of third person perspective creates a detached tone and gives the poem universality."""@en ;
  dcterms:modified "2026-02-12T08:59:21.696295Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9240-4
  a curric:KeyLearningPoint ;
  rdfs:label """The poem’s consistent and therefore predictable rhyme scheme reflects the inevitability of loss in war."""@en ;
  dcterms:modified "2026-02-12T08:59:21.696299Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9240-5
  a curric:KeyLearningPoint ;
  rdfs:label """Hardy uses punctuation to convey the wife’s shock as she struggles to process the devastating news."""@en ;
  dcterms:modified "2026-02-12T08:59:21.696304Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29060-1
  a curric:KeyLearningPoint ;
  rdfs:label """We might see the language of “ghastly” and “grey” as suggesting that the soldier is now devoid of life."""@en ;
  dcterms:modified "2026-02-12T08:59:21.696311Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29060-2
  a curric:KeyLearningPoint ;
  rdfs:label """We could see Owen’s choice to end with questions as signifying Owen’s questioning of war in general."""@en ;
  dcterms:modified "2026-02-12T08:59:21.696315Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29060-3
  a curric:KeyLearningPoint ;
  rdfs:label """Owen arguably juxtaposes the soldier’s pre-war vitality and the post-war isolation and emptiness."""@en ;
  dcterms:modified "2026-02-12T08:59:21.696320Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29060-4
  a curric:KeyLearningPoint ;
  rdfs:label """Potentially, we might see the caesuras within the poem as emphasising how the soldier is now cut off."""@en ;
  dcterms:modified "2026-02-12T08:59:21.696324Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29060-5
  a curric:KeyLearningPoint ;
  rdfs:label """We might see the flippant language as suggesting that the war was all for nothing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.696329Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29062-1
  a curric:KeyLearningPoint ;
  rdfs:label "‘Drummer Hodge’ depicts a soldier’s unceremonial burial in a foreign country."@en ;
  dcterms:modified "2026-02-12T08:59:21.696333Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29062-2
  a curric:KeyLearningPoint ;
  rdfs:label "Hardy was referencing the events of the Second Boer War (1899-1902)."@en ;
  dcterms:modified "2026-02-12T08:59:21.696340Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29062-3
  a curric:KeyLearningPoint ;
  rdfs:label """Potentially, we might read ‘Drummer Hodge’ as a criticism of sending young men away to die in war."""@en ;
  dcterms:modified "2026-02-12T08:59:21.696345Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29062-4
  a curric:KeyLearningPoint ;
  rdfs:label """We might interpret Hardy as suggesting that Hodge is now a part of the foreign land."""@en ;
  dcterms:modified "2026-02-12T08:59:21.696350Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29062-5
  a curric:KeyLearningPoint ;
  rdfs:label """Specifically, we might see Hardy as criticising the Boer War and colonialism through ‘Drummer Hodge’."""@en ;
  dcterms:modified "2026-02-12T08:59:21.696354Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2083-1
  a curric:KeyLearningPoint ;
  rdfs:label "Brontë uses a window motif throughout 'Wuthering Heights'."@en ;
  dcterms:modified "2026-02-12T08:59:21.696587Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2083-2
  a curric:KeyLearningPoint ;
  rdfs:label """Windows are a threshold space that might represent ideas of confinement, exclusion and distance."""@en ;
  dcterms:modified "2026-02-12T08:59:21.696592Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2083-3
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, Brontë uses window motifs throughout 'Wuthering Heights' in order to represent social divisions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.696600Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2083-4
  a curric:KeyLearningPoint ;
  rdfs:label """She may also use windows in order to foreshadow how Heathcliff and Cathy are separated."""@en ;
  dcterms:modified "2026-02-12T08:59:21.696604Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2088-1
  a curric:KeyLearningPoint ;
  rdfs:label """In order to emulate Chandler's use of similes, we might use an existing simile as a starting point."""@en ;
  dcterms:modified "2026-02-12T08:59:21.696609Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2088-2
  a curric:KeyLearningPoint ;
  rdfs:label """Then, we might use a synonym or antonym of the existing comparative word to create something unexpected."""@en ;
  dcterms:modified "2026-02-12T08:59:21.696613Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2088-3
  a curric:KeyLearningPoint ;
  rdfs:label """As well as the visual, we might think of the connotations of the comparative word to add layers of meaning."""@en ;
  dcterms:modified "2026-02-12T08:59:21.696618Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2088-4
  a curric:KeyLearningPoint ;
  rdfs:label """Moreover, we might consider adding extra detail to our comparative image to further add nuance."""@en ;
  dcterms:modified "2026-02-12T08:59:21.696622Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1473-1
  a curric:KeyLearningPoint ;
  rdfs:label """To write a description that shows rising tension you might open with an emotionally charged declarative sentence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.696629Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1473-2
  a curric:KeyLearningPoint ;
  rdfs:label """You might follow that with consecutive interrogative sentences that use personal pronouns."""@en ;
  dcterms:modified "2026-02-12T08:59:21.696634Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1473-3
  a curric:KeyLearningPoint ;
  rdfs:label """You might then end on a repeated exclamatory fragment that finishes on an emotionally charged word."""@en ;
  dcterms:modified "2026-02-12T08:59:21.696638Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2472-1
  a curric:KeyLearningPoint ;
  rdfs:label """When writing an essay, you have to think carefully about the order in which you present your ideas."""@en ;
  dcterms:modified "2026-02-12T08:59:21.696642Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2472-2
  a curric:KeyLearningPoint ;
  rdfs:label """When writing, lay the foundational knowledge, then include primary/secondary evidence, then give a personal response."""@en ;
  dcterms:modified "2026-02-12T08:59:21.696647Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2472-3
  a curric:KeyLearningPoint ;
  rdfs:label """It can be difficult to bring any new interpretations to commonly-used quotations, so try to pick some lesser-used ones."""@en ;
  dcterms:modified "2026-02-12T08:59:21.696651Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2472-4
  a curric:KeyLearningPoint ;
  rdfs:label """Giving a personal response to the text shows your reader your enthusiasm for the text and the subject."""@en ;
  dcterms:modified "2026-02-12T08:59:21.696656Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2472-5
  a curric:KeyLearningPoint ;
  rdfs:label """Using paragraph outlines to plan your response can be useful when considering the structure of your argument."""@en ;
  dcterms:modified "2026-02-12T08:59:21.696662Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2461-1
  a curric:KeyLearningPoint ;
  rdfs:label """The Cratchits embody the values of Christmas: family; community; empathy; gratitude and Christmas spirit."""@en ;
  dcterms:modified "2026-02-12T08:59:21.696667Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2461-2
  a curric:KeyLearningPoint ;
  rdfs:label "Bob Cratchit’s name reflects that he is underpaid and impoverished."@en ;
  dcterms:modified "2026-02-12T08:59:21.696671Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2461-3
  a curric:KeyLearningPoint ;
  rdfs:label """Tiny Tim was allegedly inspired by Dickens’ nephew, Harry, who was also disabled, but sadly passed away."""@en ;
  dcterms:modified "2026-02-12T08:59:21.696676Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2461-4
  a curric:KeyLearningPoint ;
  rdfs:label """Tiny Tim is a symbol of Scrooge’s selfishness and cruelty, as well as hope for his transformation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.696680Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2461-5
  a curric:KeyLearningPoint ;
  rdfs:label """Dickens uses the Cratchits to humanise the poor and illustrate the direct (and personal) consequences of selfishness."""@en ;
  dcterms:modified "2026-02-12T08:59:21.696685Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2377-1
  a curric:KeyLearningPoint ;
  rdfs:label """Dickens arguably draws parallels between Tiny Tim and Christ, who both play significant roles in others' salvation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.696689Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2377-2
  a curric:KeyLearningPoint ;
  rdfs:label "Like Jesus Christ, Tiny Tim is described as a ‘patient and mild’ child."@en ;
  dcterms:modified "2026-02-12T08:59:21.696694Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2377-3
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, Tiny Tim has a sort of resurrection in the novella, which could be portrayed as a Christian miracle."""@en ;
  dcterms:modified "2026-02-12T08:59:21.696698Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2377-4
  a curric:KeyLearningPoint ;
  rdfs:label """Through the resurrection of Tiny Tim, Dickens could be showing us the transformative power of Christian values."""@en ;
  dcterms:modified "2026-02-12T08:59:21.696703Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2377-5
  a curric:KeyLearningPoint ;
  rdfs:label """Parallels can arguably be drawn at some points between Scrooge and Christ, as Scrooge is also reborn."""@en ;
  dcterms:modified "2026-02-12T08:59:21.696707Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1499-1
  a curric:KeyLearningPoint ;
  rdfs:label """The status of the recipient defined in your task will indicate the level of formality required in the speech."""@en ;
  dcterms:modified "2026-02-12T08:59:21.696712Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1499-2
  a curric:KeyLearningPoint ;
  rdfs:label """Take a clear stance for or against the statement; alternative arguments should be refuted at least once in the piece."""@en ;
  dcterms:modified "2026-02-12T08:59:21.696716Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1499-3
  a curric:KeyLearningPoint ;
  rdfs:label """We can employ rhetorical devices to seem relatable to the audience, grab their attention and emphasise  key messages."""@en ;
  dcterms:modified "2026-02-12T08:59:21.696721Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1499-4
  a curric:KeyLearningPoint ;
  rdfs:label """Your conclusion is your final chance to persuade the audience so use as many relevant rhetorical devices as you can."""@en ;
  dcterms:modified "2026-02-12T08:59:21.696725Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1499-5
  a curric:KeyLearningPoint ;
  rdfs:label """A great way to end your speech is to consider what the consequences would be if people don't take action."""@en ;
  dcterms:modified "2026-02-12T08:59:21.696730Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2119-1
  a curric:KeyLearningPoint ;
  rdfs:label "Robert Louis Stevenson was a Victorian writer of novels and travel books."@en ;
  dcterms:modified "2026-02-12T08:59:21.696734Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2119-2
  a curric:KeyLearningPoint ;
  rdfs:label "John Steinbeck was a 20th century American writer of novels and travel books."@en ;
  dcterms:modified "2026-02-12T08:59:21.696739Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2119-3
  a curric:KeyLearningPoint ;
  rdfs:label """Both Stevenson and Steinbeck wrote books about travelling with animal companions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.696747Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2119-4
  a curric:KeyLearningPoint ;
  rdfs:label """When writers describe someone or something, they are also conveying information about themselves."""@en ;
  dcterms:modified "2026-02-12T08:59:21.696752Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2119-5
  a curric:KeyLearningPoint ;
  rdfs:label "We use inference to understand the more hidden information they are telling us."@en ;
  dcterms:modified "2026-02-12T08:59:21.696757Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2030-1
  a curric:KeyLearningPoint ;
  rdfs:label """Sunlight in the poem could represent hope, power of place or an idealised version of the past."""@en ;
  dcterms:modified "2026-02-12T08:59:21.696761Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2030-2
  a curric:KeyLearningPoint ;
  rdfs:label "Free verse could reflect a conflicted identity."@en ;
  dcterms:modified "2026-02-12T08:59:21.696766Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2030-3
  a curric:KeyLearningPoint ;
  rdfs:label """Regular line length seems to reflect the speaker coming to terms with the two parts of her identity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.696770Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2030-4
  a curric:KeyLearningPoint ;
  rdfs:label """Personification likens the city to a child, perhaps reflecting the speaker wanting to take care of it as it did for her."""@en ;
  dcterms:modified "2026-02-12T08:59:21.696775Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2030-5
  a curric:KeyLearningPoint ;
  rdfs:label """The final line of the poem is defiant, suggesting that cherishing memory defies the oppression of tyranny."""@en ;
  dcterms:modified "2026-02-12T08:59:21.696779Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2479-1
  a curric:KeyLearningPoint ;
  rdfs:label """Byron uses an extended metaphor to compare the end of the affair to the loss of a loved one."""@en ;
  dcterms:modified "2026-02-12T08:59:21.696784Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2479-2
  a curric:KeyLearningPoint ;
  rdfs:label """The progression of this metaphor throughout the poem symbolises the progression of the speaker’s grief as time passes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.696788Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2479-3
  a curric:KeyLearningPoint ;
  rdfs:label "Byron uses a euphemism to refer to the illicit nature of the relationship."@en ;
  dcterms:modified "2026-02-12T08:59:21.696793Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2479-4
  a curric:KeyLearningPoint ;
  rdfs:label "Byron uses sibilance to emphasise the secretive nature of the affair."@en ;
  dcterms:modified "2026-02-12T08:59:21.696797Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2479-5
  a curric:KeyLearningPoint ;
  rdfs:label """Byron uses anaphora to reveal how he has to hide his anguish in the wake of the affair."""@en ;
  dcterms:modified "2026-02-12T08:59:21.696802Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2528-1
  a curric:KeyLearningPoint ;
  rdfs:label """The short lines and lack of punctuation make the poem sound conversational in tone."""@en ;
  dcterms:modified "2026-02-12T08:59:21.696806Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2528-2
  a curric:KeyLearningPoint ;
  rdfs:label """The lack of punctuation could create a sense of strong emotion, illustrating Agard's frustration."""@en ;
  dcterms:modified "2026-02-12T08:59:21.696811Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2528-3
  a curric:KeyLearningPoint ;
  rdfs:label """It is written in a mixture of dialects, perhaps reflecting the merging of identities."""@en ;
  dcterms:modified "2026-02-12T08:59:21.696815Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2528-4
  a curric:KeyLearningPoint ;
  rdfs:label "Agard uses direct address to encourage the reader to challenge their prejudices."@en ;
  dcterms:modified "2026-02-12T08:59:21.696820Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2528-5
  a curric:KeyLearningPoint ;
  rdfs:label """Agard uses a series of comparisons to underline the ridiculousness of these prejudicial thoughts."""@en ;
  dcterms:modified "2026-02-12T08:59:21.696824Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28646-1
  a curric:KeyLearningPoint ;
  rdfs:label "Arguably, Shakespeare presents fate as inevitable throughout ‘Romeo and Juliet’."@en ;
  dcterms:modified "2026-02-12T08:59:21.696998Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28646-2
  a curric:KeyLearningPoint ;
  rdfs:label """Act 5, Scene 3 reinforces the idea of fate being inevitable through Romeo and Juliet’s deaths."""@en ;
  dcterms:modified "2026-02-12T08:59:21.697004Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28646-3
  a curric:KeyLearningPoint ;
  rdfs:label """Using single paragraph outlines can be an effective way of creating a plan for an analytical essay."""@en ;
  dcterms:modified "2026-02-12T08:59:21.697009Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28646-4
  a curric:KeyLearningPoint ;
  rdfs:label """Considering the writer’s intentions allows us to think about how the text connects to the ‘bigger picture’."""@en ;
  dcterms:modified "2026-02-12T08:59:21.697013Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1657-1
  a curric:KeyLearningPoint ;
  rdfs:label """Utterson visits Jekyll in his laboratory, which is full of symbols relating to concealment"""@en ;
  dcterms:modified "2026-02-12T08:59:21.697018Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1657-2
  a curric:KeyLearningPoint ;
  rdfs:label """Utterson assumes that Jekyll is a victim of blackmail and must be concealing a secret to protect his reputation"""@en ;
  dcterms:modified "2026-02-12T08:59:21.697023Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1657-3
  a curric:KeyLearningPoint ;
  rdfs:label """The setting of London and the motif of fog in particular further link to concealment"""@en ;
  dcterms:modified "2026-02-12T08:59:21.697027Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1657-4
  a curric:KeyLearningPoint ;
  rdfs:label """The forged letter provides another key clue to Jekyll and Hyde's linked identity and therefore duality"""@en ;
  dcterms:modified "2026-02-12T08:59:21.697034Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1657-5
  a curric:KeyLearningPoint ;
  rdfs:label "The letter is another key clue which forms part of the detective plot"@en ;
  dcterms:modified "2026-02-12T08:59:21.697039Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1485-1
  a curric:KeyLearningPoint ;
  rdfs:label """An extended analogy is a comparison between one thing and another that is developed throughout the piece of work."""@en ;
  dcterms:modified "2026-02-12T08:59:21.697043Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1485-2
  a curric:KeyLearningPoint ;
  rdfs:label """A non-fiction piece of writing might use extended analogies to help communicate an idea to the audience."""@en ;
  dcterms:modified "2026-02-12T08:59:21.697048Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1485-3
  a curric:KeyLearningPoint ;
  rdfs:label """To craft an extended analogy, we might begin by thinking about what idea we want to communicate."""@en ;
  dcterms:modified "2026-02-12T08:59:21.697054Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1485-4
  a curric:KeyLearningPoint ;
  rdfs:label """Once we have our idea, we might think about what comparison we can use to communicate this idea."""@en ;
  dcterms:modified "2026-02-12T08:59:21.697059Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1485-5
  a curric:KeyLearningPoint ;
  rdfs:label """Once we have our comparison, we might develop it into an extended analogy through synonyms and semantic fields."""@en ;
  dcterms:modified "2026-02-12T08:59:21.697063Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2124-1
  a curric:KeyLearningPoint ;
  rdfs:label "Compound adjectives are highly effective in your writing."@en ;
  dcterms:modified "2026-02-12T08:59:21.697068Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2124-2
  a curric:KeyLearningPoint ;
  rdfs:label "Compound adjectives are created by combining multiple words."@en ;
  dcterms:modified "2026-02-12T08:59:21.697072Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2124-3
  a curric:KeyLearningPoint ;
  rdfs:label "Compound adjectives help to add precision and vivid description to your writing."@en ;
  dcterms:modified "2026-02-12T08:59:21.697079Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2124-4
  a curric:KeyLearningPoint ;
  rdfs:label """Analogies are a way of comparing two things in order to make your point both clear and imaginative."""@en ;
  dcterms:modified "2026-02-12T08:59:21.697084Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2026-1
  a curric:KeyLearningPoint ;
  rdfs:label """Introduction and topic sentences should use comparative and correlative conjunctions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.697088Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2026-2
  a curric:KeyLearningPoint ;
  rdfs:label """Within a wider similarity, explore smaller variations or connections in the poets ideas, messages or use of devices."""@en ;
  dcterms:modified "2026-02-12T08:59:21.697095Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2026-3
  a curric:KeyLearningPoint ;
  rdfs:label """Use sequences of developmental and evaluative connectives to explore multiple angles of an idea."""@en ;
  dcterms:modified "2026-02-12T08:59:21.697100Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2026-4
  a curric:KeyLearningPoint ;
  rdfs:label """Ensure concluding sentences and conclusions are evaluative, drawing out precise ideas."""@en ;
  dcterms:modified "2026-02-12T08:59:21.697105Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1680-1
  a curric:KeyLearningPoint ;
  rdfs:label """Shelley was a Romantic poet who rejected monarchy, religion and other powerful institutions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.697109Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1680-2
  a curric:KeyLearningPoint ;
  rdfs:label """‘Ozymandias’ reflects Romanticism e.g. awe of nature, emotion, rejection of human power, fascination with the past."""@en ;
  dcterms:modified "2026-02-12T08:59:21.697114Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1680-3
  a curric:KeyLearningPoint ;
  rdfs:label """The poem reflects the power of pharaonic Egypt, which seemed eternal but fell to ruin."""@en ;
  dcterms:modified "2026-02-12T08:59:21.697118Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1680-4
  a curric:KeyLearningPoint ;
  rdfs:label """‘Ozymandias’ can be read as a criticism of individuals and institutions that consider themselves invincible."""@en ;
  dcterms:modified "2026-02-12T08:59:21.697122Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1680-5
  a curric:KeyLearningPoint ;
  rdfs:label "‘Ozymandias’ can be read as an allegory for the ephemeral nature of human power."@en ;
  dcterms:modified "2026-02-12T08:59:21.697127Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1608-1
  a curric:KeyLearningPoint ;
  rdfs:label "The animals are beginning to run out of food on the farm"@en ;
  dcterms:modified "2026-02-12T08:59:21.697131Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1608-2
  a curric:KeyLearningPoint ;
  rdfs:label "The hens are punished for refusing to give up their eggs"@en ;
  dcterms:modified "2026-02-12T08:59:21.697135Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1608-3
  a curric:KeyLearningPoint ;
  rdfs:label "The pigs run show trials which represent Stalin’s period of ‘Great Terror'"@en ;
  dcterms:modified "2026-02-12T08:59:21.697140Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1608-4
  a curric:KeyLearningPoint ;
  rdfs:label """The show trials act as a way of cultivating a culture of fear to keep the animals under control"""@en ;
  dcterms:modified "2026-02-12T08:59:21.697147Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1608-5
  a curric:KeyLearningPoint ;
  rdfs:label """Napoleon’s totalitarian regime is fully realised and the revolution is not as promised"""@en ;
  dcterms:modified "2026-02-12T08:59:21.697152Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9252-1
  a curric:KeyLearningPoint ;
  rdfs:label """In the first stanza, Keats describes autumn as being almost fat or ripe with prosperity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.697156Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9252-2
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, Keats presents autumn as an abundant season to show that the autumn of a person’s life can be fruitful too."""@en ;
  dcterms:modified "2026-02-12T08:59:21.697161Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9252-3
  a curric:KeyLearningPoint ;
  rdfs:label """The autumn of Keats’ life would have come much earlier than he had likely planned for."""@en ;
  dcterms:modified "2026-02-12T08:59:21.697165Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9252-4
  a curric:KeyLearningPoint ;
  rdfs:label """Keats shifts tone a few times in the poem as he progresses from feelings of optimism to nostalgia then to acceptance."""@en ;
  dcterms:modified "2026-02-12T08:59:21.697170Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9252-5
  a curric:KeyLearningPoint ;
  rdfs:label """The reference to a bountiful harvest could represent the abundance that autumn can bring."""@en ;
  dcterms:modified "2026-02-12T08:59:21.697174Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2405-1
  a curric:KeyLearningPoint ;
  rdfs:label "Brod wakes up at Mai’s house after a night of excessive drinking."@en ;
  dcterms:modified "2026-02-12T08:59:21.697238Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2405-2
  a curric:KeyLearningPoint ;
  rdfs:label "Enid has thrown Brod and Viv out of the house."@en ;
  dcterms:modified "2026-02-12T08:59:21.697242Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2405-3
  a curric:KeyLearningPoint ;
  rdfs:label """Brod tells Del that her father’s attitude towards her mother changed after facing daily racial discrimination at work."""@en ;
  dcterms:modified "2026-02-12T08:59:21.697247Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2405-4
  a curric:KeyLearningPoint ;
  rdfs:label "Brod tells Del that her mother left her father to protect her and Viv."@en ;
  dcterms:modified "2026-02-12T08:59:21.697280Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2332-1
  a curric:KeyLearningPoint ;
  rdfs:label """Using correlative conjunctions allows for nuanced topic sentences that link ideas."""@en ;
  dcterms:modified "2026-02-12T08:59:21.697346Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2332-2
  a curric:KeyLearningPoint ;
  rdfs:label "Effective introductions explore a smaller variation in a wider similarity."@en ;
  dcterms:modified "2026-02-12T08:59:21.697353Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2332-3
  a curric:KeyLearningPoint ;
  rdfs:label "Tentative language should be used to explore multiple interpretations."@en ;
  dcterms:modified "2026-02-12T08:59:21.697358Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2332-4
  a curric:KeyLearningPoint ;
  rdfs:label "Using the active voice helps create clarity in our sentences."@en ;
  dcterms:modified "2026-02-12T08:59:21.697362Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2549-1
  a curric:KeyLearningPoint ;
  rdfs:label """Peckham is an area of South East London, known for having multicultural community."""@en ;
  dcterms:modified "2026-02-12T08:59:21.697367Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2549-2
  a curric:KeyLearningPoint ;
  rdfs:label """The poem follows the speaker on a bus, describing what they see out of the window."""@en ;
  dcterms:modified "2026-02-12T08:59:21.697372Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2549-3
  a curric:KeyLearningPoint ;
  rdfs:label "Arguably, we might see the poem as an expression of multiculturalism."@en ;
  dcterms:modified "2026-02-12T08:59:21.697376Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2549-4
  a curric:KeyLearningPoint ;
  rdfs:label """Blakemore references Blake, a Romantic poet, who believed in individualism and freedom."""@en ;
  dcterms:modified "2026-02-12T08:59:21.697383Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29010-1
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, Shakespeare shows Juliet as both exerting agency and assuming a passive role in ‘Romeo and Juliet’."""@en ;
  dcterms:modified "2026-02-12T08:59:21.697565Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29010-2
  a curric:KeyLearningPoint ;
  rdfs:label """A writer’s intentions can reveal their overall message - what are they saying about society or humanity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.697570Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29010-3
  a curric:KeyLearningPoint ;
  rdfs:label """Using tentative language is important because we can never truly be sure of a writer’s intentions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.697574Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1641-1
  a curric:KeyLearningPoint ;
  rdfs:label "Lady Macbeth seems to become more desperate for power throughout Act 1"@en ;
  dcterms:modified "2026-02-12T08:59:21.697579Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1641-2
  a curric:KeyLearningPoint ;
  rdfs:label """Lady Macbeth's desperation could be interpreted as what leads to her manipulating her husband"""@en ;
  dcterms:modified "2026-02-12T08:59:21.697584Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1641-3
  a curric:KeyLearningPoint ;
  rdfs:label """Lady Macbeth's language appears to get more aggressive and violent in Act 1, Scene 7"""@en ;
  dcterms:modified "2026-02-12T08:59:21.697588Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1641-4
  a curric:KeyLearningPoint ;
  rdfs:label "Lady Macbeth uses persuasive rhetoric in Act 1, Scene 7"@en ;
  dcterms:modified "2026-02-12T08:59:21.697593Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1663-1
  a curric:KeyLearningPoint ;
  rdfs:label """Readers are put in the position of juror at the end of the novella, deciding whether Jekyll is guilty of Hyde’s crimes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.697597Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1663-2
  a curric:KeyLearningPoint ;
  rdfs:label "The extent to which Jekyll is a sympathetic character is debateable."@en ;
  dcterms:modified "2026-02-12T08:59:21.697604Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1663-3
  a curric:KeyLearningPoint ;
  rdfs:label """Jekyll's double life comes to an end because he can no longer control his transformations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.697609Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1663-4
  a curric:KeyLearningPoint ;
  rdfs:label "As Hyde grows stronger, Jekyll grows weaker."@en ;
  dcterms:modified "2026-02-12T08:59:21.697614Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1663-5
  a curric:KeyLearningPoint ;
  rdfs:label "Jekyll and Hyde grow to hate each other, finding it harder to coexist."@en ;
  dcterms:modified "2026-02-12T08:59:21.697618Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1675-1
  a curric:KeyLearningPoint ;
  rdfs:label """In literature, a foil is a contrasting character who highlights another’s qualities or flaws."""@en ;
  dcterms:modified "2026-02-12T08:59:21.697623Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1675-2
  a curric:KeyLearningPoint ;
  rdfs:label "Lanyon acts as a foil to Jekyll in the novella."@en ;
  dcterms:modified "2026-02-12T08:59:21.697628Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1675-3
  a curric:KeyLearningPoint ;
  rdfs:label """Lanyon represents the rational and reputable face of science, highlighting Jekyll’s recklessness."""@en ;
  dcterms:modified "2026-02-12T08:59:21.697632Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1675-4
  a curric:KeyLearningPoint ;
  rdfs:label """Some argue that Lanyon represents Stevenson’s own criticisms of unfettered scientific experimentation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.697636Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1675-5
  a curric:KeyLearningPoint ;
  rdfs:label """Lanyon and Jekyll’s conflict may represent the contemporary concerns about science."""@en ;
  dcterms:modified "2026-02-12T08:59:21.697641Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2075-1
  a curric:KeyLearningPoint ;
  rdfs:label """Social divide is a key idea here, highlighted because the reader sees Soho through the middle class eyes of Utterson."""@en ;
  dcterms:modified "2026-02-12T08:59:21.697648Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2075-2
  a curric:KeyLearningPoint ;
  rdfs:label """Utterson is portrayed as judgemental towards the poor, mirroring commonplace Victorian beliefs."""@en ;
  dcterms:modified "2026-02-12T08:59:21.697653Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2075-3
  a curric:KeyLearningPoint ;
  rdfs:label """Stevenson criticises the idea that only the poor are prone to sin and vice: the middle class characters harbour secrets."""@en ;
  dcterms:modified "2026-02-12T08:59:21.697657Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2075-4
  a curric:KeyLearningPoint ;
  rdfs:label """The description of Soho links to the theme of duality, showing that the city is as divided as Jekyll is."""@en ;
  dcterms:modified "2026-02-12T08:59:21.697662Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2075-5
  a curric:KeyLearningPoint ;
  rdfs:label """Concealment is an important theme here as Utterson confronts a side of London that middle class men don't usually see."""@en ;
  dcterms:modified "2026-02-12T08:59:21.697666Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2521-1
  a curric:KeyLearningPoint ;
  rdfs:label """There are repeated references to both day and night in the poem, illustrating the all consuming nature of emotions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.697671Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2521-2
  a curric:KeyLearningPoint ;
  rdfs:label """The extended metaphor of a tree is used to depict how negative strong emotions can grow."""@en ;
  dcterms:modified "2026-02-12T08:59:21.697675Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2521-3
  a curric:KeyLearningPoint ;
  rdfs:label """The apple grown on the tree could symbolise the speaker’s growing resentment towards their “foe”."""@en ;
  dcterms:modified "2026-02-12T08:59:21.697680Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2521-4
  a curric:KeyLearningPoint ;
  rdfs:label """The rhythm of the poem is straightforward and matter-of-fact, reflecting the everyday nature of these emotions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.697684Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2521-5
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, the ABAB rhyme scheme has a nursery rhyme feel giving the impression of it as a ‘cautionary tale’."""@en ;
  dcterms:modified "2026-02-12T08:59:21.697689Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2561-1
  a curric:KeyLearningPoint ;
  rdfs:label """Zephaniah's use of oppressive verbs throughout the poem reflect the oppressive regimes people flee from."""@en ;
  dcterms:modified "2026-02-12T08:59:21.697693Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2561-2
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, Zephaniah suggests that the oppression continues once the refugees have arrived "somewhere"."""@en ;
  dcterms:modified "2026-02-12T08:59:21.697700Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2561-3
  a curric:KeyLearningPoint ;
  rdfs:label """The juxtaposition surrounding the ideas of place could reflect how easily somewhere can shift to a war or disaster."""@en ;
  dcterms:modified "2026-02-12T08:59:21.697705Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2561-4
  a curric:KeyLearningPoint ;
  rdfs:label """The change from "forest" to "field" could suggest how people lose connections to their heritage through refugeeism."""@en ;
  dcterms:modified "2026-02-12T08:59:21.697709Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2560-1
  a curric:KeyLearningPoint ;
  rdfs:label """Zephaniah's poem focuses on the struggle of refugees and how badly they are treated by many in society."""@en ;
  dcterms:modified "2026-02-12T08:59:21.697727Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2560-2
  a curric:KeyLearningPoint ;
  rdfs:label """Zephaniah uses the pronoun 'we' in the title to remind readers that anyone could become a refugee in their life."""@en ;
  dcterms:modified "2026-02-12T08:59:21.697734Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2560-3
  a curric:KeyLearningPoint ;
  rdfs:label "Zephaniah is a strong advocate for human rights."@en ;
  dcterms:modified "2026-02-12T08:59:21.697739Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2306-1
  a curric:KeyLearningPoint ;
  rdfs:label "Jamaica was colonised by the British in 1655."@en ;
  dcterms:modified "2026-02-12T08:59:21.697744Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2306-2
  a curric:KeyLearningPoint ;
  rdfs:label """Until Jamaica achieved independence in 1962, its education system was largely Eurocentric."""@en ;
  dcterms:modified "2026-02-12T08:59:21.697748Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2306-3
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, Brod is a foil to Enid: he criticises British institutions, policies and attitudes in a way that she does not."""@en ;
  dcterms:modified "2026-02-12T08:59:21.697753Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2306-4
  a curric:KeyLearningPoint ;
  rdfs:label "Arguably, Brod is a catalyst for Viv’s questioning of her education."@en ;
  dcterms:modified "2026-02-12T08:59:21.697757Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9248-1
  a curric:KeyLearningPoint ;
  rdfs:label """When comparing poems, you should choose a poem that matches the poem you have been given thematically."""@en ;
  dcterms:modified "2026-02-12T08:59:21.697780Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9248-2
  a curric:KeyLearningPoint ;
  rdfs:label "Use comparative connectives like 'however' or 'both' to structure your response."@en ;
  dcterms:modified "2026-02-12T08:59:21.697785Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9248-3
  a curric:KeyLearningPoint ;
  rdfs:label """You can discuss the poems separately, but if you can, try to make small comparative comments throughout."""@en ;
  dcterms:modified "2026-02-12T08:59:21.697791Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9248-4
  a curric:KeyLearningPoint ;
  rdfs:label """You can focus on ‘bigger’ methods (like imagery or form) as well as close-text analysis."""@en ;
  dcterms:modified "2026-02-12T08:59:21.697796Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9248-5
  a curric:KeyLearningPoint ;
  rdfs:label "Context should be relevant, specific and support your argument."@en ;
  dcterms:modified "2026-02-12T08:59:21.697801Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1614-1
  a curric:KeyLearningPoint ;
  rdfs:label "All the pigs use rhetoric to present their messages to the masses."@en ;
  dcterms:modified "2026-02-12T08:59:21.697848Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1614-2
  a curric:KeyLearningPoint ;
  rdfs:label "Whilst all the pigs use rhetoric, they do so in different ways."@en ;
  dcterms:modified "2026-02-12T08:59:21.697857Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1614-3
  a curric:KeyLearningPoint ;
  rdfs:label "Ultimately, Napoleon and Squealer rely on fear in controlling the animals."@en ;
  dcterms:modified "2026-02-12T08:59:21.697862Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1614-4
  a curric:KeyLearningPoint ;
  rdfs:label "Orwell uses the delivery of the speeches to develop characterisation."@en ;
  dcterms:modified "2026-02-12T08:59:21.697867Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1614-5
  a curric:KeyLearningPoint ;
  rdfs:label "Snowball is much more serious and earnest compared to the other pigs"@en ;
  dcterms:modified "2026-02-12T08:59:21.697872Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2397-1
  a curric:KeyLearningPoint ;
  rdfs:label """The Windrush Generation are those who arrived from Caribbean countries between 1948 and 1973"""@en ;
  dcterms:modified "2026-02-12T08:59:21.697897Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2397-2
  a curric:KeyLearningPoint ;
  rdfs:label """The Windrush Generation took up jobs in sectors affected by the post World War Two labour shortage"""@en ;
  dcterms:modified "2026-02-12T08:59:21.697901Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2397-3
  a curric:KeyLearningPoint ;
  rdfs:label """At the time, the Caribbean was part of the British Commonwealth so its citizens had the right to live and work in the UK"""@en ;
  dcterms:modified "2026-02-12T08:59:21.697906Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2397-4
  a curric:KeyLearningPoint ;
  rdfs:label """In 2017, it was uncovered that many Windrush citizens were facing deportation under a discriminatory immigration system"""@en ;
  dcterms:modified "2026-02-12T08:59:21.697912Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2397-5
  a curric:KeyLearningPoint ;
  rdfs:label """'Leave Taking' was written before the Windrush scandal but remains topical, especially through the character of Brod"""@en ;
  dcterms:modified "2026-02-12T08:59:21.697917Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2336-1
  a curric:KeyLearningPoint ;
  rdfs:label """Context can be interpreted in historical, social, biographical, and literary ways."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698067Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2336-2
  a curric:KeyLearningPoint ;
  rdfs:label """Incorporating meaningful context deepens our analysis of modern poems in the anthology."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698072Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2336-3
  a curric:KeyLearningPoint ;
  rdfs:label "An author's personal experiences can significantly influence their work."@en ;
  dcterms:modified "2026-02-12T08:59:21.698076Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2336-4
  a curric:KeyLearningPoint ;
  rdfs:label """Contextual points should be seamlessly included in our overall analysis and not 'bolted on' at the end."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698083Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9231-1
  a curric:KeyLearningPoint ;
  rdfs:label """Brooke uses personification to portray England as a mother figure, who has nurtured and cared for him his whole life."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698088Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9231-2
  a curric:KeyLearningPoint ;
  rdfs:label """Brooke presents England as a superior nation;  he portrays England as idyllic to illustrate his patriotism."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698092Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9231-3
  a curric:KeyLearningPoint ;
  rdfs:label """The image of an “English heaven” reflects Brooke's hopes of being reunited with England in the event of his death."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698099Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9231-4
  a curric:KeyLearningPoint ;
  rdfs:label """Brooke uses the sonnet form perhaps to reflect his love for, and devotion to, England."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698106Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9231-5
  a curric:KeyLearningPoint ;
  rdfs:label """Brooke subverts conventions of traditional sonnets, perhaps because his love for England is familial and not romantic."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698111Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9230-1
  a curric:KeyLearningPoint ;
  rdfs:label "Brooke’s patriotism is evident in this poem - he views England as paradise."@en ;
  dcterms:modified "2026-02-12T08:59:21.698115Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9230-2
  a curric:KeyLearningPoint ;
  rdfs:label "Brooke’s poem arguably glorifies war - he presents an idealistic view of war."@en ;
  dcterms:modified "2026-02-12T08:59:21.698120Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9230-3
  a curric:KeyLearningPoint ;
  rdfs:label """Brooke arguably presents death in war as the ultimate display of patriotism and bravery."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698124Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9230-4
  a curric:KeyLearningPoint ;
  rdfs:label """The poem was praised when is was published in 1915, however modern readers may view this poem as naive."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698129Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9230-5
  a curric:KeyLearningPoint ;
  rdfs:label """Despite his bravery and patriotism, Brooke never actually fought in the war - he died of infection on a ship."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698133Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2482-1
  a curric:KeyLearningPoint ;
  rdfs:label "Barrett Browning conveys her overwhelming wish to be reunited with her love."@en ;
  dcterms:modified "2026-02-12T08:59:21.698138Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2482-2
  a curric:KeyLearningPoint ;
  rdfs:label """Barrett Browning describes a relationship which although emotionally close, is physically distant."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698142Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2482-3
  a curric:KeyLearningPoint ;
  rdfs:label """Barrett Browning describes how her thoughts of her lover sometimes obscure and corrupt her reality."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698147Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2482-4
  a curric:KeyLearningPoint ;
  rdfs:label """The poem is partially autobiographical, written during her courtship with Robert Browning, who later became her husband."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698151Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2482-5
  a curric:KeyLearningPoint ;
  rdfs:label """Barrett Browning's life experiences suggest she had positive views about the power of love."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698155Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2327-1
  a curric:KeyLearningPoint ;
  rdfs:label """The bride is forced to marry the farmer at a young age and is scared of her husband."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698293Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2327-2
  a curric:KeyLearningPoint ;
  rdfs:label """The bride attempts to run away and then is chased and captured by a group of men."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698297Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2327-3
  a curric:KeyLearningPoint ;
  rdfs:label "When the bride returns she is locked up by her husband and becomes reclusive."@en ;
  dcterms:modified "2026-02-12T08:59:21.698302Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2327-4
  a curric:KeyLearningPoint ;
  rdfs:label "Despite her refusal to speak, the farmer still fantasises about his wife."@en ;
  dcterms:modified "2026-02-12T08:59:21.698306Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2327-5
  a curric:KeyLearningPoint ;
  rdfs:label """Mew was writing at a time when women's position in society was often restrictive."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698311Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1688-1
  a curric:KeyLearningPoint ;
  rdfs:label """The poems that you choose to compare should both be linked to the focus and nuances of the question you are asked."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698315Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1688-2
  a curric:KeyLearningPoint ;
  rdfs:label """Focus your introduction and topic sentences on connections and contrasts between ideas, not devices."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698322Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1688-3
  a curric:KeyLearningPoint ;
  rdfs:label "Reference poetic devices and draw attention to them, not simply the literary."@en ;
  dcterms:modified "2026-02-12T08:59:21.698327Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1688-4
  a curric:KeyLearningPoint ;
  rdfs:label """You can use poetic devices and ideas about form and structure to help support your topic sentences."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698331Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2355-1
  a curric:KeyLearningPoint ;
  rdfs:label """The speaker of the poem begins fairly sure of his views on divisions/togetherness but becomes more uncertain later on."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698338Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2355-2
  a curric:KeyLearningPoint ;
  rdfs:label """Kunial uses aspirational language to show the speaker's uncertainty towards the end of the poem."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698343Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2355-3
  a curric:KeyLearningPoint ;
  rdfs:label """Kunial playfully explores sounds and words which link to "us" and emphasise this as the central idea of the poem."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698348Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2355-4
  a curric:KeyLearningPoint ;
  rdfs:label """There are many examples of partial rhymes, alliteration and assonance throughout the poem."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698352Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2355-5
  a curric:KeyLearningPoint ;
  rdfs:label """Punctuation and line breaks are used creatively to draw attention to particular phrases or ideas."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698356Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2544-1
  a curric:KeyLearningPoint ;
  rdfs:label "Robert Bridges' poetry reflects his deep Christian faith."@en ;
  dcterms:modified "2026-02-12T08:59:21.698361Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2544-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Clear and Gentle Stream' illustrates how Bridges was influenced by nature as well as his spirituality."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698370Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2544-3
  a curric:KeyLearningPoint ;
  rdfs:label """Bridges' use of natural imagery implies that humans belong in nature and that this sense of belonging will be lasting."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698375Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2544-4
  a curric:KeyLearningPoint ;
  rdfs:label """The religious connections in 'Clear and Gentle Stream' could suggest that our souls belong in nature."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698379Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9233-1
  a curric:KeyLearningPoint ;
  rdfs:label "Owen uses graphic imagery to portray the brutal reality of war."@en ;
  dcterms:modified "2026-02-12T08:59:21.698384Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9233-2
  a curric:KeyLearningPoint ;
  rdfs:label """Owen shows the vulnerability of the men in the beginning of the poem, contradicting the public perception of soldiers."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698388Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9233-3
  a curric:KeyLearningPoint ;
  rdfs:label "Owen uses figurative language to convey a vivid account of the gas attack."@en ;
  dcterms:modified "2026-02-12T08:59:21.698393Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9233-4
  a curric:KeyLearningPoint ;
  rdfs:label """Owen switches tense throughout the poem - perhaps to represent his experiences with PTSD."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698397Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9233-5
  a curric:KeyLearningPoint ;
  rdfs:label """The inclusion of three tenses arguably illustrates the impact that war has had on Owen’s past, present and future."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698402Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2533-1
  a curric:KeyLearningPoint ;
  rdfs:label "Topic sentences need to be clear, comparative and linked to the question."@en ;
  dcterms:modified "2026-02-12T08:59:21.698596Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2533-2
  a curric:KeyLearningPoint ;
  rdfs:label "Relevant quotations from the text are used to justify arguments."@en ;
  dcterms:modified "2026-02-12T08:59:21.698600Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2533-3
  a curric:KeyLearningPoint ;
  rdfs:label "Relevant contextual information can be used to develop arguments."@en ;
  dcterms:modified "2026-02-12T08:59:21.698605Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2533-4
  a curric:KeyLearningPoint ;
  rdfs:label """Responses should focus on the intention of the author to avoid retelling the story of the poem."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698610Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2533-5
  a curric:KeyLearningPoint ;
  rdfs:label """Comparative conjunctions should be used to compare key ideas as well as language, form and structure."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698614Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9243-1
  a curric:KeyLearningPoint ;
  rdfs:label "Larkin arguably presents us with a cynical view of family life in the poem."@en ;
  dcterms:modified "2026-02-12T08:59:21.698618Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9243-2
  a curric:KeyLearningPoint ;
  rdfs:label """This cynicism could be reflective of his mother’s attitudes towards marriage, which she shared with Larkin"""@en ;
  dcterms:modified "2026-02-12T08:59:21.698623Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9243-3
  a curric:KeyLearningPoint ;
  rdfs:label """The passage of time is a key theme in the poem; Larkin arguably presents time as a threat to the young parents."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698627Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9243-4
  a curric:KeyLearningPoint ;
  rdfs:label """Larkin arguably presents the monotony of family life as unfulfilling and arduous."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698632Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9243-5
  a curric:KeyLearningPoint ;
  rdfs:label """Larkin presents the young couples as emotionally-distant, their responsibilities have forced them apart."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698636Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1691-1
  a curric:KeyLearningPoint ;
  rdfs:label """Comparative introductions should give equal weighting to both poems and explore the big ideas in both poems."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698891Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1691-2
  a curric:KeyLearningPoint ;
  rdfs:label """Introductions should use correlative and comparative conjunctions to actively compare poems."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698896Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1691-3
  a curric:KeyLearningPoint ;
  rdfs:label """Introductions need not focus heavily on biographical details of poets or language devices."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698902Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1691-4
  a curric:KeyLearningPoint ;
  rdfs:label """An effective essay compares two poems on big ideas in question, weaving in comparison throughout paragraphs."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698907Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1691-5
  a curric:KeyLearningPoint ;
  rdfs:label """An effective comparative essay explores language, form and structure to support comparisons."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698912Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1679-1
  a curric:KeyLearningPoint ;
  rdfs:label "We can identify and explore modern and historic ideas about power and conflict."@en ;
  dcterms:modified "2026-02-12T08:59:21.698917Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1679-2
  a curric:KeyLearningPoint ;
  rdfs:label """Power might entail tyranny, hierarchy, dictatorship, tradition, progress, historical dominance or force."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698921Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1679-3
  a curric:KeyLearningPoint ;
  rdfs:label """Conflict might be: war; tradition vs progress; man vs nature; psychological; moral; personal vs national duty."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698928Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2423-1
  a curric:KeyLearningPoint ;
  rdfs:label """The craft of the jewellery maker is implied to be precise, focused and potentially dangerous."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698933Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2423-2
  a curric:KeyLearningPoint ;
  rdfs:label """‘The Jewellery Maker’ tells the narrative of an old man who makes beautiful jewellery in the sweltering heat."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698937Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2423-3
  a curric:KeyLearningPoint ;
  rdfs:label """The jewellery maker dreams of giving his creations to his wife, but instead they are bought by rich women."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698942Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2487-1
  a curric:KeyLearningPoint ;
  rdfs:label """Dooley uses metaphors to convey how the speaker yearns to have a closer relationship with the natural world."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698947Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2487-2
  a curric:KeyLearningPoint ;
  rdfs:label "Dooley uses natural imagery to romanticise the man’s life in a rural setting."@en ;
  dcterms:modified "2026-02-12T08:59:21.698951Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2487-3
  a curric:KeyLearningPoint ;
  rdfs:label """Dooley uses rhetorical questions to convey the moral value the speaker attaches to the natural world."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698956Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2487-4
  a curric:KeyLearningPoint ;
  rdfs:label """Dooley's use of tercets could mimic the brief and fleeting nature of the communication between the pair."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698960Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2487-5
  a curric:KeyLearningPoint ;
  rdfs:label """Dooley’s use of personal pronouns could mirror the ‘back and forth’ nature of their communication."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698965Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2534-1
  a curric:KeyLearningPoint ;
  rdfs:label "A poetry anthology is chosen with overall themes and ‘big ideas’ in mind."@en ;
  dcterms:modified "2026-02-12T08:59:21.698969Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2534-2
  a curric:KeyLearningPoint ;
  rdfs:label """We might conceptualise belonging as meaning ideas of family, place, positivity and connection."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698974Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2534-3
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, the anthology is just as much about not belonging as it is about belonging."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698978Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2534-4
  a curric:KeyLearningPoint ;
  rdfs:label """Exploring ideas of not belonging are just as important as arguably they reflect the realities of society."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698983Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2493-1
  a curric:KeyLearningPoint ;
  rdfs:label """Waterhouse use an extended metaphor to compare climbing a mountain with reflecting upon the past."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699149Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2493-2
  a curric:KeyLearningPoint ;
  rdfs:label """Waterhouse uses imagery to convey the precarious and multifaceted nature of the climb and remembering a loved one."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699153Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2493-3
  a curric:KeyLearningPoint ;
  rdfs:label """Waterhouse juxtaposes the comfort derived from the 'grandfather memory' with the painful process of reminiscing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699158Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2493-4
  a curric:KeyLearningPoint ;
  rdfs:label """Waterhouse uses imagery to create a peaceful and tranquil final image of the grandfather."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699162Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2493-5
  a curric:KeyLearningPoint ;
  rdfs:label """The single, unbroken stanza could reflect the unending process of grieving for a loved one."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699167Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2347-1
  a curric:KeyLearningPoint ;
  rdfs:label "It's a good idea to find thematic connections between the poems."@en ;
  dcterms:modified "2026-02-12T08:59:21.699171Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2347-2
  a curric:KeyLearningPoint ;
  rdfs:label """Theoretically, you can compare any of the anthology poems but it's useful to choose two which complement each other."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699176Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2347-3
  a curric:KeyLearningPoint ;
  rdfs:label """Thinking about why you chose to compare two poems can help you build a thesis statement."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699183Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2347-4
  a curric:KeyLearningPoint ;
  rdfs:label """Expanding your thesis statement into 'mini-arguments' can help you to build topic sentences."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699190Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2347-5
  a curric:KeyLearningPoint ;
  rdfs:label """A great way to build a concluding sentence is to make the opposite connections to your topic sentence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699194Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2425-1
  a curric:KeyLearningPoint ;
  rdfs:label "The subject of the poem is likely the speaker’s relative."@en ;
  dcterms:modified "2026-02-12T08:59:21.699462Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2425-2
  a curric:KeyLearningPoint ;
  rdfs:label """The speaker implies that the subject felt is necessary to hide their regional dialect."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699467Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2425-3
  a curric:KeyLearningPoint ;
  rdfs:label "The speaker is trying to keep the dialect alive by recreating it."@en ;
  dcterms:modified "2026-02-12T08:59:21.699471Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2425-4
  a curric:KeyLearningPoint ;
  rdfs:label "Arguably, Berry’s intention is to suggest the importance of accents to identity."@en ;
  dcterms:modified "2026-02-12T08:59:21.699476Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2354-1
  a curric:KeyLearningPoint ;
  rdfs:label "Kunial was born in Birmingham, to an English mother and Pakistani father."@en ;
  dcterms:modified "2026-02-12T08:59:21.699480Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2354-2
  a curric:KeyLearningPoint ;
  rdfs:label "Kunial's poems often refer to identity and cultural heritage."@en ;
  dcterms:modified "2026-02-12T08:59:21.699485Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2354-3
  a curric:KeyLearningPoint ;
  rdfs:label """In his poem 'Us', Kunial uses the collective pronoun to highlight how society needs to be more tolerant."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699489Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2354-4
  a curric:KeyLearningPoint ;
  rdfs:label "Kunial's poem is about both divisions and togetherness."@en ;
  dcterms:modified "2026-02-12T08:59:21.699494Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2354-5
  a curric:KeyLearningPoint ;
  rdfs:label """Although the speaker of the poem believes in unity, they admit this is difficult with their personal relationships."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699499Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2537-1
  a curric:KeyLearningPoint ;
  rdfs:label """Like other Romantic poets, Brontë uses natural imagery to present human emotions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699503Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2537-2
  a curric:KeyLearningPoint ;
  rdfs:label "Brontë lived a quiet and reclusive life in the Yorkshire countryside."@en ;
  dcterms:modified "2026-02-12T08:59:21.699508Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2537-3
  a curric:KeyLearningPoint ;
  rdfs:label """Some may argue Brontë's poem is about the sense of security and belonging her nostalgic memories bring."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699512Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2537-4
  a curric:KeyLearningPoint ;
  rdfs:label "Others may claim there is a melancholic tone to the poem."@en ;
  dcterms:modified "2026-02-12T08:59:21.699516Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9261-1
  a curric:KeyLearningPoint ;
  rdfs:label "A good analytical response begins with a clear and concise thesis statement."@en ;
  dcterms:modified "2026-02-12T08:59:21.699521Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9261-2
  a curric:KeyLearningPoint ;
  rdfs:label """Comparative connectives can be used to link ideas together and explore connections between poems."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699526Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9261-3
  a curric:KeyLearningPoint ;
  rdfs:label """Quotations can be signposted with where they appear in the poem e.g. 'in the final stanza'."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699530Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9261-4
  a curric:KeyLearningPoint ;
  rdfs:label "Analysis can move from exploring holistic ideas through to specific methods."@en ;
  dcterms:modified "2026-02-12T08:59:21.699537Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9261-5
  a curric:KeyLearningPoint ;
  rdfs:label "Context should be used to support your argument."@en ;
  dcterms:modified "2026-02-12T08:59:21.699542Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29077-1
  a curric:KeyLearningPoint ;
  rdfs:label """Analysing model answers allows us to explore how we might frame ideas and how to avoid misconceptions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699547Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29077-2
  a curric:KeyLearningPoint ;
  rdfs:label """An effective introduction should clearly set out the argument of the essay in relation to the question."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699551Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29077-3
  a curric:KeyLearningPoint ;
  rdfs:label """One misconception is to interweave quotations from both poems but not effectively analyse them."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699556Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29077-4
  a curric:KeyLearningPoint ;
  rdfs:label """Another misconception is to point out differences between the poems but not effectively analyse them."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699560Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2326-1
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, Nagra uses anaphora to depict the speaker's joyful and equitable relationship with his wife."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699787Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2326-2
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, Nagra uses a simile to euphemistically convey the speaker's intimacy with his wife."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699794Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2326-3
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, Nagra uses contrast to show how the couple find romance in the mundanity of their lives."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699799Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2326-4
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, Nagra uses imagery to convey the conflict between the unconventional wife and more traditional parents."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699804Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2329-1
  a curric:KeyLearningPoint ;
  rdfs:label """The poem starts with the speaker feeling unsettled but is soon warmed physically and emotionally by Porphyria's arrival."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699808Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2329-2
  a curric:KeyLearningPoint ;
  rdfs:label "Porphyria begins to undress and instigates intimacy with the speaker."@en ;
  dcterms:modified "2026-02-12T08:59:21.699813Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2329-3
  a curric:KeyLearningPoint ;
  rdfs:label """The speaker seems to want ownership of Porphyria and is jealous she has a life outside of his."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699817Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2329-4
  a curric:KeyLearningPoint ;
  rdfs:label """The speaker strangles Porphyria with her own hair and marvels how he can then keep Porphyria like a doll."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699822Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2329-5
  a curric:KeyLearningPoint ;
  rdfs:label """Browning was writing at a time when Porphyria's sexual and suggestive manner would have been transgressive."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699826Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6255-1
  a curric:KeyLearningPoint ;
  rdfs:label """The anthology poems all arguably consider conflict and its impact on the people who experience it."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699833Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6255-2
  a curric:KeyLearningPoint ;
  rdfs:label """The poems that you choose to compare should both be linked to the focus and nuances of the question you are asked."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699838Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6255-3
  a curric:KeyLearningPoint ;
  rdfs:label """It is useful to consider the similarities between poems and then consider any subtle differences between them."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699843Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6255-4
  a curric:KeyLearningPoint ;
  rdfs:label "Concluding sentences should have a sharp focus on the writer’s intention."@en ;
  dcterms:modified "2026-02-12T08:59:21.699847Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2538-1
  a curric:KeyLearningPoint ;
  rdfs:label "We might interpret Brontë’s poem as evoking either nostalgia or melancholia."@en ;
  dcterms:modified "2026-02-12T08:59:21.699865Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2538-2
  a curric:KeyLearningPoint ;
  rdfs:label """The use of euphonic sounds and a regular rhyme associate a sense of peace with the speaker’s memories."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699870Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2538-3
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, Brontë is adhering to Romantic nostalgia in presenting a longing for the past."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699875Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2538-4
  a curric:KeyLearningPoint ;
  rdfs:label """The use of pathetic fallacy and alternating rhythm could create a sense of melancholia."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699879Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2538-5
  a curric:KeyLearningPoint ;
  rdfs:label "Arguably, the melancholia is associated with nature rather than the speaker."@en ;
  dcterms:modified "2026-02-12T08:59:21.699884Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9242-1
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, Dove tells a series of stories in the poem that all illustrate her love for her husband."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699888Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9242-2
  a curric:KeyLearningPoint ;
  rdfs:label "Dove uses humour to avoid this becoming a cliched poem about love."@en ;
  dcterms:modified "2026-02-12T08:59:21.699893Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9242-3
  a curric:KeyLearningPoint ;
  rdfs:label "Dove portrays her relationship as mundane, but secure and safe."@en ;
  dcterms:modified "2026-02-12T08:59:21.699898Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9242-4
  a curric:KeyLearningPoint ;
  rdfs:label """A person’s interpretation of a poem is unique to them; as long as it can be supported with evidence, it is valid."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699902Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9242-5
  a curric:KeyLearningPoint ;
  rdfs:label """It can be useful to consider multiple interpretations of a poem to enhance your understanding of it."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699907Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29064-1
  a curric:KeyLearningPoint ;
  rdfs:label """Both Hardy and Armitage arguably depict the dehumanising effect of war through the treatment of fallen soldiers’ bodies."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699911Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29064-2
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, both Hardy and Armitage suggest that the soldiers were somewhere that they didn’t belong."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699918Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29064-3
  a curric:KeyLearningPoint ;
  rdfs:label """While Hardy may imply the soldiers’ ignorance of the realities of war, Armitage arguably shows the uncertainty of war."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699925Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29064-4
  a curric:KeyLearningPoint ;
  rdfs:label """We might interpret the regular rhyme of ‘Drummer Hodge’ as showing ideas of inevitability."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699930Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29064-5
  a curric:KeyLearningPoint ;
  rdfs:label """However, the irregularity of ‘Remains’ may instead suggest the unpredictable nature of war."""@en ;
  dcterms:modified "2026-02-12T08:59:21.699935Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1615-1
  a curric:KeyLearningPoint ;
  rdfs:label """Orwell presents the pigs in a nuanced way exposing both their positive and negative qualities."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700179Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1615-2
  a curric:KeyLearningPoint ;
  rdfs:label "Summaries are a useful way to embed key character information."@en ;
  dcterms:modified "2026-02-12T08:59:21.700186Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1615-3
  a curric:KeyLearningPoint ;
  rdfs:label """Exploring comparisons in summaries can offer a more nuanced perspective of characters."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700191Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1623-1
  a curric:KeyLearningPoint ;
  rdfs:label "Context refers to the historical, social, literary and biographical."@en ;
  dcterms:modified "2026-02-12T08:59:21.700562Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1623-2
  a curric:KeyLearningPoint ;
  rdfs:label "Context should not be presented as isolated facts or generalisations."@en ;
  dcterms:modified "2026-02-12T08:59:21.700567Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1623-3
  a curric:KeyLearningPoint ;
  rdfs:label "Context should be relevant to the analysis and embedded in the response."@en ;
  dcterms:modified "2026-02-12T08:59:21.700571Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1623-4
  a curric:KeyLearningPoint ;
  rdfs:label """Context should develop your ideas and give an insight into the writer’s purpose and intention."""@en ;
  dcterms:modified "2026-02-12T08:59:21.700576Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1618-1
  a curric:KeyLearningPoint ;
  rdfs:label "Quotes should be judiciously chosen."@en ;
  dcterms:modified "2026-02-12T08:59:21.700581Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1618-2
  a curric:KeyLearningPoint ;
  rdfs:label "Single paragraph outlines can be used to practice finding supporting details."@en ;
  dcterms:modified "2026-02-12T08:59:21.700585Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1618-3
  a curric:KeyLearningPoint ;
  rdfs:label "Quotes should be analysed using a layered approach."@en ;
  dcterms:modified "2026-02-12T08:59:21.700590Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1620-1
  a curric:KeyLearningPoint ;
  rdfs:label "Planning topic sentences is an important part of the writing process."@en ;
  dcterms:modified "2026-02-12T08:59:21.701154Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1620-2
  a curric:KeyLearningPoint ;
  rdfs:label """Topic sentences are structurally important in supporting your overarching argument."""@en ;
  dcterms:modified "2026-02-12T08:59:21.701158Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1620-3
  a curric:KeyLearningPoint ;
  rdfs:label """Using discourse markers at the beginning of a topic sentence can help you logically sequence your response."""@en ;
  dcterms:modified "2026-02-12T08:59:21.701163Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1620-4
  a curric:KeyLearningPoint ;
  rdfs:label "Single paragraph outlines are en effective way to plan paragraphs."@en ;
  dcterms:modified "2026-02-12T08:59:21.701167Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1620-5
  a curric:KeyLearningPoint ;
  rdfs:label "Conclusive discourse markers are an effective way to begin concluding sentences."@en ;
  dcterms:modified "2026-02-12T08:59:21.701174Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28392-1
  a curric:KeyLearningPoint ;
  rdfs:label "To emulate Horowitz's reassuring resolution, we might choose a calming setting."@en ;
  dcterms:modified "2026-02-12T08:59:21.701513Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28392-2
  a curric:KeyLearningPoint ;
  rdfs:label "We may then use superlatives and tactile imagery to describe that setting."@en ;
  dcterms:modified "2026-02-12T08:59:21.701520Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28392-3
  a curric:KeyLearningPoint ;
  rdfs:label """We might use a simile and colour imagery in order to diminish the threat of a criminal in our writing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.701527Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28392-4
  a curric:KeyLearningPoint ;
  rdfs:label """Finally, we may use symbolism to represent the idea that evil has been contained and controlled."""@en ;
  dcterms:modified "2026-02-12T08:59:21.701531Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28037-1
  a curric:KeyLearningPoint ;
  rdfs:label "An essay should have a strong central argument."@en ;
  dcterms:modified "2026-02-12T08:59:21.701704Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28037-2
  a curric:KeyLearningPoint ;
  rdfs:label """Use an evaluative or critical thesis to 'hang' your essay on and support with clear topic sentences."""@en ;
  dcterms:modified "2026-02-12T08:59:21.701711Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28037-3
  a curric:KeyLearningPoint ;
  rdfs:label """Analysis of writer's methods should be interwoven and used to support each other."""@en ;
  dcterms:modified "2026-02-12T08:59:21.701716Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28037-4
  a curric:KeyLearningPoint ;
  rdfs:label """Essays should focus on the writer’s intentions - the conclusion is an opportunity to summarise this."""@en ;
  dcterms:modified "2026-02-12T08:59:21.701720Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2399-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘Leave Taking’ is considered a classic in the canon of Black British playwrights."""@en ;
  dcterms:modified "2026-02-12T08:59:21.701842Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2399-2
  a curric:KeyLearningPoint ;
  rdfs:label "Having a Black British female cleaner as the heroine was groundbreaking."@en ;
  dcterms:modified "2026-02-12T08:59:21.701847Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2399-3
  a curric:KeyLearningPoint ;
  rdfs:label "Pinnock wanted to explore the unique Black British experience in her writing."@en ;
  dcterms:modified "2026-02-12T08:59:21.701852Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2399-4
  a curric:KeyLearningPoint ;
  rdfs:label """One reason that ‘Leave Taking’ is universal is that the character of Enid seems to resonate particularly with audiences."""@en ;
  dcterms:modified "2026-02-12T08:59:21.701856Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2399-5
  a curric:KeyLearningPoint ;
  rdfs:label "The play remains relevant because of the Windrush scandal."@en ;
  dcterms:modified "2026-02-12T08:59:21.701861Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1624-1
  a curric:KeyLearningPoint ;
  rdfs:label """Using a success criteria to look at model essays is a good way to understand and embed the expectations of writing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.701866Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1624-2
  a curric:KeyLearningPoint ;
  rdfs:label """Reading model essays is a great way to find adaptable phrases and ideas for your own essays."""@en ;
  dcterms:modified "2026-02-12T08:59:21.701870Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1624-3
  a curric:KeyLearningPoint ;
  rdfs:label "Using WWW and EBI is an efficient way to identify areas of improvement."@en ;
  dcterms:modified "2026-02-12T08:59:21.701877Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1624-4
  a curric:KeyLearningPoint ;
  rdfs:label "Rewriting model essays will help you be more critical of your own writing."@en ;
  dcterms:modified "2026-02-12T08:59:21.701882Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1613-1
  a curric:KeyLearningPoint ;
  rdfs:label """Animal Farm is a microcosm because it is a self-contained representation of a larger society and system."""@en ;
  dcterms:modified "2026-02-12T08:59:21.701887Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1613-2
  a curric:KeyLearningPoint ;
  rdfs:label """The windmill represents how progress can better a society, but can also be exploited."""@en ;
  dcterms:modified "2026-02-12T08:59:21.701891Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1613-3
  a curric:KeyLearningPoint ;
  rdfs:label "Food is used to symbolise luxury and inequality."@en ;
  dcterms:modified "2026-02-12T08:59:21.701896Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1613-4
  a curric:KeyLearningPoint ;
  rdfs:label "Flags and rituals are used to both galvanise the animals and maintain control."@en ;
  dcterms:modified "2026-02-12T08:59:21.701900Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1625-1
  a curric:KeyLearningPoint ;
  rdfs:label """Reading the question and picking out key words is useful in order to understand its expectations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.701905Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1625-2
  a curric:KeyLearningPoint ;
  rdfs:label "Planning key points helps to create an overarching argument."@en ;
  dcterms:modified "2026-02-12T08:59:21.701909Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1625-3
  a curric:KeyLearningPoint ;
  rdfs:label """Single paragraph outlines are useful in creating a detailed plan for the main body of an essay."""@en ;
  dcterms:modified "2026-02-12T08:59:21.701917Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1625-4
  a curric:KeyLearningPoint ;
  rdfs:label "Using success criteria is an effective way to help write an essay."@en ;
  dcterms:modified "2026-02-12T08:59:21.701921Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28074-1
  a curric:KeyLearningPoint ;
  rdfs:label """Dickens' detailed descriptions of the Cratchits and their belongings emphasise how they are living in abject poverty."""@en ;
  dcterms:modified "2026-02-12T08:59:21.702015Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28074-2
  a curric:KeyLearningPoint ;
  rdfs:label """He conveys the message 'money doesn't buy happiness' by showing how they value family time over material possessions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.702020Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28074-3
  a curric:KeyLearningPoint ;
  rdfs:label """Dickens encourages his wealthy readers to show compassion by using the Cratchits to humanise poor people."""@en ;
  dcterms:modified "2026-02-12T08:59:21.702029Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28074-4
  a curric:KeyLearningPoint ;
  rdfs:label """Poor Victorians lived in cramped conditions and endured awful working conditions to avoid debtors prisons or workhouses."""@en ;
  dcterms:modified "2026-02-12T08:59:21.702034Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28074-5
  a curric:KeyLearningPoint ;
  rdfs:label """There was a lot of social stigma around poverty; many believed poor Victorians were lazy, stupid or morally inferior."""@en ;
  dcterms:modified "2026-02-12T08:59:21.702070Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2403-1
  a curric:KeyLearningPoint ;
  rdfs:label "Del is pregnant and is going to raise her child alone."@en ;
  dcterms:modified "2026-02-12T08:59:21.702102Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2403-2
  a curric:KeyLearningPoint ;
  rdfs:label "Viv offers Del the money their mother gave her for her university education."@en ;
  dcterms:modified "2026-02-12T08:59:21.702109Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2403-3
  a curric:KeyLearningPoint ;
  rdfs:label "Viv expresses her frustrations with the school system."@en ;
  dcterms:modified "2026-02-12T08:59:21.702114Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2403-4
  a curric:KeyLearningPoint ;
  rdfs:label "Viv tells Del she skipped one of her English exams."@en ;
  dcterms:modified "2026-02-12T08:59:21.702118Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2403-5
  a curric:KeyLearningPoint ;
  rdfs:label """Del tells Viv that she must complete all of her exams, and says she won’t see her until she does."""@en ;
  dcterms:modified "2026-02-12T08:59:21.702123Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1611-1
  a curric:KeyLearningPoint ;
  rdfs:label "'Animal Farm' has a cyclical structure"@en ;
  dcterms:modified "2026-02-12T08:59:21.702255Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1611-2
  a curric:KeyLearningPoint ;
  rdfs:label "The novella ends with the pigs being indistinguishable from men"@en ;
  dcterms:modified "2026-02-12T08:59:21.702266Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1611-3
  a curric:KeyLearningPoint ;
  rdfs:label "Many of the original ideals have now been forgotten or completely subverted"@en ;
  dcterms:modified "2026-02-12T08:59:21.702271Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1611-4
  a curric:KeyLearningPoint ;
  rdfs:label "Orwell shows how power and control are always inevitable"@en ;
  dcterms:modified "2026-02-12T08:59:21.702276Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1611-5
  a curric:KeyLearningPoint ;
  rdfs:label """The commandments are simplified into one maxim, implying the pigs are better than the other animals"""@en ;
  dcterms:modified "2026-02-12T08:59:21.702280Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29025-1
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, gender stereotypes and expectations exist in society and impact the way we perceive ourselves and others."""@en ;
  dcterms:modified "2026-02-12T08:59:21.702423Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29025-2
  a curric:KeyLearningPoint ;
  rdfs:label """Gender and class are inextricably linked and impact the lives and experiences of people differently."""@en ;
  dcterms:modified "2026-02-12T08:59:21.702428Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29025-3
  a curric:KeyLearningPoint ;
  rdfs:label "Gender roles were more traditionally defined in Edwardian society."@en ;
  dcterms:modified "2026-02-12T08:59:21.702432Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29025-4
  a curric:KeyLearningPoint ;
  rdfs:label """Priestley was writing in post-war Britain which saw the traditional expectations of gender roles being challenged."""@en ;
  dcterms:modified "2026-02-12T08:59:21.702437Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29025-5
  a curric:KeyLearningPoint ;
  rdfs:label """Priestley’s ending is both hopeful, with characters challenging views, and futile, as society repeats its mistakes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.702444Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1601-1
  a curric:KeyLearningPoint ;
  rdfs:label "Orwell was influenced by his varied life experiences"@en ;
  dcterms:modified "2026-02-12T08:59:21.702449Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1601-2
  a curric:KeyLearningPoint ;
  rdfs:label """Orwell was against authoritarian regimes and viewed his writing as a way to criticise the abuse of power"""@en ;
  dcterms:modified "2026-02-12T08:59:21.702454Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1601-3
  a curric:KeyLearningPoint ;
  rdfs:label "'Animal Farm' is an allegory for the Russian Revolution"@en ;
  dcterms:modified "2026-02-12T08:59:21.702458Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1601-4
  a curric:KeyLearningPoint ;
  rdfs:label """Orwell was a democratic socialist and against the ideals of communism which he saw as easily corruptible and flawed"""@en ;
  dcterms:modified "2026-02-12T08:59:21.702462Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1601-5
  a curric:KeyLearningPoint ;
  rdfs:label "'Animal Farm' explores themes of power and hierarchy"@en ;
  dcterms:modified "2026-02-12T08:59:21.702467Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2407-1
  a curric:KeyLearningPoint ;
  rdfs:label "Enid faced hardship growing up in Jamaica."@en ;
  dcterms:modified "2026-02-12T08:59:21.702564Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2407-2
  a curric:KeyLearningPoint ;
  rdfs:label "Enid experienced a strong sense of community growing up in Jamaica."@en ;
  dcterms:modified "2026-02-12T08:59:21.702569Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2407-3
  a curric:KeyLearningPoint ;
  rdfs:label "Enid’s life in England is still characterised by hardship."@en ;
  dcterms:modified "2026-02-12T08:59:21.702575Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2407-4
  a curric:KeyLearningPoint ;
  rdfs:label "Arguably, Enid is more isolated in Britain than in Jamaica."@en ;
  dcterms:modified "2026-02-12T08:59:21.702580Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1605-1
  a curric:KeyLearningPoint ;
  rdfs:label """The pigs position themselves as leaders and take advantange of the other animals' relative stupidity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.702585Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1605-2
  a curric:KeyLearningPoint ;
  rdfs:label "The animals seek to spread news of their revolution to other farms."@en ;
  dcterms:modified "2026-02-12T08:59:21.702589Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1605-3
  a curric:KeyLearningPoint ;
  rdfs:label "Snowball shows exceptional valour in the 'Battle of the Cowshed'."@en ;
  dcterms:modified "2026-02-12T08:59:21.702593Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1605-4
  a curric:KeyLearningPoint ;
  rdfs:label """The simplifying of the commandments into one maxim, means the rules of Animalism lack nuance."""@en ;
  dcterms:modified "2026-02-12T08:59:21.702598Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2406-1
  a curric:KeyLearningPoint ;
  rdfs:label "Del sits exams with Mai to prove she is capable of being an obeah woman."@en ;
  dcterms:modified "2026-02-12T08:59:21.702796Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2406-2
  a curric:KeyLearningPoint ;
  rdfs:label "Mai has a serious heart condition that will prove fatal."@en ;
  dcterms:modified "2026-02-12T08:59:21.702801Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2406-3
  a curric:KeyLearningPoint ;
  rdfs:label "Mai gives Del her notebook which contains everything she knows about obeah."@en ;
  dcterms:modified "2026-02-12T08:59:21.702808Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2406-4
  a curric:KeyLearningPoint ;
  rdfs:label "Enid justifies the choices she made in bringing up her daughters."@en ;
  dcterms:modified "2026-02-12T08:59:21.702812Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2406-5
  a curric:KeyLearningPoint ;
  rdfs:label "The play ends with Del reading Enid’s palm."@en ;
  dcterms:modified "2026-02-12T08:59:21.702817Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1604-1
  a curric:KeyLearningPoint ;
  rdfs:label "The pigs are the most intelligent animals on the farm."@en ;
  dcterms:modified "2026-02-12T08:59:21.702824Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1604-2
  a curric:KeyLearningPoint ;
  rdfs:label "Squealer uses rhetoric to control the less intelligent animals."@en ;
  dcterms:modified "2026-02-12T08:59:21.702829Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1604-3
  a curric:KeyLearningPoint ;
  rdfs:label "The pigs appear to be taking advantage of their position as leaders."@en ;
  dcterms:modified "2026-02-12T08:59:21.702833Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1607-1
  a curric:KeyLearningPoint ;
  rdfs:label "The motif of slavery is used to illustrate the plight of the animals"@en ;
  dcterms:modified "2026-02-12T08:59:21.702838Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1607-2
  a curric:KeyLearningPoint ;
  rdfs:label """The pigs violate the commandments by moving into the farm house and making deals with Mr. Whymper who is human"""@en ;
  dcterms:modified "2026-02-12T08:59:21.702843Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1607-3
  a curric:KeyLearningPoint ;
  rdfs:label "The pigs doctor the commandments"@en ;
  dcterms:modified "2026-02-12T08:59:21.702847Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1607-4
  a curric:KeyLearningPoint ;
  rdfs:label """Squealer uses rhetoric to convince the animals that life is better than under Jones"""@en ;
  dcterms:modified "2026-02-12T08:59:21.702852Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1607-5
  a curric:KeyLearningPoint ;
  rdfs:label "The revolution is not as idealistic as initially promised"@en ;
  dcterms:modified "2026-02-12T08:59:21.702856Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2415-1
  a curric:KeyLearningPoint ;
  rdfs:label "A thesis statement is a clear, overarching argument."@en ;
  dcterms:modified "2026-02-12T08:59:21.703203Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2415-2
  a curric:KeyLearningPoint ;
  rdfs:label "Topic sentences give focus to individual paragraphs."@en ;
  dcterms:modified "2026-02-12T08:59:21.703207Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2415-3
  a curric:KeyLearningPoint ;
  rdfs:label "Topic sentences should support the overarching thesis."@en ;
  dcterms:modified "2026-02-12T08:59:21.703212Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2415-4
  a curric:KeyLearningPoint ;
  rdfs:label "Select main quotations and supporting quotations to include in an essay."@en ;
  dcterms:modified "2026-02-12T08:59:21.703219Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2415-5
  a curric:KeyLearningPoint ;
  rdfs:label """Main quotations should be analysed; supporting quotations don’t need to be analysed."""@en ;
  dcterms:modified "2026-02-12T08:59:21.703224Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2417-1
  a curric:KeyLearningPoint ;
  rdfs:label "Annotate an essay question so you know its focus."@en ;
  dcterms:modified "2026-02-12T08:59:21.703399Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2417-2
  a curric:KeyLearningPoint ;
  rdfs:label "A successful plan follows a clear structure."@en ;
  dcterms:modified "2026-02-12T08:59:21.703404Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2417-3
  a curric:KeyLearningPoint ;
  rdfs:label "A thesis is a clear overarching argument supported by the whole text."@en ;
  dcterms:modified "2026-02-12T08:59:21.703411Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2417-4
  a curric:KeyLearningPoint ;
  rdfs:label "Topic sentences state a paragraph's main idea."@en ;
  dcterms:modified "2026-02-12T08:59:21.703416Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2417-5
  a curric:KeyLearningPoint ;
  rdfs:label """Concluding sentences focus on the writer’s intentions and link to your topic sentence, without repeating it."""@en ;
  dcterms:modified "2026-02-12T08:59:21.703421Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2439-1
  a curric:KeyLearningPoint ;
  rdfs:label "The title 'Thirteen' has connotations of an unlucky, transitional period."@en ;
  dcterms:modified "2026-02-12T08:59:21.703525Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2439-2
  a curric:KeyLearningPoint ;
  rdfs:label """The poem implies the officers now perceive the boy as threatening because he has transitioned from child to adolescent."""@en ;
  dcterms:modified "2026-02-12T08:59:21.703530Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2439-3
  a curric:KeyLearningPoint ;
  rdfs:label "There is a power imbalance between the officers and the boy."@en ;
  dcterms:modified "2026-02-12T08:59:21.703534Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2439-4
  a curric:KeyLearningPoint ;
  rdfs:label "The boy feels physically intimidated and scared by the officers,"@en ;
  dcterms:modified "2026-02-12T08:59:21.703539Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2439-5
  a curric:KeyLearningPoint ;
  rdfs:label """The poem is based on Femi’s real-life experience of being stopped by police and falsely accused when he was thirteen."""@en ;
  dcterms:modified "2026-02-12T08:59:21.703543Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2387-1
  a curric:KeyLearningPoint ;
  rdfs:label """Identifying the overall tone of a text can help to understand the writer’s attitude."""@en ;
  dcterms:modified "2026-02-12T08:59:21.703548Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2387-2
  a curric:KeyLearningPoint ;
  rdfs:label "Comparing the tone used by each writer makes for a subtle point of comparison"@en ;
  dcterms:modified "2026-02-12T08:59:21.703555Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2387-3
  a curric:KeyLearningPoint ;
  rdfs:label """When writers share similar attitudes, it is possible to evaluate the different methods they use to convey these ideas"""@en ;
  dcterms:modified "2026-02-12T08:59:21.703560Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2387-4
  a curric:KeyLearningPoint ;
  rdfs:label "Always consider why the author has selected the form that they have"@en ;
  dcterms:modified "2026-02-12T08:59:21.703567Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6251-1
  a curric:KeyLearningPoint ;
  rdfs:label """The structure of a poem arguably represents the journey of a concept or idea through the poem."""@en ;
  dcterms:modified "2026-02-12T08:59:21.703575Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6251-2
  a curric:KeyLearningPoint ;
  rdfs:label """The structure of the poem could represent the connection between the speaker’s identity and their ancestor’s life."""@en ;
  dcterms:modified "2026-02-12T08:59:21.703580Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6251-3
  a curric:KeyLearningPoint ;
  rdfs:label "Seneviratne uses metaphysical language to consider the nature of time"@en ;
  dcterms:modified "2026-02-12T08:59:21.703584Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6251-4
  a curric:KeyLearningPoint ;
  rdfs:label "Arguably, Seneviratne represents time as existing in a constant cyclical motion."@en ;
  dcterms:modified "2026-02-12T08:59:21.703589Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2438-1
  a curric:KeyLearningPoint ;
  rdfs:label """Berry may have utilised contrasting pairs to show the inherent differences between people"""@en ;
  dcterms:modified "2026-02-12T08:59:21.703593Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2438-2
  a curric:KeyLearningPoint ;
  rdfs:label """The existence of these contrasting pairs within the framework of the poem could represent people coexisting in society."""@en ;
  dcterms:modified "2026-02-12T08:59:21.703598Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2438-3
  a curric:KeyLearningPoint ;
  rdfs:label "The structural progression of the poem shows the subjects forming a connection."@en ;
  dcterms:modified "2026-02-12T08:59:21.703602Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2438-4
  a curric:KeyLearningPoint ;
  rdfs:label "Berry may have done this to show how open communication can lead to connections"@en ;
  dcterms:modified "2026-02-12T08:59:21.703607Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1701-1
  a curric:KeyLearningPoint ;
  rdfs:label "The poem’s title may reflect the long-lasting unpleasant effects of war."@en ;
  dcterms:modified "2026-02-12T08:59:21.703649Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1701-2
  a curric:KeyLearningPoint ;
  rdfs:label """In ‘Remains', Armitage explores the PTSD and other disorders that many veterans deal with."""@en ;
  dcterms:modified "2026-02-12T08:59:21.703653Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1701-3
  a curric:KeyLearningPoint ;
  rdfs:label """The poem is taken from a collection called ‘The Not Dead’, based on interviews with soldiers from Iraq and Gulf Wars."""@en ;
  dcterms:modified "2026-02-12T08:59:21.703658Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1701-4
  a curric:KeyLearningPoint ;
  rdfs:label """The speaker’s battle with PTSD may reflect the long-term effects of conflict that are left unnoticed by society."""@en ;
  dcterms:modified "2026-02-12T08:59:21.703663Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2431-1
  a curric:KeyLearningPoint ;
  rdfs:label """Dharker’s use of natural imagery may connect to the growth of the girls’ resistance and fight against their oppressors."""@en ;
  dcterms:modified "2026-02-12T08:59:21.703707Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2431-2
  a curric:KeyLearningPoint ;
  rdfs:label """The image of the poppy may acknowledge that sacrifices will be made but that there is hope for the girls’ protest."""@en ;
  dcterms:modified "2026-02-12T08:59:21.703711Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2431-3
  a curric:KeyLearningPoint ;
  rdfs:label """The “bullet” may symbolise their failure to not only kill her but also their failure to silence the movement."""@en ;
  dcterms:modified "2026-02-12T08:59:21.703716Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2431-4
  a curric:KeyLearningPoint ;
  rdfs:label """Potentially, the enjambment in the poem links to the continuation of the girls’ fight."""@en ;
  dcterms:modified "2026-02-12T08:59:21.703720Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9246-1
  a curric:KeyLearningPoint ;
  rdfs:label """In the beginning of the poem, love is presented as nurturing, caring and pure - it brings connection and intimacy."""@en ;
  dcterms:modified "2026-02-12T08:59:21.703753Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9246-2
  a curric:KeyLearningPoint ;
  rdfs:label """Duffy presents love as something that many people strive to protect - something precious and valuable."""@en ;
  dcterms:modified "2026-02-12T08:59:21.703758Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9246-3
  a curric:KeyLearningPoint ;
  rdfs:label """Duffy explores the darker side of love, suggesting that love can have an irreversible and harmful effect."""@en ;
  dcterms:modified "2026-02-12T08:59:21.703762Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9246-4
  a curric:KeyLearningPoint ;
  rdfs:label """Duffy defies romanticised presentations of love; presenting us with a realistic portrayal of love that is often ignored."""@en ;
  dcterms:modified "2026-02-12T08:59:21.703767Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2499-1
  a curric:KeyLearningPoint ;
  rdfs:label """Armitage uses an extended metaphor to compare an expansive new house to the growing distance in a relationship."""@en ;
  dcterms:modified "2026-02-12T08:59:21.703847Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2499-2
  a curric:KeyLearningPoint ;
  rdfs:label """Armitage uses symbolism to represent the bond between the mother and son that exists despite the growing detachment."""@en ;
  dcterms:modified "2026-02-12T08:59:21.703851Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2499-3
  a curric:KeyLearningPoint ;
  rdfs:label """Armitage uses metaphors to convey the complex and nuanced maternal relationship in light of the physical separation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.703856Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2499-4
  a curric:KeyLearningPoint ;
  rdfs:label """Armitage conveys how the speaker's future is uncertain without the proximity and support of their mother."""@en ;
  dcterms:modified "2026-02-12T08:59:21.703860Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6253-1
  a curric:KeyLearningPoint ;
  rdfs:label """The anthology poems all arguably consider our connection and place within the wider world."""@en ;
  dcterms:modified "2026-02-12T08:59:21.703888Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6253-2
  a curric:KeyLearningPoint ;
  rdfs:label """The poems that you choose to compare should both be linked to the focus and nuances of the question you are asked."""@en ;
  dcterms:modified "2026-02-12T08:59:21.703893Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6253-3
  a curric:KeyLearningPoint ;
  rdfs:label """It is useful to consider the similarities between poems and then consider on any subtle differences between them."""@en ;
  dcterms:modified "2026-02-12T08:59:21.703897Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6253-4
  a curric:KeyLearningPoint ;
  rdfs:label "Concluding sentences should have a sharp focus on the writer’s intention."@en ;
  dcterms:modified "2026-02-12T08:59:21.703902Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2496-1
  a curric:KeyLearningPoint ;
  rdfs:label "The poets reminisce on memories of familial relations."@en ;
  dcterms:modified "2026-02-12T08:59:21.703907Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2496-2
  a curric:KeyLearningPoint ;
  rdfs:label "The poets convey the admiration they felt towards their loved ones."@en ;
  dcterms:modified "2026-02-12T08:59:21.703914Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2496-3
  a curric:KeyLearningPoint ;
  rdfs:label """The poets present the process of reminiscing on a loved one as complicated and multifaceted."""@en ;
  dcterms:modified "2026-02-12T08:59:21.703918Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2496-4
  a curric:KeyLearningPoint ;
  rdfs:label """Duffy and Waterhouse reflect on childhood memories, but Causley creates ambiguity, possibly symbolising the afterlife."""@en ;
  dcterms:modified "2026-02-12T08:59:21.703923Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2496-5
  a curric:KeyLearningPoint ;
  rdfs:label "Exploring differences within similarities can result in a nuanced analysis."@en ;
  dcterms:modified "2026-02-12T08:59:21.703927Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6252-1
  a curric:KeyLearningPoint ;
  rdfs:label """Both Eliot and Seneviratne present the negative impact of industrialisation on the environment and people."""@en ;
  dcterms:modified "2026-02-12T08:59:21.703964Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6252-2
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, Seneviratne’s poem is more optimistic since it shows there is a future for the city and its people."""@en ;
  dcterms:modified "2026-02-12T08:59:21.703969Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6252-3
  a curric:KeyLearningPoint ;
  rdfs:label "Both Eliot and Seneviratne show the impact of place on human connections."@en ;
  dcterms:modified "2026-02-12T08:59:21.703973Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6252-4
  a curric:KeyLearningPoint ;
  rdfs:label """Eliot depicts the connections between people through a sense of disconnection and loss of individuality."""@en ;
  dcterms:modified "2026-02-12T08:59:21.703978Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6252-5
  a curric:KeyLearningPoint ;
  rdfs:label """Seneviratne depicts the bond between people through the impact ancestors have on their descendants."""@en ;
  dcterms:modified "2026-02-12T08:59:21.703982Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9247-1
  a curric:KeyLearningPoint ;
  rdfs:label """You can highlight the key similarities between poems, but also explore their subtle differences (and vice versa)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704095Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9247-2
  a curric:KeyLearningPoint ;
  rdfs:label """Asking yourself questions about the poems, such as ‘how do the poets feel about X?' is useful when planning comparisons."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704100Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9247-3
  a curric:KeyLearningPoint ;
  rdfs:label """Comparative connectives are useful for highlighting similarities and/or differences between poems."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704104Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9247-4
  a curric:KeyLearningPoint ;
  rdfs:label """You should select your evidence carefully, by evaluating which quotations best support your argument."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704109Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9247-5
  a curric:KeyLearningPoint ;
  rdfs:label """Relevant context must be included in your comparison - think about the reasons for the poets’ different perspectives."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704113Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2507-1
  a curric:KeyLearningPoint ;
  rdfs:label """Satyamurti is a sociologist with an interest in the stories people tell about themselves."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704209Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2507-2
  a curric:KeyLearningPoint ;
  rdfs:label """The poem was published in the 1980s, against a backdrop of conflicts: the Falklands War and the Arab-Israeli conflict."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704213Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2507-3
  a curric:KeyLearningPoint ;
  rdfs:label """The poem addresses the contrast between the atrocities of war and those safe at home."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704218Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2507-4
  a curric:KeyLearningPoint ;
  rdfs:label """The ‘story’ behind many images of conflict published by the media can often be misunderstood."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704222Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2507-5
  a curric:KeyLearningPoint ;
  rdfs:label """A war photographer's job is one with moral implications: they raise awareness of conflict but are powerless to help."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704227Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2426-1
  a curric:KeyLearningPoint ;
  rdfs:label """Berry may have personified the accent in order to show the emotional connection between voice and individual."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704271Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2426-2
  a curric:KeyLearningPoint ;
  rdfs:label """Berry uses vivid sound imagery such as onomatopoeia and cacophony within the poem."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704276Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2426-3
  a curric:KeyLearningPoint ;
  rdfs:label """Berry’s juxtaposition of the regular stanzas yet the irregular rhyme may represent the struggle of the accent to escape."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704280Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2426-4
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, the anaphora emphasises the speaker’s desire to form a connection and shared identity with the speaker."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704285Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9238-1
  a curric:KeyLearningPoint ;
  rdfs:label """The poems that you choose to compare should both be linked to the focus and nuances of the question you are asked."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704290Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9238-2
  a curric:KeyLearningPoint ;
  rdfs:label """Focus your introduction and topic sentences on connections and contrasts between ideas, not devices."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704294Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9238-3
  a curric:KeyLearningPoint ;
  rdfs:label """It is useful to consider the similarities between poems and then consider any subtle differences between them."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704299Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9238-4
  a curric:KeyLearningPoint ;
  rdfs:label "You can consider the different contexts of poems as part of your comparison."@en ;
  dcterms:modified "2026-02-12T08:59:21.704303Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9238-5
  a curric:KeyLearningPoint ;
  rdfs:label """Whereas most of the poems present the horrors of war, Brooke is the most patriotic in his writing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704310Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20156-1
  a curric:KeyLearningPoint ;
  rdfs:label """The poem is written from the perspective of a drowsy hawk, who muses on his life as a predator."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704315Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20156-2
  a curric:KeyLearningPoint ;
  rdfs:label """The hawk’s voice is characterised as egotistical and conceited; he revels in the power that nature has allowed him."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704320Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20156-3
  a curric:KeyLearningPoint ;
  rdfs:label """The poem explores the instinctive savagery and violence of nature; the hawk is therefore amoral."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704324Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20156-4
  a curric:KeyLearningPoint ;
  rdfs:label """The poem was published in 1960, and many people thought that the hawk may be a metaphor for fascist dictators."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704329Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20156-5
  a curric:KeyLearningPoint ;
  rdfs:label """Hughes stated that he wanted to explore the power and complexity of nature through this poem."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704333Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2032-1
  a curric:KeyLearningPoint ;
  rdfs:label """This poem is part of Dharker’s collection 'Terrorist at My Table' written at a time when her partner was terminally ill."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704486Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2032-2
  a curric:KeyLearningPoint ;
  rdfs:label "The speaker in this poem uses tissue as an extended metaphor for life."@en ;
  dcterms:modified "2026-02-12T08:59:21.704491Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2032-3
  a curric:KeyLearningPoint ;
  rdfs:label """Dharker uses the homonym "tissue" to draw parallels to the fragility of both paper and human life."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704495Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2032-4
  a curric:KeyLearningPoint ;
  rdfs:label """Imtiaz Dharker was born in Pakistan but moved to Glasgow when she was under a year of age."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704500Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2032-5
  a curric:KeyLearningPoint ;
  rdfs:label """Dharker turned down the Poet Laureate role in 2019 in order to maintain the personal nature of her work."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704504Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1706-1
  a curric:KeyLearningPoint ;
  rdfs:label """The poem reveals the difficult and complex emotions that a war photographer may experience."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704509Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1706-2
  a curric:KeyLearningPoint ;
  rdfs:label """The symbolic space of the dark room might suggest isolation and depression due to trauma."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704513Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1706-3
  a curric:KeyLearningPoint ;
  rdfs:label """The use of a tight and predictable structure in the poem may contrast the chaos of war with the order of civilian life."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704518Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1706-4
  a curric:KeyLearningPoint ;
  rdfs:label """The final stanza has a caustic tone created through sharp plosives and mocking the insensitivity of indifference."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704522Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1706-5
  a curric:KeyLearningPoint ;
  rdfs:label """There is a sense of disillusionment communicated through the poem’s simple monosyllabic final line."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704527Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1696-1
  a curric:KeyLearningPoint ;
  rdfs:label "‘Bayonet Charge’ depicts a soldier in the midst of a harrowing battle."@en ;
  dcterms:modified "2026-02-12T08:59:21.704534Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1696-2
  a curric:KeyLearningPoint ;
  rdfs:label """‘Bayonet Charge’ exposes how war damages people, innocence and the natural world."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704539Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1696-3
  a curric:KeyLearningPoint ;
  rdfs:label """Hughes’ intention may be to criticise the patriotic ideals surrounding war and expose the true horrors of war."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704543Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1696-4
  a curric:KeyLearningPoint ;
  rdfs:label "Hughes may have based his poem on his father’s stories of WW1 ."@en ;
  dcterms:modified "2026-02-12T08:59:21.704548Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1696-5
  a curric:KeyLearningPoint ;
  rdfs:label """Hughes' fathers stories were so vivid that Hughes felt he himself had witnessed the apocalyptic carnage."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704552Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1705-1
  a curric:KeyLearningPoint ;
  rdfs:label """The speaker may be based on Duffy’s friend, Don McCullin, a photojournalist who was moved by his time in warzones."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704556Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1705-2
  a curric:KeyLearningPoint ;
  rdfs:label "In the poem, photojournalism is depicted as an important and necessary job."@en ;
  dcterms:modified "2026-02-12T08:59:21.704563Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1705-3
  a curric:KeyLearningPoint ;
  rdfs:label """Many photojournalists wish for their photos to incite awareness and social action in the public."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704568Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1705-4
  a curric:KeyLearningPoint ;
  rdfs:label """Duffy's 'War Photographer' seems to criticise our increasing indifference to the victims of conflict."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704572Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1705-5
  a curric:KeyLearningPoint ;
  rdfs:label """The poem explores the lesser-explored experiences of psychological and moral conflict that war presents."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704577Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1698-1
  a curric:KeyLearningPoint ;
  rdfs:label """'Charge of the Light Brigade', 'Bayonet Charge', and 'Exposure' are all poems about war."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704581Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1698-2
  a curric:KeyLearningPoint ;
  rdfs:label """'Exposure' and 'Bayonet Charge' both convey the futility of war and convey the links between war and nature."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704586Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1698-3
  a curric:KeyLearningPoint ;
  rdfs:label """'Charge of the Light Brigade' and 'Bayonet Charge' both expose the truth about powerful ideas and powerful people."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704591Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1698-4
  a curric:KeyLearningPoint ;
  rdfs:label """Comparative thesis statements should provide an overarching argument and focus on both poems as a whole."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704595Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1698-5
  a curric:KeyLearningPoint ;
  rdfs:label "Comparative topic sentences should have a clear focus and link to the question."@en ;
  dcterms:modified "2026-02-12T08:59:21.704600Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6250-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘A Wider View’ begins in the past and considers the life of the speaker’s great-great grandfather."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704604Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6250-2
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, the Industrial Revolution has made his life physically harsh and metaphorically restricted it."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704609Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6250-3
  a curric:KeyLearningPoint ;
  rdfs:label """When shifting to the present time, the poem implies that the past “echoes” and impacts the present."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704613Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6250-4
  a curric:KeyLearningPoint ;
  rdfs:label """Seneviratne arguably reminds the reader of the importance of place when considering identity and heritage."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704618Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1702-1
  a curric:KeyLearningPoint ;
  rdfs:label """Armitage uses language and structure to expose the traumatic events in war and the effects of conflict."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704666Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1702-2
  a curric:KeyLearningPoint ;
  rdfs:label """Enjambment and caesura may reflect the soldier’s disturbed mind and lack of control over his emotions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704670Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1702-3
  a curric:KeyLearningPoint ;
  rdfs:label """Syntactic parallelism is used to demonstrate the soldier’s ongoing battle with his accountability."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704675Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1702-4
  a curric:KeyLearningPoint ;
  rdfs:label """Imagery in lines 26-29 contrasts the distant warzone, highlighting the public’s false view of their separation from war."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704679Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1702-5
  a curric:KeyLearningPoint ;
  rdfs:label "The present tense reflects the power of the past in the present."@en ;
  dcterms:modified "2026-02-12T08:59:21.704684Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1609-1
  a curric:KeyLearningPoint ;
  rdfs:label "Squealer uses statistics to inflate the success of the pigs' rule"@en ;
  dcterms:modified "2026-02-12T08:59:21.704704Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1609-2
  a curric:KeyLearningPoint ;
  rdfs:label "The windmill is finally completed"@en ;
  dcterms:modified "2026-02-12T08:59:21.704709Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1609-3
  a curric:KeyLearningPoint ;
  rdfs:label """Despite the many deaths, injuries and loss of the the windmill, the pigs declare the battle a success"""@en ;
  dcterms:modified "2026-02-12T08:59:21.704714Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1609-4
  a curric:KeyLearningPoint ;
  rdfs:label "The pigs drink alcohol, breaking another of the commandments"@en ;
  dcterms:modified "2026-02-12T08:59:21.704718Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1609-5
  a curric:KeyLearningPoint ;
  rdfs:label "The pigs continue to rewrite the commandments to suit their own needs"@en ;
  dcterms:modified "2026-02-12T08:59:21.704723Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1621-1
  a curric:KeyLearningPoint ;
  rdfs:label """Underlining key words in an essay question helps identify what the focus of the question is."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704727Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1621-2
  a curric:KeyLearningPoint ;
  rdfs:label """The 'how' in the question refers to language devices, character arcs and structural devices."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704732Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1621-3
  a curric:KeyLearningPoint ;
  rdfs:label "Connect key words in the question to key themes in the novella."@en ;
  dcterms:modified "2026-02-12T08:59:21.704739Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1621-4
  a curric:KeyLearningPoint ;
  rdfs:label "Connect key words in a question to key plot points in the novella."@en ;
  dcterms:modified "2026-02-12T08:59:21.704743Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1621-5
  a curric:KeyLearningPoint ;
  rdfs:label """A thesis statement is an overarching argument and should include the writer's purpose."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704748Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2490-1
  a curric:KeyLearningPoint ;
  rdfs:label "The speaker meets his parents in an ambiguous ‘dream-like’ location."@en ;
  dcterms:modified "2026-02-12T08:59:21.704921Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2490-2
  a curric:KeyLearningPoint ;
  rdfs:label "The speaker describes his parents, particularly his mother, in intricate detail."@en ;
  dcterms:modified "2026-02-12T08:59:21.704925Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2490-3
  a curric:KeyLearningPoint ;
  rdfs:label """The speaker also describes the picnic in intricate detail, suggesting he is recalling a memory."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704930Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2490-4
  a curric:KeyLearningPoint ;
  rdfs:label """The speaker is separated from his parents by a stream which they encourage him to cross"""@en ;
  dcterms:modified "2026-02-12T08:59:21.704934Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2490-5
  a curric:KeyLearningPoint ;
  rdfs:label """Causley grew up in Cornwall and has suggested that the fictional 'Eden Rock' is based on the Cornish landscape."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704939Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20154-1
  a curric:KeyLearningPoint ;
  rdfs:label "The poem describes the unsafe living conditions of the slums in Mumbai."@en ;
  dcterms:modified "2026-02-12T08:59:21.704944Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20154-2
  a curric:KeyLearningPoint ;
  rdfs:label """Dharker illustrates the adversity these slum communities face, but celebrates their resourcefulness and resilience."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704948Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20154-3
  a curric:KeyLearningPoint ;
  rdfs:label "She illustrates how faith unites this community."@en ;
  dcterms:modified "2026-02-12T08:59:21.704953Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20154-4
  a curric:KeyLearningPoint ;
  rdfs:label """Dharker celebrates human beings’ incredible capacity for innovation and invention in the face of adversity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704957Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2491-1
  a curric:KeyLearningPoint ;
  rdfs:label """Causley uses biblical and mythical imagery to suggest his parents are in the afterlife."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704962Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2491-2
  a curric:KeyLearningPoint ;
  rdfs:label "Causley uses ethereal imagery to depict his mother as an angelic figure."@en ;
  dcterms:modified "2026-02-12T08:59:21.704969Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2491-3
  a curric:KeyLearningPoint ;
  rdfs:label """Causley uses precise sensory imagery to make the moment of reunion seem like a memory."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704973Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2491-4
  a curric:KeyLearningPoint ;
  rdfs:label """Causely uses an ambiguous resolution to leave the nature of the reunion a mystery."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704978Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2491-5
  a curric:KeyLearningPoint ;
  rdfs:label """Effective analysis writing is nuanced because it includes multiple interpretations of the text."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704983Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2314-1
  a curric:KeyLearningPoint ;
  rdfs:label """Nichols’ personification of nature may be to heighten the unjust treatment of nature by humanity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705015Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2314-2
  a curric:KeyLearningPoint ;
  rdfs:label """The link to the sonnet form through the length may be to show the love that the speaker has for nature and her heritage."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705020Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2314-3
  a curric:KeyLearningPoint ;
  rdfs:label """However, the lack of adherence to the sonnet form may show that humanity itself doesn’t love nature."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705024Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2314-4
  a curric:KeyLearningPoint ;
  rdfs:label """It may also be representative of the disconnect the speaker feels towards her home."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705029Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2314-5
  a curric:KeyLearningPoint ;
  rdfs:label """The irregularity of the poem may be indicative of the uncertainty towards the planet’s future."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705033Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2315-1
  a curric:KeyLearningPoint ;
  rdfs:label """The title implies that Antrobus’ intention is to encourage the reader to forge a connection with nature."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705038Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2315-2
  a curric:KeyLearningPoint ;
  rdfs:label "Arguably, the modern, urban world is presented as isolating."@en ;
  dcterms:modified "2026-02-12T08:59:21.705043Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2315-3
  a curric:KeyLearningPoint ;
  rdfs:label "In contrast, we might see nature as being full of life and connections."@en ;
  dcterms:modified "2026-02-12T08:59:21.705047Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2315-4
  a curric:KeyLearningPoint ;
  rdfs:label """Antrobus is a d/Deaf poet and the use of sound implies that silence can be enriching in certain circumstances."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705051Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2315-5
  a curric:KeyLearningPoint ;
  rdfs:label """Antrobus often explores themes of communication, connection, and cultural inheritance."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705056Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2497-1
  a curric:KeyLearningPoint ;
  rdfs:label """Context is a useful lens through which to consider the writer’s intentions and evaluate our interpretations of the text."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705127Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2497-2
  a curric:KeyLearningPoint ;
  rdfs:label """Contextual links should be relevant to analysis and not used as ‘bolt-on’ sentences."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705132Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2497-3
  a curric:KeyLearningPoint ;
  rdfs:label """Effective analysis begins with a strong thesis statement, introducing key ideas and the relationship between both texts."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705136Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2497-4
  a curric:KeyLearningPoint ;
  rdfs:label """Single paragraph outlines are useful tools to plan comparative analysis paragraphs."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705141Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2410-1
  a curric:KeyLearningPoint ;
  rdfs:label """Unlike Viv, Del appears uninterested in obeah and her culture at the start of the play."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705173Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2410-2
  a curric:KeyLearningPoint ;
  rdfs:label """Del feels her opportunities in life are hampered by the fact she is a second generation immigrant."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705180Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2410-3
  a curric:KeyLearningPoint ;
  rdfs:label "Del struggles to see where she fits in with both her family and Britain."@en ;
  dcterms:modified "2026-02-12T08:59:21.705184Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2410-4
  a curric:KeyLearningPoint ;
  rdfs:label """At the end of the play, Del’s calling to obeah could reflect a sense of understanding about her place in the world."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705189Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1602-1
  a curric:KeyLearningPoint ;
  rdfs:label "Mr Jones is the drunk and reckless owner of the farm."@en ;
  dcterms:modified "2026-02-12T08:59:21.705194Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1602-2
  a curric:KeyLearningPoint ;
  rdfs:label """Old Major is a well respected boar. He represents a challenge to authority and dominant ideology"""@en ;
  dcterms:modified "2026-02-12T08:59:21.705199Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1602-3
  a curric:KeyLearningPoint ;
  rdfs:label "Old Major uses rhetoric effectively to influence the animals."@en ;
  dcterms:modified "2026-02-12T08:59:21.705203Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1602-4
  a curric:KeyLearningPoint ;
  rdfs:label """Powers and hierarchical structures are already beginning to emerge. The pigs have more authority."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705208Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2400-1
  a curric:KeyLearningPoint ;
  rdfs:label "A Pastor comes over to Enid’s house for dinner."@en ;
  dcterms:modified "2026-02-12T08:59:21.705212Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2400-2
  a curric:KeyLearningPoint ;
  rdfs:label """Brod is critical of the sanitised version of the church he experiences in the UK."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705217Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2400-3
  a curric:KeyLearningPoint ;
  rdfs:label "Enid is not supportive of Viv’s desire to visit Jamaica and delay her education."@en ;
  dcterms:modified "2026-02-12T08:59:21.705221Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2400-4
  a curric:KeyLearningPoint ;
  rdfs:label "Pinnock describes Enid’s predicament as being \"caught between two worlds\"."@en ;
  dcterms:modified "2026-02-12T08:59:21.705226Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2400-5
  a curric:KeyLearningPoint ;
  rdfs:label "Enid learns of the death of her mother."@en ;
  dcterms:modified "2026-02-12T08:59:21.705230Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2441-1
  a curric:KeyLearningPoint ;
  rdfs:label "Both Mundair and Berry place their speakers in a liminal space."@en ;
  dcterms:modified "2026-02-12T08:59:21.705351Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2441-2
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, through this liminality, their intention could be to show the connection between place and identity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705358Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2441-3
  a curric:KeyLearningPoint ;
  rdfs:label """Both Mundair and Femi present the uncomfortable physical experience of discrimination."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705362Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2441-4
  a curric:KeyLearningPoint ;
  rdfs:label """Both Femi and Berry consider ideas of voice and agency to comment on the experience of minorities."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705367Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2498-1
  a curric:KeyLearningPoint ;
  rdfs:label """Armitage describes a mother helping her son move into his own home as he reaches adulthood."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705371Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2498-2
  a curric:KeyLearningPoint ;
  rdfs:label """The speaker’s new home seems huge and expansive, emphasising the growing distance between mother and child."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705376Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2498-3
  a curric:KeyLearningPoint ;
  rdfs:label """The speaker builds on the emotional distance between the mother and son as their physical distance increases."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705380Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2498-4
  a curric:KeyLearningPoint ;
  rdfs:label """Both speaker and subject seem apprehensive about the son's upcoming independence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705385Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2498-5
  a curric:KeyLearningPoint ;
  rdfs:label """The poem comes from ‘Books of Matches’, reflecting on ephemeral moments that make a deep impression."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705390Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9237-1
  a curric:KeyLearningPoint ;
  rdfs:label """Armitage uses figurative language to illustrate the severity of the soldier’s injuries - both physical and mental."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705411Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9237-2
  a curric:KeyLearningPoint ;
  rdfs:label """Armitage’s use of figurative language portrays the soldier as fragile and delicate, showing his vulnerability."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705415Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9237-3
  a curric:KeyLearningPoint ;
  rdfs:label """The use of rhyming couplets arguably reflect the unified approach the couple are taking to the soldier’s recovery."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705420Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9237-4
  a curric:KeyLearningPoint ;
  rdfs:label """Armitage's repetition could illustrate the constant and repeated support and care the wife demonstrates for her husband."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705424Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9237-5
  a curric:KeyLearningPoint ;
  rdfs:label """Armitage’s use of enjambment could reflect the couple’s continuous journey or rehabilitation and reconnection."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705429Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20155-1
  a curric:KeyLearningPoint ;
  rdfs:label "In the poem, Dharker shows us the unifying qualities of faith and hope."@en ;
  dcterms:modified "2026-02-12T08:59:21.705454Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20155-2
  a curric:KeyLearningPoint ;
  rdfs:label """Dharker juxtaposes shapes in the poem, arguably to reflect the fragility and beauty of human life."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705459Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20155-3
  a curric:KeyLearningPoint ;
  rdfs:label """The fragility of the eggs arguably reflects the fragility of the people’s hope and faith."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705463Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20155-4
  a curric:KeyLearningPoint ;
  rdfs:label """The poem’s irregular structure might reflect the irregular structure of the slum itself."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705470Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20155-5
  a curric:KeyLearningPoint ;
  rdfs:label """Dharker marvels at the way in which the slum communities find solutions to “problems” - she celebrates human ingenuity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705475Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1697-1
  a curric:KeyLearningPoint ;
  rdfs:label """Hughes shows the destructive nature of war through its impact on the soldier and the environment."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705531Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1697-2
  a curric:KeyLearningPoint ;
  rdfs:label """In medias res and the use of a chaotic and disorientating structure shows the inherent panic of conflict."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705536Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1697-3
  a curric:KeyLearningPoint ;
  rdfs:label """Hughes’ complex combination of violence, human body parts and weaponry blurs the line between the human and machine."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705541Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1697-4
  a curric:KeyLearningPoint ;
  rdfs:label """Hughes subverts pastoral imagery to show that warfare destroys the environment, peace and innocence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705545Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2501-1
  a curric:KeyLearningPoint ;
  rdfs:label """Day-Lewis uses a simile to show the overwhelming pain he feels initially at the separation from his son."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705550Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2501-2
  a curric:KeyLearningPoint ;
  rdfs:label """Day-Lewis uses natural imagery to convey how he feels his son is not yet ready to be independent."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705554Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2501-3
  a curric:KeyLearningPoint ;
  rdfs:label """Day-Lewis uses a metaphor to suggest how although this is a natural process, it can be painful and deeply impactful."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705559Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2501-4
  a curric:KeyLearningPoint ;
  rdfs:label """Day-Lewis uses the resolution to reveal how since the moment of parting, he has learnt the importance of it."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705563Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2501-5
  a curric:KeyLearningPoint ;
  rdfs:label """Day-Lewis' use of a regular rhyme scheme could mirror the stable nature of parental love."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705568Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9249-1
  a curric:KeyLearningPoint ;
  rdfs:label """When comparing poems, you should choose a poem that matches the poem you have been given thematically."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705572Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9249-2
  a curric:KeyLearningPoint ;
  rdfs:label """You can compare any of the poems from the anthology, though the poems should have some similarities for comparison."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705577Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9249-3
  a curric:KeyLearningPoint ;
  rdfs:label """Thesis statements help you to refine your argument and give you a point of reference to return to as you write."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705581Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9249-4
  a curric:KeyLearningPoint ;
  rdfs:label """Evidence should be selected judiciously - it is important to choose the quotation that best supports your argument."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705588Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2414-1
  a curric:KeyLearningPoint ;
  rdfs:label """Essays are extended pieces of writing in which you establish and explain your own ideas."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705648Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2414-2
  a curric:KeyLearningPoint ;
  rdfs:label """Underlining keywords and annotating an essay question helps direct your thinking."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705655Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2414-3
  a curric:KeyLearningPoint ;
  rdfs:label "It is useful to connect keywords to plot points and themes."@en ;
  dcterms:modified "2026-02-12T08:59:21.705660Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2414-4
  a curric:KeyLearningPoint ;
  rdfs:label "Essays begin with a thesis."@en ;
  dcterms:modified "2026-02-12T08:59:21.705664Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2414-5
  a curric:KeyLearningPoint ;
  rdfs:label "A thesis is an idea supported by the whole text."@en ;
  dcterms:modified "2026-02-12T08:59:21.705669Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1606-1
  a curric:KeyLearningPoint ;
  rdfs:label "Mollie leaves Animal Farm and is never spoken of again"@en ;
  dcterms:modified "2026-02-12T08:59:21.705674Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1606-2
  a curric:KeyLearningPoint ;
  rdfs:label "Snowball and Napoleon have different motivations"@en ;
  dcterms:modified "2026-02-12T08:59:21.705680Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1606-3
  a curric:KeyLearningPoint ;
  rdfs:label "Napoleon uses a range of strategies to gain power and control"@en ;
  dcterms:modified "2026-02-12T08:59:21.705685Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1606-4
  a curric:KeyLearningPoint ;
  rdfs:label "Snowball is used as a scapegoat and chased off the farm"@en ;
  dcterms:modified "2026-02-12T08:59:21.705690Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1606-5
  a curric:KeyLearningPoint ;
  rdfs:label """Squealer rewrites historical narratives to manipulate the animals and support Napoleon's rise to power"""@en ;
  dcterms:modified "2026-02-12T08:59:21.705694Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2421-1
  a curric:KeyLearningPoint ;
  rdfs:label "Topic sentences should link to the question."@en ;
  dcterms:modified "2026-02-12T08:59:21.705812Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2421-2
  a curric:KeyLearningPoint ;
  rdfs:label """References to the text should link to your topic sentence, come from across the play, and be rich in methods."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705817Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2421-3
  a curric:KeyLearningPoint ;
  rdfs:label """Writer’s methods should be explored without always relying on single word analysis."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705821Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2421-4
  a curric:KeyLearningPoint ;
  rdfs:label "Context should be woven into analysis, not bolted on to the end of a paragraph."@en ;
  dcterms:modified "2026-02-12T08:59:21.705828Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9258-1
  a curric:KeyLearningPoint ;
  rdfs:label """Throughout the poem, Heaney uses multi-sensory descriptions to create vivid imagery."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705966Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9258-2
  a curric:KeyLearningPoint ;
  rdfs:label """Heaney creates a grotesque description of the flax-dam, perhaps to foreshadow its capability to be threatening."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705971Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9258-3
  a curric:KeyLearningPoint ;
  rdfs:label """Heaney uses onomatopoeia in the poem to convey the speaker's enthusiasm for, and then later fear of, nature."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705976Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9258-4
  a curric:KeyLearningPoint ;
  rdfs:label """Heaney presents the power of nature by portraying the frogs as an army through the use of a semantic field."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705980Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9258-5
  a curric:KeyLearningPoint ;
  rdfs:label """Heaney perhaps aimed to show man's insignificance vs nature and discourage us from interfering in natural processes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705985Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2033-1
  a curric:KeyLearningPoint ;
  rdfs:label """Paper is presented as seemingly important to our lives but is ultimately insignificant."""@en ;
  dcterms:modified "2026-02-12T08:59:21.706043Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2033-2
  a curric:KeyLearningPoint ;
  rdfs:label """This free verse poem, without regular rhyme, reflects the unsteady nature of tissue, power and the transience of life."""@en ;
  dcterms:modified "2026-02-12T08:59:21.706047Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2033-3
  a curric:KeyLearningPoint ;
  rdfs:label """The early focus is on paper ‘tissue’ and its connection to human power. The latter focus is on human ‘tissue’ and life."""@en ;
  dcterms:modified "2026-02-12T08:59:21.706052Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2033-4
  a curric:KeyLearningPoint ;
  rdfs:label "The poem uses an extended metaphor throughout, comparing ‘tissue’ to human life."@en ;
  dcterms:modified "2026-02-12T08:59:21.706056Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20157-1
  a curric:KeyLearningPoint ;
  rdfs:label """Hughes' poem takes the form of a dramatic monolgue from the perspective of the hawk."""@en ;
  dcterms:modified "2026-02-12T08:59:21.706061Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20157-2
  a curric:KeyLearningPoint ;
  rdfs:label """The hawk is presented as omniscient and omnipotent because he appears to know everything and see everything."""@en ;
  dcterms:modified "2026-02-12T08:59:21.706065Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20157-3
  a curric:KeyLearningPoint ;
  rdfs:label """The hawk arguably views himself as a God-like figure in the poem, who controls life and death in the wood."""@en ;
  dcterms:modified "2026-02-12T08:59:21.706070Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20157-4
  a curric:KeyLearningPoint ;
  rdfs:label """The hawk is presented as an articulate speaker, highlighting that his power is more than just physical."""@en ;
  dcterms:modified "2026-02-12T08:59:21.706074Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20157-5
  a curric:KeyLearningPoint ;
  rdfs:label """Hughes uses personal pronouns, perhaps to show that the hawk’s only interest is his own survival - he is amoral."""@en ;
  dcterms:modified "2026-02-12T08:59:21.706079Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9236-1
  a curric:KeyLearningPoint ;
  rdfs:label """'The Manhunt' is from a collection of poems, *The Not Dead*, which explores the effect of recent conflict on soldiers."""@en ;
  dcterms:modified "2026-02-12T08:59:21.706223Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9236-2
  a curric:KeyLearningPoint ;
  rdfs:label """The speaker in the poem is a wife looking to reconnect with her husband who has returned from war."""@en ;
  dcterms:modified "2026-02-12T08:59:21.706228Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9236-3
  a curric:KeyLearningPoint ;
  rdfs:label """The wife tenderly explores her husband’s physical injuries, discovering his considerable mental scarring in the process."""@en ;
  dcterms:modified "2026-02-12T08:59:21.706233Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9236-4
  a curric:KeyLearningPoint ;
  rdfs:label """The poem is based on the relationship between a soldier and his wife that Armitage interviewed as part of a documentary."""@en ;
  dcterms:modified "2026-02-12T08:59:21.706237Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9236-5
  a curric:KeyLearningPoint ;
  rdfs:label """The poem explores the harrowing physical and psychological effects of war on both soldiers and their loved ones."""@en ;
  dcterms:modified "2026-02-12T08:59:21.706242Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2028-1
  a curric:KeyLearningPoint ;
  rdfs:label """Dual structure, highlighted by the use of italics , shows the separation between taught history and Black history."""@en ;
  dcterms:modified "2026-02-12T08:59:21.706274Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2028-2
  a curric:KeyLearningPoint ;
  rdfs:label """Plosives and monosyllabic words convey an indignant tone, showing the harm that is caused by colonial control."""@en ;
  dcterms:modified "2026-02-12T08:59:21.706281Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2028-3
  a curric:KeyLearningPoint ;
  rdfs:label """The poem is didactic, teaching the reader about Black history, encouraging them to find out about their own identity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.706286Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2028-4
  a curric:KeyLearningPoint ;
  rdfs:label """Natural imagery and light imagery is used to portray figures from Agard’s heritage, celebrating their power."""@en ;
  dcterms:modified "2026-02-12T08:59:21.706290Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2028-5
  a curric:KeyLearningPoint ;
  rdfs:label """The final stanza shows Agard’s move from passively learning history to actively researching culture and identity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.706295Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2440-1
  a curric:KeyLearningPoint ;
  rdfs:label """Femi uses “star” imagery throughout the poem to perhaps symbolise the boy’s loss of hope and opportunities."""@en ;
  dcterms:modified "2026-02-12T08:59:21.706300Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2440-2
  a curric:KeyLearningPoint ;
  rdfs:label """The use of the extended metaphor could perhaps suggest that people often perceive the boy as different from who he is."""@en ;
  dcterms:modified "2026-02-12T08:59:21.706304Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2440-3
  a curric:KeyLearningPoint ;
  rdfs:label "The structural progression of the poem could represent the boy’s journey."@en ;
  dcterms:modified "2026-02-12T08:59:21.706309Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2440-4
  a curric:KeyLearningPoint ;
  rdfs:label """The use of caesuras throughout could imply that Femi wants us to continually stop and consider the effects of prejudice."""@en ;
  dcterms:modified "2026-02-12T08:59:21.706313Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1626-1
  a curric:KeyLearningPoint ;
  rdfs:label "Topic sentences need to be clear and linked to the question."@en ;
  dcterms:modified "2026-02-12T08:59:21.706336Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1626-2
  a curric:KeyLearningPoint ;
  rdfs:label "Main and supporting quotations from the text are used to justify arguments."@en ;
  dcterms:modified "2026-02-12T08:59:21.706341Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1626-3
  a curric:KeyLearningPoint ;
  rdfs:label "Responses should avoid re-telling the plot."@en ;
  dcterms:modified "2026-02-12T08:59:21.706345Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1626-4
  a curric:KeyLearningPoint ;
  rdfs:label "Revising and editing your essays is an important part of the writing process."@en ;
  dcterms:modified "2026-02-12T08:59:21.706350Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1626-5
  a curric:KeyLearningPoint ;
  rdfs:label "Analysis should be linked to the writer’s purpose and comment on choices."@en ;
  dcterms:modified "2026-02-12T08:59:21.706356Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2418-1
  a curric:KeyLearningPoint ;
  rdfs:label "An introduction and conclusion could follow a three part structure."@en ;
  dcterms:modified "2026-02-12T08:59:21.706361Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2418-2
  a curric:KeyLearningPoint ;
  rdfs:label "An excellent introduction could start with a general statement about the text."@en ;
  dcterms:modified "2026-02-12T08:59:21.706366Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2418-3
  a curric:KeyLearningPoint ;
  rdfs:label """An introduction could then have a more specific statement about the focus of the question, followed by a thesis."""@en ;
  dcterms:modified "2026-02-12T08:59:21.706370Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2418-4
  a curric:KeyLearningPoint ;
  rdfs:label "A conclusion could consider the timeless nature of the text."@en ;
  dcterms:modified "2026-02-12T08:59:21.706375Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1699-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘Storm on the Island’ can be read as a poem about the power of nature on the Aran Islands."""@en ;
  dcterms:modified "2026-02-12T08:59:21.706420Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1699-2
  a curric:KeyLearningPoint ;
  rdfs:label """Heaney may have been influenced by the conflict between Protestants and Catholics in Northern Ireland."""@en ;
  dcterms:modified "2026-02-12T08:59:21.706429Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1699-3
  a curric:KeyLearningPoint ;
  rdfs:label """‘Storm on the Island’ was published in 1966, when the IRA were carrying out military operations in Northern Ireland."""@en ;
  dcterms:modified "2026-02-12T08:59:21.706434Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1699-4
  a curric:KeyLearningPoint ;
  rdfs:label "The storm can be read as an extended metaphor for ‘The Troubles’."@en ;
  dcterms:modified "2026-02-12T08:59:21.706438Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1699-5
  a curric:KeyLearningPoint ;
  rdfs:label """'The Troubles' refers to a violent thirty-year civil conflict in Ireland which led to around 3,500 deaths."""@en ;
  dcterms:modified "2026-02-12T08:59:21.706445Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2503-1
  a curric:KeyLearningPoint ;
  rdfs:label """Heaney uses imagery to convey the sense of wonder, awe and admiration felt towards a parental figure."""@en ;
  dcterms:modified "2026-02-12T08:59:21.706450Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2503-2
  a curric:KeyLearningPoint ;
  rdfs:label """Heaney uses powerful verbs to suggest how the speaker felt inadequate when with his father."""@en ;
  dcterms:modified "2026-02-12T08:59:21.706455Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2503-3
  a curric:KeyLearningPoint ;
  rdfs:label """Heaney uses the resolution to reveal how the roles of the father and son are reversed in their later years."""@en ;
  dcterms:modified "2026-02-12T08:59:21.706460Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2503-4
  a curric:KeyLearningPoint ;
  rdfs:label """The stable rhyme scheme could mirror the stable nature of parental support the speaker felt."""@en ;
  dcterms:modified "2026-02-12T08:59:21.706465Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2503-5
  a curric:KeyLearningPoint ;
  rdfs:label """Heaney’s use of caesura could indicate a turning point in the poem at the end of stanzas 2 and 6."""@en ;
  dcterms:modified "2026-02-12T08:59:21.706469Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9235-1
  a curric:KeyLearningPoint ;
  rdfs:label """Sheers uses a semantic field of fragility to demonstrate how delicate the soldiers were versus the brutality of war."""@en ;
  dcterms:modified "2026-02-12T08:59:21.706520Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9235-2
  a curric:KeyLearningPoint ;
  rdfs:label "The poet compares the soldiers’ bodies to beautiful, but very fragile objects."@en ;
  dcterms:modified "2026-02-12T08:59:21.706525Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9235-3
  a curric:KeyLearningPoint ;
  rdfs:label """Sheers uses imagery to illustrate what a senseless waste of life war is; he illustrates the devastating legacy of war."""@en ;
  dcterms:modified "2026-02-12T08:59:21.706532Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9235-4
  a curric:KeyLearningPoint ;
  rdfs:label """The poet uses the poem to show us how war affects not only people, but nature too."""@en ;
  dcterms:modified "2026-02-12T08:59:21.706536Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9235-5
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, the poem itself is a memorial to commemorate the Welsh soldiers of the 38th division."""@en ;
  dcterms:modified "2026-02-12T08:59:21.706541Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2502-1
  a curric:KeyLearningPoint ;
  rdfs:label """The speaker feels deep admiration for his father’s skill and prowess on the farm."""@en ;
  dcterms:modified "2026-02-12T08:59:21.706629Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2502-2
  a curric:KeyLearningPoint ;
  rdfs:label """The speaker sometimes felt incompetent or overwhelmed in the presence of his father."""@en ;
  dcterms:modified "2026-02-12T08:59:21.706634Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2502-3
  a curric:KeyLearningPoint ;
  rdfs:label """Despite the multifaceted nature of the relationship, the father and son were close and spent a lot of time together."""@en ;
  dcterms:modified "2026-02-12T08:59:21.706638Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2502-4
  a curric:KeyLearningPoint ;
  rdfs:label "The speaker and their father swap or reverse roles at the end of the poem."@en ;
  dcterms:modified "2026-02-12T08:59:21.706643Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2502-5
  a curric:KeyLearningPoint ;
  rdfs:label """Heaney has seemingly taken inspiration from his own past growing up in rural Ireland."""@en ;
  dcterms:modified "2026-02-12T08:59:21.706647Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1700-1
  a curric:KeyLearningPoint ;
  rdfs:label "Conflict between nature and man seems to be a 'big idea' in the poem."@en ;
  dcterms:modified "2026-02-12T08:59:21.706746Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1700-2
  a curric:KeyLearningPoint ;
  rdfs:label """The speaker opens with a confident assertion but becomes increasingly insecure and powerless as the storm progresses."""@en ;
  dcterms:modified "2026-02-12T08:59:21.706751Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1700-3
  a curric:KeyLearningPoint ;
  rdfs:label """The use of enjambment, volta, lack of rhyme and single stanza form may reflect nature’s omnipotence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.706755Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1700-4
  a curric:KeyLearningPoint ;
  rdfs:label """Iambic pentameter, colloquialisms and oxymorons may reflect speaker’s attempt to stay calm and confident in the storm."""@en ;
  dcterms:modified "2026-02-12T08:59:21.706760Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-1700-5
  a curric:KeyLearningPoint ;
  rdfs:label """The use of  half-rhyme may reflect the speaker’s futile attempts to assert control over nature."""@en ;
  dcterms:modified "2026-02-12T08:59:21.706765Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2432-1
  a curric:KeyLearningPoint ;
  rdfs:label """Shelley foregrounds the difference between the past and the present in ‘England in 1819’."""@en ;
  dcterms:modified "2026-02-12T08:59:21.706893Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2432-2
  a curric:KeyLearningPoint ;
  rdfs:label "Dharker suggests that the past impacts the present in ‘A century later’."@en ;
  dcterms:modified "2026-02-12T08:59:21.706899Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2432-3
  a curric:KeyLearningPoint ;
  rdfs:label """Shelley may draw our attention to one moment in time to imply the cyclical nature of oppression can be broken."""@en ;
  dcterms:modified "2026-02-12T08:59:21.706904Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2432-4
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, Dharker refers to the past to imply that we are caught in a a recurring cycle of violence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.706909Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2432-5
  a curric:KeyLearningPoint ;
  rdfs:label """both poems advocate for the importance of considering the temporal context of a poem in order to understand its meaning."""@en ;
  dcterms:modified "2026-02-12T08:59:21.706916Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2508-1
  a curric:KeyLearningPoint ;
  rdfs:label "Juxtaposing images are used between the second and third stanza."@en ;
  dcterms:modified "2026-02-12T08:59:21.706920Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2508-2
  a curric:KeyLearningPoint ;
  rdfs:label "The poem is written in free verse which could increase the feeling of reality."@en ;
  dcterms:modified "2026-02-12T08:59:21.706925Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2508-3
  a curric:KeyLearningPoint ;
  rdfs:label """Caesura is used after 'almost-smile', perhaps to reflect happiness being cut short."""@en ;
  dcterms:modified "2026-02-12T08:59:21.706932Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2508-4
  a curric:KeyLearningPoint ;
  rdfs:label "Arguably, the photographer is presented as a predator."@en ;
  dcterms:modified "2026-02-12T08:59:21.706936Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2508-5
  a curric:KeyLearningPoint ;
  rdfs:label "Intense and vivid imagery is used to capture the realities of war."@en ;
  dcterms:modified "2026-02-12T08:59:21.706941Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9245-1
  a curric:KeyLearningPoint ;
  rdfs:label """The poem ‘Valentine’ is an unconventional love poem, which subverts the conventions of traditional love poems."""@en ;
  dcterms:modified "2026-02-12T08:59:21.706946Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9245-2
  a curric:KeyLearningPoint ;
  rdfs:label """The speaker gives her lover an onion and explains why this is a better metaphor for their relationship than a rose."""@en ;
  dcterms:modified "2026-02-12T08:59:21.706950Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9245-3
  a curric:KeyLearningPoint ;
  rdfs:label """The onion arguably represents both the joy in relationships, but also the pain and suffering that people endure."""@en ;
  dcterms:modified "2026-02-12T08:59:21.706955Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9245-4
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, the poet feels that conventional romantic gifts are cliché, and limit people’s freedom of expression."""@en ;
  dcterms:modified "2026-02-12T08:59:21.706961Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9245-5
  a curric:KeyLearningPoint ;
  rdfs:label """The tone shifts throughout the poem; the poem ends with an ominous tone, perhaps to show the dangers of possessive love."""@en ;
  dcterms:modified "2026-02-12T08:59:21.706966Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9234-1
  a curric:KeyLearningPoint ;
  rdfs:label "‘Mametz Wood’ was inspired by the Battle of Mametz Wood in 1916."@en ;
  dcterms:modified "2026-02-12T08:59:21.706984Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9234-2
  a curric:KeyLearningPoint ;
  rdfs:label """Sheers tells the story of the discovery of the bodies of 20 young men, all of whom were slaughtered in battle."""@en ;
  dcterms:modified "2026-02-12T08:59:21.706989Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9234-3
  a curric:KeyLearningPoint ;
  rdfs:label """Some people attribute the 4000 deaths in the battle to poor tactical decisions made by commanders."""@en ;
  dcterms:modified "2026-02-12T08:59:21.706993Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9234-4
  a curric:KeyLearningPoint ;
  rdfs:label "The poem conveys how devastating, destructive and futile war is."@en ;
  dcterms:modified "2026-02-12T08:59:21.707001Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9234-5
  a curric:KeyLearningPoint ;
  rdfs:label """The poet illustrates that war affects not only people, but nature too, as the land has been scarred by violence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707008Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2396-1
  a curric:KeyLearningPoint ;
  rdfs:label "‘Leave Taking’ is set in London"@en ;
  dcterms:modified "2026-02-12T08:59:21.707013Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2396-2
  a curric:KeyLearningPoint ;
  rdfs:label "There are five characters in the play, of two different generations"@en ;
  dcterms:modified "2026-02-12T08:59:21.707018Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2396-3
  a curric:KeyLearningPoint ;
  rdfs:label "Enid and Brod moved to England from Jamaica when they were younger"@en ;
  dcterms:modified "2026-02-12T08:59:21.707022Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2396-4
  a curric:KeyLearningPoint ;
  rdfs:label "Enid’s daughters were born, and have grown up in, London"@en ;
  dcterms:modified "2026-02-12T08:59:21.707027Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2396-5
  a curric:KeyLearningPoint ;
  rdfs:label "Obeah is a series of spell-casting and healing traditions found in the Caribbean"@en ;
  dcterms:modified "2026-02-12T08:59:21.707031Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2313-1
  a curric:KeyLearningPoint ;
  rdfs:label """Comparing the speaker to an “heiress” could imply that they are set to inherit the value of the natural world."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707100Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2313-2
  a curric:KeyLearningPoint ;
  rdfs:label """However, imagery associated with the natural world is that of destruction which could show the damage humanity has done."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707105Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2313-3
  a curric:KeyLearningPoint ;
  rdfs:label """Comparison to “tourist” could connect to how humanity exploits the natural world."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707109Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2313-4
  a curric:KeyLearningPoint ;
  rdfs:label """On the other hand, “tourist” could link to how the speaker feels disconnected from their home and heritage."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707114Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2311-1
  a curric:KeyLearningPoint ;
  rdfs:label """Robinson moved to Trinidad aged four with his Trinidadian parents and then returned to England after fifteen years."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707221Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2311-2
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, the title 'A Portable Paradise' can be read as an extended metaphor for the speaker’s Trinidadian heritage."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707226Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2311-3
  a curric:KeyLearningPoint ;
  rdfs:label """Robinson might be suggesting that our 'portable paradise' provides an internal hope when life is difficult."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707230Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2311-4
  a curric:KeyLearningPoint ;
  rdfs:label """Robinson may also be referencing the struggles of migration through the poem and the pressure to integrate."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707235Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6254-1
  a curric:KeyLearningPoint ;
  rdfs:label "Topic sentences must be comparative when comparing texts."@en ;
  dcterms:modified "2026-02-12T08:59:21.707242Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6254-2
  a curric:KeyLearningPoint ;
  rdfs:label "Comparisons should be made between ideas, intentions, themes, and messages."@en ;
  dcterms:modified "2026-02-12T08:59:21.707247Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6254-3
  a curric:KeyLearningPoint ;
  rdfs:label """Correlative and comparative conjunctions are a good way to signpost your comparative writing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707251Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6254-4
  a curric:KeyLearningPoint ;
  rdfs:label """Within paragraphs, evidence can move back and forth between the two poems and be linked with connectives."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707256Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6254-5
  a curric:KeyLearningPoint ;
  rdfs:label """Drawing a direct comparison of quotations should take place at least once across the essay."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707261Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6248-1
  a curric:KeyLearningPoint ;
  rdfs:label """Summarising each poem individually in relation to the question helps to begin building a thesis statement."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707309Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6248-2
  a curric:KeyLearningPoint ;
  rdfs:label "Topic sentences should be specific, precise and express duality."@en ;
  dcterms:modified "2026-02-12T08:59:21.707314Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6248-3
  a curric:KeyLearningPoint ;
  rdfs:label "Evidence should be embedded into analytical paragraphs."@en ;
  dcterms:modified "2026-02-12T08:59:21.707318Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6248-4
  a curric:KeyLearningPoint ;
  rdfs:label "Tentative language should be used to explore interpretations within analysis."@en ;
  dcterms:modified "2026-02-12T08:59:21.707323Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2494-1
  a curric:KeyLearningPoint ;
  rdfs:label """The speaker is initially looking at a photo and reminiscing about their mother’s life before she had children."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707346Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2494-2
  a curric:KeyLearningPoint ;
  rdfs:label """The mother's life seemed glamorous, rebellious and full of promise before the speaker was born."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707351Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2494-3
  a curric:KeyLearningPoint ;
  rdfs:label """The speaker feels her birth made her mother's life more mundane due to the responsibilities of parenthood."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707357Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2494-4
  a curric:KeyLearningPoint ;
  rdfs:label """Duffy is a feminist writer who often criticises conventional and restrictive roles for women."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707362Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2494-5
  a curric:KeyLearningPoint ;
  rdfs:label """This poem is semi-autobiographical, based on photographs of Duffy’s mother as a young woman."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707367Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2027-1
  a curric:KeyLearningPoint ;
  rdfs:label """Agard received a Eurocentric perspective on history, growing up in Guyana whilst it was a British colony."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707448Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2027-2
  a curric:KeyLearningPoint ;
  rdfs:label """Agard shares his indignation that the education system restricted him from understanding his full identity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707453Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2027-3
  a curric:KeyLearningPoint ;
  rdfs:label """In his poem, Agard affirms his Caribbean heritage through his use of Guyanese creole."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707457Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2027-4
  a curric:KeyLearningPoint ;
  rdfs:label """Agard celebrates Caribbean figures, neglected in his history lessons, in the italicised sections of the poem."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707464Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-2027-5
  a curric:KeyLearningPoint ;
  rdfs:label """One of Agard’s messages could be the importance of breaking free from restrictive systems."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707469Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9215-1
  a curric:KeyLearningPoint ;
  rdfs:label """An anthology is a collection of artistic works that have a similar form or subject."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707473Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9215-2
  a curric:KeyLearningPoint ;
  rdfs:label """Reading poetry from multiple centuries helps us understand how the world we know today has been shaped by our history."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707478Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9215-3
  a curric:KeyLearningPoint ;
  rdfs:label """Exploring titles and quotations from poems can help you see potential connections between them."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707482Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9215-4
  a curric:KeyLearningPoint ;
  rdfs:label "Our personal response to a poem is important."@en ;
  dcterms:modified "2026-02-12T08:59:21.707487Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28035-1
  a curric:KeyLearningPoint ;
  rdfs:label """One interpretation might suggest that Orwell is using the narrator to say that truth is spoken in ordinary language."""@en ;
  dcterms:modified "2026-02-12T08:59:21.709239Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28035-2
  a curric:KeyLearningPoint ;
  rdfs:label """However, arguably, the narrator withholds information on the pigs’ behaviour rather than explicitly saying the truth."""@en ;
  dcterms:modified "2026-02-12T08:59:21.709243Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28035-3
  a curric:KeyLearningPoint ;
  rdfs:label """Furthermore, we may see the narrator as justifying the pigs’ actions and therefore being complicit in their oppression."""@en ;
  dcterms:modified "2026-02-12T08:59:21.709248Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29047-1
  a curric:KeyLearningPoint ;
  rdfs:label """In Elizabethan England, violence and honour were arguably seen as integral to masculinity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.709253Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29047-2
  a curric:KeyLearningPoint ;
  rdfs:label """We might see Romeo's killing of Tybalt as conforming to masculine expectations and leading to his downfall."""@en ;
  dcterms:modified "2026-02-12T08:59:21.709258Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29047-3
  a curric:KeyLearningPoint ;
  rdfs:label "In Elizabethan England, obedience was arguably seen as integral to femininity."@en ;
  dcterms:modified "2026-02-12T08:59:21.709262Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29047-4
  a curric:KeyLearningPoint ;
  rdfs:label """By marrying Romeo, Juliet subverts the expectations of how a daughter should behave."""@en ;
  dcterms:modified "2026-02-12T08:59:21.709267Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29047-5
  a curric:KeyLearningPoint ;
  rdfs:label """However, we might see Juliet as conforming to societal expectations of how a wife should behave."""@en ;
  dcterms:modified "2026-02-12T08:59:21.709271Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28021-1
  a curric:KeyLearningPoint ;
  rdfs:label "Blood is a motif that is associated with guilt in 'Macbeth'."@en ;
  dcterms:modified "2026-02-12T08:59:21.711371Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28021-2
  a curric:KeyLearningPoint ;
  rdfs:label """Initially, both Lady Macbeth and Macbeth's reference to blood reflects their guilt and intact conscience."""@en ;
  dcterms:modified "2026-02-12T08:59:21.711376Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28021-3
  a curric:KeyLearningPoint ;
  rdfs:label "As the play progresses, Macbeth is haunted by blood and guilt."@en ;
  dcterms:modified "2026-02-12T08:59:21.711380Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28021-4
  a curric:KeyLearningPoint ;
  rdfs:label """Lady Macbeth doesn't see blood as staining and thus rejects her guilt early on in the play."""@en ;
  dcterms:modified "2026-02-12T08:59:21.711385Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28021-5
  a curric:KeyLearningPoint ;
  rdfs:label """At the end of the play, both Macbeth and his wife are consumed by blood and guilt, both appearing helpless."""@en ;
  dcterms:modified "2026-02-12T08:59:21.711392Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28019-1
  a curric:KeyLearningPoint ;
  rdfs:label """In 'Macbeth', Shakespeare repeatedly uses the motif of light alongside the themes of innocence, guilt and sin."""@en ;
  dcterms:modified "2026-02-12T08:59:21.711397Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28019-2
  a curric:KeyLearningPoint ;
  rdfs:label """Macbeth initially wants darkness to conceal his sin from God, demonstrating his guilt."""@en ;
  dcterms:modified "2026-02-12T08:59:21.711401Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28019-3
  a curric:KeyLearningPoint ;
  rdfs:label """Shakespeare uses light imagery to describe the macrocosm, suggesting the wider repercussions of Macbeth's guilt."""@en ;
  dcterms:modified "2026-02-12T08:59:21.711406Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28019-4
  a curric:KeyLearningPoint ;
  rdfs:label """As the play progresses, Macbeth's alignment with darkness may show his moral compass becoming tainted."""@en ;
  dcterms:modified "2026-02-12T08:59:21.711411Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28019-5
  a curric:KeyLearningPoint ;
  rdfs:label """The light imagery associated with the murder of Banquo could represent the murder of innocence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.711415Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28393-1
  a curric:KeyLearningPoint ;
  rdfs:label """A writer might use a cliffhanger to create tension or subvert the reader's expectations around resolutions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712434Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28393-2
  a curric:KeyLearningPoint ;
  rdfs:label "Tolkien uses sentence fragments and simple sentences to create an abrupt tone."@en ;
  dcterms:modified "2026-02-12T08:59:21.712441Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28393-3
  a curric:KeyLearningPoint ;
  rdfs:label "Furthermore, Tolkien uses onomatopoeia and plosive sounds to add to the tension."@en ;
  dcterms:modified "2026-02-12T08:59:21.712446Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28393-4
  a curric:KeyLearningPoint ;
  rdfs:label """By ending on the provocative word "Enemy", Tolkien leaves the reader with a heightened sense of unease."""@en ;
  dcterms:modified "2026-02-12T08:59:21.712453Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28040-1
  a curric:KeyLearningPoint ;
  rdfs:label """Enid's flat symbolises conflict, both generational and cultural, within her family."""@en ;
  dcterms:modified "2026-02-12T08:59:21.717205Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28040-2
  a curric:KeyLearningPoint ;
  rdfs:label """The clean, orderly flat reflects Enid's desire for stability and integration into British society."""@en ;
  dcterms:modified "2026-02-12T08:59:21.717209Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28040-3
  a curric:KeyLearningPoint ;
  rdfs:label """Mai's bedsit contrasts with Enid's flat, representing spiritual and cultural roots through its clutter and artefacts."""@en ;
  dcterms:modified "2026-02-12T08:59:21.717213Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28040-4
  a curric:KeyLearningPoint ;
  rdfs:label """The lack of Jamaican cultural elements in Enid's flat arguably highlights her emotional distance from her Jamaican past."""@en ;
  dcterms:modified "2026-02-12T08:59:21.717218Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28040-5
  a curric:KeyLearningPoint ;
  rdfs:label """Enid's domestic focus and Viv's academic pursuits reflect generational differences in values and aspirations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.717223Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28451-1
  a curric:KeyLearningPoint ;
  rdfs:label """Modal verbs are verbs that indicate likelihood, ability, permission or obligation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.717324Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28451-2
  a curric:KeyLearningPoint ;
  rdfs:label "We might sort modal verbs into categories of low, medium and high modality."@en ;
  dcterms:modified "2026-02-12T08:59:21.717328Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28451-3
  a curric:KeyLearningPoint ;
  rdfs:label "Words with low modality may convey a sense of uncertainty to your writing."@en ;
  dcterms:modified "2026-02-12T08:59:21.717333Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28451-4
  a curric:KeyLearningPoint ;
  rdfs:label """Words with high modality are considered the most persuasive since they convey confidence and obligation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.717337Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28043-1
  a curric:KeyLearningPoint ;
  rdfs:label """A turning point is a moment in a dramatic work when the plot takes a decisive shift."""@en ;
  dcterms:modified "2026-02-12T08:59:21.717342Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28043-2
  a curric:KeyLearningPoint ;
  rdfs:label """Turning points often involve high stakes, character transformation and irreversible consequences."""@en ;
  dcterms:modified "2026-02-12T08:59:21.717347Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28043-3
  a curric:KeyLearningPoint ;
  rdfs:label """Scene Three is a turning point that forces Enid to confront her identity and her relationships with her daughters."""@en ;
  dcterms:modified "2026-02-12T08:59:21.717351Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28043-4
  a curric:KeyLearningPoint ;
  rdfs:label """The death of Mooma serves as a catalyst for a resolution to some of the generational conflict in the play."""@en ;
  dcterms:modified "2026-02-12T08:59:21.717355Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28039-1
  a curric:KeyLearningPoint ;
  rdfs:label "Mai’s bedsit represents her struggle between Jamaican heritage and British life."@en ;
  dcterms:modified "2026-02-12T08:59:21.718572Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28039-2
  a curric:KeyLearningPoint ;
  rdfs:label """The cluttered state of the bedsit reflects Mai’s transient lifestyle and emotional turmoil."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718577Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28039-3
  a curric:KeyLearningPoint ;
  rdfs:label """Pinnock uses objects like obeah artefacts to symbolise Mai’s connection to her Caribbean roots."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718581Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28039-4
  a curric:KeyLearningPoint ;
  rdfs:label """The bedsit serves as a place of stability for other characters, despite Mai’s own sense of impermanence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718586Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28039-5
  a curric:KeyLearningPoint ;
  rdfs:label """Pinnock uses the bedsit to explore themes of belonging and identity for Windrush migrants."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718590Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28452-1
  a curric:KeyLearningPoint ;
  rdfs:label """Personification can be effective in persuasive writing because it evokes an emotional connection to the reader."""@en ;
  dcterms:modified "2026-02-12T08:59:21.719694Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28452-2
  a curric:KeyLearningPoint ;
  rdfs:label "Arguably, personification makes the subject of your writing more relatable."@en ;
  dcterms:modified "2026-02-12T08:59:21.719698Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28452-3
  a curric:KeyLearningPoint ;
  rdfs:label """When deciding how to use personification, you should think about what emotional reaction you want to evoke."""@en ;
  dcterms:modified "2026-02-12T08:59:21.719702Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28396-1
  a curric:KeyLearningPoint ;
  rdfs:label """Writers may choose to use a plot twist to subvert the readers’ expectations around life and people’s behaviour."""@en ;
  dcterms:modified "2026-02-12T08:59:21.719707Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28396-2
  a curric:KeyLearningPoint ;
  rdfs:label """In ‘Atonement’, McEwan’s use of a plot twist may subvert our expectations of love and forgiveness."""@en ;
  dcterms:modified "2026-02-12T08:59:21.719711Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28396-3
  a curric:KeyLearningPoint ;
  rdfs:label """To create an emotional plot twist, McEwan arguably uses idioms, juxtaposition, and plosive sounds."""@en ;
  dcterms:modified "2026-02-12T08:59:21.719716Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28018-1
  a curric:KeyLearningPoint ;
  rdfs:label """Macbeth's initial reaction to the witches' prophecies could reflect his guilt at contemplating regicide."""@en ;
  dcterms:modified "2026-02-12T08:59:21.719720Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28018-2
  a curric:KeyLearningPoint ;
  rdfs:label """Shakespeare may depict Macbeth's overwhelming sense of guilt because he was violating two important codes of conduct."""@en ;
  dcterms:modified "2026-02-12T08:59:21.719724Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28018-3
  a curric:KeyLearningPoint ;
  rdfs:label """Macbeth's soliloquy can be interpreted through a lens of guilt, offering an interesting alternative interpretation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.719729Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28018-4
  a curric:KeyLearningPoint ;
  rdfs:label """Nuanced, critical understanding of texts include alternative interpretations and consideration of a writer's intentions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.719736Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28453-1
  a curric:KeyLearningPoint ;
  rdfs:label "We might see active voice as more direct, concise and confident."@en ;
  dcterms:modified "2026-02-12T08:59:21.719742Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28453-2
  a curric:KeyLearningPoint ;
  rdfs:label "We could see passive voice as less direct, more detached and objective."@en ;
  dcterms:modified "2026-02-12T08:59:21.719747Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28453-3
  a curric:KeyLearningPoint ;
  rdfs:label """Potentially, we might see active voice as more appropriate in more persuasive writing circumstances."""@en ;
  dcterms:modified "2026-02-12T08:59:21.719751Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28453-4
  a curric:KeyLearningPoint ;
  rdfs:label """However, we might use passive voice if we want to avoid responsibility or make a complaint."""@en ;
  dcterms:modified "2026-02-12T08:59:21.719756Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28032-1
  a curric:KeyLearningPoint ;
  rdfs:label "The language we use determines our relationships and connections with others."@en ;
  dcterms:modified "2026-02-12T08:59:21.721473Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28032-2
  a curric:KeyLearningPoint ;
  rdfs:label "As well as connections, language can be used to alienate and differentiate."@en ;
  dcterms:modified "2026-02-12T08:59:21.721478Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28032-3
  a curric:KeyLearningPoint ;
  rdfs:label """Orwell arguably demonstrates how language can be used to create social distinctions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.721484Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28032-4
  a curric:KeyLearningPoint ;
  rdfs:label """Furthermore, Orwell may be commenting on how language can control people through isolation and division."""@en ;
  dcterms:modified "2026-02-12T08:59:21.721489Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28050-1
  a curric:KeyLearningPoint ;
  rdfs:label """Priestley uses multiple narrators to show how truth is subjective and shaped by bias."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723096Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28050-2
  a curric:KeyLearningPoint ;
  rdfs:label """The fragmented narrative encourages the audience to question the reliability of each account."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723101Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28050-3
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, Priestley uses this technique to critique class inequality and the lack of moral introspection."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723107Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28050-4
  a curric:KeyLearningPoint ;
  rdfs:label """The Inspector could be interpreted as an unreliable narrator in how he controls the narrative."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723112Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28050-5
  a curric:KeyLearningPoint ;
  rdfs:label """The use of multiple character narration and a fragmented narrative can be linked to political theatre traditions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723116Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28041-1
  a curric:KeyLearningPoint ;
  rdfs:label """Jamaica influences characters' identities, even though it's not physically present on stage."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723121Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28041-2
  a curric:KeyLearningPoint ;
  rdfs:label "Brod idealises Jamaica, seeing it as a symbol of resistance and beauty."@en ;
  dcterms:modified "2026-02-12T08:59:21.723125Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28041-3
  a curric:KeyLearningPoint ;
  rdfs:label "Enid views Jamaica pragmatically, shaped by poverty and hardship."@en ;
  dcterms:modified "2026-02-12T08:59:21.723129Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28041-4
  a curric:KeyLearningPoint ;
  rdfs:label "Viv is curious about Jamaica, influenced by others' conflicting views."@en ;
  dcterms:modified "2026-02-12T08:59:21.723134Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28041-5
  a curric:KeyLearningPoint ;
  rdfs:label "Characters' perceptions of Jamaica shape their sense of belonging."@en ;
  dcterms:modified "2026-02-12T08:59:21.723138Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28391-1
  a curric:KeyLearningPoint ;
  rdfs:label """Potentially, crime fiction is a popular genre because people want to explore the darkness without experiencing it."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723686Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28391-2
  a curric:KeyLearningPoint ;
  rdfs:label """Stereotypically, crime fiction is resolved by the crime being solved and the criminal facing justice."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723719Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28391-3
  a curric:KeyLearningPoint ;
  rdfs:label """While the criminal is apprehended in his story, Horowitz subverts the genre by having another criminal capture him."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723724Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28391-4
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, Horowitz creates a reassuring resolution through the use of setting, light imagery and symbolism."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723728Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28395-1
  a curric:KeyLearningPoint ;
  rdfs:label """Saint arguably uses an anti-climax in order to subvert the reader's expectations about ambition and power."""@en ;
  dcterms:modified "2026-02-12T08:59:21.725417Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28395-2
  a curric:KeyLearningPoint ;
  rdfs:label """In order to craft an anti-climax, Saint uses symbolism and semantic fields to create ideas of transience."""@en ;
  dcterms:modified "2026-02-12T08:59:21.725422Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28395-3
  a curric:KeyLearningPoint ;
  rdfs:label """In order to emulate Saint's work, we might use the symbolism of water and repetition of a verb which implies departing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.725426Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28395-4
  a curric:KeyLearningPoint ;
  rdfs:label "Furthermore, we might consider using a semantic field of being unbalanced."@en ;
  dcterms:modified "2026-02-12T08:59:21.725431Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28626-1
  a curric:KeyLearningPoint ;
  rdfs:label """Being an effective audience member can mean being supportive, respectful and encouraging success."""@en ;
  dcterms:modified "2026-02-12T08:59:21.725438Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28626-2
  a curric:KeyLearningPoint ;
  rdfs:label """When asking questions, you should aim to make them relevant, clear and constructive."""@en ;
  dcterms:modified "2026-02-12T08:59:21.725444Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28626-3
  a curric:KeyLearningPoint ;
  rdfs:label """When responding to questions, you should aim to answer in a concise and respectful way."""@en ;
  dcterms:modified "2026-02-12T08:59:21.725451Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28626-4
  a curric:KeyLearningPoint ;
  rdfs:label """It is natural to feel nervous but effective preparation like vocal and body warm ups can help."""@en ;
  dcterms:modified "2026-02-12T08:59:21.725456Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28078-1
  a curric:KeyLearningPoint ;
  rdfs:label """Christmas for wealthy Victorians was a time of extravagant parties, feasts and gift giving."""@en ;
  dcterms:modified "2026-02-12T08:59:21.727099Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28078-2
  a curric:KeyLearningPoint ;
  rdfs:label """Poorer people often had to work at Christmas for little money so Christmas was a time of simple, modest celebrations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.727103Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28078-3
  a curric:KeyLearningPoint ;
  rdfs:label """Dickens depicts wealthy Victorians as materialistic and oblivious to the struggles of others."""@en ;
  dcterms:modified "2026-02-12T08:59:21.727107Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28078-4
  a curric:KeyLearningPoint ;
  rdfs:label """Dickens suggests poor people are happier than the wealthy because they are able to appreciate simple pleasures."""@en ;
  dcterms:modified "2026-02-12T08:59:21.727114Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28078-5
  a curric:KeyLearningPoint ;
  rdfs:label """He arguably does this to urge wealthy readers to focus less on wealth and show compassion to those in need."""@en ;
  dcterms:modified "2026-02-12T08:59:21.727118Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28622-1
  a curric:KeyLearningPoint ;
  rdfs:label "Part of being an effective public speaker is ‘finding your voice’."@en ;
  dcterms:modified "2026-02-12T08:59:21.727123Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28622-2
  a curric:KeyLearningPoint ;
  rdfs:label "Developing your authentic voice is all about your views and your voice."@en ;
  dcterms:modified "2026-02-12T08:59:21.727127Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28622-3
  a curric:KeyLearningPoint ;
  rdfs:label "When picking a topic you could choose something that is important to you."@en ;
  dcterms:modified "2026-02-12T08:59:21.727131Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28622-4
  a curric:KeyLearningPoint ;
  rdfs:label """Creating a meaningful statement or title can help to develop and focus ideas in your topic."""@en ;
  dcterms:modified "2026-02-12T08:59:21.727136Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28622-5
  a curric:KeyLearningPoint ;
  rdfs:label """Effective research can elevate a presentation, but must come from credible sources."""@en ;
  dcterms:modified "2026-02-12T08:59:21.727142Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28038-1
  a curric:KeyLearningPoint ;
  rdfs:label """The technical elements of stagecraft, like lighting, sound, and props, can enhance the play’s action."""@en ;
  dcterms:modified "2026-02-12T08:59:21.727147Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28038-2
  a curric:KeyLearningPoint ;
  rdfs:label """Stage directions can reveal character emotions and development (for example Enid’s identity crisis)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.727151Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28038-3
  a curric:KeyLearningPoint ;
  rdfs:label """The contrasting settings of Mai's bedsit and Enid’s flat highlight key differences between them."""@en ;
  dcterms:modified "2026-02-12T08:59:21.727156Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28038-4
  a curric:KeyLearningPoint ;
  rdfs:label "Lighting and music can emphasise themes of nostalgia, loss and identity."@en ;
  dcterms:modified "2026-02-12T08:59:21.727160Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28044-1
  a curric:KeyLearningPoint ;
  rdfs:label """A thesis statement is an overarching argument that presents your main idea for the essay."""@en ;
  dcterms:modified "2026-02-12T08:59:21.728457Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28044-2
  a curric:KeyLearningPoint ;
  rdfs:label """A topic sentence introduces the main idea of a paragraph and links it to the thesis."""@en ;
  dcterms:modified "2026-02-12T08:59:21.728462Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28044-3
  a curric:KeyLearningPoint ;
  rdfs:label "You should use stagecraft and setting as evidence to support your argument."@en ;
  dcterms:modified "2026-02-12T08:59:21.728466Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28044-4
  a curric:KeyLearningPoint ;
  rdfs:label """Concluding sentences can focus on a writer’s intention and draw your paragraph to a close."""@en ;
  dcterms:modified "2026-02-12T08:59:21.728471Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28045-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘An Inspector Calls’ can be interpreted as a political manifesto, propaganda and a persuasive drama."""@en ;
  dcterms:modified "2026-02-12T08:59:21.729785Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28045-2
  a curric:KeyLearningPoint ;
  rdfs:label """The Inspector's language is both didactic, teaching morals, and persuasive, urging reflection on social responsibility."""@en ;
  dcterms:modified "2026-02-12T08:59:21.729789Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28045-3
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, Priestley's exaggerated portrayal of the Birlings reinforces his socialist message."""@en ;
  dcterms:modified "2026-02-12T08:59:21.729819Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28045-4
  a curric:KeyLearningPoint ;
  rdfs:label """The Birlings’ lack of nuance may alienate audiences with opposing views, limiting more complex reflection."""@en ;
  dcterms:modified "2026-02-12T08:59:21.729824Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28394-1
  a curric:KeyLearningPoint ;
  rdfs:label """An anti-climax is when something that is much less exciting or dramatic happens than was expected."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732399Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28394-2
  a curric:KeyLearningPoint ;
  rdfs:label """Stereotypically, anti-climaxes might be considered disappointing; however, they can be very subjective."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732403Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28394-3
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, Saint's 'Hera' has an anti-climatic ending since the gods lose their power and fade away."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732409Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28394-4
  a curric:KeyLearningPoint ;
  rdfs:label """Potentially, Saint may have chosen an anti-climatic ending to comment on ideas of transience and power."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732413Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28394-5
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, the anti-climatic ending reflects how the gods no longer have the same power as they did."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732420Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28079-1
  a curric:KeyLearningPoint ;
  rdfs:label """An excellent introduction could start with a brief summary of the text and its overarching message."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732930Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28079-2
  a curric:KeyLearningPoint ;
  rdfs:label """It should then have a specific statement about the focus of the question, followed by a thesis (overarching argument)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732934Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28079-3
  a curric:KeyLearningPoint ;
  rdfs:label """Topic sentences need to be clear, linked to the question and led by key ideas (not feature-spotting)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732938Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28079-4
  a curric:KeyLearningPoint ;
  rdfs:label "Context can be used to develop arguments."@en ;
  dcterms:modified "2026-02-12T08:59:21.732942Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28079-5
  a curric:KeyLearningPoint ;
  rdfs:label """An effective conclusion will summarise key points in the response and consider the writer’s intentions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732945Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28051-1
  a curric:KeyLearningPoint ;
  rdfs:label """A nuanced response means going beyond surface-level analysis and considering multiple layers of meaning in the text."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732949Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28051-2
  a curric:KeyLearningPoint ;
  rdfs:label "When planning a response, your thesis should present a clear argument."@en ;
  dcterms:modified "2026-02-12T08:59:21.732953Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28051-3
  a curric:KeyLearningPoint ;
  rdfs:label "Topic sentences should focus on individual paragraph points."@en ;
  dcterms:modified "2026-02-12T08:59:21.732959Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28051-4
  a curric:KeyLearningPoint ;
  rdfs:label """Supporting details should include relevant text references and analysis of methods."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732964Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28051-5
  a curric:KeyLearningPoint ;
  rdfs:label "All comments in an essay should link tightly to your overarching argument."@en ;
  dcterms:modified "2026-02-12T08:59:21.732968Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28072-1
  a curric:KeyLearningPoint ;
  rdfs:label """An excellent introduction could start with a brief summary of the text and its overarching message."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732974Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28072-2
  a curric:KeyLearningPoint ;
  rdfs:label """It should then have a specific statement about the focus of the question, followed by a thesis (overarching argument)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732978Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28072-3
  a curric:KeyLearningPoint ;
  rdfs:label """Topic sentences need to be clear, linked to the question and led by key ideas (not feature-spotting)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732982Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28072-4
  a curric:KeyLearningPoint ;
  rdfs:label "Context can be used to develop arguments."@en ;
  dcterms:modified "2026-02-12T08:59:21.732986Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28072-5
  a curric:KeyLearningPoint ;
  rdfs:label """An effective conclusion will summarise key points in the response and consider the writer’s intentions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732990Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28031-1
  a curric:KeyLearningPoint ;
  rdfs:label """Orwell believed in the power of language and how it can be used to corrupt and control people."""@en ;
  dcterms:modified "2026-02-12T08:59:21.733408Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28031-2
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, we see this corruption and control through the pigs' manipulation of the commandments."""@en ;
  dcterms:modified "2026-02-12T08:59:21.733412Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28031-3
  a curric:KeyLearningPoint ;
  rdfs:label """Potentially, we might consider the commandments as representing religious language."""@en ;
  dcterms:modified "2026-02-12T08:59:21.733418Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28031-4
  a curric:KeyLearningPoint ;
  rdfs:label """Therefore, we may think that Orwell is commenting on how religion can corrupt and control people."""@en ;
  dcterms:modified "2026-02-12T08:59:21.733422Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28033-1
  a curric:KeyLearningPoint ;
  rdfs:label "Arguably, Benjamin's language conveys apathy throughout 'Animal Farm'."@en ;
  dcterms:modified "2026-02-12T08:59:21.733426Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28033-2
  a curric:KeyLearningPoint ;
  rdfs:label """We might see Orwell as suggesting that Benjamin's apathy is a form of complicity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.733430Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28033-3
  a curric:KeyLearningPoint ;
  rdfs:label """Potentially, we might see the animals’ complicity as allowing the pigs’ oppression."""@en ;
  dcterms:modified "2026-02-12T08:59:21.733434Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28033-4
  a curric:KeyLearningPoint ;
  rdfs:label """On the other hand, we might consider the pigs’ language as conditioning the animals to be complicit."""@en ;
  dcterms:modified "2026-02-12T08:59:21.733438Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28398-1
  a curric:KeyLearningPoint ;
  rdfs:label """We might find a resolution reassuring because it teaches us that society can return to order and justice will be done."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734558Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28398-2
  a curric:KeyLearningPoint ;
  rdfs:label """A cliffhanger ending may create tension because it could imply that there will never be a satisfying ending to problems."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734562Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28398-3
  a curric:KeyLearningPoint ;
  rdfs:label """We may find that an anti-climax subverts our expectations of what a ‘happy ending’ or ‘winning’ looks like."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734566Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28398-4
  a curric:KeyLearningPoint ;
  rdfs:label """A plot twist might be unsettling as it could imply that we can’t predict outcomes or people’s behaviour."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734570Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29049-1
  a curric:KeyLearningPoint ;
  rdfs:label "Arguably, Friar Lawrence represents religion in 'Romeo and Juliet'."@en ;
  dcterms:modified "2026-02-12T08:59:21.734586Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29049-2
  a curric:KeyLearningPoint ;
  rdfs:label """Throughout the play, we see Friar Lawrence influencing the lives and behaviour of characters."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734589Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29049-3
  a curric:KeyLearningPoint ;
  rdfs:label """Potentially, we might see Shakespeare as criticising the influence of religion on society through Friar Lawrence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734593Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29049-4
  a curric:KeyLearningPoint ;
  rdfs:label """Furthermore, we might see Shakespeare as criticising Catholicism through Friar Lawrence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734597Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28077-1
  a curric:KeyLearningPoint ;
  rdfs:label """Reputation was important to wealthy Victorians because it ensured access to power, influence and social connections."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734601Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28077-2
  a curric:KeyLearningPoint ;
  rdfs:label """The wealthy lived in large houses and had lavish lifestyles, attending operas, dinner parties and embarking on holidays."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734607Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28077-3
  a curric:KeyLearningPoint ;
  rdfs:label """Dickens uses negative language and words linked to the cold to imply Scrooge's life was lonely due to his selfishness."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734611Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28077-4
  a curric:KeyLearningPoint ;
  rdfs:label """He uses positive language to present Fezziwig as a jolly, lively figure who is well-liked and respected."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734615Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28077-5
  a curric:KeyLearningPoint ;
  rdfs:label """He contrasts his depictions of both men to suggest that compassion can ultimately lead to a happy life."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734621Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29053-1
  a curric:KeyLearningPoint ;
  rdfs:label "An essay should have a strong central argument."@en ;
  dcterms:modified "2026-02-12T08:59:21.734625Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29053-2
  a curric:KeyLearningPoint ;
  rdfs:label """Use an evaluative or critical thesis to “hang” your essay on and support with clear topic sentences."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734629Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29053-3
  a curric:KeyLearningPoint ;
  rdfs:label """Analysis of writer's methods should be interwoven and used to support each other."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734633Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29053-4
  a curric:KeyLearningPoint ;
  rdfs:label "Context should be highly selective and used to add to your argument."@en ;
  dcterms:modified "2026-02-12T08:59:21.734637Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29053-5
  a curric:KeyLearningPoint ;
  rdfs:label """Essays should focus on the writer’s intentions - the conclusion is an opportunity to summarise this."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734641Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28047-1
  a curric:KeyLearningPoint ;
  rdfs:label """‘An Inspector Calls’ uses Brechtian techniques, like alienation, to provoke critical thought."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734645Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28047-2
  a curric:KeyLearningPoint ;
  rdfs:label """Brechtian techniques and epic theatre contrast with naturalism, urging intellectual engagement over emotional immersion."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734651Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28047-3
  a curric:KeyLearningPoint ;
  rdfs:label """The play critiques class inequality, aligning with Brechtian and socialist realism themes of social justice."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734655Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28047-4
  a curric:KeyLearningPoint ;
  rdfs:label """Priestley’s Inspector is a symbolic figure of moral authority, resembling socialist realism heroes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734661Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28047-5
  a curric:KeyLearningPoint ;
  rdfs:label """Priestley critiques both capitalism and the idealism of socialist realism, avoiding utopian solutions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734666Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28071-1
  a curric:KeyLearningPoint ;
  rdfs:label """The Indutrial Revolution saw an increase in psychological conditions (anxiety, depression and feelings of alienation)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734670Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28071-2
  a curric:KeyLearningPoint ;
  rdfs:label """Strict moral codes of behaviour often led Victorians to live double lives, leading to a fragmentation of identities."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734674Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28071-3
  a curric:KeyLearningPoint ;
  rdfs:label "Many believed psychological conditions signified weakness or moral failure."@en ;
  dcterms:modified "2026-02-12T08:59:21.734677Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28071-4
  a curric:KeyLearningPoint ;
  rdfs:label """Dr. Jekyll’s battle between good and evil reflects the Victorian ideas of repressed desires and loss of self-control."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734681Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28071-5
  a curric:KeyLearningPoint ;
  rdfs:label """After his initial transformation, Jekyll begins to lose control over Hyde and grows weaker while Hyde gains strength."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734687Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28454-1
  a curric:KeyLearningPoint ;
  rdfs:label """Using words with medium and high modality can convey a sense of confidence and obligation onto your writing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734691Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28454-2
  a curric:KeyLearningPoint ;
  rdfs:label "However, only using words with high modality can make your tone seem too direct."@en ;
  dcterms:modified "2026-02-12T08:59:21.734695Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28454-3
  a curric:KeyLearningPoint ;
  rdfs:label """Using personification can create an emotional connection between the reader and the subject."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734699Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28454-4
  a curric:KeyLearningPoint ;
  rdfs:label "Using active voice can ensure the reader's focus is on the subject."@en ;
  dcterms:modified "2026-02-12T08:59:21.734703Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28070-1
  a curric:KeyLearningPoint ;
  rdfs:label """Significant scientific advances during the height of the Industrial Revolution often used unethical practices."""@en ;
  dcterms:modified "2026-02-12T08:59:21.735730Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28070-2
  a curric:KeyLearningPoint ;
  rdfs:label """Stevenson draws on the 'mad scientist' trope to emphasise how the pursuit of knowledge can lead to a loss of humanity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.735734Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28070-3
  a curric:KeyLearningPoint ;
  rdfs:label """Jekyll represents the respectable public face whereas Hyde represents the repressed desires he keeps hidden."""@en ;
  dcterms:modified "2026-02-12T08:59:21.735738Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28070-4
  a curric:KeyLearningPoint ;
  rdfs:label """Lanyon's horror at Hyde's transformation reflects Victorian fears that unchecked ambition led to horrifying outcomes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.735741Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28070-5
  a curric:KeyLearningPoint ;
  rdfs:label """Jekyll describes his transformation as painful yet enjoyable because it frees him from moral expectations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.735745Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28397-1
  a curric:KeyLearningPoint ;
  rdfs:label """To emulate McEwan’s emotional plot twist, we might use figurative language to influence the readers’ expectations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.735934Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28397-2
  a curric:KeyLearningPoint ;
  rdfs:label """We may then use juxtaposition to contrast their expectations with the reality of the situation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.735941Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28397-3
  a curric:KeyLearningPoint ;
  rdfs:label "We could use repetition to emphasise the emotion behind the plot twist."@en ;
  dcterms:modified "2026-02-12T08:59:21.735945Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28397-4
  a curric:KeyLearningPoint ;
  rdfs:label """We could also use consonant sounds in order to enhance the tone of the plot twist."""@en ;
  dcterms:modified "2026-02-12T08:59:21.735949Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29050-1
  a curric:KeyLearningPoint ;
  rdfs:label "By taking their own lives, Romeo and Juliet are committing a religious sin."@en ;
  dcterms:modified "2026-02-12T08:59:21.735953Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29050-2
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, Juliet perceives the sin of bigamy as a greater sin than taking her own life."""@en ;
  dcterms:modified "2026-02-12T08:59:21.735957Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29050-3
  a curric:KeyLearningPoint ;
  rdfs:label """Through this, we might suggest that Shakespeare has positioned Romeo and Juliet’s marriage as religiously sanctified."""@en ;
  dcterms:modified "2026-02-12T08:59:21.735960Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29050-4
  a curric:KeyLearningPoint ;
  rdfs:label """Alternatively, we could say that Juliet’s perception of sin has been influenced by societal expectations of women."""@en ;
  dcterms:modified "2026-02-12T08:59:21.735964Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29050-5
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, both interpretations link the perception of sin to societal expectations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.735968Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28034-1
  a curric:KeyLearningPoint ;
  rdfs:label "Many of the animals in 'Animal Farm' do not have a voice within the text."@en ;
  dcterms:modified "2026-02-12T08:59:21.736729Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28034-2
  a curric:KeyLearningPoint ;
  rdfs:label "Arguably, we connect having a voice with having power."@en ;
  dcterms:modified "2026-02-12T08:59:21.736735Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28034-3
  a curric:KeyLearningPoint ;
  rdfs:label """Potentially, Orwell is representing how the masses do not have a voice in political systems."""@en ;
  dcterms:modified "2026-02-12T08:59:21.736740Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28034-4
  a curric:KeyLearningPoint ;
  rdfs:label "Arguably, we see the pigs’ suppressing the animals language."@en ;
  dcterms:modified "2026-02-12T08:59:21.736744Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28034-5
  a curric:KeyLearningPoint ;
  rdfs:label """Orwell implies that the animals' lack of linguistic ability contributes to their subjugation ."""@en ;
  dcterms:modified "2026-02-12T08:59:21.736747Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28036-1
  a curric:KeyLearningPoint ;
  rdfs:label "We see the pigs' language shifting throughout 'Animal Farm'."@en ;
  dcterms:modified "2026-02-12T08:59:21.737839Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28036-2
  a curric:KeyLearningPoint ;
  rdfs:label "Arguably, this shift reflects ideological shifts."@en ;
  dcterms:modified "2026-02-12T08:59:21.737843Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28036-3
  a curric:KeyLearningPoint ;
  rdfs:label """For example, the shifting place name represents the pigs' shifting ideology around Animalism."""@en ;
  dcterms:modified "2026-02-12T08:59:21.737846Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28036-4
  a curric:KeyLearningPoint ;
  rdfs:label """Potentially, Orwell might be commenting on how language can be used to rewrite history."""@en ;
  dcterms:modified "2026-02-12T08:59:21.737850Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28022-1
  a curric:KeyLearningPoint ;
  rdfs:label "Sleep is a motif in 'Macbeth' associated with innocence."@en ;
  dcterms:modified "2026-02-12T08:59:21.740286Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28022-2
  a curric:KeyLearningPoint ;
  rdfs:label """Both Macbeth and Lady Macbeth suffer with lack of sleep (insomnia) and nightmares."""@en ;
  dcterms:modified "2026-02-12T08:59:21.740290Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28022-3
  a curric:KeyLearningPoint ;
  rdfs:label "Insomnia is associated with guilt in the play."@en ;
  dcterms:modified "2026-02-12T08:59:21.740294Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28022-4
  a curric:KeyLearningPoint ;
  rdfs:label """Insomnia might be considered a punishment that either God or the conscience inflicts."""@en ;
  dcterms:modified "2026-02-12T08:59:21.740298Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28022-5
  a curric:KeyLearningPoint ;
  rdfs:label """We can use discourse markers to help us trace different uses of a motif across a text."""@en ;
  dcterms:modified "2026-02-12T08:59:21.740302Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28450-1
  a curric:KeyLearningPoint ;
  rdfs:label """We might use formal letters for professional matters relating to employment or complaints."""@en ;
  dcterms:modified "2026-02-12T08:59:21.740306Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28450-2
  a curric:KeyLearningPoint ;
  rdfs:label "We might use informal letters for emotional matters such as thank you notes."@en ;
  dcterms:modified "2026-02-12T08:59:21.740312Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28450-3
  a curric:KeyLearningPoint ;
  rdfs:label """We might use letters because it shows a personal touch and a certain level of care and attention."""@en ;
  dcterms:modified "2026-02-12T08:59:21.740316Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28450-4
  a curric:KeyLearningPoint ;
  rdfs:label "Formal letters have a specific form."@en ;
  dcterms:modified "2026-02-12T08:59:21.740320Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28450-5
  a curric:KeyLearningPoint ;
  rdfs:label """A formal letter should include your address, the date, the recipient’s address, a salutation and sign off."""@en ;
  dcterms:modified "2026-02-12T08:59:21.740324Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29051-1
  a curric:KeyLearningPoint ;
  rdfs:label """Until the late 16th century, individual identity was seen as a function of an individual's place in a social network."""@en ;
  dcterms:modified "2026-02-12T08:59:21.740578Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29051-2
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, Romeo and Juliet both act based on their individual desires in 'Romeo and Juliet'."""@en ;
  dcterms:modified "2026-02-12T08:59:21.740582Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29051-3
  a curric:KeyLearningPoint ;
  rdfs:label """For Romeo, this individuality causes social isolation at the beginning of the play."""@en ;
  dcterms:modified "2026-02-12T08:59:21.740586Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29051-4
  a curric:KeyLearningPoint ;
  rdfs:label """For Romeo and Juliet, their individual desires arguably lead to their tragic downfall."""@en ;
  dcterms:modified "2026-02-12T08:59:21.740590Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28017-1
  a curric:KeyLearningPoint ;
  rdfs:label """Guilt is an uncomfortable feeling with the purpose of aligning one with their moral compass."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742110Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28017-2
  a curric:KeyLearningPoint ;
  rdfs:label "The theme of guilt is central to 'Macbeth'."@en ;
  dcterms:modified "2026-02-12T08:59:21.742114Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28017-3
  a curric:KeyLearningPoint ;
  rdfs:label "Shakespeare exposes the destructive force of guilt in 'Macbeth'."@en ;
  dcterms:modified "2026-02-12T08:59:21.742118Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28017-4
  a curric:KeyLearningPoint ;
  rdfs:label """Shakespeare may have centered the play on guilt to warn against regicide and treachery."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742122Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28017-5
  a curric:KeyLearningPoint ;
  rdfs:label """King James I was a patron of Shakespeare's company; guilt may have been used as a device to please the King."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742125Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28076-1
  a curric:KeyLearningPoint ;
  rdfs:label """There was no state support available for poor Victorians; they were forced to rely on charities and philanthropy."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742131Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28076-2
  a curric:KeyLearningPoint ;
  rdfs:label """The Poor Laws made it legal for those in debt to be sent to prison or forced to live in squalid workhouses."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742135Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28076-3
  a curric:KeyLearningPoint ;
  rdfs:label """Scrooge’s dialogue with the charity men critiques the Victorian belief that the poor were lazy or morally inferior."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742139Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28076-4
  a curric:KeyLearningPoint ;
  rdfs:label """Dickens later shows Scrooge’s transformation towards redemption when he is introduced to Ignorance and Want."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742143Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28076-5
  a curric:KeyLearningPoint ;
  rdfs:label """They symbolise a lack of awareness of poor's struggles and warn of the consequences of ongoing social inequality."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742147Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28623-1
  a curric:KeyLearningPoint ;
  rdfs:label """Being a critical friend means helping others to improve by giving honest feedback in a supportive way."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742153Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28623-2
  a curric:KeyLearningPoint ;
  rdfs:label """Being able to articulate the main points of a presentation verbally is good preparation for developing ideas."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742159Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28623-3
  a curric:KeyLearningPoint ;
  rdfs:label """Discussion and probing questions can help to refine and develop ideas for a presentation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742164Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28623-4
  a curric:KeyLearningPoint ;
  rdfs:label """When creating a presentation you could consider the time limit, evidence, clarity and structure."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742168Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28623-5
  a curric:KeyLearningPoint ;
  rdfs:label """The process of rebuttal can be useful to strengthen arguments or viewpoints in a presentation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742171Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29052-1
  a curric:KeyLearningPoint ;
  rdfs:label """Romeo and Juliet's secret marriage creates a conflict between individual desire and traditional authority."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742175Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29052-2
  a curric:KeyLearningPoint ;
  rdfs:label """We also arguably see the rule of law and religion being challenged by individual desire."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742179Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29052-3
  a curric:KeyLearningPoint ;
  rdfs:label """Potentially, the feud serves to preserve the status quo that is threatened by individualism."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742183Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29052-4
  a curric:KeyLearningPoint ;
  rdfs:label """Shakespeare's depiction of individualism may represent Elizabethan anxiety about the social cost of individualism."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742187Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29048-1
  a curric:KeyLearningPoint ;
  rdfs:label """Arguably, Shakespeare suggests that adolescence was associated with impulsiveness in Elizabethan England."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742191Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29048-2
  a curric:KeyLearningPoint ;
  rdfs:label """Therefore, we might suggest that the tragedy of ‘Romeo and Juliet’ was in part due to societal expectations of youth."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742195Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29048-3
  a curric:KeyLearningPoint ;
  rdfs:label """Shakespeare presents parental relationships as distant and separate from their children."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742198Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29048-4
  a curric:KeyLearningPoint ;
  rdfs:label """Potentially, we might see Shakespeare as questioning ideas of parental control and children's obedience."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742202Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28455-1
  a curric:KeyLearningPoint ;
  rdfs:label """Offering ideas for further steps to the recipient of your letter can make your argument more persuasive."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742803Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28455-2
  a curric:KeyLearningPoint ;
  rdfs:label """Using words with medium and high modality can convey confidence and a sense of obligation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742807Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28455-3
  a curric:KeyLearningPoint ;
  rdfs:label "Using personification can evoke an emotional reaction in the reader."@en ;
  dcterms:modified "2026-02-12T08:59:21.742811Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28455-4
  a curric:KeyLearningPoint ;
  rdfs:label "Using active voice can focus the reader’s attention onto the subject."@en ;
  dcterms:modified "2026-02-12T08:59:21.742815Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28073-1
  a curric:KeyLearningPoint ;
  rdfs:label """Victorian London was noisy, overcrowded and diverse, with people from various cultural backgrounds and social classes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742818Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28073-2
  a curric:KeyLearningPoint ;
  rdfs:label """The Industrial Revolution transformed the city, worsening pollution and widening the class divide."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742824Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28073-3
  a curric:KeyLearningPoint ;
  rdfs:label """The poor lived in cramped, unsanitary conditions, with little support available to improve their lives."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742828Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28073-4
  a curric:KeyLearningPoint ;
  rdfs:label """Dickens campaigned for social reform and the novella encouraged middle-class readers to show compassion for the poor."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742832Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28073-5
  a curric:KeyLearningPoint ;
  rdfs:label """Descriptions of the setting foreshadow how this ghost story exposes the harsh realities of poverty in Victorian London."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742838Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28020-1
  a curric:KeyLearningPoint ;
  rdfs:label """Macbeth and Lady Macbeth are haunted by supernatural phenomena after committing crimes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.743492Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28020-2
  a curric:KeyLearningPoint ;
  rdfs:label """Perhaps Lady Macbeth and Macbeth suffer such supernatural punishment due to the extent of their "unnatural deeds"."""@en ;
  dcterms:modified "2026-02-12T08:59:21.743496Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28020-3
  a curric:KeyLearningPoint ;
  rdfs:label "A common Renaissance belief was there were no limits to God's vengeance."@en ;
  dcterms:modified "2026-02-12T08:59:21.743500Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28020-4
  a curric:KeyLearningPoint ;
  rdfs:label """In the Renaissance, people believed that the conscience was a tool imposed by God to inflict punishment."""@en ;
  dcterms:modified "2026-02-12T08:59:21.743506Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28020-5
  a curric:KeyLearningPoint ;
  rdfs:label """Macbeth and Lady Macbeth's hallucinations can be read as a symbol of their guilt as well as divine retribution."""@en ;
  dcterms:modified "2026-02-12T08:59:21.743510Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28023-1
  a curric:KeyLearningPoint ;
  rdfs:label "The theme of guilt is pertinent throughout ‘Macbeth’."@en ;
  dcterms:modified "2026-02-12T08:59:21.743514Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28023-2
  a curric:KeyLearningPoint ;
  rdfs:label "A thesis statement is a clear, overarching argument."@en ;
  dcterms:modified "2026-02-12T08:59:21.743525Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28023-3
  a curric:KeyLearningPoint ;
  rdfs:label "Topic sentences give focus to individual paragraphs."@en ;
  dcterms:modified "2026-02-12T08:59:21.743529Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28023-4
  a curric:KeyLearningPoint ;
  rdfs:label """Concluding sentences can focus on a writer’s intention and draw your paragraph to a close."""@en ;
  dcterms:modified "2026-02-12T08:59:21.743533Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28023-5
  a curric:KeyLearningPoint ;
  rdfs:label """Choose quotations that support your topic sentence and come from across the play."""@en ;
  dcterms:modified "2026-02-12T08:59:21.743537Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28046-1
  a curric:KeyLearningPoint ;
  rdfs:label """Naturalism presents realistic settings and characters to critique social and economic inequalities."""@en ;
  dcterms:modified "2026-02-12T08:59:21.743541Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28046-2
  a curric:KeyLearningPoint ;
  rdfs:label """Priestley uses naturalism to expose class disparities, making his political message convincing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.743544Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28046-3
  a curric:KeyLearningPoint ;
  rdfs:label """Expressionism emphasises emotions, symbolism, and exaggerated elements to highlight societal flaws."""@en ;
  dcterms:modified "2026-02-12T08:59:21.743548Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28046-4
  a curric:KeyLearningPoint ;
  rdfs:label """Priestley’s use of expressionism critiques capitalism and class hierarchies, supporting his political agenda."""@en ;
  dcterms:modified "2026-02-12T08:59:21.743553Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28046-5
  a curric:KeyLearningPoint ;
  rdfs:label """Daldry's staging enhances expressionism, symbolising the Birlings' moral decay and societal consequences."""@en ;
  dcterms:modified "2026-02-12T08:59:21.743556Z"^^xsd:dateTime .

