  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils have a detailed understanding of how societal status is presented in the
  novella."""@en ;
  dcterms:modified "2026-06-07T15:29:26.834913Z"^^xsd:dateTime .

oakcurric:priorknowledge-174-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils can structure arguments clearly, using thesis statements, topic sentences and
  single paragraph outlines."""@en ;
  dcterms:modified "2026-06-07T15:29:26.834918Z"^^xsd:dateTime .

oakcurric:priorknowledge-174-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils have memorised numerous quotations from the novella and can select them
  judiciously for evidence."""@en ;
  dcterms:modified "2026-06-07T15:29:26.834928Z"^^xsd:dateTime .

oakcurric:priorknowledge-174-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils can identify the main motifs of the novella: light and dark and silence."@en ;
  dcterms:modified "2026-06-07T15:29:26.834933Z"^^xsd:dateTime .

oakcurric:priorknowledge-174-7
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils use the historical and social context of the novella to support their
  analysis."""@en ;
  dcterms:modified "2026-06-07T15:29:26.834937Z"^^xsd:dateTime .

oakcurric:priorknowledge-174-8
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils can use tentative langauge to explore alternative interpretations."@en ;
  dcterms:modified "2026-06-07T15:29:26.834942Z"^^xsd:dateTime .

oakcurric:priorknowledge-174-9
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils can use superlatives to evaluate an author's choice of langauge or
  structure."""@en ;
  dcterms:modified "2026-06-07T15:29:26.834946Z"^^xsd:dateTime .

oakcurric:priorknowledge-174-10
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils can draw clear conclusions to their arguments."@en ;
  dcterms:modified "2026-06-07T15:29:26.834950Z"^^xsd:dateTime .

