# ----------------------------------------------------------------------
# Keywords
# ----------------------------------------------------------------------

oakcurric:keyword-dominant
  a curric:Keyword ;
  schema:name "dominant"@en ;
  schema:description "the most widely accepted or prevailing (idea or concept)"@en ;
  dcterms:modified "2026-02-12T08:59:15.789347Z"^^xsd:dateTime .

oakcurric:keyword-conform
  a curric:Keyword ;
  schema:name "conform"@en ;
  schema:description "to behave or think in a way that is socially acceptable"@en ;
  dcterms:modified "2026-02-12T08:59:15.789355Z"^^xsd:dateTime .

oakcurric:keyword-societal
  a curric:Keyword ;
  schema:name "societal"@en ;
  schema:description "anything related to society, including beliefs, customs  and behaviours"@en ;
  dcterms:modified "2026-02-12T08:59:15.789361Z"^^xsd:dateTime .

oakcurric:keyword-stereotype
  a curric:Keyword ;
  schema:name "stereotype"@en ;
  schema:description "a simplified belief, view or representation of a group of people"@en ;
  dcterms:modified "2026-02-12T08:59:15.789366Z"^^xsd:dateTime .

oakcurric:keyword-fleeting
  a curric:Keyword ;
  schema:name "fleeting"@en ;
  schema:description "passing quickly"@en ;
  dcterms:modified "2026-02-12T08:59:15.789372Z"^^xsd:dateTime .

oakcurric:keyword-foreboding
  a curric:Keyword ;
  schema:name "foreboding"@en ;
  schema:description "a feeling that something bad is going to happen"@en ;
  dcterms:modified "2026-02-12T08:59:15.789377Z"^^xsd:dateTime .

oakcurric:keyword-theme
  a curric:Keyword ;
  schema:name "theme"@en ;
  schema:description """an important idea or thread in a text that is explored in a number of different ways"""@en ;
  dcterms:modified "2026-02-12T08:59:15.789391Z"^^xsd:dateTime .

oakcurric:keyword-unsanitary
  a curric:Keyword ;
  schema:name "unsanitary"@en ;
  schema:description "dirty or unhealthy and therefore likely to cause disease"@en ;
  dcterms:modified "2026-02-12T08:59:15.789405Z"^^xsd:dateTime .

oakcurric:keyword-alliteration
  a curric:Keyword ;
  schema:name "alliteration"@en ;
  schema:description "when two or more words start with the same consonant"@en ;
  dcterms:modified "2026-02-12T08:59:15.789414Z"^^xsd:dateTime .

oakcurric:keyword-onomatopoeia
  a curric:Keyword ;
  schema:name "onomatopoeia"@en ;
  schema:description "words which sound like the noise they describe e.g. crash"@en ;
  dcterms:modified "2026-02-12T08:59:15.789423Z"^^xsd:dateTime .

oakcurric:keyword-sibilance
  a curric:Keyword ;
  schema:name "sibilance"@en ;
  schema:description "repetition of the letter 's' in successive words"@en ;
  dcterms:modified "2026-02-12T08:59:15.789435Z"^^xsd:dateTime .

oakcurric:keyword-emanating
  a curric:Keyword ;
  schema:name "emanating"@en ;
  schema:description "emitting or spreading from something"@en ;
  dcterms:modified "2026-02-12T08:59:15.789486Z"^^xsd:dateTime .

oakcurric:keyword-commonwealth
  a curric:Keyword ;
  schema:name "Commonwealth"@en ;
  schema:description """an international organisation consisting of states which once belonged to the British Empire"""@en ;
  dcterms:modified "2026-02-12T08:59:15.789500Z"^^xsd:dateTime .

oakcurric:keyword-patriotic
  a curric:Keyword ;
  schema:name "Patriotic"@en ;
  schema:description "Being patriotic means showing love and support for your country."@en ;
  dcterms:modified "2026-02-12T08:59:15.789519Z"^^xsd:dateTime .

oakcurric:keyword-propaganda
  a curric:Keyword ;
  schema:name "Propaganda"@en ;
  schema:description """Propaganda is information, especially of a biased or misleading nature, used to promote a political cause or point of view."""@en ;
  dcterms:modified "2026-02-12T08:59:15.789531Z"^^xsd:dateTime .

oakcurric:keyword-provocative
  a curric:Keyword ;
  schema:name "Provocative"@en ;
  schema:description """Something provocative is deliberately designed to cause anger or another strong emotion."""@en ;
  dcterms:modified "2026-02-12T08:59:15.789540Z"^^xsd:dateTime .

oakcurric:keyword-gist
  a curric:Keyword ;
  schema:name "gist"@en ;
  schema:description "the main idea or essence of something, often brief and in a simplified form"@en ;
  dcterms:modified "2026-02-12T08:59:15.789545Z"^^xsd:dateTime .

oakcurric:keyword-militant
  a curric:Keyword ;
  schema:name "militant"@en ;
  schema:description "to be forceful, determined and extreme, sometimes using aggressive methods"@en ;
  dcterms:modified "2026-02-12T08:59:15.789549Z"^^xsd:dateTime .

oakcurric:keyword-archaic
  a curric:Keyword ;
  schema:name "archaic"@en ;
  schema:description "something that is outdated, old-fashioned, or no longer in common use"@en ;
  dcterms:modified "2026-02-12T08:59:15.789558Z"^^xsd:dateTime .

oakcurric:keyword-autonomy
  a curric:Keyword ;
  schema:name "autonomy"@en ;
  schema:description """having the freedom and independence to make your own decisions without being controlled by others"""@en ;
  dcterms:modified "2026-02-12T08:59:15.789563Z"^^xsd:dateTime .

oakcurric:keyword-rhythm
  a curric:Keyword ;
  schema:name "rhythm"@en ;
  schema:description "the beat, flow, or pattern of a piece of music or writing."@en ;
  dcterms:modified "2026-02-12T08:59:15.789567Z"^^xsd:dateTime .

oakcurric:keyword-defiant
  a curric:Keyword ;
  schema:name "defiant"@en ;
  schema:description "boldly disobedient."@en ;
  dcterms:modified "2026-02-12T08:59:15.789576Z"^^xsd:dateTime .

oakcurric:keyword-subordinate-clause
  a curric:Keyword ;
  schema:name "subordinate clause"@en ;
  schema:description "a clause of a sentence which doesn’t make sense by itself."@en ;
  dcterms:modified "2026-02-12T08:59:15.789581Z"^^xsd:dateTime .

oakcurric:keyword-sensory-language
  a curric:Keyword ;
  schema:name "sensory language"@en ;
  schema:description "writing that includes reference to some, or all, of the five senses"@en ;
  dcterms:modified "2026-02-12T08:59:15.789611Z"^^xsd:dateTime .

oakcurric:keyword-third-person-limited
  a curric:Keyword ;
  schema:name "third person limited"@en ;
  schema:description """the narrator isn’t a character in the story and presents the feelings and experiences of one character using pronouns like 'she', 'he', 'they', 'it'"""@en ;
  dcterms:modified "2026-02-12T08:59:15.789632Z"^^xsd:dateTime .

oakcurric:keyword-migration
  a curric:Keyword ;
  schema:name "migration"@en ;
  schema:description """the movement of people from one place to another, either within a country or between countries, often for economic, social, political or environmental reasons"""@en ;
  dcterms:modified "2026-02-12T08:59:15.789717Z"^^xsd:dateTime .

oakcurric:keyword-disparity
  a curric:Keyword ;
  schema:name "disparity"@en ;
  schema:description "a lack of equality or devoid of similarities"@en ;
  dcterms:modified "2026-02-12T08:59:15.789744Z"^^xsd:dateTime .

oakcurric:keyword-erratic
  a curric:Keyword ;
  schema:name "erratic"@en ;
  schema:description "irregular or lacking consistency"@en ;
  dcterms:modified "2026-02-12T08:59:15.789768Z"^^xsd:dateTime .

oakcurric:keyword-scrutiny
  a curric:Keyword ;
  schema:name "scrutiny"@en ;
  schema:description "intense observation or examination"@en ;
  dcterms:modified "2026-02-12T08:59:15.789772Z"^^xsd:dateTime .

oakcurric:keyword-anguish
  a curric:Keyword ;
  schema:name "anguish"@en ;
  schema:description "an extreme sense of anger, resulting in murderous thoughts"@en ;
  dcterms:modified "2026-02-12T08:59:15.789776Z"^^xsd:dateTime .

oakcurric:keyword-form
  a curric:Keyword ;
  schema:name "form"@en ;
  schema:description "in writing, this refers to the structure, format or genre of a text"@en ;
  dcterms:modified "2026-02-12T08:59:15.789782Z"^^xsd:dateTime .

oakcurric:keyword-literary
  a curric:Keyword ;
  schema:name "literary"@en ;
  schema:description """relating to literature or written works, especially those considered to have artistic or intellectual value"""@en ;
  dcterms:modified "2026-02-12T08:59:15.789786Z"^^xsd:dateTime .

oakcurric:keyword-autobiographical
  a curric:Keyword ;
  schema:name "autobiographical"@en ;
  schema:description "a piece of writing in which the author tells the story of their own life"@en ;
  dcterms:modified "2026-02-12T08:59:15.789793Z"^^xsd:dateTime .

oakcurric:keyword-direct-address
  a curric:Keyword ;
  schema:name "Direct address"@en ;
  schema:description "where a speaker talks directly to the audience"@en ;
  dcterms:modified "2026-02-12T08:59:15.789828Z"^^xsd:dateTime .

oakcurric:keyword-flashback
  a curric:Keyword ;
  schema:name "Flashback"@en ;
  schema:description "a scene that is set earlier than the main story"@en ;
  dcterms:modified "2026-02-12T08:59:15.789832Z"^^xsd:dateTime .

oakcurric:keyword-dialogue
  a curric:Keyword ;
  schema:name "Dialogue"@en ;
  schema:description "conversation and spoken interactions written for a play, book or film"@en ;
  dcterms:modified "2026-02-12T08:59:15.789846Z"^^xsd:dateTime .

oakcurric:keyword-dialect
  a curric:Keyword ;
  schema:name "Dialect"@en ;
  schema:description """a variation of a language spoken in a particular part of the country or by a particular group"""@en ;
  dcterms:modified "2026-02-12T08:59:15.789850Z"^^xsd:dateTime .

oakcurric:keyword-objectify
  a curric:Keyword ;
  schema:name "objectify"@en ;
  schema:description "to treat someone like a thing or object, instead of a person"@en ;
  dcterms:modified "2026-02-12T08:59:15.789859Z"^^xsd:dateTime .

oakcurric:keyword-derogatory
  a curric:Keyword ;
  schema:name "derogatory"@en ;
  schema:description "a disrespectful or belittling attitude towards someone or something"@en ;
  dcterms:modified "2026-02-12T08:59:15.789865Z"^^xsd:dateTime .

oakcurric:keyword-witty
  a curric:Keyword ;
  schema:name "witty"@en ;
  schema:description "clever and amusing"@en ;
  dcterms:modified "2026-02-12T08:59:15.789869Z"^^xsd:dateTime .

oakcurric:keyword-idealistic
  a curric:Keyword ;
  schema:name "idealistic"@en ;
  schema:description "to view something with unrealistic perfectionism"@en ;
  dcterms:modified "2026-02-12T08:59:15.789875Z"^^xsd:dateTime .

oakcurric:keyword-authoritative
  a curric:Keyword ;
