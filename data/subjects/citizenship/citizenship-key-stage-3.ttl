  dcterms:modified "2026-02-12T08:59:15.792953Z"^^xsd:dateTime .

oakcurric:keyword-health
  a curric:Keyword ;
  schema:name "health"@en ;
  schema:description """a state of overall wellbeing that includes physical, mental and social aspects, not just the absence of disease or injury"""@en ;
  dcterms:modified "2026-02-12T08:59:15.792961Z"^^xsd:dateTime .

oakcurric:keyword-healthcare
  a curric:Keyword ;
