  a curric:Keyword ;
  schema:name "invest"@en ;
  schema:description """To invest in something, means to put time, money or effort into something
  that you think will go up in value."""@en ;
  dcterms:modified "2026-06-07T15:30:02.422061Z"^^xsd:dateTime .

oakcurric:keyword-legal-age
  a curric:Keyword ;
  schema:name "legal age"@en ;
  schema:description "the age at which you can do something as defined by the law"@en ;
  dcterms:modified "2026-06-07T15:30:02.422304Z"^^xsd:dateTime .

oakcurric:keyword-crime-prevention-strategy
  a curric:Keyword ;
  schema:name "crime prevention strategy"@en ;
  schema:description """a plan or set of actions designed to reduce the likelihood of crime
  occurring"""@en ;
  dcterms:modified "2026-06-07T15:30:02.422535Z"^^xsd:dateTime .

oakcurric:keyword-responsible-action
  a curric:Keyword ;
  schema:name "responsible action"@en ;
  schema:description """doing something to to bring about change that does not harm others or cause
  damage"""@en ;
  dcterms:modified "2026-06-07T15:30:02.423444Z"^^xsd:dateTime .

oakcurric:keyword-effective-change
  a curric:Keyword ;
  schema:name "effective change"@en ;
  schema:description """this is when an event or change happens which achieves its goal, makes a
  difference for the better and has a lasting effect"""@en ;
  dcterms:modified "2026-06-07T15:30:02.423605Z"^^xsd:dateTime .

oakcurric:keyword-local-democracy
  a curric:Keyword ;
  schema:name "local democracy"@en ;
  schema:description """a system of government in which citizens vote in regular, fair elections for
  representatives in their geographical area"""@en ;
  dcterms:modified "2026-06-07T15:30:02.424181Z"^^xsd:dateTime .

oakcurric:keyword-youth-council
  a curric:Keyword ;
  schema:name "Youth Council"@en ;
  schema:description """a group set up, led and shaped by young people to represent the views and
  interests of other young people in a democratic way"""@en ;
  dcterms:modified "2026-06-07T15:30:02.424189Z"^^xsd:dateTime .

oakcurric:keyword-pupil-voice
  a curric:Keyword ;
  schema:name "pupil voice"@en ;
  schema:description """the views, opinions and ideas of pupils about their school experience, which
  are listened to and considered in decision-making"""@en ;
  dcterms:modified "2026-06-07T15:30:02.425278Z"^^xsd:dateTime .

oakcurric:keyword-decision-makers
  a curric:Keyword ;
  schema:name "decision-makers"@en ;
  schema:description """people or groups who have the authority to make lasting change in
  communities"""@en ;
  dcterms:modified "2026-06-07T15:30:02.425283Z"^^xsd:dateTime .

oakcurric:keyword-active-citizens
  a curric:Keyword ;
  schema:name "active citizens"@en ;
  schema:description """a person who actively takes responsibility, becomes involved in areas of
  public concern and tries to make a positive difference in their community"""@en ;
  dcterms:modified "2026-06-07T15:30:02.425288Z"^^xsd:dateTime .

oakcurric:keyword-petitions
  a curric:Keyword ;
  schema:name "petitions"@en ;
  schema:description """gathering signatures to show support for a cause, which can be done on paper
  or online"""@en ;
  dcterms:modified "2026-06-07T15:30:02.425434Z"^^xsd:dateTime .

oakcurric:keyword-member-of-parliament
  a curric:Keyword ;
  schema:name "Member of Parliament"@en ;
  schema:description """a person elected to represent our interests and concerns in the House of
  Commons; they consider and can propose new laws, as well as raising issues that matter to
  you in the House"""@en ;
  dcterms:modified "2026-06-07T15:30:02.426908Z"^^xsd:dateTime .

oakcurric:keyword-speaker-house-of-commons
  a curric:Keyword ;
  schema:name "Speaker (House of Commons)"@en ;
  schema:description """an MP chosen by other MPs to chair debates in the House of Commons; they
  make sure the rules are followed; once elected they stop being involved in party politics
  and stay neutral in debates"""@en ;
  dcterms:modified "2026-06-07T15:30:02.426913Z"^^xsd:dateTime .

oakcurric:keyword-voting-reform
  a curric:Keyword ;
  schema:name "voting reform"@en ;
  schema:description """the process by which the voting laws are modified and shaped over time to
  better reflect the social values that society feels are important"""@en ;
  dcterms:modified "2026-06-07T15:30:02.427163Z"^^xsd:dateTime .

oakcurric:keyword-borrow
  a curric:Keyword ;
  schema:name "borrow"@en ;
  schema:description "taking money from a lender with the intention of paying it back"@en ;
  dcterms:modified "2026-06-07T15:30:02.427440Z"^^xsd:dateTime .

oakcurric:keyword-overdraft
  a curric:Keyword ;
  schema:name "overdraft"@en ;
  schema:description "when you spend more money than you have from your bank account"@en ;
  dcterms:modified "2026-06-07T15:30:02.427445Z"^^xsd:dateTime .

oakcurric:keyword-loan
  a curric:Keyword ;
  schema:name "loan"@en ;
  schema:description "a sum of money you receive and agree to pay back with interest"@en ;
  dcterms:modified "2026-06-07T15:30:02.427450Z"^^xsd:dateTime .

oakcurric:keyword-devolved
  a curric:Keyword ;
  schema:name "devolved"@en ;
  schema:description """political powers which have been transferred from the central Government or
  Parliament to a national, regional or local government or Parliament"""@en ;
  dcterms:modified "2026-06-07T15:30:02.427456Z"^^xsd:dateTime .

oakcurric:keyword-eligible
  a curric:Keyword ;
  schema:name "eligible"@en ;
  schema:description "to meet the criteria or rules to be able to do something"@en ;
  dcterms:modified "2026-06-07T15:30:02.427997Z"^^xsd:dateTime .

oakcurric:keyword-youth-crime
  a curric:Keyword ;
  schema:name "youth crime"@en ;
  schema:description """crimes committed by people above the age of criminal responsibility, but
  under the age of 18"""@en ;
  dcterms:modified "2026-06-07T15:30:02.428183Z"^^xsd:dateTime .

oakcurric:keyword-trustworthy
  a curric:Keyword ;
  schema:name "trustworthy"@en ;
  schema:description """something or someone who is able to be relied upon as honest and
  truthful"""@en ;
  dcterms:modified "2026-06-07T15:30:02.428260Z"^^xsd:dateTime .

oakcurric:keyword-debit
  a curric:Keyword ;
  schema:name "debit"@en ;
  schema:description "money taken from a bank account and used for payment"@en ;
  dcterms:modified "2026-06-07T15:30:02.428582Z"^^xsd:dateTime .

oakcurric:keyword-credit
  a curric:Keyword ;
  schema:name "credit"@en ;
  schema:description """money that can be used for payment but it is borrowed from a lender so
  interest might be charged"""@en ;
  dcterms:modified "2026-06-07T15:30:02.428590Z"^^xsd:dateTime .

oakcurric:keyword-budgeting
  a curric:Keyword ;
  schema:name "budgeting"@en ;
  schema:description "the process and plan of sticking to a budget"@en ;
  dcterms:modified "2026-06-07T15:30:02.428598Z"^^xsd:dateTime .

oakcurric:keyword-absolute-poverty
  a curric:Keyword ;
  schema:name "absolute poverty"@en ;
  schema:description """when someone doesn’t have enough money or resources to meet their most basic
  needs, such as food, shelter and clean water"""@en ;
  dcterms:modified "2026-06-07T15:30:02.428604Z"^^xsd:dateTime .

oakcurric:keyword-relative-poverty
  a curric:Keyword ;
  schema:name "relative poverty"@en ;
  schema:description """when someone’s income is much lower than the average in their society
  (typically 50-60% less), meaning they struggle to afford the same standard of living as
  most people around them"""@en ;
  dcterms:modified "2026-06-07T15:30:02.428609Z"^^xsd:dateTime .

# ----------------------------------------------------------------------
# Misconceptions
# ----------------------------------------------------------------------

oakcurric:misconception-changemakers-make-lasting-change
  a curric:Misconception ;
  curric:statement "Very few changemakers make lasting change."@en ;
  curric:correction """There are many examples, both throughout history and modern-day society,
  where changemakers have made a positive impact and lasting change."""@en ;
  dcterms:modified "2026-06-07T15:30:15.084682Z"^^xsd:dateTime .

oakcurric:misconception-mps-work-parliament
  a curric:Misconception ;
  curric:statement "MPs only work in Parliament."@en ;
  curric:correction """MPs spend a lot of time helping constituents, attending local events and
  managing casework."""@en ;
  dcterms:modified "2026-06-07T15:30:15.084827Z"^^xsd:dateTime .

oakcurric:misconception-fairness-means-treating-everybody-same
  a curric:Misconception ;
  curric:statement "Fairness always means treating everybody the same."@en ;
  curric:correction """Fairness may involve treating people differently based on their individual
  circumstances in order to achieve equitable outcomes."""@en ;
  dcterms:modified "2026-06-07T15:30:15.085082Z"^^xsd:dateTime .

oakcurric:misconception-social-media-automatically-leads-increased
  a curric:Misconception ;
  curric:statement """Social media automatically leads to increased political participation because
  it reaches so many people."""@en ;
  curric:correction """Social media can engage many, but it doesn’t ensure political participation.
  Misinformation, digital divides, echo chambers, and apathy can hinder impact. Success
  depends on content quality, usage, and users’ critical thinking skills."""@en ;
  dcterms:modified "2026-06-07T15:30:15.085542Z"^^xsd:dateTime .

oakcurric:misconception-citizens-power-influence-law-uk
  a curric:Misconception ;
  curric:statement "Citizens have no power to influence the law in the UK."@en ;
  curric:correction """Citizens in the UK do have the power to influence the law. They can use
  methods like online petitions, surveys, lobbying politicians and working with the media or
  charities to bring attention to issues and encourage lawmakers to make changes."""@en ;
  dcterms:modified "2026-06-07T15:30:15.086750Z"^^xsd:dateTime .

oakcurric:misconception-people-eligible-vote-general-elections
  a curric:Misconception ;
  curric:statement "All people who are eligible will vote in general elections."@en ;
  curric:correction """Just because someone is eligible, it doesn't mean they will vote. In the UK
  2024 general election, voter turnout was 59.7%. This was the lowest turnout at a general
  election since 2001."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087508Z"^^xsd:dateTime .

oakcurric:misconception-discrimination-past-harmful-because-people
  a curric:Misconception ;
  curric:statement """Discrimination in the past was not as harmful because people did not know any
  better."""@en ;
  curric:correction """Even though discrimination was accepted in the past, it still caused real
  harm. People lost rights, faced unfair treatment and suffered. Increased awareness led to
  campaigns and laws being made to protect people's rights."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087712Z"^^xsd:dateTime .

oakcurric:misconception-civil-servants-public-sector-workers
  a curric:Misconception ;
  curric:statement "Civil servants and public sector workers make political decisions."@en ;
  curric:correction """Civil servants and other public sector workers are neutral professionals who
  work to implement government policies and decisions made by elected ministers, but they do
  not make political decisions themselves."""@en ;
  dcterms:modified "2026-06-07T15:30:15.087948Z"^^xsd:dateTime .

oakcurric:misconception-pressure-groups-usually-violent
  a curric:Misconception ;
  curric:statement "Pressure groups are usually violent."@en ;
  curric:correction """Pressure groups can lobby MPs and protest for change but usually in a
  peaceful way. There is a wide range of different pressure groups in the UK using peaceful
  methods to perform effective action and bring lasting change."""@en ;
  dcterms:modified "2026-06-07T15:30:15.088311Z"^^xsd:dateTime .

oakcurric:misconception-equality-means-treating-everyone-same
  a curric:Misconception ;
  curric:statement """Equality means treating everyone the same, so that’s the fairest thing
  to do."""@en ;
  curric:correction """Treating everyone the same is not always fair. Equality gives the same to
  all, but equity gives people what they need to have the same chance and opportunities.
  Equality is about meeting different needs, not pretending everyone is the same."""@en ;
  dcterms:modified "2026-06-07T15:30:15.088944Z"^^xsd:dateTime .

oakcurric:misconception-because-countries-democracies-uk-us
  a curric:Misconception ;
  curric:statement """Because both countries are democracies, the UK and the US political systems
  are the same."""@en ;
  curric:correction """Both countries are democracies but they differ: for example, the UK has a
  parliamentary system where only the House of Commons is elected, while the US has a
  presidential system where voters elect both houses of Congress and the President
  separately."""@en ;
  dcterms:modified "2026-06-07T15:30:15.089219Z"^^xsd:dateTime .

oakcurric:misconception-globalisation-benefit-everybody
  a curric:Misconception ;
  curric:statement "Globalisation does not benefit everybody."@en ;
  curric:correction """Globalisation benefits everyone because with collaboration we can achieve
  more things together as a global community."""@en ;
  dcterms:modified "2026-06-07T15:30:15.089315Z"^^xsd:dateTime .

oakcurric:misconception-make-difference-within-school-community
  a curric:Misconception ;
  curric:statement """To make a difference within the school community an active citizen has to make
  a big change."""@en ;
  curric:correction "Even small actions at school can make a meaningful change."@en ;
  dcterms:modified "2026-06-07T15:30:15.089670Z"^^xsd:dateTime .

oakcurric:misconception-fracking-shale-gas-environmentally-friendly
  a curric:Misconception ;
  curric:statement """Fracking shale gas is more environmentally friendly than other gas and fossil
  fuels."""@en ;
  curric:correction """Whilst shale gas releases less CO2 than coal and oil, it is still not a
  renewable energy source and has several other negative environmental impacts, such as
  using huge amounts of water."""@en ;
  dcterms:modified "2026-06-07T15:30:15.089995Z"^^xsd:dateTime .

oakcurric:misconception-media-doesnt-play-role-democracy
  a curric:Misconception ;
  curric:statement """The media doesn’t play a role in democracy and simply reports what the
  Government tells it."""@en ;
  curric:correction """The media has an important role in democracy. It sets the agenda by choosing
  which issues to focus on, helping inform and educate the public. This means the media, not
  the Government, decides which stories are highlighted and discussed."""@en ;
  dcterms:modified "2026-06-07T15:30:15.090056Z"^^xsd:dateTime .

oakcurric:misconception-digital-democracy-works-other-countries
  a curric:Misconception ;
  curric:statement """If digital democracy works in other countries, the UK can easily copy the same
  methods."""@en ;
  curric:correction """Success in other countries depends on specific factors like strong digital
  infrastructure, cybersecurity systems and public trust in technology. For the UK to adopt
  similar methods, these factors must be carefully considered and adapted."""@en ;
  dcterms:modified "2026-06-07T15:30:15.090685Z"^^xsd:dateTime .

oakcurric:misconception-young-people-cant-real-influence
  a curric:Misconception ;
  curric:statement """Young people can't have a real influence on local decision making because they
  are not old enough to vote or be a councillor."""@en ;
  curric:correction """Young people can have a significant impact by speaking up, raising awareness,
  organising community actions and engaging with local leaders. They can be powerful voices
  for change, especially when working together and being persistent."""@en ;
  dcterms:modified "2026-06-07T15:30:15.090791Z"^^xsd:dateTime .

oakcurric:misconception-community-groups-charities-ngos-make
  a curric:Misconception ;
  curric:statement """Community groups, charities and NGOs do not make much of a difference in local
  communities."""@en ;
  curric:correction """Charities, groups and NGOs make a huge difference and have a measurable
  impact on local communities and their success."""@en ;
  dcterms:modified "2026-06-07T15:30:15.090911Z"^^xsd:dateTime .

oakcurric:misconception-government-same-thing-parliament
  a curric:Misconception ;
  curric:statement "The Government is the same thing as Parliament."@en ;
  curric:correction """Parliament makes laws and is made up of elected MPs, appointed Lords and the
  monarch. The Government implements laws and runs the country, led by the PM. Parliament
  scrutinises Government decisions."""@en ;
  dcterms:modified "2026-06-07T15:30:15.091117Z"^^xsd:dateTime .

oakcurric:misconception-civil-service-political-body
  a curric:Misconception ;
  curric:statement "The Civil Service is a political body."@en ;
  curric:correction """The Civil Service is designed to be impartial, serving the Government of the
  day. Civil servants are expected to provide objective advice and implement policy without
  political bias. This allows for continuity even when political leadership changes."""@en ;
  dcterms:modified "2026-06-07T15:30:15.091242Z"^^xsd:dateTime .

oakcurric:misconception-powerless-protect-rights-others-until
  a curric:Misconception ;
  curric:statement "We are powerless to protect the rights of others until we are adults."@en ;
  curric:correction """Children can protect the rights of others by using active citizenship
  methods."""@en ;
  dcterms:modified "2026-06-07T15:30:15.092053Z"^^xsd:dateTime .

oakcurric:misconception-schools-little-local-community
  a curric:Misconception ;
  curric:statement "Schools have very little to do with the local community."@en ;
  curric:correction """Schools are often at the centre of local communities, offering opportunities,
  facilities and events to people in the community as well as educating the young people who
  live in the community."""@en ;
  dcterms:modified "2026-06-07T15:30:15.092398Z"^^xsd:dateTime .

oakcurric:misconception-young-people-represented-parliament
  a curric:Misconception ;
  curric:statement "No young people are represented in Parliament."@en ;
  curric:correction """The UK Youth Parliament has been running for 25 years and holds elections to
  join. These elections are open to all young people aged 11-18. They liaise with Parliament
  on various issues and campaign for change as a way to be represented nationally."""@en ;
  dcterms:modified "2026-06-07T15:30:15.098936Z"^^xsd:dateTime .

oakcurric:misconception-communities-diverse
  a curric:Misconception ;
  curric:statement "All communities are diverse."@en ;
  curric:correction """Communities are different depending on where they are located and the people
  they contain. However, in some places, communities have not seen much migration and are
  not diverse as a result."""@en ;
  dcterms:modified "2026-06-07T15:30:15.098942Z"^^xsd:dateTime .

oakcurric:misconception-leaders-power-active-citizens
  a curric:Misconception ;
  curric:statement "Only leaders, or those in power, can be active citizens."@en ;
  curric:correction """Whilst leadership skills might help in some situations, many active citizens
  work behind the scenes, you don’t need to be a leader or in power to be an active citizen."""@en ;
  dcterms:modified "2026-06-07T15:30:15.099207Z"^^xsd:dateTime .

oakcurric:misconception-migration-happens-people-escaping-danger
  a curric:Misconception ;
  curric:statement """Migration only happens when people are escaping danger, like war or natural
  disasters."""@en ;
  curric:correction """Many people are forced to migrate because of danger, but others choose to
  move for different reasons, like better jobs, studying or a different lifestyle. Migration
  is not always about escaping something bad, but about moving toward something better."""@en ;
  dcterms:modified "2026-06-07T15:30:15.099636Z"^^xsd:dateTime .

oakcurric:misconception-climate-change-natural-part-earths
  a curric:Misconception ;
  curric:statement """Climate change is just a natural part of Earth’s cycles, and humans aren't
  responsible for it."""@en ;
  curric:correction """While Earth’s climate has naturally changed in the past, the IPCC shows that
  the current rapid warming is mainly caused by human activities, like burning fossil fuels
  and deforestation."""@en ;
  dcterms:modified "2026-06-07T15:30:15.099647Z"^^xsd:dateTime .

oakcurric:misconception-judges-courts-make-biased
  a curric:Misconception ;
  curric:statement "Judges or courts just “make it up” or are biased."@en ;
  curric:correction """Independent courts follow the law and make decisions without outside
  influence to ensure fairness."""@en ;
  dcterms:modified "2026-06-07T15:30:15.102680Z"^^xsd:dateTime .

oakcurric:misconception-everyone-gets-education
  a curric:Misconception ;
  curric:statement "Everyone gets an education."@en ;
  curric:correction "Some children do not have access to their right to education."@en ;
  dcterms:modified "2026-06-07T15:30:15.103276Z"^^xsd:dateTime .

oakcurric:misconception-law-matters-people-break
  a curric:Misconception ;
  curric:statement "The law only matters for some people, or only for those who break it."@en ;
  curric:correction """Use real-life examples, such as school rules vs. national laws, or news
  stories in which leaders were held accountable, to show the law in action."""@en ;
  dcterms:modified "2026-06-07T15:30:15.103359Z"^^xsd:dateTime .

oakcurric:misconception-party-wins-seats-form-government
  a curric:Misconception ;
  curric:statement """The party that wins the most seats will form the Government and have all the
  power."""@en ;
  curric:correction """If a party does not have the majority of seats (50%+1) in Parliament, they
  may not be able to form a government. They might have to form a formal coalition or a
  voting agreement with a smaller party to get the majority. Power may have to be shared."""@en ;
  dcterms:modified "2026-06-07T15:30:15.104167Z"^^xsd:dateTime .

oakcurric:misconception-communities-change-stay-same-regardless
  a curric:Misconception ;
  curric:statement """Communities do not change and stay the same, regardless of the people
  in them."""@en ;
  curric:correction """Communities will always change due to many reasons including migration,
  politics, demography and the economy."""@en ;
  dcterms:modified "2026-06-07T15:30:15.106334Z"^^xsd:dateTime .

oakcurric:misconception-lobby-mps
  a curric:Misconception ;
  curric:statement "You can only lobby MPs."@en ;
  curric:correction """You can lobby MPs, local councillors and any politicans to try and influence
  change. Any decision-maker can be lobbied."""@en ;
  dcterms:modified "2026-06-07T15:30:15.108106Z"^^xsd:dateTime .

oakcurric:misconception-banks-ethics-dont-mix-cannot
  a curric:Misconception ;
  curric:statement "Banks and ethics don't mix. You cannot bank ethically."@en ;
  curric:correction """There are ways to ethically bank in the UK that use the money you invest in
  responsible ways, such as funding community projects, supporting sustainable businesses,
  or avoiding investments in harmful industries like fossil fuels or weapons."""@en ;
  dcterms:modified "2026-06-07T15:30:15.108728Z"^^xsd:dateTime .

oakcurric:misconception-alternatives-plastic
  a curric:Misconception ;
  curric:statement "There are no alternatives to plastic."@en ;
  curric:correction """There are lots of alternatives to plastic that are easier to break down or
  recycle and therefore have less of an environmental impact, for example, glass and metal."""@en ;
  dcterms:modified "2026-06-07T15:30:15.108959Z"^^xsd:dateTime .

oakcurric:misconception-times-changed-everyone-already-treated
  a curric:Misconception ;
  curric:statement """Times have changed: everyone is already treated equally, so we do not really
  need equality laws anymore."""@en ;
  curric:correction """While progress has been made, unfair treatment still happens. Equality laws
  are there to protect people and make sure everyone gets a fair chance, especially those
  who might otherwise be left out or discriminated against."""@en ;
  dcterms:modified "2026-06-07T15:30:15.108967Z"^^xsd:dateTime .

oakcurric:misconception-councils-deal-minor-issues-like
  a curric:Misconception ;
  curric:statement "Councils only deal with minor issues, like park maintenance."@en ;
  curric:correction """Local councils play a crucial role in many significant areas, including urban
  and housing planning, public health, education and community services. They have a say in
  local regulations, budgets and initiatives that greatly impact quality of life."""@en ;
  dcterms:modified "2026-06-07T15:30:15.109230Z"^^xsd:dateTime .

oakcurric:misconception-ireland-part-united-kingdom
  a curric:Misconception ;
  curric:statement "Ireland is part of the United Kingdom."@en ;
  curric:correction """Ireland is a separate country that gained independence from the United
  Kingdom in 1922, but Northern Ireland is part of the UK."""@en ;
  dcterms:modified "2026-06-07T15:30:15.109380Z"^^xsd:dateTime .

oakcurric:misconception-local-councillors-same-mps
  a curric:Misconception ;
  curric:statement "Local councillors are the same as MPs."@en ;
  curric:correction """MPs represent local areas on a national level. Councillors represent
  residents at a local level within cities, towns or counties. Councillors do not get a say
  in making laws, like MPs do. Councillors get an allowance, while MPs are paid a salary."""@en ;
  dcterms:modified "2026-06-07T15:30:15.109386Z"^^xsd:dateTime .

oakcurric:misconception-easily-tell-information-unreliable-inaccurate
  a curric:Misconception ;
  curric:statement "We can easily tell when information is unreliable and inaccurate."@en ;
  curric:correction """There are several ways that misinformation can convince us that untruths are
  real without us always realising."""@en ;
  dcterms:modified "2026-06-07T15:30:15.110273Z"^^xsd:dateTime .

oakcurric:misconception-need-pay-see-doctor-uk
  a curric:Misconception ;
  curric:statement "You need to pay to see a doctor in the UK."@en ;
  curric:correction """The NHS is free in the UK; therefore you can see a doctor for no charge -
  this protects our right to healthcare. Some people choose to have private healthcare in
  the UK, but this is a personal choice."""@en ;
  dcterms:modified "2026-06-07T15:30:15.110290Z"^^xsd:dateTime .

oakcurric:misconception-local-governments-make-laws
  a curric:Misconception ;
  curric:statement "Local governments make laws."@en ;
  curric:correction """Laws are made by central government, which must be followed by local
  councils. However, they can lobby the central government and influence policy through
  campaigns, consultations and public pressure."""@en ;
  dcterms:modified "2026-06-07T15:30:15.110506Z"^^xsd:dateTime .

oakcurric:misconception-police-make-whole-justice-system
  a curric:Misconception ;
  curric:statement "The police make up the whole of the justice system."@en ;
  curric:correction """The police are part of the justice system. There are three layers to the
  justice system: laws, courts and the police."""@en ;
  dcterms:modified "2026-06-07T15:30:15.111464Z"^^xsd:dateTime .

oakcurric:misconception-positive-stereotypes-dont-cause-harm
  a curric:Misconception ;
  curric:statement "Positive stereotypes don’t cause any harm because they seem complimentary."@en ;
  curric:correction """Positive stereotypes can be damaging because they create pressure for
  individuals to meet unrealistic expectations, ignore individuality, and reinforce limiting
  roles and ideas about what people should be like."""@en ;
  dcterms:modified "2026-06-07T15:30:15.111469Z"^^xsd:dateTime .

oakcurric:misconception-fairness-following-law-something-legal
  a curric:Misconception ;
  curric:statement """Fairness is only about following the law; if something is legal, then it must
  be fair."""@en ;
  curric:correction """While laws set important standards, fairness also depends on how people treat
  each other every day. Sometimes, unfairness happens even when no laws are broken. True
  fairness requires respectful actions, understanding and challenging unfair attitudes."""@en ;
  dcterms:modified "2026-06-07T15:30:15.111551Z"^^xsd:dateTime .

oakcurric:misconception-anyone-forced-leave-their-home
  a curric:Misconception ;
  curric:statement """Anyone forced to leave their home because of a risk to life is automatically
  recognised as a refugee and protected by international law."""@en ;
  curric:correction """People who migrate due to environmental reasons are not currently recognised
  as refugees under the 1951 Refugee Convention. That law only protects people fleeing
  persecution based on, for example, race, religion, nationality, political opinion."""@en ;
  dcterms:modified "2026-06-07T15:30:15.111557Z"^^xsd:dateTime .

oakcurric:misconception-protection-30-days-purchasing-goods
  a curric:Misconception ;
  curric:statement "You have no protection after 30 days of purchasing goods and services."@en ;
  curric:correction """After 30 days, a replacement, repair or credit can be given (except for food
  items like milk). A discount or a refund could also still be given. There is some level of
  protection up to six months after you purchased something with no extra guarantee."""@en ;
  dcterms:modified "2026-06-07T15:30:15.111633Z"^^xsd:dateTime .

oakcurric:misconception-discrimination-affects-someone-moment-happens
  a curric:Misconception ;
  curric:statement "Discrimination only affects someone in the moment it happens."@en ;
  curric:correction """The effects can be long-lasting and deeply personal. Discrimination can lead
  to emotional distress, loss of confidence and reduced life opportunities. Even if an
  incident seems small to others, it can be big to the person being discriminated against."""@en ;
  dcterms:modified "2026-06-07T15:30:15.111666Z"^^xsd:dateTime .

oakcurric:misconception-necessary-campaigners-financial-skills
  a curric:Misconception ;
  curric:statement "It is not necessary for campaigners to have any financial skills."@en ;
  curric:correction """Financial skills are really important in active citizenship campaigns. There
  are often budgets to stick to, risks to manage and financial reporting to complete."""@en ;
  dcterms:modified "2026-06-07T15:30:15.122919Z"^^xsd:dateTime .

oakcurric:misconception-community-cohesion-comes-easily-communities
  a curric:Misconception ;
  curric:statement "Community cohesion comes easily to all communities."@en ;
  curric:correction """Community cohesion takes work and effort to maintain relationships and keep
  everyone together working towards the same goal."""@en ;
  dcterms:modified "2026-06-07T15:30:15.124310Z"^^xsd:dateTime .

oakcurric:misconception-devolved-governments-make-laws-issue
  a curric:Misconception ;
  curric:statement "Devolved governments can make laws on any issue."@en ;
  curric:correction """The powers of devolved governments are limited to specific policy areas
  defined by devolution agreements."""@en ;
  dcterms:modified "2026-06-07T15:30:15.125347Z"^^xsd:dateTime .

oakcurric:misconception-age-criminal-responsibility-same-worldwide
  a curric:Misconception ;
  curric:statement "The age of criminal responsibility is the same worldwide."@en ;
  curric:correction """The age of criminal responsibility varies across countries. For example, in
  Grenada and Trinidad and Tobago it’s seven, while in Spain it’s 14."""@en ;
  dcterms:modified "2026-06-07T15:30:15.125865Z"^^xsd:dateTime .

oakcurric:misconception-women-now-same-voting-rights
  a curric:Misconception ;
  curric:statement """As women now have the same voting rights as men in the UK, they are equally
  represented in the Government and Parliament."""@en ;
  curric:correction """This is not the case in the UK. However, as of the 2024 General Election,
  40.5% of MPs in the House of Commons are female, which is the highest number ever recorded
  of female MPs."""@en ;
  dcterms:modified "2026-06-07T15:30:15.128508Z"^^xsd:dateTime .

oakcurric:misconception-active-citizenship-campaigns-part-democracy
  a curric:Misconception ;
  curric:statement "Active citizenship campaigns are not part of democracy."@en ;
  curric:correction """If you work together effectively, active citizen campaign tasks are an
  important form of taking part in democracy."""@en ;
  dcterms:modified "2026-06-07T15:30:15.131900Z"^^xsd:dateTime .

oakcurric:misconception-rights-adults
  a curric:Misconception ;
  curric:statement "We only have rights when we are adults."@en ;
  curric:correction """We have rights as children as well as adults. Some of these are different but
  they are all designed to allow everyone to live a safe and happy life."""@en ;
  dcterms:modified "2026-06-07T15:30:15.139271Z"^^xsd:dateTime .

oakcurric:misconception-take-legal-action-your-human
  a curric:Misconception ;
  curric:statement "You can take legal action if your human rights are abused by anyone."@en ;
  curric:correction """You cannot take legal action for violations by private individuals, like a
  friend. You can only take action against a public authority if they’ve breached your human
  rights."""@en ;
  dcterms:modified "2026-06-07T15:30:15.139286Z"^^xsd:dateTime .

oakcurric:misconception-candidates-same-level-resources-support
  a curric:Misconception ;
  curric:statement """All candidates have the same level of resources and support during
  campaigns."""@en ;
  curric:correction """In reality, some candidates may struggle to reach voters due to limited
  funding or organisation, which can affect their visibility and chances of success."""@en ;
  dcterms:modified "2026-06-07T15:30:15.141904Z"^^xsd:dateTime .

oakcurric:misconception-criminal-law-serious-crimes-like
  a curric:Misconception ;
  curric:statement "Criminal law is only for very serious crimes, like murder or robbery."@en ;
  curric:correction """Whilst criminal law deals with serious crimes like murder and robbery, it
  also covers a wide range of other offenses, such as theft and vandalism. Criminal law is
  used when someone's actions harm society, no matter how big or small the crime is."""@en ;
  dcterms:modified "2026-06-07T15:30:15.149433Z"^^xsd:dateTime .

oakcurric:misconception-bad-people-commit-crimes
  a curric:Misconception ;
  curric:statement "Only \"bad people\" commit crimes."@en ;
  curric:correction """Criminal behaviour can be influenced by various factors like their
  environment, the people around them, or their mental state."""@en ;
  dcterms:modified "2026-06-07T15:30:15.149863Z"^^xsd:dateTime .

oakcurric:misconception-get-our-news-information-same
  a curric:Misconception ;
  curric:statement "We all get our news and information from the same place."@en ;
  curric:correction """People get their news and information from a range of different media sources
  which can result in people believing very different stories."""@en ;
  dcterms:modified "2026-06-07T15:30:15.151699Z"^^xsd:dateTime .

oakcurric:misconception-media-report-whatever-like-consequences
  a curric:Misconception ;
  curric:statement "The media can report whatever they like, there are no consequences."@en ;
  curric:correction """There are consequences for the media breaking the rules and not fulfilling
  their responsibilities. They have to abide by a strict code of conduct and ethics."""@en ;
  dcterms:modified "2026-06-07T15:30:15.152140Z"^^xsd:dateTime .

oakcurric:misconception-media-helps-public-learn-information
  a curric:Misconception ;
  curric:statement "The media always helps the public learn information."@en ;
  curric:correction """Sometimes we are given misinformation, disinformation or malinformation. It
  is important to learn to spot this and realise that some of the media we are presented
  with is not always designed to help the public learn the true facts."""@en ;
  dcterms:modified "2026-06-07T15:30:15.152385Z"^^xsd:dateTime .

oakcurric:misconception-young-person-accused-crime-treated
  a curric:Misconception ;
  curric:statement """If a young person is accused of a crime, they are treated the same as an adult
  in court."""@en ;
  curric:correction """Young people have some special protections in the legal system, e.g., in
  youth courts, the focus is on rehabilitation and making sure young people are given the
  support they need to avoid reoffending. They also have extra rights when arrested."""@en ;
  dcterms:modified "2026-06-07T15:30:15.152391Z"^^xsd:dateTime .

oakcurric:misconception-local-councillors-get-salary
  a curric:Misconception ;
  curric:statement "Local councillors get a salary."@en ;
  curric:correction """Local councillors do not get a salary. They are entitled to receive an
  allowance to cover costs associated with their role. This allowance is intended to
  reimburse them for time spent on council duties and is a basic allowance."""@en ;
  dcterms:modified "2026-06-07T15:30:15.152987Z"^^xsd:dateTime .

oakcurric:misconception-democracy-exists-countries-different-ways
  a curric:Misconception ;
  curric:statement "Democracy exists in all countries, just in different ways."@en ;
  curric:correction """Democracy exists in many countries and the levels of it vary. However, in
  many countries, there is a large mix of democratic and non-democratic practices, and in
  others, there is no true democracy at all, with the government taking full control."""@en ;
  dcterms:modified "2026-06-07T15:30:15.154678Z"^^xsd:dateTime .

oakcurric:misconception-migration-causes-problems-communities
  a curric:Misconception ;
  curric:statement "Migration always causes problems in communities."@en ;
  curric:correction """Migration can bring challenges, but it also brings many benefits like new
  skills, jobs and cultures. Communities often grow stronger by learning from each other and
  working together to solve problems."""@en ;
  dcterms:modified "2026-06-07T15:30:15.155473Z"^^xsd:dateTime .

oakcurric:misconception-citizenship-legal-status
  a curric:Misconception ;
  curric:statement "Citizenship is only about legal status."@en ;
  curric:correction """Citizenship is all about being part of a society and being an active
  citizen."""@en ;
  dcterms:modified "2026-06-07T15:30:15.155486Z"^^xsd:dateTime .

oakcurric:misconception-bank-phones-ask-tell-them
  a curric:Misconception ;
  curric:statement """When a bank phones you they will ask you to tell them all of your personal
  details."""@en ;
  curric:correction """Your bank will only ever ask you to disclose some of your personal details,
  never all of them. If you are asked for all of your details, it is a scam."""@en ;
  dcterms:modified "2026-06-07T15:30:15.157520Z"^^xsd:dateTime .

oakcurric:misconception-men-right-vote-1918
  a curric:Misconception ;
  curric:statement "All men had the right to vote before 1918."@en ;
  curric:correction "Approximately 40% of men could not vote before 1918."@en ;
  dcterms:modified "2026-06-07T15:30:15.158255Z"^^xsd:dateTime .

oakcurric:misconception-political-parties-either-left-wing
  a curric:Misconception ;
  curric:statement "Political parties are all either left wing or right wing."@en ;
  curric:correction """Many parties mix both views or focus on specific issues, like regional
  concerns. Some parties are centrist or have ideas that don’t fit neatly into either side."""@en ;
  dcterms:modified "2026-06-07T15:30:15.159456Z"^^xsd:dateTime .

oakcurric:misconception-chartists-achieved-their-aims-parliament
  a curric:Misconception ;
  curric:statement "The Chartists achieved their aims and Parliament adopted their charter."@en ;
  curric:correction """The charter was not adopted by Parliament and the next Reform Act wasn't
  passed until 1867, after the Chartists had disbanded."""@en ;
  dcterms:modified "2026-06-07T15:30:15.160410Z"^^xsd:dateTime .

oakcurric:misconception-prime-minister-directly-elected-public
  a curric:Misconception ;
  curric:statement """The Prime Minister is directly elected by the public during the general
  election."""@en ;
  curric:correction """The Prime Minister is not elected by the people; instead, they are the leader
  of the party that has the most seats in the House of Commons after the election."""@en ;
  dcterms:modified "2026-06-07T15:30:15.160501Z"^^xsd:dateTime .

oakcurric:misconception-democracy-voting-leaders-making-decisions
  a curric:Misconception ;
  curric:statement """Democracy is just about voting for leaders and making decisions by majority
  rule."""@en ;
  curric:correction """Democracy is about fairness, equality and everyone having a voice in how
  their society is run."""@en ;
  dcterms:modified "2026-06-07T15:30:15.160821Z"^^xsd:dateTime .

oakcurric:misconception-people-power-take-effective-action
  a curric:Misconception ;
  curric:statement "Only people in power can take effective action."@en ;
  curric:correction """Every citizen can take effective action to make lasting change to their
  local, national or global community. You do not need to be in a position of power to take
  effective action."""@en ;
  dcterms:modified "2026-06-07T15:30:15.161031Z"^^xsd:dateTime .

oakcurric:misconception-representative-democracies-take-choices-citizens
  a curric:Misconception ;
  curric:statement """Representative democracies take away the choices of citizens because the
  representatives make all the decisions on their behalf."""@en ;
  curric:correction """In a representative democracy, citizens elect representatives to make
  decisions on their behalf, but they can also influence policies through voting in
  elections, contacting their representatives and sometimes even through referendums."""@en ;
  dcterms:modified "2026-06-07T15:30:15.161037Z"^^xsd:dateTime .

oakcurric:misconception-voting-way-exercise-your-democratic
  a curric:Misconception ;
  curric:statement "Voting is the only way you can exercise your democratic rights."@en ;
  curric:correction """There are several ways you can exercise your democratic rights, even if you
  cannot vote. You could: contact your local councillor or Member of Parliament (MP);
  express your opinion; join a peaceful protest or pressure group or join a political party."""@en ;
  dcterms:modified "2026-06-07T15:30:15.161537Z"^^xsd:dateTime .

oakcurric:misconception-digital-democracy-means-easier-everyone
  a curric:Misconception ;
  curric:statement "Digital democracy means it is easier for everyone to get involved."@en ;
  curric:correction """Digital democracy can help reduce barriers. However, not everyone has equal
  access to technology or the internet. Some people may struggle with digital skills or lack
  internet access, creating barriers to participation."""@en ;
  dcterms:modified "2026-06-07T15:30:15.161704Z"^^xsd:dateTime .

oakcurric:misconception-children-age-10-consequences-their
  a curric:Misconception ;
  curric:statement "Children under the age of 10 have no consequences for their actions."@en ;
  curric:correction """Whilst the age of criminal responsbility in England, Wales and Northern
  Ireland is 10, this does not mean children under this age will face no conseqences if they
  break the law. They may still face other forms of intervention."""@en ;
  dcterms:modified "2026-06-07T15:30:15.162021Z"^^xsd:dateTime .

oakcurric:misconception-role-police-make-laws
  a curric:Misconception ;
  curric:statement "It is the role of the police to make laws."@en ;
  curric:correction """Laws are created by Parliament. The police do not make the law, they enforce
  it."""@en ;
  dcterms:modified "2026-06-07T15:30:15.162810Z"^^xsd:dateTime .

oakcurric:misconception-crime-prevention-strategies-work-catch
  a curric:Misconception ;
  curric:statement "Crime prevention strategies only work if they catch criminals."@en ;
  curric:correction """Crime prevention strategies are about stopping crime before it happens. For
  example, strategies like educating young people, improving public spaces and changing
  attitudes can help reduce the chances of crime occurring in the first place."""@en ;
  dcterms:modified "2026-06-07T15:30:15.162945Z"^^xsd:dateTime .

oakcurric:misconception-currently-16-17-year-olds
  a curric:Misconception ;
  curric:statement """Currently no 16- and 17-year-olds have the right to vote in elections in the
  UK."""@en ;
  curric:correction """In Scotland and Wales, you can vote from the age of 16 in Senedd, Scottish
  Parliament, and local elections."""@en ;
  dcterms:modified "2026-06-07T15:30:15.163115Z"^^xsd:dateTime .

oakcurric:misconception-young-people-cannot-change-anything
  a curric:Misconception ;
  curric:statement "Young people cannot change anything in their communities, only adults can."@en ;
  curric:correction """Young people, as well as adults, can make lasting change in their
  communities. Young people have many powerful tools, like social media, to campaign for
  change."""@en ;
  dcterms:modified "2026-06-07T15:30:15.163183Z"^^xsd:dateTime .

oakcurric:misconception-individual-am-responsible-taking-action
  a curric:Misconception ;
  curric:statement "As an individual, I am not responsible for taking action on global issues."@en ;
  curric:correction """You can make a difference by being an active citizen and taking responsible
  action."""@en ;
  dcterms:modified "2026-06-07T15:30:15.164134Z"^^xsd:dateTime .

oakcurric:misconception-effective-change-happens-large-dramatic
  a curric:Misconception ;
  curric:statement """Effective change only happens through large, dramatic actions or protests and
  smaller efforts don't make a difference."""@en ;
  curric:correction """Effective change can happen in many ways. While protests like those led by
  the women's suffrage movement can bring attention to important issues, smaller actions,
  like community policing, can also lead to significant and lasting change."""@en ;
  dcterms:modified "2026-06-07T15:30:15.164266Z"^^xsd:dateTime .

oakcurric:misconception-examples-media-holding-power-account
  a curric:Misconception ;
  curric:statement "There are no examples of the media holding those in power to account."@en ;
  curric:correction """There are many examples of the media holding those in power to account, for
  example, if a politician makes promises about education and doesn't deliver, the media
  could publish an article about it to hold them to account."""@en ;
  dcterms:modified "2026-06-07T15:30:15.164624Z"^^xsd:dateTime .

oakcurric:misconception-local-democracy-happens-elections
  a curric:Misconception ;
  curric:statement "Local democracy only happens during elections."@en ;
  curric:correction """Local democracy is happening all the time. It occurs in council meetings,
  Youth Councils, local campaigns and anytime that people speak up about local issues. You
  do not need to wait for local elections to take part."""@en ;
  dcterms:modified "2026-06-07T15:30:15.164957Z"^^xsd:dateTime .

oakcurric:misconception-nothing-protects-supports-childrens-rights
  a curric:Misconception ;
  curric:statement "There is nothing that protects and supports children’s rights in the UK."@en ;
  curric:correction """There are lots of organisations that protect and support children’s rights in
  the UK."""@en ;
  dcterms:modified "2026-06-07T15:30:15.164962Z"^^xsd:dateTime .

oakcurric:misconception-immigration-control-means-stopping-immigration
  a curric:Misconception ;
  curric:statement "Immigration control means stopping all immigration."@en ;
  curric:correction """Immigration control does not mean stopping all immigration. It means managing
  who can come, when and why, using systems like visas, border checks and rules. The aim is
  to make immigration fair, safe and planned, not to block everyone from entering."""@en ;
  dcterms:modified "2026-06-07T15:30:15.165932Z"^^xsd:dateTime .

oakcurric:misconception-rules-same-everyone
  a curric:Misconception ;
  curric:statement "Rules are the same for everyone."@en ;
  curric:correction """Rules may be different in different settings and situations, for example, you
  may have different rules at school and home. Laws are the same for everyone."""@en ;
  dcterms:modified "2026-06-07T15:30:15.166390Z"^^xsd:dateTime .

oakcurric:misconception-campaigns-work-same-way-one
  a curric:Misconception ;
  curric:statement """All campaigns work the same way; if one method worked once, it will always
  work."""@en ;
  curric:correction """Never overlook the importance of choosing the right method for the right
  situation and evaluating its impact. Some campaigns will require a combination of methods."""@en ;
  dcterms:modified "2026-06-07T15:30:15.166602Z"^^xsd:dateTime .

oakcurric:misconception-prime-minister-cabinet-total-control
  a curric:Misconception ;
  curric:statement "The Prime Minister and the Cabinet have total control over the UK."@en ;
  curric:correction """The Prime Minister leads the Government but must answer to Parliament.
  Members of Parliament (MPs) debate and approve laws and can challenge a Prime Minister.
  The Cabinet makes decisions but is accountable to Parliament and the law."""@en ;
  dcterms:modified "2026-06-07T15:30:15.166669Z"^^xsd:dateTime .

oakcurric:misconception-asylum-seekers-need-support-move
  a curric:Misconception ;
  curric:statement "Only asylum seekers need support when they move to a new country."@en ;
  curric:correction """All migrants may need support. Refugees often flee danger and need urgent
  help, but even those who move for work, study or family benefit from language classes, job
  advice and community events to settle in and feel part of their new home."""@en ;
  dcterms:modified "2026-06-07T15:30:15.166782Z"^^xsd:dateTime .

oakcurric:misconception-young-people-cannot-make-difference
  a curric:Misconception ;
  curric:statement """Young people cannot make a difference because adults are the
  decision-makers."""@en ;
  curric:correction """Young people can make a difference. Article 12 of the UNCRC says children
  have the right to be heard in decisions that affect them. For example, Martha Payne was
  only nine years old when she helped change school meals by sharing her views."""@en ;
  dcterms:modified "2026-06-07T15:30:15.166788Z"^^xsd:dateTime .

oakcurric:misconception-social-media-fun-entertainment
  a curric:Misconception ;
  curric:statement "Social media is just for fun and entertainment."@en ;
  curric:correction """Social media is also used for serious things like political campaigns,
  protests, and sharing important issues."""@en ;
  dcterms:modified "2026-06-07T15:30:15.168257Z"^^xsd:dateTime .

oakcurric:misconception-crimes-committed-adults
  a curric:Misconception ;
  curric:statement "Crimes can only be committed by adults."@en ;
  curric:correction """Anyone can commit a crime. In England, once you reach the age of ten, you can
  be held criminally responsible for your actions. This means that if a person aged ten or
  older breaks the law, they can face legal consequences."""@en ;
  dcterms:modified "2026-06-07T15:30:15.168457Z"^^xsd:dateTime .

oakcurric:misconception-mps-dont-vote-digitally-done
  a curric:Misconception ;
  curric:statement "MPs don’t vote digitally at all, it is all done on paper or by hand."@en ;
  curric:correction """It is true that MPs vote in person, but since 2020 they have used electronic
  systems in the division lobbies to record their votes by scanning a pass."""@en ;
  dcterms:modified "2026-06-07T15:30:15.168538Z"^^xsd:dateTime .

oakcurric:misconception-nations-within-united-kingdom-same
  a curric:Misconception ;
  curric:statement """All nations within the United Kingdom have the same voting age for all
  elections."""@en ;
  curric:correction """In May 2025 in Scotland and Wales, apart from UK general elections, you can
  vote in public elections when you are 16 years old. Whereas in England and Northern
  Ireland you cannot vote until you are 18 years old."""@en ;
  dcterms:modified "2026-06-07T15:30:15.168862Z"^^xsd:dateTime .

oakcurric:misconception-borrowing-money-dangerous-thing
  a curric:Misconception ;
  curric:statement "Borrowing money is always a dangerous thing to do."@en ;
  curric:correction """In our lives it is sometimes necessary to borrow money, e.g., when we buy a
  house most people have to get a mortgage. However, this can be part of budgeting sensibly
  and learning to be financially responsible by always paying loans back on time."""@en ;
  dcterms:modified "2026-06-07T15:30:15.169421Z"^^xsd:dateTime .

oakcurric:misconception-investments-carry-same-level-financial
  a curric:Misconception ;
  curric:statement "Investments all carry the same level of financial risk."@en ;
  curric:correction """There are many different types of investments and they all provide different
  risks. For example, cryptocurrency is very risky, whereas investing in funds provides more
  financial security."""@en ;
  dcterms:modified "2026-06-07T15:30:15.169430Z"^^xsd:dateTime .

oakcurric:misconception-devolved-governments-make-laws-policies
  a curric:Misconception ;
  curric:statement """Devolved governments can make laws and policies on any issue in their devolved
  region."""@en ;
  curric:correction """The powers of devolved governments are limited to specific policy areas
  defined by devolution agreements. Northern Ireland, Scotland and Wales have some executive
  and legislative powers. English regional governments only have some executive powers."""@en ;
  dcterms:modified "2026-06-07T15:30:15.169436Z"^^xsd:dateTime .

oakcurric:misconception-police-prevent-crime
  a curric:Misconception ;
  curric:statement "Only the police can prevent crime."@en ;
  curric:correction """Communities can also play a key role by using strategies like education,
  situational changes and deterrents to reduce crime and promote safety."""@en ;
  dcterms:modified "2026-06-07T15:30:15.169991Z"^^xsd:dateTime .

oakcurric:misconception-many-young-people-believe-cannot
  a curric:Misconception ;
  curric:statement """Many young people believe they cannot influence decisions because they are not
  old enough to vote."""@en ;
  curric:correction """Emphasise that democratic participation is not limited to voting. Pupils can
  have power and influence through various actions such as campaigning, petitions, joining
  youth organisations and speaking to decision makers."""@en ;
  dcterms:modified "2026-06-07T15:30:15.170174Z"^^xsd:dateTime .

oakcurric:misconception-everyone-automatically-gets-chance-vote
  a curric:Misconception ;
  curric:statement "Everyone automatically gets a chance to vote in a UK election."@en ;
  curric:correction """Not all residents are eligible to vote or are registered to vote. Some may
  miss out on elections if they don’t register in time or are unaware of the process."""@en ;
  dcterms:modified "2026-06-07T15:30:15.170472Z"^^xsd:dateTime .

oakcurric:misconception-children-protected-wars-conflicts-because
  a curric:Misconception ;
  curric:statement """Children are always protected during wars and conflicts because there are laws
  and organisations to help them."""@en ;
  curric:correction """Even though laws and organisations aim to protect children, conflict can
  still put them in danger. Many lose homes, schools or family, and may not get the help
  they need. Protection efforts are vital, but they can't always reach every child in time."""@en ;
  dcterms:modified "2026-06-07T15:30:15.170822Z"^^xsd:dateTime .

oakcurric:misconception-young-people-involved-crime-because
  a curric:Misconception ;
  curric:statement """Most young people are involved in crime because the media shows so many
  negative stories about them."""@en ;
  curric:correction """While the media often focuses on negative stories, the majority of young
  people are not involved in crime. Recent statistics show that many stop and searches and
  arrests don’t lead to charges, and the number of young people in custody is low."""@en ;
  dcterms:modified "2026-06-07T15:30:15.170874Z"^^xsd:dateTime .

oakcurric:misconception-cant-trust-anything-see-media
  a curric:Misconception ;
  curric:statement "We can't trust anything we see in the media."@en ;
  curric:correction """We can make sure we know how to get access to reliable and accurate
  information which will be more trustworthy."""@en ;
  dcterms:modified "2026-06-07T15:30:15.170995Z"^^xsd:dateTime .

oakcurric:misconception-digital-citizenship-means-knowing-use
  a curric:Misconception ;
  curric:statement "Digital citizenship just means knowing how to use technology."@en ;
  curric:correction """Digital citizenship includes understanding how to behave responsibly online,
  respect others, protect your privacy, think critically about information, and participate
  in digital spaces in ethical and constructive ways."""@en ;
  dcterms:modified "2026-06-07T15:30:15.171253Z"^^xsd:dateTime .

oakcurric:misconception-politicians-people-important-jobs-contribute
  a curric:Misconception ;
  curric:statement """Only politicians and people in important jobs can contribute to a select
  committee."""@en ;
  curric:correction "Anyone can submit evidence to a select committee, including pupils."@en ;
  dcterms:modified "2026-06-07T15:30:15.171258Z"^^xsd:dateTime .

oakcurric:misconception-pay-minimum-payment-month-credit
  a curric:Misconception ;
  curric:statement """You only have to pay the minimum payment each month on a credit card to not
  pay any interest."""@en ;
  curric:correction """Unless your credit card is interest-free for an amount of time, if you pay
  the minimum payment each month, you will be charged interest. Some credit cards can charge
  up to 30% or more in interest, so it is best to pay it off in full each month."""@en ;
  dcterms:modified "2026-06-07T15:30:15.171349Z"^^xsd:dateTime .

oakcurric:misconception-people-believe-one-identity
  a curric:Misconception ;
  curric:statement "Some people believe that you can only have one identity."@en ;
  curric:correction """People can have multiple identities because they can belong to different
  groups at the same time."""@en ;
  dcterms:modified "2026-06-07T15:30:15.171354Z"^^xsd:dateTime .

oakcurric:misconception-theres-way-individual-national-organisation
  a curric:Misconception ;
  curric:statement """There’s no way an individual or national organisation can make a difference to
  tackling global poverty."""@en ;
  curric:correction """There are many NGOs, global organisations and communities that are working
  hard to make a difference to global poverty."""@en ;
  dcterms:modified "2026-06-07T15:30:15.171360Z"^^xsd:dateTime .
