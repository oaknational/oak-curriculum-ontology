# ----------------------------------------------------------------------
# Keywords
# ----------------------------------------------------------------------

oakcurric:keyword-stereotype
  a curric:Keyword ;
  schema:name "stereotype"@en ;
  schema:description "a simplified belief, view or representation of a group of people"@en ;
  dcterms:modified "2026-02-12T08:59:15.789366Z"^^xsd:dateTime .

oakcurric:keyword-campaign
  a curric:Keyword ;
  schema:name "campaign"@en ;
  schema:description "a series of military operations, usually with the aim of defeating an enemy"@en ;
  dcterms:modified "2026-02-12T08:59:15.789466Z"^^xsd:dateTime .

oakcurric:keyword-militant
  a curric:Keyword ;
  schema:name "militant"@en ;
  schema:description "to be forceful, determined and extreme, sometimes using aggressive methods"@en ;
  dcterms:modified "2026-02-12T08:59:15.789549Z"^^xsd:dateTime .

oakcurric:keyword-migration
  a curric:Keyword ;
  schema:name "migration"@en ;
  schema:description """the movement of people from one place to another, either within a country or between countries, often for economic, social, political or environmental reasons"""@en ;
  dcterms:modified "2026-02-12T08:59:15.789717Z"^^xsd:dateTime .

oakcurric:keyword-government
  a curric:Keyword ;
  schema:name "government"@en ;
  schema:description "a government is a group of leaders who make laws and decisions for a country"@en ;
  dcterms:modified "2026-02-12T08:59:15.790003Z"^^xsd:dateTime .

oakcurric:keyword-refugee
  a curric:Keyword ;
  schema:name "refugee"@en ;
  schema:description """a refugee is a person who has been forced to leave their country in order to escape war, persecution or natural disaster"""@en ;
  dcterms:modified "2026-02-12T08:59:15.790020Z"^^xsd:dateTime .

oakcurric:keyword-evaluate
  a curric:Keyword ;
  schema:name "evaluate"@en ;
  schema:description "to consider something carefully and make a judgement about it."@en ;
  dcterms:modified "2026-02-12T08:59:15.790049Z"^^xsd:dateTime .

oakcurric:keyword-prejudice
  a curric:Keyword ;
  schema:name "prejudice"@en ;
  schema:description "unfair or unreasonable opinions formed without thought or knowledge"@en ;
  dcterms:modified "2026-02-12T08:59:15.790131Z"^^xsd:dateTime .

oakcurric:keyword-discrimination
  a curric:Keyword ;
  schema:name "discrimination"@en ;
  schema:description """discrimination is the unjust treatment of a person or group of people, usually on the grounds of a physical quality or belief"""@en ;
  dcterms:modified "2026-02-12T08:59:15.790161Z"^^xsd:dateTime .

oakcurric:keyword-climate-change
  a curric:Keyword ;
  schema:name "climate change"@en ;
  schema:description "long-term shifts in temperatures and weather patterns"@en ;
  dcterms:modified "2026-02-12T08:59:15.790394Z"^^xsd:dateTime .

oakcurric:keyword-manifesto
  a curric:Keyword ;
  schema:name "manifesto"@en ;
  schema:description """a clear statement of beliefs, goals, or intentions, often published publicly by a person, group, or organisation"""@en ;
  dcterms:modified "2026-02-12T08:59:15.790750Z"^^xsd:dateTime .

oakcurric:keyword-reliable
  a curric:Keyword ;
  schema:name "reliable"@en ;
  schema:description """reliable data is data that would show the same result were it to be collected on a comparably similar occasion"""@en ;
  dcterms:modified "2026-02-12T08:59:15.790938Z"^^xsd:dateTime .

oakcurric:keyword-immigration
  a curric:Keyword ;
  schema:name "immigration"@en ;
  schema:description "the act of moving into a new host location"@en ;
  dcterms:modified "2026-02-12T08:59:15.791133Z"^^xsd:dateTime .

oakcurric:keyword-emigration
  a curric:Keyword ;
  schema:name "emigration"@en ;
  schema:description "the act of moving out of a source location"@en ;
  dcterms:modified "2026-02-12T08:59:15.791137Z"^^xsd:dateTime .

oakcurric:keyword-asylum-seeker
  a curric:Keyword ;
  schema:name "asylum seeker"@en ;
  schema:description """someone who seeks permanent or temporary protection in another country from the persecution or danger they experience in their home country"""@en ;
  dcterms:modified "2026-02-12T08:59:15.791141Z"^^xsd:dateTime .

oakcurric:keyword-referendum
  a curric:Keyword ;
  schema:name "referendum"@en ;
  schema:description "a vote held in which citizens vote directly on a closed question"@en ;
  dcterms:modified "2026-02-12T08:59:15.791197Z"^^xsd:dateTime .

oakcurric:keyword-inequality
  a curric:Keyword ;
  schema:name "inequality"@en ;
  schema:description "inequality is when something is not shared evenly between everyone"@en ;
  dcterms:modified "2026-02-12T08:59:15.791205Z"^^xsd:dateTime .

oakcurric:keyword-renewable-energy
  a curric:Keyword ;
  schema:name "renewable energy"@en ;
  schema:description """a natural source of energy that will never run out, such as flows of wind, water and solar energy"""@en ;
  dcterms:modified "2026-02-12T08:59:15.791287Z"^^xsd:dateTime .

oakcurric:keyword-sustainable
  a curric:Keyword ;
  schema:name "sustainable"@en ;
  schema:description "able to continue over a long time"@en ;
  dcterms:modified "2026-02-12T08:59:15.791311Z"^^xsd:dateTime .

oakcurric:keyword-protest
  a curric:Keyword ;
  schema:name "protest"@en ;
  schema:description """a protest is a statement or action expressing disapproval of or objection to something"""@en ;
  dcterms:modified "2026-02-12T08:59:15.791715Z"^^xsd:dateTime .

oakcurric:keyword-court
  a curric:Keyword ;
  schema:name "court"@en ;
  schema:description "the place where a ruler spends time ruling is known as their court"@en ;
  dcterms:modified "2026-02-12T08:59:15.791789Z"^^xsd:dateTime .

oakcurric:keyword-tax
  a curric:Keyword ;
  schema:name "tax"@en ;
  schema:description "tax is a compulsory payment to the government to cover various costs"@en ;
  dcterms:modified "2026-02-12T08:59:15.791953Z"^^xsd:dateTime .

oakcurric:keyword-community
  a curric:Keyword ;
  schema:name "community"@en ;
  schema:description """a group of people living in the same place or having a particular characteristic in common"""@en ;
  dcterms:modified "2026-02-12T08:59:15.791975Z"^^xsd:dateTime .

oakcurric:keyword-active-citizen
  a curric:Keyword ;
  schema:name "active citizen"@en ;
  schema:description """a person who actively takes responsibility, becomes involved in areas of public concern and tries to make a positive difference in their community"""@en ;
  dcterms:modified "2026-02-12T08:59:15.791979Z"^^xsd:dateTime .

oakcurric:keyword-school-council
  a curric:Keyword ;
  schema:name "school council"@en ;
  schema:description """a formal group of pupils who act as representatives for their fellow students in discussing school issues with the people who run the school"""@en ;
  dcterms:modified "2026-02-12T08:59:15.791983Z"^^xsd:dateTime .

oakcurric:keyword-campaigning
  a curric:Keyword ;
  schema:name "campaigning"@en ;
  schema:description """actions or events organised by an individual or a group of people to achieve an aim"""@en ;
  dcterms:modified "2026-02-12T08:59:15.791987Z"^^xsd:dateTime .

oakcurric:keyword-parliament
  a curric:Keyword ;
  schema:name "parliament"@en ;
  schema:description """parliament, or talking meeting, is the group of political representatives who make laws, grant taxes and advise the king"""@en ;
  dcterms:modified "2026-02-12T08:59:15.792075Z"^^xsd:dateTime .

oakcurric:keyword-human-rights
  a curric:Keyword ;
  schema:name "human rights"@en ;
  schema:description """human rights are the basic rights that many consider all people should have, such as justice and the freedom to say what you think"""@en ;
  dcterms:modified "2026-02-12T08:59:15.792123Z"^^xsd:dateTime .

oakcurric:keyword-active-citizenship
  a curric:Keyword ;
  schema:name "active citizenship"@en ;
  schema:description """the process of learning how to take part in democracy and use Citizenship knowledge, skills and understanding to work together and try to make a positive difference in the world"""@en ;
  dcterms:modified "2026-02-12T08:59:15.792151Z"^^xsd:dateTime .

oakcurric:keyword-charities
  a curric:Keyword ;
  schema:name "charities"@en ;
  schema:description """local, national or international organisations which are set up to help those in need or to raise awareness of an issue"""@en ;
  dcterms:modified "2026-02-12T08:59:15.792341Z"^^xsd:dateTime .

oakcurric:keyword-ngo
  a curric:Keyword ;
  schema:name "NGO"@en ;
  schema:description """a non-governmental organisation, non-profit, voluntary group of citizens who work on a local, national or international level to achieve an aim"""@en ;
  dcterms:modified "2026-02-12T08:59:15.792345Z"^^xsd:dateTime .

oakcurric:keyword-community-groups
  a curric:Keyword ;
  schema:name "community groups"@en ;
  schema:description """an organised collective of people with similar interests or aims, including NGOs, charities and other organisations within the community"""@en ;
  dcterms:modified "2026-02-12T08:59:15.792349Z"^^xsd:dateTime .

oakcurric:keyword-crime
  a curric:Keyword ;
  schema:name "crime"@en ;
  schema:description "an illegal act that is punishable by law"@en ;
  dcterms:modified "2026-02-12T08:59:15.792371Z"^^xsd:dateTime .

oakcurric:keyword-law
  a curric:Keyword ;
  schema:name "law"@en ;
  schema:description """rules, usually made by Parliament, that are used to order the way in which a society behaves"""@en ;
  dcterms:modified "2026-02-12T08:59:15.792376Z"^^xsd:dateTime .

oakcurric:keyword-police
  a curric:Keyword ;
  schema:name "police"@en ;
  schema:description """a public force that helps keep the community safe; they work to prevent and investigate crimes, enforce laws and maintain order in society"""@en ;
  dcterms:modified "2026-02-12T08:59:15.792380Z"^^xsd:dateTime .

oakcurric:keyword-right
  a curric:Keyword ;
  schema:name "right"@en ;
  schema:description "something we are entitled to by law"@en ;
  dcterms:modified "2026-02-12T08:59:15.792498Z"^^xsd:dateTime .

oakcurric:keyword-civil-law
  a curric:Keyword ;
  schema:name "civil law"@en ;
  schema:description "law that deals with disputes between individuals or groups"@en ;
  dcterms:modified "2026-02-12T08:59:15.792503Z"^^xsd:dateTime .

oakcurric:keyword-information
  a curric:Keyword ;
  schema:name "information"@en ;
  schema:description """knowledge communicated concerning a particular fact or subject, often presented to us in the media"""@en ;
  dcterms:modified "2026-02-12T08:59:15.792528Z"^^xsd:dateTime .

oakcurric:keyword-reliable-information
  a curric:Keyword ;
  schema:name "reliable information"@en ;
  schema:description """knowledge communicated about a particular fact or subject, often presented to us in the media, that can be trusted, believed and verified with external sources"""@en ;
  dcterms:modified "2026-02-12T08:59:15.792533Z"^^xsd:dateTime .

oakcurric:keyword-councillor
  a curric:Keyword ;
  schema:name "councillor"@en ;
  schema:description """elected representatives who make decisions, set policies and represent the views of the community"""@en ;
  dcterms:modified "2026-02-12T08:59:15.792563Z"^^xsd:dateTime .

oakcurric:keyword-ward
  a curric:Keyword ;
  schema:name "ward"@en ;
  schema:description "smaller, specific area within a local council's district"@en ;
  dcterms:modified "2026-02-12T08:59:15.792567Z"^^xsd:dateTime .

oakcurric:keyword-council-officers
  a curric:Keyword ;
  schema:name "council officers"@en ;
  schema:description """often those with specialist knowledge who work for the council; support councillors to make decisions for the local area"""@en ;
  dcterms:modified "2026-02-12T08:59:15.792575Z"^^xsd:dateTime .

oakcurric:keyword-authority
  a curric:Keyword ;
  schema:name "authority"@en ;
  schema:description "authority is the power or ability to control or demand obedience"@en ;
  dcterms:modified "2026-02-12T08:59:15.792646Z"^^xsd:dateTime .

oakcurric:keyword-action
  a curric:Keyword ;
  schema:name "action"@en ;
  schema:description """practical steps designed to try to raise public awareness or influence key decision-makers"""@en ;
  dcterms:modified "2026-02-12T08:59:15.792661Z"^^xsd:dateTime .

oakcurric:keyword-support
  a curric:Keyword ;
  schema:name "support"@en ;
  schema:description """support means to provide assistance or encouragement in order to help someone succeed"""@en ;
  dcterms:modified "2026-02-12T08:59:15.792743Z"^^xsd:dateTime .

oakcurric:keyword-belonging
  a curric:Keyword ;
