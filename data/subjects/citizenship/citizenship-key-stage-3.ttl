# ----------------------------------------------------------------------
# Key Learning Points
# ----------------------------------------------------------------------

oakcurric:keylearningpoint-lesson-24862-1
  a curric:KeyLearningPoint ;
  rdfs:label """A changemaker is someone who sees a problem in the world and works to fix it by
  using resources and taking action."""@en ;
  dcterms:modified "2026-06-07T15:30:29.002084Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24862-2
  a curric:KeyLearningPoint ;
  rdfs:label """Changemakers imagine a better future, take steps to make it happen, and work with
  others to create positive change."""@en ;
  dcterms:modified "2026-06-07T15:30:29.002088Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24862-3
  a curric:KeyLearningPoint ;
  rdfs:label """Changemakers are important in democracy because they push for policy changes and
  hold those in power to account."""@en ;
  dcterms:modified "2026-06-07T15:30:29.002092Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24862-4
  a curric:KeyLearningPoint ;
  rdfs:label """Inspiring others to get involved, changemakers raise awareness about issues like
  human rights and the environment."""@en ;
  dcterms:modified "2026-06-07T15:30:29.002100Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24831-1
  a curric:KeyLearningPoint ;
  rdfs:label """A Member of Parliament (MP) is an elected representative of citizens in
  Parliament."""@en ;
  dcterms:modified "2026-06-07T15:30:29.002615Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24831-2
  a curric:KeyLearningPoint ;
  rdfs:label """The name of the geographical area and its citizens that an MP represents is called a
  constituency."""@en ;
  dcterms:modified "2026-06-07T15:30:29.002619Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24831-3
  a curric:KeyLearningPoint ;
  rdfs:label """MPs split their time between working in Parliament and working in their
  constituency."""@en ;
  dcterms:modified "2026-06-07T15:30:29.002624Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24831-4
  a curric:KeyLearningPoint ;
  rdfs:label """Some MPs also have additional responsibilities working in the UK Government's
  Cabinet."""@en ;
  dcterms:modified "2026-06-07T15:30:29.002628Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22510-1
  a curric:KeyLearningPoint ;
  rdfs:label """Two different ideas of fairness are treating people the same or treating people
  differently according to their needs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.003811Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22510-2
  a curric:KeyLearningPoint ;
  rdfs:label """Fairness involves a process to decide what is and isn't fair, considering whether
  everyone can achieve the same outcome."""@en ;
  dcterms:modified "2026-06-07T15:30:29.003815Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22510-3
  a curric:KeyLearningPoint ;
  rdfs:label """There are different organisations who fight for fairness including the NSPCC and
  UNICEF."""@en ;
  dcterms:modified "2026-06-07T15:30:29.003819Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24912-1
  a curric:KeyLearningPoint ;
  rdfs:label """Social media increases political participation by enabling sharing, organising and
  raising awareness."""@en ;
  dcterms:modified "2026-06-07T15:30:29.005131Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24912-2
  a curric:KeyLearningPoint ;
  rdfs:label """The Black Lives Matter movement is an example of how social media can influence
  public debate and political action."""@en ;
  dcterms:modified "2026-06-07T15:30:29.005136Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24912-3
  a curric:KeyLearningPoint ;
  rdfs:label """Social media boosts political participation but its reliability is limited by issues
  e.g. misinformation & polarisation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.005140Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24912-4
  a curric:KeyLearningPoint ;
  rdfs:label """Data misuse scandals show risks to privacy and trust, raising questions about social
  media’s reliability."""@en ;
  dcterms:modified "2026-06-07T15:30:29.005146Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24852-1
  a curric:KeyLearningPoint ;
  rdfs:label """In the UK laws are made by Parliament, also known as the legislature. Parliament is
  made of three parts."""@en ;
  dcterms:modified "2026-06-07T15:30:29.255404Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24852-2
  a curric:KeyLearningPoint ;
  rdfs:label """MPs debate and vote on proposed laws called Bills. A Bill must receive at least 50%
  support from MPs to become an Act."""@en ;
  dcterms:modified "2026-06-07T15:30:29.255408Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24852-3
  a curric:KeyLearningPoint ;
  rdfs:label """Citizens can influence lawmakers through methods like petitions, surveys, lobbying
  and media."""@en ;
  dcterms:modified "2026-06-07T15:30:29.255413Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24852-4
  a curric:KeyLearningPoint ;
  rdfs:label """PC Wardell is an example of a citizen who helped change the law, through the Animal
  Welfare (Service Animals) Act 2018."""@en ;
  dcterms:modified "2026-06-07T15:30:29.255417Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24868-1
  a curric:KeyLearningPoint ;
  rdfs:label "Politics impacts all the activities we take part in."@en ;
  dcterms:modified "2026-06-07T15:30:29.257565Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24868-2
  a curric:KeyLearningPoint ;
  rdfs:label "In a general election we vote for MPs who represent us in Parliament."@en ;
  dcterms:modified "2026-06-07T15:30:29.257570Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24868-3
  a curric:KeyLearningPoint ;
  rdfs:label """Exercising our right to vote is a good way of taking part in the politics and
  influencing the decisions made by MPs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.257574Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24893-1
  a curric:KeyLearningPoint ;
  rdfs:label """When people treat others less favourably because of their prejudices, this is
  discrimination."""@en ;
  dcterms:modified "2026-06-07T15:30:29.258145Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24893-2
  a curric:KeyLearningPoint ;
  rdfs:label """In the past, people were often treated unequally, but there were no laws in place to
  protect people from discrimination."""@en ;
  dcterms:modified "2026-06-07T15:30:29.258149Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24893-3
  a curric:KeyLearningPoint ;
  rdfs:label """Some actions now seen as discriminatory, e.g., punishing people for sexuality, were
  once crimes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.258153Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24893-4
  a curric:KeyLearningPoint ;
  rdfs:label "Many people have raised awareness and pushed for positive change."@en ;
  dcterms:modified "2026-06-07T15:30:29.258196Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24893-5
  a curric:KeyLearningPoint ;
  rdfs:label """The law has gradually shifted to ensure greater protection for everyone, e.g., the
  Equality Act 2010."""@en ;
  dcterms:modified "2026-06-07T15:30:29.258201Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24832-1
  a curric:KeyLearningPoint ;
  rdfs:label "The UK Government has three main branches: legislative, executive and judiciary."@en ;
  dcterms:modified "2026-06-07T15:30:29.258889Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24832-2
  a curric:KeyLearningPoint ;
  rdfs:label """The Cabinet is chosen by the PM. It leads government departments and makes key
  decisions on government policies."""@en ;
  dcterms:modified "2026-06-07T15:30:29.258892Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24832-3
  a curric:KeyLearningPoint ;
  rdfs:label """The Civil Service and arm's-length bodies implement policies made by the
  Government."""@en ;
  dcterms:modified "2026-06-07T15:30:29.258896Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24832-4
  a curric:KeyLearningPoint ;
  rdfs:label """Ministers are appointed to their roles in the Government by the monarch, after being
  handpicked by the PM."""@en ;
  dcterms:modified "2026-06-07T15:30:29.258902Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24832-5
  a curric:KeyLearningPoint ;
  rdfs:label "Civil servants and public sector workers are employed after a hiring process."@en ;
  dcterms:modified "2026-06-07T15:30:29.258906Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24860-1
  a curric:KeyLearningPoint ;
  rdfs:label """Pressure groups, protest groups and social movements can create change by
  influencing decisions in society."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259544Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24860-2
  a curric:KeyLearningPoint ;
  rdfs:label """Pressure groups focus on specific issues, using methods like lobbying and protest
  groups protest for change."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259547Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24860-3
  a curric:KeyLearningPoint ;
  rdfs:label """Social movements unite large numbers of people to fight for broad social, political
  or cultural change."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259551Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24860-4
  a curric:KeyLearningPoint ;
  rdfs:label """Successful groups use various methods like petitions, media appearances, advertising
  campaigns and marches."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259555Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24860-5
  a curric:KeyLearningPoint ;
  rdfs:label """Greenpeace and the RSPCA show how pressure groups can protect the environment and
  animals and can create lasting change."""@en ;
  dcterms:modified "2026-06-07T15:30:29.259558Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24889-1
  a curric:KeyLearningPoint ;
  rdfs:label """Equality is the quality of treating people the same, or in a way that is right or
  reasonable."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261089Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24889-2
  a curric:KeyLearningPoint ;
  rdfs:label "Equity means giving people what they need to have fair access to opportunities."@en ;
  dcterms:modified "2026-06-07T15:30:29.261093Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24889-3
  a curric:KeyLearningPoint ;
  rdfs:label """Equal oportunity is allowing all people access to the same opportunities, regardless
  of their background or identity."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261099Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24889-4
  a curric:KeyLearningPoint ;
  rdfs:label """Discrimination means treating people unfairly or differently because of their
  characteristics or identity."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261103Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24889-5
  a curric:KeyLearningPoint ;
  rdfs:label """The Equality Act 2010 protects people from inequality by making discrimination
  illegal."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261106Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24885-1
  a curric:KeyLearningPoint ;
  rdfs:label """The UK monarch is the Head of State and the Prime Minister is Head of
  Government."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261860Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24885-2
  a curric:KeyLearningPoint ;
  rdfs:label "The US President is both Head of State and Government."@en ;
  dcterms:modified "2026-06-07T15:30:29.261864Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24885-3
  a curric:KeyLearningPoint ;
  rdfs:label """The UK Parliament has two houses, but only the House of Commons is elected; both
  houses of US Congress are elected."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261867Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24885-4
  a curric:KeyLearningPoint ;
  rdfs:label """The UK Prime Minister is the leader of the largest party in Parliament. The US
  President is elected every four years."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261871Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24885-5
  a curric:KeyLearningPoint ;
  rdfs:label """The UK Parliament is sovereign. In the US, power is split so that no branch holds
  more power than another."""@en ;
  dcterms:modified "2026-06-07T15:30:29.261874Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22524-1
  a curric:KeyLearningPoint ;
  rdfs:label """Globalisation refers to the connection of all the countries in the world through
  cooperation and collaboration."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262117Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22524-2
  a curric:KeyLearningPoint ;
  rdfs:label """Nations work together on key issues such as trade, the economy, technology and
  health which improves life for everyone."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262120Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22524-3
  a curric:KeyLearningPoint ;
  rdfs:label """In times of crises, like natural disasters or pandemics, countries provide mutual
  support, such as developing vaccines."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262124Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22524-4
  a curric:KeyLearningPoint ;
  rdfs:label """Organisations like the United Nations and World Health Organisation exemplify global
  efforts to ensure public safety."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262130Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22524-5
  a curric:KeyLearningPoint ;
  rdfs:label """Global collaboration is essential for sharing resources, ideas, management
  strategies and cultural understanding."""@en ;
  dcterms:modified "2026-06-07T15:30:29.262133Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22512-1
  a curric:KeyLearningPoint ;
  rdfs:label """An active citizen is someone who works towards making a positive change in society
  and in communities."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263092Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22512-2
  a curric:KeyLearningPoint ;
  rdfs:label """Understanding who key decision-makers are makes active citizens more able to bring
  about positive change."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263098Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22512-3
  a curric:KeyLearningPoint ;
  rdfs:label """An active citizen can campaign by raising awareness, writing letters, and more to
  bring about change."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263102Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22512-4
  a curric:KeyLearningPoint ;
  rdfs:label """There are many famous young active citizens such as Greta Thunberg and Xiuhtezcatl
  Martinez."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263107Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22512-5
  a curric:KeyLearningPoint ;
  rdfs:label """We can use the campaigning methods of famous active citizens to inspire us to make
  change within our communities."""@en ;
  dcterms:modified "2026-06-07T15:30:29.263111Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24873-1
  a curric:KeyLearningPoint ;
  rdfs:label """Supporters argue fracking creates jobs, lowers energy prices and reduces reliance on
  imports in uncertain times."""@en ;
  dcterms:modified "2026-06-07T15:30:29.264141Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24873-2
  a curric:KeyLearningPoint ;
  rdfs:label """Some countries have banned fracking due to risks like pollution, earthquakes,
  wildlife disruption and climate impact."""@en ;
  dcterms:modified "2026-06-07T15:30:29.264145Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24873-3
  a curric:KeyLearningPoint ;
  rdfs:label """Alternatives to fracking include renewable energy, nuclear, geothermal, biomass
  energy and improving energy efficiency."""@en ;
  dcterms:modified "2026-06-07T15:30:29.264149Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24873-4
  a curric:KeyLearningPoint ;
  rdfs:label """The UK Government shifted its stance on fracking, halting it in 2019 due to
  environmental risks and earthquakes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.264154Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24842-1
  a curric:KeyLearningPoint ;
  rdfs:label "Democracy allows the people to rule and vote in free and fair elections."@en ;
  dcterms:modified "2026-06-07T15:30:29.264792Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24842-2
  a curric:KeyLearningPoint ;
  rdfs:label """The media has three main roles: setting the agenda, informing and educating, and
  holding people accountable."""@en ;
  dcterms:modified "2026-06-07T15:30:29.264807Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24842-3
  a curric:KeyLearningPoint ;
  rdfs:label """The media encourages public debate, gives everyone a voice and reveals the truth,
  especially during elections."""@en ;
  dcterms:modified "2026-06-07T15:30:29.264815Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24842-4
  a curric:KeyLearningPoint ;
  rdfs:label """By sharing key events and running campaigns, the media raises awareness of important
  issues."""@en ;
  dcterms:modified "2026-06-07T15:30:29.264819Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24842-5
  a curric:KeyLearningPoint ;
  rdfs:label """The media encourages active participation in democracy and keeps us informed about
  what is happening around the world."""@en ;
  dcterms:modified "2026-06-07T15:30:29.264823Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24910-1
  a curric:KeyLearningPoint ;
  rdfs:label """Digital tools, like online petitions/consultations & social media can increase
  access to democratic processes in the UK."""@en ;
  dcterms:modified "2026-06-07T15:30:29.266673Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24910-2
  a curric:KeyLearningPoint ;
  rdfs:label """Other countries have gone further, using it for public decision-making and
  crowdsourced policymaking."""@en ;
  dcterms:modified "2026-06-07T15:30:29.266676Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24910-3
  a curric:KeyLearningPoint ;
  rdfs:label """Digital democracy in Taiwan & Estonia increases participation but faces challenges
  like digital access & security risks."""@en ;
  dcterms:modified "2026-06-07T15:30:29.266682Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24910-4
  a curric:KeyLearningPoint ;
  rdfs:label """There are both opportunities and challenges to adopting digital democracy more
  widely in the UK."""@en ;
  dcterms:modified "2026-06-07T15:30:29.266686Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23739-1
  a curric:KeyLearningPoint ;
  rdfs:label """Local issues are concerns or problems that directly affect a specific community or
  area."""@en ;
  dcterms:modified "2026-06-07T15:30:29.266967Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23739-2
  a curric:KeyLearningPoint ;
  rdfs:label """Campaigning techniques include petitioning, protesting, raising awareness and
  volunteering."""@en ;
  dcterms:modified "2026-06-07T15:30:29.266970Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23739-3
  a curric:KeyLearningPoint ;
  rdfs:label """Young active citizens take action to improve areas by identifying issues, planning,
  working together and evaluating."""@en ;
  dcterms:modified "2026-06-07T15:30:29.266976Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25390-1
  a curric:KeyLearningPoint ;
  rdfs:label """Charities address community needs, focusing on helping people, the environment and
  animals."""@en ;
  dcterms:modified "2026-06-07T15:30:29.267327Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25390-2
  a curric:KeyLearningPoint ;
  rdfs:label """NGOs offer humanitarian aid, support vulnerable groups and advocate for social
  change."""@en ;
  dcterms:modified "2026-06-07T15:30:29.267330Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25390-3
  a curric:KeyLearningPoint ;
  rdfs:label """Community groups, led by volunteers, promote collaboration and provide local
  activities."""@en ;
  dcterms:modified "2026-06-07T15:30:29.267334Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25390-4
  a curric:KeyLearningPoint ;
  rdfs:label """Charities, NGOs and community groups work together to build healthier, safer
  communities."""@en ;
  dcterms:modified "2026-06-07T15:30:29.267340Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24828-1
  a curric:KeyLearningPoint ;
  rdfs:label "The Government has the authority to govern the UK."@en ;
  dcterms:modified "2026-06-07T15:30:29.267966Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24828-2
  a curric:KeyLearningPoint ;
  rdfs:label """It is formed by the political party that wins a majority in the House of Commons and
  is led by the Prime Minister (PM)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.267972Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24828-3
  a curric:KeyLearningPoint ;
  rdfs:label """Parliament is made up of the House of Commons, the House of Lords and the
  monarch."""@en ;
  dcterms:modified "2026-06-07T15:30:29.267977Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24828-4
  a curric:KeyLearningPoint ;
  rdfs:label """The Government runs the country and enforces laws. Parliament debates, makes laws
  and scrutinises the Government."""@en ;
  dcterms:modified "2026-06-07T15:30:29.267980Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24882-1
  a curric:KeyLearningPoint ;
  rdfs:label "The UK Government has three main branches: legislative, executive and judiciary."@en ;
  dcterms:modified "2026-06-07T15:30:29.268334Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24882-2
  a curric:KeyLearningPoint ;
  rdfs:label """The Cabinet is chosen by the PM. It leads government departments and makes key
  decisions on government policies."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268338Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24882-3
  a curric:KeyLearningPoint ;
  rdfs:label """The Civil Service advises ministers, implements government policies and provides
  services to the public."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268341Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24882-4
  a curric:KeyLearningPoint ;
  rdfs:label """Ministers and civil servants both work within government departments, but their job
  roles and responsibilities differ."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268345Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24882-5
  a curric:KeyLearningPoint ;
  rdfs:label """Civil servants are employed after a hiring process, whereas ministers are elected,
  then chosen for particular roles."""@en ;
  dcterms:modified "2026-06-07T15:30:29.268349Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22707-1
  a curric:KeyLearningPoint ;
  rdfs:label """The UNCRC protects children’s rights in 196 countries, setting guidelines to
  safeguard their wellbeing worldwide."""@en ;
  dcterms:modified "2026-06-07T15:30:29.270408Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22707-2
  a curric:KeyLearningPoint ;
  rdfs:label """Advocacy skills like lobbying MPs, petitioning and campaigning can help ensure
  children’s rights are protected."""@en ;
  dcterms:modified "2026-06-07T15:30:29.270412Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22707-3
  a curric:KeyLearningPoint ;
  rdfs:label """Listening to children allows their voices to influence decisions and empowers others
  to protect their rights."""@en ;
  dcterms:modified "2026-06-07T15:30:29.270415Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22707-4
  a curric:KeyLearningPoint ;
  rdfs:label """Active citizenship includes fundraising, social media campaigns and charity auctions
  to support children’s rights."""@en ;
  dcterms:modified "2026-06-07T15:30:29.270419Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22707-5
  a curric:KeyLearningPoint ;
  rdfs:label """Working with changemakers like MPs and councillors is a powerful way to advocate for
  and protect children’s rights."""@en ;
  dcterms:modified "2026-06-07T15:30:29.270422Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25389-1
  a curric:KeyLearningPoint ;
  rdfs:label """Schools are linked to the local community in many ways including celebrating local
  events."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271373Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25389-2
  a curric:KeyLearningPoint ;
  rdfs:label "Local businesses often partner with schools to offer real-life work experience."@en ;
  dcterms:modified "2026-06-07T15:30:29.271377Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25389-3
  a curric:KeyLearningPoint ;
  rdfs:label "Schools play a crucial part in supporting local growth and the economy."@en ;
  dcterms:modified "2026-06-07T15:30:29.271381Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25389-4
  a curric:KeyLearningPoint ;
  rdfs:label """Promoting values like compassion and responsibility in schools helps improve
  community cohesion."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271384Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25389-5
  a curric:KeyLearningPoint ;
  rdfs:label """Pupils can take part in community projects or volunteering to help others in the
  local community."""@en ;
  dcterms:modified "2026-06-07T15:30:29.271388Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22523-1
  a curric:KeyLearningPoint ;
  rdfs:label """Communities are made up of a series of important connections, between people and
  places."""@en ;
  dcterms:modified "2026-06-07T15:30:29.291475Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22523-2
  a curric:KeyLearningPoint ;
  rdfs:label """Family, friends, neighbours and anyone with a shared interest or characteristic are
  connected in some way."""@en ;
  dcterms:modified "2026-06-07T15:30:29.291479Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22523-3
  a curric:KeyLearningPoint ;
  rdfs:label """Communities can use their connections to improve things for people and ensure they
  live in a safe place."""@en ;
  dcterms:modified "2026-06-07T15:30:29.291483Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22523-4
  a curric:KeyLearningPoint ;
  rdfs:label "Communication and interaction is vital for community connections to thrive."@en ;
  dcterms:modified "2026-06-07T15:30:29.291487Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22523-5
  a curric:KeyLearningPoint ;
  rdfs:label """Young people can join the UK Youth Parliament and get involved in trying to change
  things, both locally and nationally."""@en ;
  dcterms:modified "2026-06-07T15:30:29.291491Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22521-1
  a curric:KeyLearningPoint ;
  rdfs:label """There are different types of diverse communities but they often share similar
  interests, values and traditions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.291495Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22521-2
  a curric:KeyLearningPoint ;
  rdfs:label """People work hard to give equal access and opportunities and get rid of intolerance
  to create an inclusive community."""@en ;
  dcterms:modified "2026-06-07T15:30:29.291499Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22521-3
  a curric:KeyLearningPoint ;
  rdfs:label """There are many types of communities including social, neighbourhood and family
  communities."""@en ;
  dcterms:modified "2026-06-07T15:30:29.291503Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22521-4
  a curric:KeyLearningPoint ;
  rdfs:label "Everyone in the world is part of a global community."@en ;
  dcterms:modified "2026-06-07T15:30:29.291507Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27579-1
  a curric:KeyLearningPoint ;
  rdfs:label """An active citizen is someone who takes an active role in their community and society
  to bring about positive change."""@en ;
  dcterms:modified "2026-06-07T15:30:29.292274Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27579-2
  a curric:KeyLearningPoint ;
  rdfs:label """Citizens can bring about positive change using different methods, e.g. petitioning,
  protesting, boycotting and lobbying."""@en ;
  dcterms:modified "2026-06-07T15:30:29.292280Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27579-3
  a curric:KeyLearningPoint ;
  rdfs:label """To make a positive difference, active citizens need skills such as communication,
  teamwork and critical thinking."""@en ;
  dcterms:modified "2026-06-07T15:30:29.292284Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24895-1
  a curric:KeyLearningPoint ;
  rdfs:label """Migration is when people move from one place to another, either within a country or
  across borders."""@en ;
  dcterms:modified "2026-06-07T15:30:29.293543Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24895-2
  a curric:KeyLearningPoint ;
  rdfs:label """People migrate for many reasons, including: work, education, lifestyle, retirement
  or to escape danger."""@en ;
  dcterms:modified "2026-06-07T15:30:29.293546Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24895-3
  a curric:KeyLearningPoint ;
  rdfs:label """Migration often involves big changes to daily life, identity and sense of
  belonging."""@en ;
  dcterms:modified "2026-06-07T15:30:29.293554Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24895-4
  a curric:KeyLearningPoint ;
  rdfs:label """Even planned migration can be long, expensive and involve strict rules and
  paperwork."""@en ;
  dcterms:modified "2026-06-07T15:30:29.293559Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24895-5
  a curric:KeyLearningPoint ;
  rdfs:label """Migrating is a complex process that can offer new opportunities but also involves
  significant challenges."""@en ;
  dcterms:modified "2026-06-07T15:30:29.293563Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24872-1
  a curric:KeyLearningPoint ;
  rdfs:label """Global warming is the process of our planet heating up. Global warming has led to
  climate change."""@en ;
  dcterms:modified "2026-06-07T15:30:29.293587Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24872-2
  a curric:KeyLearningPoint ;
  rdfs:label """There are significant consequences of climate change that impact our global
  environment."""@en ;
  dcterms:modified "2026-06-07T15:30:29.293591Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24872-3
  a curric:KeyLearningPoint ;
  rdfs:label """Activists have campaigned in different ways to highlight the impacts of climate
  change."""@en ;
  dcterms:modified "2026-06-07T15:30:29.293595Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24872-4
  a curric:KeyLearningPoint ;
  rdfs:label """Some sceptics doubt global warming science, but the IPCC says 97% of scientists
  agree humans are mainly causing it."""@en ;
  dcterms:modified "2026-06-07T15:30:29.293601Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29981-1
  a curric:KeyLearningPoint ;
  rdfs:label "Judges and magistrates make decisions fairly without being influenced by others."@en ;
  dcterms:modified "2026-06-07T15:30:29.298787Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29981-2
  a curric:KeyLearningPoint ;
  rdfs:label "Laws are clear, so people know their rights and responsibilities."@en ;
  dcterms:modified "2026-06-07T15:30:29.298792Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29981-3
  a curric:KeyLearningPoint ;
  rdfs:label "People can access help if laws are broken or unfair."@en ;
  dcterms:modified "2026-06-07T15:30:29.298795Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29981-4
  a curric:KeyLearningPoint ;
  rdfs:label "Fair and independent systems help build trust across society."@en ;
  dcterms:modified "2026-06-07T15:30:29.298799Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22706-1
  a curric:KeyLearningPoint ;
  rdfs:label """A child’s right to education is protected by law under the UNCRC without
  discrimination."""@en ;
  dcterms:modified "2026-06-07T15:30:29.300807Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22706-2
  a curric:KeyLearningPoint ;
  rdfs:label """Education gives skills, opportunities, empowerment, equality and boosts mental and
  physical health."""@en ;
  dcterms:modified "2026-06-07T15:30:29.300813Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22706-3
  a curric:KeyLearningPoint ;
  rdfs:label "251 million children worldwide do not have access to their right to education."@en ;
  dcterms:modified "2026-06-07T15:30:29.300817Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22706-4
  a curric:KeyLearningPoint ;
  rdfs:label """Natural disasters, conflict or poor government policies can block access to
  education."""@en ;
  dcterms:modified "2026-06-07T15:30:29.300821Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22706-5
  a curric:KeyLearningPoint ;
  rdfs:label """Malala Yousafzai is a changemaker who advocates for a child’s right to education
  worldwide."""@en ;
  dcterms:modified "2026-06-07T15:30:29.300825Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29980-1
  a curric:KeyLearningPoint ;
  rdfs:label "The rule of law applies to everyone, including those in power."@en ;
  dcterms:modified "2026-06-07T15:30:29.301068Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29980-2
  a curric:KeyLearningPoint ;
  rdfs:label "Everyone is treated equally and fairly by the law, no matter who they are."@en ;
  dcterms:modified "2026-06-07T15:30:29.301075Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29980-3
  a curric:KeyLearningPoint ;
  rdfs:label "Laws must apply equally to everyone."@en ;
  dcterms:modified "2026-06-07T15:30:29.301081Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29980-4
  a curric:KeyLearningPoint ;
  rdfs:label "Following laws helps prevent problems and build people's trust in the system."@en ;
  dcterms:modified "2026-06-07T15:30:29.301086Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29112-1
  a curric:KeyLearningPoint ;
  rdfs:label """A general election in the UK is when MPs are voted for by people in their
  constituency."""@en ;
  dcterms:modified "2026-06-07T15:30:29.303909Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29112-2
  a curric:KeyLearningPoint ;
  rdfs:label """After a general election, the Prime Minister is accepted by the monarch and is
  invited to make a government."""@en ;
  dcterms:modified "2026-06-07T15:30:29.303913Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29112-3
  a curric:KeyLearningPoint ;
  rdfs:label "Governments may be run with a majority, minority or coalition."@en ;
  dcterms:modified "2026-06-07T15:30:29.303917Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22522-1
  a curric:KeyLearningPoint ;
  rdfs:label """Early communities changed dramatically throughout different time periods in history
  for a variety of reasons."""@en ;
  dcterms:modified "2026-06-07T15:30:29.309295Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22522-2
  a curric:KeyLearningPoint ;
  rdfs:label """Politics, the economy and demography are three important reasons why communities
  change."""@en ;
  dcterms:modified "2026-06-07T15:30:29.309300Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22522-3
  a curric:KeyLearningPoint ;
  rdfs:label """Communication has become easier and more efficient with technological advances,
  having a positive impact on communities."""@en ;
  dcterms:modified "2026-06-07T15:30:29.309304Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22522-4
  a curric:KeyLearningPoint ;
  rdfs:label """Migration changes communities because people from different places move to another,
  bringing different traditions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.309307Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22522-5
  a curric:KeyLearningPoint ;
  rdfs:label """Communities will continue to change with the advancement of technology and changes
  in politics, economy and demography."""@en ;
  dcterms:modified "2026-06-07T15:30:29.309311Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24861-1
  a curric:KeyLearningPoint ;
  rdfs:label """Campaigning involves persuading individuals to support a cause or alter their
  behaviour through organised actions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.314817Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24861-2
  a curric:KeyLearningPoint ;
  rdfs:label """The use of social media and online campaigns are a powerful mechanism for raising
  awareness and mobilising support."""@en ;
  dcterms:modified "2026-06-07T15:30:29.314821Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24861-3
  a curric:KeyLearningPoint ;
  rdfs:label """Lobbying targets decision-makers, including MPs and Peers, to advocate for action on
  specific issues."""@en ;
  dcterms:modified "2026-06-07T15:30:29.314827Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24861-4
  a curric:KeyLearningPoint ;
  rdfs:label """Effective lobbying can result in policy changes or localised improvements,
  contributing to societal advancements."""@en ;
  dcterms:modified "2026-06-07T15:30:29.314831Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24861-5
  a curric:KeyLearningPoint ;
  rdfs:label """Campaigning and lobbying are essential democratic rights so individuals can
  influence decisions and promote change."""@en ;
  dcterms:modified "2026-06-07T15:30:29.314836Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24901-1
  a curric:KeyLearningPoint ;
  rdfs:label """Financial responsibility involves making informed decisions about budgeting, saving
  and avoiding debt."""@en ;
  dcterms:modified "2026-06-07T15:30:29.317558Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24901-2
  a curric:KeyLearningPoint ;
  rdfs:label """Various bank accounts serve different purposes, like current for spending and
  savings accounts for storing money."""@en ;
  dcterms:modified "2026-06-07T15:30:29.317562Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24901-3
  a curric:KeyLearningPoint ;
  rdfs:label """Ethical banking focuses on supporting banks that invest in responsbile social and
  environmental causes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.317566Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24901-4
  a curric:KeyLearningPoint ;
  rdfs:label """Learning about responsible money management prepares individuals for future
  financial stability."""@en ;
  dcterms:modified "2026-06-07T15:30:29.317572Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24871-1
  a curric:KeyLearningPoint ;
  rdfs:label """Plastic pollution harms ecosystems, oceans, and wildlife by causing ingestion and
  entanglement."""@en ;
  dcterms:modified "2026-06-07T15:30:29.318321Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24871-2
  a curric:KeyLearningPoint ;
  rdfs:label """It can take thousands of years for plastic to break down and so it accumulates in
  landfills and natural environments."""@en ;
  dcterms:modified "2026-06-07T15:30:29.318325Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24871-3
  a curric:KeyLearningPoint ;
  rdfs:label """The convenience, affordability, and durability of plastic make it difficult to
  replace."""@en ;
  dcterms:modified "2026-06-07T15:30:29.318329Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24871-4
  a curric:KeyLearningPoint ;
  rdfs:label """Strategies to reduce plastic waste include recycling, cutting single-use plastic and
  policy change."""@en ;
  dcterms:modified "2026-06-07T15:30:29.318333Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24892-1
  a curric:KeyLearningPoint ;
  rdfs:label "Laws are official rules that set out what is right and fair and protect people."@en ;
  dcterms:modified "2026-06-07T15:30:29.318339Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24892-2
  a curric:KeyLearningPoint ;
  rdfs:label """Equal opportunities are when everyone is treated fairly and given the same chances
  in life."""@en ;
  dcterms:modified "2026-06-07T15:30:29.318343Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24892-3
  a curric:KeyLearningPoint ;
  rdfs:label """Equality laws in the UK exist today because, in the past, many people were treated
  unfairly."""@en ;
  dcterms:modified "2026-06-07T15:30:29.318347Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24892-4
  a curric:KeyLearningPoint ;
  rdfs:label """Equality laws have developed over time to stop unfair treatment and ensure that
  everyone has the same rights."""@en ;
  dcterms:modified "2026-06-07T15:30:29.318351Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24892-5
  a curric:KeyLearningPoint ;
  rdfs:label """The Equality Act 2010 aims to prevent all forms of discrimination, based on nine
  protected characteristics."""@en ;
  dcterms:modified "2026-06-07T15:30:29.318355Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23735-1
  a curric:KeyLearningPoint ;
  rdfs:label """Local councils provide and manage essential community services, including education,
  health and waste management."""@en ;
  dcterms:modified "2026-06-07T15:30:29.318988Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23735-2
  a curric:KeyLearningPoint ;
  rdfs:label """The local government system is different around the country and works in a tier
  system."""@en ;
  dcterms:modified "2026-06-07T15:30:29.318991Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23735-3
  a curric:KeyLearningPoint ;
  rdfs:label """Local government is funded by grants from central government, council taxes,
  business rates and local service fees."""@en ;
  dcterms:modified "2026-06-07T15:30:29.318998Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23735-4
  a curric:KeyLearningPoint ;
  rdfs:label """Councils only have a certain amount of income and so they have to make difficult
  spending decisions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319002Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22520-1
  a curric:KeyLearningPoint ;
  rdfs:label """Belonging to a group can give you a sense of safety and security and it helps form
  your identity."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319519Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22520-2
  a curric:KeyLearningPoint ;
  rdfs:label """Identities can change over time for many reasons, including personal choice,
  experiences, influences and life events."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319523Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22520-3
  a curric:KeyLearningPoint ;
  rdfs:label """Some parts of our identity are fixed including genes inherited by our parents, e.g.
  eye colour and facial features."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319527Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22520-4
  a curric:KeyLearningPoint ;
  rdfs:label """Countries' identities can also change. The United Kingdom has changed its identity
  many times over the years."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319531Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23736-1
  a curric:KeyLearningPoint ;
  rdfs:label """A local councillor in the UK is an elected representative who helps make decisions
  about local services and policies."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319535Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23736-2
  a curric:KeyLearningPoint ;
  rdfs:label """A local councillor works with their community to address local issues, make
  decisions on local services."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319539Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23736-3
  a curric:KeyLearningPoint ;
  rdfs:label """Local councillors are supported by council officers who have specialist skills
  knowledge in different areas."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319543Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23736-4
  a curric:KeyLearningPoint ;
  rdfs:label """Skills, such as communication, listening, trustworthiness and commitment, are useful
  for local councillors to have."""@en ;
  dcterms:modified "2026-06-07T15:30:29.319547Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22709-1
  a curric:KeyLearningPoint ;
  rdfs:label """Article 17 of the UNCRC makes sure children have the right to accurate and reliable
  information."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322151Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22709-2
  a curric:KeyLearningPoint ;
  rdfs:label """This right says that the Government is responsible for promoting child-friendly
  media and protecting them from harm."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322157Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22709-3
  a curric:KeyLearningPoint ;
  rdfs:label """Reliable information helps people exercise their rights, participate in decisions
  and make informed choices."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322161Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22709-4
  a curric:KeyLearningPoint ;
  rdfs:label """Children accessing media often encounter misinformation, disinformation and
  malinformation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322165Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22709-5
  a curric:KeyLearningPoint ;
  rdfs:label """Evaluating, cross-checking, analysing, using logic and critical thinking skills are
  vital for spotting misinformation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322169Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22708-1
  a curric:KeyLearningPoint ;
  rdfs:label """The right to health is protected by Article 24 of the UNCRC, ensuring access to
  healthcare and health information."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322286Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22708-2
  a curric:KeyLearningPoint ;
  rdfs:label """The UNCRC emphasises the responsibility of high-income countries to help low-income
  nations access health services."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322289Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22708-3
  a curric:KeyLearningPoint ;
  rdfs:label """It promotes healthcare access, reduces inequality, improves public health, boosts
  economies and upholds human dignity."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322293Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22708-4
  a curric:KeyLearningPoint ;
  rdfs:label """The NHS, founded in 1948, transformed the UK’s healthcare system after World War
  Two."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322298Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22708-5
  a curric:KeyLearningPoint ;
  rdfs:label """The NHS offers free healthcare, health information and support for mental and
  physical wellbeing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.322302Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23734-1
  a curric:KeyLearningPoint ;
  rdfs:label """The UK is a democracy which gives citizens the right to vote for people to make
  decisions on their behalf."""@en ;
  dcterms:modified "2026-06-07T15:30:29.323025Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23734-2
  a curric:KeyLearningPoint ;
  rdfs:label """The government is made up of two main branches, local and central, which have
  different roles and responsibilities."""@en ;
  dcterms:modified "2026-06-07T15:30:29.323029Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23734-3
  a curric:KeyLearningPoint ;
  rdfs:label """Central government makes laws and decisions about national issues. It is at the
  centre of decision-making."""@en ;
  dcterms:modified "2026-06-07T15:30:29.323033Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23734-4
  a curric:KeyLearningPoint ;
  rdfs:label """Local governments make decisions regarding how services are carried out in the local
  area."""@en ;
  dcterms:modified "2026-06-07T15:30:29.323037Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23742-1
  a curric:KeyLearningPoint ;
  rdfs:label "The police are one part of the justice system of the UK."@en ;
  dcterms:modified "2026-06-07T15:30:29.326056Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23742-2
  a curric:KeyLearningPoint ;
  rdfs:label """The police protect life and property, maintain order, bring offenders to justice and
  prevent crime."""@en ;
  dcterms:modified "2026-06-07T15:30:29.326060Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23742-3
  a curric:KeyLearningPoint ;
  rdfs:label """The three main police powers to tackle crime are stop and search, arrest and entry,
  search and seizure."""@en ;
  dcterms:modified "2026-06-07T15:30:29.326067Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24890-1
  a curric:KeyLearningPoint ;
  rdfs:label """A stereotype is a simplified idea or belief about a person based on limited aspects
  of their identity."""@en ;
  dcterms:modified "2026-06-07T15:30:29.326071Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24890-2
  a curric:KeyLearningPoint ;
  rdfs:label """When people develop negative feelings based on their stereotypes, this is called
  prejudice."""@en ;
  dcterms:modified "2026-06-07T15:30:29.326075Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24890-3
  a curric:KeyLearningPoint ;
  rdfs:label """When people start treating others less favourably because of their prejudices, this
  is discrimination."""@en ;
  dcterms:modified "2026-06-07T15:30:29.326080Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24890-4
  a curric:KeyLearningPoint ;
  rdfs:label "Discrimination can be direct or indirect."@en ;
  dcterms:modified "2026-06-07T15:30:29.326085Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24890-5
  a curric:KeyLearningPoint ;
  rdfs:label """People who have been discriminated against may also experience victimisation or
  harassment."""@en ;
  dcterms:modified "2026-06-07T15:30:29.326089Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24894-1
  a curric:KeyLearningPoint ;
  rdfs:label "In the UK, laws now exist to prevent inequality and discrimination."@en ;
  dcterms:modified "2026-06-07T15:30:29.326330Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24894-2
  a curric:KeyLearningPoint ;
  rdfs:label """Campaigning and speaking out helped bring about important laws to protect rights and
  promote equality."""@en ;
  dcterms:modified "2026-06-07T15:30:29.326334Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24894-3
  a curric:KeyLearningPoint ;
  rdfs:label """Despite these laws, unfair treatment still occurs, sometimes unintentionally, and
  can have serious effects."""@en ;
  dcterms:modified "2026-06-07T15:30:29.326338Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24894-4
  a curric:KeyLearningPoint ;
  rdfs:label """Cases like Stephen Lawrence’s reveal how discrimination can be built into
  systems."""@en ;
  dcterms:modified "2026-06-07T15:30:29.326342Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24894-5
  a curric:KeyLearningPoint ;
  rdfs:label """Fairness goes beyond laws and policies; it depends on everyday actions by people to
  ensure all are treated with respect."""@en ;
  dcterms:modified "2026-06-07T15:30:29.326346Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24896-1
  a curric:KeyLearningPoint ;
  rdfs:label """Climate change refers to long-term changes in the Earth’s climate system. It is
  mostly caused by human activities."""@en ;
  dcterms:modified "2026-06-07T15:30:29.326350Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24896-2
  a curric:KeyLearningPoint ;
  rdfs:label """These changes can affect human health, food and water supplies, and people’s ability
  to live in certain areas."""@en ;
  dcterms:modified "2026-06-07T15:30:29.326354Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24896-3
  a curric:KeyLearningPoint ;
  rdfs:label """As a result, climate change is becoming a growing push factor for migration, forcing
  people to leave their homes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.326358Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24896-4
  a curric:KeyLearningPoint ;
  rdfs:label """Some people migrate temporarily or permanently within their own country, while
  others cross international borders."""@en ;
  dcterms:modified "2026-06-07T15:30:29.326362Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24896-5
  a curric:KeyLearningPoint ;
  rdfs:label """Climate refugees are not recognised by law. Many face difficulties with migration,
  such as a lack of legal protection."""@en ;
  dcterms:modified "2026-06-07T15:30:29.326366Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24906-1
  a curric:KeyLearningPoint ;
  rdfs:label """Consumers have the right to receive goods and services that are safe, satisfactory
  quality and accurately described."""@en ;
  dcterms:modified "2026-06-07T15:30:29.326584Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24906-2
  a curric:KeyLearningPoint ;
  rdfs:label """The Consumer Rights Act (2015) ensures protection against faulty or misleading
  products."""@en ;
  dcterms:modified "2026-06-07T15:30:29.326588Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24906-3
  a curric:KeyLearningPoint ;
  rdfs:label """Trading Standards enforces these laws by investigating complaints and holding
  businesses accountable."""@en ;
  dcterms:modified "2026-06-07T15:30:29.326592Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24906-4
  a curric:KeyLearningPoint ;
  rdfs:label "If a seller refuses to resolve an issue, legal action can be taken."@en ;
  dcterms:modified "2026-06-07T15:30:29.326596Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24906-5
  a curric:KeyLearningPoint ;
  rdfs:label """Understanding our rights empowers us to be critical consumers who make informed
  choices."""@en ;
  dcterms:modified "2026-06-07T15:30:29.326600Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24891-1
  a curric:KeyLearningPoint ;
  rdfs:label """When people develop negative feelings based on their stereotypes, this is called
  prejudice."""@en ;
  dcterms:modified "2026-06-07T15:30:29.326672Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24891-2
  a curric:KeyLearningPoint ;
  rdfs:label """When people treat others less favourably because of their prejudices, this is
  discrimination."""@en ;
  dcterms:modified "2026-06-07T15:30:29.326676Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24891-3
  a curric:KeyLearningPoint ;
  rdfs:label """Discrimination can have lasting and painful effects, harming a person’s wellbeing
  and opportunities."""@en ;
  dcterms:modified "2026-06-07T15:30:29.326680Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24891-4
  a curric:KeyLearningPoint ;
  rdfs:label """These difficult experiences can also lead to greater awareness and positive change,
  leading to fairer policies."""@en ;
  dcterms:modified "2026-06-07T15:30:29.326686Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25393-1
  a curric:KeyLearningPoint ;
  rdfs:label """Successful campaigning depends on efficient financial skills, making sure funds are
  allocated sensibly to achieve aims."""@en ;
  dcterms:modified "2026-06-07T15:30:29.356037Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25393-2
  a curric:KeyLearningPoint ;
  rdfs:label """Three essential financial skills for campaigning include creating budgets, managing
  risks and reporting finances."""@en ;
  dcterms:modified "2026-06-07T15:30:29.356041Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25393-3
  a curric:KeyLearningPoint ;
  rdfs:label """The last step in the active citizenship process includes evaluating outcomes and
  reporting your campaign."""@en ;
  dcterms:modified "2026-06-07T15:30:29.356047Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25393-4
  a curric:KeyLearningPoint ;
  rdfs:label """Advocating and speaking about campaigning helps raise awareness and inspire
  action."""@en ;
  dcterms:modified "2026-06-07T15:30:29.356054Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25388-1
  a curric:KeyLearningPoint ;
  rdfs:label """Community cohesion is when communities work together to achieve shared goals or
  values."""@en ;
  dcterms:modified "2026-06-07T15:30:29.362120Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25388-2
  a curric:KeyLearningPoint ;
  rdfs:label """Community cohesion allows everyone, despite their differences, to have equal
  opportunities in life."""@en ;
  dcterms:modified "2026-06-07T15:30:29.362124Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25388-3
  a curric:KeyLearningPoint ;
  rdfs:label """To support community cohesion, neighbours need lots of different skills and
  qualities."""@en ;
  dcterms:modified "2026-06-07T15:30:29.362128Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25388-4
  a curric:KeyLearningPoint ;
  rdfs:label """If people in communities come together and work together, lasting change will occur
  as a result."""@en ;
  dcterms:modified "2026-06-07T15:30:29.362132Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24833-1
  a curric:KeyLearningPoint ;
  rdfs:label """Devolution is the transfer of political powers from a central government to regional
  government."""@en ;
  dcterms:modified "2026-06-07T15:30:29.365311Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24833-2
  a curric:KeyLearningPoint ;
  rdfs:label """Devolved powers are issues or matters on which the devolved government or regional
  areas can decide."""@en ;
  dcterms:modified "2026-06-07T15:30:29.365315Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24833-3
  a curric:KeyLearningPoint ;
  rdfs:label "Reserved powers are issues or matters on which the UK Government can decide."@en ;
  dcterms:modified "2026-06-07T15:30:29.365319Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24833-4
  a curric:KeyLearningPoint ;
  rdfs:label """Devolved governments have authority on issues affecting their regions, such as
  health, education and transport."""@en ;
  dcterms:modified "2026-06-07T15:30:29.365323Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24833-5
  a curric:KeyLearningPoint ;
  rdfs:label """Devolution has pros and cons, for example, giving control, but may contribute to
  confusion or inequality."""@en ;
  dcterms:modified "2026-06-07T15:30:29.365327Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24853-1
  a curric:KeyLearningPoint ;
  rdfs:label """In England, Wales and Northern Ireland, the age of criminal responsibility is ten
  and has remained the same since 1963."""@en ;
  dcterms:modified "2026-06-07T15:30:29.366913Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24853-2
  a curric:KeyLearningPoint ;
  rdfs:label """Some think the age of criminal responsibility should be raised, while others argue
  it should stay the same."""@en ;
  dcterms:modified "2026-06-07T15:30:29.366917Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24853-3
  a curric:KeyLearningPoint ;
  rdfs:label """In a deliberative discussion, we consider different viewpoints and can use the REAL
  model to structure our arguments."""@en ;
  dcterms:modified "2026-06-07T15:30:29.366921Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24867-1
  a curric:KeyLearningPoint ;
  rdfs:label """The National Union of Women’s Suffrage Societies (NUWSS), set up by Millicent
  Fawcett, became known as the Suffragists."""@en ;
  dcterms:modified "2026-06-07T15:30:29.372477Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24867-2
  a curric:KeyLearningPoint ;
  rdfs:label """The Suffragists aimed to gain women's suffrage by consistently pressuring the
  Government through peaceful campaigning."""@en ;
  dcterms:modified "2026-06-07T15:30:29.372481Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24867-3
  a curric:KeyLearningPoint ;
  rdfs:label """The Women's Social and Political Union (WSPU) was set up in 1903 and became known as
  the Suffragettes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.372485Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24867-4
  a curric:KeyLearningPoint ;
  rdfs:label "The Suffragettes used more militant methods in their campaigns."@en ;
  dcterms:modified "2026-06-07T15:30:29.372489Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24867-5
  a curric:KeyLearningPoint ;
  rdfs:label """Today, women have the same voting rights as men. However, women are not equally
  represented in Parliament/Government."""@en ;
  dcterms:modified "2026-06-07T15:30:29.372493Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25392-1
  a curric:KeyLearningPoint ;
  rdfs:label """Active citizenship involves key skills such as advocacy, collaboration and political
  literacy."""@en ;
  dcterms:modified "2026-06-07T15:30:29.378581Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25392-2
  a curric:KeyLearningPoint ;
  rdfs:label """Engaging in democracy and contributing to lasting change are essential aspects of
  being an active citizen."""@en ;
  dcterms:modified "2026-06-07T15:30:29.378586Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25392-3
  a curric:KeyLearningPoint ;
  rdfs:label """Active citizens identify community issues, seek help from relevant resources and
  decide effective actions for campaigns."""@en ;
  dcterms:modified "2026-06-07T15:30:29.378592Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25392-4
  a curric:KeyLearningPoint ;
  rdfs:label """Planning and measuring the success of a campaign are crucial steps in creating a
  positive impact on the community."""@en ;
  dcterms:modified "2026-06-07T15:30:29.378596Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25392-5
  a curric:KeyLearningPoint ;
  rdfs:label """Active citizenship does not have to be too hard if you work collaboratively to
  divide the work between group members."""@en ;
  dcterms:modified "2026-06-07T15:30:29.378600Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22705-1
  a curric:KeyLearningPoint ;
  rdfs:label """Rights are guaranteed by law and ensure that every individual is entitled to
  them."""@en ;
  dcterms:modified "2026-06-07T15:30:29.396781Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22705-2
  a curric:KeyLearningPoint ;
  rdfs:label """Rights are universal, designed to provide everyone with a healthy, safe and happy
  life, regardless of background."""@en ;
  dcterms:modified "2026-06-07T15:30:29.396785Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22705-3
  a curric:KeyLearningPoint ;
  rdfs:label """The United Nations Convention on the Rights of the Child (UNCRC) outlines 54
  specific rights for children."""@en ;
  dcterms:modified "2026-06-07T15:30:29.396789Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22705-4
  a curric:KeyLearningPoint ;
  rdfs:label """The UNCRC can be summarised into four principles including: non-discrimination and
  the best interests of the child."""@en ;
  dcterms:modified "2026-06-07T15:30:29.396793Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22705-5
  a curric:KeyLearningPoint ;
  rdfs:label """This agreement, signed by 196 countries, emphasises the importance of supporting and
  protecting children’s rights."""@en ;
  dcterms:modified "2026-06-07T15:30:29.396797Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24874-1
  a curric:KeyLearningPoint ;
  rdfs:label """There are several important documents which set out our human rights, including the
  UDHR, ECHR & the Human Rights Act."""@en ;
  dcterms:modified "2026-06-07T15:30:29.396812Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24874-2
  a curric:KeyLearningPoint ;
  rdfs:label """All public authorities, such as the Government, the NHS, schools and the police,
  must follow the Human Rights Act."""@en ;
  dcterms:modified "2026-06-07T15:30:29.396818Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24874-3
  a curric:KeyLearningPoint ;
  rdfs:label "Human rights is a global issue, with some countries still abusing rights today."@en ;
  dcterms:modified "2026-06-07T15:30:29.396822Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24874-4
  a curric:KeyLearningPoint ;
  rdfs:label """Protecting human rights is a global responsibility, addressed by the organisations
  such as the UN and NGOs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.396826Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23737-1
  a curric:KeyLearningPoint ;
  rdfs:label """A political party is an organised group of people who share similar beliefs and
  goals about how society should be run."""@en ;
  dcterms:modified "2026-06-07T15:30:29.404815Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23737-2
  a curric:KeyLearningPoint ;
  rdfs:label """A local election is a formal process for voters to choose people to represent their
  views on the council."""@en ;
  dcterms:modified "2026-06-07T15:30:29.404819Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23737-3
  a curric:KeyLearningPoint ;
  rdfs:label """Candidates run campaigns to tell local residents about their policies and ideas for
  the local area."""@en ;
  dcterms:modified "2026-06-07T15:30:29.404823Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24851-1
  a curric:KeyLearningPoint ;
  rdfs:label """Most laws in England are made by Parliament. Parliament is also known as the
  legislature."""@en ;
  dcterms:modified "2026-06-07T15:30:29.422347Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24851-2
  a curric:KeyLearningPoint ;
  rdfs:label """A proposal for a new law is called a Bill. A Bill must pass through many stages
  before it can become a law."""@en ;
  dcterms:modified "2026-06-07T15:30:29.422351Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24851-3
  a curric:KeyLearningPoint ;
  rdfs:label "There are two main categories of law in England: criminal and civil."@en ;
  dcterms:modified "2026-06-07T15:30:29.422357Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23741-1
  a curric:KeyLearningPoint ;
  rdfs:label """If a citizen breaks the rules in an Act of Parliament, they commit a crime, which is
  an illegal act punishable by law."""@en ;
  dcterms:modified "2026-06-07T15:30:29.423691Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23741-2
  a curric:KeyLearningPoint ;
  rdfs:label """Anyone can potentially be a criminal. It is the circumstances around them that may
  influence them and their choices."""@en ;
  dcterms:modified "2026-06-07T15:30:29.423695Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23741-3
  a curric:KeyLearningPoint ;
  rdfs:label """There are three main factors that impact criminal behaviour: social, environmental
  and psychological."""@en ;
  dcterms:modified "2026-06-07T15:30:29.423699Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24840-1
  a curric:KeyLearningPoint ;
  rdfs:label """Media has three main types: print media, such as newspapers; broadcast media like TV
  and new media, like social media."""@en ;
  dcterms:modified "2026-06-07T15:30:29.429854Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24840-2
  a curric:KeyLearningPoint ;
  rdfs:label """To be considered reliable news, information must follow the VIA model -
  Verification, Independence, Accountability."""@en ;
  dcterms:modified "2026-06-07T15:30:29.429858Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24840-3
  a curric:KeyLearningPoint ;
  rdfs:label """News values guide journalists in selecting stories which are interesting, for
  example timelessness, oddity and impact."""@en ;
  dcterms:modified "2026-06-07T15:30:29.429862Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24840-4
  a curric:KeyLearningPoint ;
  rdfs:label """It's important to know the information neighbourhood you are in. These include
  categories like news and propaganda."""@en ;
  dcterms:modified "2026-06-07T15:30:29.429866Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24840-5
  a curric:KeyLearningPoint ;
  rdfs:label """Understanding these different sources of media and information neighbourhoods helps
  you know the purpose of the media."""@en ;
  dcterms:modified "2026-06-07T15:30:29.429870Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24841-1
  a curric:KeyLearningPoint ;
  rdfs:label """We expect the media to be accurate, verify facts and act independently without
  personal benefit, in the public interest."""@en ;
  dcterms:modified "2026-06-07T15:30:29.431417Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24841-2
  a curric:KeyLearningPoint ;
  rdfs:label """Journalists take responsibility for their work, put their name to it, and aim to
  inform and explain important issues."""@en ;
  dcterms:modified "2026-06-07T15:30:29.431421Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24841-3
  a curric:KeyLearningPoint ;
  rdfs:label """The media must follow the law and the rules in the NUJ Code of Conduct and Editors'
  Code of Practice."""@en ;
  dcterms:modified "2026-06-07T15:30:29.431425Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24841-4
  a curric:KeyLearningPoint ;
  rdfs:label """The media are responsible for respecting privacy, providing truthful, accurate
  information and avoiding discrimination."""@en ;
  dcterms:modified "2026-06-07T15:30:29.431430Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24841-5
  a curric:KeyLearningPoint ;
  rdfs:label """If the media break these rules, IPSO or OFCOM can investigate, leading to legal
  action, mistrust or other consequences."""@en ;
  dcterms:modified "2026-06-07T15:30:29.431436Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24845-1
  a curric:KeyLearningPoint ;
  rdfs:label """The media can both positively and negatively influence public opinion, depending on
  how it is used."""@en ;
  dcterms:modified "2026-06-07T15:30:29.432155Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24845-2
  a curric:KeyLearningPoint ;
  rdfs:label """Tools like the EVALUATE acronym help us critically assess arguments for and against
  various perspectives."""@en ;
  dcterms:modified "2026-06-07T15:30:29.432159Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24845-3
  a curric:KeyLearningPoint ;
  rdfs:label """Carefully reviewing evidence and reasoning on both sides of an issue is essential
  for forming well-rounded opinions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.432163Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24845-4
  a curric:KeyLearningPoint ;
  rdfs:label """Media plays a vital informing role, but evaluating sources is crucial to identifying
  and avoiding disinformation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.432169Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24845-5
  a curric:KeyLearningPoint ;
  rdfs:label """Ensuring the media we consume is reliable and accurate helps maximise its benefits
  while minimising potential harm."""@en ;
  dcterms:modified "2026-06-07T15:30:29.432176Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24854-1
  a curric:KeyLearningPoint ;
  rdfs:label """Young people have additional rights when arrested, like having an appropriate adult
  present during questioning."""@en ;
  dcterms:modified "2026-06-07T15:30:29.432180Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24854-2
  a curric:KeyLearningPoint ;
  rdfs:label """Youth courts handle cases for 10-17-year-olds; focusing on protection &
  rehabilitation. They have different procedures."""@en ;
  dcterms:modified "2026-06-07T15:30:29.432184Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24854-3
  a curric:KeyLearningPoint ;
  rdfs:label """When sentencing, youth courts focus on preventing reoffending and prioritising the
  young person’s wellbeing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.432189Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24918-1
  a curric:KeyLearningPoint ;
  rdfs:label """Local councils are responsible for services that affect daily life, like education,
  transport and housing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.433952Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24918-2
  a curric:KeyLearningPoint ;
  rdfs:label """In all parts of the UK, individuals must be 18 or over to stand as a local
  councillor."""@en ;
  dcterms:modified "2026-06-07T15:30:29.433956Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24918-3
  a curric:KeyLearningPoint ;
  rdfs:label """16 and 17 year olds can vote in local elections in Scotland and Wales, but they are
  not allowed to stand for election."""@en ;
  dcterms:modified "2026-06-07T15:30:29.433960Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24918-4
  a curric:KeyLearningPoint ;
  rdfs:label """To be a councillor, a person must live, work, own or rent property or be registered
  to vote in the area for 12 months."""@en ;
  dcterms:modified "2026-06-07T15:30:29.433964Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24918-5
  a curric:KeyLearningPoint ;
  rdfs:label """Youth Councils enable young people to express their views but do not hold legal
  decision-making power."""@en ;
  dcterms:modified "2026-06-07T15:30:29.433968Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24884-1
  a curric:KeyLearningPoint ;
  rdfs:label "The UK is a representative democracy."@en ;
  dcterms:modified "2026-06-07T15:30:29.584740Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24884-2
  a curric:KeyLearningPoint ;
  rdfs:label """Democracies give citizens many freedoms, which have often developed over
  many years."""@en ;
  dcterms:modified "2026-06-07T15:30:29.584745Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24884-3
  a curric:KeyLearningPoint ;
  rdfs:label """The government is made of three parts: Parliament (legislative), government
  (executive) and judiciary (judicial)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.584749Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24884-4
  a curric:KeyLearningPoint ;
  rdfs:label """The main categories of political systems are: full democracy, flawed democracy,
  hybrid regime and authoritarian regime."""@en ;
  dcterms:modified "2026-06-07T15:30:29.584757Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24900-1
  a curric:KeyLearningPoint ;
  rdfs:label """Migration affects both the communities people leave and the communities they move
  to."""@en ;
  dcterms:modified "2026-06-07T15:30:29.587764Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24900-2
  a curric:KeyLearningPoint ;
  rdfs:label """Migrants may fill workforce gaps, start businesses and introduce new cultures,
  languages and ideas that enrich society."""@en ;
  dcterms:modified "2026-06-07T15:30:29.587769Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24900-3
  a curric:KeyLearningPoint ;
  rdfs:label """They may need extra support with housing, language or education, and some
  communities might experience tension."""@en ;
  dcterms:modified "2026-06-07T15:30:29.587774Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24900-4
  a curric:KeyLearningPoint ;
  rdfs:label """Migration may bring benefits like remittances or migrants may return with
  skills/experience that help communities grow."""@en ;
  dcterms:modified "2026-06-07T15:30:29.587778Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24900-5
  a curric:KeyLearningPoint ;
  rdfs:label """There are many challenges, including the loss of skilled workers and emotional
  strain from long-term family separation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.587783Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22507-1
  a curric:KeyLearningPoint ;
  rdfs:label """Citizenship covers concepts such as the law, democracy, the economy, identities,
  communities and rights."""@en ;
  dcterms:modified "2026-06-07T15:30:29.587787Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22507-2
  a curric:KeyLearningPoint ;
  rdfs:label """There are many ways to make social change happen like volunteering, pressure groups
  and lobbying."""@en ;
  dcterms:modified "2026-06-07T15:30:29.587792Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22507-3
  a curric:KeyLearningPoint ;
  rdfs:label "Statistics help me understand society and social change."@en ;
  dcterms:modified "2026-06-07T15:30:29.587796Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24904-1
  a curric:KeyLearningPoint ;
  rdfs:label """Fraud is deception for financial gain, often through scams that steal money or
  personal information."""@en ;
  dcterms:modified "2026-06-07T15:30:29.594253Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24904-2
  a curric:KeyLearningPoint ;
  rdfs:label """Awareness of phishing, pharming, APP fraud and cryptocurrency fraud help protect
  financial security."""@en ;
  dcterms:modified "2026-06-07T15:30:29.594257Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24904-3
  a curric:KeyLearningPoint ;
  rdfs:label "Action Fraud and banks have teams to investigate fraud and support victims."@en ;
  dcterms:modified "2026-06-07T15:30:29.594263Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24904-4
  a curric:KeyLearningPoint ;
  rdfs:label """Government campaigns like 'Stop! Think Fraud' educate the public on fraud
  prevention."""@en ;
  dcterms:modified "2026-06-07T15:30:29.594270Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24904-5
  a curric:KeyLearningPoint ;
  rdfs:label """Avoiding suspicious links, verifying payment sites and protecting financial details
  help prevent fraud."""@en ;
  dcterms:modified "2026-06-07T15:30:29.594274Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24865-1
  a curric:KeyLearningPoint ;
  rdfs:label "Political rights are the rights people have and may use in a democracy."@en ;
  dcterms:modified "2026-06-07T15:30:29.596956Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24865-2
  a curric:KeyLearningPoint ;
  rdfs:label "The fight for political rights in the UK has been a long one."@en ;
  dcterms:modified "2026-06-07T15:30:29.596960Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24865-3
  a curric:KeyLearningPoint ;
  rdfs:label "One of the biggest changes has been in relation to suffrage."@en ;
  dcterms:modified "2026-06-07T15:30:29.596964Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24830-1
  a curric:KeyLearningPoint ;
  rdfs:label """A political party is an organised group of people who share similar beliefs and
  goals about how society should be run."""@en ;
  dcterms:modified "2026-06-07T15:30:29.601601Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24830-2
  a curric:KeyLearningPoint ;
  rdfs:label """Political party policies align with their values. This influences what their
  manifesto is."""@en ;
  dcterms:modified "2026-06-07T15:30:29.601605Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24830-3
  a curric:KeyLearningPoint ;
  rdfs:label """There are many UK political parties to ensure that different ideas are represented
  and that every voice can be heard."""@en ;
  dcterms:modified "2026-06-07T15:30:29.601609Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24830-4
  a curric:KeyLearningPoint ;
  rdfs:label """The political spectrum shows where parties stand on political issues, from left wing
  to right wing."""@en ;
  dcterms:modified "2026-06-07T15:30:29.601613Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24866-1
  a curric:KeyLearningPoint ;
  rdfs:label """The Chartists were a group of men and women who campaigned to improve political
  rights in the UK."""@en ;
  dcterms:modified "2026-06-07T15:30:29.604508Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24866-2
  a curric:KeyLearningPoint ;
  rdfs:label "They had six demands written down on a charter."@en ;
  dcterms:modified "2026-06-07T15:30:29.604513Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24866-3
  a curric:KeyLearningPoint ;
  rdfs:label "They campaigned through different methods, such as petitions and protests."@en ;
  dcterms:modified "2026-06-07T15:30:29.604517Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24866-4
  a curric:KeyLearningPoint ;
  rdfs:label "They had a mixed impact on political rights."@en ;
  dcterms:modified "2026-06-07T15:30:29.604521Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24829-1
  a curric:KeyLearningPoint ;
  rdfs:label """A general election is a formal process for the electorate to choose their
  representatives (MPs) in the House of Commons."""@en ;
  dcterms:modified "2026-06-07T15:30:29.604875Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24829-2
  a curric:KeyLearningPoint ;
  rdfs:label """Each general election process is the same, starting with the dissolution of
  Parliament."""@en ;
  dcterms:modified "2026-06-07T15:30:29.604879Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22511-1
  a curric:KeyLearningPoint ;
  rdfs:label """A community is a group of people living or existing together sharing common values,
  interests and ways of doing things."""@en ;
  dcterms:modified "2026-06-07T15:30:29.606162Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22511-2
  a curric:KeyLearningPoint ;
  rdfs:label """In a democracy you have more rights and you can influence decision-makers and those
  in power."""@en ;
  dcterms:modified "2026-06-07T15:30:29.606166Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22511-3
  a curric:KeyLearningPoint ;
  rdfs:label """Democracies have key features such as free and fair elections and protected human
  rights."""@en ;
  dcterms:modified "2026-06-07T15:30:29.606170Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24859-1
  a curric:KeyLearningPoint ;
  rdfs:label """The UK is a representative democracy where citizens can influence the country's
  decisions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.606881Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24859-2
  a curric:KeyLearningPoint ;
  rdfs:label """Article 21 of the UDHR guarantees citizens the right to participate in politics
  through choosing their representatives."""@en ;
  dcterms:modified "2026-06-07T15:30:29.606885Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24859-3
  a curric:KeyLearningPoint ;
  rdfs:label """Citizens can take action in a democracy through voting, social media, petitions,
  lobbying, demonstrations and boycotts."""@en ;
  dcterms:modified "2026-06-07T15:30:29.606889Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24859-4
  a curric:KeyLearningPoint ;
  rdfs:label """Successful campaigns use effective methods like a clear message and public
  support."""@en ;
  dcterms:modified "2026-06-07T15:30:29.606896Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24859-5
  a curric:KeyLearningPoint ;
  rdfs:label """Effective actions also require support from those in power, financial backing and
  determination to succeed."""@en ;
  dcterms:modified "2026-06-07T15:30:29.606901Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24886-1
  a curric:KeyLearningPoint ;
  rdfs:label """Direct democracy is where citizens decide on policy directly, for example, through a
  referendum on each issue."""@en ;
  dcterms:modified "2026-06-07T15:30:29.606905Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24886-2
  a curric:KeyLearningPoint ;
  rdfs:label """Representative democracy is where citizens choose others to represent them to make
  important decisions on their behalf."""@en ;
  dcterms:modified "2026-06-07T15:30:29.606909Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24886-3
  a curric:KeyLearningPoint ;
  rdfs:label """Some countries may not be a full direct democracy but may use elements of this
  system, e.g., by holding referendums."""@en ;
  dcterms:modified "2026-06-07T15:30:29.606913Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24870-1
  a curric:KeyLearningPoint ;
  rdfs:label """Democratic rights are fundamental freedoms and entitlements needed to sustain
  political democracy."""@en ;
  dcterms:modified "2026-06-07T15:30:29.607878Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24870-2
  a curric:KeyLearningPoint ;
  rdfs:label """There are several ways you can exercise your democratic rights, even if you cannot
  vote."""@en ;
  dcterms:modified "2026-06-07T15:30:29.607882Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24908-1
  a curric:KeyLearningPoint ;
  rdfs:label """Voting is essential in democracy, giving citizens a voice in decisions and holding
  leaders accountable."""@en ;
  dcterms:modified "2026-06-07T15:30:29.608158Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24908-2
  a curric:KeyLearningPoint ;
  rdfs:label """High voter turnout leads to more representative outcomes, strengthening the
  legitimacy of governments."""@en ;
  dcterms:modified "2026-06-07T15:30:29.608162Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24908-3
  a curric:KeyLearningPoint ;
  rdfs:label """Digital democracy could improve voter engagement by making political information and
  participation more accessible."""@en ;
  dcterms:modified "2026-06-07T15:30:29.608166Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24908-4
  a curric:KeyLearningPoint ;
  rdfs:label """Digital tools connect voters with politicians and provide opportunities for
  political education and feedback."""@en ;
  dcterms:modified "2026-06-07T15:30:29.608173Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24855-1
  a curric:KeyLearningPoint ;
  rdfs:label """As we age, our understanding of right and wrong evolves from following rules to
  considering the impact of our actions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.609048Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24855-2
  a curric:KeyLearningPoint ;
  rdfs:label """Everyone must follow the law, but in England, Wales and Northern Ireland, the age of
  criminal responsibility is 10."""@en ;
  dcterms:modified "2026-06-07T15:30:29.609052Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24855-3
  a curric:KeyLearningPoint ;
  rdfs:label """It has been 10 since 1963, with changes in 1998 which removed protections for those
  aged 10-14."""@en ;
  dcterms:modified "2026-06-07T15:30:29.609056Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24855-4
  a curric:KeyLearningPoint ;
  rdfs:label """The age of criminal responsibility is different around the world, for example, in
  Cuba it is 16 and in Grenada it is 7."""@en ;
  dcterms:modified "2026-06-07T15:30:29.609062Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24850-1
  a curric:KeyLearningPoint ;
  rdfs:label "Laws are rules everyone must obey. In the UK, laws are created by Parliament."@en ;
  dcterms:modified "2026-06-07T15:30:29.611847Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24850-2
  a curric:KeyLearningPoint ;
  rdfs:label "The law is there to protect us and our rights."@en ;
  dcterms:modified "2026-06-07T15:30:29.611854Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24850-3
  a curric:KeyLearningPoint ;
  rdfs:label "Legal age is the age you can do something as defined by the law."@en ;
  dcterms:modified "2026-06-07T15:30:29.611858Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24850-4
  a curric:KeyLearningPoint ;
  rdfs:label """The age of criminal responsibility is the age you are held legally responsible for
  your actions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.611862Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24850-5
  a curric:KeyLearningPoint ;
  rdfs:label """Most citizens obey the law but some will break it. There are consequences for
  breaking the law which are set out in law."""@en ;
  dcterms:modified "2026-06-07T15:30:29.611866Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23745-1
  a curric:KeyLearningPoint ;
  rdfs:label """There are different types of crime prevention strategy, e.g. educational,
  situational and deterents."""@en ;
  dcterms:modified "2026-06-07T15:30:29.612803Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23745-2
  a curric:KeyLearningPoint ;
  rdfs:label """A successful crime prevention strategy should have a clear aim, be well planned,
  well implemented and clearly measured."""@en ;
  dcterms:modified "2026-06-07T15:30:29.612812Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23745-3
  a curric:KeyLearningPoint ;
  rdfs:label """The Ben Kinsella Trust is an example of an organisation who have run a successful
  crime prevention strategy."""@en ;
  dcterms:modified "2026-06-07T15:30:29.612816Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24869-1
  a curric:KeyLearningPoint ;
  rdfs:label """You can vote in elections if you meet the eligibility criteria including age,
  citizenship, and residency."""@en ;
  dcterms:modified "2026-06-07T15:30:29.613311Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24869-2
  a curric:KeyLearningPoint ;
  rdfs:label "You cannot vote in a general election until you are 18."@en ;
  dcterms:modified "2026-06-07T15:30:29.613315Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24869-3
  a curric:KeyLearningPoint ;
  rdfs:label """There are certain things you can do at 16, for example, apply for a passport or open
  a bank account."""@en ;
  dcterms:modified "2026-06-07T15:30:29.613319Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24869-4
  a curric:KeyLearningPoint ;
  rdfs:label """There are other things you have to be 18 to do, for example, get a tattoo or get
  married."""@en ;
  dcterms:modified "2026-06-07T15:30:29.613323Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24869-5
  a curric:KeyLearningPoint ;
  rdfs:label """The discussion on lowering the voting age to 16 is complex and can be divisive with
  strong arguments on both sides."""@en ;
  dcterms:modified "2026-06-07T15:30:29.613327Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25391-1
  a curric:KeyLearningPoint ;
  rdfs:label """Changemakers work at local, national and global levels to solve problems and create
  positive change in communities."""@en ;
  dcterms:modified "2026-06-07T15:30:29.613561Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25391-2
  a curric:KeyLearningPoint ;
  rdfs:label """Examples of changemakers include volunteers, community leaders, campaigners,
  politicians, scientists and charities."""@en ;
  dcterms:modified "2026-06-07T15:30:29.613565Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25391-3
  a curric:KeyLearningPoint ;
  rdfs:label """Citizens can participate in decision-making by voting, joining councils or engaging
  in activities like protests."""@en ;
  dcterms:modified "2026-06-07T15:30:29.613569Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25391-4
  a curric:KeyLearningPoint ;
  rdfs:label """Young people can drive change by volunteering, raising awareness, organising events
  and using social media effectively."""@en ;
  dcterms:modified "2026-06-07T15:30:29.613574Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25391-5
  a curric:KeyLearningPoint ;
  rdfs:label """Active citizenship helps people to become changemakers and influence decisions in
  their communities."""@en ;
  dcterms:modified "2026-06-07T15:30:29.613578Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24876-1
  a curric:KeyLearningPoint ;
  rdfs:label """Being an active citizen means engaging in democracy and making a positive impact
  through responsible action."""@en ;
  dcterms:modified "2026-06-07T15:30:29.616225Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24876-2
  a curric:KeyLearningPoint ;
  rdfs:label """Changemakers, global organisations and NGOs can all take responsible action to
  tackle global problems."""@en ;
  dcterms:modified "2026-06-07T15:30:29.616230Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24876-3
  a curric:KeyLearningPoint ;
  rdfs:label """There are lots of examples of actions we can take to tackle global problems,
  individually or through collective action."""@en ;
  dcterms:modified "2026-06-07T15:30:29.616234Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24876-4
  a curric:KeyLearningPoint ;
  rdfs:label """Examples of actions include peacful protests, petitioning, boycotting, educating
  yourself and rasising awarness."""@en ;
  dcterms:modified "2026-06-07T15:30:29.616238Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24864-1
  a curric:KeyLearningPoint ;
  rdfs:label """Effective change addresses root causes, is strategically planned, sustainable and
  has a lasting impact."""@en ;
  dcterms:modified "2026-06-07T15:30:29.616740Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24864-2
  a curric:KeyLearningPoint ;
  rdfs:label """It enhances quality of life and strengthens communities by tackling critical issues
  and delivering meaningful outcomes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.616745Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24864-3
  a curric:KeyLearningPoint ;
  rdfs:label """The women's suffrage movement exemplified effective change by creating a more
  equitable society."""@en ;
  dcterms:modified "2026-06-07T15:30:29.616749Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24864-4
  a curric:KeyLearningPoint ;
  rdfs:label "Community policing shows how effective change can build trust and reduce crime."@en ;
  dcterms:modified "2026-06-07T15:30:29.616753Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24864-5
  a curric:KeyLearningPoint ;
  rdfs:label """Housing improvements, such as safer homes, demonstrate how effective change can
  address social inequalities."""@en ;
  dcterms:modified "2026-06-07T15:30:29.616757Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24843-1
  a curric:KeyLearningPoint ;
  rdfs:label """Holding people to account ensures those in power are responsible for their actions
  and decisions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.617898Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24843-2
  a curric:KeyLearningPoint ;
  rdfs:label """The media holds leaders accountable through interviews, the design of front pages
  and investigative journalism."""@en ;
  dcterms:modified "2026-06-07T15:30:29.617902Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24843-3
  a curric:KeyLearningPoint ;
  rdfs:label """In a democracy, leaders must act fairly and deliver on their promises; it is the
  media's role to hold them to account."""@en ;
  dcterms:modified "2026-06-07T15:30:29.617906Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24843-4
  a curric:KeyLearningPoint ;
  rdfs:label """Media accountability prevents power misuse and reminds leaders that they serve the
  public."""@en ;
  dcterms:modified "2026-06-07T15:30:29.617910Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24914-1
  a curric:KeyLearningPoint ;
  rdfs:label """Local democracy refers to the participation of citizens in decision-making at a
  community level."""@en ;
  dcterms:modified "2026-06-07T15:30:29.618731Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24914-2
  a curric:KeyLearningPoint ;
  rdfs:label """Young people can engage through democratic processes such as consultations,
  campaigning and meetings with councillors."""@en ;
  dcterms:modified "2026-06-07T15:30:29.618735Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24914-3
  a curric:KeyLearningPoint ;
  rdfs:label """Youth Councils are formal bodies led by young people to represent youth perspectives
  in local governance."""@en ;
  dcterms:modified "2026-06-07T15:30:29.618740Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24914-4
  a curric:KeyLearningPoint ;
  rdfs:label """Participation in Youth Councils encourages civic responsibility, political literacy
  and leadership development."""@en ;
  dcterms:modified "2026-06-07T15:30:29.618746Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22710-1
  a curric:KeyLearningPoint ;
  rdfs:label """Laws like the Children’s Act 1989 and international agreements like the UNCRC
  support and protect children’s rights."""@en ;
  dcterms:modified "2026-06-07T15:30:29.618750Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22710-2
  a curric:KeyLearningPoint ;
  rdfs:label "Organisations like the NSPCC work to protect children from harm."@en ;
  dcterms:modified "2026-06-07T15:30:29.618755Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22710-3
  a curric:KeyLearningPoint ;
  rdfs:label """Charities like Save the Children and UNICEF UK support vulnerable children and
  improve their lives."""@en ;
  dcterms:modified "2026-06-07T15:30:29.618759Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22710-4
  a curric:KeyLearningPoint ;
  rdfs:label """Community groups and individual changemakers also help protect and support
  children’s rights."""@en ;
  dcterms:modified "2026-06-07T15:30:29.618763Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22710-5
  a curric:KeyLearningPoint ;
  rdfs:label """Some believe the UK protects children’s rights well, others argue issues like
  poverty still deny many their rights."""@en ;
  dcterms:modified "2026-06-07T15:30:29.618767Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24899-1
  a curric:KeyLearningPoint ;
  rdfs:label """Immigration is when people move to a country to live there. Emigration is when
  people move out of a country."""@en ;
  dcterms:modified "2026-06-07T15:30:29.621766Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24899-2
  a curric:KeyLearningPoint ;
  rdfs:label """Immigration control refers to the ways countries manage and limit who can enter,
  stay or settle."""@en ;
  dcterms:modified "2026-06-07T15:30:29.621772Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24899-3
  a curric:KeyLearningPoint ;
  rdfs:label "Immigration control is beneficial for planning, safety and services."@en ;
  dcterms:modified "2026-06-07T15:30:29.621776Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24899-4
  a curric:KeyLearningPoint ;
  rdfs:label """Its drawbacks include long delays, labour shortages and the risk of treating people
  unfairly."""@en ;
  dcterms:modified "2026-06-07T15:30:29.621780Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24899-5
  a curric:KeyLearningPoint ;
  rdfs:label """Decisions about immigration involve complex matters, and it is likely that the
  debate will continue for some time."""@en ;
  dcterms:modified "2026-06-07T15:30:29.621785Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22509-1
  a curric:KeyLearningPoint ;
  rdfs:label """Rules are guidelines that tell you what is and isn't allowed, they may change in
  different settings e.g. home, school."""@en ;
  dcterms:modified "2026-06-07T15:30:29.623324Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22509-2
  a curric:KeyLearningPoint ;
  rdfs:label """Laws are rules which apply to everyone, all the time, they are created by
  parliament."""@en ;
  dcterms:modified "2026-06-07T15:30:29.623328Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22509-3
  a curric:KeyLearningPoint ;
  rdfs:label """Magna Carta was the first document to put in writing the principle that the king is
  not above the law."""@en ;
  dcterms:modified "2026-06-07T15:30:29.623332Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22509-4
  a curric:KeyLearningPoint ;
  rdfs:label """Rules and laws are there to protect us, keep the peace and make sure everyone is
  treated fairly."""@en ;
  dcterms:modified "2026-06-07T15:30:29.623337Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24917-1
  a curric:KeyLearningPoint ;
  rdfs:label """Change can be achieved through various campaigning methods, including petitions,
  protests and direct contact with MPs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.624006Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24917-2
  a curric:KeyLearningPoint ;
  rdfs:label """Each method has specific strengths and is suited to different objectives, like
  influence or public awareness."""@en ;
  dcterms:modified "2026-06-07T15:30:29.624011Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24917-3
  a curric:KeyLearningPoint ;
  rdfs:label """Effective campaigns are characterised by clear messaging, the use of real-life
  evidence and strong partnerships."""@en ;
  dcterms:modified "2026-06-07T15:30:29.624015Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24917-4
  a curric:KeyLearningPoint ;
  rdfs:label """Strategic timing, particularly when aligned with current events or agendas,
  increases the likelihood of success."""@en ;
  dcterms:modified "2026-06-07T15:30:29.624019Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24917-5
  a curric:KeyLearningPoint ;
  rdfs:label """Evaluating the impact of a campaign involves assessing whether the chosen method led
  to meaningful outcomes or change."""@en ;
  dcterms:modified "2026-06-07T15:30:29.624086Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24881-1
  a curric:KeyLearningPoint ;
  rdfs:label """The Government has the authority to govern the UK. The Government is chosen and led
  by the Prime Minister (PM)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.624767Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24881-2
  a curric:KeyLearningPoint ;
  rdfs:label "The UK Government has three main branches: legislative, executive and judiciary."@en ;
  dcterms:modified "2026-06-07T15:30:29.624841Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24881-3
  a curric:KeyLearningPoint ;
  rdfs:label """The Cabinet is chosen by the PM. It leads government departments and makes key
  decisions on government policies."""@en ;
  dcterms:modified "2026-06-07T15:30:29.624985Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24898-1
  a curric:KeyLearningPoint ;
  rdfs:label """Migration is when people move between places and across borders. Some migrants need
  support when living in a new place."""@en ;
  dcterms:modified "2026-06-07T15:30:29.626309Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24898-2
  a curric:KeyLearningPoint ;
  rdfs:label """All migrants need the basics, like shelter, but other kinds of support can depend on
  why they moved."""@en ;
  dcterms:modified "2026-06-07T15:30:29.626346Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24898-3
  a curric:KeyLearningPoint ;
  rdfs:label """Refugees and asylum seekers have rights under international law and are helped by
  government, charities and communities."""@en ;
  dcterms:modified "2026-06-07T15:30:29.626357Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24898-4
  a curric:KeyLearningPoint ;
  rdfs:label """Even migrants who choose to move still need support, for example, social support,
  language or schooling and work advice."""@en ;
  dcterms:modified "2026-06-07T15:30:29.626362Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24898-5
  a curric:KeyLearningPoint ;
  rdfs:label """Supporting migrants allows them to share their skills and get involved in
  society."""@en ;
  dcterms:modified "2026-06-07T15:30:29.626553Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24913-1
  a curric:KeyLearningPoint ;
  rdfs:label """Article 12 of the UNCRC grants children the right to express their views on matters
  affecting them."""@en ;
  dcterms:modified "2026-06-07T15:30:29.626617Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24913-2
  a curric:KeyLearningPoint ;
  rdfs:label "Pupil voice contributes to enhanced school climate, behaviour and wellbeing."@en ;
  dcterms:modified "2026-06-07T15:30:29.626645Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24913-3
  a curric:KeyLearningPoint ;
  rdfs:label """Decision-makers include individuals or bodies with authority to implement change in
  education settings."""@en ;
  dcterms:modified "2026-06-07T15:30:29.626656Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24913-4
  a curric:KeyLearningPoint ;
  rdfs:label """Influencing change involves identifying a need, gathering evidence, cause and
  effect, planning and taking action."""@en ;
  dcterms:modified "2026-06-07T15:30:29.626695Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24913-5
  a curric:KeyLearningPoint ;
  rdfs:label """An active citizen engages constructively in school and community decision-making
  processes."""@en ;
  dcterms:modified "2026-06-07T15:30:29.626707Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24909-1
  a curric:KeyLearningPoint ;
  rdfs:label """Political engagement has shifted from traditional media to digital platforms,
  especially for young people."""@en ;
  dcterms:modified "2026-06-07T15:30:29.628219Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24909-2
  a curric:KeyLearningPoint ;
  rdfs:label """Digital media offers new ways to engage in politics, such as social media campaigns
  and online petitions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.628223Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24909-3
  a curric:KeyLearningPoint ;
  rdfs:label """Digital media can increase political engagement by removing barriers and enabling
  youth-led activism."""@en ;
  dcterms:modified "2026-06-07T15:30:29.628230Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24909-4
  a curric:KeyLearningPoint ;
  rdfs:label """Online risks like misinformation, echo chambers, and the digital divide can limit or
  distort engagement."""@en ;
  dcterms:modified "2026-06-07T15:30:29.628234Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23740-1
  a curric:KeyLearningPoint ;
  rdfs:label """Our views of what is right and wrong come from a range of influences in our lives
  and can evolve as we get older."""@en ;
  dcterms:modified "2026-06-07T15:30:29.630187Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23740-2
  a curric:KeyLearningPoint ;
  rdfs:label """When someone breaks the law, this is known as a crime. We become criminally
  responsible at the age of ten in England."""@en ;
  dcterms:modified "2026-06-07T15:30:29.630191Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23740-3
  a curric:KeyLearningPoint ;
  rdfs:label "There are two main types of law in England: civil and criminal."@en ;
  dcterms:modified "2026-06-07T15:30:29.630195Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24911-1
  a curric:KeyLearningPoint ;
  rdfs:label """MPs vote in person by walking into aye or nay lobbies and scanning passes to record
  their vote."""@en ;
  dcterms:modified "2026-06-07T15:30:29.630568Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24911-2
  a curric:KeyLearningPoint ;
  rdfs:label """Tellers count votes and report results to the Speaker, who oversees and announces
  the final outcome."""@en ;
  dcterms:modified "2026-06-07T15:30:29.630572Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24911-3
  a curric:KeyLearningPoint ;
  rdfs:label """During Covid-19, MPs used a digital system to vote remotely for the first time in UK
  Parliament history."""@en ;
  dcterms:modified "2026-06-07T15:30:29.630576Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24911-4
  a curric:KeyLearningPoint ;
  rdfs:label """Remote voting offered benefits like better access, time-saving, and continuity in
  emergencies."""@en ;
  dcterms:modified "2026-06-07T15:30:29.630581Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24911-5
  a curric:KeyLearningPoint ;
  rdfs:label """Concerns included security risks, weaker debate, and the loss of tradition and
  accountability."""@en ;
  dcterms:modified "2026-06-07T15:30:29.630584Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24915-1
  a curric:KeyLearningPoint ;
  rdfs:label """Voting reform refers to changes made to voting laws or systems. These changes aim to
  make the democratic process fairer."""@en ;
  dcterms:modified "2026-06-07T15:30:29.631855Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24915-2
  a curric:KeyLearningPoint ;
  rdfs:label """In Scotland, the voting age was reduced to 16 years old by the Scottish Elections
  (Reduction of Voting Age) Act 2015."""@en ;
  dcterms:modified "2026-06-07T15:30:29.631861Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24915-3
  a curric:KeyLearningPoint ;
  rdfs:label """The Senedd and Elections Act 2020 extended the franchise to 16 and 17 year olds in
  Wales."""@en ;
  dcterms:modified "2026-06-07T15:30:29.631866Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24915-4
  a curric:KeyLearningPoint ;
  rdfs:label """Supporters say 16 year olds are responsible and politically educated. It could boost
  long term voter turnout."""@en ;
  dcterms:modified "2026-06-07T15:30:29.631870Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24915-5
  a curric:KeyLearningPoint ;
  rdfs:label """Critics say 16 year olds lack experience, are easily influenced and may not have
  enough political literacy to vote."""@en ;
  dcterms:modified "2026-06-07T15:30:29.631874Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24903-1
  a curric:KeyLearningPoint ;
  rdfs:label "Borrowing money through credit cards can lead to high interest rates."@en ;
  dcterms:modified "2026-06-07T15:30:29.633713Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24903-2
  a curric:KeyLearningPoint ;
  rdfs:label "Short-term loans can quickly accumulate debt and become expensive."@en ;
  dcterms:modified "2026-06-07T15:30:29.633717Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24903-3
  a curric:KeyLearningPoint ;
  rdfs:label "Long-term loans can result in paying more interest over time."@en ;
  dcterms:modified "2026-06-07T15:30:29.633722Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24903-4
  a curric:KeyLearningPoint ;
  rdfs:label "Overdrafts can lead to high fees if not repaid quickly."@en ;
  dcterms:modified "2026-06-07T15:30:29.633726Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24903-5
  a curric:KeyLearningPoint ;
  rdfs:label """Loan sharks charge extremely high interest rates and operate outside FCA
  protections."""@en ;
  dcterms:modified "2026-06-07T15:30:29.633730Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24905-1
  a curric:KeyLearningPoint ;
  rdfs:label """Ways to save are instant access, notice accounts and Cash ISAs, each with different
  interest rates and accessibility."""@en ;
  dcterms:modified "2026-06-07T15:30:29.633734Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24905-2
  a curric:KeyLearningPoint ;
  rdfs:label """Being a critical consumer helps people avoid impulse purchases and maximise savings
  through better interest rates."""@en ;
  dcterms:modified "2026-06-07T15:30:29.633743Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24905-3
  a curric:KeyLearningPoint ;
  rdfs:label """The Monetary Policy Committee (MPC) sets the Bank of England base rate, influencing
  savings, borrowing and inflation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.633747Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24905-4
  a curric:KeyLearningPoint ;
  rdfs:label """Investments like stocks, bonds, funds, property, commodities and cryptocurrency
  generate returns but all carry risks."""@en ;
  dcterms:modified "2026-06-07T15:30:29.633752Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24905-5
  a curric:KeyLearningPoint ;
  rdfs:label """Investments like stocks offer greater returns, while funds provide stable growth for
  risk-averse investors."""@en ;
  dcterms:modified "2026-06-07T15:30:29.633772Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24883-1
  a curric:KeyLearningPoint ;
  rdfs:label """The United Kingdom is a parliamentary democracy, where citizens vote for their
  representatives in Parliament."""@en ;
  dcterms:modified "2026-06-07T15:30:29.633776Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24883-2
  a curric:KeyLearningPoint ;
  rdfs:label """Central Government is led by the Prime Minister and Cabinet. They are elected
  ministers and make decisions on UK issues."""@en ;
  dcterms:modified "2026-06-07T15:30:29.633780Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24883-3
  a curric:KeyLearningPoint ;
  rdfs:label """Local governments are led by elected councillors. They have authority over decisions
  which affect citizens locally."""@en ;
  dcterms:modified "2026-06-07T15:30:29.633784Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24883-4
  a curric:KeyLearningPoint ;
  rdfs:label """Regional governments have devolved powers. Elected representatives make key regional
  decisions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.633788Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24883-5
  a curric:KeyLearningPoint ;
  rdfs:label """Devolved powers are those which have been transferred from central Government to
  local or regional governments."""@en ;
  dcterms:modified "2026-06-07T15:30:29.633792Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23744-1
  a curric:KeyLearningPoint ;
  rdfs:label """There are different strategies that can be used to prevent crime, for example:
  educational, situational and deterrents."""@en ;
  dcterms:modified "2026-06-07T15:30:29.634778Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23744-2
  a curric:KeyLearningPoint ;
  rdfs:label """Educational crime prevention strategies reduce crime by educating people about the
  law and consequences of breaking it."""@en ;
  dcterms:modified "2026-06-07T15:30:29.634782Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23744-3
  a curric:KeyLearningPoint ;
  rdfs:label """Situational crime prevention strategies reduce crime by altering the situations in
  which crime can take place."""@en ;
  dcterms:modified "2026-06-07T15:30:29.634789Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23744-4
  a curric:KeyLearningPoint ;
  rdfs:label """Deterrents discourage people from committing crimes by making the consequences clear
  and the risks higher."""@en ;
  dcterms:modified "2026-06-07T15:30:29.634793Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23744-5
  a curric:KeyLearningPoint ;
  rdfs:label """Communities can use crime prevention strategies to reduce crime opportunities and
  foster shared responsibility."""@en ;
  dcterms:modified "2026-06-07T15:30:29.634797Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24916-1
  a curric:KeyLearningPoint ;
  rdfs:label """Power is the ability to make decisions, whereas influence is the ability to affect
  or shape decisions."""@en ;
  dcterms:modified "2026-06-07T15:30:29.635176Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24916-2
  a curric:KeyLearningPoint ;
  rdfs:label "Young people can use democratic participation to influence leaders in power."@en ;
  dcterms:modified "2026-06-07T15:30:29.635181Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24916-3
  a curric:KeyLearningPoint ;
  rdfs:label """You do not need to have power to make change; influence can be just as effective
  when used with support."""@en ;
  dcterms:modified "2026-06-07T15:30:29.635187Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24916-4
  a curric:KeyLearningPoint ;
  rdfs:label """Campaigns are organised actions that people use to raise awareness and push for
  change within a democratic system."""@en ;
  dcterms:modified "2026-06-07T15:30:29.635193Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24916-5
  a curric:KeyLearningPoint ;
  rdfs:label """Campaigning methods include: petitions, demonstrations, consultations, meetings with
  decision makers and lobbying MPs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.635198Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23738-1
  a curric:KeyLearningPoint ;
  rdfs:label "There are many eligibility criteria for voting, e.g. age and residency."@en ;
  dcterms:modified "2026-06-07T15:30:29.636265Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23738-2
  a curric:KeyLearningPoint ;
  rdfs:label """To register to vote, an eligible person must complete an online or paper form with
  their details."""@en ;
  dcterms:modified "2026-06-07T15:30:29.636269Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23738-3
  a curric:KeyLearningPoint ;
  rdfs:label """Local elections give communities the opportunity to choose who they want to make
  decisions on essential services."""@en ;
  dcterms:modified "2026-06-07T15:30:29.636273Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23738-4
  a curric:KeyLearningPoint ;
  rdfs:label """Voter registration drives aim to encourage people to join the electoral roll and
  vote on polling day."""@en ;
  dcterms:modified "2026-06-07T15:30:29.636277Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23738-5
  a curric:KeyLearningPoint ;
  rdfs:label """The political party with the majority (50% +1) gains overall power of the council,
  which gives them more control."""@en ;
  dcterms:modified "2026-06-07T15:30:29.636282Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24897-1
  a curric:KeyLearningPoint ;
  rdfs:label """Rights are the things that every person is guaranteed and entitled to have
  by law."""@en ;
  dcterms:modified "2026-06-07T15:30:29.637172Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24897-2
  a curric:KeyLearningPoint ;
  rdfs:label """Rights are universal and are made so everyone can have a healthy, safe and happy
  life, no matter their background."""@en ;
  dcterms:modified "2026-06-07T15:30:29.637176Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24897-3
  a curric:KeyLearningPoint ;
  rdfs:label """Children have 54 rights that are outlined in the United Nations Convention on the
  Rights of a Child (UNCRC)."""@en ;
  dcterms:modified "2026-06-07T15:30:29.637180Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24897-4
  a curric:KeyLearningPoint ;
  rdfs:label """During conflict, many of these rights are put at risk. Children may lose access to
  basics like shelter and safety."""@en ;
  dcterms:modified "2026-06-07T15:30:29.637184Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24897-5
  a curric:KeyLearningPoint ;
  rdfs:label """There are organisations which exist to help protect children's rights and provide
  support during crises."""@en ;
  dcterms:modified "2026-06-07T15:30:29.637188Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23743-1
  a curric:KeyLearningPoint ;
  rdfs:label """The justice system deals with youth crime differently to crimes committed by
  adults."""@en ;
  dcterms:modified "2026-06-07T15:30:29.637330Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23743-2
  a curric:KeyLearningPoint ;
  rdfs:label """Each year the Government releases statistics about crime, these include youth crime
  statistics."""@en ;
  dcterms:modified "2026-06-07T15:30:29.637334Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23743-3
  a curric:KeyLearningPoint ;
  rdfs:label """According to a 2024 report, media coverage of young people is twice as likely to be
  negative as it is to be positive."""@en ;
  dcterms:modified "2026-06-07T15:30:29.637338Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-23743-4
  a curric:KeyLearningPoint ;
  rdfs:label """Actions to improve media portrayal include petitions, events, campaigns and creating
  new news sources."""@en ;
  dcterms:modified "2026-06-07T15:30:29.637342Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24844-1
  a curric:KeyLearningPoint ;
  rdfs:label """Some media outlets are trustworthy because they verify facts and do investigative
  journalism, but not all are reliable."""@en ;
  dcterms:modified "2026-06-07T15:30:29.637634Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24844-2
  a curric:KeyLearningPoint ;
  rdfs:label """Be aware of disinformation, misinformation and malinformation when interpreting
  media content."""@en ;
  dcterms:modified "2026-06-07T15:30:29.637638Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24844-3
  a curric:KeyLearningPoint ;
  rdfs:label """The REVIEW model helps spot misinformation: Reputation, Evidence, Verify, Intent,
  Emotions and Weigh it up."""@en ;
  dcterms:modified "2026-06-07T15:30:29.637642Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24844-4
  a curric:KeyLearningPoint ;
  rdfs:label """Always question the purpose, evidence and trustworthiness of the information you
  see."""@en ;
  dcterms:modified "2026-06-07T15:30:29.637647Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24844-5
  a curric:KeyLearningPoint ;
  rdfs:label """Evaluate all aspects of the media content before deciding if it’s accurate and
  reliable."""@en ;
  dcterms:modified "2026-06-07T15:30:29.637651Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24907-1
  a curric:KeyLearningPoint ;
  rdfs:label """Digital citizenship means using technology safely, ethically and with respect for
  rights and responsibilities."""@en ;
  dcterms:modified "2026-06-07T15:30:29.638542Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24907-2
  a curric:KeyLearningPoint ;
  rdfs:label """Being an active digital citizen means engaging with public issues to make a positive
  difference."""@en ;
  dcterms:modified "2026-06-07T15:30:29.638546Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24907-3
  a curric:KeyLearningPoint ;
  rdfs:label """Digital democracy is using online tools to support key democratic functions like
  voting and participation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.638550Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24907-4
  a curric:KeyLearningPoint ;
  rdfs:label """Digital technologies are making democracy more accessible, but challenges like
  security and access remain."""@en ;
  dcterms:modified "2026-06-07T15:30:29.638554Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24863-1
  a curric:KeyLearningPoint ;
  rdfs:label """Select committees allow citizens to help shape policies and strengthen
  democracy."""@en ;
  dcterms:modified "2026-06-07T15:30:29.638561Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24863-2
  a curric:KeyLearningPoint ;
  rdfs:label """Select committees use evidence from the public, experts and organisations to make
  recommendations to the Government."""@en ;
  dcterms:modified "2026-06-07T15:30:29.638565Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24863-3
  a curric:KeyLearningPoint ;
  rdfs:label """Evidence can be given through written submissions, oral testimony or hearings, or
  sharing documents."""@en ;
  dcterms:modified "2026-06-07T15:30:29.638569Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24863-4
  a curric:KeyLearningPoint ;
  rdfs:label """The process of collecting evidence for select committees ensures fairness,
  accountability and diverse representation."""@en ;
  dcterms:modified "2026-06-07T15:30:29.638573Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24863-5
  a curric:KeyLearningPoint ;
  rdfs:label """Engaging with and contributing to select committees supports democracy and reflects
  community needs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.638577Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24902-1
  a curric:KeyLearningPoint ;
  rdfs:label """There are multiple ways to pay, including cash, debit cards, credit cards and
  digital payments."""@en ;
  dcterms:modified "2026-06-07T15:30:29.638815Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24902-2
  a curric:KeyLearningPoint ;
  rdfs:label """A debit card allows you to spend directly from your bank account, while a credit
  card lets you repay money later."""@en ;
  dcterms:modified "2026-06-07T15:30:29.638819Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24902-3
  a curric:KeyLearningPoint ;
  rdfs:label """A budget is a plan that helps track income and expenses, making sure spending is
  controlled and savings are a priority."""@en ;
  dcterms:modified "2026-06-07T15:30:29.638823Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24902-4
  a curric:KeyLearningPoint ;
  rdfs:label """Budgeting means regularly checking and adjusting spending to avoid debt, cover bills
  and prepare for future costs."""@en ;
  dcterms:modified "2026-06-07T15:30:29.638827Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24902-5
  a curric:KeyLearningPoint ;
  rdfs:label """Successful budgeting involves spending within your means and using different payment
  methods wisely."""@en ;
  dcterms:modified "2026-06-07T15:30:29.638831Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22519-1
  a curric:KeyLearningPoint ;
  rdfs:label """Identity is made up of who a person is, or the qualities of a person or group that
  make them different from others."""@en ;
  dcterms:modified "2026-06-07T15:30:29.638835Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22519-2
  a curric:KeyLearningPoint ;
  rdfs:label "We all have characteristics which help to identify us."@en ;
  dcterms:modified "2026-06-07T15:30:29.638842Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22519-3
  a curric:KeyLearningPoint ;
  rdfs:label "We get our personal identities from both nature and nurture."@en ;
  dcterms:modified "2026-06-07T15:30:29.638846Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-22519-4
  a curric:KeyLearningPoint ;
  rdfs:label """People can have multiple identities because they can belong to different groups at
  the same time."""@en ;
  dcterms:modified "2026-06-07T15:30:29.638850Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24875-1
  a curric:KeyLearningPoint ;
  rdfs:label """Poverty is when people don't have enough money or resources to meet their basic
  needs, like food and shelter."""@en ;
  dcterms:modified "2026-06-07T15:30:29.638854Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24875-2
  a curric:KeyLearningPoint ;
  rdfs:label "How poverty is measured can be different depending on where you live."@en ;
  dcterms:modified "2026-06-07T15:30:29.638861Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24875-3
  a curric:KeyLearningPoint ;
  rdfs:label """Global poverty still exists because of factors like inequality, lack of education
  and limited access to resources."""@en ;
  dcterms:modified "2026-06-07T15:30:29.638865Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24875-4
  a curric:KeyLearningPoint ;
  rdfs:label """Poverty can be exacerbated by other factors such as conflict, government instability
  and climate change."""@en ;
  dcterms:modified "2026-06-07T15:30:29.638869Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-24875-5
  a curric:KeyLearningPoint ;
  rdfs:label """The UN and NGOs work hard to tackle global poverty through programmes and
  initiatives."""@en ;
  dcterms:modified "2026-06-07T15:30:29.638873Z"^^xsd:dateTime .

# ----------------------------------------------------------------------
# Pupil Lesson Outcomes
# ----------------------------------------------------------------------

oakcurric:pupillessonoutcome-lesson-24862
  a curric:PupilLessonOutcome ;
  rdfs:label """I can explain the role of a changemaker in a democracy and give examples of what
  changemakers have achieved globally."""@en ;
  dcterms:modified "2026-06-07T15:30:41.063670Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-24831
  a curric:PupilLessonOutcome ;
  rdfs:label """I can explain what an MP is and describe some of their key roles, responsibilities
  and skills."""@en ;
  dcterms:modified "2026-06-07T15:30:41.063853Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-22510
  a curric:PupilLessonOutcome ;
  rdfs:label "I can explain what fairness means and how we can fight for a fairer society."@en ;
  dcterms:modified "2026-06-07T15:30:41.064017Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-24912
  a curric:PupilLessonOutcome ;
  rdfs:label """I can critically assess the use of social media to increase political
  participation."""@en ;
  dcterms:modified "2026-06-07T15:30:41.064237Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-24852
  a curric:PupilLessonOutcome ;
  rdfs:label """I can describe methods citizens use to influence lawmakers and provide an example of
  how a citizen has changed the law."""@en ;
  dcterms:modified "2026-06-07T15:30:41.065082Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-24868
  a curric:PupilLessonOutcome ;
  rdfs:label """I can explain why voting is an important part of the democratic process and how
  political decisions are made."""@en ;
  dcterms:modified "2026-06-07T15:30:41.065586Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-24893
  a curric:PupilLessonOutcome ;
  rdfs:label """I can explain how the absence of laws in the past allowed inequality to happen and
  how the introduction of new laws has helped create a fairer society."""@en ;
  dcterms:modified "2026-06-07T15:30:41.065726Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-24832
  a curric:PupilLessonOutcome ;
  rdfs:label """I can describe the structure of the Government in the UK and explain some of the job
  roles within it."""@en ;
  dcterms:modified "2026-06-07T15:30:41.066086Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-24860
  a curric:PupilLessonOutcome ;
  rdfs:label """I can explain how groups, including pressure groups, drive social change and the
  effective methods they use."""@en ;
  dcterms:modified "2026-06-07T15:30:41.066237Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-24889
  a curric:PupilLessonOutcome ;
  rdfs:label """I can explain what equality is and understand how the Equality Act 2010 protects
  people against discrimination and inequality."""@en ;
  dcterms:modified "2026-06-07T15:30:41.066604Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-24885
  a curric:PupilLessonOutcome ;
  rdfs:label """I can explain and compare some of the key differences and similarities between the
  UK and the US political systems."""@en ;
  dcterms:modified "2026-06-07T15:30:41.066784Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-22524
  a curric:PupilLessonOutcome ;
  rdfs:label "I can explain how the global community is connected."@en ;
  dcterms:modified "2026-06-07T15:30:41.066846Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-22512
  a curric:PupilLessonOutcome ;
  rdfs:label """I can identify a number of ways we can make a positive difference in our school
  communities."""@en ;
  dcterms:modified "2026-06-07T15:30:41.067119Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-24873
  a curric:PupilLessonOutcome ;
  rdfs:label "I can describe what fracking is and explain the risks and benefits of fracking."@en ;
  dcterms:modified "2026-06-07T15:30:41.067345Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-24842
  a curric:PupilLessonOutcome ;
  rdfs:label """I can explain why the media is important in a democracy and how the media informs
  and educates us."""@en ;
  dcterms:modified "2026-06-07T15:30:41.067381Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-24910
  a curric:PupilLessonOutcome ;
  rdfs:label """I can assess how well digital democracy has worked in other countries and consider
  whether we should use it in the UK."""@en ;
  dcterms:modified "2026-06-07T15:30:41.067735Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-23739
  a curric:PupilLessonOutcome ;
  rdfs:label """I can describe how young people can be included in local decision making and plan an
  active citizenship campaign."""@en ;
  dcterms:modified "2026-06-07T15:30:41.067806Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-25390
  a curric:PupilLessonOutcome ;
  rdfs:label "I can explain the contribution charities, NGOs and groups make in our community."@en ;
  dcterms:modified "2026-06-07T15:30:41.067879Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-24828
  a curric:PupilLessonOutcome ;
  rdfs:label """I can describe the key differences between the Government and Parliament and explain
  some of their key roles."""@en ;
  dcterms:modified "2026-06-07T15:30:41.068072Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-24882
  a curric:PupilLessonOutcome ;
  rdfs:label """I can explain how the Civil Service is governed and describe its roles and
  responsibilities in government."""@en ;
  dcterms:modified "2026-06-07T15:30:41.068152Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-22707
  a curric:PupilLessonOutcome ;
  rdfs:label "I can explain what we can do as citizens to protect the rights of others."@en ;
  dcterms:modified "2026-06-07T15:30:41.068637Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-25389
  a curric:PupilLessonOutcome ;
  rdfs:label "I can explain the role our school plays in our local community."@en ;
  dcterms:modified "2026-06-07T15:30:41.068866Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-22523
  a curric:PupilLessonOutcome ;
  rdfs:label "I can explain how UK communities are connected and why this is important."@en ;
  dcterms:modified "2026-06-07T15:30:41.073259Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-22521
  a curric:PupilLessonOutcome ;
  rdfs:label "I can explain the main features of a diverse and inclusive community."@en ;
  dcterms:modified "2026-06-07T15:30:41.073263Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-27579
  a curric:PupilLessonOutcome ;
  rdfs:label """I can explain what active citizenship is and what skills are needed to bring about
  positive change."""@en ;
  dcterms:modified "2026-06-07T15:30:41.073438Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-24895
  a curric:PupilLessonOutcome ;
  rdfs:label """I can explain what migration is, why people migrate and describe the challenges and
  opportunities they may experience."""@en ;
  dcterms:modified "2026-06-07T15:30:41.073731Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-24872
  a curric:PupilLessonOutcome ;
  rdfs:label """I can critically examine different arguments about climate change and explain what
  actions we can take to address climate change."""@en ;
  dcterms:modified "2026-06-07T15:30:41.073739Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-29981
  a curric:PupilLessonOutcome ;
  rdfs:label """I can explain how laws are applied fairly, how judges make fair decisions, and how
  people can get help if laws are unfair."""@en ;
  dcterms:modified "2026-06-07T15:30:41.075012Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-22706
  a curric:PupilLessonOutcome ;
  rdfs:label "I can explain what the right to education means and why it is important."@en ;
  dcterms:modified "2026-06-07T15:30:41.075470Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-29980
  a curric:PupilLessonOutcome ;
  rdfs:label """I can explain what the rule of law is, why everyone must follow it, and how it keeps
  people fair and safe."""@en ;
  dcterms:modified "2026-06-07T15:30:41.075524Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-29112
  a curric:PupilLessonOutcome ;
  rdfs:label """I can explain what happens after a general election and describe what majority,
  minority and coalition governments are."""@en ;
  dcterms:modified "2026-06-07T15:30:41.076069Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-22522
  a curric:PupilLessonOutcome ;
  rdfs:label "I can explain how and why communities have changed over time."@en ;
  dcterms:modified "2026-06-07T15:30:41.077435Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-24861
  a curric:PupilLessonOutcome ;
  rdfs:label """I can describe what campaigning is, identify successful examples of campaigns and
  explain ways to lobby."""@en ;
  dcterms:modified "2026-06-07T15:30:41.079205Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-24901
  a curric:PupilLessonOutcome ;
  rdfs:label """I can explain what financial responsibility is, the different types of bank accounts
  and ways to bank ethically."""@en ;
  dcterms:modified "2026-06-07T15:30:41.079701Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-24871
  a curric:PupilLessonOutcome ;
  rdfs:label """I can describe the environmental impacts of plastic pollution and the challenges in
  reducing plastic use and propose strategies to reduce plastic waste."""@en ;
  dcterms:modified "2026-06-07T15:30:41.079865Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-24892
  a curric:PupilLessonOutcome ;
  rdfs:label """I can explain what laws are, how they help promote equality and how equality laws
  were created over time."""@en ;
  dcterms:modified "2026-06-07T15:30:41.079870Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-23735
  a curric:PupilLessonOutcome ;
  rdfs:label """I can describe some of the key services a local council provides and how these are
  funded."""@en ;
  dcterms:modified "2026-06-07T15:30:41.080012Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-22520
  a curric:PupilLessonOutcome ;
  rdfs:label "I can explain how and why identities change over time."@en ;
  dcterms:modified "2026-06-07T15:30:41.080123Z"^^xsd:dateTime .

oakcurric:pupillessonoutcome-lesson-23736
  a curric:PupilLessonOutcome ;
  rdfs:label """I can describe what a councillor is and explain some of their key roles and
  responsibilities."""@en ;
  dcterms:modified "2026-06-07T15:30:41.080127Z"^^xsd:dateTime .

