# ----------------------------------------------------------------------
# Subject Group
# ----------------------------------------------------------------------

natcurric:subjectgroup-citizenship
  a curric:SubjectGroup ;
  rdfs:label "Citizenship"@en ;
  dcterms:modified "2025-12-18T12:33:32Z"^^xsd:dateTime ;
  curric:coversDiscipline natcurric:discipline-citizenship .
  
# ----------------------------------------------------------------------
# Subject
# ----------------------------------------------------------------------

natcurric:subject-citizenship
  a curric:Subject ;
  rdfs:label "Citizenship"@en ;
  curric:aims (
    """Acquire a sound knowledge and understanding of how the United Kingdom is governed, its 
    political system and how citizens participate actively in its democratic systems of 
    government."""@en
    """Develop a sound knowledge and understanding of the role of law and the justice system in 
    our society and how laws are shaped and enforced."""@en
    """Develop an interest in, and commitment to, participation in volunteering as well as other 
    forms of responsible activity, that they will take with them into adulthood."""@en
    """Are equipped with the skills to think critically and debate political questions, to enable 
    them to manage their money on a day-to-day basis, and plan for future financial needs."""@en
  ) ;
  curric:rationale """A high-quality citizenship education helps to provide pupils with knowledge, 
  skills and understanding to prepare them to play a full and active part in society. In 
  particular, citizenship education should foster pupils' keen awareness and understanding of 
  democracy, government and how laws are made and upheld. Teaching should equip pupils with the 
  skills and knowledge to explore political and social issues critically, to weigh evidence, debate 
  and make reasoned arguments. It should also prepare pupils to take their place in society as 
  responsible citizens, manage their money well and make sound financial decisions."""@en ;
  curric:structure "Text for structure..."@en ;
  curric:schoolCurriculum "Text for school curriculum..."@en ;
  dcterms:modified "2025-12-18T12:33:32Z"^^xsd:dateTime ;
  curric:isSubjectOf natcurric:subjectgroup-citizenship ;
  curric:coversStrand natcurric:strand-democracy ,
                      natcurric:strand-government ,
                      natcurric:strand-rights-justice-and-the-law .

# ----------------------------------------------------------------------
# Schemes 
# ----------------------------------------------------------------------

natcurric:scheme-citizenship-key-stage-3
  a curric:Scheme ;
  rdfs:label "Citizenship Key Stage 3"@en ;
  dcterms:description """Teaching should develop pupils' understanding of democracy, government, 
  rights justice and the law. Pupils should use and apply their knowledge and understanding whilst 
  developing skills to research and interrogate evidence, debate and evaluate viewpoints, present 
  reasoned arguments and take informed action."""@en ;
  dcterms:modified "2025-12-18T12:33:32Z"^^xsd:dateTime ;
  curric:isSchemeOf natcurric:subject-citizenship ;
  curric:coversKeyStage natcurric:key-stage-3 .

natcurric:scheme-citizenship-key-stage-4
  a curric:Scheme ;
  rdfs:label "Citizenship Key Stage 4"@en ;
  dcterms:description """Teaching should build on the key stage 3 programme of study to deepen 
  pupils' understanding of democracy, government, rights justice and the law. Pupils should develop 
  their skills to be able to use a range of research strategies, weigh up evidence, make persuasive 
  arguments and substantiate their conclusions. They should experience and evaluate different ways 
  that citizens can act together to solve problems and contribute to society."""@en ;
  dcterms:modified "2025-12-18T12:33:32Z"^^xsd:dateTime ;
  curric:isSchemeOf natcurric:subject-citizenship ;
  curric:coversKeyStage natcurric:key-stage-4 .

