# ======================================================================
# National Curriculum for England - Citizenship Knowledge Taxonomy
# ======================================================================

# ----------------------------------------------------------------------
# Ontology Declaration
# ----------------------------------------------------------------------

<https://w3id.org/uk/oak/curriculum/nationalcurriculum/citizenship-knowledge-taxonomy>
  rdf:type owl:Ontology ;

  rdfs:label "National Curriculum for England - Citizenship Knowledge Taxonomy"@en ;
  dc:title "National Curriculum for England - Citizenship Knowledge Taxonomy"@en ;
  rdfs:comment """Citizenship knowledge taxonomy defining the hierarchical organisation of content
  from strands through to sub-content descriptors."""@en ;

  owl:versionInfo "0.1.1" ;
  owl:versionIRI <https://w3id.org/uk/oak/curriculum/nationalcurriculum/citizenship-knowledge-taxonomy/0.1.1> ;

  dcterms:description """This file defines the Citizenship knowledge taxonomy for the National
  Curriculum in England, organising content through strands, sub-strands, content
  descriptors, and sub-content descriptors."""@en ;
  dc:creator "Department for Education" ;
  dcterms:created "2026-05-04T19:24:29Z"^^xsd:dateTime ;
  dcterms:modified "2026-05-04T19:24:29Z"^^xsd:dateTime ;
  dcterms:issued "2026-05-04T19:24:29Z"^^xsd:dateTime ;

  # OGL 3.0 License
  dcterms:license <http://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/> ;
  dcterms:rights "Crown Copyright"@en ;

  rdfs:seeAlso <https://w3id.org/uk/oak/curriculum/ontology> ;

  vann:preferredNamespacePrefix "natcurric" ;
  vann:preferredNamespaceUri "https://w3id.org/uk/oak/curriculum/nationalcurriculum/" ;

  owl:imports <https://w3id.org/uk/oak/curriculum/ontology> ;
  owl:imports <https://w3id.org/uk/oak/curriculum/nationalcurriculum/citizenship-programme-structure> .

# ----------------------------------------------------------------------
# Knowledge Taxonomy
# ----------------------------------------------------------------------

natcurric:knowledge-taxonomy
  a skos:ConceptScheme ;
  skos:prefLabel "National Curriculum for England Knowledge Taxonomy"@en ;
  skos:hasTopConcept natcurric:discipline-citizenship ;
  dcterms:modified "2026-05-04T19:24:29Z"^^xsd:dateTime .

# ----------------------------------------------------------------------
# Disciplines
# ----------------------------------------------------------------------

natcurric:discipline-citizenship
  a skos:Concept, curric:Discipline ;
  skos:prefLabel "Citizenship"@en ;
  skos:topConceptOf natcurric:knowledge-taxonomy ;
  skos:narrower natcurric:strand-citizenship ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-05-04T19:24:29Z"^^xsd:dateTime .

# ----------------------------------------------------------------------
# Strands
# ----------------------------------------------------------------------

natcurric:strand-citizenship
  a skos:Concept, curric:Strand ;
  skos:prefLabel "Citizenship"@en ;
  skos:definition "Description of strand..."@en ;
  skos:broader natcurric:discipline-citizenship ;
  skos:narrower natcurric:substrand-citizenship ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-05-04T19:24:29Z"^^xsd:dateTime .

# ----------------------------------------------------------------------
# Sub-Strands
# ----------------------------------------------------------------------

natcurric:substrand-citizenship
  a skos:Concept, curric:SubStrand ;
  skos:prefLabel "Citizenship"@en ;
  skos:broader natcurric:strand-citizenship ;
  skos:narrower
    natcurric:contentdescriptor-development-political-system-democratic-government ,
    natcurric:contentdescriptor-operation-parliament-voting-elections-role ,
    natcurric:contentdescriptor-precious-liberties-enjoyed-citizens-united ,
    natcurric:contentdescriptor-nature-rules-laws-justice-system ,
    natcurric:contentdescriptor-roles-played-public-institutions-voluntary ,
    natcurric:contentdescriptor-functions-money-importance-practice-budgeting ,
    natcurric:contentdescriptor-parliamentary-democracy-key-elements-constitution ,
    natcurric:contentdescriptor-different-electoral-systems-used-united ,
    natcurric:contentdescriptor-other-systems-forms-government-democratic ,
    natcurric:contentdescriptor-local-regional-international-governance-united ,
    natcurric:contentdescriptor-human-rights-and-international-law ,
    natcurric:contentdescriptor-legal-system-uk-different-sources ,
    natcurric:contentdescriptor-diverse-national-regional-religious-ethnic ,
    natcurric:contentdescriptor-different-ways-citizen-contribute-improvement ,
    natcurric:contentdescriptor-income-expenditure-credit-debt-insurance ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-05-04T19:24:29Z"^^xsd:dateTime .

# ----------------------------------------------------------------------
# Content Descriptors
# ----------------------------------------------------------------------

natcurric:contentdescriptor-development-political-system-democratic-government
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel """The development of the political system of democratic government in the United
  Kingdom, including the roles of citizens, Parliament and the monarch."""@en ;
  skos:broader natcurric:substrand-citizenship ;
  skos:narrower natcurric:subcontentdescriptor-development-political-system-democratic-government ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-05-04T19:24:29Z"^^xsd:dateTime .

natcurric:contentdescriptor-operation-parliament-voting-elections-role
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel """The operation of Parliament, including voting and elections, and the role of
  political parties."""@en ;
  skos:broader natcurric:substrand-citizenship ;
  skos:narrower natcurric:subcontentdescriptor-operation-parliament-voting-elections-role ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-05-04T19:24:29Z"^^xsd:dateTime .

natcurric:contentdescriptor-precious-liberties-enjoyed-citizens-united
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "The precious liberties enjoyed by the citizens of the United Kingdom."@en ;
  skos:broader natcurric:substrand-citizenship ;
  skos:narrower natcurric:subcontentdescriptor-precious-liberties-enjoyed-citizens-united ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-05-04T19:24:29Z"^^xsd:dateTime .

natcurric:contentdescriptor-nature-rules-laws-justice-system
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel """The nature of rules and laws and the justice system, including the role of the
  police and the operation of courts and tribunals."""@en ;
  skos:broader natcurric:substrand-citizenship ;
  skos:narrower natcurric:subcontentdescriptor-nature-rules-laws-justice-system ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-05-04T19:24:29Z"^^xsd:dateTime .

natcurric:contentdescriptor-roles-played-public-institutions-voluntary
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel """The roles played by public institutions and voluntary groups in society, and 
  the ways in which citizens work together to improve their communities, including opportunities
  to participate in school-based activities."""@en ;
  skos:broader natcurric:substrand-citizenship ;
  skos:narrower natcurric:subcontentdescriptor-roles-played-public-institutions-voluntary ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-05-04T19:24:29Z"^^xsd:dateTime .

natcurric:contentdescriptor-functions-money-importance-practice-budgeting
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel """The functions and uses of money, the importance and practice of budgeting, and
  managing risk."""@en ;
  skos:broader natcurric:substrand-citizenship ;
  skos:narrower natcurric:subcontentdescriptor-functions-money-importance-practice-budgeting ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-05-04T19:24:29Z"^^xsd:dateTime .

natcurric:contentdescriptor-parliamentary-democracy-key-elements-constitution
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel """Parliamentary democracy and the key elements of the constitution of the United
  Kingdom, including the power of government, the role of citizens and Parliament in holding
  those in power to account, and the different roles of the executive, legislature and
  judiciary and a free press."""@en ;
  skos:broader natcurric:substrand-citizenship ;
  skos:narrower natcurric:subcontentdescriptor-parliamentary-democracy-key-elements-constitution ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-05-04T19:24:29Z"^^xsd:dateTime .

natcurric:contentdescriptor-different-electoral-systems-used-united
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel """The different electoral systems used in and beyond the United Kingdom and
  actions citizens can take in democratic and electoral processes to influence decisions
  locally, nationally and beyond."""@en ;
  skos:broader natcurric:substrand-citizenship ;
  skos:narrower natcurric:subcontentdescriptor-different-electoral-systems-used-united ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-05-04T19:24:29Z"^^xsd:dateTime .

natcurric:contentdescriptor-other-systems-forms-government-democratic
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel """Other systems and forms of government, both democratic and non-democratic,
  beyond the United Kingdom."""@en ;
  skos:broader natcurric:substrand-citizenship ;
  skos:narrower natcurric:subcontentdescriptor-other-systems-forms-government-democratic ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-05-04T19:24:29Z"^^xsd:dateTime .

natcurric:contentdescriptor-local-regional-international-governance-united
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel """Local, regional and international governance and the United Kingdom’s relations
  with the rest of Europe, the Commonwealth, the United Nations and the wider world."""@en ;
  skos:broader natcurric:substrand-citizenship ;
  skos:narrower natcurric:subcontentdescriptor-local-regional-international-governance-united ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-05-04T19:24:29Z"^^xsd:dateTime .

natcurric:contentdescriptor-human-rights-and-international-law
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel "Human rights and international law."@en ;
  skos:broader natcurric:substrand-citizenship ;
  skos:narrower natcurric:subcontentdescriptor-human-rights-and-international-law ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-05-04T19:24:29Z"^^xsd:dateTime .

natcurric:contentdescriptor-legal-system-uk-different-sources
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel """The legal system in the UK, different sources of law and how the law helps
  society deal with complex problems."""@en ;
  skos:broader natcurric:substrand-citizenship ;
  skos:narrower natcurric:subcontentdescriptor-legal-system-uk-different-sources ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-05-04T19:24:29Z"^^xsd:dateTime .

natcurric:contentdescriptor-diverse-national-regional-religious-ethnic
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel """Diverse national, regional, religious and ethnic identities in the United
  Kingdom and the need for mutual respect and understanding."""@en ;
  skos:broader natcurric:substrand-citizenship ;
  skos:narrower natcurric:subcontentdescriptor-diverse-national-regional-religious-ethnic ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-05-04T19:24:29Z"^^xsd:dateTime .

natcurric:contentdescriptor-different-ways-citizen-contribute-improvement
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel """The different ways in which a citizen can contribute to the improvement of his
  or her community, to include the opportunity to participate actively in community
  volunteering, as well as other forms of responsible activity."""@en ;
  skos:broader natcurric:substrand-citizenship ;
  skos:narrower natcurric:subcontentdescriptor-different-ways-citizen-contribute-improvement ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-05-04T19:24:29Z"^^xsd:dateTime .

natcurric:contentdescriptor-income-expenditure-credit-debt-insurance
  a skos:Concept, curric:ContentDescriptor ;
  skos:prefLabel """Income and expenditure, credit and debt, insurance, savings and pensions,
  financial products and services, and how public money is raised and spent."""@en ;
  skos:broader natcurric:substrand-citizenship ;
  skos:narrower natcurric:subcontentdescriptor-income-expenditure-credit-debt-insurance ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2026-05-04T19:24:29Z"^^xsd:dateTime .

