oakcurric:priorknowledge-3465-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know the difference between local, regional, and national government."@en ;
  dcterms:modified "2026-06-07T15:29:23.518452Z"^^xsd:dateTime .

oakcurric:priorknowledge-3465-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know how local councils work and who represents people in their area."@en ;
  dcterms:modified "2026-06-07T15:29:23.518468Z"^^xsd:dateTime .

oakcurric:priorknowledge-3465-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know there is a difference between government and Parliament."@en ;
  dcterms:modified "2026-06-07T15:29:23.518475Z"^^xsd:dateTime .

oakcurric:priorknowledge-3465-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know that we elect people to represent us."@en ;
  dcterms:modified "2026-06-07T15:29:23.518480Z"^^xsd:dateTime .

oakcurric:priorknowledge-3476-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils have covered key concepts from across the GCSE Citizenship course, including
  rights, democracy, power, identity, justice, and the UK’s global role."""@en ;
  dcterms:modified "2026-06-07T15:29:23.686348Z"^^xsd:dateTime .

oakcurric:priorknowledge-3476-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils have developed knowledge and understanding of how these concepts
  interconnect."""@en ;
  dcterms:modified "2026-06-07T15:29:23.686365Z"^^xsd:dateTime .

oakcurric:priorknowledge-3693-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "What credit and loans are"@en ;
  dcterms:modified "2026-06-07T15:29:24.077046Z"^^xsd:dateTime .

oakcurric:priorknowledge-3693-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "What local authorities and national government fund"@en ;
  dcterms:modified "2026-06-07T15:29:24.077062Z"^^xsd:dateTime .

oakcurric:priorknowledge-3693-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Financial challenges local and national government have"@en ;
  dcterms:modified "2026-06-07T15:29:24.077069Z"^^xsd:dateTime .

oakcurric:priorknowledge-3693-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "What taxes are and why we pay them"@en ;
  dcterms:modified "2026-06-07T15:29:24.077074Z"^^xsd:dateTime .

oakcurric:priorknowledge-3693-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "How citizens can support a healthy economy"@en ;
  dcterms:modified "2026-06-07T15:29:24.077085Z"^^xsd:dateTime .

oakcurric:priorknowledge-3693-6
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "What debt is"@en ;
  dcterms:modified "2026-06-07T15:29:24.077091Z"^^xsd:dateTime .

oakcurric:priorknowledge-3457-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils should understand what democracy means and the key features that
  define it."""@en ;
  dcterms:modified "2026-06-07T15:29:24.168741Z"^^xsd:dateTime .

oakcurric:priorknowledge-3457-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils should recognise the structure and role of the UK Parliament."@en ;
  dcterms:modified "2026-06-07T15:29:24.168757Z"^^xsd:dateTime .

oakcurric:priorknowledge-3457-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils should have a general awareness of the media’s role in society and the
  importance of free press."""@en ;
  dcterms:modified "2026-06-07T15:29:24.168764Z"^^xsd:dateTime .

oakcurric:priorknowledge-3457-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils should be familiar with the concept of devolution and its impact on
  governance."""@en ;
  dcterms:modified "2026-06-07T15:29:24.168770Z"^^xsd:dateTime .

oakcurric:priorknowledge-3457-5
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils should understand basic democratic participation methods and how citizens can
  get involved."""@en ;
  dcterms:modified "2026-06-07T15:29:24.168775Z"^^xsd:dateTime .

oakcurric:priorknowledge-3442-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils have studied a broad range of citizenship topics including active
  citizenship, human rights, politics/parliament/government, law, media, economy, and
  international relations."""@en ;
  dcterms:modified "2026-06-07T15:29:24.180383Z"^^xsd:dateTime .

oakcurric:priorknowledge-3442-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils are prepared to integrate knowledge and skills from across the curriculum to
  deepen their understanding of citizenship."""@en ;
  dcterms:modified "2026-06-07T15:29:24.180405Z"^^xsd:dateTime .

oakcurric:priorknowledge-3473-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils understand the concept of legal rights and how they are protected through UK
  law."""@en ;
  dcterms:modified "2026-06-07T15:29:24.219541Z"^^xsd:dateTime .

oakcurric:priorknowledge-3473-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils know how citizens can participate in democracy, including through direct
  action and campaigning."""@en ;
  dcterms:modified "2026-06-07T15:29:24.219555Z"^^xsd:dateTime .

oakcurric:priorknowledge-3473-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils can identify how individuals and groups influence change within democratic
  systems."""@en ;
  dcterms:modified "2026-06-07T15:29:24.219562Z"^^xsd:dateTime .

oakcurric:priorknowledge-3456-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils know that citizens can take action to bring about change in society."@en ;
  dcterms:modified "2026-06-07T15:29:24.416644Z"^^xsd:dateTime .

oakcurric:priorknowledge-3456-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils know what a community is and how people and organisations work to
  support it."""@en ;
  dcterms:modified "2026-06-07T15:29:24.416659Z"^^xsd:dateTime .

oakcurric:priorknowledge-3456-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils know they have rights and responsibilities as part of a democratic
  society."""@en ;
  dcterms:modified "2026-06-07T15:29:24.416666Z"^^xsd:dateTime .

oakcurric:priorknowledge-3456-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils know that they can play a role in creating a fairer and more inclusive
  community."""@en ;
  dcterms:modified "2026-06-07T15:29:24.416671Z"^^xsd:dateTime .

oakcurric:priorknowledge-3448-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label "Pupils have explored what personal and national identity means."@en ;
  dcterms:modified "2026-06-07T15:29:24.512663Z"^^xsd:dateTime .

oakcurric:priorknowledge-3448-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils have They have examined rights and responsibilities, including how the law
  protects against discrimination."""@en ;
  dcterms:modified "2026-06-07T15:29:24.512676Z"^^xsd:dateTime .

oakcurric:priorknowledge-3448-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils have considered migration, diversity, and equality, and how people are
  treated in UK society."""@en ;
  dcterms:modified "2026-06-07T15:29:24.512683Z"^^xsd:dateTime .

oakcurric:priorknowledge-3464-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils understand there are different ways citizens can make a positive difference
  in their communities"""@en ;
  dcterms:modified "2026-06-07T15:29:24.537679Z"^^xsd:dateTime .

oakcurric:priorknowledge-3464-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils can explain how young people can take part in democracy and influence
  decisions."""@en ;
  dcterms:modified "2026-06-07T15:29:24.537691Z"^^xsd:dateTime .

oakcurric:priorknowledge-3464-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils can identify opportunities to get involved and work with others to create
  change."""@en ;
  dcterms:modified "2026-06-07T15:29:24.537697Z"^^xsd:dateTime .

oakcurric:priorknowledge-3471-1
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils know what identity means and how individual and group identities are
  shaped."""@en ;
  dcterms:modified "2026-06-07T15:29:24.622856Z"^^xsd:dateTime .

oakcurric:priorknowledge-3471-2
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils have examined the role of communities in shaping identity and the importance
  of mutual respect, inclusion, and shared values."""@en ;
  dcterms:modified "2026-06-07T15:29:24.622866Z"^^xsd:dateTime .

oakcurric:priorknowledge-3471-3
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils have considered how social change and migration contribute to the diversity
  of UK society and how communities respond to change."""@en ;
  dcterms:modified "2026-06-07T15:29:24.622872Z"^^xsd:dateTime .

oakcurric:priorknowledge-3471-4
  a curric:PriorKnowledgeRequirement ;
  rdfs:label """Pupils have developed an understanding of the challenges and opportunities that come
  with living in a diverse society."""@en ;
  dcterms:modified "2026-06-07T15:29:24.622877Z"^^xsd:dateTime .

