# ----------------------------------------------------------------------
# Keywords
# ----------------------------------------------------------------------

oakcurric:keyword-prejudice
  a curric:Keyword ;
  schema:name "prejudice"@en ;
  schema:description """preconceived opinions or attitudes towards a person or group, often based on
  stereotypes"""@en ;
  dcterms:modified "2026-06-07T15:30:02.347231Z"^^xsd:dateTime .

oakcurric:keyword-evaluate
  a curric:Keyword ;
  schema:name "evaluate"@en ;
  schema:description """to examine something closely and make a judgement about its
  effectiveness"""@en ;
  dcterms:modified "2026-06-07T15:30:02.347900Z"^^xsd:dateTime .

oakcurric:keyword-investigate
  a curric:Keyword ;
  schema:name "investigate"@en ;
  schema:description "to look into something carefully to find out the truth or facts"@en ;
  dcterms:modified "2026-06-07T15:30:02.347947Z"^^xsd:dateTime .

oakcurric:keyword-analyse
  a curric:Keyword ;
  schema:name "analyse"@en ;
  schema:description "examining something in detail"@en ;
  dcterms:modified "2026-06-07T15:30:02.347957Z"^^xsd:dateTime .

oakcurric:keyword-digital-media
  a curric:Keyword ;
  schema:name "digital media"@en ;
  schema:description "any content created, stored, or shared using digital technology"@en ;
  dcterms:modified "2026-06-07T15:30:02.348012Z"^^xsd:dateTime .

oakcurric:keyword-trade
  a curric:Keyword ;
  schema:name "trade"@en ;
  schema:description "Trade is the exchange of goods, commodities and services."@en ;
  dcterms:modified "2026-06-07T15:30:02.348359Z"^^xsd:dateTime .

oakcurric:keyword-evidence
  a curric:Keyword ;
  schema:name "evidence"@en ;
  schema:description "the information from a text that can support or justify our reasoning"@en ;
  dcterms:modified "2026-06-07T15:30:02.348463Z"^^xsd:dateTime .

oakcurric:keyword-tolerance
  a curric:Keyword ;
  schema:name "tolerance"@en ;
  schema:description "the acceptable range of variation in a product's dimensions"@en ;
  dcterms:modified "2026-06-07T15:30:02.348537Z"^^xsd:dateTime .

oakcurric:keyword-bias
  a curric:Keyword ;
  schema:name "bias"@en ;
  schema:description """Inclination or prejudice for or against one person or group, especially in a
  way considered to be unfair."""@en ;
  dcterms:modified "2026-06-07T15:30:02.349312Z"^^xsd:dateTime .

oakcurric:keyword-treaty
  a curric:Keyword ;
  schema:name "treaty"@en ;
  schema:description "a treaty is a formal agreement between two countries"@en ;
  dcterms:modified "2026-06-07T15:30:02.349406Z"^^xsd:dateTime .

oakcurric:keyword-impact
  a curric:Keyword ;
  schema:name "impact"@en ;
  schema:description "have a strong effect on someone or something"@en ;
  dcterms:modified "2026-06-07T15:30:02.349836Z"^^xsd:dateTime .

oakcurric:keyword-stereotype
  a curric:Keyword ;
  schema:name "stereotype"@en ;
  schema:description "a set idea that people have about what someone or something is like"@en ;
  dcterms:modified "2026-06-07T15:30:02.349897Z"^^xsd:dateTime .

oakcurric:keyword-changemaker
  a curric:Keyword ;
  schema:name "changemaker"@en ;
  schema:description """someone who wants change in the world and, by gathering knowledge and
  resources, makes that change happen"""@en ;
  dcterms:modified "2026-06-07T15:30:02.349916Z"^^xsd:dateTime .

oakcurric:keyword-democracy
  a curric:Keyword ;
  schema:name "democracy"@en ;
  schema:description """a system of government in which citizens vote in regular, fair elections for
  representatives who then make laws and decisions on their behalf"""@en ;
  dcterms:modified "2026-06-07T15:30:02.349921Z"^^xsd:dateTime .

oakcurric:keyword-government
  a curric:Keyword ;
  schema:name "government"@en ;
  schema:description """a government is a group of leaders who make laws and decisions for a
  country"""@en ;
  dcterms:modified "2026-06-07T15:30:02.350145Z"^^xsd:dateTime .

oakcurric:keyword-society
  a curric:Keyword ;
  schema:name "society"@en ;
  schema:description """a society is a large group of people who live within the same area and
  usually share similar cultures and beliefs"""@en ;
  dcterms:modified "2026-06-07T15:30:02.350195Z"^^xsd:dateTime .

oakcurric:keyword-action-plan
  a curric:Keyword ;
  schema:name "action plan"@en ;
  schema:description "a proposed strategy or course of action to improve performance"@en ;
  dcterms:modified "2026-06-07T15:30:02.350240Z"^^xsd:dateTime .

oakcurric:keyword-member-of-parliament-mp
  a curric:Keyword ;
  schema:name "Member of Parliament (MP)"@en ;
  schema:description """a person elected to represent citizens’ interests and concerns in the House
  of Commons"""@en ;
  dcterms:modified "2026-06-07T15:30:02.350261Z"^^xsd:dateTime .

oakcurric:keyword-constituency
  a curric:Keyword ;
  schema:name "constituency"@en ;
  schema:description """the specific geographical area that is represented by each MP in the House
  of Commons"""@en ;
  dcterms:modified "2026-06-07T15:30:02.350267Z"^^xsd:dateTime .

oakcurric:keyword-representative-democracy
  a curric:Keyword ;
  schema:name "representative democracy"@en ;
  schema:description """a type of democracy where citizens choose others to represent them, making
  important decisions on their behalf"""@en ;
  dcterms:modified "2026-06-07T15:30:02.350276Z"^^xsd:dateTime .

oakcurric:keyword-representation
  a curric:Keyword ;
  schema:name "representation"@en ;
  schema:description """ensuring that different groups of people have a voice in the decision-making
  process and that their views, interests and needs are reflected in government"""@en ;
  dcterms:modified "2026-06-07T15:30:02.350283Z"^^xsd:dateTime .

oakcurric:keyword-participation
  a curric:Keyword ;
  schema:name "participation"@en ;
  schema:description """refers to the active involvement of citizens in the political process, such
  as voting in elections, engaging in debates or joining political groups"""@en ;
  dcterms:modified "2026-06-07T15:30:02.350288Z"^^xsd:dateTime .

oakcurric:keyword-climate-change
  a curric:Keyword ;
  schema:name "climate change"@en ;
  schema:description "a long-term change in Earth’s climate patterns"@en ;
  dcterms:modified "2026-06-07T15:30:02.350396Z"^^xsd:dateTime .

oakcurric:keyword-conflict
  a curric:Keyword ;
  schema:name "conflict"@en ;
  schema:description """an active disagreement between people with opposing opinions or
  principles"""@en ;
  dcterms:modified "2026-06-07T15:30:02.350705Z"^^xsd:dateTime .

oakcurric:keyword-campaigning
  a curric:Keyword ;
  schema:name "campaigning"@en ;
  schema:description """actions or events organised by an individual or a group of people to achieve
  an aim"""@en ;
  dcterms:modified "2026-06-07T15:30:02.350879Z"^^xsd:dateTime .

oakcurric:keyword-campaign
  a curric:Keyword ;
  schema:name "campaign"@en ;
  schema:description """a campaign is a series of military operations intended to achieve a
  particular goal"""@en ;
  dcterms:modified "2026-06-07T15:30:02.350929Z"^^xsd:dateTime .

oakcurric:keyword-power
  a curric:Keyword ;
  schema:name "power"@en ;
  schema:description "having control or authority over something or someone"@en ;
  dcterms:modified "2026-06-07T15:30:02.351112Z"^^xsd:dateTime .

oakcurric:keyword-influence
  a curric:Keyword ;
  schema:name "influence"@en ;
  schema:description "the power to affect or change someone's thoughts, actions or decisions"@en ;
  dcterms:modified "2026-06-07T15:30:02.351117Z"^^xsd:dateTime .

oakcurric:keyword-parliamentary-sovereignty
  a curric:Keyword ;
  schema:name "parliamentary sovereignty"@en ;
  schema:description """the principle that Parliament is the supreme legal authority in the UK; only
  Parliament can create or end any UK law"""@en ;
  dcterms:modified "2026-06-07T15:30:02.351121Z"^^xsd:dateTime .

oakcurric:keyword-gentrification
  a curric:Keyword ;
  schema:name "gentrification"@en ;
  schema:description """the upgrading of areas (typically housing) often in the inner city, making
  them more desirable but often more expensive"""@en ;
  dcterms:modified "2026-06-07T15:30:02.351200Z"^^xsd:dateTime .

oakcurric:keyword-journalist
  a curric:Keyword ;
  schema:name "journalist"@en ;
  schema:description """someone who investigates news stories for newspapers, magazines or news
  websites"""@en ;
  dcterms:modified "2026-06-07T15:30:02.351275Z"^^xsd:dateTime .

oakcurric:keyword-immigration
  a curric:Keyword ;
  schema:name "immigration"@en ;
  schema:description "the act of moving into a new host location"@en ;
  dcterms:modified "2026-06-07T15:30:02.351691Z"^^xsd:dateTime .

oakcurric:keyword-emigration
  a curric:Keyword ;
  schema:name "emigration"@en ;
  schema:description "the act of moving out of a source location"@en ;
  dcterms:modified "2026-06-07T15:30:02.351695Z"^^xsd:dateTime .

oakcurric:keyword-asylum-seeker
  a curric:Keyword ;
  schema:name "asylum seeker"@en ;
  schema:description """someone who seeks permanent or temporary protection in another country from
  the persecution or danger they experience in their home country"""@en ;
  dcterms:modified "2026-06-07T15:30:02.351702Z"^^xsd:dateTime .

oakcurric:keyword-refugee
  a curric:Keyword ;
  schema:name "refugee"@en ;
  schema:description """someone who has successfully sought asylum in another country and is
  henceforth protected by international law"""@en ;
  dcterms:modified "2026-06-07T15:30:02.351707Z"^^xsd:dateTime .

oakcurric:keyword-community
  a curric:Keyword ;
  schema:name "community"@en ;
  schema:description "a group of people who share something in common"@en ;
  dcterms:modified "2026-06-07T15:30:02.352054Z"^^xsd:dateTime .

oakcurric:keyword-circular-economy
  a curric:Keyword ;
  schema:name "circular economy"@en ;
  schema:description """an economic system where products and materials are kept in circulation and
  do not become waste"""@en ;
  dcterms:modified "2026-06-07T15:30:02.352088Z"^^xsd:dateTime .

oakcurric:keyword-strategy
  a curric:Keyword ;
  schema:name "strategy"@en ;
  schema:description "a plan for achieving success"@en ;
  dcterms:modified "2026-06-07T15:30:02.352572Z"^^xsd:dateTime .

oakcurric:keyword-economy
  a curric:Keyword ;
  schema:name "economy"@en ;
  schema:description """economy is the way people, businesses and governments make and spend
  money"""@en ;
  dcterms:modified "2026-06-07T15:30:02.352604Z"^^xsd:dateTime .

oakcurric:keyword-universal
  a curric:Keyword ;
