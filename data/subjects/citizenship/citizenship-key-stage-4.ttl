# ----------------------------------------------------------------------
# Keywords
# ----------------------------------------------------------------------

oakcurric:keyword-stereotype
  a curric:Keyword ;
  schema:name "stereotype"@en ;
  schema:description "a simplified belief, view or representation of a group of people"@en ;
  dcterms:modified "2026-02-12T08:59:15.789366Z"^^xsd:dateTime .

oakcurric:keyword-campaign
  a curric:Keyword ;
  schema:name "campaign"@en ;
  schema:description "a series of military operations, usually with the aim of defeating an enemy"@en ;
  dcterms:modified "2026-02-12T08:59:15.789466Z"^^xsd:dateTime .

oakcurric:keyword-commonwealth
  a curric:Keyword ;
  schema:name "Commonwealth"@en ;
  schema:description """an international organisation consisting of states which once belonged to the British Empire"""@en ;
  dcterms:modified "2026-02-12T08:59:15.789500Z"^^xsd:dateTime .

oakcurric:keyword-empire
  a curric:Keyword ;
  schema:name "Empire"@en ;
  schema:description """An Empire is a group of countries ruled by a single person, government or country, e.g. The Roman Empire."""@en ;
  dcterms:modified "2026-02-12T08:59:15.789526Z"^^xsd:dateTime .

oakcurric:keyword-censorship
  a curric:Keyword ;
  schema:name "Censorship"@en ;
  schema:description """The act of preventing something from being seen or made available to the public for political reasons is known as censorship."""@en ;
  dcterms:modified "2026-02-12T08:59:15.789536Z"^^xsd:dateTime .

oakcurric:keyword-migration
  a curric:Keyword ;
  schema:name "migration"@en ;
  schema:description """the movement of people from one place to another, either within a country or between countries, often for economic, social, political or environmental reasons"""@en ;
  dcterms:modified "2026-02-12T08:59:15.789717Z"^^xsd:dateTime .

oakcurric:keyword-advocate
  a curric:Keyword ;
  schema:name "advocate"@en ;
  schema:description "to support or argue in favor of something or someone"@en ;
  dcterms:modified "2026-02-12T08:59:15.789986Z"^^xsd:dateTime .

oakcurric:keyword-government
  a curric:Keyword ;
  schema:name "government"@en ;
  schema:description "a government is a group of leaders who make laws and decisions for a country"@en ;
  dcterms:modified "2026-02-12T08:59:15.790003Z"^^xsd:dateTime .

oakcurric:keyword-refugee
  a curric:Keyword ;
  schema:name "refugee"@en ;
  schema:description """a refugee is a person who has been forced to leave their country in order to escape war, persecution or natural disaster"""@en ;
  dcterms:modified "2026-02-12T08:59:15.790020Z"^^xsd:dateTime .

oakcurric:keyword-method
  a curric:Keyword ;
  schema:name "method"@en ;
  schema:description """the tools a writer uses to create their work; structure, form and language are perhaps the most significant examples."""@en ;
  dcterms:modified "2026-02-12T08:59:15.790045Z"^^xsd:dateTime .

oakcurric:keyword-evaluate
  a curric:Keyword ;
  schema:name "evaluate"@en ;
  schema:description "to consider something carefully and make a judgement about it."@en ;
  dcterms:modified "2026-02-12T08:59:15.790049Z"^^xsd:dateTime .

oakcurric:keyword-prejudice
  a curric:Keyword ;
  schema:name "prejudice"@en ;
  schema:description "unfair or unreasonable opinions formed without thought or knowledge"@en ;
  dcterms:modified "2026-02-12T08:59:15.790131Z"^^xsd:dateTime .

oakcurric:keyword-discrimination
  a curric:Keyword ;
  schema:name "discrimination"@en ;
  schema:description """discrimination is the unjust treatment of a person or group of people, usually on the grounds of a physical quality or belief"""@en ;
  dcterms:modified "2026-02-12T08:59:15.790161Z"^^xsd:dateTime .

oakcurric:keyword-regeneration
  a curric:Keyword ;
  schema:name "regeneration"@en ;
  schema:description """investing money into poorer and derelict urban areas where there was once a sustainable economy in industry"""@en ;
  dcterms:modified "2026-02-12T08:59:15.790305Z"^^xsd:dateTime .

oakcurric:keyword-climate-change
  a curric:Keyword ;
  schema:name "climate change"@en ;
  schema:description "long-term shifts in temperatures and weather patterns"@en ;
  dcterms:modified "2026-02-12T08:59:15.790394Z"^^xsd:dateTime .

oakcurric:keyword-manifesto
  a curric:Keyword ;
  schema:name "manifesto"@en ;
  schema:description """a clear statement of beliefs, goals, or intentions, often published publicly by a person, group, or organisation"""@en ;
  dcterms:modified "2026-02-12T08:59:15.790750Z"^^xsd:dateTime .

oakcurric:keyword-gentrification
  a curric:Keyword ;
  schema:name "gentrification"@en ;
  schema:description """the upgrading of areas (typically housing) often in the inner city, making them more desirable but often more expensive"""@en ;
  dcterms:modified "2026-02-12T08:59:15.790889Z"^^xsd:dateTime .

oakcurric:keyword-analysis
  a curric:Keyword ;
  schema:name "analysis"@en ;
  schema:description """to unpick and examine a text in detail, considering a writer’s choice of language and intention"""@en ;
  dcterms:modified "2026-02-12T08:59:15.791021Z"^^xsd:dateTime .

oakcurric:keyword-alliance
  a curric:Keyword ;
  schema:name "alliance"@en ;
  schema:description """an agreement between countries or political parties to work together to achieve something"""@en ;
  dcterms:modified "2026-02-12T08:59:15.791082Z"^^xsd:dateTime .

oakcurric:keyword-direct-action
  a curric:Keyword ;
  schema:name "direct action"@en ;
  schema:description """direct action is the use of demonstrations or protests to achieve a goal, rather than negotiation"""@en ;
  dcterms:modified "2026-02-12T08:59:15.791094Z"^^xsd:dateTime .

oakcurric:keyword-immigration
  a curric:Keyword ;
  schema:name "immigration"@en ;
  schema:description "the act of moving into a new host location"@en ;
  dcterms:modified "2026-02-12T08:59:15.791133Z"^^xsd:dateTime .

oakcurric:keyword-emigration
  a curric:Keyword ;
  schema:name "emigration"@en ;
  schema:description "the act of moving out of a source location"@en ;
  dcterms:modified "2026-02-12T08:59:15.791137Z"^^xsd:dateTime .

oakcurric:keyword-asylum-seeker
  a curric:Keyword ;
  schema:name "asylum seeker"@en ;
  schema:description """someone who seeks permanent or temporary protection in another country from the persecution or danger they experience in their home country"""@en ;
  dcterms:modified "2026-02-12T08:59:15.791141Z"^^xsd:dateTime .

oakcurric:keyword-value
  a curric:Keyword ;
  schema:name "value"@en ;
  schema:description "how important an area is either socially, economically or environmentally"@en ;
  dcterms:modified "2026-02-12T08:59:15.791180Z"^^xsd:dateTime .

oakcurric:keyword-referendum
  a curric:Keyword ;
