# ----------------------------------------------------------------------
# Key Learning Points
# ----------------------------------------------------------------------

oakcurric:keylearningpoint-lesson-25239-1
  a curric:KeyLearningPoint ;
  rdfs:label """SDG progress has been slower than expected due to challenges like global events, political changes & economic setbacks."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483869Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25239-2
  a curric:KeyLearningPoint ;
  rdfs:label """Despite positive steps, such as renewable energy growth, the SDGs are not currently on track to meet their targets."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483873Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25239-3
  a curric:KeyLearningPoint ;
  rdfs:label """For LICs, climate action like transitioning to renewable energy takes up a large share of GDP, hindering development."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483879Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25214-1
  a curric:KeyLearningPoint ;
  rdfs:label """Migration is the movement of people from one place to another; the people who move are called migrants."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483884Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25214-2
  a curric:KeyLearningPoint ;
  rdfs:label """Migrants may be encouraged by pull factors, like economic opportunities, better climate, or better public services."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483888Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25214-3
  a curric:KeyLearningPoint ;
  rdfs:label """Migrants will have different experiences in the UK, some will be positive, but some will be negative."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483892Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25214-4
  a curric:KeyLearningPoint ;
  rdfs:label "In the UK, migrants are protected by laws such as the Equality Act (2010)."@en ;
  dcterms:modified "2026-02-12T08:59:21.483896Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25314-1
  a curric:KeyLearningPoint ;
  rdfs:label """An active citizenship project should connect to broader Citizenship concepts like democracy, law, rights and equality."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483962Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25314-2
  a curric:KeyLearningPoint ;
  rdfs:label """There are three stages in the active citizenship project cycle: planning, taking action and measuring impact."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483966Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25314-3
  a curric:KeyLearningPoint ;
  rdfs:label """Active citizens need a number of skills to carry out a successful active citizenship project."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483970Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25314-4
  a curric:KeyLearningPoint ;
  rdfs:label """Case studies are crucial for active citizenship as they give us a real-world, complete view of an issue."""@en ;
  dcterms:modified "2026-02-12T08:59:21.483976Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25361-1
  a curric:KeyLearningPoint ;
  rdfs:label """In the UK, powers are separated between the executive, legislative, and judiciary, the separation has evolved over time."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484312Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25361-2
  a curric:KeyLearningPoint ;
  rdfs:label """The Supreme Court is the highest court of appeal it ensures a separation of powers between legislative and judiciary."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484316Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25361-3
  a curric:KeyLearningPoint ;
  rdfs:label """The Supreme Court is the UK's final court of appeal for civil and criminal cases and interprets UK law."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484320Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25361-4
  a curric:KeyLearningPoint ;
  rdfs:label """The Supreme Court sets precedents, clarifies laws on important issues, and makes rulings on major political matters."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484324Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25380-1
  a curric:KeyLearningPoint ;
  rdfs:label """The UDHR and UNCRC establish international human rights standards recognised by the UK."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484479Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25380-2
  a curric:KeyLearningPoint ;
  rdfs:label """Acts like the Human Rights Act 1998 and Equality Act 2010 embed these international obligations into domestic law."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484483Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25380-3
  a curric:KeyLearningPoint ;
  rdfs:label """Individuals can seek redress through civil courts, employment tribunals, mediations or judicial review."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484487Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25380-4
  a curric:KeyLearningPoint ;
  rdfs:label """Additional support is available via independent bodies such as ombudsman services."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484494Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25380-5
  a curric:KeyLearningPoint ;
  rdfs:label """Rights breaches persist, highlighting limitations in access, enforcement and system effectiveness."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484498Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25257-1
  a curric:KeyLearningPoint ;
  rdfs:label """Migration to the UK is shaped by internal and international factors and measured in four key ways."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484558Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25257-2
  a curric:KeyLearningPoint ;
  rdfs:label """The Home Office manages migration to the UK through a points-based system, visas and border checks."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484564Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25257-3
  a curric:KeyLearningPoint ;
  rdfs:label """Border Force checks entry, while other agencies enforce rules on stay duration, activities and residency."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484568Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25257-4
  a curric:KeyLearningPoint ;
  rdfs:label """Migration to the UK brings both benefits and challenges, with government agencies working to balance these impacts."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484576Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25386-1
  a curric:KeyLearningPoint ;
  rdfs:label """The UK has an uncodified constitution, made up of laws, conventions and traditions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484653Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25386-2
  a curric:KeyLearningPoint ;
  rdfs:label "Parliamentary Sovereignty means Parliament can make or change any law."@en ;
  dcterms:modified "2026-02-12T08:59:21.484656Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25386-3
  a curric:KeyLearningPoint ;
  rdfs:label """The UK system is flexible and can respond quickly, like with the Online Safety Act 2023."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484660Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25386-4
  a curric:KeyLearningPoint ;
  rdfs:label """The US has a codified constitution, which is written in one document and harder to change."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484664Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25386-5
  a curric:KeyLearningPoint ;
  rdfs:label """The US is a federal system, so states control areas like education, unlike the UK's devolved system."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484668Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25192-1
  a curric:KeyLearningPoint ;
  rdfs:label "Citizen involvement in law can boost fairness, relatability and democracy."@en ;
  dcterms:modified "2026-02-12T08:59:21.484888Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25192-2
  a curric:KeyLearningPoint ;
  rdfs:label "Juries and magistrates can bring real-life views to legal decisions."@en ;
  dcterms:modified "2026-02-12T08:59:21.484892Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25192-3
  a curric:KeyLearningPoint ;
  rdfs:label """Special constables can help build trust within their communities, reducing crime and keeping people safe."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484896Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25192-4
  a curric:KeyLearningPoint ;
  rdfs:label "Legal complexity might sometimes confuse juries and untrained magistrates."@en ;
  dcterms:modified "2026-02-12T08:59:21.484900Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25192-5
  a curric:KeyLearningPoint ;
  rdfs:label """Citizens can push for law reform but may face hurdles, like with the proposed pro-legalisation of cannabis."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484904Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25260-1
  a curric:KeyLearningPoint ;
  rdfs:label """Everyone has the right to feel safe from harm or threat and enjoy a sense of belonging in their communities."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484950Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25260-2
  a curric:KeyLearningPoint ;
  rdfs:label """Communities are connected by shared goals and values which also form parts of a person's identity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484954Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25260-3
  a curric:KeyLearningPoint ;
  rdfs:label """A mix of education and legistlation are important aspects of ensuring respect and understanding in society."""@en ;
  dcterms:modified "2026-02-12T08:59:21.484958Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25178-1
  a curric:KeyLearningPoint ;
  rdfs:label "Human rights are basic freedoms everyone should have."@en ;
  dcterms:modified "2026-02-12T08:59:21.485139Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25178-2
  a curric:KeyLearningPoint ;
  rdfs:label """NGOs are groups that work independently from the Government to support a particular cause."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485143Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25178-3
  a curric:KeyLearningPoint ;
  rdfs:label """NGOs raise awareness, support victims and pressure governments to protect human rights globally."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485147Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25258-1
  a curric:KeyLearningPoint ;
  rdfs:label """The Windrush generation are migrants who were invited to the UK to help rebuild after World War Two."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485151Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25258-2
  a curric:KeyLearningPoint ;
  rdfs:label """Windrush migrants had legal rights but faced discrimination and wrongful treatment decades later."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485155Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25258-3
  a curric:KeyLearningPoint ;
  rdfs:label """Some people migrate to the UK as refugees, they may have UN support or come through UK resettlement schemes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485159Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25258-4
  a curric:KeyLearningPoint ;
  rdfs:label """Asylum seekers flee danger and seek protection in other countries; their claims may lead to refugee status."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485162Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25327-1
  a curric:KeyLearningPoint ;
  rdfs:label """Law enforcement refers to the people/groups that make sure everyone follows the laws in society."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485166Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25327-2
  a curric:KeyLearningPoint ;
  rdfs:label """Many people and organisations in England and Wales play a role in enforcing the law within the justice system."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485170Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25327-3
  a curric:KeyLearningPoint ;
  rdfs:label """Each group plays a key role in law enforcement; removing any would disrupt the system's efficiency."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485174Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25383-1
  a curric:KeyLearningPoint ;
  rdfs:label """Immigration and key historical events have significantly influenced the development of UK identity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485200Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25383-2
  a curric:KeyLearningPoint ;
  rdfs:label """Census data reveals a change towards greater religious and ethnic diversity, reflecting a more multicultural society."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485204Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25383-3
  a curric:KeyLearningPoint ;
  rdfs:label """Political events such as Brexit have altered how individuals perceive their national identity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485208Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25383-4
  a curric:KeyLearningPoint ;
  rdfs:label """Devolution has enabled nations to govern independently on certain issues, reinforcing distinct national identities."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485212Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25383-5
  a curric:KeyLearningPoint ;
  rdfs:label """These evolving identities affect public policy, political engagement and debates over the future structure of the UK."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485215Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25259-1
  a curric:KeyLearningPoint ;
  rdfs:label """Respect and understanding help people work together, feel safe and build inclusive communities."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485288Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25259-2
  a curric:KeyLearningPoint ;
  rdfs:label """The British values of democracy, rule of law, individual liberty, tolerance & mutual respect help shape a fair society."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485292Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25259-3
  a curric:KeyLearningPoint ;
  rdfs:label """Laws like the Human Rights Act and Equality Act protect rights and promote respect in society."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485297Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25259-4
  a curric:KeyLearningPoint ;
  rdfs:label """Hate crime laws make it illegal to target someone because of their identity, ensuring safety and fairness for all."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485302Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25382-1
  a curric:KeyLearningPoint ;
  rdfs:label """Parliamentary sovereignty grants the UK Parliament ultimate legal authority to enact or repeal laws."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485306Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25382-2
  a curric:KeyLearningPoint ;
  rdfs:label """Devolved governments in Scotland, Wales and Northern Ireland possess legislative powers over key areas, such as health."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485310Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25382-3
  a curric:KeyLearningPoint ;
  rdfs:label """Local governments influence daily life through the delivery of essential public services, including transport."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485314Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25382-4
  a curric:KeyLearningPoint ;
  rdfs:label """Media outlets, charities and NGOs play a significant role in influencing political discourse and public attitudes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485318Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25382-5
  a curric:KeyLearningPoint ;
  rdfs:label """Civic engagement, such as demonstrations and boycotts, enables individuals to influence democratic processes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485321Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25274-1
  a curric:KeyLearningPoint ;
  rdfs:label "A range of specfic skills are needed to be an active citizen and a changemaker."@en ;
  dcterms:modified "2026-02-12T08:59:21.485480Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25274-2
  a curric:KeyLearningPoint ;
  rdfs:label """Skills include communication, critical thinking, analysis, evaluation, research, teamwork, confidence and resilience."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485484Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25274-3
  a curric:KeyLearningPoint ;
  rdfs:label """They also include creating reasoned aruments, decision making, advocating for others and persuasion skills."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485490Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25274-4
  a curric:KeyLearningPoint ;
  rdfs:label "These skills all help active citizenship projects to be successful."@en ;
  dcterms:modified "2026-02-12T08:59:21.485494Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27988-1
  a curric:KeyLearningPoint ;
  rdfs:label """The UK’s departure from the EU was a lengthy and complex process.  It began with the triggering of Article 50."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485498Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27988-2
  a curric:KeyLearningPoint ;
  rdfs:label """Key Brexit issues: trade with the EU, financial settlement, and citizens' rights, including workers' rights."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485502Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27988-3
  a curric:KeyLearningPoint ;
  rdfs:label """Brexit’s close result caused disagreements in Parliament, leading some to call for a second referendum."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485506Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27988-4
  a curric:KeyLearningPoint ;
  rdfs:label """Britain experienced political instablity as a result of the referendum on leaving the EU."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485510Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25264-1
  a curric:KeyLearningPoint ;
  rdfs:label """Injustice can take many forms, such as discrimination, lack of access to education, or unfair treatment by authorities."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485552Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25264-2
  a curric:KeyLearningPoint ;
  rdfs:label """Human rights defenders are individuals or groups who work to protect and promote the human rights of others."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485556Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25264-3
  a curric:KeyLearningPoint ;
  rdfs:label """Duty bearers, such as a government have the responsibility to protect and uphold human rights."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485560Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25264-4
  a curric:KeyLearningPoint ;
  rdfs:label """Defenders use tools such as protest, social media, legal action, petitions, and education to challenge injustice."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485573Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25264-5
  a curric:KeyLearningPoint ;
  rdfs:label """Action can lead to real change by raising awareness, influencing law, or supporting those affected by injustice."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485578Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25256-1
  a curric:KeyLearningPoint ;
  rdfs:label """Regular and irregular migrants refer to different migration methods, based on legal or administrative processes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485657Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25256-2
  a curric:KeyLearningPoint ;
  rdfs:label """Asylum seekers and refugees are migrants seeking safety from persecution or danger in another country."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485661Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25256-3
  a curric:KeyLearningPoint ;
  rdfs:label """Migration push factors include war, natural disasters & persecution; pull factors include jobs, safety & opportunities."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485665Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25256-4
  a curric:KeyLearningPoint ;
  rdfs:label """Understanding push & pull factors can help governments create policies to improve living conditions & support migrants."""@en ;
  dcterms:modified "2026-02-12T08:59:21.485671Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25372-1
  a curric:KeyLearningPoint ;
  rdfs:label "The UK Prime Minister leads the government in the UK."@en ;
  dcterms:modified "2026-02-12T08:59:21.485851Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25372-2
  a curric:KeyLearningPoint ;
  rdfs:label "Some countries have leaders that are both head of state and government."@en ;
  dcterms:modified "2026-02-12T08:59:21.485855Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25357-1
  a curric:KeyLearningPoint ;
  rdfs:label """Traditional procedures are embedded in Parliament through the State Opening of Parliament and in the day-to-day running."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486031Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25357-2
  a curric:KeyLearningPoint ;
  rdfs:label """Some traditions in Parliament include: guards checking cellars, role of Black Rod, Speaker, prayers."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486035Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25357-3
  a curric:KeyLearningPoint ;
  rdfs:label """Some traditions could stay the same to celebrate history or could be modernised, like voting in Scottish Parliament."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486039Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25345-1
  a curric:KeyLearningPoint ;
  rdfs:label """The decline of the British Empire led to the creation of the modern Commonwealth."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486370Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25345-2
  a curric:KeyLearningPoint ;
  rdfs:label "The Commonwealth is not the same as an empire. It is a voluntary association."@en ;
  dcterms:modified "2026-02-12T08:59:21.486376Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25345-3
  a curric:KeyLearningPoint ;
  rdfs:label "The UK has played a leadership role in the Commonwealth since it was created."@en ;
  dcterms:modified "2026-02-12T08:59:21.486380Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25345-4
  a curric:KeyLearningPoint ;
  rdfs:label """The UK plays a key role in the Commonwealth but also faces challenges linked to its colonial past."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486384Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25261-1
  a curric:KeyLearningPoint ;
  rdfs:label """Speaking truth to power means challenging unfairness by sharing honest views with those in charge."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486934Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25261-2
  a curric:KeyLearningPoint ;
  rdfs:label """People in power include leaders, politicians, and organisations that can make or change rules."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486938Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25261-3
  a curric:KeyLearningPoint ;
  rdfs:label """Speeches and messages can be powerful tools to challenge injustice and raise awareness."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486964Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25261-4
  a curric:KeyLearningPoint ;
  rdfs:label "Speaking out helps influence change and can inspire others to take action too."@en ;
  dcterms:modified "2026-02-12T08:59:21.486968Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25350-1
  a curric:KeyLearningPoint ;
  rdfs:label """Identity consists of the qualities people have that make them different from others."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487036Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25350-2
  a curric:KeyLearningPoint ;
  rdfs:label """People’s identity can be shaped by many different factors. These factors can be separated into nature and nurture."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487040Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25350-3
  a curric:KeyLearningPoint ;
  rdfs:label """People can have multiple identities because different parts of who they are show up in different situations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487044Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25350-4
  a curric:KeyLearningPoint ;
  rdfs:label "People's identity can change because identity is fluid, not fixed."@en ;
  dcterms:modified "2026-02-12T08:59:21.487048Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25350-5
  a curric:KeyLearningPoint ;
  rdfs:label "With time, our views, values and beliefs may change because of our experiences."@en ;
  dcterms:modified "2026-02-12T08:59:21.487052Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25379-1
  a curric:KeyLearningPoint ;
  rdfs:label """Civil society includes voluntary & community organistions that work independently of the government to improve society."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487685Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25379-2
  a curric:KeyLearningPoint ;
  rdfs:label "Civil society supports through relief, aid and upholding rights."@en ;
  dcterms:modified "2026-02-12T08:59:21.487689Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25379-3
  a curric:KeyLearningPoint ;
  rdfs:label "Civil society holds power through research, campaigning and lobbying."@en ;
  dcterms:modified "2026-02-12T08:59:21.487693Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25366-1
  a curric:KeyLearningPoint ;
  rdfs:label """Everyone has the right to protest. This right is protected by law. However, restrictions can be placed on this right."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487968Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25366-2
  a curric:KeyLearningPoint ;
  rdfs:label """Organisations might use a range of different protest tactics to achieve their aims, some tactics break the law."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487996Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25366-3
  a curric:KeyLearningPoint ;
  rdfs:label """While protests are protected under law, they must find a balance with public safety and order regulations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.488001Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25172-1
  a curric:KeyLearningPoint ;
  rdfs:label """The Government uses population data to plan services and make fair, informed decisions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.488081Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25172-2
  a curric:KeyLearningPoint ;
  rdfs:label """Population data shows where people live, their age, background and what support they need."""@en ;
  dcterms:modified "2026-02-12T08:59:21.488084Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25172-3
  a curric:KeyLearningPoint ;
  rdfs:label """Political decisions have shaped how the UK population has grown and changed over time."""@en ;
  dcterms:modified "2026-02-12T08:59:21.488088Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25172-4
  a curric:KeyLearningPoint ;
  rdfs:label "Immigration laws have increased the population and made it more diverse."@en ;
  dcterms:modified "2026-02-12T08:59:21.488092Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25172-5
  a curric:KeyLearningPoint ;
  rdfs:label """Health, housing, and welfare laws have helped people live longer, creating an ageing population."""@en ;
  dcterms:modified "2026-02-12T08:59:21.488098Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25364-1
  a curric:KeyLearningPoint ;
  rdfs:label """Protests have led to significant changes, and usually address social, political, economic and environmental issues."""@en ;
  dcterms:modified "2026-02-12T08:59:21.488102Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25364-2
  a curric:KeyLearningPoint ;
  rdfs:label """Effective protests often involve large numbers of participants and sustained efforts over time."""@en ;
  dcterms:modified "2026-02-12T08:59:21.488106Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25364-3
  a curric:KeyLearningPoint ;
  rdfs:label """The success of a protest often depends on public support, media attention, and the clarity of its goals."""@en ;
  dcterms:modified "2026-02-12T08:59:21.488110Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25374-1
  a curric:KeyLearningPoint ;
  rdfs:label "The national government is overseen by the Prime Minister and Cabinet."@en ;
  dcterms:modified "2026-02-12T08:59:21.597170Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25374-2
  a curric:KeyLearningPoint ;
  rdfs:label """The main responsibilities of the national government are to oversee the UK economy and implement policies."""@en ;
  dcterms:modified "2026-02-12T08:59:21.597180Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25374-3
  a curric:KeyLearningPoint ;
  rdfs:label """The main responsibilities of local government are education, housing and public services."""@en ;
  dcterms:modified "2026-02-12T08:59:21.597190Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25374-4
  a curric:KeyLearningPoint ;
  rdfs:label """There are differences in geographical area, roles and responsibilities and decision-makers."""@en ;
  dcterms:modified "2026-02-12T08:59:21.597199Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25185-1
  a curric:KeyLearningPoint ;
  rdfs:label "The UDHR outlines fundamental rights for all."@en ;
  dcterms:modified "2026-02-12T08:59:21.597644Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25185-2
  a curric:KeyLearningPoint ;
  rdfs:label """The UDHR is not legally binding, so not all countries uphold these rights in practice."""@en ;
  dcterms:modified "2026-02-12T08:59:21.597653Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25185-3
  a curric:KeyLearningPoint ;
  rdfs:label "Human rights violations still exist."@en ;
  dcterms:modified "2026-02-12T08:59:21.597668Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25185-4
  a curric:KeyLearningPoint ;
  rdfs:label """International organisations help to raise awarenss and investigate issues of human rights violations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.597680Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27986-1
  a curric:KeyLearningPoint ;
  rdfs:label """Investment stimulates local economies by generating employment and attracting business activity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.599222Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27986-2
  a curric:KeyLearningPoint ;
  rdfs:label """Effective financial management enables investment in infrastructure, education and housing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.599231Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27986-3
  a curric:KeyLearningPoint ;
  rdfs:label """Financial mismanagement can result in reduced public services and weakened economic confidence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.599240Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27986-4
  a curric:KeyLearningPoint ;
  rdfs:label """Recent UK examples are: Sunderland’s regeneration, Cardiff’s commercial development and Croydon’s financial issues."""@en ;
  dcterms:modified "2026-02-12T08:59:21.599249Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27986-5
  a curric:KeyLearningPoint ;
  rdfs:label """The impact of finance on communities is determined by the quality and focus of financial decision making."""@en ;
  dcterms:modified "2026-02-12T08:59:21.599257Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25179-1
  a curric:KeyLearningPoint ;
  rdfs:label """NGOs are groups that work independently from the Government to support a particular cause."""@en ;
  dcterms:modified "2026-02-12T08:59:21.599647Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25179-2
  a curric:KeyLearningPoint ;
  rdfs:label """International agencies are organisations formed between countries to address global issues and promote cooperation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.599656Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25179-3
  a curric:KeyLearningPoint ;
  rdfs:label """NGOs provide expert knowledge; international agencies have global reach and political power."""@en ;
  dcterms:modified "2026-02-12T08:59:21.599665Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25179-4
  a curric:KeyLearningPoint ;
  rdfs:label """NGOs and agencies cooperate via research, advocacy and policy influence to solve global issues."""@en ;
  dcterms:modified "2026-02-12T08:59:21.599674Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25179-5
  a curric:KeyLearningPoint ;
  rdfs:label """Collaboration helps hold governments accountable, ensuring transparency and policy enforcement."""@en ;
  dcterms:modified "2026-02-12T08:59:21.599682Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25363-1
  a curric:KeyLearningPoint ;
  rdfs:label "The right to protest is a fundamental aspect of democratic participation."@en ;
  dcterms:modified "2026-02-12T08:59:21.600051Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25363-2
  a curric:KeyLearningPoint ;
  rdfs:label "Protests can take many forms, including marches, sit-ins, and online activism."@en ;
  dcterms:modified "2026-02-12T08:59:21.600060Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25363-3
  a curric:KeyLearningPoint ;
  rdfs:label """In a democracy, peaceful protest is an important mechanism to hold those in power accountable."""@en ;
  dcterms:modified "2026-02-12T08:59:21.600069Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25363-4
  a curric:KeyLearningPoint ;
  rdfs:label """Legal frameworks, such as public order laws, ensure protests remain peaceful and within the bounds of the law."""@en ;
  dcterms:modified "2026-02-12T08:59:21.600077Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25268-1
  a curric:KeyLearningPoint ;
  rdfs:label "UK Parliament is made up of three parts."@en ;
  dcterms:modified "2026-02-12T08:59:21.614248Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25268-2
  a curric:KeyLearningPoint ;
  rdfs:label "The government is formed after a general election."@en ;
  dcterms:modified "2026-02-12T08:59:21.614255Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25268-3
  a curric:KeyLearningPoint ;
  rdfs:label """The main political parties in the UK  are Conservatives, Labour, Liberal Democrats and the SNP."""@en ;
  dcterms:modified "2026-02-12T08:59:21.614295Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25268-4
  a curric:KeyLearningPoint ;
  rdfs:label """Political parties and APPGs support democracy by offering choices and representing diverse views."""@en ;
  dcterms:modified "2026-02-12T08:59:21.614304Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25329-1
  a curric:KeyLearningPoint ;
  rdfs:label """Youth courts handle 10-17-year-olds and have different processes to adult court. Some cases are sent to the crown court."""@en ;
  dcterms:modified "2026-02-12T08:59:21.615361Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25329-2
  a curric:KeyLearningPoint ;
  rdfs:label """Youth courts balance punishment with safeguarding the welfare of the child and preventing re-offending."""@en ;
  dcterms:modified "2026-02-12T08:59:21.615368Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25329-3
  a curric:KeyLearningPoint ;
  rdfs:label """Differences include: courtroom layout, less formal proceedings, reporting restrictons and additonal checks."""@en ;
  dcterms:modified "2026-02-12T08:59:21.615375Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25329-4
  a curric:KeyLearningPoint ;
  rdfs:label """Due to devolution, England and Wales have a separate criminal justice system, including youth justice, from Scotland."""@en ;
  dcterms:modified "2026-02-12T08:59:21.615382Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25353-1
  a curric:KeyLearningPoint ;
  rdfs:label """The UK has come to be one of the most diverse states in Europe.  This is largely due to historical migration."""@en ;
  dcterms:modified "2026-02-12T08:59:21.617389Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25353-2
  a curric:KeyLearningPoint ;
  rdfs:label """Migration over centuries from different groups and events has shaped the UK’s diverse society today."""@en ;
  dcterms:modified "2026-02-12T08:59:21.617396Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25353-3
  a curric:KeyLearningPoint ;
  rdfs:label """There are many benefits to migration to the UK, including exposure to diverse cultures and rich cultural diversity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.617402Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25353-4
  a curric:KeyLearningPoint ;
  rdfs:label """However, there are also challenges, including discrimination and difficulties in integrating into communities."""@en ;
  dcterms:modified "2026-02-12T08:59:21.617409Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25320-1
  a curric:KeyLearningPoint ;
  rdfs:label """A democracy is a type of government where the citizens are involved in decision making"""@en ;
  dcterms:modified "2026-02-12T08:59:21.617415Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25320-2
  a curric:KeyLearningPoint ;
  rdfs:label """Key features of a democracy include free and fair elections, multi party system and protection of human rights"""@en ;
  dcterms:modified "2026-02-12T08:59:21.617422Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25320-3
  a curric:KeyLearningPoint ;
  rdfs:label """The are different categories of democracy around the world including: full democracy, flawed democracy and hybrid regime"""@en ;
  dcterms:modified "2026-02-12T08:59:21.617428Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25250-1
  a curric:KeyLearningPoint ;
  rdfs:label """Conflicts happen for a range of reasons including; economic, religious and political."""@en ;
  dcterms:modified "2026-02-12T08:59:21.617435Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25250-2
  a curric:KeyLearningPoint ;
  rdfs:label """Conflicts can grow from small, national issues to regional and even global issues."""@en ;
  dcterms:modified "2026-02-12T08:59:21.617441Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25250-3
  a curric:KeyLearningPoint ;
  rdfs:label """Recent examples of global conflict include the Russo-Ukrainian War and the Israeli-Palestinian conflict."""@en ;
  dcterms:modified "2026-02-12T08:59:21.617448Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25250-4
  a curric:KeyLearningPoint ;
  rdfs:label """Countries can respond to global conflicts through diplomatic actions, economic measures, and military support."""@en ;
  dcterms:modified "2026-02-12T08:59:21.617473Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25250-5
  a curric:KeyLearningPoint ;
  rdfs:label """The UK has used financial aid, arms sales, and diplomacy to respond to global conflicts."""@en ;
  dcterms:modified "2026-02-12T08:59:21.617479Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25212-1
  a curric:KeyLearningPoint ;
  rdfs:label """British people share a set of values which are called fundamental British values."""@en ;
  dcterms:modified "2026-02-12T08:59:21.617770Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25212-2
  a curric:KeyLearningPoint ;
  rdfs:label "There are five British values which come from our shared history and customs."@en ;
  dcterms:modified "2026-02-12T08:59:21.617776Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25212-3
  a curric:KeyLearningPoint ;
  rdfs:label """Public sector organisations have a duty to promote British values and this is done in numerous different ways."""@en ;
  dcterms:modified "2026-02-12T08:59:21.617782Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25212-4
  a curric:KeyLearningPoint ;
  rdfs:label """Not all people within British society will agree with the fundamental British values."""@en ;
  dcterms:modified "2026-02-12T08:59:21.617788Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25365-1
  a curric:KeyLearningPoint ;
  rdfs:label "Ordinary citizens can play a part in positive change."@en ;
  dcterms:modified "2026-02-12T08:59:21.618745Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25365-2
  a curric:KeyLearningPoint ;
  rdfs:label "Change can take time and it can have a local, national or international impact."@en ;
  dcterms:modified "2026-02-12T08:59:21.618752Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25365-3
  a curric:KeyLearningPoint ;
  rdfs:label "To create our own change, we need to be active citizens."@en ;
  dcterms:modified "2026-02-12T08:59:21.618758Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25217-1
  a curric:KeyLearningPoint ;
  rdfs:label """You can have multiple identities. For example, a personal identity, a group identity and a national identity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.618837Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25217-2
  a curric:KeyLearningPoint ;
  rdfs:label """British values are part of our national identity. The Government have stated there are five fundamental British values."""@en ;
  dcterms:modified "2026-02-12T08:59:21.618843Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25217-3
  a curric:KeyLearningPoint ;
  rdfs:label """Our rights change depending on our maturity. As citizens grow older, they are given more rights."""@en ;
  dcterms:modified "2026-02-12T08:59:21.618852Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25217-4
  a curric:KeyLearningPoint ;
  rdfs:label "Everyone has rights, regardless of their citizenship status."@en ;
  dcterms:modified "2026-02-12T08:59:21.618859Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25217-5
  a curric:KeyLearningPoint ;
  rdfs:label """There are arguments both for and against the idea that our identity affects our rights."""@en ;
  dcterms:modified "2026-02-12T08:59:21.618865Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25211-1
  a curric:KeyLearningPoint ;
  rdfs:label """Britain has benefited from migration throughout its history. From the Angles, Saxons and Jutes to Windrush."""@en ;
  dcterms:modified "2026-02-12T08:59:21.619241Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25211-2
  a curric:KeyLearningPoint ;
  rdfs:label """The United Kingdom is made up of four nations: England, Scotland, Wales and Northern Ireland."""@en ;
  dcterms:modified "2026-02-12T08:59:21.619247Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25211-3
  a curric:KeyLearningPoint ;
  rdfs:label """Each of these countries have their own political assemblies, cultures and language, but they form the United Kingdom."""@en ;
  dcterms:modified "2026-02-12T08:59:21.619253Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25211-4
  a curric:KeyLearningPoint ;
  rdfs:label "Stereotypes are simplified views of people. They can be positive or negative."@en ;
  dcterms:modified "2026-02-12T08:59:21.619259Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25211-5
  a curric:KeyLearningPoint ;
  rdfs:label "Prejudice and discrimination can occur because of stereotypes."@en ;
  dcterms:modified "2026-02-12T08:59:21.619266Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25352-1
  a curric:KeyLearningPoint ;
  rdfs:label """Since the 1950s, the UK's population has grown steadily, increasing from about 50 million to 69.5 million in 2025."""@en ;
  dcterms:modified "2026-02-12T08:59:21.623788Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25352-2
  a curric:KeyLearningPoint ;
  rdfs:label """The UK now has an ageing population, is more religiously and ethnically diverse and more people identify as disabled."""@en ;
  dcterms:modified "2026-02-12T08:59:21.623794Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25352-3
  a curric:KeyLearningPoint ;
  rdfs:label """An increasing and changing population has an impact on the public services the Government provides."""@en ;
  dcterms:modified "2026-02-12T08:59:21.623802Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25352-4
  a curric:KeyLearningPoint ;
  rdfs:label """It is important to understand population changes so Government can make better policies and support everyone’s needs."""@en ;
  dcterms:modified "2026-02-12T08:59:21.623808Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25351-1
  a curric:KeyLearningPoint ;
  rdfs:label """British identity is complex, diverse and shaped by history, culture and politics."""@en ;
  dcterms:modified "2026-02-12T08:59:21.624527Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25351-2
  a curric:KeyLearningPoint ;
  rdfs:label """British values developed over time, promoting democracy, law, liberty, respect and tolerance for all."""@en ;
  dcterms:modified "2026-02-12T08:59:21.624532Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25351-3
  a curric:KeyLearningPoint ;
  rdfs:label """British values are debated in politics, schools, media and communities as society changes and faces challenges."""@en ;
  dcterms:modified "2026-02-12T08:59:21.624538Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25356-1
  a curric:KeyLearningPoint ;
  rdfs:label """The House of Commons is set up in a rectangle shape and has opposing sides face each other."""@en ;
  dcterms:modified "2026-02-12T08:59:21.625384Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25356-2
  a curric:KeyLearningPoint ;
  rdfs:label """The debating chambers of Scottish and Welsh Parliament / Senedd are both laid out differently to the House of Commons."""@en ;
  dcterms:modified "2026-02-12T08:59:21.625389Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25356-3
  a curric:KeyLearningPoint ;
  rdfs:label """The House of Commons has a traditional layout and others follow a more modern layout."""@en ;
  dcterms:modified "2026-02-12T08:59:21.625395Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25215-1
  a curric:KeyLearningPoint ;
  rdfs:label """There are many push factors that might force someone to leave their home e.g. climate, fear of persecution and war."""@en ;
  dcterms:modified "2026-02-12T08:59:21.625780Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25215-2
  a curric:KeyLearningPoint ;
  rdfs:label """Asylum seekers are formally seeking protection from another country. Not all asylum applications are granted."""@en ;
  dcterms:modified "2026-02-12T08:59:21.625786Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25215-3
  a curric:KeyLearningPoint ;
  rdfs:label """The process of seeking asylum can be lengthy. Asylum seekers have access to some support during this time."""@en ;
  dcterms:modified "2026-02-12T08:59:21.625791Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25215-4
  a curric:KeyLearningPoint ;
  rdfs:label "Asylum seekers and refugees can experience both support and hostility."@en ;
  dcterms:modified "2026-02-12T08:59:21.625796Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25346-1
  a curric:KeyLearningPoint ;
  rdfs:label """The WTO ensures fair trade by creating rules, transparency and providing a platform for global discussions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.675940Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25346-2
  a curric:KeyLearningPoint ;
  rdfs:label """The WTO works to prevent trade conflicts by supporting regulation and promoting open, fair trade practices."""@en ;
  dcterms:modified "2026-02-12T08:59:21.675944Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25346-3
  a curric:KeyLearningPoint ;
  rdfs:label """The WTO has 166 members, with the Ministerial Conference at the top and the General Council managing daily operations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.675948Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25346-4
  a curric:KeyLearningPoint ;
  rdfs:label """The UK plays a key role in the WTO by contributing to its budget and shaping fair global trade policies."""@en ;
  dcterms:modified "2026-02-12T08:59:21.675953Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25368-1
  a curric:KeyLearningPoint ;
  rdfs:label "Democratic governments have free, fair elections and citizen participation."@en ;
  dcterms:modified "2026-02-12T08:59:21.676092Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25368-2
  a curric:KeyLearningPoint ;
  rdfs:label "Non-democratic governments limit political freedom and control powers."@en ;
  dcterms:modified "2026-02-12T08:59:21.676097Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25368-3
  a curric:KeyLearningPoint ;
  rdfs:label """Democratic governments choose their leaders whereas non-democratic governments might not."""@en ;
  dcterms:modified "2026-02-12T08:59:21.676101Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25330-1
  a curric:KeyLearningPoint ;
  rdfs:label """The five purposes of sentencing are to punish, reduce crime, reform, protect the public, and offer reparation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.676517Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25330-2
  a curric:KeyLearningPoint ;
  rdfs:label """There are different types of sentences: discharge, fine, community sentence, and custodial sentence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.676522Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25330-3
  a curric:KeyLearningPoint ;
  rdfs:label """Judges decide sentences based on Sentencing Council guidelines, considering both aggravating and mitigating factors."""@en ;
  dcterms:modified "2026-02-12T08:59:21.676529Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25330-4
  a curric:KeyLearningPoint ;
  rdfs:label "Parliament creates laws that set maximum and minimum sentences for crimes."@en ;
  dcterms:modified "2026-02-12T08:59:21.676533Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25230-1
  a curric:KeyLearningPoint ;
  rdfs:label """That digital media is a new media type which is interactive, quick and uses technology."""@en ;
  dcterms:modified "2026-02-12T08:59:21.680358Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25230-2
  a curric:KeyLearningPoint ;
  rdfs:label """Digital media is self-regulated, with each platform setting its own guidelines. Checking takes place after publication."""@en ;
  dcterms:modified "2026-02-12T08:59:21.680362Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25230-3
  a curric:KeyLearningPoint ;
  rdfs:label """Whereas traditional media is centrally regulated and rigorous checks happen before publication."""@en ;
  dcterms:modified "2026-02-12T08:59:21.680367Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25358-1
  a curric:KeyLearningPoint ;
  rdfs:label """There are two types of constituition codified and uncodified. The UK has an uncodified constitution."""@en ;
  dcterms:modified "2026-02-12T08:59:21.682979Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25358-2
  a curric:KeyLearningPoint ;
  rdfs:label """The UK constitution is shaped by many different documents e.g. Magna Carta and the Bill of Rights."""@en ;
  dcterms:modified "2026-02-12T08:59:21.682983Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25358-3
  a curric:KeyLearningPoint ;
  rdfs:label """An advantage of an uncodified constitution is it is more flexible. A disadvantage is it can seem more complicated."""@en ;
  dcterms:modified "2026-02-12T08:59:21.682988Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25189-1
  a curric:KeyLearningPoint ;
  rdfs:label """Trade unions are groups of workers who protect rights and improve pay and conditions through collective bargaining."""@en ;
  dcterms:modified "2026-02-12T08:59:21.688444Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25189-2
  a curric:KeyLearningPoint ;
  rdfs:label """The relationship between trade unions and government has changed, from collaboration in 1871 to conflict in the 1980s."""@en ;
  dcterms:modified "2026-02-12T08:59:21.688448Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25189-3
  a curric:KeyLearningPoint ;
  rdfs:label """Trade unions have influenced workplace laws, including minimum wage, equality, and health and safety regulations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.688453Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25189-4
  a curric:KeyLearningPoint ;
  rdfs:label """Unions continue to lobby for stronger worker protections and push for improved workplace legislation today."""@en ;
  dcterms:modified "2026-02-12T08:59:21.688457Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25242-1
  a curric:KeyLearningPoint ;
  rdfs:label "Direct democracy allows citizens to participate directly in decisions."@en ;
  dcterms:modified "2026-02-12T08:59:21.698805Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25242-2
  a curric:KeyLearningPoint ;
  rdfs:label """Direct democracy can happen through the use of referendums or types of citizens' initiatives."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698810Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25242-3
  a curric:KeyLearningPoint ;
  rdfs:label "Direct democracy exists regularly in Switzerland."@en ;
  dcterms:modified "2026-02-12T08:59:21.698814Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25242-4
  a curric:KeyLearningPoint ;
  rdfs:label """Some representative democracies occasionally use forms of direct democracy such as the UK, US and New Zealand."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698819Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25242-5
  a curric:KeyLearningPoint ;
  rdfs:label "Direct democracy can be costly and timely due to running regular referendums."@en ;
  dcterms:modified "2026-02-12T08:59:21.698823Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27989-1
  a curric:KeyLearningPoint ;
  rdfs:label """Following the 2016 EU referendum, the UK left the EU on 31 Jan 2020, entering a transition until 31 Dec 2020."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698828Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27989-2
  a curric:KeyLearningPoint ;
  rdfs:label """Since the UK left the EU, there have been many debates about the benefits and challenges of Brexit."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698835Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27989-3
  a curric:KeyLearningPoint ;
  rdfs:label """Benefits and challenges include impacts on the economy, UK control, sovereignty and national identity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698842Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25385-1
  a curric:KeyLearningPoint ;
  rdfs:label """The UK is part of key international organisations such as the UN, NATO, WTO, the Commonwealth."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698869Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25385-2
  a curric:KeyLearningPoint ;
  rdfs:label """International organisations help with peace, defence, trade and development, both nationally and globally."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698874Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25385-3
  a curric:KeyLearningPoint ;
  rdfs:label """Membership gives the UK benefits like influence, trade access, defence support and military training."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698878Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25385-4
  a curric:KeyLearningPoint ;
  rdfs:label """The UK also has obligations, like paying membership fees,  following rules and upholding shared values."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698882Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25385-5
  a curric:KeyLearningPoint ;
  rdfs:label """Working with others through collaboration helps the UK stay safe and respected in the global community."""@en ;
  dcterms:modified "2026-02-12T08:59:21.698887Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25193-1
  a curric:KeyLearningPoint ;
  rdfs:label """A crime occurs when an illegal act, punishable by law, is committed, regardless of whether it's seen as immoral or not."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704766Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25193-2
  a curric:KeyLearningPoint ;
  rdfs:label """Crime rates fluctuate due to factors like legal changes, technological advances and shifts in societal structures."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704771Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25193-3
  a curric:KeyLearningPoint ;
  rdfs:label """Society has systems in place that aim to reduce crime such as education, crime deterrents and adapting the law."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704775Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25355-1
  a curric:KeyLearningPoint ;
  rdfs:label """Integration fosters unity by encouraging mixing and shared values while respecting cultural identities."""@en ;
  dcterms:modified "2026-02-12T08:59:21.706318Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25355-2
  a curric:KeyLearningPoint ;
  rdfs:label """Unity in a diverse society means that people from different backgrounds can work together to create community cohesion."""@en ;
  dcterms:modified "2026-02-12T08:59:21.706322Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25355-3
  a curric:KeyLearningPoint ;
  rdfs:label """Benefits of diversity include creativity, understanding and stronger communities."""@en ;
  dcterms:modified "2026-02-12T08:59:21.706327Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25355-4
  a curric:KeyLearningPoint ;
  rdfs:label """Challenges to unity can arise from misunderstandings, clashing values and social divisions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.706331Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25309-1
  a curric:KeyLearningPoint ;
  rdfs:label """That media has regulations that it must follow to ensure accuracy, fairness and accountability."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707036Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25309-2
  a curric:KeyLearningPoint ;
  rdfs:label """Journalists agree to a code of conduct when they join the national journalist union, this includes moral values."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707041Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25309-3
  a curric:KeyLearningPoint ;
  rdfs:label """The Editors' Code of Practice is enforced by IPSO, an external independent organisation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707045Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25309-4
  a curric:KeyLearningPoint ;
  rdfs:label """The Royal Charter sets the BBC's responsibilities which are based on being educational, informative and impartial."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707050Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27981-1
  a curric:KeyLearningPoint ;
  rdfs:label """Retirement requires careful financial preparation to ensure a stable income after paid work ends."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707119Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27981-2
  a curric:KeyLearningPoint ;
  rdfs:label """Effective planning includes using workplace pensions, ISAs and personal financial strategies."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707123Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27981-3
  a curric:KeyLearningPoint ;
  rdfs:label """The Government provides support through the State Pension and additional benefits such as Pension Credit."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707128Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27981-4
  a curric:KeyLearningPoint ;
  rdfs:label """Retirees may also access healthcare and social support through the NHS and local government services."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707132Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27981-5
  a curric:KeyLearningPoint ;
  rdfs:label """In the context of an ageing population, proactive financial planning enhances security and independence in later life."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707137Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25354-1
  a curric:KeyLearningPoint ;
  rdfs:label """Both mutual respect and tolerance are essential to building a cohesive and inclusive community."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707291Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25354-2
  a curric:KeyLearningPoint ;
  rdfs:label """Mutual respect and tolerance help diverse communities live peacefully and reduce discrimination and inequality."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707295Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25354-3
  a curric:KeyLearningPoint ;
  rdfs:label """Mutual respect supports democratic values like participation, open debate and inclusion in diverse societies."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707300Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25354-4
  a curric:KeyLearningPoint ;
  rdfs:label """UK law protects against discrimination, supports people’s rights and freedoms and promotes inclusion and fairness."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707305Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25228-1
  a curric:KeyLearningPoint ;
  rdfs:label """We can protect oursleves from misinformation by checking the source for a history of false or biased information."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707328Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25228-2
  a curric:KeyLearningPoint ;
  rdfs:label """We can also compare sources to see if the facts match; as well as consider why the story was written and if it's fair."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707332Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25228-3
  a curric:KeyLearningPoint ;
  rdfs:label "We should also be aware of emotions used to influence opinions within the story."@en ;
  dcterms:modified "2026-02-12T08:59:21.707337Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25228-4
  a curric:KeyLearningPoint ;
  rdfs:label """A media story goes through many checks as it's developed, but mistakes can still be made causing misinformation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707341Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25331-1
  a curric:KeyLearningPoint ;
  rdfs:label "The justice system does not treat young people the same as adults."@en ;
  dcterms:modified "2026-02-12T08:59:21.707817Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25331-2
  a curric:KeyLearningPoint ;
  rdfs:label """In the justice system, police interact with young offenders but also have broader responsibilities for all young people."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707821Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25331-3
  a curric:KeyLearningPoint ;
  rdfs:label """All citizens, including young people, have the right to share their opinions on laws and issues and push for change."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707826Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25331-4
  a curric:KeyLearningPoint ;
  rdfs:label """There are various arguments for and against the effectiveness of the legal system."""@en ;
  dcterms:modified "2026-02-12T08:59:21.707831Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25324-1
  a curric:KeyLearningPoint ;
  rdfs:label """In the UK the type of democracy used is representative democracy. It involves electing MPs to act upon citizens' behalf."""@en ;
  dcterms:modified "2026-02-12T08:59:21.708707Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25324-2
  a curric:KeyLearningPoint ;
  rdfs:label """Democracy can be improved in the UK by improving representation in Parliament and participation from electorates."""@en ;
  dcterms:modified "2026-02-12T08:59:21.708712Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25336-1
  a curric:KeyLearningPoint ;
  rdfs:label """Local government deliver essential public services, including education, social care and waste management."""@en ;
  dcterms:modified "2026-02-12T08:59:21.708716Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25336-2
  a curric:KeyLearningPoint ;
  rdfs:label """Local councils are funded through government grants, business rates, Council Tax contributions and fees and fines."""@en ;
  dcterms:modified "2026-02-12T08:59:21.708723Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25336-3
  a curric:KeyLearningPoint ;
  rdfs:label """A key financial challenge for local government is the reduction of central government funding."""@en ;
  dcterms:modified "2026-02-12T08:59:21.708728Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25336-4
  a curric:KeyLearningPoint ;
  rdfs:label """Increased demand for public services intensifies fiscal pressure on council budgets."""@en ;
  dcterms:modified "2026-02-12T08:59:21.708732Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25336-5
  a curric:KeyLearningPoint ;
  rdfs:label """Local councils also contend with revenue uncertainty from business rates and restricted income-generating powers."""@en ;
  dcterms:modified "2026-02-12T08:59:21.708737Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25224-1
  a curric:KeyLearningPoint ;
  rdfs:label """Some of the types of power within society include: political power, legal power, media power and hard power."""@en ;
  dcterms:modified "2026-02-12T08:59:21.708742Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25224-2
  a curric:KeyLearningPoint ;
  rdfs:label """Types of influence within society include: political influence, legal influence, media influence and social influence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.708746Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25224-3
  a curric:KeyLearningPoint ;
  rdfs:label """Some people may argue that power is needed to influence others, as this can give you status, notoriety and popularity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.708753Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25224-4
  a curric:KeyLearningPoint ;
  rdfs:label """Other people think that power is not needed to be influential as there are lots of normal influential people."""@en ;
  dcterms:modified "2026-02-12T08:59:21.708757Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25197-1
  a curric:KeyLearningPoint ;
  rdfs:label """Different countries use different sentencing guidelines, some are rehabilitation focused others are retribution focused."""@en ;
  dcterms:modified "2026-02-12T08:59:21.708762Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25197-2
  a curric:KeyLearningPoint ;
  rdfs:label """Scotland uses a different legal system to England and Wales and therefore has different sentencing guidelines."""@en ;
  dcterms:modified "2026-02-12T08:59:21.708767Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25197-3
  a curric:KeyLearningPoint ;
  rdfs:label """Custodial sentencing exists everywhere but can look very different, e.g. Norweigan prisons are theraputic and home-like."""@en ;
  dcterms:modified "2026-02-12T08:59:21.708772Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25197-4
  a curric:KeyLearningPoint ;
  rdfs:label """Youth justice is different depending on the country and how they view culpability for this age."""@en ;
  dcterms:modified "2026-02-12T08:59:21.708776Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25266-1
  a curric:KeyLearningPoint ;
  rdfs:label """Injustice occurs when individuals or groups are denied fair treatment or basic rights."""@en ;
  dcterms:modified "2026-02-12T08:59:21.709445Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25266-2
  a curric:KeyLearningPoint ;
  rdfs:label """Anyone can challenge injustice, even through small actions like reporting unfair treatment at school."""@en ;
  dcterms:modified "2026-02-12T08:59:21.709449Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25266-3
  a curric:KeyLearningPoint ;
  rdfs:label """Not all injustice needs a big campaign — standing up for someone being treated unfairly is also action."""@en ;
  dcterms:modified "2026-02-12T08:59:21.709456Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25248-1
  a curric:KeyLearningPoint ;
  rdfs:label """The UK is a representative democracy but still involves citizens in the decision making process."""@en ;
  dcterms:modified "2026-02-12T08:59:21.709880Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25248-2
  a curric:KeyLearningPoint ;
  rdfs:label """The UK invovles citizens through the use of refernedums, select committees and citizens' assemblies."""@en ;
  dcterms:modified "2026-02-12T08:59:21.709885Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25248-3
  a curric:KeyLearningPoint ;
  rdfs:label """Involving citizens in the decision making process gives people a voice and ensures a wider range of views are heard."""@en ;
  dcterms:modified "2026-02-12T08:59:21.709889Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25248-4
  a curric:KeyLearningPoint ;
  rdfs:label """The UK Government might not involve citizens in decisions that are complex or need to be made quickly such as crises."""@en ;
  dcterms:modified "2026-02-12T08:59:21.709894Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25317-1
  a curric:KeyLearningPoint ;
  rdfs:label """Research analysis in the active citizenship project planning stage ensures informed decisions before taking action."""@en ;
  dcterms:modified "2026-02-12T08:59:21.711542Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25317-2
  a curric:KeyLearningPoint ;
  rdfs:label """Analysis involves identifying findings, exploring cause and effect, checking reliability, and drawing conclusions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.711547Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25317-3
  a curric:KeyLearningPoint ;
  rdfs:label """Action plans are created after research analysis, setting a goal, outlining tasks, and setting deadlines for progress."""@en ;
  dcterms:modified "2026-02-12T08:59:21.711551Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25317-4
  a curric:KeyLearningPoint ;
  rdfs:label """Action plans must be regularly reviewed and adjusted to stay effective and address challenges in the project."""@en ;
  dcterms:modified "2026-02-12T08:59:21.711555Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25313-1
  a curric:KeyLearningPoint ;
  rdfs:label "A deliberative discussion is well planned and respectful, it's not an argument."@en ;
  dcterms:modified "2026-02-12T08:59:21.711560Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25313-2
  a curric:KeyLearningPoint ;
  rdfs:label """Holding someone or something to account means they are being scrutinised and are responsible for their actions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.711566Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25313-3
  a curric:KeyLearningPoint ;
  rdfs:label """People in power must be held to account due to the responsibility trum e.g. politicians are trusted to represent us."""@en ;
  dcterms:modified "2026-02-12T08:59:21.711571Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25313-4
  a curric:KeyLearningPoint ;
  rdfs:label "Media holds those in power to account but there are limitations to this."@en ;
  dcterms:modified "2026-02-12T08:59:21.711576Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25284-1
  a curric:KeyLearningPoint ;
  rdfs:label """A portion of our earnings is deducted by the Government for taxes like Income Tax and National Insurance."""@en ;
  dcterms:modified "2026-02-12T08:59:21.711580Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25284-2
  a curric:KeyLearningPoint ;
  rdfs:label """The amount of government deductions is shown to us on our payslip. This will show other deducations too such as pension."""@en ;
  dcterms:modified "2026-02-12T08:59:21.711585Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25284-3
  a curric:KeyLearningPoint ;
  rdfs:label "Income Tax is a progressive tax whereas National Insurance is a regressive tax."@en ;
  dcterms:modified "2026-02-12T08:59:21.711589Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25174-1
  a curric:KeyLearningPoint ;
  rdfs:label "National government makes laws and policies that local governments must follow."@en ;
  dcterms:modified "2026-02-12T08:59:21.711621Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25174-2
  a curric:KeyLearningPoint ;
  rdfs:label "Local councils rely on funding and powers given by national government."@en ;
  dcterms:modified "2026-02-12T08:59:21.711626Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25174-3
  a curric:KeyLearningPoint ;
  rdfs:label "Local councils deliver services and report local issues to national government."@en ;
  dcterms:modified "2026-02-12T08:59:21.711631Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25174-4
  a curric:KeyLearningPoint ;
  rdfs:label "Local feedback helps shape national policies and decisions."@en ;
  dcterms:modified "2026-02-12T08:59:21.711638Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25174-5
  a curric:KeyLearningPoint ;
  rdfs:label "National and local government work together to run the country effectively."@en ;
  dcterms:modified "2026-02-12T08:59:21.711642Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27982-1
  a curric:KeyLearningPoint ;
  rdfs:label """An ageing population faces significant financial risks, including outliving savings, healthcare costs and scams."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713401Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27982-2
  a curric:KeyLearningPoint ;
  rdfs:label """Financial education and early preparation are essential to reduce long term financial vulnerability."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713405Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27982-3
  a curric:KeyLearningPoint ;
  rdfs:label """The Government provides support through the state pension, Pension Credit and regulatory protections."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713410Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27982-4
  a curric:KeyLearningPoint ;
  rdfs:label """Local government assists with grants, home adaptations and essential social care services."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713414Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27982-5
  a curric:KeyLearningPoint ;
  rdfs:label """Charities and advice organisations further strengthen protections by offering guidance, advocacy and practical support."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713419Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25292-1
  a curric:KeyLearningPoint ;
  rdfs:label """Defendants have the right to a fair trial, legal representation, and presumption of innocence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713424Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25292-2
  a curric:KeyLearningPoint ;
  rdfs:label """Defendants can remain silent, challenge evidence, and appeal convictions to ensure justice."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713428Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25292-3
  a curric:KeyLearningPoint ;
  rdfs:label """Legal rights protect individuals from wrongful punishment and ensure fair trials."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713435Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25292-4
  a curric:KeyLearningPoint ;
  rdfs:label """Victims are entitled to respect, case updates, and support during the legal process."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713443Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25292-5
  a curric:KeyLearningPoint ;
  rdfs:label """Victims can give statements and apply for compensation, ensuring they are heard and involved."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713447Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25199-1
  a curric:KeyLearningPoint ;
  rdfs:label """The EU formed through gradual supranational cooperation, with treaties promoting closer ties between Western Europe."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713457Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25199-2
  a curric:KeyLearningPoint ;
  rdfs:label """Post-WWII there were a number of key treaties that lead to the formation of different unions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713462Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25199-3
  a curric:KeyLearningPoint ;
  rdfs:label """The formation of the EU has economic, security and social benefits for member countries."""@en ;
  dcterms:modified "2026-02-12T08:59:21.713467Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25196-1
  a curric:KeyLearningPoint ;
  rdfs:label """There are a range of different sentences, including custodial and community sentences, fines and discharges."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716617Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25196-2
  a curric:KeyLearningPoint ;
  rdfs:label """Youth sentencing is slightly different and focuses on rehabilitative imposed orders designed to reshape behaviour."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716622Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25196-3
  a curric:KeyLearningPoint ;
  rdfs:label """When sentencing, judges must use guidelines that provide minimum and maximum sentences and factors to consider."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716626Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25196-4
  a curric:KeyLearningPoint ;
  rdfs:label """Sentences can rehabilitate and provide retribution. Both have positive and negative points and the UK uses both."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716631Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25267-1
  a curric:KeyLearningPoint ;
  rdfs:label """There are two main types of democracy: direct and representative. The UK is a representative democracy."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716635Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25267-2
  a curric:KeyLearningPoint ;
  rdfs:label """Key features of democracy incude free and fair elections, multi-party system and protect of human rights."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716642Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25267-3
  a curric:KeyLearningPoint ;
  rdfs:label """First Past The Post is the electoral system used for general elections in the UK."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716647Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25267-4
  a curric:KeyLearningPoint ;
  rdfs:label """Democracy can always be improved, e.g., by increasing voter turnout, reducing apathy and addressing tactical voting."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716651Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25282-1
  a curric:KeyLearningPoint ;
  rdfs:label """An active citizenship report explains what you did, discovered, and the outcomes of your project."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716655Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25282-2
  a curric:KeyLearningPoint ;
  rdfs:label """Sharing your report can help raise awareness and build wider support for your issue."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716660Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25282-3
  a curric:KeyLearningPoint ;
  rdfs:label """It also helps promote the values of active citizenship in your community personally, within yourself."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716664Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25282-4
  a curric:KeyLearningPoint ;
  rdfs:label """Share your report with peers, your school, local community, decision makers, and relevant organisations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716669Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25333-1
  a curric:KeyLearningPoint ;
  rdfs:label """The Budget is a financial framework that annually shows how the Government generates and allocates money."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716792Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25333-2
  a curric:KeyLearningPoint ;
  rdfs:label """The Government funds the country through six primary revenue streams including taxation, borrowing, natural resources."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716825Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25333-3
  a curric:KeyLearningPoint ;
  rdfs:label """Taxation is the main source of government revenue, with income tax, VAT and corporate levies funding public services."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716830Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25333-4
  a curric:KeyLearningPoint ;
  rdfs:label """The Government incurs debt by issuing bonds, creating national liabilities that must be repaid with interest."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716835Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25333-5
  a curric:KeyLearningPoint ;
  rdfs:label """Natural resources, such as oil from the North Sea, and public assets like land are sold or taxed to generate revenue."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716839Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25294-1
  a curric:KeyLearningPoint ;
  rdfs:label """Judges protect legal rights by applying the law, ensuring fairness and advising on appropriate sentencing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716851Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25294-2
  a curric:KeyLearningPoint ;
  rdfs:label """Legal Executives assist in case prep, ensuring accessibility to legal services in specific law areas."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716856Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25294-3
  a curric:KeyLearningPoint ;
  rdfs:label """Solicitors provide legal advice, prepare cases, and represent clients in legal matters."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716860Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25294-4
  a curric:KeyLearningPoint ;
  rdfs:label """Barristers specialise in courtroom advocacy, defending clients or prosecuting cases in Crown Court."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716865Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25294-5
  a curric:KeyLearningPoint ;
  rdfs:label """Legal professionals uphold our rights, ensuring justice is served through fair legal representation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716869Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25219-1
  a curric:KeyLearningPoint ;
  rdfs:label """Local economies include businesses like shops, financial institutions and social enterprises that support growth."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716874Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25219-2
  a curric:KeyLearningPoint ;
  rdfs:label """Markets and credit unions help local people by providing goods, services and financial support."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716878Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25219-3
  a curric:KeyLearningPoint ;
  rdfs:label """Small businesses create jobs, drive innovation and keep money circulating locally."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716883Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25219-4
  a curric:KeyLearningPoint ;
  rdfs:label """Taxes from businesses fund public services like schools, healthcare and transport."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716888Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25219-5
  a curric:KeyLearningPoint ;
  rdfs:label """Small businesses also support communities through charity, events and local investment."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716892Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25184-1
  a curric:KeyLearningPoint ;
  rdfs:label """In a democracy, citizens take action in many ways such as through protests and stunts."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716896Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25184-2
  a curric:KeyLearningPoint ;
  rdfs:label "Action can be seen as civil disobedience in non-democratic societies."@en ;
  dcterms:modified "2026-02-12T08:59:21.716901Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25184-3
  a curric:KeyLearningPoint ;
  rdfs:label "Some international organisations support citizens to take action."@en ;
  dcterms:modified "2026-02-12T08:59:21.716905Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25204-1
  a curric:KeyLearningPoint ;
  rdfs:label """In 2016, the UK’s EU referendum had a close, divisive result, unlike typical clear-cut referendums."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716910Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25204-2
  a curric:KeyLearningPoint ;
  rdfs:label """The results varied across the UK, with Scotland and Northern Ireland voting to remain in the EU."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716914Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25204-3
  a curric:KeyLearningPoint ;
  rdfs:label """Regional differences emerged in the vote, with patterns tied to demographics such as age influencing the results."""@en ;
  dcterms:modified "2026-02-12T08:59:21.716919Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25367-1
  a curric:KeyLearningPoint ;
  rdfs:label "Pressure groups do not want power but try to shape government policy."@en ;
  dcterms:modified "2026-02-12T08:59:21.717398Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25367-2
  a curric:KeyLearningPoint ;
  rdfs:label """Pressure groups fall into two categories: insider & outsider groups. They use a range of strategies: direct & indirect."""@en ;
  dcterms:modified "2026-02-12T08:59:21.717403Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25367-3
  a curric:KeyLearningPoint ;
  rdfs:label """Pressure groups may be successful without meeting all their aims; they can change public opinion or gain awareness."""@en ;
  dcterms:modified "2026-02-12T08:59:21.717409Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25277-1
  a curric:KeyLearningPoint ;
  rdfs:label "Primary research is research that you carry out yourself."@en ;
  dcterms:modified "2026-02-12T08:59:21.717414Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25277-2
  a curric:KeyLearningPoint ;
  rdfs:label """Primary research includes interviews, observations, questionnaires, focus groups, suggestion boxes and visual logs."""@en ;
  dcterms:modified "2026-02-12T08:59:21.717421Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25277-3
  a curric:KeyLearningPoint ;
  rdfs:label """It helps you understand real experiences to make your project more relevant and connected to your audience."""@en ;
  dcterms:modified "2026-02-12T08:59:21.717428Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25277-4
  a curric:KeyLearningPoint ;
  rdfs:label """It involves gathering new evidence and stories to highlight issues that may not be widely known."""@en ;
  dcterms:modified "2026-02-12T08:59:21.717433Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25277-5
  a curric:KeyLearningPoint ;
  rdfs:label """It shows you've listened to others, adding credibility and impact to your campaign."""@en ;
  dcterms:modified "2026-02-12T08:59:21.717437Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27984-1
  a curric:KeyLearningPoint ;
  rdfs:label """The main housing options in the UK are buying with a mortgage, private renting, social housing and shared ownership."""@en ;
  dcterms:modified "2026-02-12T08:59:21.717442Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27984-2
  a curric:KeyLearningPoint ;
  rdfs:label """Each option offers benefits and challenges depending on an individual’s income, financial stability and future goals."""@en ;
  dcterms:modified "2026-02-12T08:59:21.717447Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27984-3
  a curric:KeyLearningPoint ;
  rdfs:label """Financial factors, such as mortgage interest rates and income levels, influence whether people can afford to buy a home."""@en ;
  dcterms:modified "2026-02-12T08:59:21.717451Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27984-4
  a curric:KeyLearningPoint ;
  rdfs:label """Recent rises in house prices in 2025 have made it more difficult for many to join the property ladder."""@en ;
  dcterms:modified "2026-02-12T08:59:21.717457Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27984-5
  a curric:KeyLearningPoint ;
  rdfs:label """Renters are protected by laws like Awaab’s Law and the Renters Reform Bill, with help from Shelter and Citizens Advice."""@en ;
  dcterms:modified "2026-02-12T08:59:21.717462Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25280-1
  a curric:KeyLearningPoint ;
  rdfs:label """When carrying out active citizenship, create a clear action plan: outline detailed steps with agreed deadlines."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718091Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25280-2
  a curric:KeyLearningPoint ;
  rdfs:label """Define roles and responsibilities; ensure everyone knows what they are responsible for."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718096Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25280-3
  a curric:KeyLearningPoint ;
  rdfs:label """Hold regular team check-ins: meet often to track progress and adjust the plan if needed."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718100Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25280-4
  a curric:KeyLearningPoint ;
  rdfs:label "Keep records: document all actions and decisions throughout the project."@en ;
  dcterms:modified "2026-02-12T08:59:21.718105Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25280-5
  a curric:KeyLearningPoint ;
  rdfs:label """Overcome barriers: address challenges like time, resources, or conflict by staying organised and goal-focused."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718109Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25225-1
  a curric:KeyLearningPoint ;
  rdfs:label """Media supports democracy by informing the public but also risks spreading misinformation and regulatory challenges."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718113Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25225-2
  a curric:KeyLearningPoint ;
  rdfs:label """Traditional media was once small-owned, but it is now dominated by large corporations, with regulation limits."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718118Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25225-3
  a curric:KeyLearningPoint ;
  rdfs:label """Digital media is dominated by global tech firms that largely self-regulate, increasing bias risks and misinformation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718122Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27985-1
  a curric:KeyLearningPoint ;
  rdfs:label """Renting requires financial responsibility, including timely payments and awareness of additional living costs."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718641Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27985-2
  a curric:KeyLearningPoint ;
  rdfs:label """Prospective tenants must understand their legal rights and assess the affordability of rental agreements."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718648Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27985-3
  a curric:KeyLearningPoint ;
  rdfs:label """Effective income management involves tracking earnings and creating a balanced financial plan."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718653Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27985-4
  a curric:KeyLearningPoint ;
  rdfs:label """Regular saving from income supports financial stability and long-term independence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718660Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27985-5
  a curric:KeyLearningPoint ;
  rdfs:label """Financial planning is essential for sustaining rental commitments and making informed economic decisions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718664Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25220-1
  a curric:KeyLearningPoint ;
  rdfs:label """Local taxation funds essential services, infrastructure, and business support, driving economic growth."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718670Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25220-2
  a curric:KeyLearningPoint ;
  rdfs:label """The Levelling Up agenda reduces regional inequalities through targeted investment in skills and business development."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718675Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25220-3
  a curric:KeyLearningPoint ;
  rdfs:label """Regeneration projects, such as in Glenrothes, enhance public spaces, attract investment and create jobs."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718680Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25220-4
  a curric:KeyLearningPoint ;
  rdfs:label """Community involvement ensures regeneration aligns with local needs, fostering economic and social sustainability."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718686Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25220-5
  a curric:KeyLearningPoint ;
  rdfs:label """Administrative efficiency optimises resource allocation, ensuring timely and effective economic impact."""@en ;
  dcterms:modified "2026-02-12T08:59:21.718691Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25255-1
  a curric:KeyLearningPoint ;
  rdfs:label """Our identities are shaped by many factors, including nature, nurture, and experiences, and change over time."""@en ;
  dcterms:modified "2026-02-12T08:59:21.719342Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25255-2
  a curric:KeyLearningPoint ;
  rdfs:label """We can have multiple identities that change depending on the situation, such as group or national identities."""@en ;
  dcterms:modified "2026-02-12T08:59:21.719347Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25255-3
  a curric:KeyLearningPoint ;
  rdfs:label """Communities come in many forms, from local neighborhoods to global groups, united by shared interests or location."""@en ;
  dcterms:modified "2026-02-12T08:59:21.719351Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25255-4
  a curric:KeyLearningPoint ;
  rdfs:label """Community involvement means participating in activities that improve the area and support others."""@en ;
  dcterms:modified "2026-02-12T08:59:21.719355Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25325-1
  a curric:KeyLearningPoint ;
  rdfs:label "There are both pros and cons to the current form of democracy in the UK."@en ;
  dcterms:modified "2026-02-12T08:59:21.719917Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25325-2
  a curric:KeyLearningPoint ;
  rdfs:label """Electoral reform could improve democracy in the UK, for example, lowering the voting age and increasing referendums."""@en ;
  dcterms:modified "2026-02-12T08:59:21.719922Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25290-1
  a curric:KeyLearningPoint ;
  rdfs:label """Laws ensure justice, fairness, safety and clarity, protecting rights and providing rules for society."""@en ;
  dcterms:modified "2026-02-12T08:59:21.719927Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25290-2
  a curric:KeyLearningPoint ;
  rdfs:label """Legislature creates laws through Parliament, with Bills going through stages before becoming Acts."""@en ;
  dcterms:modified "2026-02-12T08:59:21.719931Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25290-3
  a curric:KeyLearningPoint ;
  rdfs:label "The legislative process ensures laws reflect society's needs and values."@en ;
  dcterms:modified "2026-02-12T08:59:21.719935Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25290-4
  a curric:KeyLearningPoint ;
  rdfs:label """Common law is created by judges in cases where no legislation exists, setting legal precedents."""@en ;
  dcterms:modified "2026-02-12T08:59:21.719940Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25290-5
  a curric:KeyLearningPoint ;
  rdfs:label """This allows the law to adapt to new issues quickly, without waiting for Parliament's action."""@en ;
  dcterms:modified "2026-02-12T08:59:21.719944Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25263-1
  a curric:KeyLearningPoint ;
  rdfs:label "Citizens in the UK have democratic tools to influence or change laws."@en ;
  dcterms:modified "2026-02-12T08:59:21.721552Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25263-2
  a curric:KeyLearningPoint ;
  rdfs:label """Citizens can join lobbying groups to influence law change, like ASH did with the smoking ban."""@en ;
  dcterms:modified "2026-02-12T08:59:21.721557Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25263-3
  a curric:KeyLearningPoint ;
  rdfs:label """MPs hold surgeries so constituents can raise issues directly and influence change."""@en ;
  dcterms:modified "2026-02-12T08:59:21.721561Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25263-4
  a curric:KeyLearningPoint ;
  rdfs:label """Select committees gather public evidence to help shape recommendations and policy."""@en ;
  dcterms:modified "2026-02-12T08:59:21.721565Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25263-5
  a curric:KeyLearningPoint ;
  rdfs:label """Citizens can support Private Members’ bills by asking MPs to take up important causes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.721570Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25378-1
  a curric:KeyLearningPoint ;
  rdfs:label """There are different types of elections in the UK including general, local, PCC, Mayoral and devolved elections."""@en ;
  dcterms:modified "2026-02-12T08:59:21.721574Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25378-2
  a curric:KeyLearningPoint ;
  rdfs:label """The Prime Minster calls general elections and request the monarch to dissolve Parliament."""@en ;
  dcterms:modified "2026-02-12T08:59:21.721579Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25378-3
  a curric:KeyLearningPoint ;
  rdfs:label """Election processes include nominating candidates, finalising manifestos, campaigning, voting and results."""@en ;
  dcterms:modified "2026-02-12T08:59:21.721585Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25378-4
  a curric:KeyLearningPoint ;
  rdfs:label "The electorate must be registered to vote in order to participate in elections"@en ;
  dcterms:modified "2026-02-12T08:59:21.721590Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25295-1
  a curric:KeyLearningPoint ;
  rdfs:label """Civil courts ensure justice by resolving disputes fairly and protecting individual rights."""@en ;
  dcterms:modified "2026-02-12T08:59:21.722208Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25295-2
  a curric:KeyLearningPoint ;
  rdfs:label """Civil judges analyse evidence and apply laws to reach fair outcomes based on probability."""@en ;
  dcterms:modified "2026-02-12T08:59:21.722213Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25295-3
  a curric:KeyLearningPoint ;
  rdfs:label """Ombudsman services and mediation offer faster, cost-effective dispute resolution."""@en ;
  dcterms:modified "2026-02-12T08:59:21.722219Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25295-4
  a curric:KeyLearningPoint ;
  rdfs:label "The Financial Ombudsman helped consumers claim £38B in PPI compensation."@en ;
  dcterms:modified "2026-02-12T08:59:21.722224Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25295-5
  a curric:KeyLearningPoint ;
  rdfs:label """Mediation aids in resolving civil conflicts collaboritively, without legal battles."""@en ;
  dcterms:modified "2026-02-12T08:59:21.722228Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25182-1
  a curric:KeyLearningPoint ;
  rdfs:label "Countries are governed in different ways depending on their political system."@en ;
  dcterms:modified "2026-02-12T08:59:21.722233Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25182-2
  a curric:KeyLearningPoint ;
  rdfs:label """Democratic countries, such as Belgium, protect rights, allow elections and encourage citizen participation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.722237Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25182-3
  a curric:KeyLearningPoint ;
  rdfs:label "Non-democratic countries, such as China, concentrate power and limit freedoms."@en ;
  dcterms:modified "2026-02-12T08:59:21.722242Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25246-1
  a curric:KeyLearningPoint ;
  rdfs:label """Moral decisions often involve rights and values. In the UK, the Government is mainly responsible for making them."""@en ;
  dcterms:modified "2026-02-12T08:59:21.722573Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25246-2
  a curric:KeyLearningPoint ;
  rdfs:label """The UK Government may involve the people by using ethics committees or public consultations to shape moral decisions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.722579Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25246-3
  a curric:KeyLearningPoint ;
  rdfs:label """Some countries use referendums to decide moral decisions, such as Switzerland's vote on animal testing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.722583Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25246-4
  a curric:KeyLearningPoint ;
  rdfs:label """Referendums can reflect changing values over time, but they can be expensive and time-consuming."""@en ;
  dcterms:modified "2026-02-12T08:59:21.722588Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25187-1
  a curric:KeyLearningPoint ;
  rdfs:label """Magna Carta, sealed in 1215, limited the King’s power and established key legal principles."""@en ;
  dcterms:modified "2026-02-12T08:59:21.722595Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25187-2
  a curric:KeyLearningPoint ;
  rdfs:label """It stated that the monarch is not above the law and protected free men's right to a fair trial."""@en ;
  dcterms:modified "2026-02-12T08:59:21.722599Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25187-3
  a curric:KeyLearningPoint ;
  rdfs:label """It introduced the principle that free men could not be punished without due legal process."""@en ;
  dcterms:modified "2026-02-12T08:59:21.722604Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25187-4
  a curric:KeyLearningPoint ;
  rdfs:label "Justice must be accessible, not denied or delayed, as outlined in Magna Carta."@en ;
  dcterms:modified "2026-02-12T08:59:21.722608Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25187-5
  a curric:KeyLearningPoint ;
  rdfs:label """Magna Carta's core principles evolved over time to influence modern legal systems where rulers follow the law."""@en ;
  dcterms:modified "2026-02-12T08:59:21.722613Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25186-1
  a curric:KeyLearningPoint ;
  rdfs:label """International organisations each serve a different purpose such as promoting peace or supporting trade."""@en ;
  dcterms:modified "2026-02-12T08:59:21.722617Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25186-2
  a curric:KeyLearningPoint ;
  rdfs:label """Some of the major international organisations include the UN, WTO, NATO, EU and the Commonwealth."""@en ;
  dcterms:modified "2026-02-12T08:59:21.722621Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25186-3
  a curric:KeyLearningPoint ;
  rdfs:label """Not all countries are part of all international organisations; countries join based on values and needs."""@en ;
  dcterms:modified "2026-02-12T08:59:21.722626Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25335-1
  a curric:KeyLearningPoint ;
  rdfs:label """The Government allocates funding to essential public services, including health, education, defence and infrastructure."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723820Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25335-2
  a curric:KeyLearningPoint ;
  rdfs:label """Financial decisions are determined by the Treasury and debated in Parliament to uphold democratic accountability."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723827Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25335-3
  a curric:KeyLearningPoint ;
  rdfs:label """Spending priorities are influenced by societal needs, economic conditions and long-term fiscal strategies."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723831Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25335-4
  a curric:KeyLearningPoint ;
  rdfs:label """Ongoing debates consider whether increased investment should be directed more to sectors such as the NHS or housing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723836Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25335-5
  a curric:KeyLearningPoint ;
  rdfs:label """Government spending seeks to balance economic growth, public welfare and fiscal responsibility."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723840Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25332-1
  a curric:KeyLearningPoint ;
  rdfs:label """A healthy economy has GDP growth, low unemployment, stable inflation and strong business investment."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723964Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25332-2
  a curric:KeyLearningPoint ;
  rdfs:label """In a recession, the Government may borrow money or lower taxes, while in a strong economy, it invests in services."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723969Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25332-3
  a curric:KeyLearningPoint ;
  rdfs:label """Inflation is important, and the Government aims to keep it low but positive to prevent rapid price rises or slow growth."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723973Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25332-4
  a curric:KeyLearningPoint ;
  rdfs:label """Taxes may be raised to control inflation in good times, and cut to boost spending in a recession."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723978Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25332-5
  a curric:KeyLearningPoint ;
  rdfs:label """While areas like defence, law enforcement and elections are less affected by the economy, it still influences decisions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723982Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25288-1
  a curric:KeyLearningPoint ;
  rdfs:label """The UK Government manages national debt by borrowing money, raising taxes and adjusting public spending."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723987Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25288-2
  a curric:KeyLearningPoint ;
  rdfs:label """If debt is too high, austerity measures may be used, meaning cuts to services like education and healthcare."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723995Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25288-3
  a curric:KeyLearningPoint ;
  rdfs:label """High national debt can lead to increased taxes, higher interest rates and rising costs for essentials."""@en ;
  dcterms:modified "2026-02-12T08:59:21.723999Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25288-4
  a curric:KeyLearningPoint ;
  rdfs:label """National debt affects individuals by making it harder to afford housing, transport and everyday living expenses."""@en ;
  dcterms:modified "2026-02-12T08:59:21.724004Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25288-5
  a curric:KeyLearningPoint ;
  rdfs:label """Careful management of national debt is needed to balance economic stability with public safety and wellbeing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.724008Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25180-1
  a curric:KeyLearningPoint ;
  rdfs:label """The role of the justice system is to enforce laws, ensure fairness and  protect rights."""@en ;
  dcterms:modified "2026-02-12T08:59:21.724012Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25180-2
  a curric:KeyLearningPoint ;
  rdfs:label "The justice system varies on how a country is governed."@en ;
  dcterms:modified "2026-02-12T08:59:21.724017Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25180-3
  a curric:KeyLearningPoint ;
  rdfs:label "An independent judiciary helps protect human rights."@en ;
  dcterms:modified "2026-02-12T08:59:21.724021Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25180-4
  a curric:KeyLearningPoint ;
  rdfs:label "An independent judiciary is crucial for separation of powers."@en ;
  dcterms:modified "2026-02-12T08:59:21.724025Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25347-1
  a curric:KeyLearningPoint ;
  rdfs:label """International law limits suffering in war, with key rules set out in documents like the Geneva Conventions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.724030Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25347-2
  a curric:KeyLearningPoint ;
  rdfs:label """The ICC prosecutes individuals for crimes like genocide and war crimes under international law."""@en ;
  dcterms:modified "2026-02-12T08:59:21.724035Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25347-3
  a curric:KeyLearningPoint ;
  rdfs:label """The ECtHR allows individuals to bring cases against Council of Europe Member States for human rights violations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.724039Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25347-4
  a curric:KeyLearningPoint ;
  rdfs:label """The UK supports international courts, contributing financially and shaping human rights law globally."""@en ;
  dcterms:modified "2026-02-12T08:59:21.724043Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25177-1
  a curric:KeyLearningPoint ;
  rdfs:label "There is a clear relationship between the judiciary and human rights."@en ;
  dcterms:modified "2026-02-12T08:59:21.724048Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25177-2
  a curric:KeyLearningPoint ;
  rdfs:label """The judiciary strengthen human rights through equality before the law, fair, public trials and appropriate sentencing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.724054Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25177-3
  a curric:KeyLearningPoint ;
  rdfs:label "They also allow citizens to defend their rights through the civil courts."@en ;
  dcterms:modified "2026-02-12T08:59:21.724059Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25177-4
  a curric:KeyLearningPoint ;
  rdfs:label """The judiciary has been accused of failing rights, e.g. Rwanda policy, Belmarsh dentention case, Tony Nicklinson case."""@en ;
  dcterms:modified "2026-02-12T08:59:21.724064Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25252-1
  a curric:KeyLearningPoint ;
  rdfs:label "The UK has used hard power to deal with Russia by deploying economic sanctions."@en ;
  dcterms:modified "2026-02-12T08:59:21.724068Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25252-2
  a curric:KeyLearningPoint ;
  rdfs:label """The UK has used soft power to deal with Russia by utilising diplomacy and institutions like universities."""@en ;
  dcterms:modified "2026-02-12T08:59:21.724073Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25252-3
  a curric:KeyLearningPoint ;
  rdfs:label "How effective these strategies are is a matter of debate."@en ;
  dcterms:modified "2026-02-12T08:59:21.724079Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25271-1
  a curric:KeyLearningPoint ;
  rdfs:label "Devolution is the transfer of powers from the UK to regional government."@en ;
  dcterms:modified "2026-02-12T08:59:21.724233Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25271-2
  a curric:KeyLearningPoint ;
  rdfs:label "Devolution invovles transferred powers for Scotland, Wales and Northern Ireland."@en ;
  dcterms:modified "2026-02-12T08:59:21.724237Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25271-3
  a curric:KeyLearningPoint ;
  rdfs:label "Devolution impacts democracy by giving regions more control over local issues."@en ;
  dcterms:modified "2026-02-12T08:59:21.724241Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25271-4
  a curric:KeyLearningPoint ;
  rdfs:label "Devolution can impact the unity and identity of the UK."@en ;
  dcterms:modified "2026-02-12T08:59:21.724248Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25270-1
  a curric:KeyLearningPoint ;
  rdfs:label """A free press is the right for the media to publish and share information and opinions without interference."""@en ;
  dcterms:modified "2026-02-12T08:59:21.724292Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25270-2
  a curric:KeyLearningPoint ;
  rdfs:label "A free press allows for freedom, transparency and accountability."@en ;
  dcterms:modified "2026-02-12T08:59:21.724298Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25270-3
  a curric:KeyLearningPoint ;
  rdfs:label "A free press can support and hinder democracy in the UK."@en ;
  dcterms:modified "2026-02-12T08:59:21.724303Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25244-1
  a curric:KeyLearningPoint ;
  rdfs:label "Select committees scrutinise government policies."@en ;
  dcterms:modified "2026-02-12T08:59:21.724307Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25244-2
  a curric:KeyLearningPoint ;
  rdfs:label """Citizens influence select committees by submitting evidence and engaging in consultations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.724312Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25244-3
  a curric:KeyLearningPoint ;
  rdfs:label """Select committees use public input to better understand issues and make informed recommendations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.724316Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25244-4
  a curric:KeyLearningPoint ;
  rdfs:label """Public engagement can be improved through civic education and accessible communication."""@en ;
  dcterms:modified "2026-02-12T08:59:21.724320Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25190-1
  a curric:KeyLearningPoint ;
  rdfs:label """Special constables are volunteers who support police by patrolling and responding to incidents."""@en ;
  dcterms:modified "2026-02-12T08:59:21.724325Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25190-2
  a curric:KeyLearningPoint ;
  rdfs:label """Special constables have full police powers and help prevent crime by increasing police presence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.724329Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25190-3
  a curric:KeyLearningPoint ;
  rdfs:label """Special constable's diverse skills and backgrounds can help build trust with communities."""@en ;
  dcterms:modified "2026-02-12T08:59:21.724336Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25190-4
  a curric:KeyLearningPoint ;
  rdfs:label """Police staff support justice through roles like call handling, forensics and administrative work."""@en ;
  dcterms:modified "2026-02-12T08:59:21.724340Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25190-5
  a curric:KeyLearningPoint ;
  rdfs:label """Police staff help protect rights, ensure fair treatment and keep the legal system running smoothly."""@en ;
  dcterms:modified "2026-02-12T08:59:21.724345Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25348-1
  a curric:KeyLearningPoint ;
  rdfs:label """NATO was created in 1949 in response to global tensions and has grown into a key force in international security."""@en ;
  dcterms:modified "2026-02-12T08:59:21.724349Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25348-2
  a curric:KeyLearningPoint ;
  rdfs:label """Whilst it is a military organisation, it has wider aims such as international humanitarian law."""@en ;
  dcterms:modified "2026-02-12T08:59:21.724353Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25348-3
  a curric:KeyLearningPoint ;
  rdfs:label """NATO's structure allows Member States to make joint political and military decisions through consensus."""@en ;
  dcterms:modified "2026-02-12T08:59:21.724358Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25348-4
  a curric:KeyLearningPoint ;
  rdfs:label """The UK is a key NATO member, contributing leadership, military support and financial commitment to collective defence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.724362Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25326-1
  a curric:KeyLearningPoint ;
  rdfs:label "Laws are created within a three branch system."@en ;
  dcterms:modified "2026-02-12T08:59:21.724688Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25326-2
  a curric:KeyLearningPoint ;
  rdfs:label """Separation of powers includes the three branches of the legislature, the executive and the judicary."""@en ;
  dcterms:modified "2026-02-12T08:59:21.724694Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25326-3
  a curric:KeyLearningPoint ;
  rdfs:label "Before a Bill becomes a law, it goes through many stages."@en ;
  dcterms:modified "2026-02-12T08:59:21.724699Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25326-4
  a curric:KeyLearningPoint ;
  rdfs:label "There are advantages and disadvantages to these different stages."@en ;
  dcterms:modified "2026-02-12T08:59:21.724703Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25286-1
  a curric:KeyLearningPoint ;
  rdfs:label """The UK Government uses risk management to prevent economic instability from cyber attacks and financial downturns."""@en ;
  dcterms:modified "2026-02-12T08:59:21.724708Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25286-2
  a curric:KeyLearningPoint ;
  rdfs:label """Public health planning, like Exercise Cygnus and cybersecurity laws, strengthen national risk management."""@en ;
  dcterms:modified "2026-02-12T08:59:21.724712Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25286-3
  a curric:KeyLearningPoint ;
  rdfs:label """Financial oversight, including FCA investigations, ensures businesses follow regulations and protects the economy."""@en ;
  dcterms:modified "2026-02-12T08:59:21.724717Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25286-4
  a curric:KeyLearningPoint ;
  rdfs:label """Emergency frameworks and international cooperation with organisations like the G20 help the UK manage risks."""@en ;
  dcterms:modified "2026-02-12T08:59:21.724721Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25286-5
  a curric:KeyLearningPoint ;
  rdfs:label """These strategies strengthen economic resilience, protect jobs and ensure long-term stability."""@en ;
  dcterms:modified "2026-02-12T08:59:21.724727Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25233-1
  a curric:KeyLearningPoint ;
  rdfs:label """The UK Undercover Voters project explored how algorithms target political content based on online profiles."""@en ;
  dcterms:modified "2026-02-12T08:59:21.724732Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25233-2
  a curric:KeyLearningPoint ;
  rdfs:label """Targeted content may influence voting by reinforcing existing beliefs, spreading misinformation & shaping opinion."""@en ;
  dcterms:modified "2026-02-12T08:59:21.724736Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25233-3
  a curric:KeyLearningPoint ;
  rdfs:label """Algorithms can create echo chambers, limiting exposure to diverse viewpoints & making critical thinking challenging."""@en ;
  dcterms:modified "2026-02-12T08:59:21.724741Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25233-4
  a curric:KeyLearningPoint ;
  rdfs:label """Misinformation and disinformation tailored to personal beliefs could affect voting behavior."""@en ;
  dcterms:modified "2026-02-12T08:59:21.724745Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25322-1
  a curric:KeyLearningPoint ;
  rdfs:label """There are two main voting systems: first-past-the-post and proportional representation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.725871Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25322-2
  a curric:KeyLearningPoint ;
  rdfs:label """Advantages of first-past-the-post are: it produces a clear winner. However, winners might have little public support."""@en ;
  dcterms:modified "2026-02-12T08:59:21.725876Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25322-3
  a curric:KeyLearningPoint ;
  rdfs:label """Advantages of proportional representation include fairer representation. However, it can lead to coalition governments."""@en ;
  dcterms:modified "2026-02-12T08:59:21.725880Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25223-1
  a curric:KeyLearningPoint ;
  rdfs:label """The nighttime economy includes jobs like taxi drivers and takeaway delivery staff working after 6pm in towns and cities."""@en ;
  dcterms:modified "2026-02-12T08:59:21.726316Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25223-2
  a curric:KeyLearningPoint ;
  rdfs:label """The nighttime economy boosts the local economy by increasing spending in hospitality and transport."""@en ;
  dcterms:modified "2026-02-12T08:59:21.726321Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25223-3
  a curric:KeyLearningPoint ;
  rdfs:label """The gig economy, including delivery drivers, provides flexible jobs through apps which are often short-term."""@en ;
  dcterms:modified "2026-02-12T08:59:21.726325Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25223-4
  a curric:KeyLearningPoint ;
  rdfs:label """Many workers in the gig economy are on zero-hour contracts, which allow choice, but offer no guaranteed income."""@en ;
  dcterms:modified "2026-02-12T08:59:21.726329Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25223-5
  a curric:KeyLearningPoint ;
  rdfs:label """Councils like North Lanarkshire are promoting sustainability by encouraging fairer contracts and greener transport."""@en ;
  dcterms:modified "2026-02-12T08:59:21.726334Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25334-1
  a curric:KeyLearningPoint ;
  rdfs:label """Taxation is the primary method by which governments generate revenue to fund public services."""@en ;
  dcterms:modified "2026-02-12T08:59:21.726338Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25334-2
  a curric:KeyLearningPoint ;
  rdfs:label """The UK tax system comprises various forms, including Income Tax, National Insurance, VAT and Corporation Tax."""@en ;
  dcterms:modified "2026-02-12T08:59:21.726345Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25334-3
  a curric:KeyLearningPoint ;
  rdfs:label """A progressive tax system ensures that individuals with higher incomes contribute a greater proportion."""@en ;
  dcterms:modified "2026-02-12T08:59:21.726349Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25334-4
  a curric:KeyLearningPoint ;
  rdfs:label "Advocates for equal taxation emphasise simplicity and consistency."@en ;
  dcterms:modified "2026-02-12T08:59:21.726354Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25334-5
  a curric:KeyLearningPoint ;
  rdfs:label """Critics highlight its disproportionate impact on lower income groups and the importance of wealth redistribution."""@en ;
  dcterms:modified "2026-02-12T08:59:21.726358Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25232-1
  a curric:KeyLearningPoint ;
  rdfs:label """AI played a key feature in India's general election and this raised many questions over its advantages and disadantages."""@en ;
  dcterms:modified "2026-02-12T08:59:21.726390Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25232-2
  a curric:KeyLearningPoint ;
  rdfs:label """Advantages included increased voter engagement, efficiency, improved outreach and translation features."""@en ;
  dcterms:modified "2026-02-12T08:59:21.726395Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25232-3
  a curric:KeyLearningPoint ;
  rdfs:label "Disadvanatges included disinformation, deepfakes, data privacy and manipulation."@en ;
  dcterms:modified "2026-02-12T08:59:21.726400Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25232-4
  a curric:KeyLearningPoint ;
  rdfs:label """AI could have a place in future elections, but the benefits would need to be balanced against the risks."""@en ;
  dcterms:modified "2026-02-12T08:59:21.726404Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25362-1
  a curric:KeyLearningPoint ;
  rdfs:label """A key feature of the rule of law is that everyone, including those in power, are subject to the law."""@en ;
  dcterms:modified "2026-02-12T08:59:21.726409Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25362-2
  a curric:KeyLearningPoint ;
  rdfs:label """The rule of law and democratic systems hold those in power accountable, preventing dictatorship and corruption​."""@en ;
  dcterms:modified "2026-02-12T08:59:21.726416Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25362-3
  a curric:KeyLearningPoint ;
  rdfs:label """There is a long history of human rights legislation in the UK, Europe and the world."""@en ;
  dcterms:modified "2026-02-12T08:59:21.726421Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25362-4
  a curric:KeyLearningPoint ;
  rdfs:label """Each piece of legislation has had a different impact on how human rights are protected in societies today."""@en ;
  dcterms:modified "2026-02-12T08:59:21.726425Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25321-1
  a curric:KeyLearningPoint ;
  rdfs:label """A direct democracy is where people decide on the policy directly, with Switzerland being an example."""@en ;
  dcterms:modified "2026-02-12T08:59:21.727476Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25321-2
  a curric:KeyLearningPoint ;
  rdfs:label """A representative democracy is a system where citizens elect others to represent them, with the UK being an example."""@en ;
  dcterms:modified "2026-02-12T08:59:21.727480Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25321-3
  a curric:KeyLearningPoint ;
  rdfs:label "There are advantages and disadvantages to both types of democracy."@en ;
  dcterms:modified "2026-02-12T08:59:21.727485Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25376-1
  a curric:KeyLearningPoint ;
  rdfs:label "Local government in the UK are structured into single and two-tiers."@en ;
  dcterms:modified "2026-02-12T08:59:21.727489Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25376-2
  a curric:KeyLearningPoint ;
  rdfs:label """Single-tiers include unitary authorities, London boroughs and Metropolitan borough councils."""@en ;
  dcterms:modified "2026-02-12T08:59:21.727495Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25376-3
  a curric:KeyLearningPoint ;
  rdfs:label "Two-tiers include county and district councils."@en ;
  dcterms:modified "2026-02-12T08:59:21.727500Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25376-4
  a curric:KeyLearningPoint ;
  rdfs:label """Council roles include local councillors, cabinet members, backbench councillors, mayors and council officers."""@en ;
  dcterms:modified "2026-02-12T08:59:21.727505Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25300-1
  a curric:KeyLearningPoint ;
  rdfs:label """Media informs, scrutinises, and helps raise party profiles during elections, with strict rules on spending and fairness."""@en ;
  dcterms:modified "2026-02-12T08:59:21.727509Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25300-2
  a curric:KeyLearningPoint ;
  rdfs:label """Media sources vary in reliability and bias; critical checking of sources is essential for informed voting decisions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.727514Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25300-3
  a curric:KeyLearningPoint ;
  rdfs:label """Media can influence elections in ways such as shaping perception, setting the agenda, and amplifying campaign messages."""@en ;
  dcterms:modified "2026-02-12T08:59:21.727546Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25300-4
  a curric:KeyLearningPoint ;
  rdfs:label """Voters' views, media trust issues, and fact-checking reduce the media's influence on election outcomes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.727551Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25328-1
  a curric:KeyLearningPoint ;
  rdfs:label """In a criminal law case, the person charged with an offence is called the defendant. The CPS brings the case."""@en ;
  dcterms:modified "2026-02-12T08:59:21.728029Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25328-2
  a curric:KeyLearningPoint ;
  rdfs:label """In a civil law case, the person who brings the case is called the claimant. The accused is called the defendant."""@en ;
  dcterms:modified "2026-02-12T08:59:21.728034Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25328-3
  a curric:KeyLearningPoint ;
  rdfs:label "Civil cases are heard in either county or high courts."@en ;
  dcterms:modified "2026-02-12T08:59:21.728038Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25328-4
  a curric:KeyLearningPoint ;
  rdfs:label "Criminal cases are heard in either magistrates or crown courts."@en ;
  dcterms:modified "2026-02-12T08:59:21.728043Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25328-5
  a curric:KeyLearningPoint ;
  rdfs:label """Both criminal and civil cases can be heard in the court of appeal or Supreme Court."""@en ;
  dcterms:modified "2026-02-12T08:59:21.728047Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25240-1
  a curric:KeyLearningPoint ;
  rdfs:label """COP meetings allow countries to negotiate climate action and set goals such as global emission reduction targets."""@en ;
  dcterms:modified "2026-02-12T08:59:21.728051Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25240-2
  a curric:KeyLearningPoint ;
  rdfs:label """COP meetings help ensure that all nations have a voice in shaping climate solutions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.728056Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25240-3
  a curric:KeyLearningPoint ;
  rdfs:label """The Kyoto Protocol was the first international treaty to set legally binding emissions targets."""@en ;
  dcterms:modified "2026-02-12T08:59:21.728060Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25240-4
  a curric:KeyLearningPoint ;
  rdfs:label """The Paris Agreement focused on limiting temperature rise and promoted flexible, self-set targets for all nations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.728065Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25240-5
  a curric:KeyLearningPoint ;
  rdfs:label """Active citizenship, through protests and citizen assemblies, helps influence climate action at global conferences."""@en ;
  dcterms:modified "2026-02-12T08:59:21.728069Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25323-1
  a curric:KeyLearningPoint ;
  rdfs:label "The media plays a key role in any democracy."@en ;
  dcterms:modified "2026-02-12T08:59:21.728076Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25323-2
  a curric:KeyLearningPoint ;
  rdfs:label "The media can be controlled to protect others, allow integrity and fairness."@en ;
  dcterms:modified "2026-02-12T08:59:21.728083Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25323-3
  a curric:KeyLearningPoint ;
  rdfs:label "The media can be controlled through censorship, regulation and laws."@en ;
  dcterms:modified "2026-02-12T08:59:21.728087Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25323-4
  a curric:KeyLearningPoint ;
  rdfs:label "Media freedom allows scrutiny of government and holds them to account."@en ;
  dcterms:modified "2026-02-12T08:59:21.728092Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25315-1
  a curric:KeyLearningPoint ;
  rdfs:label """Citizenship covers broad concepts like equality, democracy, and justice, each addressing specific issues in society."""@en ;
  dcterms:modified "2026-02-12T08:59:21.728096Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25315-2
  a curric:KeyLearningPoint ;
  rdfs:label """Active citizenship projects can address various issues, but each issue must relate to a Citizenship concept."""@en ;
  dcterms:modified "2026-02-12T08:59:21.728101Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25315-3
  a curric:KeyLearningPoint ;
  rdfs:label """There are many factors that need to be considered before choosing an issue to investigate such as resources and impact."""@en ;
  dcterms:modified "2026-02-12T08:59:21.728105Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25281-1
  a curric:KeyLearningPoint ;
  rdfs:label """Success in an active citizenship project can look different depending on the goal."""@en ;
  dcterms:modified "2026-02-12T08:59:21.729157Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25281-2
  a curric:KeyLearningPoint ;
  rdfs:label """It might involve raising awareness, changing opinions, fundraising, or developing personal skills."""@en ;
  dcterms:modified "2026-02-12T08:59:21.729162Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25281-3
  a curric:KeyLearningPoint ;
  rdfs:label "Communicating with decision makers is also a form of success."@en ;
  dcterms:modified "2026-02-12T08:59:21.729166Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25281-4
  a curric:KeyLearningPoint ;
  rdfs:label """Success can be measured using clear targets, like numbers of signatures or people reached."""@en ;
  dcterms:modified "2026-02-12T08:59:21.729170Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25281-5
  a curric:KeyLearningPoint ;
  rdfs:label """Pre and post action surveys, questionnaires, and reflections help track progress and impact."""@en ;
  dcterms:modified "2026-02-12T08:59:21.729177Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25188-1
  a curric:KeyLearningPoint ;
  rdfs:label "A jury of 12 citizens decides crown court trial outcomes based on evidence."@en ;
  dcterms:modified "2026-02-12T08:59:21.729181Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25188-2
  a curric:KeyLearningPoint ;
  rdfs:label "Juries ensure fair verdicts and uphold justice by peers."@en ;
  dcterms:modified "2026-02-12T08:59:21.729186Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25188-3
  a curric:KeyLearningPoint ;
  rdfs:label """Magistrates and JPs handle summary cases in magistrate courts ensuring efficiency and easing higher court burdens."""@en ;
  dcterms:modified "2026-02-12T08:59:21.729190Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25188-4
  a curric:KeyLearningPoint ;
  rdfs:label """Juries, magistrates and JPs let citizens contribute to justice in their community as a part of civic responsibility."""@en ;
  dcterms:modified "2026-02-12T08:59:21.729195Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25183-1
  a curric:KeyLearningPoint ;
  rdfs:label """In some countries, censorship restricts press freedom by controlling what can be reported."""@en ;
  dcterms:modified "2026-02-12T08:59:21.729199Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25183-2
  a curric:KeyLearningPoint ;
  rdfs:label "Journalists may face punishment or imprisonment for reporting on certain topics."@en ;
  dcterms:modified "2026-02-12T08:59:21.729203Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25183-3
  a curric:KeyLearningPoint ;
  rdfs:label """A free press is essential for democracy but is limited by government control in some countries."""@en ;
  dcterms:modified "2026-02-12T08:59:21.729208Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25310-1
  a curric:KeyLearningPoint ;
  rdfs:label """Democratic values include transparency, participation, effectively functioning government, trust and liberties."""@en ;
  dcterms:modified "2026-02-12T08:59:21.729893Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25310-2
  a curric:KeyLearningPoint ;
  rdfs:label """The media supports democratic values by providing a free press so we can be kept up to date and make informed decisions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.729897Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25310-3
  a curric:KeyLearningPoint ;
  rdfs:label """Media holds politicians to account via interviews, debates, viewer engagement, investigative journalism and reporting."""@en ;
  dcterms:modified "2026-02-12T08:59:21.729901Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25301-1
  a curric:KeyLearningPoint ;
  rdfs:label """Roles in politics range from elected officials to civil servants and advisers, all supporting government functions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.730253Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25301-2
  a curric:KeyLearningPoint ;
  rdfs:label """Politics-related careers include MPs, civil servants, journalists, and NGO workers, each helping to create change."""@en ;
  dcterms:modified "2026-02-12T08:59:21.730257Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25301-3
  a curric:KeyLearningPoint ;
  rdfs:label """Key qualities like communication, empathy, and resilience are essential for creating change in politics."""@en ;
  dcterms:modified "2026-02-12T08:59:21.730261Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25301-4
  a curric:KeyLearningPoint ;
  rdfs:label """Practical experience and developing essential skills are crucial for making a lasting impact in politics."""@en ;
  dcterms:modified "2026-02-12T08:59:21.730266Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25337-1
  a curric:KeyLearningPoint ;
  rdfs:label """Public services, like the NHS, are primarily funded through taxation, ensuring equitable access to essential services."""@en ;
  dcterms:modified "2026-02-12T08:59:21.730309Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25337-2
  a curric:KeyLearningPoint ;
  rdfs:label """Private services rely on customer payments and private investment, often prioritising profit generation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.730314Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25337-3
  a curric:KeyLearningPoint ;
  rdfs:label """Government ownership ensures consistent service delivery nationwide and long-term infrastructure investment."""@en ;
  dcterms:modified "2026-02-12T08:59:21.730318Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25337-4
  a curric:KeyLearningPoint ;
  rdfs:label "Privatisation can drive efficiency, innovation and service improvements."@en ;
  dcterms:modified "2026-02-12T08:59:21.730322Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25337-5
  a curric:KeyLearningPoint ;
  rdfs:label """The UK has a combined economy to balance equity, competition and economic efficiency, using private and public funds."""@en ;
  dcterms:modified "2026-02-12T08:59:21.730326Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25272-1
  a curric:KeyLearningPoint ;
  rdfs:label "Select committees scrutinise government policies to ensure accountability."@en ;
  dcterms:modified "2026-02-12T08:59:21.730331Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25272-2
  a curric:KeyLearningPoint ;
  rdfs:label "Select committees gather evidence, question ministers and preduce reports."@en ;
  dcterms:modified "2026-02-12T08:59:21.730337Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25272-3
  a curric:KeyLearningPoint ;
  rdfs:label """Citizens can participate by submitting evidence or attending public consultations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.730344Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25251-1
  a curric:KeyLearningPoint ;
  rdfs:label """The Homes for Ukraine scheme is a key example of UK citizenship action in response to a global humanitarian crisis."""@en ;
  dcterms:modified "2026-02-12T08:59:21.730348Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25251-2
  a curric:KeyLearningPoint ;
  rdfs:label """Demonstrations are a key form of citizenship action that raise awareness and express views on global conflicts."""@en ;
  dcterms:modified "2026-02-12T08:59:21.730353Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25251-3
  a curric:KeyLearningPoint ;
  rdfs:label """Citizens worldwide use demonstrations to raise awareness and express their views about the Gaza conflict."""@en ;
  dcterms:modified "2026-02-12T08:59:21.730357Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25251-4
  a curric:KeyLearningPoint ;
  rdfs:label """Voting and other citizenship actions can influence government, but change may take time and face challenges."""@en ;
  dcterms:modified "2026-02-12T08:59:21.730361Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25349-1
  a curric:KeyLearningPoint ;
  rdfs:label "Countries pursue foreign policy aims through soft and hard power."@en ;
  dcterms:modified "2026-02-12T08:59:21.730365Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25349-2
  a curric:KeyLearningPoint ;
  rdfs:label """Hard power uses military/economic pressure, while soft power relies on attraction and persuasion."""@en ;
  dcterms:modified "2026-02-12T08:59:21.730372Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25349-3
  a curric:KeyLearningPoint ;
  rdfs:label """Soft power may be subtle but shapes international relations and influences policies globally."""@en ;
  dcterms:modified "2026-02-12T08:59:21.730377Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25349-4
  a curric:KeyLearningPoint ;
  rdfs:label """The UK, despite challenges, remains an influential nation today due to its membership of international organisations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.730381Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25269-1
  a curric:KeyLearningPoint ;
  rdfs:label "The main branches of power in the UK are executive, legislative and judiciary."@en ;
  dcterms:modified "2026-02-12T08:59:21.730385Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25269-2
  a curric:KeyLearningPoint ;
  rdfs:label "The three branches perform checks and balances on each other."@en ;
  dcterms:modified "2026-02-12T08:59:21.730389Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25269-3
  a curric:KeyLearningPoint ;
  rdfs:label """Leaders are held accountable through debates, questioning and parliamentary inquiries."""@en ;
  dcterms:modified "2026-02-12T08:59:21.730393Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25370-1
  a curric:KeyLearningPoint ;
  rdfs:label """Non-democratic nations limit citizen participation and centralise power with a single leader or ruling party."""@en ;
  dcterms:modified "2026-02-12T08:59:21.730441Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25370-2
  a curric:KeyLearningPoint ;
  rdfs:label "Non-democratic countries include China, North Korea, and Saudi Arabia."@en ;
  dcterms:modified "2026-02-12T08:59:21.730446Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25298-1
  a curric:KeyLearningPoint ;
  rdfs:label """Democracies have many key features such as free and fair elections and a pluralistic system."""@en ;
  dcterms:modified "2026-02-12T08:59:21.730489Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25298-2
  a curric:KeyLearningPoint ;
  rdfs:label "There are different types of democracy such as representative and direct."@en ;
  dcterms:modified "2026-02-12T08:59:21.730493Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25298-3
  a curric:KeyLearningPoint ;
  rdfs:label """Authoritarianism concentrates power in a leader or small elite, making decisions without considering the people's will."""@en ;
  dcterms:modified "2026-02-12T08:59:21.730497Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25298-4
  a curric:KeyLearningPoint ;
  rdfs:label """When evaluating a government system, we can consider criteria like rights protection and fairness for all."""@en ;
  dcterms:modified "2026-02-12T08:59:21.730501Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25289-1
  a curric:KeyLearningPoint ;
  rdfs:label """The economy influences employment opportunities, income levels, public services and living costs, affecting everyone."""@en ;
  dcterms:modified "2026-02-12T08:59:21.730505Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25289-2
  a curric:KeyLearningPoint ;
  rdfs:label """Citizens contribute to economic stability through responsible spending, taxation and skill development."""@en ;
  dcterms:modified "2026-02-12T08:59:21.730510Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25289-3
  a curric:KeyLearningPoint ;
  rdfs:label """Active citizens get involved in economic policy decisions, support local enterprises and practise financial management."""@en ;
  dcterms:modified "2026-02-12T08:59:21.730514Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25289-4
  a curric:KeyLearningPoint ;
  rdfs:label """Inflation diminishes the value of money, but prudent consumer behaviour helps maintain economic stability."""@en ;
  dcterms:modified "2026-02-12T08:59:21.730519Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25289-5
  a curric:KeyLearningPoint ;
  rdfs:label """Strategic investments in emerging sectors such as renewable energy encourage sustainable economic expansion and jobs."""@en ;
  dcterms:modified "2026-02-12T08:59:21.730524Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25216-1
  a curric:KeyLearningPoint ;
  rdfs:label """International humanitarian laws protect individuals and ensure their safety and rights, regardless of identity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.731182Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25216-2
  a curric:KeyLearningPoint ;
  rdfs:label """International agencies, such as the UN and Red Cross work to uphold these international humanitarian laws."""@en ;
  dcterms:modified "2026-02-12T08:59:21.731185Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25216-3
  a curric:KeyLearningPoint ;
  rdfs:label """International laws shape UK legislation, like the Human Rights Act and Equality Act, to protect all citizens."""@en ;
  dcterms:modified "2026-02-12T08:59:21.731191Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25200-1
  a curric:KeyLearningPoint ;
  rdfs:label """The EU is a political and economic union of 27 member states. MEPs vote on and shape legislation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.731985Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25200-2
  a curric:KeyLearningPoint ;
  rdfs:label """The European Council sets the EU's strategic direction, with Heads of State or government meeting to discuss key issues."""@en ;
  dcterms:modified "2026-02-12T08:59:21.731989Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25200-3
  a curric:KeyLearningPoint ;
  rdfs:label """The Parliament of the EU is made up of elected MEPs from Member States. Citizens can engage with them in many ways."""@en ;
  dcterms:modified "2026-02-12T08:59:21.731993Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25200-4
  a curric:KeyLearningPoint ;
  rdfs:label """Political institutions, like Parliament, the EU and the EC evolve over time to address increasingly complex issues."""@en ;
  dcterms:modified "2026-02-12T08:59:21.731997Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25254-1
  a curric:KeyLearningPoint ;
  rdfs:label """International humanitarian law balances universal rules with diverse cultural challenges to protect people in conflicts."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732619Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25254-2
  a curric:KeyLearningPoint ;
  rdfs:label """The Geneva Conventions set universal rules for protecting civilians and prisoners during armed conflict."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732623Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25254-3
  a curric:KeyLearningPoint ;
  rdfs:label """The ICC enforces humanitarian law by investigating and punishing individuals for serious crimes like war crimes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732627Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25254-4
  a curric:KeyLearningPoint ;
  rdfs:label """Some countries don’t join international courts, but global pressure encourages them to follow international law."""@en ;
  dcterms:modified "2026-02-12T08:59:21.732631Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25283-1
  a curric:KeyLearningPoint ;
  rdfs:label """Build systems, not just events, to make your project last beyond your involvement."""@en ;
  dcterms:modified "2026-02-12T08:59:21.733685Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25283-2
  a curric:KeyLearningPoint ;
  rdfs:label "Work with local groups to keep your project going after you step back."@en ;
  dcterms:modified "2026-02-12T08:59:21.733689Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25283-3
  a curric:KeyLearningPoint ;
  rdfs:label "Inspire others so your message and impact continue without you."@en ;
  dcterms:modified "2026-02-12T08:59:21.733693Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25283-4
  a curric:KeyLearningPoint ;
  rdfs:label "Active citizenship teaches you to make informed choices when voting."@en ;
  dcterms:modified "2026-02-12T08:59:21.733697Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25283-5
  a curric:KeyLearningPoint ;
  rdfs:label "It helps you advocate for others and defend your own rights confidently."@en ;
  dcterms:modified "2026-02-12T08:59:21.733701Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25371-1
  a curric:KeyLearningPoint ;
  rdfs:label """The UK Parliament overlaps the executive and legislative branches, the US separates them."""@en ;
  dcterms:modified "2026-02-12T08:59:21.733705Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25371-2
  a curric:KeyLearningPoint ;
  rdfs:label """The Prime Minister is part of the UK Parliament, the US President is independent."""@en ;
  dcterms:modified "2026-02-12T08:59:21.733709Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25371-3
  a curric:KeyLearningPoint ;
  rdfs:label """UK laws are passed by the UK Parliament, whereas laws in the US need presidential approval."""@en ;
  dcterms:modified "2026-02-12T08:59:21.733713Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25308-1
  a curric:KeyLearningPoint ;
  rdfs:label """Media includes mediums of getting information out to the masses on a large scale."""@en ;
  dcterms:modified "2026-02-12T08:59:21.733716Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25308-2
  a curric:KeyLearningPoint ;
  rdfs:label """There are different types of media: broadcast (TV, radio) print (newspapers, magazines) and new media (socials, blogs)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.733720Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25308-3
  a curric:KeyLearningPoint ;
  rdfs:label """The UK has a free press which means it is not subject to interference from the Government, this is vital in a democracy."""@en ;
  dcterms:modified "2026-02-12T08:59:21.733724Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25308-4
  a curric:KeyLearningPoint ;
  rdfs:label """Media supports democracy by providing us with information, checking the work of the Government and allowing for debate."""@en ;
  dcterms:modified "2026-02-12T08:59:21.733728Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25291-1
  a curric:KeyLearningPoint ;
  rdfs:label """Criminal law keeps society safe, ensures justice, and deters crime by setting clear rules and consequences."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734323Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25291-2
  a curric:KeyLearningPoint ;
  rdfs:label """It punishes offenders fairly, deters crime, and provides justice for victims by ensuring accountability."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734327Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25291-3
  a curric:KeyLearningPoint ;
  rdfs:label """Civil law resolves disputes and ensures justice when people's rights are affected, like family or work issues."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734331Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25291-4
  a curric:KeyLearningPoint ;
  rdfs:label """It holds individuals and businesses accountable, ensuring people can defend their rights."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734335Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25291-5
  a curric:KeyLearningPoint ;
  rdfs:label """Without civil law, people could struggle to protect their rights and resolve disputes fairly."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734339Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25279-1
  a curric:KeyLearningPoint ;
  rdfs:label "Set clear goals for what you want to achieve through your citizenship project."@en ;
  dcterms:modified "2026-02-12T08:59:21.734343Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25279-2
  a curric:KeyLearningPoint ;
  rdfs:label "Use SMART targets to break your goal into achievable steps."@en ;
  dcterms:modified "2026-02-12T08:59:21.734346Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25279-3
  a curric:KeyLearningPoint ;
  rdfs:label """Make a detailed action plan and use technology tools to stay on track and improve efficiency."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734350Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25279-4
  a curric:KeyLearningPoint ;
  rdfs:label """Get feedback from your teacher and do a SWOT analysis to improve the likelihood of your project’s success."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734354Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25373-1
  a curric:KeyLearningPoint ;
  rdfs:label """There are two main voting systems: First Past The Post and Proportional Representation, although other variations exist."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734894Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25373-2
  a curric:KeyLearningPoint ;
  rdfs:label "Different countries use different election systems."@en ;
  dcterms:modified "2026-02-12T08:59:21.734898Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25373-3
  a curric:KeyLearningPoint ;
  rdfs:label "Some countries use mixed systems, combining various election types."@en ;
  dcterms:modified "2026-02-12T08:59:21.734901Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25373-4
  a curric:KeyLearningPoint ;
  rdfs:label "The US electoral college is used for presidential elections in the USA."@en ;
  dcterms:modified "2026-02-12T08:59:21.734905Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25273-1
  a curric:KeyLearningPoint ;
  rdfs:label "We belong to school, local, national and global communities."@en ;
  dcterms:modified "2026-02-12T08:59:21.734911Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25273-2
  a curric:KeyLearningPoint ;
  rdfs:label "Communities share values but also have differences."@en ;
  dcterms:modified "2026-02-12T08:59:21.734917Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25273-3
  a curric:KeyLearningPoint ;
  rdfs:label "Issues linked to injustice and inequality can exist in all communities."@en ;
  dcterms:modified "2026-02-12T08:59:21.734921Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25273-4
  a curric:KeyLearningPoint ;
  rdfs:label "Some problems are community specific, others are shared across many communities."@en ;
  dcterms:modified "2026-02-12T08:59:21.734925Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25273-5
  a curric:KeyLearningPoint ;
  rdfs:label "Changemakers help improve life and fight injustice in all communities."@en ;
  dcterms:modified "2026-02-12T08:59:21.734929Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25245-1
  a curric:KeyLearningPoint ;
  rdfs:label "Referendums allow citizens to directly vote on important environmental policies."@en ;
  dcterms:modified "2026-02-12T08:59:21.734933Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25245-2
  a curric:KeyLearningPoint ;
  rdfs:label """The Irish Citizens' Assembly allowed citizens to discuss and advise on biodiversity issues."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734937Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25245-3
  a curric:KeyLearningPoint ;
  rdfs:label "Referendums for environmental issues can be costly and time-consuming."@en ;
  dcterms:modified "2026-02-12T08:59:21.734941Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25245-4
  a curric:KeyLearningPoint ;
  rdfs:label """Many environmental topics are complex and may require expert knowledge that the general public might not have."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734945Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25245-5
  a curric:KeyLearningPoint ;
  rdfs:label """In the UK, elected representatives make environmental laws and follow global agreements like the Paris Agreement."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734948Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25176-1
  a curric:KeyLearningPoint ;
  rdfs:label "Campaigning has a strong influence on changing or creating laws in the UK."@en ;
  dcterms:modified "2026-02-12T08:59:21.734952Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25176-2
  a curric:KeyLearningPoint ;
  rdfs:label "Laws like the Human Rights Act protect the right to campaign and protest."@en ;
  dcterms:modified "2026-02-12T08:59:21.734956Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25176-3
  a curric:KeyLearningPoint ;
  rdfs:label """Some see the Police, Crime, Sentencing and Courts Act as limiting protest rights."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734960Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25176-4
  a curric:KeyLearningPoint ;
  rdfs:label """The women's suffrage movement helped lead to laws giving women equal voting rights."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734964Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25176-5
  a curric:KeyLearningPoint ;
  rdfs:label """Stonewall’s campaigns have helped change laws to protect LGBTQ+ rights and equality."""@en ;
  dcterms:modified "2026-02-12T08:59:21.734968Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25198-1
  a curric:KeyLearningPoint ;
  rdfs:label """There are various crime prevention strategies used in the UK with variations in their effectiveness."""@en ;
  dcterms:modified "2026-02-12T08:59:21.735274Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25198-2
  a curric:KeyLearningPoint ;
  rdfs:label """Safer Schools Police Officers, intervention 22s and citizenship are all types of education which could reduce crime."""@en ;
  dcterms:modified "2026-02-12T08:59:21.735278Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25198-3
  a curric:KeyLearningPoint ;
  rdfs:label """Situational crime prevention strategies are things put in place to make crime more difficult or less successful."""@en ;
  dcterms:modified "2026-02-12T08:59:21.735283Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25198-4
  a curric:KeyLearningPoint ;
  rdfs:label """Deterrence is a strategy which aims to reduce crime by putting people off committing it due to the sentence."""@en ;
  dcterms:modified "2026-02-12T08:59:21.735288Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25247-1
  a curric:KeyLearningPoint ;
  rdfs:label """Political problems affect how a country is run and can create conflict or unfairness in society."""@en ;
  dcterms:modified "2026-02-12T08:59:21.736208Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25247-2
  a curric:KeyLearningPoint ;
  rdfs:label "Political problems can lead to low voter turnout and unfair representation."@en ;
  dcterms:modified "2026-02-12T08:59:21.736212Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25247-3
  a curric:KeyLearningPoint ;
  rdfs:label "Australia uses referendums to change its constitution through a national vote."@en ;
  dcterms:modified "2026-02-12T08:59:21.736216Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25247-4
  a curric:KeyLearningPoint ;
  rdfs:label "Electoral reform can be used to address political problems."@en ;
  dcterms:modified "2026-02-12T08:59:21.736220Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25173-1
  a curric:KeyLearningPoint ;
  rdfs:label "The media strongly influences public perception of immigration issues."@en ;
  dcterms:modified "2026-02-12T08:59:21.736224Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25173-2
  a curric:KeyLearningPoint ;
  rdfs:label "Positive media can highlight immigrant contributions and promote inclusion."@en ;
  dcterms:modified "2026-02-12T08:59:21.736227Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25173-3
  a curric:KeyLearningPoint ;
  rdfs:label """The media can support human rights and challenge harmful immigration stereotypes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.736233Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25173-4
  a curric:KeyLearningPoint ;
  rdfs:label "Negative or biased reporting may fuel public fear and resentment."@en ;
  dcterms:modified "2026-02-12T08:59:21.736239Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25173-5
  a curric:KeyLearningPoint ;
  rdfs:label "The media plays a powerful role in shaping immigration narratives and responses."@en ;
  dcterms:modified "2026-02-12T08:59:21.736243Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25318-1
  a curric:KeyLearningPoint ;
  rdfs:label "Campaign methods spread messages to target groups to create change."@en ;
  dcterms:modified "2026-02-12T08:59:21.736263Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25318-2
  a curric:KeyLearningPoint ;
  rdfs:label "Different campaign methods include protest, boycotting and lobbying."@en ;
  dcterms:modified "2026-02-12T08:59:21.736267Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25318-3
  a curric:KeyLearningPoint ;
  rdfs:label "Each campaign method will have advantages and disadvantages."@en ;
  dcterms:modified "2026-02-12T08:59:21.736270Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25318-4
  a curric:KeyLearningPoint ;
  rdfs:label """Campaign methods can be divided into direct action (e.g., protests) and indirect action (e.g., petitions)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.736276Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25318-5
  a curric:KeyLearningPoint ;
  rdfs:label "Direct and indirect actions have advantages and disadvantages."@en ;
  dcterms:modified "2026-02-12T08:59:21.736280Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25265-1
  a curric:KeyLearningPoint ;
  rdfs:label """Direct action is immediate action like protests or strikes to challenge injustice."""@en ;
  dcterms:modified "2026-02-12T08:59:21.736284Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25265-2
  a curric:KeyLearningPoint ;
  rdfs:label """Indirect action aims to bring about change over time through influencing others and using existing systems."""@en ;
  dcterms:modified "2026-02-12T08:59:21.736288Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25265-3
  a curric:KeyLearningPoint ;
  rdfs:label "Tools for change work differently depending on the campaign and goal."@en ;
  dcterms:modified "2026-02-12T08:59:21.736316Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25265-4
  a curric:KeyLearningPoint ;
  rdfs:label "Some injustices need legal or political action for lasting change."@en ;
  dcterms:modified "2026-02-12T08:59:21.736321Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25265-5
  a curric:KeyLearningPoint ;
  rdfs:label """No single tool works best; campaign success depends on the specific details such as the goal and who is in power."""@en ;
  dcterms:modified "2026-02-12T08:59:21.736325Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25253-1
  a curric:KeyLearningPoint ;
  rdfs:label """NGOs are non-governmental organisations using varied strategies to address social, political and humanitarian issues."""@en ;
  dcterms:modified "2026-02-12T08:59:21.736329Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25253-2
  a curric:KeyLearningPoint ;
  rdfs:label """NGOs respond to crises by delivering aid and often work with global agencies like the WHO to save lives."""@en ;
  dcterms:modified "2026-02-12T08:59:21.736333Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25253-3
  a curric:KeyLearningPoint ;
  rdfs:label """The effectiveness of NGOs in crises depends on factors like funding, accountability and community reach."""@en ;
  dcterms:modified "2026-02-12T08:59:21.736338Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25381-1
  a curric:KeyLearningPoint ;
  rdfs:label "Democracy means ‘rule of the people’, where citizens hold political power."@en ;
  dcterms:modified "2026-02-12T08:59:21.737184Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25381-2
  a curric:KeyLearningPoint ;
  rdfs:label """Representative democracy allows elected individuals to make decisions on behalf of the public."""@en ;
  dcterms:modified "2026-02-12T08:59:21.737190Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25381-3
  a curric:KeyLearningPoint ;
  rdfs:label """Democracy is based on core values such as freedom, justice, participation, accountability, tolerance and human rights."""@en ;
  dcterms:modified "2026-02-12T08:59:21.737194Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25381-4
  a curric:KeyLearningPoint ;
  rdfs:label """Balancing democratic values with rights involves protecting freedoms like speech while preventing things like abuse."""@en ;
  dcterms:modified "2026-02-12T08:59:21.737198Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25381-5
  a curric:KeyLearningPoint ;
  rdfs:label """This balance is kept through laws like the Human Rights Act 1998 and Equality Act 2010, alongside judicial oversight."""@en ;
  dcterms:modified "2026-02-12T08:59:21.737202Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25297-1
  a curric:KeyLearningPoint ;
  rdfs:label """Voting is important because it allows people to choose their leaders and influence decisions on key issues."""@en ;
  dcterms:modified "2026-02-12T08:59:21.737640Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25297-2
  a curric:KeyLearningPoint ;
  rdfs:label "Voting ensures your voice is heard and helps shape the future."@en ;
  dcterms:modified "2026-02-12T08:59:21.737647Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25297-3
  a curric:KeyLearningPoint ;
  rdfs:label """Politics isn't just about voting other actions you can take include: attend protests, contact your MP or sign petitions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.737652Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25297-4
  a curric:KeyLearningPoint ;
  rdfs:label """Young people can make a difference by speaking out on social media, participating in campaigns and youth councils."""@en ;
  dcterms:modified "2026-02-12T08:59:21.737656Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25297-5
  a curric:KeyLearningPoint ;
  rdfs:label """Being an active citizen means being aware, engaging with your community and taking action to make a positive impact."""@en ;
  dcterms:modified "2026-02-12T08:59:21.737660Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25229-1
  a curric:KeyLearningPoint ;
  rdfs:label """The Government has power through elections, gaining a mandate to make decisions for all."""@en ;
  dcterms:modified "2026-02-12T08:59:21.737664Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25229-2
  a curric:KeyLearningPoint ;
  rdfs:label """Parliamentary sovereignty lets the Government change laws, shaping society and key policies."""@en ;
  dcterms:modified "2026-02-12T08:59:21.737668Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25229-3
  a curric:KeyLearningPoint ;
  rdfs:label """The media shapes public opinion, reaching millions daily and influencing elections."""@en ;
  dcterms:modified "2026-02-12T08:59:21.737672Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25229-4
  a curric:KeyLearningPoint ;
  rdfs:label """Media holds the Government accountable but can also spread misinformation online."""@en ;
  dcterms:modified "2026-02-12T08:59:21.737676Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25316-1
  a curric:KeyLearningPoint ;
  rdfs:label """Research is an important part of the active citizenship project cycle as it enables well informed-decision making."""@en ;
  dcterms:modified "2026-02-12T08:59:21.738056Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25316-2
  a curric:KeyLearningPoint ;
  rdfs:label """Research can be divided into two types: primary (original data) or secondary (existing data)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.738060Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25316-3
  a curric:KeyLearningPoint ;
  rdfs:label """Key questions like 'what do we need to know?' and 'who to involve?' guide the choice of research methods."""@en ;
  dcterms:modified "2026-02-12T08:59:21.738064Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25316-4
  a curric:KeyLearningPoint ;
  rdfs:label """Pupils may need qualitative (descriptive) or quantitative (numerical) data for their active citizenship project."""@en ;
  dcterms:modified "2026-02-12T08:59:21.738068Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25296-1
  a curric:KeyLearningPoint ;
  rdfs:label """FPTP is a voting system where the candidate with the most votes wins, even without a majority."""@en ;
  dcterms:modified "2026-02-12T08:59:21.738072Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25296-2
  a curric:KeyLearningPoint ;
  rdfs:label "FPTP can lead to 'wasted vote' and may not reflect the views of all voters."@en ;
  dcterms:modified "2026-02-12T08:59:21.738076Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25296-3
  a curric:KeyLearningPoint ;
  rdfs:label """The UK uses more proportional voting systems like AMS in Scotland and Wales for fairer representation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.738080Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25296-4
  a curric:KeyLearningPoint ;
  rdfs:label "Some argue FPTP should be reformed to better reflect voters' true choices."@en ;
  dcterms:modified "2026-02-12T08:59:21.738084Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25296-5
  a curric:KeyLearningPoint ;
  rdfs:label "Others defend FPTP for its simplicity, fearing reforms may complicate results."@en ;
  dcterms:modified "2026-02-12T08:59:21.738088Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29590-1
  a curric:KeyLearningPoint ;
  rdfs:label """Safeguarding protects people from harm and is key during active citizenship projects."""@en ;
  dcterms:modified "2026-02-12T08:59:21.738829Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29590-2
  a curric:KeyLearningPoint ;
  rdfs:label "Keep yourself safe by avoiding dangerous situations or harmful content."@en ;
  dcterms:modified "2026-02-12T08:59:21.738835Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29590-3
  a curric:KeyLearningPoint ;
  rdfs:label "Think about others' age and experience to avoid causing them distress."@en ;
  dcterms:modified "2026-02-12T08:59:21.738839Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29590-4
  a curric:KeyLearningPoint ;
  rdfs:label "Always explain your project clearly and allow people to opt out if needed."@en ;
  dcterms:modified "2026-02-12T08:59:21.738843Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29590-5
  a curric:KeyLearningPoint ;
  rdfs:label "Do a risk assessment with your teacher to plan a safe and responsible project."@en ;
  dcterms:modified "2026-02-12T08:59:21.738847Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25235-1
  a curric:KeyLearningPoint ;
  rdfs:label """Free and fair elections allow people to vote for their representatives without fear, manipulation, or interference."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739071Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25235-2
  a curric:KeyLearningPoint ;
  rdfs:label """Social media likely impacted voting beliefs and behaviour during the UK 2024 election, both positively and negatively."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739076Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25235-3
  a curric:KeyLearningPoint ;
  rdfs:label """Social media shaped public opinion, amplified political messages and provided a platform for debate."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739080Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25235-4
  a curric:KeyLearningPoint ;
  rdfs:label """Influencers can increase voter engagement, raise awareness of political issues and encourage public debate."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739084Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25235-5
  a curric:KeyLearningPoint ;
  rdfs:label """Influencers can reduce informed decision-making, spread misinformation and raise concerns about financial motivation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739088Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25241-1
  a curric:KeyLearningPoint ;
  rdfs:label """Actions the UN has taken include organising climate conferences, creating SDGs & mobilising funding for climate action."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739092Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25241-2
  a curric:KeyLearningPoint ;
  rdfs:label "The UN primarily uses soft powers to encourage global climate action."@en ;
  dcterms:modified "2026-02-12T08:59:21.739096Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25241-3
  a curric:KeyLearningPoint ;
  rdfs:label """Views on the UN’s effectiveness in tackling climate change differ, with progress seen alongside ongoing challenges."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739100Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25287-1
  a curric:KeyLearningPoint ;
  rdfs:label """The UK Government borrows when tax revenue is insufficient to fund essential services."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739104Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25287-2
  a curric:KeyLearningPoint ;
  rdfs:label """Borrowing supports public spending, infrastructure and economic stability during crises."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739108Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25287-3
  a curric:KeyLearningPoint ;
  rdfs:label "Excessive borrowing can limit future investment and create financial risks."@en ;
  dcterms:modified "2026-02-12T08:59:21.739112Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25287-4
  a curric:KeyLearningPoint ;
  rdfs:label """Government regulations protect borrowers from unfair lending and high interest debt traps."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739116Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25287-5
  a curric:KeyLearningPoint ;
  rdfs:label """Responsible borrowing and awareness of financial protections help individuals and the economy stay secure."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739119Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25285-1
  a curric:KeyLearningPoint ;
  rdfs:label """Taxation funds essential public services, ensuring universal access to healthcare, education and infrastructure."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739123Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25285-2
  a curric:KeyLearningPoint ;
  rdfs:label """Tax avoidance, though legal, reduces government revenue, whereas tax evasion is illegal and punishable by law."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739127Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25285-3
  a curric:KeyLearningPoint ;
  rdfs:label """Taxation upholds social equity by ensuring proportional contributions based on income levels."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739131Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25285-4
  a curric:KeyLearningPoint ;
  rdfs:label """Tax-free economies often rely on high consumption taxes or privatised services, increasing financial barriers to access."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739137Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25285-5
  a curric:KeyLearningPoint ;
  rdfs:label """Without taxation, public services would become market-dependent, exacerbating social and economic inequalities."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739141Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27980-1
  a curric:KeyLearningPoint ;
  rdfs:label """Banking in the UK has evolved from traditional branch services to widespread online banking."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739145Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27980-2
  a curric:KeyLearningPoint ;
  rdfs:label """Technological advances such as ATMs, debit cards and mobile apps have transformed financial management."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739149Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27980-3
  a curric:KeyLearningPoint ;
  rdfs:label """This shift has increased risks, notably online fraud and challenges linked to an ageing population."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739153Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27980-4
  a curric:KeyLearningPoint ;
  rdfs:label """Online banking has improved accessibility for some people but also deepened the digital divide."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739157Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27980-5
  a curric:KeyLearningPoint ;
  rdfs:label """Government initiatives now focus on regulation, education and community support to address these issues."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739161Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25311-1
  a curric:KeyLearningPoint ;
  rdfs:label """There are different types of false information including misinformation, disinformation and malinformation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739545Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25311-2
  a curric:KeyLearningPoint ;
  rdfs:label """False information is damaging in a democracy as citizens need to be able to trust the news."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739549Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25311-3
  a curric:KeyLearningPoint ;
  rdfs:label """Regulations can support in limiting the ammount of false news, but social media is more difficult to regulate."""@en ;
  dcterms:modified "2026-02-12T08:59:21.739553Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25311-4
  a curric:KeyLearningPoint ;
  rdfs:label "Citizens should critically evaluate information to consider its accuracy."@en ;
  dcterms:modified "2026-02-12T08:59:21.739557Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25234-1
  a curric:KeyLearningPoint ;
  rdfs:label """A democracy includes democratic values as well as being able to vote in elections, eg. respect, tolerance, rule of law."""@en ;
  dcterms:modified "2026-02-12T08:59:21.740899Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25234-2
  a curric:KeyLearningPoint ;
  rdfs:label """Digital media unites communities by coordininating support during crisis, supporting campaigns and celebrating culture."""@en ;
  dcterms:modified "2026-02-12T08:59:21.740903Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25234-3
  a curric:KeyLearningPoint ;
  rdfs:label """Digital media divides communities by the sharing of disinformation and hate speech, echo chambers and polarisation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.740907Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25227-1
  a curric:KeyLearningPoint ;
  rdfs:label "The ability to find out about international issues is key part of democracy."@en ;
  dcterms:modified "2026-02-12T08:59:21.740911Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25227-2
  a curric:KeyLearningPoint ;
  rdfs:label """UK media uses foreign correspondents, partnerships, citizen journalism and NGO data to report international news."""@en ;
  dcterms:modified "2026-02-12T08:59:21.740915Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25227-3
  a curric:KeyLearningPoint ;
  rdfs:label """Journalists must be free to report accurately within a democracy but their ability to do this is inconsistent."""@en ;
  dcterms:modified "2026-02-12T08:59:21.740919Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25227-4
  a curric:KeyLearningPoint ;
  rdfs:label """In countries where journalists are protected by press freedom laws, citizens have access to a free press, & vice versa."""@en ;
  dcterms:modified "2026-02-12T08:59:21.740923Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25227-5
  a curric:KeyLearningPoint ;
  rdfs:label """There are international organisations that work to protect journalists and campaign for global press freedom."""@en ;
  dcterms:modified "2026-02-12T08:59:21.740929Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29601-1
  a curric:KeyLearningPoint ;
  rdfs:label "International law influences UK law through treaties and agreements."@en ;
  dcterms:modified "2026-02-12T08:59:21.740934Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29601-2
  a curric:KeyLearningPoint ;
  rdfs:label "The UK must follow international laws it agrees to."@en ;
  dcterms:modified "2026-02-12T08:59:21.740940Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-29601-3
  a curric:KeyLearningPoint ;
  rdfs:label "International law can shape UK court decisions and government actions."@en ;
  dcterms:modified "2026-02-12T08:59:21.740944Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25175-1
  a curric:KeyLearningPoint ;
  rdfs:label "The Government makes key decisions to help the UK economy grow and stay stable."@en ;
  dcterms:modified "2026-02-12T08:59:21.741278Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25175-2
  a curric:KeyLearningPoint ;
  rdfs:label "Support is given to struggling businesses and communities to help them recover."@en ;
  dcterms:modified "2026-02-12T08:59:21.741282Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25175-3
  a curric:KeyLearningPoint ;
  rdfs:label """The economy can be affected by unexpected global events outside government control."""@en ;
  dcterms:modified "2026-02-12T08:59:21.741286Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25175-4
  a curric:KeyLearningPoint ;
  rdfs:label "Quick political decisions are sometimes needed to protect jobs and services."@en ;
  dcterms:modified "2026-02-12T08:59:21.741290Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25175-5
  a curric:KeyLearningPoint ;
  rdfs:label "These decisions aim to keep the economy strong during tough times."@en ;
  dcterms:modified "2026-02-12T08:59:21.741293Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25375-1
  a curric:KeyLearningPoint ;
  rdfs:label """Devolution is the transfer of powers from the UK government to regional government."""@en ;
  dcterms:modified "2026-02-12T08:59:21.741814Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25375-2
  a curric:KeyLearningPoint ;
  rdfs:label "Scotland, Wales and Northern Ireland have their own parliaments or assemblies."@en ;
  dcterms:modified "2026-02-12T08:59:21.741818Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25375-3
  a curric:KeyLearningPoint ;
  rdfs:label """Devolution allows regions to make decisions on local issues such as health or education."""@en ;
  dcterms:modified "2026-02-12T08:59:21.741823Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25375-4
  a curric:KeyLearningPoint ;
  rdfs:label "Devolution is still evolving and powers continue to be devolved."@en ;
  dcterms:modified "2026-02-12T08:59:21.741830Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25276-1
  a curric:KeyLearningPoint ;
  rdfs:label """Secondary research has been collected and published by others and includes articles, reports and websites."""@en ;
  dcterms:modified "2026-02-12T08:59:21.741834Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25276-2
  a curric:KeyLearningPoint ;
  rdfs:label """High quality secondary data should be valid, reliable, accurate, current and free from bias."""@en ;
  dcterms:modified "2026-02-12T08:59:21.741838Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25276-3
  a curric:KeyLearningPoint ;
  rdfs:label """It can help you to back up your arguments with facts and persuade others to support your action."""@en ;
  dcterms:modified "2026-02-12T08:59:21.741842Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25276-4
  a curric:KeyLearningPoint ;
  rdfs:label "It can also provide you with useful tips about methods you could use."@en ;
  dcterms:modified "2026-02-12T08:59:21.741845Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25191-1
  a curric:KeyLearningPoint ;
  rdfs:label """Law change succeeds with public support, strong media, political backing, clear goals and expert input."""@en ;
  dcterms:modified "2026-02-12T08:59:21.741849Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25191-2
  a curric:KeyLearningPoint ;
  rdfs:label """A united, well-funded and persistent campaign increases the chance of legal reform."""@en ;
  dcterms:modified "2026-02-12T08:59:21.741853Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25191-3
  a curric:KeyLearningPoint ;
  rdfs:label """The marriage age law changed due to broad support, media coverage and expert-backed advocacy."""@en ;
  dcterms:modified "2026-02-12T08:59:21.741857Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25191-4
  a curric:KeyLearningPoint ;
  rdfs:label """Law change often fails with weak support, poor media and divided political or public opinion."""@en ;
  dcterms:modified "2026-02-12T08:59:21.741861Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25191-5
  a curric:KeyLearningPoint ;
  rdfs:label """Cannabis legalisation struggles due to mixed views, limited backing and lack of consistent advocacy."""@en ;
  dcterms:modified "2026-02-12T08:59:21.741865Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25293-1
  a curric:KeyLearningPoint ;
  rdfs:label """Police enforce laws, prevent crime, protect the public, and maintain order while building community trust."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742524Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25293-2
  a curric:KeyLearningPoint ;
  rdfs:label """Police respond to emergencies, investigate crimes, and ensure justice while safeguarding people and property."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742528Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25293-3
  a curric:KeyLearningPoint ;
  rdfs:label """Police can arrest suspects, search properties with warrants, or stop and search based on reasonable suspicion."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742531Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25293-4
  a curric:KeyLearningPoint ;
  rdfs:label """Citizens must be treated with dignity, informed of their rights, and given access to legal support during arrests."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742535Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25293-5
  a curric:KeyLearningPoint ;
  rdfs:label """Vulnerable individuals need an appropriate adult present during questioning and have rights to basic care."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742539Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25243-1
  a curric:KeyLearningPoint ;
  rdfs:label "Policies are aimed to address issues such as healthcare."@en ;
  dcterms:modified "2026-02-12T08:59:21.742543Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25243-2
  a curric:KeyLearningPoint ;
  rdfs:label "Policies are shaped through proposals, debates and consultations."@en ;
  dcterms:modified "2026-02-12T08:59:21.742546Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25243-3
  a curric:KeyLearningPoint ;
  rdfs:label "Citizens shape policies directly by voting and protesting."@en ;
  dcterms:modified "2026-02-12T08:59:21.742550Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25243-4
  a curric:KeyLearningPoint ;
  rdfs:label """Citizens shape policies indirectly by petitions  and participating in consultations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742554Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25213-1
  a curric:KeyLearningPoint ;
  rdfs:label """Being a citizen of the UK comes with a range of rights and freedoms, but also with certain obligations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742558Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25213-2
  a curric:KeyLearningPoint ;
  rdfs:label "The rights and freedoms we have come partly from The Human Rights Act (1998)."@en ;
  dcterms:modified "2026-02-12T08:59:21.742562Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25213-3
  a curric:KeyLearningPoint ;
  rdfs:label "As we get older, we are given more rights and our obligations increase too."@en ;
  dcterms:modified "2026-02-12T08:59:21.742566Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25202-1
  a curric:KeyLearningPoint ;
  rdfs:label """The Vote Remain campaign set out three main arguments centered around control, the economy and our national identity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742570Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25202-2
  a curric:KeyLearningPoint ;
  rdfs:label """Vote Remain argued that being in the EU gives us more control, as leaving means losing our voice in the EU Parliament."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742573Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25202-3
  a curric:KeyLearningPoint ;
  rdfs:label """Vote Remain argued that being in the EU's single market makes trade easier and more cost-effective for businesses."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742577Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25202-4
  a curric:KeyLearningPoint ;
  rdfs:label """Vote Remain argued that our connection to Europe was an important part of our identity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.742583Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25218-1
  a curric:KeyLearningPoint ;
  rdfs:label "The local economy involves money, businesses and jobs within a community."@en ;
  dcterms:modified "2026-02-12T08:59:21.743105Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25218-2
  a curric:KeyLearningPoint ;
  rdfs:label """The local economy changes due to business growth, industry shifts, and consumer habits."""@en ;
  dcterms:modified "2026-02-12T08:59:21.743109Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25218-3
  a curric:KeyLearningPoint ;
  rdfs:label """Employment, government policies, transport and public services impact the success of the local economy."""@en ;
  dcterms:modified "2026-02-12T08:59:21.743112Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25218-4
  a curric:KeyLearningPoint ;
  rdfs:label "Investment in infrastructure and business support promotes economic growth."@en ;
  dcterms:modified "2026-02-12T08:59:21.743116Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25218-5
  a curric:KeyLearningPoint ;
  rdfs:label """A strong local economy creates jobs, supports businesses and funds public services."""@en ;
  dcterms:modified "2026-02-12T08:59:21.743120Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25237-1
  a curric:KeyLearningPoint ;
  rdfs:label """Climate change drives species extinction, habitat loss, and soil erosion, worsening the environmental crisis."""@en ;
  dcterms:modified "2026-02-12T08:59:21.743162Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25237-2
  a curric:KeyLearningPoint ;
  rdfs:label """Positive action is happening at individual, group, and government levels to combat climate change."""@en ;
  dcterms:modified "2026-02-12T08:59:21.743166Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25237-3
  a curric:KeyLearningPoint ;
  rdfs:label """Climate change impacts human rights, with vulnerable communities facing food insecurity, health risks, and displacement."""@en ;
  dcterms:modified "2026-02-12T08:59:21.743170Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25237-4
  a curric:KeyLearningPoint ;
  rdfs:label """Resource scarcity from climate change threatens global stability, increasing the risk of conflict and civil unrest."""@en ;
  dcterms:modified "2026-02-12T08:59:21.743174Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25195-1
  a curric:KeyLearningPoint ;
  rdfs:label """All crimes that are reported must be recorded as either crime or non-crime incidents."""@en ;
  dcterms:modified "2026-02-12T08:59:21.743178Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25195-2
  a curric:KeyLearningPoint ;
  rdfs:label """There are two ways in which crime is recorded, via police data and crime surveys."""@en ;
  dcterms:modified "2026-02-12T08:59:21.743182Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25195-3
  a curric:KeyLearningPoint ;
  rdfs:label "Crime figures are not necessarily always accurate as not all crime is reported."@en ;
  dcterms:modified "2026-02-12T08:59:21.743187Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25195-4
  a curric:KeyLearningPoint ;
  rdfs:label "The media can impact perception of crime and therefore crime reporting."@en ;
  dcterms:modified "2026-02-12T08:59:21.743192Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25236-1
  a curric:KeyLearningPoint ;
  rdfs:label """Climate change poses serious challenges to humanity, including health issues, people displacement and resource scarcity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.743292Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25236-2
  a curric:KeyLearningPoint ;
  rdfs:label """The UN uses both hard and soft power to drive global change, despite facing political and practical challenges."""@en ;
  dcterms:modified "2026-02-12T08:59:21.743296Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25236-3
  a curric:KeyLearningPoint ;
  rdfs:label """The SDGs are 17 global goals set by the UN to promote sustainable development and reduce inequality by 2030."""@en ;
  dcterms:modified "2026-02-12T08:59:21.743300Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25236-4
  a curric:KeyLearningPoint ;
  rdfs:label """The UN’s work on the SDGs and peacekeeping shows its long-term influence, though action can be slow and complex."""@en ;
  dcterms:modified "2026-02-12T08:59:21.743303Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25181-1
  a curric:KeyLearningPoint ;
  rdfs:label "Countries have different political systems for making decisions."@en ;
  dcterms:modified "2026-02-12T08:59:21.743329Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25181-2
  a curric:KeyLearningPoint ;
  rdfs:label "Parliamentary systems, like the UK, have a Prime Minister."@en ;
  dcterms:modified "2026-02-12T08:59:21.743333Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25181-3
  a curric:KeyLearningPoint ;
  rdfs:label """Presidential systems, like the USA, have a President who is the Head of State and Head of Government."""@en ;
  dcterms:modified "2026-02-12T08:59:21.743337Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25181-4
  a curric:KeyLearningPoint ;
  rdfs:label "Hybrid systems, like France, combine elements of other systems."@en ;
  dcterms:modified "2026-02-12T08:59:21.743341Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25312-1
  a curric:KeyLearningPoint ;
  rdfs:label """Sometimes media is censored due to potentially causing offence, sensitive content, or harmful content."""@en ;
  dcterms:modified "2026-02-12T08:59:21.744631Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25312-2
  a curric:KeyLearningPoint ;
  rdfs:label """Inconvenience censorship also happens where certain information might need to be restricted."""@en ;
  dcterms:modified "2026-02-12T08:59:21.744635Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25312-3
  a curric:KeyLearningPoint ;
  rdfs:label "Censorship can also happen to support democracy and uphold democratic values."@en ;
  dcterms:modified "2026-02-12T08:59:21.744639Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25312-4
  a curric:KeyLearningPoint ;
  rdfs:label """There are global differences in censorship, for example, China has very strict censorship."""@en ;
  dcterms:modified "2026-02-12T08:59:21.744643Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25359-1
  a curric:KeyLearningPoint ;
  rdfs:label """Bicameral refers to the two chambers in UK Parliament which are the House of Commons and the House of Lords."""@en ;
  dcterms:modified "2026-02-12T08:59:21.744647Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25359-2
  a curric:KeyLearningPoint ;
  rdfs:label "The bicameral system has evolved over time."@en ;
  dcterms:modified "2026-02-12T08:59:21.744651Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25359-3
  a curric:KeyLearningPoint ;
  rdfs:label """Advantages include more scrutiny of suggested laws; disadvantages include slower processes and not fully representative."""@en ;
  dcterms:modified "2026-02-12T08:59:21.744654Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25278-1
  a curric:KeyLearningPoint ;
  rdfs:label """Listening to others helps you understand diverse views and strengthens your arguments for decision makers."""@en ;
  dcterms:modified "2026-02-12T08:59:21.744658Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25278-2
  a curric:KeyLearningPoint ;
  rdfs:label """Considering different perspectives can improve your action’s methods and outcomes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.744662Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25278-3
  a curric:KeyLearningPoint ;
  rdfs:label """Team collaboration builds communication and teamwork skills for real life democracy action."""@en ;
  dcterms:modified "2026-02-12T08:59:21.744666Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25278-4
  a curric:KeyLearningPoint ;
  rdfs:label "Sharing ideas with your team makes your action more organised and impactful."@en ;
  dcterms:modified "2026-02-12T08:59:21.744670Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25278-5
  a curric:KeyLearningPoint ;
  rdfs:label "Working with others prepares you for active citizenship now and in the future."@en ;
  dcterms:modified "2026-02-12T08:59:21.744674Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25238-1
  a curric:KeyLearningPoint ;
  rdfs:label "The UN organises COP summits to unite countries and set climate action goals."@en ;
  dcterms:modified "2026-02-12T08:59:21.744678Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25238-2
  a curric:KeyLearningPoint ;
  rdfs:label """The UNFCCC framework guides global climate policies, including the Paris Agreement on limiting temperature rise."""@en ;
  dcterms:modified "2026-02-12T08:59:21.744682Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25238-3
  a curric:KeyLearningPoint ;
  rdfs:label """HICs have more resources for climate action but are also major contributors to climate change due to fossil fuel use."""@en ;
  dcterms:modified "2026-02-12T08:59:21.744686Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25238-4
  a curric:KeyLearningPoint ;
  rdfs:label """LICs face challenges in funding climate action but are working with the UN to implement solutions like green energy."""@en ;
  dcterms:modified "2026-02-12T08:59:21.744689Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25319-1
  a curric:KeyLearningPoint ;
  rdfs:label """Measuring impact helps improve future projects by showing what worked and what needs to change."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745152Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25319-2
  a curric:KeyLearningPoint ;
  rdfs:label """Evidence like feedback, participation levels, or policy changes can be used to measure the success of the project."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745156Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25319-3
  a curric:KeyLearningPoint ;
  rdfs:label """Both short-term progress and long-term effects help show the real impact of an active citizenship project."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745160Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25319-4
  a curric:KeyLearningPoint ;
  rdfs:label """Evaluation results are used to improve, adapt strategies, or plan further actions for greater impact in the future."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745164Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27983-1
  a curric:KeyLearningPoint ;
  rdfs:label """Fintech companies are introducing innovative financial products that are transforming money management in the UK."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745168Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27983-2
  a curric:KeyLearningPoint ;
  rdfs:label """Some financial products are increasing accessibility, convenience and support for educating young people."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745172Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27983-3
  a curric:KeyLearningPoint ;
  rdfs:label """Some new emerging financial products present risks, including potential debt and digital exclusion."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745178Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27983-4
  a curric:KeyLearningPoint ;
  rdfs:label """Emerging trends like green finance, open banking and financial inclusion are reshaping the financial services sector."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745182Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27983-5
  a curric:KeyLearningPoint ;
  rdfs:label """Understanding these developments equips young people to make informed financial decisions in modern Britain."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745185Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25377-1
  a curric:KeyLearningPoint ;
  rdfs:label """Local councils provide many services including education, healthcare, transport, housing and waste management."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745190Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25377-2
  a curric:KeyLearningPoint ;
  rdfs:label """Local councils are given a budget through government funding, council tax and business rates."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745194Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25377-3
  a curric:KeyLearningPoint ;
  rdfs:label """Local councils have the power to make decisions on planning, local laws and public services."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745198Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25377-4
  a curric:KeyLearningPoint ;
  rdfs:label """Community members can get their voice heard by voting in elections or attending council meetings."""@en ;
  dcterms:modified "2026-02-12T08:59:21.745202Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25369-1
  a curric:KeyLearningPoint ;
  rdfs:label """Governments range across the world from full democracies to authoritarian regimes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.746223Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25369-2
  a curric:KeyLearningPoint ;
  rdfs:label "There are five main factors that determine how democratic a country is."@en ;
  dcterms:modified "2026-02-12T08:59:21.746227Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25369-3
  a curric:KeyLearningPoint ;
  rdfs:label "Systems of government are different across the world."@en ;
  dcterms:modified "2026-02-12T08:59:21.746231Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25360-1
  a curric:KeyLearningPoint ;
  rdfs:label """Power in the UK is split into three branches; the legislative, the executive and the judiciary."""@en ;
  dcterms:modified "2026-02-12T08:59:21.746583Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25360-2
  a curric:KeyLearningPoint ;
  rdfs:label """Separation of powers exist to ensure checks and balances, accountability, protection of rights and scrutiny."""@en ;
  dcterms:modified "2026-02-12T08:59:21.746586Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25360-3
  a curric:KeyLearningPoint ;
  rdfs:label """Power is shared to prevent corruption, allowing each branch to oversee and check the actions of the others."""@en ;
  dcterms:modified "2026-02-12T08:59:21.746590Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25299-1
  a curric:KeyLearningPoint ;
  rdfs:label """The main UK parties—Conservatives, Labour, and Liberal Democrats—each have distinct ideas, priorities, and policies."""@en ;
  dcterms:modified "2026-02-12T08:59:21.747355Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25299-2
  a curric:KeyLearningPoint ;
  rdfs:label """The political spectrum shows where parties like Conservatives and Labour are positioned based on their policies."""@en ;
  dcterms:modified "2026-02-12T08:59:21.747359Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25299-3
  a curric:KeyLearningPoint ;
  rdfs:label """Smaller parties like Reform UK, Green Party, the SNP and Plaid Cymru often focus on specific issues or policies."""@en ;
  dcterms:modified "2026-02-12T08:59:21.747363Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25299-4
  a curric:KeyLearningPoint ;
  rdfs:label """Smaller parties can influence decisions by forming coalitions or pushing larger parties' ideas."""@en ;
  dcterms:modified "2026-02-12T08:59:21.747367Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25222-1
  a curric:KeyLearningPoint ;
  rdfs:label """Consumer spending in the UK has shifted towards online shopping and experience-based purchases."""@en ;
  dcterms:modified "2026-02-12T08:59:21.747669Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25222-2
  a curric:KeyLearningPoint ;
  rdfs:label """The decline of the high street has been accelerated by the growth of online companies and Covid-19 lockdowns."""@en ;
  dcterms:modified "2026-02-12T08:59:21.747673Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25222-3
  a curric:KeyLearningPoint ;
  rdfs:label """Local councils are using regeneration strategies to improve retail areas and boost local economies."""@en ;
  dcterms:modified "2026-02-12T08:59:21.747676Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25222-4
  a curric:KeyLearningPoint ;
  rdfs:label """The Brixton Arches case highlights how regeneration can raise rents and displace long-standing businesses."""@en ;
  dcterms:modified "2026-02-12T08:59:21.747680Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25222-5
  a curric:KeyLearningPoint ;
  rdfs:label """This highlights the link between regeneration and gentrification in high street redevelopment."""@en ;
  dcterms:modified "2026-02-12T08:59:21.747684Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25203-1
  a curric:KeyLearningPoint ;
  rdfs:label "Vote Leave campaigned to exit the EU."@en ;
  dcterms:modified "2026-02-12T08:59:21.747688Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25203-2
  a curric:KeyLearningPoint ;
  rdfs:label "They argued it was better for control to leave the EU."@en ;
  dcterms:modified "2026-02-12T08:59:21.747692Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25203-3
  a curric:KeyLearningPoint ;
  rdfs:label "They argued it was better for the economy to leave the EU."@en ;
  dcterms:modified "2026-02-12T08:59:21.747698Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25203-4
  a curric:KeyLearningPoint ;
  rdfs:label "They argued it was better for national identity to leave the EU."@en ;
  dcterms:modified "2026-02-12T08:59:21.747702Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27987-1
  a curric:KeyLearningPoint ;
  rdfs:label "The media provides information and holds those in power to account."@en ;
  dcterms:modified "2026-02-12T08:59:21.747706Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27987-2
  a curric:KeyLearningPoint ;
  rdfs:label "Governments in a democracy make laws and manage national policies."@en ;
  dcterms:modified "2026-02-12T08:59:21.747712Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27987-3
  a curric:KeyLearningPoint ;
  rdfs:label """A free media challenges government actions through investigations and public reporting."""@en ;
  dcterms:modified "2026-02-12T08:59:21.747716Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27987-4
  a curric:KeyLearningPoint ;
  rdfs:label "Media scrutiny helps prevent misuse of power and keeps citizens informed."@en ;
  dcterms:modified "2026-02-12T08:59:21.747720Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25194-1
  a curric:KeyLearningPoint ;
  rdfs:label """There are different and complex reasons for why people commit crime e.g social, economic, psychological and educational."""@en ;
  dcterms:modified "2026-02-12T08:59:21.747945Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25194-2
  a curric:KeyLearningPoint ;
  rdfs:label "The physical environment can impact crime rates."@en ;
  dcterms:modified "2026-02-12T08:59:21.747969Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25194-3
  a curric:KeyLearningPoint ;
  rdfs:label """Prejudice exists towards crime and criminality and this can have a negative impact in the justice system."""@en ;
  dcterms:modified "2026-02-12T08:59:21.747973Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25262-1
  a curric:KeyLearningPoint ;
  rdfs:label "Grassroots campaigns are started by ordinary people, not powerful leaders."@en ;
  dcterms:modified "2026-02-12T08:59:21.747993Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25262-2
  a curric:KeyLearningPoint ;
  rdfs:label """Grassroots campaigns often focus on local issues that affect communities directly."""@en ;
  dcterms:modified "2026-02-12T08:59:21.747998Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25262-3
  a curric:KeyLearningPoint ;
  rdfs:label "Campaigners use simple methods like petitions and protests."@en ;
  dcterms:modified "2026-02-12T08:59:21.748004Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25262-4
  a curric:KeyLearningPoint ;
  rdfs:label "Working together helps grassroots developments stronger and more effective."@en ;
  dcterms:modified "2026-02-12T08:59:21.748009Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25262-5
  a curric:KeyLearningPoint ;
  rdfs:label "Even small actions can lead to real change when many people get involved."@en ;
  dcterms:modified "2026-02-12T08:59:21.748013Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25275-1
  a curric:KeyLearningPoint ;
  rdfs:label """Choose a topic that connects clearly to a key idea or value of citizenship you've studied in class."""@en ;
  dcterms:modified "2026-02-12T08:59:21.748017Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25275-2
  a curric:KeyLearningPoint ;
  rdfs:label """Make SMART goals to ensure your actions are focused, achievable, and meaningful for your chosen issue."""@en ;
  dcterms:modified "2026-02-12T08:59:21.748020Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25275-3
  a curric:KeyLearningPoint ;
  rdfs:label """Educate others and raise awareness to shift opinions and communicate with decision makers to share your ideas."""@en ;
  dcterms:modified "2026-02-12T08:59:21.748024Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25275-4
  a curric:KeyLearningPoint ;
  rdfs:label "Reember that the difference you make could be suble, but this is stil valuable."@en ;
  dcterms:modified "2026-02-12T08:59:21.748028Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25275-5
  a curric:KeyLearningPoint ;
  rdfs:label """Fundraising is helpful, but combine it with awareness to make a real and lasting impact."""@en ;
  dcterms:modified "2026-02-12T08:59:21.748032Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25249-1
  a curric:KeyLearningPoint ;
  rdfs:label """Humanitarian problems can be sudden or long-term and often lead to widespread human suffering and displacement."""@en ;
  dcterms:modified "2026-02-12T08:59:21.748038Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25249-2
  a curric:KeyLearningPoint ;
  rdfs:label """Short-term responses to humanitarian crises focus on saving lives, providing immediate aid and preventing further harm."""@en ;
  dcterms:modified "2026-02-12T08:59:21.748043Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25249-3
  a curric:KeyLearningPoint ;
  rdfs:label """Countries support long-term responses through development aid, peacebuilding and human rights protections."""@en ;
  dcterms:modified "2026-02-12T08:59:21.748046Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25221-1
  a curric:KeyLearningPoint ;
  rdfs:label """Sustainable shopping involves environmentally and financially responsible consumer choices, such as buying second-hand."""@en ;
  dcterms:modified "2026-02-12T08:59:21.748909Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25221-2
  a curric:KeyLearningPoint ;
  rdfs:label """Spending locally supports small businesses, leading to job creation and economic growth through the multiplier effect."""@en ;
  dcterms:modified "2026-02-12T08:59:21.748913Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25221-3
  a curric:KeyLearningPoint ;
  rdfs:label """Small businesses contribute to public services by paying business rates and Corporation Tax to fund the local economy."""@en ;
  dcterms:modified "2026-02-12T08:59:21.748917Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25221-4
  a curric:KeyLearningPoint ;
  rdfs:label """National initiatives like Small Business Saturday UK help promote the importance of supporting local enterprises."""@en ;
  dcterms:modified "2026-02-12T08:59:21.748920Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25221-5
  a curric:KeyLearningPoint ;
  rdfs:label """Young people can engage in active citizenship by promoting sustainable and local shopping through social action."""@en ;
  dcterms:modified "2026-02-12T08:59:21.748924Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25231-1
  a curric:KeyLearningPoint ;
  rdfs:label """A bad actor uses digital media in negative ways to manipulate people's political beliefs and actions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.748928Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25231-2
  a curric:KeyLearningPoint ;
  rdfs:label """Deepfakes can be created by AI and used to mislead the public during an election."""@en ;
  dcterms:modified "2026-02-12T08:59:21.748932Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25231-3
  a curric:KeyLearningPoint ;
  rdfs:label """Digital media can go wrong e.g. information during the Brazilion election and the Cambridge Analtica Scandal."""@en ;
  dcterms:modified "2026-02-12T08:59:21.748936Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25226-1
  a curric:KeyLearningPoint ;
  rdfs:label """National media covers news of interest to the entire country, while local media focuses on smaller areas."""@en ;
  dcterms:modified "2026-02-12T08:59:21.749502Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25226-2
  a curric:KeyLearningPoint ;
  rdfs:label "Local media holds authorities accountable and raises awareness of local issues."@en ;
  dcterms:modified "2026-02-12T08:59:21.749505Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25226-3
  a curric:KeyLearningPoint ;
  rdfs:label "Local media encourages civic engagement and strengthens community cohesion."@en ;
  dcterms:modified "2026-02-12T08:59:21.749509Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25226-4
  a curric:KeyLearningPoint ;
  rdfs:label "National media shapes public opinion and holds the Government accountable."@en ;
  dcterms:modified "2026-02-12T08:59:21.749513Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25226-5
  a curric:KeyLearningPoint ;
  rdfs:label "National media sets the national agenda and unifies the nation."@en ;
  dcterms:modified "2026-02-12T08:59:21.749517Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25201-1
  a curric:KeyLearningPoint ;
  rdfs:label """Democracy is a system of government where power is rooted in the people. There are two types: direct and representative."""@en ;
  dcterms:modified "2026-02-12T08:59:21.749521Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25201-2
  a curric:KeyLearningPoint ;
  rdfs:label """Representative democracy is the most common, where people elect representatives to vote and make laws on their behalf."""@en ;
  dcterms:modified "2026-02-12T08:59:21.749525Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25201-3
  a curric:KeyLearningPoint ;
  rdfs:label """A referendum is an example of direct democracy; they are held on issues of national, regional and local importance."""@en ;
  dcterms:modified "2026-02-12T08:59:21.749529Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25384-1
  a curric:KeyLearningPoint ;
  rdfs:label """The UK justice system is based on the rule of law, which ensures fairness and equality for all."""@en ;
  dcterms:modified "2026-02-12T08:59:21.749533Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25384-2
  a curric:KeyLearningPoint ;
  rdfs:label """Justice includes access to legal advice, fair trials and support for both the victims and the accused."""@en ;
  dcterms:modified "2026-02-12T08:59:21.749539Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25384-3
  a curric:KeyLearningPoint ;
  rdfs:label """Sentences like prison, community orders and fines are used depending on the severity of the crime."""@en ;
  dcterms:modified "2026-02-12T08:59:21.749543Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25384-4
  a curric:KeyLearningPoint ;
  rdfs:label """These sentences aim to protect the public, rehabilitate offenders and deter future crime."""@en ;
  dcterms:modified "2026-02-12T08:59:21.749548Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25384-5
  a curric:KeyLearningPoint ;
  rdfs:label """Legal professionals help make sure the correct processes are followed and that everyone’s rights are respected."""@en ;
  dcterms:modified "2026-02-12T08:59:21.749552Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25344-1
  a curric:KeyLearningPoint ;
  rdfs:label """The UN was created after WWII and works through its members to tackle global challenges and support peace efforts."""@en ;
  dcterms:modified "2026-02-12T08:59:21.750833Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25344-2
  a curric:KeyLearningPoint ;
  rdfs:label """The General Assembly is made up of all UN Member States and allows every country an equal vote to discuss global issues."""@en ;
  dcterms:modified "2026-02-12T08:59:21.750837Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25344-3
  a curric:KeyLearningPoint ;
  rdfs:label """The Security Council maintains peace, with five permanent members and 10 rotating members."""@en ;
  dcterms:modified "2026-02-12T08:59:21.750841Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25344-4
  a curric:KeyLearningPoint ;
  rdfs:label """The UK is a permanent Security Council member with veto power and influence over peace and security decisions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.750847Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-25344-5
  a curric:KeyLearningPoint ;
  rdfs:label """The UK contributes troops and funding to UN peacekeeping and supports global action through the General Assembly."""@en ;
  dcterms:modified "2026-02-12T08:59:21.750852Z"^^xsd:dateTime .

