  a curric:Keyword ;
  schema:name "Vote Remain"@en ;
  schema:description """the campaign group that wanted Britain to remain in the European Union, it was officially called 'Stronger In Europe'"""@en ;
  dcterms:modified "2026-02-12T08:59:15.827681Z"^^xsd:dateTime .

oakcurric:keyword-resource-scarcity
  a curric:Keyword ;
  schema:name "resource scarcity"@en ;
  schema:description """the limited availability of natural resources, such as food, water, fuel, and raw materials, which are required to meet the needs of the population"""@en ;
  dcterms:modified "2026-02-12T08:59:15.827765Z"^^xsd:dateTime .

oakcurric:keyword-ncrs
  a curric:Keyword ;
  schema:name "NCRS"@en ;
  schema:description """National Crime Recording Standards; principles that ensure police record all reported crimes accurately and consistently across the UK"""@en ;
  dcterms:modified "2026-02-12T08:59:15.827770Z"^^xsd:dateTime .

oakcurric:keyword-crime-survey
  a curric:Keyword ;
  schema:name "crime survey"@en ;
  schema:description """an interview that asks people about their experiences of crime, including those not reported to the police"""@en ;
  dcterms:modified "2026-02-12T08:59:15.827774Z"^^xsd:dateTime .

oakcurric:keyword-inconvenient
  a curric:Keyword ;
  schema:name "inconvenient"@en ;
  schema:description """causing difficulty, trouble, or discomfort, often by disrupting plans or making things less easy"""@en ;
  dcterms:modified "2026-02-12T08:59:15.827977Z"^^xsd:dateTime .

oakcurric:keyword-views
  a curric:Keyword ;
  schema:name "views"@en ;
  schema:description "people’s opinions or what they think about something"@en ;
  dcterms:modified "2026-02-12T08:59:15.827983Z"^^xsd:dateTime .

oakcurric:keyword-successful
  a curric:Keyword ;
  schema:name "successful"@en ;
  schema:description "achieving what you set out to do or getting a good result"@en ;
  dcterms:modified "2026-02-12T08:59:15.827987Z"^^xsd:dateTime .

oakcurric:keyword-high-income-country-hic
  a curric:Keyword ;
  schema:name "high income country (HIC)"@en ;
  schema:description """a wealthy nation with high economic development, typically having a strong economy and high gross national income (GNI) per person, where people generally enjoy good incomes and living standards"""@en ;
  dcterms:modified "2026-02-12T08:59:15.827992Z"^^xsd:dateTime .

oakcurric:keyword-low-income-country-lic
  a curric:Keyword ;
  schema:name "low income country (LIC)"@en ;
  schema:description """a nation with limited wealth and development, often having a low GNI per person, where many face challenges accessing basic services like healthcare and education"""@en ;
  dcterms:modified "2026-02-12T08:59:15.827996Z"^^xsd:dateTime .

oakcurric:keyword-financial-products
  a curric:Keyword ;
  schema:name "financial products"@en ;
  schema:description """products, services and tools provided by banks, building societies or other companies"""@en ;
  dcterms:modified "2026-02-12T08:59:15.828071Z"^^xsd:dateTime .

oakcurric:keyword-grants
  a curric:Keyword ;
  schema:name "grants"@en ;
  schema:description """a sum of money gifted by an organisation or person that does not need to be repaid"""@en ;
  dcterms:modified "2026-02-12T08:59:15.828075Z"^^xsd:dateTime .

oakcurric:keyword-vote-leave
  a curric:Keyword ;
  schema:name "Vote Leave"@en ;
  schema:description "the campaign group that wanted Britain to leave the European Union"@en ;
  dcterms:modified "2026-02-12T08:59:15.828491Z"^^xsd:dateTime .

oakcurric:keyword-grassroots-development
  a curric:Keyword ;
  schema:name "grassroots development"@en ;
  schema:description """when a group of people come together to pursue a common goal, largely on a volunteer and non-profit basis, to serve a local need in their community; often called a community-led project"""@en ;
  dcterms:modified "2026-02-12T08:59:15.828512Z"^^xsd:dateTime .

oakcurric:keyword-humanitarian-problem
  a curric:Keyword ;
  schema:name "humanitarian problem"@en ;
  schema:description """a situation or event, often large-scale, that poses a serious and immediate threat to the health, safety or wellbeing of a community or group of people"""@en ;
  dcterms:modified "2026-02-12T08:59:15.828516Z"^^xsd:dateTime .

oakcurric:keyword-natural-disasters
  a curric:Keyword ;
  schema:name "natural disasters"@en ;
  schema:description """a harmful event caused by natural forces, like a volcanic eruption, earthquake or drought, that can damage communities and the environment"""@en ;
  dcterms:modified "2026-02-12T08:59:15.828524Z"^^xsd:dateTime .

oakcurric:keyword-sustainable-shopping
  a curric:Keyword ;
  schema:name "sustainable shopping"@en ;
  schema:description """using resources and making choices as a consumer in a way that does not harm the environment and can continue for a long time"""@en ;
  dcterms:modified "2026-02-12T08:59:15.828625Z"^^xsd:dateTime .

oakcurric:keyword-circular-economy
  a curric:Keyword ;
  schema:name "circular economy"@en ;
  schema:description """an economic system based on the reuse and regeneration of materials or products, moving away from the model of ‘take, make and throw away’"""@en ;
  dcterms:modified "2026-02-12T08:59:15.828629Z"^^xsd:dateTime .

oakcurric:keyword-bad-actor
  a curric:Keyword ;
  schema:name "bad actor"@en ;
  schema:description """individuals or groups that engage in harmful, illegal or unethical behavior online, such as hacking, spreading disinformation or manipulating information"""@en ;
  dcterms:modified "2026-02-12T08:59:15.828633Z"^^xsd:dateTime .

oakcurric:keyword-deepfake
  a curric:Keyword ;
  schema:name "deepfake"@en ;
  schema:description """using artificial intelligence to manipulate a video clip or images to create new deceptive content, often with known faces or voices"""@en ;
  dcterms:modified "2026-02-12T08:59:15.828638Z"^^xsd:dateTime .

oakcurric:keyword-security-council
  a curric:Keyword ;
  schema:name "Security Council"@en ;
  schema:description """the UN Security Council is made up of 15 members, five permanent and 10 rotating; it is primarily responsible for international peace and security"""@en ;
  dcterms:modified "2026-02-12T08:59:15.828967Z"^^xsd:dateTime .

oakcurric:keyword-general-assembly
  a curric:Keyword ;
  schema:name "General Assembly"@en ;
  schema:description """the main meeting of all UN Member States where each has one vote to discuss global issues and suggest actions"""@en ;
  dcterms:modified "2026-02-12T08:59:15.828971Z"^^xsd:dateTime .

oakcurric:keyword-permanent-member
  a curric:Keyword ;
  schema:name "permanent member"@en ;
  schema:description """the five nations who permanently sit on the UN Security Council; they have the power to veto UN actions and decisions"""@en ;
  dcterms:modified "2026-02-12T08:59:15.828975Z"^^xsd:dateTime .

oakcurric:keyword-veto
  a curric:Keyword ;
  schema:name "veto"@en ;
  schema:description "the right to reject a decision or proposal"@en ;
  dcterms:modified "2026-02-12T08:59:15.828979Z"^^xsd:dateTime .

# ----------------------------------------------------------------------
# Misconceptions
# ----------------------------------------------------------------------

oakcurric:misconception-climate-action-positive-world
  a curric:Misconception ;
  curric:statement "Climate action is positive for all of the world."@en ;
  curric:correction """Climate action aims to benefit the world, but political issues arise. Low income and emerging countries are asked to reduce industries, while the top five polluters are developed nations, creating an imbalance in responsibility for climate action."""@en ;
  dcterms:modified "2026-02-12T08:59:18.676222Z"^^xsd:dateTime .

oakcurric:misconception-migrants-bring-benefits-country-moved
  a curric:Misconception ;
  curric:statement "Migrants do not bring benefits to the country they have moved to."@en ;
  curric:correction """Migrants help fill important skills shortages in the country, bringing valuable talents and expertise that keep essential services and industries running smoothly."""@en ;
  dcterms:modified "2026-02-12T08:59:18.676226Z"^^xsd:dateTime .

oakcurric:misconception-active-citizens-high-profile-people
  a curric:Misconception ;
  curric:statement "Active citizens are always high-profile people."@en ;
  curric:correction """Anyone can be an active citizen. Active citizenship projects can be at a local, national or international level; the key purpose is to make a positive difference in society."""@en ;
  dcterms:modified "2026-02-12T08:59:18.676247Z"^^xsd:dateTime .

oakcurric:misconception-supreme-court-same-powers-throughout
  a curric:Misconception ;
  curric:statement "The Supreme Court has the same powers throughout the UK."@en ;
  curric:correction """While the Supreme Court is the final court of appeal for most cases in the UK, its role in Scotland differs as Scotland has its own distinct legal system. In Scotland, the High Court of Justiciary is the highest court of appeal for criminal cases."""@en ;
  dcterms:modified "2026-02-12T08:59:18.676335Z"^^xsd:dateTime .

oakcurric:misconception-my-rights-protected-go-court
  a curric:Misconception ;
  curric:statement "My rights are only protected if I go to court."@en ;
  curric:correction """Rights do not only matter in legal cases, they are protected every day through laws, policies and the actions of public bodies like the police and the NHS."""@en ;
  dcterms:modified "2026-02-12T08:59:18.676381Z"^^xsd:dateTime .

oakcurric:misconception-migration-uk-people-coming-other
  a curric:Misconception ;
  curric:statement """Migration to the UK is only about people coming from other countries to live here."""@en ;
  curric:correction """Migration includes both people coming to the UK (immigration) and those leaving (emigration). It’s shaped by global and local factors and impacts communities, industries and the economy in various ways."""@en ;
  dcterms:modified "2026-02-12T08:59:18.676401Z"^^xsd:dateTime .

oakcurric:misconception-uk-written-constitution-like-united
  a curric:Misconception ;
  curric:statement "The UK has a written constitution like the United States."@en ;
  curric:correction """The UK Constitution is uncodified; it exists through laws, customs and conventions, but is not written down in one single document."""@en ;
  dcterms:modified "2026-02-12T08:59:18.676426Z"^^xsd:dateTime .

oakcurric:misconception-ordinary-citizens-dont-really-power
  a curric:Misconception ;
  curric:statement "Ordinary citizens don't really have any power or impact in the legal system."@en ;
  curric:correction """Citizens can play key roles, like serving as jurors, becoming magistrates or special constables, and even push for legal reforms, as shown by trade unions helping pass the Minimum Wage Act."""@en ;
  dcterms:modified "2026-02-12T08:59:18.676491Z"^^xsd:dateTime .

oakcurric:misconception-communities-work-together-successfully-everyone
  a curric:Misconception ;
  curric:statement "For communities to work together successfully everyone has to always agree."@en ;
  curric:correction """Individuals can recognise and co-exist with beliefs, opinions and values that are different to their own. This allows people to peacefully live with others who we might disagree with, as long as they do not harm anyone through their choices."""@en ;
  dcterms:modified "2026-02-12T08:59:18.676504Z"^^xsd:dateTime .

oakcurric:misconception-governments-protect-enforce-human-rights
  a curric:Misconception ;
  curric:statement "Only governments can protect and enforce human rights."@en ;
  curric:correction """NGOs also play a vital role by raising awareness, supporting victims and pressuring governments to uphold human rights worldwide."""@en ;
  dcterms:modified "2026-02-12T08:59:18.676548Z"^^xsd:dateTime .

oakcurric:misconception-migrants-move-choice-example-work
  a curric:Misconception ;
  curric:statement """All migrants move by choice. For example, for work or a better life, rather than because they are forced to leave."""@en ;
  curric:correction """Not all migrants move by choice. Some, like refugees and asylum seekers, are forced to flee due to war or persecution."""@en ;
  dcterms:modified "2026-02-12T08:59:18.676554Z"^^xsd:dateTime .

oakcurric:misconception-police-enforce-law
  a curric:Misconception ;
  curric:statement "Only the police enforce the law."@en ;
  curric:correction """The police play a key role in enforcing the law, however, they are not the only ones involved. Other groups, like magistrates, judges, the CPS, and lawyers, all have important roles in making sure laws are followed and justice is served."""@en ;
  dcterms:modified "2026-02-12T08:59:18.676561Z"^^xsd:dateTime .

oakcurric:misconception-people-uk-identify-british
  a curric:Misconception ;
  curric:statement "Most people in the UK identify only as British."@en ;
  curric:correction """The UK is a multicultural society and many people identify as more than one nationality."""@en ;
  dcterms:modified "2026-02-12T08:59:18.676566Z"^^xsd:dateTime .

oakcurric:misconception-hate-crimes-count-someone-actually
  a curric:Misconception ;
  curric:statement "Hate crimes only count if someone actually hurts you physically."@en ;
  curric:correction """Hate crimes include any criminal act where someone is targeted because of their disability, race, religion, sexual orientation or transgender identity. The law protects people from all kinds of harm motivated by prejudice."""@en ;
  dcterms:modified "2026-02-12T08:59:18.676582Z"^^xsd:dateTime .

oakcurric:misconception-prime-minister-pm-holds-power
  a curric:Misconception ;
  curric:statement "The Prime Minister (PM) holds all of the power in the UK."@en ;
  curric:correction """The PM is only in their position because of the electorate, and many decisions are made by the Cabinet, who are appointed by the PM to make decisions on behalf of the country. The media, other decision-makers and the public also hold power in the UK."""@en ;
  dcterms:modified "2026-02-12T08:59:18.676587Z"^^xsd:dateTime .

oakcurric:misconception-citizenship-skills-important-politicians-activists
  a curric:Misconception ;
  curric:statement """That citizenship skills are only important for politicians, activists, or people with a lot of power."""@en ;
  curric:correction """Citizenship skills are important for everyone, because even small actions help strengthen communities and make a difference. These skills help ordinary people stand up for their rights, support others and create positive change in everyday life."""@en ;
  dcterms:modified "2026-02-12T08:59:18.676626Z"^^xsd:dateTime .

oakcurric:misconception-article-50-means-uk-left
  a curric:Misconception ;
  curric:statement "Article 50 means the UK left the EU."@en ;
  curric:correction """Article 50 is the start of the process to leave the EU. A Member State must trigger this to begin negotiations to leave the EU."""@en ;
  dcterms:modified "2026-02-12T08:59:18.676630Z"^^xsd:dateTime .

oakcurric:misconception-governments-protect-human-rights-fairly
  a curric:Misconception ;
  curric:statement "Governments always protect human rights fairly and equally for everyone."@en ;
  curric:correction """While governments are duty bearers, they don’t always protect everyone’s rights. In some cases, they may ignore, limit, or even violate rights, which is why human rights defenders are important because they hold duty bearers to account."""@en ;
  dcterms:modified "2026-02-12T08:59:18.676649Z"^^xsd:dateTime .

oakcurric:misconception-migration-occurs-because-people-forced
  a curric:Misconception ;
  curric:statement """Migration only occurs because people are forced to leave their country due to negative reasons (e.g., war or persecution)."""@en ;
  curric:correction """While people are often forced to migrate (due to push factors like war or persecution), others choose to migrate for reasons like better job opportunities, family reunification, or improved living conditions (pull factors)."""@en ;
  dcterms:modified "2026-02-12T08:59:18.676672Z"^^xsd:dateTime .

oakcurric:misconception-uk-prime-minister-same-level
  a curric:Misconception ;
  curric:statement "The UK Prime Minister has the same level of power as other elected leaders."@en ;
  curric:correction """The UK Prime Minister can be removed with a vote of no confidence. The US President has fixed terms and a stronger separation from the legislature."""@en ;
  dcterms:modified "2026-02-12T08:59:18.676723Z"^^xsd:dateTime .

oakcurric:misconception-parliamentary-procedures-traditions-old-fashioned
  a curric:Misconception ;
  curric:statement """Parliamentary procedures and traditions are old-fashioned and have no meaning in modern society."""@en ;
  curric:correction """The traditions in Parliament exist for important reasons and serve to highlight the democratic principles that shape our society."""@en ;
  dcterms:modified "2026-02-12T08:59:18.676776Z"^^xsd:dateTime .

oakcurric:misconception-commonwealth-british-empire-another-name
  a curric:Misconception ;
  curric:statement "The Commonwealth is just the British Empire with another name."@en ;
  curric:correction """The Commonwealth is a voluntary association where countries choose to work together toward shared goals. Unlike the British Empire, which often involved control over other nations, Commonwealth members join freely and are treated as equals."""@en ;
  dcterms:modified "2026-02-12T08:59:18.676861Z"^^xsd:dateTime .

oakcurric:misconception-famous-people-power-speak-truth
  a curric:Misconception ;
  curric:statement """Only famous people or those in power can speak truth to power and challenge injustice to make a difference."""@en ;
  curric:correction """Anyone, including young people, can speak truth to power and challenge injustice. Powerful speeches and actions have come from ordinary individuals who spoke out with courage and clarity."""@en ;
  dcterms:modified "2026-02-12T08:59:18.676981Z"^^xsd:dateTime .

oakcurric:misconception-identity-fixed-based-things-like
  a curric:Misconception ;
  curric:statement "Identity is fixed and based only on things like nationality or ethnicity."@en ;
  curric:correction """Identity is complex and fluid, made up of many parts including culture, experiences and beliefs, and can change over time."""@en ;
  dcterms:modified "2026-02-12T08:59:18.677003Z"^^xsd:dateTime .

oakcurric:misconception-civil-society-ngos-charities-same
  a curric:Misconception ;
  curric:statement "Civil society, NGOs and charities are all the same thing."@en ;
  curric:correction """They are interlinked and might have common goals but work and run in different ways."""@en ;
  dcterms:modified "2026-02-12T08:59:18.677131Z"^^xsd:dateTime .

oakcurric:misconception-breaking-law-protest-justified-cause
  a curric:Misconception ;
  curric:statement "Breaking the law during a protest is always justified if the cause is important."@en ;
  curric:correction """Breaking the law during a protest can have legal consequences and can undermine public support. In a democracy, lawful methods are typically seen as more effective and legitimate forms of protest."""@en ;
  dcterms:modified "2026-02-12T08:59:18.677200Z"^^xsd:dateTime .

oakcurric:misconception-political-decisions-dont-really-affect
  a curric:Misconception ;
  curric:statement """Political decisions don’t really affect the population, people just move or live longer naturally."""@en ;
  curric:correction """Government policies (like immigration laws or public health measures) directly shape who lives in the country, how many people come or go and how long people live."""@en ;
  dcterms:modified "2026-02-12T08:59:18.677227Z"^^xsd:dateTime .

oakcurric:misconception-protests-lead-immediate-change
  a curric:Misconception ;
  curric:statement "Protests always lead to immediate change."@en ;
  curric:correction """Change brought by protests can take time and often requires persistence and widespread support. While some protests have led to quick reforms, others have taken years or even decades to achieve their goals."""@en ;
  dcterms:modified "2026-02-12T08:59:18.677266Z"^^xsd:dateTime .

oakcurric:misconception-local-national-governments-same-powers
  a curric:Misconception ;
  curric:statement "Local and national governments have the same powers."@en ;
  curric:correction """The national government have broader powers and devolves some of this to local governments."""@en ;
  dcterms:modified "2026-02-12T08:59:18.677353Z"^^xsd:dateTime .

oakcurric:misconception-everyone-across-world-gets-their
  a curric:Misconception ;
  curric:statement "Everyone across the world gets their fundamental human rights."@en ;
  curric:correction "Human rights violations exist in many countries."@en ;
  dcterms:modified "2026-02-12T08:59:18.677403Z"^^xsd:dateTime .

oakcurric:misconception-investment-makes-local-area-better
  a curric:Misconception ;
  curric:statement "Investment always makes a local area better straight away."@en ;
  curric:correction """Investment usually takes time to show its effects, and sometimes it can create challenges like rising rents or traffic before the benefits are fully seen."""@en ;
  dcterms:modified "2026-02-12T08:59:18.677579Z"^^xsd:dateTime .

oakcurric:misconception-ngos-international-agencies-work-separately
  a curric:Misconception ;
  curric:statement "NGOs and international agencies work separately and do not rely on each other."@en ;
  curric:correction """NGOs often work closely with international organisations such as the UN to deliver aid, share information and promote human rights more effectively."""@en ;
  dcterms:modified "2026-02-12T08:59:18.677628Z"^^xsd:dateTime .

oakcurric:misconception-people-protest-anytime-anywhere-without
  a curric:Misconception ;
  curric:statement "People can protest anytime and anywhere without any restrictions."@en ;
  curric:correction """While the right to protest is fundamental in a democracy, it is subject to certain limitations. Protests must comply with laws regarding public safety and order, and respect the rights of others."""@en ;
  dcterms:modified "2026-02-12T08:59:18.677672Z"^^xsd:dateTime .

oakcurric:misconception-members-political-parties-share-same
  a curric:Misconception ;
  curric:statement "All members of political parties share the same views."@en ;
  curric:correction """Political parties generally align with core values and principles but will have varying opinions on certain issues."""@en ;
  dcterms:modified "2026-02-12T08:59:18.679647Z"^^xsd:dateTime .

oakcurric:misconception-young-people-tried-same-courts
  a curric:Misconception ;
  curric:statement "Young people are tried in the same courts as adults."@en ;
  curric:correction """Young people are tried in a youth court, except for offences that are considered to be too serious."""@en ;
  dcterms:modified "2026-02-12T08:59:18.679848Z"^^xsd:dateTime .

oakcurric:misconception-diversity-refers-ethnicity-race
  a curric:Misconception ;
  curric:statement "Diversity only refers to ethnicity or race."@en ;
  curric:correction """Diversity includes many aspects such as culture, religion, language, age, gender and socioeconomic background."""@en ;
  dcterms:modified "2026-02-12T08:59:18.680177Z"^^xsd:dateTime .

oakcurric:misconception-democracy-works-exactly-same-way
  a curric:Misconception ;
  curric:statement "Democracy works exactly the same way in every country."@en ;
  curric:correction """Democracy takes different forms across the world, for example, direct, full, flawed democracies and hybrid regimes."""@en ;
  dcterms:modified "2026-02-12T08:59:18.680182Z"^^xsd:dateTime .

oakcurric:misconception-countries-respond-conflicts-sending-soldiers
  a curric:Misconception ;
  curric:statement "Countries only respond to conflicts by sending soldiers to fight."@en ;
  curric:correction """While military intervention is one option, countries often respond to conflicts through diplomacy, economic sanctions, and financial or arms support. These methods can be used to influence or support other nations without direct military involvement."""@en ;
  dcterms:modified "2026-02-12T08:59:18.680187Z"^^xsd:dateTime .

oakcurric:misconception-people-live-britain-agree-fundamental
  a curric:Misconception ;
  curric:statement "All people who live in Britain agree with the fundamental British values."@en ;
  curric:correction """British values are shared beliefs about who we are as a group of people. It is a requirement that they are promoted by public sector organisations but they remain open to debate, not every citizen will agree with them in their current format."""@en ;
  dcterms:modified "2026-02-12T08:59:18.680232Z"^^xsd:dateTime .

oakcurric:misconception-changemakers-connected-influential-people-lots
  a curric:Misconception ;
  curric:statement "That changemakers are connected or influential people with lots of resources."@en ;
  curric:correction """Anyone can be a changemaker. It depends on the ability of the person to bring people along with them and build a cause people believe in."""@en ;
  dcterms:modified "2026-02-12T08:59:18.680390Z"^^xsd:dateTime .

oakcurric:misconception-identity-refers-personal-characteristics-like
  a curric:Misconception ;
  curric:statement """That identity only refers to personal characteristics like gender, race, or ethnicity."""@en ;
  curric:correction """Identity can also include factors like socioeconomic background, religion, sexual orientation, disability, nationality, or even personal experiences."""@en ;
  dcterms:modified "2026-02-12T08:59:18.680410Z"^^xsd:dateTime .

oakcurric:misconception-migration-new-event-past-people
  a curric:Misconception ;
  curric:statement "Migration is a new event, in the past people stayed where they lived."@en ;
  curric:correction """Migration has always existed. Britain has benefited from many centuries of migration from Europe and the wider world."""@en ;
  dcterms:modified "2026-02-12T08:59:18.680486Z"^^xsd:dateTime .

oakcurric:misconception-population-changes-happen-immigration
  a curric:Misconception ;
  curric:statement "Population changes only happen through immigration."@en ;
  curric:correction """Population changes include factors like birth rates, ageing and internal migration, as well as immigration."""@en ;
  dcterms:modified "2026-02-12T08:59:18.681487Z"^^xsd:dateTime .

oakcurric:misconception-single-clear-british-identity-everyone
  a curric:Misconception ;
  curric:statement "There is a single, clear British identity that everyone shares."@en ;
  curric:correction """British identity is diverse and multi-faceted, with different people valuing different aspects depending on their background and experience."""@en ;
  dcterms:modified "2026-02-12T08:59:18.681758Z"^^xsd:dateTime .

oakcurric:misconception-speaker-able-influence-decisions-house
  a curric:Misconception ;
  curric:statement "The Speaker is able to influence decisions in the House of Commons."@en ;
  curric:correction """The Speaker is politically neutral and there to chair debates and keep order in the House of Commons."""@en ;
  dcterms:modified "2026-02-12T08:59:18.681928Z"^^xsd:dateTime .

oakcurric:misconception-asylum-seekers-refugees-same-thing
  a curric:Misconception ;
  curric:statement "Asylum seekers and refugees are the same thing."@en ;
  curric:correction """Asylum seekers are seeking safety but not yet granted leave to remain. Refugees were asylum seekers but have been allowed to remain in a country by the government as their claim has been assessed as credible."""@en ;
  dcterms:modified "2026-02-12T08:59:18.682004Z"^^xsd:dateTime .

oakcurric:misconception-wto-deals-buy-sell-other
  a curric:Misconception ;
  curric:statement "The WTO deals with what we buy and sell other nations. It acts as a regulator."@en ;
  curric:correction """The WTO does not control specific goods or services we trade. It oversees the rules, policies and agreements that guide trade between countries, ensuring fairness and transparency, and works to prevent conflicts."""@en ;
  dcterms:modified "2026-02-12T08:59:18.693123Z"^^xsd:dateTime .

oakcurric:misconception-non-democratic-governments-provide-rights
  a curric:Misconception ;
  curric:statement """Non-democratic governments do not provide any rights or benefits to their people."""@en ;
  curric:correction """Non-democratic governments might limit political freedom and participation. However, they may still provide rights and benefits to their people."""@en ;
  dcterms:modified "2026-02-12T08:59:18.693155Z"^^xsd:dateTime .

oakcurric:misconception-judges-magistrates-complete-freedom-deciding
  a curric:Misconception ;
  curric:statement "Judges and magistrates have complete freedom in deciding sentences."@en ;
  curric:correction """Parliament sets the laws that determine maximum and minimum sentences, and the Sentencing Council provides guidelines that judges and magistrates must follow."""@en ;
  dcterms:modified "2026-02-12T08:59:18.693252Z"^^xsd:dateTime .

oakcurric:misconception-media-types-regulated-same-way
  a curric:Misconception ;
  curric:statement "That all media types are regulated in the same way."@en ;
  curric:correction """Although traditional media has consistent, central regulation, digital media sets its own guidelines and these can vary between platforms. Although anyone can be charged with defamation laws, regardless of media type."""@en ;
  dcterms:modified "2026-02-12T08:59:18.694225Z"^^xsd:dateTime .

oakcurric:misconception-uncodified-constitution-means-rules-limitations
  a curric:Misconception ;
  curric:statement """An uncodified constitution means there are no rules or limitations on government power."""@en ;
  curric:correction """There are rules and limitations on government power in an uncodified constitution, e.g. the UK’s uncodified constitution is made up of various sources, including statute law and common law. Rule of law is a key principle that guides Parliament."""@en ;
  dcterms:modified "2026-02-12T08:59:18.694765Z"^^xsd:dateTime .

oakcurric:misconception-relationship-trade-unions-government-ever
  a curric:Misconception ;
  curric:statement """That the relationship between trade unions and government has only ever been one of conflict."""@en ;
  curric:correction "Trade unions have also worked alongside government to create employment law."@en ;
  dcterms:modified "2026-02-12T08:59:18.695982Z"^^xsd:dateTime .

oakcurric:misconception-democratic-countries-governed-same-way
  a curric:Misconception ;
  curric:statement "All democratic countries are governed in the same way."@en ;
  curric:correction """Democracy takes many different forms including direct democracy and representative democracy. Some representative democracies even include forms of direct democracy."""@en ;
  dcterms:modified "2026-02-12T08:59:18.698995Z"^^xsd:dateTime .

oakcurric:misconception-decision-leave-eu-either-good
  a curric:Misconception ;
  curric:statement "The decision to leave the EU has been either all good or all bad."@en ;
  curric:correction """Whilst many politicians have strong views about the impact of Brexit, the truth is more nuanced. There have been advantages (such as creating our own immigration system) and negatives (like the loss of foreign direct investment)."""@en ;
  dcterms:modified "2026-02-12T08:59:18.699000Z"^^xsd:dateTime .

oakcurric:misconception-international-organisations-like-nato-un
  a curric:Misconception ;
  curric:statement """International organisations like NATO or the UN control the UK Government and make all its decisions."""@en ;
  curric:correction """International organisations can influence the UK, but they do not have power to make decisions for the UK Government."""@en ;
  dcterms:modified "2026-02-12T08:59:18.699012Z"^^xsd:dateTime .

oakcurric:misconception-action-considered-crime-its-seen
  a curric:Misconception ;
  curric:statement "An action is only considered a crime if it's seen as morally wrong."@en ;
  curric:correction """In reality, a crime is defined by breaking the law, regardless of whether it seems unethical to the individual."""@en ;
  dcterms:modified "2026-02-12T08:59:18.700143Z"^^xsd:dateTime .

oakcurric:misconception-diversity-unity-opposing-ideas-cannot
  a curric:Misconception ;
  curric:statement "Diversity and unity are opposing ideas and cannot coexist."@en ;
  curric:correction """A diverse society can be united through shared values, inclusion, and respect, which help build strong, cohesive communities."""@en ;
  dcterms:modified "2026-02-12T08:59:18.700469Z"^^xsd:dateTime .

oakcurric:misconception-media-print-publish-like-due
  a curric:Misconception ;
  curric:statement "The media can print or publish what they like due to free press."@en ;
  curric:correction """They must still follow regulations so that the public can trust what is being published."""@en ;
  dcterms:modified "2026-02-12T08:59:18.700613Z"^^xsd:dateTime .

oakcurric:misconception-everyone-same-retirement-age
  a curric:Misconception ;
  curric:statement "Everyone has the same retirement age."@en ;
  curric:correction """Not everyone retires at the same age. Retirement age can vary greatly depending on personal finances, circumstances, health and family."""@en ;
  dcterms:modified "2026-02-12T08:59:18.700634Z"^^xsd:dateTime .

oakcurric:misconception-respect-tolerance-happen-naturally-without
  a curric:Misconception ;
  curric:statement "Respect and tolerance happen naturally without effort or laws."@en ;
  curric:correction """Mutual respect requires active effort, education and legal frameworks like the Equality Act 2010 to support fairness and prevent discrimination."""@en ;
  dcterms:modified "2026-02-12T08:59:18.700664Z"^^xsd:dateTime .

oakcurric:misconception-final-editorial-checks-mean-news
  a curric:Misconception ;
  curric:statement "Final editorial checks mean the news is always factual and true."@en ;
  curric:correction """Even though clear procedures are in place, errors can still occur; these could be due to human error, rushing or embelishing a story to generate more sales."""@en ;
  dcterms:modified "2026-02-12T08:59:18.700675Z"^^xsd:dateTime .

oakcurric:misconception-young-people-treated-same-adults
  a curric:Misconception ;
  curric:statement "Young people are treated the same as adults in the justice system."@en ;
  curric:correction """Young people are treated differently in the justice system. Youth courts focus on rehabilitation with alternative sentences to prison, like community service or rehabilitation orders, to help young people learn from mistakes and avoid re-offending."""@en ;
  dcterms:modified "2026-02-12T08:59:18.700812Z"^^xsd:dateTime .

oakcurric:misconception-prime-minister-directly-elected-electorates
  a curric:Misconception ;
  curric:statement "The Prime Minister is directly elected by the electorates."@en ;
  curric:correction """The leader of each political party is voted in by members of that party. When the general election takes place, the party with the majority of seats forms the Government and the leader of that party becomes the Prime Minister."""@en ;
  dcterms:modified "2026-02-12T08:59:18.700983Z"^^xsd:dateTime .

oakcurric:misconception-local-government-control-their-finances
  a curric:Misconception ;
  curric:statement """Local government has no control over their finances because the Government controls the Budget."""@en ;
  curric:correction """Devolution of the economy means that the Government have given local government more control over their local community spending."""@en ;
  dcterms:modified "2026-02-12T08:59:18.700988Z"^^xsd:dateTime .

oakcurric:misconception-young-people-little-power-influence
  a curric:Misconception ;
  curric:statement """Young people have little or no power to influence political systems or decisions because they are too young, not eligible to vote, or lack resources and authority."""@en ;
  curric:correction """Individuals, including young people can be influential as they are still able to lobby MPs, liaise with the police, engage with media and take part in campaigns."""@en ;
  dcterms:modified "2026-02-12T08:59:18.700994Z"^^xsd:dateTime .

oakcurric:misconception-countries-sentence-same-way-other
  a curric:Misconception ;
  curric:statement "All countries sentence in the same way as each other."@en ;
  curric:correction """Although sentencing within a country follows sentencing guidelines, these can vary vastly between each other, e.g. the USA is able to pass the death penalty in some states."""@en ;
  dcterms:modified "2026-02-12T08:59:18.700999Z"^^xsd:dateTime .

oakcurric:misconception-campaign-needed-challenge-injustice
  a curric:Misconception ;
  curric:statement "A campaign is always needed to challenge injustice."@en ;
  curric:correction """Not all injustice needs a full campaign. Sometimes, speaking up, helping someone or reporting unfair treatment can challenge injustice effectively, for example, telling a teacher if someone is being bullied is a way of standing up to injustice."""@en ;
  dcterms:modified "2026-02-12T08:59:18.701163Z"^^xsd:dateTime .

oakcurric:misconception-uk-representative-democracy-citizens-cannot
  a curric:Misconception ;
  curric:statement """The UK is a representative democracy so citizens cannot be involved in the decision making process at all."""@en ;
  curric:correction """Even though the UK is a representative democracy (where elected MPs make decisions), citizens can still be involved in the decision making process through referendums, select committees and citizens' assemblies."""@en ;
  dcterms:modified "2026-02-12T08:59:18.701246Z"^^xsd:dateTime .

oakcurric:misconception-action-plan-static-document-need
  a curric:Misconception ;
  curric:statement """An action plan is a static document, there is no need update it once it has been made."""@en ;
  curric:correction """Action plans are fluid and need to be reviewed regularly; they can become obsolete which can hinder the success as they are no longer relevant. Sometimes action plans need to be amended or adjusted to respond to challenges or barriers."""@en ;
  dcterms:modified "2026-02-12T08:59:18.701503Z"^^xsd:dateTime .

oakcurric:misconception-well-discussion-debate-shout-loudest
  a curric:Misconception ;
  curric:statement """That to do well in a discussion or debate you must shout the loudest and interupt others."""@en ;
  curric:correction """A successful deliberative discussion involves consideration, weighing different viewpoints and respect."""@en ;
  dcterms:modified "2026-02-12T08:59:18.701507Z"^^xsd:dateTime .

oakcurric:misconception-everyone-pays-same-rate-tax
  a curric:Misconception ;
  curric:statement "Everyone pays the same rate of tax regardless of their salary."@en ;
  curric:correction """The UK operates a progressive taxation system so people pay more if they earn more, according to the Government's band system."""@en ;
  dcterms:modified "2026-02-12T08:59:18.701512Z"^^xsd:dateTime .

oakcurric:misconception-national-government-impact-local-government
  a curric:Misconception ;
  curric:statement """That national government can impact local government, but that local government has no impact on national."""@en ;
  curric:correction """Local governments can play a crucial role in shaping the work and direction of national government."""@en ;
  dcterms:modified "2026-02-12T08:59:18.701521Z"^^xsd:dateTime .

oakcurric:misconception-aging-population-financially-secure-because
  a curric:Misconception ;
  curric:statement "The aging population are all financially secure because they receive pensions."@en ;
  curric:correction """Not all people are financially secure. Some may struggle due to low pension incomes, rising living costs, or a lack of savings, which can make it harder to cover everyday expenses."""@en ;
  dcterms:modified "2026-02-12T08:59:18.701940Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-rights-solely-lie
  a curric:Misconception ;
  curric:statement """Pupils may think that rights solely lie with the victim of crime, as they are the ones who have been wronged in some way."""@en ;
  curric:correction """Our legal system is based on justice, a key aspect of this is to ensure rights for both defendants and victims of crime; this ensures a fair trial and allows justice to be served."""@en ;
  dcterms:modified "2026-02-12T08:59:18.701945Z"^^xsd:dateTime .

oakcurric:misconception-eu-same-eec
  a curric:Misconception ;
  curric:statement "The EU is the same as the EEC."@en ;
  curric:correction """The European Economic Community was formed first and is separate from the EU. The EU is the larger union of countries who cooperate on social, economic and security issues. The EEC is mostly focused on the economy of member states."""@en ;
  dcterms:modified "2026-02-12T08:59:18.701949Z"^^xsd:dateTime .

oakcurric:misconception-punishment-purpose-sentencing
  a curric:Misconception ;
  curric:statement "Punishment is the only purpose of sentencing."@en ;
  curric:correction """To try and change behaviour, rehabilitation is also needed. This aims to reduce further crime being committed."""@en ;
  dcterms:modified "2026-02-12T08:59:18.702637Z"^^xsd:dateTime .

oakcurric:misconception-low-voter-turnout-means-people
  a curric:Misconception ;
  curric:statement "Low voter turnout means people are not interested in politics."@en ;
  curric:correction """Voter apathy might play a part in low voter turnout but other reasons exist, such as feeling votes will not count."""@en ;
  dcterms:modified "2026-02-12T08:59:18.702642Z"^^xsd:dateTime .

oakcurric:misconception-once-active-citizenship-project-complete
  a curric:Misconception ;
  curric:statement "That once the active citizenship project is complete, it's over."@en ;
  curric:correction """By reporting about your project and sharing this with others, it can continue to amplify the issue and develop ongoing active citizenship skills."""@en ;
  dcterms:modified "2026-02-12T08:59:18.702648Z"^^xsd:dateTime .

oakcurric:misconception-budget-shows-money-allocated-across
  a curric:Misconception ;
  curric:statement "The Budget just shows how money is allocated across the country."@en ;
  curric:correction """The Budget maps all income and expenditure so it shows us what money goes where and how money is generated, not just allocated."""@en ;
  dcterms:modified "2026-02-12T08:59:18.702668Z"^^xsd:dateTime .

oakcurric:misconception-solicitors-work-community-barristers-work
  a curric:Misconception ;
  curric:statement """That solicitors only work in the community and it is just barristers that work on criminal cases that end up in the court room."""@en ;
  curric:correction """Solicitors prepare the criminal case and advise the defendant prior to the case going to court, they appoint the barristers to represent their client (the defendant) in court."""@en ;
  dcterms:modified "2026-02-12T08:59:18.702672Z"^^xsd:dateTime .

oakcurric:misconception-large-businesses-contribute-local-economy
  a curric:Misconception ;
  curric:statement "Only large businesses contribute to the local economy."@en ;
  curric:correction """Small businesses also play a crucial role in job creation, local investment and community development. They generate employment, keep money circulating within the community and contribute significantly through taxation."""@en ;
  dcterms:modified "2026-02-12T08:59:18.702677Z"^^xsd:dateTime .

oakcurric:misconception-citizens-across-world-able-take
  a curric:Misconception ;
  curric:statement "All citizens across the world are able to take action."@en ;
  curric:correction """In some non-democratic countries taking action can be seen as civil disobedience and citizens can face punishment."""@en ;
  dcterms:modified "2026-02-12T08:59:18.702682Z"^^xsd:dateTime .

oakcurric:misconception-brexit-result-overwhelmingly-favour-brexit
  a curric:Misconception ;
  curric:statement "The Brexit result was overwhelmingly in favour of Brexit."@en ;
  curric:correction """The result was very close which is not typical of referendums. Many factors played a part including age, region and education."""@en ;
  dcterms:modified "2026-02-12T08:59:18.702688Z"^^xsd:dateTime .

oakcurric:misconception-pressure-groups-fringe-groups-little
  a curric:Misconception ;
  curric:statement """Pressure groups are always fringe groups with little influence on the Government."""@en ;
  curric:correction """Pressure groups vary in size and influence. They can be insider groups which already support the Government in writing policies."""@en ;
  dcterms:modified "2026-02-12T08:59:18.702815Z"^^xsd:dateTime .

oakcurric:misconception-primary-research-simple-involves-finding
  a curric:Misconception ;
  curric:statement """That primary research simple involves finding out what people think about your project."""@en ;
  curric:correction """Primary research does much more than this, it provides first hand accounts to help you be persuasive, it informs you whether or not your project is likely to be successful and it provides data that might not already be known to you."""@en ;
  dcterms:modified "2026-02-12T08:59:18.702820Z"^^xsd:dateTime .

oakcurric:misconception-people-low-incomes-apply-social
  a curric:Misconception ;
  curric:statement "Only people with very low incomes can apply for social housing."@en ;
  curric:correction """While social housing is mainly aimed at people with lower incomes or in urgent need, you don’t have to be unemployed or on benefits to apply. Local councils assess need based on income, family size and housing situation, not just income alone."""@en ;
  dcterms:modified "2026-02-12T08:59:18.702825Z"^^xsd:dateTime .

oakcurric:misconception-isnt-need-action-plan-long
  a curric:Misconception ;
  curric:statement """There isn't a need for an action plan as long as pupils are passionate about the issue."""@en ;
  curric:correction """An action plan is vital as it ensures everyone knows what their responsibilities are."""@en ;
  dcterms:modified "2026-02-12T08:59:18.702957Z"^^xsd:dateTime .

oakcurric:misconception-digital-media-diverse-traditional-media
  a curric:Misconception ;
  curric:statement """Digital media is more diverse than traditional media because anyone can create content."""@en ;
  curric:correction """Digital media is still often controlled by a few large corporations, limiting true diversity."""@en ;
  dcterms:modified "2026-02-12T08:59:18.702961Z"^^xsd:dateTime .

oakcurric:misconception-dont-need-worry-financial-planning
  a curric:Misconception ;
  curric:statement "You don’t need to worry about financial planning until you are older."@en ;
  curric:correction """Financial planning starts as soon as you have any income, like pocket money or a part-time job. Learning to plan now helps build strong habits for the future."""@en ;
  dcterms:modified "2026-02-12T08:59:18.703089Z"^^xsd:dateTime .

oakcurric:misconception-local-taxation-funds-national-priorities
  a curric:Misconception ;
  curric:statement "Local taxation only funds national priorities like healthcare and defence."@en ;
  curric:correction """Local taxation also supports local services, infrastructure and businesses. Council Tax and business rates are reinvested into local economies, funding initiatives such as skills training that benefits communities directly."""@en ;
  dcterms:modified "2026-02-12T08:59:18.703093Z"^^xsd:dateTime .

oakcurric:misconception-involved-community-means-participating-big
  a curric:Misconception ;
  curric:statement """Being involved in a community means only participating in big events or formal groups."""@en ;
  curric:correction """Community involvement can also be about smaller, everyday actions, like helping a neighbour or being part of a social group. It does not always require big events or formal organisations."""@en ;
  dcterms:modified "2026-02-12T08:59:18.703229Z"^^xsd:dateTime .

oakcurric:misconception-democracy-either-strong-weak
  a curric:Misconception ;
  curric:statement "Democracy is not either strong or weak."@en ;
  curric:correction """There are different features and areas of democracy, such as the type of democracy, electoral system, media and voting age. Each of these will have their own strengths and weaknesses that come together to form an overall judgement on democracy."""@en ;
  dcterms:modified "2026-02-12T08:59:18.703414Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-prime-minister-their
  a curric:Misconception ;
  curric:statement """Pupils may think that the Prime Minister and their government make the laws in the UK, single handidly."""@en ;
  curric:correction """Although the Government have mandate to drive their manifesto intentions, laws still pass through the whole of Parliament."""@en ;
  dcterms:modified "2026-02-12T08:59:18.703421Z"^^xsd:dateTime .

oakcurric:misconception-ordinary-people-real-influence-laws
  a curric:Misconception ;
  curric:statement "Ordinary people have no real influence over the laws made in Parliament."@en ;
  curric:correction """While politicians vote on laws, citizens play a powerful role in shaping them. By raising awareness, building public support, and working with their MPs, people outside of government have successfully influenced legal changes."""@en ;
  dcterms:modified "2026-02-12T08:59:18.703804Z"^^xsd:dateTime .

oakcurric:misconception-election-uk-general-election
  a curric:Misconception ;
  curric:statement "The only election in the UK is the general election."@en ;
  curric:correction """There are many different elections including: general, local government, PCC, Mayoral and devolved parliament elections."""@en ;
  dcterms:modified "2026-02-12T08:59:18.703808Z"^^xsd:dateTime .

oakcurric:misconception-civil-cases-end-court
  a curric:Misconception ;
  curric:statement "That all civil cases must end up in court."@en ;
  curric:correction """It is preferable for civil cases to be settled outside of court where possible as this is quicker, cheaper and less stressful for both parties."""@en ;
  dcterms:modified "2026-02-12T08:59:18.703947Z"^^xsd:dateTime .

oakcurric:misconception-one-type-government-better-other
  a curric:Misconception ;
  curric:statement "One type of government is better than the other."@en ;
  curric:correction """It is not always that simple. Every country governs differently and the effectiveness of a government depends on many factors such as how well it protects people’s rights,  ensures fairness and responds to citizens' needs."""@en ;
  dcterms:modified "2026-02-12T08:59:18.703952Z"^^xsd:dateTime .

oakcurric:misconception-public-say-moral-decisions-because
  a curric:Misconception ;
  curric:statement """The public has no say in moral decisions because the UK Government makes all the laws."""@en ;
  curric:correction """While the Government plays a key role, the public can be involved through consultations, ethics committees and campaigns. People can also challenge decisions through the courts if rights are affected."""@en ;
  dcterms:modified "2026-02-12T08:59:18.704030Z"^^xsd:dateTime .

oakcurric:misconception-royalty-follow-same-laws-citizens
  a curric:Misconception ;
  curric:statement """That royalty do not have to follow the same laws as citizens or would not be subjected to the legal system in the same way."""@en ;
  curric:correction """Rule of law states all citizens must obey the law, this includes the Royal Family."""@en ;
  dcterms:modified "2026-02-12T08:59:18.704037Z"^^xsd:dateTime .

oakcurric:misconception-countries-members-international-organisations
  a curric:Misconception ;
  curric:statement "All countries are members of international organisations."@en ;
  curric:correction "Countries have many reasons for not joining international  organisations."@en ;
  dcterms:modified "2026-02-12T08:59:18.704041Z"^^xsd:dateTime .

oakcurric:misconception-person-charge-finances-uk-chancellor
  a curric:Misconception ;
  curric:statement """The only person in charge of finances in the UK is the Chancellor of the Exchequer."""@en ;
  curric:correction """There is a whole structure of people in charge of the UK economy within the Treasury, including the Prime Minister who is the First Lord of the Treasury."""@en ;
  dcterms:modified "2026-02-12T08:59:18.704336Z"^^xsd:dateTime .

oakcurric:misconception-inflation-negative-thing-because-raises
  a curric:Misconception ;
  curric:statement """Inflation is always a negative thing because it raises prices of goods and services."""@en ;
  curric:correction """A small amount of inflation is actually necessary to keep the economy stable and encourage spending."""@en ;
  dcterms:modified "2026-02-12T08:59:18.704372Z"^^xsd:dateTime .

oakcurric:misconception-uk-government-pay-debt-completely
  a curric:Misconception ;
  curric:statement """The UK Government must pay debt off completely, like a household paying off a loan."""@en ;
  curric:correction """Governments often carry debt indefinitely and focus on managing it rather than eliminating it. As long as the Government can afford interest payments and investors have confidence in its ability to repay, borrowing can continue."""@en ;
  dcterms:modified "2026-02-12T08:59:18.704377Z"^^xsd:dateTime .

oakcurric:misconception-countries-fair-independent-justice-systems
  a curric:Misconception ;
  curric:statement """All countries have fair and independent justice systems that protect everyone's rights equally."""@en ;
  curric:correction """Not all countries have justice systems that are fair or independent. In some countries, the Government may control the courts, leading to biased decisions and limited protection of human rights."""@en ;
  dcterms:modified "2026-02-12T08:59:18.704382Z"^^xsd:dateTime .

oakcurric:misconception-international-laws-enforceable
  a curric:Misconception ;
  curric:statement "International laws are not enforceable."@en ;
  curric:correction """International laws are enforceable by courts if the nation has signed up to it. For example, the UK has agreed to the ICC and funds it. The USA has not agreed to the ICC so should follow international law but it is harder to enforce it."""@en ;
  dcterms:modified "2026-02-12T08:59:18.704386Z"^^xsd:dateTime .

oakcurric:misconception-judiciary-protects-strengthens-human-rights
  a curric:Misconception ;
  curric:statement "The judiciary always protects and strengthens human rights, no matter what."@en ;
  curric:correction """The judiciary plays a key role in defending rights, but it does not always act quickly or strongly enough. Judges often follow the law as it is written, and sometimes they decide that Parliament, not the courts, should make the final decision."""@en ;
  dcterms:modified "2026-02-12T08:59:18.704391Z"^^xsd:dateTime .

oakcurric:misconception-uk-small-nation-limited-impact
  a curric:Misconception ;
  curric:statement "The UK is a small nation and has limited impact around the world."@en ;
  curric:correction """The UK is a small nation so has to use as much of its influence as possible to make a difference. It can use its hard power through work with organisations like NATO. It can also use soft power with diplomacy."""@en ;
  dcterms:modified "2026-02-12T08:59:18.704396Z"^^xsd:dateTime .

oakcurric:misconception-devolution-means-regional-governments-independent
  a curric:Misconception ;
  curric:statement "Devolution means the regional governments are independent."@en ;
  curric:correction "Devolution allows more powers, but the countries still remain part of the UK."@en ;
  dcterms:modified "2026-02-12T08:59:18.704426Z"^^xsd:dateTime .

oakcurric:misconception-media-outlets-factual-bias
  a curric:Misconception ;
  curric:statement "Media outlets are always factual and not bias."@en ;
  curric:correction """Media outlets strive to report factual information. However, they can still exhbit media bias that can be linked to political affiliations and concentration of media ownership."""@en ;
  dcterms:modified "2026-02-12T08:59:18.704445Z"^^xsd:dateTime .

oakcurric:misconception-select-committees-criticising-government
  a curric:Misconception ;
  curric:statement "Select committees are just for criticising the Government."@en ;
  curric:correction """Select committees gather evidence and make recommendations to improve decision-making."""@en ;
  dcterms:modified "2026-02-12T08:59:18.704451Z"^^xsd:dateTime .

oakcurric:misconception-special-constables-same-police-powers
  a curric:Misconception ;
  curric:statement """That special constables do not have the same police powers as regular police officers."""@en ;
  curric:correction """Special constables have police powers and wear the same uniform as regular police officers."""@en ;
  dcterms:modified "2026-02-12T08:59:18.704458Z"^^xsd:dateTime .

oakcurric:misconception-nato-alliance-countries
  a curric:Misconception ;
  curric:statement "NATO is just an alliance between countries."@en ;
  curric:correction """NATO is more than just an alliance. It is an international organisation with a command structure, a shared budget, and agreed aims. Like the UN, it sets goals and carries out missions agreed by its Member States."""@en ;
  dcterms:modified "2026-02-12T08:59:18.704462Z"^^xsd:dateTime .

oakcurric:misconception-prime-minister-alone-makes-laws
  a curric:Misconception ;
  curric:statement "The Prime Minister alone makes all the laws."@en ;
  curric:correction """Laws are created by Parliament, this involves members of both the House of Commons and the House of Lords debating and voting on what they should look like."""@en ;
  dcterms:modified "2026-02-12T08:59:18.704539Z"^^xsd:dateTime .

oakcurric:misconception-financial-risks-affect-economy
  a curric:Misconception ;
  curric:statement "Only financial risks affect the economy."@en ;
  curric:correction """The Government must work hard to manage a large range of risks in every area of life, such as health and education, so that the economy remains stable and balanced."""@en ;
  dcterms:modified "2026-02-12T08:59:18.704546Z"^^xsd:dateTime .

oakcurric:misconception-algorithms-show-people-want-see
  a curric:Misconception ;
  curric:statement """Algorithms only show people what they want to see, they don’t really affect how people vote."""@en ;
  curric:correction """Algorithms can reinforce existing beliefs and limit exposure to different views. The UK Undercover Voters project showed that targeted content could influence opinions and spread misinformation, which could affect voting behaviour."""@en ;
  dcterms:modified "2026-02-12T08:59:18.704551Z"^^xsd:dateTime .

oakcurric:misconception-individual-votes-count-pointless-taking
  a curric:Misconception ;
  curric:statement "Individual votes do not count so could be pointless taking part."@en ;
  curric:correction "Marginal seats are an example of why every vote matters."@en ;
  dcterms:modified "2026-02-12T08:59:18.704764Z"^^xsd:dateTime .

oakcurric:misconception-advantages-zero-hour-contract-illegal
  a curric:Misconception ;
  curric:statement """There are no advantages to having a zero-hour contract and they are illegal in the UK."""@en ;
  curric:correction """Zero-hour contracts are legal in the UK and can benefit some workers who want flexible hours or less commitment than signing a permanent contract."""@en ;
  dcterms:modified "2026-02-12T08:59:18.704869Z"^^xsd:dateTime .

oakcurric:misconception-everyone-pays-same-percentage-income
  a curric:Misconception ;
  curric:statement "Everyone pays the same percentage of Income Tax."@en ;
  curric:correction """Income Tax is on a progressive scale so the percentage of income tax you pay depends on how much you earn."""@en ;
  dcterms:modified "2026-02-12T08:59:18.704873Z"^^xsd:dateTime .

oakcurric:misconception-ai-soleley-used-create-spread
  a curric:Misconception ;
  curric:statement """That AI is soleley used to create and spread disinformation, often via deepfakes."""@en ;
  curric:correction "AI can also be used to identify and delete disinfomation."@en ;
  dcterms:modified "2026-02-12T08:59:18.704878Z"^^xsd:dateTime .

oakcurric:misconception-rule-law-applies-ordinary-citizens
  a curric:Misconception ;
  curric:statement """The rule of law applies only to ordinary citizens, not leaders or those in power."""@en ;
  curric:correction """A key feature of the rule of law is that everyone, including those in power, are subject to the law."""@en ;
  dcterms:modified "2026-02-12T08:59:18.704883Z"^^xsd:dateTime .

oakcurric:misconception-country-uses-direct-democracy
  a curric:Misconception ;
  curric:statement "A country just uses direct democracy."@en ;
  curric:correction """Direct democracy can be used on its own or with other forms of democracy, such as representative democracy."""@en ;
  dcterms:modified "2026-02-12T08:59:18.705122Z"^^xsd:dateTime .

oakcurric:misconception-local-government-runs-same-way
  a curric:Misconception ;
  curric:statement "Every local government runs in the same way."@en ;
  curric:correction """Local governments do not all run in the same way. There are different type of councils including, county and district councils."""@en ;
  dcterms:modified "2026-02-12T08:59:18.705127Z"^^xsd:dateTime .

oakcurric:misconception-media-tells-truth-trust-everything
  a curric:Misconception ;
  curric:statement """The media always tells the truth, so we can trust everything we see during elections."""@en ;
  curric:correction """The media is not always completely unbiased or accurate. Different media outlets may have their own political leanings or agendas. Stories can be exaggerated or focus on sensational aspects, rather than providing balanced, factual information."""@en ;
  dcterms:modified "2026-02-12T08:59:18.705136Z"^^xsd:dateTime .

oakcurric:misconception-criminal-law-civil-law-handled
  a curric:Misconception ;
  curric:statement "Criminal law and civil law are always handled in the same courts."@en ;
  curric:correction """Criminal cases are typically heard in criminal courts, while civil cases are dealt with in civil courts; each have different procedures and purposes."""@en ;
  dcterms:modified "2026-02-12T08:59:18.705258Z"^^xsd:dateTime .

oakcurric:misconception-climate-conferences-opportunity-talk-nothing
  a curric:Misconception ;
  curric:statement "Climate conferences are just an opportunity to talk, nothing gets done."@en ;
  curric:correction """They are a chance to bring together world leaders to agree positive actions and work out problems. COP have secured important international agreements that have really helped to tackle climate change; the Paris Agreement is an example of this."""@en ;
  dcterms:modified "2026-02-12T08:59:18.705263Z"^^xsd:dateTime .

oakcurric:misconception-media-neutral
  a curric:Misconception ;
  curric:statement "The media should always be neutral."@en ;
  curric:correction """Media freedom does not require journalists to be entirely neutral. It allows for a range of perspectives, such as investigative journalism and opinion pieces, as long as they are reported accurately."""@en ;
  dcterms:modified "2026-02-12T08:59:18.705268Z"^^xsd:dateTime .

oakcurric:misconception-issues-need-related-citizenship-concepts
  a curric:Misconception ;
  curric:statement "Issues do not need to be related to Citizenship concepts."@en ;
  curric:correction """Active citizenship requires issues investigated and advocated for to have a clear link between a Citizenship concept and the issue."""@en ;
  dcterms:modified "2026-02-12T08:59:18.705272Z"^^xsd:dateTime .

oakcurric:misconception-success-huge
  a curric:Misconception ;
  curric:statement "That success has to be huge."@en ;
  curric:correction """Success can look different depending on the action and success can be subtle too."""@en ;
  dcterms:modified "2026-02-12T08:59:18.705502Z"^^xsd:dateTime .

oakcurric:misconception-magistrates-jps-legal-background-carry
  a curric:Misconception ;
  curric:statement """That magistrates or JPs have a legal background and carry out the role in a paid capacity like crown court judges."""@en ;
  curric:correction """Magistrates and JPs carry out the role on a volunteer basis as part of their civic responsibility."""@en ;
  dcterms:modified "2026-02-12T08:59:18.705507Z"^^xsd:dateTime .

oakcurric:misconception-democracies-free-press
  a curric:Misconception ;
  curric:statement "All democracies have a free press."@en ;
  curric:correction """Democracies generally support press freedom; some still have restrictions and controls."""@en ;
  dcterms:modified "2026-02-12T08:59:18.705511Z"^^xsd:dateTime .

oakcurric:misconception-limits-media-print-government
  a curric:Misconception ;
  curric:statement "There are limits to what the media can print about the Government."@en ;
  curric:correction """As long as the media is following regulations, they have the freedom to print what they like, even if this is negative towards the Government."""@en ;
  dcterms:modified "2026-02-12T08:59:18.705654Z"^^xsd:dateTime .

oakcurric:misconception-working-politics-becoming-elected-official
  a curric:Misconception ;
  curric:statement "Working in politics is only about becoming an elected official, like an MP."@en ;
  curric:correction """There are many other important roles, such as civil servants, journalists, and NGO workers, that also contribute to shaping policies and creating change."""@en ;
  dcterms:modified "2026-02-12T08:59:18.705734Z"^^xsd:dateTime .

oakcurric:misconception-public-services-owned-run-uk
  a curric:Misconception ;
  curric:statement "All public services are owned and run by the UK Government."@en ;
  curric:correction """Since Margaret Thatcher's Government (1979-1990), many public services in the UK have been sold and are now owned by private companies, including British Rail, British Steel, British Telecom and British Gas."""@en ;
  dcterms:modified "2026-02-12T08:59:18.705750Z"^^xsd:dateTime .

oakcurric:misconception-members-parliament-mps-part-select
  a curric:Misconception ;
  curric:statement "Only Members of Parliament (MPs) can be part of select committees."@en ;
  curric:correction """The public can contribute to select committees by submitting evidence or attending public consultations."""@en ;
  dcterms:modified "2026-02-12T08:59:18.705755Z"^^xsd:dateTime .

oakcurric:misconception-voting-way-citizens-make-difference
  a curric:Misconception ;
  curric:statement """Voting is the only way citizens can make a difference in global humanitarian issues."""@en ;
  curric:correction """There are numerous things citizens can do, for example, they can also take part in demonstrations, volunteer schemes, and other actions that raise awareness and provide direct support, all of which contribute to making a difference."""@en ;
  dcterms:modified "2026-02-12T08:59:18.705759Z"^^xsd:dateTime .

oakcurric:misconception-uk-longer-influence-world
  a curric:Misconception ;
  curric:statement "The UK no longer has any influence in the world."@en ;
  curric:correction """Although the UK's influence has declined in some areas, it still holds significant global influence. Through its membership in organisations like NATO, the UN and the Commonwealth, the UK continues to shape global events."""@en ;
  dcterms:modified "2026-02-12T08:59:18.705764Z"^^xsd:dateTime .

oakcurric:misconception-citizens-arent-able-make-difference
  a curric:Misconception ;
  curric:statement "Citizens aren't able to make a difference and hold leaders accountable."@en ;
  curric:correction """Citizens hold leaders accountable through raising concerns, participating in inquiries and contacting MPs."""@en ;
  dcterms:modified "2026-02-12T08:59:18.705769Z"^^xsd:dateTime .

oakcurric:misconception-non-democratic-governments-lawless
  a curric:Misconception ;
  curric:statement "Non-democratic governments are lawless."@en ;
  curric:correction """Non-democratic governments still have laws and rules but the citizens might not get a say in what these are and they are decided by those in power."""@en ;
  dcterms:modified "2026-02-12T08:59:18.705789Z"^^xsd:dateTime .

oakcurric:misconception-democracies-efficient-quicker-making-decisions
  a curric:Misconception ;
  curric:statement """Democracies are always more efficient and quicker at making decisions than dictatorships."""@en ;
  curric:correction """While democracies can be slower in making decisions due to debates, elections, and checks on power, this doesn't mean they are less effective overall. Decisions involving multiple viewpoints can lead to more thoughtful and balanced outcomes."""@en ;
  dcterms:modified "2026-02-12T08:59:18.705804Z"^^xsd:dateTime .

oakcurric:misconception-economy-entirely-controlled-uk-government
  a curric:Misconception ;
  curric:statement """The economy is entirely controlled by the UK Government and that individuals have little to no influence over it."""@en ;
  curric:correction """While the Government plays a significant role through policies, taxation and public spending, individual citizens also shape the economy through their financial decisions, employment and consumer behaviour."""@en ;
  dcterms:modified "2026-02-12T08:59:18.705840Z"^^xsd:dateTime .

oakcurric:misconception-refugees-protected-laws-country-arrive
  a curric:Misconception ;
  curric:statement "Refugees are only protected by the laws of the country they arrive in."@en ;
  curric:correction """Refugees are protected by international agreements and laws. The geneva convention is very important and outlines how we treat refugees. This is overseen and safeguarded by the UN agency for refugees."""@en ;
  dcterms:modified "2026-02-12T08:59:18.705990Z"^^xsd:dateTime .

oakcurric:misconception-eu-ec-same-thing
  a curric:Misconception ;
  curric:statement "The EU and the EC do the same thing."@en ;
  curric:correction """The European Union is governed by the European Parliament which has directly elected represnetatives. These are called MEPs. The European Council has representatives from Member States who are their country's leaders."""@en ;
  dcterms:modified "2026-02-12T08:59:18.706151Z"^^xsd:dateTime .

oakcurric:misconception-countries-international-criminal-court-therefore
  a curric:Misconception ;
  curric:statement """All countries are in the International Criminal Court and therefore it is effective at enforcing humanitarian laws."""@en ;
  curric:correction """Not all nations are part of the ICC, for example, the USA and Russia are not. The ICC attempts to enforce humanitarian laws anyway and members can bring cases against non-members."""@en ;
  dcterms:modified "2026-02-12T08:59:18.706291Z"^^xsd:dateTime .

oakcurric:misconception-once-my-project-ends-theres
  a curric:Misconception ;
  curric:statement "Once my project ends, there's nothing more I can do to make a difference."@en ;
  curric:correction """You can create systems, inspire others, or build partnerships so your impact continues even after you finish."""@en ;
  dcterms:modified "2026-02-12T08:59:18.706536Z"^^xsd:dateTime .

oakcurric:misconception-laws-made-same-way-uk
  a curric:Misconception ;
  curric:statement "Laws are made the same way in both the UK and the US."@en ;
  curric:correction """The process of creating laws is different. The UK has a parliamentary system whereas the US follows a presidential system."""@en ;
  dcterms:modified "2026-02-12T08:59:18.706543Z"^^xsd:dateTime .

oakcurric:misconception-government-able-control-media
  a curric:Misconception ;
  curric:statement "The Government are able to control the media."@en ;
  curric:correction """The media is separate from the Government and this is an important feature of a democracy."""@en ;
  dcterms:modified "2026-02-12T08:59:18.706547Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-criminal-law-deals
  a curric:Misconception ;
  curric:statement """Pupils may think that criminal law deals with serious crime and civil law deals with less serious crime."""@en ;
  curric:correction """Criminal law and civil law are seperate. Within both, there is a range of severity."""@en ;
  dcterms:modified "2026-02-12T08:59:18.706693Z"^^xsd:dateTime .

oakcurric:misconception-negative-tempting-fate-consider-go
  a curric:Misconception ;
  curric:statement "That it is negative or 'tempting fate' to consider what could go wrong."@en ;
  curric:correction """Considering what could go wrong is a sensible part of planning for your goal, this helps to identify possible barriers and work to overcome them."""@en ;
  dcterms:modified "2026-02-12T08:59:18.706700Z"^^xsd:dateTime .

oakcurric:misconception-elections-same-across-world
  a curric:Misconception ;
  curric:statement "Elections are the same across the world."@en ;
  curric:correction "Elections run differently and follow different systems in indvidual countries."@en ;
  dcterms:modified "2026-02-12T08:59:18.706822Z"^^xsd:dateTime .

oakcurric:misconception-adults-famous-people-changemakers
  a curric:Misconception ;
  curric:statement "Only adults or famous people can be changemakers."@en ;
  curric:correction "Anyone can be a changemaker, including children and young people."@en ;
  dcterms:modified "2026-02-12T08:59:18.706830Z"^^xsd:dateTime .

oakcurric:misconception-uk-follow-international-climate-agreements
  a curric:Misconception ;
  curric:statement """The UK does not have to follow international climate agreements like the Paris Agreement because they are not UK laws."""@en ;
  curric:correction """While international agreements like the Paris Agreement are not UK laws, the UK chooses to follow them and often updates its national laws, like setting a net-zero target, to meet the promises made globally."""@en ;
  dcterms:modified "2026-02-12T08:59:18.706835Z"^^xsd:dateTime .

oakcurric:misconception-campaigning-doesnt-really-make-difference
  a curric:Misconception ;
  curric:statement "Campaigning doesn't really make a difference to the law."@en ;
  curric:correction """Campaigning has played a key role in major legal changes, like women's right to vote and LGBTQ+ equality laws."""@en ;
  dcterms:modified "2026-02-12T08:59:18.706840Z"^^xsd:dateTime .

oakcurric:misconception-specific-crime-prevention-strategies-work
  a curric:Misconception ;
  curric:statement "That only specific crime prevention strategies can work."@en ;
  curric:correction """Humans are complex and so is crime, therefore a variety of different strategies are often used together to try and reduce crime."""@en ;
  dcterms:modified "2026-02-12T08:59:18.706890Z"^^xsd:dateTime .

oakcurric:misconception-proportional-representation-better-fairer-voting
  a curric:Misconception ;
  curric:statement "Proportional Representation is always a better and fairer voting system."@en ;
  curric:correction """Proportional Representation can make elections fairer by matching seats to votes more closely. It often leads to coalition governments, which can be unstable or slow to make decisions."""@en ;
  dcterms:modified "2026-02-12T08:59:18.707114Z"^^xsd:dateTime .

oakcurric:misconception-media-tells-full-truth-immigration
  a curric:Misconception ;
  curric:statement "The media always tells the full truth about immigration."@en ;
  curric:correction """Media can be biased; some reports may exaggerate or misrepresent immigration, influencing public opinion unfairly."""@en ;
  dcterms:modified "2026-02-12T08:59:18.707119Z"^^xsd:dateTime .

oakcurric:misconception-direct-action-campaign-methods-such
  a curric:Misconception ;
  curric:statement "Only direct action campaign methods such as protests can make change happen."@en ;
  curric:correction """Direct action, like protests, can create change, but indirect methods are also powerful. Petitions, social media, education, and lobbying influence opinions and decisions over time. Successful campaigns often use both to make a lasting impact."""@en ;
  dcterms:modified "2026-02-12T08:59:18.707128Z"^^xsd:dateTime .

oakcurric:misconception-tools-used-campaign
  a curric:Misconception ;
  curric:statement "Any tools can be used for any campaign."@en ;
  curric:correction """Some tools work better depending on the issue, level, who holds the power and what resources are available."""@en ;
  dcterms:modified "2026-02-12T08:59:18.707135Z"^^xsd:dateTime .

oakcurric:misconception-ngos-dont-get-government-funding
  a curric:Misconception ;
  curric:statement "NGOs don’t get any government funding because they are non-governmental."@en ;
  curric:correction """NGOs are independent of government control but can still receive government funding to help carry out important work."""@en ;
  dcterms:modified "2026-02-12T08:59:18.707140Z"^^xsd:dateTime .

oakcurric:misconception-democracy-voting
  a curric:Misconception ;
  curric:statement "Democracy is just about voting."@en ;
  curric:correction """Democracy is about more than just voting. Democratic values include freedom of speech, the right to protest and freedom to assemble etc."""@en ;
  dcterms:modified "2026-02-12T08:59:18.707330Z"^^xsd:dateTime .

oakcurric:misconception-voting-way-become-involved-politics
  a curric:Misconception ;
  curric:statement "Voting is the only way to become involved in politics."@en ;
  curric:correction """Voting isn't the only way to be involved in politics; you can raise awareness about important issues, join campaigns, speak out on social media or participate in protests and petitions."""@en ;
  dcterms:modified "2026-02-12T08:59:18.707432Z"^^xsd:dateTime .

oakcurric:misconception-government-absolute-power-media-neutral
  a curric:Misconception ;
  curric:statement """The Government has absolute power and the media is just a neutral source of information."""@en ;
  curric:correction """The Government is powerful but must follow laws and face elections. The media influences opinion but can also mislead people."""@en ;
  dcterms:modified "2026-02-12T08:59:18.707436Z"^^xsd:dateTime .

oakcurric:misconception-careful-consideration-answering-key-questions
  a curric:Misconception ;
  curric:statement """Careful consideration, through answering the key questions, is not needed to decide which research methods to use: research methods can be chosen at random."""@en ;
  curric:correction """Pupils must consider and answer the key questions to ensure they choose appropriate and suitable research methods for their chosen active citizenship project. Failure to do so will jeopdise the project's success."""@en ;
  dcterms:modified "2026-02-12T08:59:18.707525Z"^^xsd:dateTime .

oakcurric:misconception-first-past-post-fptp-system
  a curric:Misconception ;
  curric:statement "The First Past The Post (FPTP) system produces strong and stable governments."@en ;
  curric:correction """There have been coalition and minority governments using FPTP. In addition, there can be instability as the party in power can be divided over certain issues or can have weak leadership / poor governance."""@en ;
  dcterms:modified "2026-02-12T08:59:18.707534Z"^^xsd:dateTime .

oakcurric:misconception-pupil-finds-safe-appropriate-discuss
  a curric:Misconception ;
  curric:statement """That what a pupil finds safe and appropriate to discuss will be for the same for everyone."""@en ;
  curric:correction """We all have different lived experience, which can impact whether we find topics distressing, a person's age can also have an impact."""@en ;
  dcterms:modified "2026-02-12T08:59:18.707655Z"^^xsd:dateTime .

oakcurric:misconception-pupils-believe-infleuncers-ever-positively
  a curric:Misconception ;
  curric:statement "Pupils might believe that infleuncers can only ever positively influence."@en ;
  curric:correction """Although influencers can have positive impacts, when posting about politics there can also be negative impacts if they are posting incorrect information or simplifying issues."""@en ;
  dcterms:modified "2026-02-12T08:59:18.707719Z"^^xsd:dateTime .

oakcurric:misconception-un-effective-actions-takes
  a curric:Misconception ;
  curric:statement "The UN is always effective in the actions it takes."@en ;
  curric:correction """The UN has been a powerful force for good in the world and has secured many victories. However, there have also been actions taken by the UN which have not been fully effective or only made marginal gains."""@en ;
  dcterms:modified "2026-02-12T08:59:18.707725Z"^^xsd:dateTime .

oakcurric:misconception-government-borrow-unlimited-money-without
  a curric:Misconception ;
  curric:statement "The Government can borrow unlimited money without consequences."@en ;
  curric:correction """While the Government can borrow to fund services and support the economy, excessive borrowing leads to higher debt and interest payments, which can limit future spending and create financial risks."""@en ;
  dcterms:modified "2026-02-12T08:59:18.707732Z"^^xsd:dateTime .

oakcurric:misconception-governments-charge-their-citizens-income
  a curric:Misconception ;
  curric:statement "All governments charge their citizens Income Tax."@en ;
  curric:correction """There are many countries that do not pay Income Tax at all; their governments get their income elsewhere like from VAT or natural resources."""@en ;
  dcterms:modified "2026-02-12T08:59:18.707737Z"^^xsd:dateTime .

oakcurric:misconception-older-people-cannot-use-online
  a curric:Misconception ;
  curric:statement "Older people cannot use online banking at all."@en ;
  curric:correction """With the right support and training, many older people have adapted very well to online banking. It is prejudiced to assume all older people struggle."""@en ;
  dcterms:modified "2026-02-12T08:59:18.707741Z"^^xsd:dateTime .

oakcurric:misconception-social-media-news-posts-accurate
  a curric:Misconception ;
  curric:statement "Social media news posts are always accurate."@en ;
  curric:correction """There is misinformation within all media, but even more so with social media due to a lack of regulation."""@en ;
  dcterms:modified "2026-02-12T08:59:18.707824Z"^^xsd:dateTime .

oakcurric:misconception-digital-media-good-bad-relation
  a curric:Misconception ;
  curric:statement "Digital media can only be good or bad in relation to community cohesion."@en ;
  curric:correction "Digital media can both unite and divide communities."@en ;
  dcterms:modified "2026-02-12T08:59:18.708161Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-journalism-same-everywhere
  a curric:Misconception ;
  curric:statement """Pupils may think journalism is the same everywhere and not understand the risks faced by journalists in countries with limited press freedom."""@en ;
  curric:correction """Journalism is not the same everywhere. Due to a lack of press freedom laws in some countries, journalists are putting their lives at risk by investigating and reporting about key issues."""@en ;
  dcterms:modified "2026-02-12T08:59:18.708169Z"^^xsd:dateTime .

oakcurric:misconception-international-law-automatically-replaces-uk
  a curric:Misconception ;
  curric:statement "International law automatically replaces UK law."@en ;
  curric:correction """International law does not override UK law automatically. Parliament decides how and when international law is applied in the UK."""@en ;
  dcterms:modified "2026-02-12T08:59:18.708176Z"^^xsd:dateTime .

oakcurric:misconception-government-full-control-driving-impacting
  a curric:Misconception ;
  curric:statement "The Government have full control of driving and impacting the economy."@en ;
  curric:correction """Although the Government play a key role in the UK's economy, it is also impacted by external factors, and when this happens, the Government have to make poltical decisions to protect the economy."""@en ;
  dcterms:modified "2026-02-12T08:59:18.708249Z"^^xsd:dateTime .

oakcurric:misconception-devolution-means-areas-become-independent
  a curric:Misconception ;
  curric:statement "Devolution means that areas become independent."@en ;
  curric:correction """Devolution means powers are devolved but they are still part of the UK and Parliament still holds central power."""@en ;
  dcterms:modified "2026-02-12T08:59:18.708426Z"^^xsd:dateTime .

oakcurric:misconception-secondary-research-same-value
  a curric:Misconception ;
  curric:statement "All secondary research has the same value."@en ;
  curric:correction """Secondary research is the most vauable and useful whe it is valid, reliable, accurate, current and free from bias."""@en ;
  dcterms:modified "2026-02-12T08:59:18.708431Z"^^xsd:dateTime .

oakcurric:misconception-pupils-think-success-changing-law
  a curric:Misconception ;
  curric:statement """Pupils may think that success on changing a law is solely dependant on the citizen or citizens."""@en ;
  curric:correction """Whilst personal skills of the citizens involved is important, there are many other external factors that can impact success or failure, regardless of how persuasive the individuals trying to change the law are."""@en ;
  dcterms:modified "2026-02-12T08:59:18.708436Z"^^xsd:dateTime .

oakcurric:misconception-police-authority-figures-punish-people
  a curric:Misconception ;
  curric:statement "Police are just authority figures who punish people."@en ;
  curric:correction """Police protect communities, prevent crime, and ensure safety, not just enforce punishment. They also help in emergencies."""@en ;
  dcterms:modified "2026-02-12T08:59:18.708627Z"^^xsd:dateTime .

oakcurric:misconception-petition-gets-100-000-signatures
  a curric:Misconception ;
  curric:statement """If a petition gets over 100,000 signatures and is debated in Parliament, it means the law will definitely change."""@en ;
  curric:correction """In the UK, Parliament agrees to debate any petition that gets over 100,000 signatures, but the decision to change a policy or create a new law is still up to the Government."""@en ;
  dcterms:modified "2026-02-12T08:59:18.708631Z"^^xsd:dateTime .

oakcurric:misconception-rights-obligations-legal-requirements
  a curric:Misconception ;
  curric:statement "All rights and obligations are legal requirements."@en ;
  curric:correction """Not all of our obligations are legal, some of them are moral, for example to be part of a community and support the community is a moral obligation rather than a legal one."""@en ;
  dcterms:modified "2026-02-12T08:59:18.708636Z"^^xsd:dateTime .

oakcurric:misconception-leaving-eu-make-uk-stronger
  a curric:Misconception ;
  curric:statement """Leaving the EU would make the UK stronger because we wouldn’t have to follow EU rules anymore."""@en ;
  curric:correction """This is too simplistic a viewpoint. While the UK wouldn’t need to follow EU rules, it would still need to establish new agreements with the EU and other countries."""@en ;
  dcterms:modified "2026-02-12T08:59:18.708640Z"^^xsd:dateTime .

oakcurric:misconception-local-economy-depends-businesses-jobs
  a curric:Misconception ;
  curric:statement "The local economy only depends on businesses and jobs."@en ;
  curric:correction """While businesses and jobs are important, the local economy is also influenced by government policies, public services, infrastructure and consumer behaviour. Global events like recessions or technological changes can impact local economies."""@en ;
  dcterms:modified "2026-02-12T08:59:18.708761Z"^^xsd:dateTime .

oakcurric:misconception-climate-change-affects-environment
  a curric:Misconception ;
  curric:statement "Climate change only affects the environment."@en ;
  curric:correction """Climate change also impacts human rights, causing issues like food insecurity, displacement, and health risks, particularly for vulnerable communities."""@en ;
  dcterms:modified "2026-02-12T08:59:18.708775Z"^^xsd:dateTime .

oakcurric:misconception-crime-figures-100-accurate
  a curric:Misconception ;
  curric:statement "Crime figures are 100% accurate."@en ;
  curric:correction "Not all crime is reported, so crime figures can only provide an estimate."@en ;
  dcterms:modified "2026-02-12T08:59:18.708780Z"^^xsd:dateTime .

oakcurric:misconception-climate-change-slow-moving-threat
  a curric:Misconception ;
  curric:statement "Climate change is a slow moving threat with limited impact on humanity so far."@en ;
  curric:correction """Climate change is costing countries billions of dollars a year. There is already a cost to human life due to extreme weather events. Equally, governments are facing huge challenges to become more resillient to climate change."""@en ;
  dcterms:modified "2026-02-12T08:59:18.708807Z"^^xsd:dateTime .

oakcurric:misconception-democratic-countries-make-decisions-same
  a curric:Misconception ;
  curric:statement "All democratic countries make decisions in the same way."@en ;
  curric:correction """The decision-making process varies between democratic countries and depends on the type of system they follow."""@en ;
  dcterms:modified "2026-02-12T08:59:18.708816Z"^^xsd:dateTime .

oakcurric:misconception-censorship-bad-linked-students-understanding
  a curric:Misconception ;
  curric:statement """Censorship is always bad (this might be linked to students' understanding of free press and human rights)."""@en ;
  curric:correction "Censorship sometimes needs to happen to reduce offence, upset and harm."@en ;
  dcterms:modified "2026-02-12T08:59:18.709149Z"^^xsd:dateTime .

oakcurric:misconception-chambers-uks-bicameral-system-equal
  a curric:Misconception ;
  curric:statement "Both chambers in the UK's bicameral system have equal power and roles."@en ;
  curric:correction """The House of Commons holds more legislative power, while the House of Lords primarily acts as a revising chamber, providing scrutiny and suggesting amendments, rather than making final decisions."""@en ;
  dcterms:modified "2026-02-12T08:59:18.709155Z"^^xsd:dateTime .

oakcurric:misconception-particular-opinion-viewpoint-issue-everyone
  a curric:Misconception ;
  curric:statement """If you have a particular opinion or viewpoint on an issue, everyone in your group will think the same."""@en ;
  curric:correction """This might not be the case, as diverse perspectives exist. This is why it's important to test this during primary research to discover whether your identified issue is shared by others."""@en ;
  dcterms:modified "2026-02-12T08:59:18.709160Z"^^xsd:dateTime .

oakcurric:misconception-low-income-countries-lics-take
  a curric:Misconception ;
  curric:statement """Low income countries (LICs) do not take action on climate change because they lack resources."""@en ;
  curric:correction """LICs do face challenges but are actively taking climate action with support from the UN and financial support from other sources. For example, Malawi is improving green energy, like solar power, to reduce emissions and adapt to climate impacts."""@en ;
  dcterms:modified "2026-02-12T08:59:18.709165Z"^^xsd:dateTime .

oakcurric:misconception-success-measured-big-changes
  a curric:Misconception ;
  curric:statement "Success is only measured by big changes."@en ;
  curric:correction """Encourage pupils to see that success is not just about large-scale change. Small improvements, like raising awareness, influencing opinions, or getting a response from decision-makers, also matter."""@en ;
  dcterms:modified "2026-02-12T08:59:18.709280Z"^^xsd:dateTime .

oakcurric:misconception-modern-financial-products-safe-designed
  a curric:Misconception ;
  curric:statement "All modern financial products are safe and designed to help people save money."@en ;
  curric:correction """Apps and new financial products can be popular, so young people might not recognise the risks involved, such as overspending with Buy Now, Pay Later tools or misunderstanding investment risks."""@en ;
  dcterms:modified "2026-02-12T08:59:18.709284Z"^^xsd:dateTime .

oakcurric:misconception-local-councils-full-control-their
  a curric:Misconception ;
  curric:statement """Local councils have full control of their spending so can make all decisions themselves."""@en ;
  curric:correction """Part of their funding comes from national government so they sometimes have to priorities government led initiatives over local need."""@en ;
  dcterms:modified "2026-02-12T08:59:18.709289Z"^^xsd:dateTime .

oakcurric:misconception-democratic-governments-cannot-authoritarian-features
  a curric:Misconception ;
  curric:statement """Democratic governments cannot have authoritarian features, and authoritarian regimes cannot have democratic elements."""@en ;
  curric:correction """Governments are not always purely democratic or authoritarian. Many exist on a spectrum and can have a mix of both democratic and authoritarian traits."""@en ;
  dcterms:modified "2026-02-12T08:59:18.709537Z"^^xsd:dateTime .

oakcurric:misconception-power-separated-therefore-branch-link
  a curric:Misconception ;
  curric:statement "Power is separated, therefore, each branch does not link together."@en ;
  curric:correction """While power is separated, the branches are still linked and work together. Each branch has its own responsibilities but also checks and balances the others to ensure no one branch becomes too powerful."""@en ;
  dcterms:modified "2026-02-12T08:59:18.709676Z"^^xsd:dateTime .

oakcurric:misconception-small-political-parties-cant-make
  a curric:Misconception ;
  curric:statement """Small political parties can’t make difference in the UK as they never win enough seats in Parliament."""@en ;
  curric:correction """Small parties can influence the Government by: raising important issues that main parties may ignore impacting election outcomes by taking votes away from larger parties; helping to shape policies; pushing their ideas into the national conversation."""@en ;
  dcterms:modified "2026-02-12T08:59:18.709850Z"^^xsd:dateTime .

oakcurric:misconception-regeneration-benefits-everyone-community
  a curric:Misconception ;
  curric:statement "Regeneration benefits everyone in the community."@en ;
  curric:correction """Pupils may think regeneration always helps everyone, but if it is not planned in an inclusive manner  it can lead to gentrification, displacing long-standing residents and businesses."""@en ;
  dcterms:modified "2026-02-12T08:59:18.709923Z"^^xsd:dateTime .

oakcurric:misconception-vote-leave-focused-immigration-didnt
  a curric:Misconception ;
  curric:statement """Vote Leave only focused on immigration and didn’t really care about the economy or national identity."""@en ;
  curric:correction """While immigration was a key issue, Vote Leave also argued that leaving the EU would give the UK more control over its economy, laws, and national identity. These issues were central to their campaign, not just immigration."""@en ;
  dcterms:modified "2026-02-12T08:59:18.709927Z"^^xsd:dateTime .

oakcurric:misconception-media-hold-government-account-matter
  a curric:Misconception ;
  curric:statement "The media can always hold the Government to account, no matter the country."@en ;
  curric:correction """The media can only effectively challenge the Government in countries where press freedom exists. In these countries, journalists are free to investigate, report and criticise those in power without fear of government control or censorship."""@en ;
  dcterms:modified "2026-02-12T08:59:18.709932Z"^^xsd:dateTime .

oakcurric:misconception-crime-committed-specific-groups-people
  a curric:Misconception ;
  curric:statement "That crime is only committed by specific groups of people."@en ;
  curric:correction """Crime is complex and there are social, economic, psychological and environmental factors which can all impact the likelihood of crime."""@en ;
  dcterms:modified "2026-02-12T08:59:18.709974Z"^^xsd:dateTime .

oakcurric:misconception-grassroots-campaigns-cannot-make-big
  a curric:Misconception ;
  curric:statement """Grassroots campaigns cannot make a big difference because they are local, small-scale, and led by people without influence or national recognition."""@en ;
  curric:correction """Grassroots campaigns often start small, but grow as more people join. Their local focus makes them powerful, and many have led to national policy changes or raised public awareness."""@en ;
  dcterms:modified "2026-02-12T08:59:18.709985Z"^^xsd:dateTime .

oakcurric:misconception-young-people-cant-make-real
  a curric:Misconception ;
  curric:statement """Young people can't make a real difference in society or influence decision-makers."""@en ;
  curric:correction """Young people can create change by raising awareness, educating others, and working with leaders or organisations."""@en ;
  dcterms:modified "2026-02-12T08:59:18.709992Z"^^xsd:dateTime .

oakcurric:misconception-humanitarian-problems-conflicts
  a curric:Misconception ;
  curric:statement "Humanitarian problems are just conflicts."@en ;
  curric:correction """Humanitarian problems can be a range of issues, including conflicts. It could be a natural disaster such as an earthquake or it could be other events which lead to a refugee crisis. Conflicts are one example of humantiarian problems."""@en ;
  dcterms:modified "2026-02-12T08:59:18.709997Z"^^xsd:dateTime .

oakcurric:misconception-shopping-locally-sustainably-expensive
  a curric:Misconception ;
  curric:statement "Shopping locally or sustainably is always more expensive."@en ;
  curric:correction """Many people may believe that making ethical or local shopping choices costs more, without realising the long term financial and environmental benefits, like durability, reduced waste or savings through reused and second-hand items."""@en ;
  dcterms:modified "2026-02-12T08:59:18.710189Z"^^xsd:dateTime .

oakcurric:misconception-students-less-awareness-deepfakes-believe
  a curric:Misconception ;
  curric:statement """Students who have less awareness of deepfakes may believe that anything they can see or hear within digital media is true."""@en ;
  curric:correction """Emphasise the sophistication of deepfakes and consider using the teacher tip to further demonstrate this point."""@en ;
  dcterms:modified "2026-02-12T08:59:18.710193Z"^^xsd:dateTime .

oakcurric:misconception-local-media-less-important-national
  a curric:Misconception ;
  curric:statement "Local media is less important than national media in influencing public opinion."@en ;
  curric:correction """Both are vital. Local media engages communities directly, while national media impacts the broader public and sets key agendas. They complement each other."""@en ;
  dcterms:modified "2026-02-12T08:59:18.710330Z"^^xsd:dateTime .

oakcurric:misconception-referendums-national-issues
  a curric:Misconception ;
  curric:statement "Referendums are only about national issues."@en ;
  curric:correction """Referendums are held for a wide range of reasons. They might be national, (like the UK's relationship with Europe), or they might be regional, (like Scottish independence). Sometimes, a referendum can be local too."""@en ;
  dcterms:modified "2026-02-12T08:59:18.710336Z"^^xsd:dateTime .

oakcurric:misconception-justice-punishing-criminals
  a curric:Misconception ;
  curric:statement "Justice is only about punishing criminals."@en ;
  curric:correction """Justice is about punishing criminals but it is also about fairness, access to legal help and protecting the rights of all people, including victims and the accused."""@en ;
  dcterms:modified "2026-02-12T08:59:18.710341Z"^^xsd:dateTime .

oakcurric:misconception-un-force-countries-follow-its
  a curric:Misconception ;
  curric:statement "The UN can force countries to follow its decisions."@en ;
  curric:correction """Most UN decisions are not legally binding. Only Security Council resolutions are, and even these can be blocked by a permanent member’s veto."""@en ;
  dcterms:modified "2026-02-12T08:59:18.710636Z"^^xsd:dateTime .
