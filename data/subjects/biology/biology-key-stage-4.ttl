  rdfs:label """Lifestyle factors (e.g. hygiene, diet) affect the chances of developing communicable and non-communicable diseases."""@en ;
  dcterms:modified "2026-02-12T08:59:21.601479Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9184-1
  a curric:KeyLearningPoint ;
  rdfs:label """Some, but not all, bacteria are pathogens that can cause communicable diseases in humans."""@en ;
  dcterms:modified "2026-02-12T08:59:21.601704Z"^^xsd:dateTime .

