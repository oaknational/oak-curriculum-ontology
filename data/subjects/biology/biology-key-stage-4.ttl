  a curric:KeyLearningPoint ;
  rdfs:label """Salmonella food poisoning as an example of a bacterial disease, how it is spread, and how the spread can be reduced."""@en ;
  dcterms:modified "2026-02-12T08:59:21.601720Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9184-4
  a curric:KeyLearningPoint ;
  rdfs:label "Viruses invade cells to reproduce where they cause damage to cells."@en ;
  dcterms:modified "2026-02-12T08:59:21.601727Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9184-5
  a curric:KeyLearningPoint ;
  rdfs:label """Influenza as an example of a viral disease, how it is spread, and how the spread can be reduced."""@en ;
  dcterms:modified "2026-02-12T08:59:21.601735Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5561-1
  a curric:KeyLearningPoint ;
  rdfs:label "Substances are transported around the body in the blood."@en ;
  dcterms:modified "2026-02-12T08:59:21.603599Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5561-2
  a curric:KeyLearningPoint ;
  rdfs:label "Blood is pumped through blood vessels by an organ called the heart."@en ;
  dcterms:modified "2026-02-12T08:59:21.603607Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5561-3
  a curric:KeyLearningPoint ;
  rdfs:label """The heart is made of cardiac muscle, which continually contracts and relaxes to pump blood."""@en ;
  dcterms:modified "2026-02-12T08:59:21.603664Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5561-4
  a curric:KeyLearningPoint ;
  rdfs:label """The heart has four chambers with valves, which keep oxygenated and deoxygenated blood separate."""@en ;
  dcterms:modified "2026-02-12T08:59:21.603674Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5561-5
  a curric:KeyLearningPoint ;
