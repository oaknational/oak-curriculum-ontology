# ----------------------------------------------------------------------
# Keywords
# ----------------------------------------------------------------------

oakcurric:keyword-dominant
  a curric:Keyword ;
  schema:name "dominant"@en ;
  schema:description "the most widely accepted or prevailing (idea or concept)"@en ;
  dcterms:modified "2026-02-12T08:59:15.789347Z"^^xsd:dateTime .

oakcurric:keyword-inheritance
  a curric:Keyword ;
  schema:name "inheritance"@en ;
  schema:description """belongings, for example money and property, received from someone after they have died"""@en ;
  dcterms:modified "2026-02-12T08:59:15.789654Z"^^xsd:dateTime .

oakcurric:keyword-distribution
  a curric:Keyword ;
  schema:name "distribution"@en ;
  schema:description """the spread (which may have a regular pattern) of, for example, a type of vegetation"""@en ;
  dcterms:modified "2026-02-12T08:59:15.789704Z"^^xsd:dateTime .

oakcurric:keyword-hypothesis
  a curric:Keyword ;
  schema:name "hypothesis"@en ;
  schema:description "a prediction taken at the start of the enquiry that can then be tested"@en ;
  dcterms:modified "2026-02-12T08:59:15.789905Z"^^xsd:dateTime .

oakcurric:keyword-prediction
  a curric:Keyword ;
  schema:name "prediction"@en ;
  schema:description "making a guess using what we already know"@en ;
  dcterms:modified "2026-02-12T08:59:15.790024Z"^^xsd:dateTime .

oakcurric:keyword-climate-change
  a curric:Keyword ;
  schema:name "climate change"@en ;
  schema:description "long-term shifts in temperatures and weather patterns"@en ;
  dcterms:modified "2026-02-12T08:59:15.790394Z"^^xsd:dateTime .

oakcurric:keyword-quantitative
  a curric:Keyword ;
  schema:name "quantitative"@en ;
  schema:description "data that is made up of numbers"@en ;
  dcterms:modified "2026-02-12T08:59:15.791012Z"^^xsd:dateTime .

oakcurric:keyword-qualitative
  a curric:Keyword ;
  schema:name "qualitative"@en ;
  schema:description "data that is made up of text"@en ;
  dcterms:modified "2026-02-12T08:59:15.791016Z"^^xsd:dateTime .

oakcurric:keyword-variation
  a curric:Keyword ;
  schema:name "variation"@en ;
  schema:description """differences or changes in something, for example variations in energy use between countries means differences in the amounts and types of energy that different countries use"""@en ;
  dcterms:modified "2026-02-12T08:59:15.791164Z"^^xsd:dateTime .

oakcurric:keyword-efficiency
  a curric:Keyword ;
  schema:name "efficiency"@en ;
  schema:description """energy efficiency means using technology that needs less energy to perform the same task"""@en ;
  dcterms:modified "2026-02-12T08:59:15.791330Z"^^xsd:dateTime .

oakcurric:keyword-conservation
  a curric:Keyword ;
  schema:name "conservation"@en ;
  schema:description """energy conservation involves changing people's behaviour in ways that mean they use less energy"""@en ;
  dcterms:modified "2026-02-12T08:59:15.791334Z"^^xsd:dateTime .

oakcurric:keyword-biomass
  a curric:Keyword ;
  schema:name "biomass"@en ;
  schema:description """organic matter, from plants or animals, used as a fuel source to produce energy. A biofuel is biomass converted into a liquid or gas fuel which can be used in place of oil and natural gas"""@en ;
  dcterms:modified "2026-02-12T08:59:15.791424Z"^^xsd:dateTime .

oakcurric:keyword-urbanisation
  a curric:Keyword ;
  schema:name "urbanisation"@en ;
  schema:description "the process of making an area more urban"@en ;
