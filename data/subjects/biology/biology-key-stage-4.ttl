oakcurric:keylearningpoint-lesson-7986-2
  a curric:KeyLearningPoint ;
  rdfs:label "DNA is a polymer of four different nucleotides (A, C, G and T)."@en ;
  dcterms:modified "2026-02-12T08:59:21.630028Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7986-3
  a curric:KeyLearningPoint ;
  rdfs:label """Nucleotides in each strand of DNA pair up in a complementary way; A pairs with T, and C pairs with G."""@en ;
  dcterms:modified "2026-02-12T08:59:21.630040Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7986-4
  a curric:KeyLearningPoint ;
  rdfs:label """The DNA in chromosomes is unwound & copied during interphase, then the copies separate and the cell divides by mitosis."""@en ;
  dcterms:modified "2026-02-12T08:59:21.630048Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7986-5
  a curric:KeyLearningPoint ;
  rdfs:label """Complementary base pairing allows an exact copy of each ‘unzipped’ DNA strand to be made from free nucleotides."""@en ;
  dcterms:modified "2026-02-12T08:59:21.630053Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6294-1
  a curric:KeyLearningPoint ;
  rdfs:label """Abiotic factors such as light levels, temperature, soil moisture and pH can be measured."""@en ;
  dcterms:modified "2026-02-12T08:59:21.630058Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6294-2
  a curric:KeyLearningPoint ;
  rdfs:label """Transects can be used to investigate the effects of a changing factor on the distribution and abundance of organisms."""@en ;
  dcterms:modified "2026-02-12T08:59:21.630062Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6294-3
  a curric:KeyLearningPoint ;
  rdfs:label """A transect can be placed along a gradient of a factor (e.g. from shade to full sunlight)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.630067Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6294-4
  a curric:KeyLearningPoint ;
  rdfs:label """A belt transect uses quadrats placed along the straight line to measure distribution and abundance."""@en ;
  dcterms:modified "2026-02-12T08:59:21.630072Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8102-1
  a curric:KeyLearningPoint ;
  rdfs:label """Cancer is caused by uncontrolled cell growth and division which can lead to the formation of tumours."""@en ;
  dcterms:modified "2026-02-12T08:59:21.630095Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8102-2
  a curric:KeyLearningPoint ;
  rdfs:label """Benign tumours are usually contained within one area and do not invade surrounding tissues."""@en ;
  dcterms:modified "2026-02-12T08:59:21.630100Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8102-3
  a curric:KeyLearningPoint ;
  rdfs:label """Malignant tumours are cancerous, they invade surrounding tissues and can cause secondary tumours."""@en ;
  dcterms:modified "2026-02-12T08:59:21.630109Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8102-4
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists have identified lifestyle and genetic factors that can increase the risk of developing cancer."""@en ;
  dcterms:modified "2026-02-12T08:59:21.630114Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8102-5
  a curric:KeyLearningPoint ;
  rdfs:label """Mutations can cause changes in DNA; this alters the nucleotide sequence and genetic code"""@en ;
  dcterms:modified "2026-02-12T08:59:21.630148Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6295-1
  a curric:KeyLearningPoint ;
  rdfs:label """Organisms compete for resources such as food, water, space, shelter, light, mates, pollinators and seed dispersers."""@en ;
  dcterms:modified "2026-02-12T08:59:21.630181Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6295-2
  a curric:KeyLearningPoint ;
  rdfs:label """The populations of species within a community are interdependent (they rely upon and affect one another)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.630186Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6295-3
  a curric:KeyLearningPoint ;
  rdfs:label """Organisms have adaptations that help them survive and compete in their environment."""@en ;
  dcterms:modified "2026-02-12T08:59:21.630191Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6295-4
  a curric:KeyLearningPoint ;
  rdfs:label "Adaptations can be physiological, structural or behavioural."@en ;
  dcterms:modified "2026-02-12T08:59:21.630195Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6295-5
  a curric:KeyLearningPoint ;
  rdfs:label """Extremophiles are adapted to live in extreme environments, e.g. high salt concentration or very high or low temperature."""@en ;
  dcterms:modified "2026-02-12T08:59:21.630200Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6296-1
  a curric:KeyLearningPoint ;
  rdfs:label """Microorganisms and detritivores (detritus feeders) are responsible for the decomposition of plant and animal material."""@en ;
  dcterms:modified "2026-02-12T08:59:21.632204Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6296-2
  a curric:KeyLearningPoint ;
  rdfs:label "Decay is needed to keep nutrients cycling around an ecosystem."@en ;
  dcterms:modified "2026-02-12T08:59:21.632209Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6296-3
  a curric:KeyLearningPoint ;
  rdfs:label "Compost is made out of decomposed plant and animal material."@en ;
  dcterms:modified "2026-02-12T08:59:21.632213Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6296-4
  a curric:KeyLearningPoint ;
  rdfs:label "Biogas is produced when waste material is anaerobically digested."@en ;
  dcterms:modified "2026-02-12T08:59:21.632218Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6296-5
  a curric:KeyLearningPoint ;
  rdfs:label "Biogas contains methane which can be harvested and used as a fuel."@en ;
  dcterms:modified "2026-02-12T08:59:21.632223Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6396-1
  a curric:KeyLearningPoint ;
  rdfs:label "Scientists develop theories to explain how the natural world works"@en ;
  dcterms:modified "2026-02-12T08:59:21.632228Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6396-2
  a curric:KeyLearningPoint ;
  rdfs:label """Darwin and Wallace collected evidence that helped them to develop the theory of evolution by natural selection"""@en ;
  dcterms:modified "2026-02-12T08:59:21.632232Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6396-3
  a curric:KeyLearningPoint ;
  rdfs:label """The theory was not widely accepted at first, in part because it did not explain how heritable traits were passed on"""@en ;
  dcterms:modified "2026-02-12T08:59:21.632237Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6396-4
  a curric:KeyLearningPoint ;
  rdfs:label """Many scientists contributed to wider acceptance of the theory of evolution by natural selection by investigating DNA"""@en ;
  dcterms:modified "2026-02-12T08:59:21.632241Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6396-5
  a curric:KeyLearningPoint ;
  rdfs:label """These scientists discovered DNA and demonstrated its significance as the mechanism for inheritance of traits"""@en ;
  dcterms:modified "2026-02-12T08:59:21.632246Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6292-1
  a curric:KeyLearningPoint ;
  rdfs:label "Ecosystems contain biotic and abiotic components."@en ;
  dcterms:modified "2026-02-12T08:59:21.633177Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6292-2
  a curric:KeyLearningPoint ;
  rdfs:label """Changes in biotic and abiotic factors will affect communities within an ecosystem."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633181Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6292-3
  a curric:KeyLearningPoint ;
  rdfs:label "Predators are consumers that eat prey."@en ;
  dcterms:modified "2026-02-12T08:59:21.633186Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6292-4
  a curric:KeyLearningPoint ;
  rdfs:label """The population sizes of predators and prey increase and decrease in predator-prey cycles."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633191Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7988-1
  a curric:KeyLearningPoint ;
  rdfs:label """Most cells in multicellular organisms are specialised – they have structures that are adapted for the jobs the cells."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633222Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7988-2
  a curric:KeyLearningPoint ;
  rdfs:label """Multicellular organisms grow (make new cells by mitosis) and develop (make specialised cells to form tissues/organs)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633227Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7988-3
  a curric:KeyLearningPoint ;
  rdfs:label "Unspecialised cells become specialised through a process called differentiation."@en ;
  dcterms:modified "2026-02-12T08:59:21.633232Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7988-4
  a curric:KeyLearningPoint ;
  rdfs:label """During differentiation, particular genes in the cell’s genome are switched off or on."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633237Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7988-5
  a curric:KeyLearningPoint ;
  rdfs:label """Specialised cells only use particular genes, so only make the proteins needed for the job they are adapted to do."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633241Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6397-1
  a curric:KeyLearningPoint ;
  rdfs:label """The theory of evolution by natural selection suggests that all modern species evolved from earlier species."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633390Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6397-2
  a curric:KeyLearningPoint ;
  rdfs:label """Natural selection causes each generation of a species to become better adapted to its environment."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633399Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6397-3
  a curric:KeyLearningPoint ;
  rdfs:label """Natural selection can cause common features of a population to change so much that we classify them as a new species."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633404Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6397-4
  a curric:KeyLearningPoint ;
  rdfs:label """Populations of the same species living in different conditions can evolve to become separate species."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633409Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6397-5
  a curric:KeyLearningPoint ;
  rdfs:label """An example of speciation of populations living in different conditions (e.g. Galápagos tortoises)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633414Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6393-1
  a curric:KeyLearningPoint ;
  rdfs:label """The fossil record includes species that appear to be the common ancestor of numerous later species."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633506Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6393-2
  a curric:KeyLearningPoint ;
  rdfs:label """Evolutionary trees can be used to help visualise the relationships between groups of organisms."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633511Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6393-3
  a curric:KeyLearningPoint ;
  rdfs:label """The fossil record includes transitional species with features of both evolutionary ancestors and modern species."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633515Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6393-4
  a curric:KeyLearningPoint ;
  rdfs:label """A case study of an example of a transitional species (e.g. Archaeopteryx, which links dinosaurs and modern birds)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633520Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6393-5
  a curric:KeyLearningPoint ;
  rdfs:label """There are gaps in the fossil record, e.g. ‘missing links’ between evolutionary ancestors and modern species."""@en ;
  dcterms:modified "2026-02-12T08:59:21.633524Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8101-1
  a curric:KeyLearningPoint ;
  rdfs:label """Cancer is caused by uncontrolled cell growth and division which can lead to the formation of tumours."""@en ;
  dcterms:modified "2026-02-12T08:59:21.634595Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8101-2
  a curric:KeyLearningPoint ;
  rdfs:label "Not all tumours are cancerous; they can be benign or malignant."@en ;
  dcterms:modified "2026-02-12T08:59:21.634602Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8101-3
  a curric:KeyLearningPoint ;
  rdfs:label """Benign tumours are usually contained within one area and do not invade surrounding tissues."""@en ;
  dcterms:modified "2026-02-12T08:59:21.634607Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8101-4
  a curric:KeyLearningPoint ;
  rdfs:label """Malignant tumours are cancerous, they invade surrounding tissues and can cause secondary tumours."""@en ;
  dcterms:modified "2026-02-12T08:59:21.634614Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8101-5
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists have identified lifestyle and genetic factors that can increase the risk of developing cancer."""@en ;
  dcterms:modified "2026-02-12T08:59:21.634619Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6392-1
  a curric:KeyLearningPoint ;
  rdfs:label """The fossil record is made up of millions of fossils aged from 10,000 to billions of years old."""@en ;
  dcterms:modified "2026-02-12T08:59:21.634624Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6392-2
  a curric:KeyLearningPoint ;
  rdfs:label "Fossils show that some species have gone extinct."@en ;
  dcterms:modified "2026-02-12T08:59:21.634629Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6392-3
  a curric:KeyLearningPoint ;
  rdfs:label "Fossils show that the features of some species have changed (evolved) over time."@en ;
  dcterms:modified "2026-02-12T08:59:21.634633Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6392-4
  a curric:KeyLearningPoint ;
  rdfs:label """An example of a series of fossils showing changes from evolutionary ancestors to modern species (e.g. whales)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.634638Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8104-1
  a curric:KeyLearningPoint ;
  rdfs:label """Embryonic and adult stem cells can be used in treatments to make new specialised cells to replace damaged ones."""@en ;
  dcterms:modified "2026-02-12T08:59:21.634694Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8104-2
  a curric:KeyLearningPoint ;
  rdfs:label """Examples include using stem cells to treat type 1 diabetes and bone marrow transplants for leukaemia."""@en ;
  dcterms:modified "2026-02-12T08:59:21.634699Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8104-3
  a curric:KeyLearningPoint ;
  rdfs:label """Transplanting stem cells into a patient has risks (e.g. immune rejection, cancer from uncontrolled division, infection)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.634706Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8104-4
  a curric:KeyLearningPoint ;
  rdfs:label "Ethical objections to harvesting embryos as a source of embryonic stem cells."@en ;
  dcterms:modified "2026-02-12T08:59:21.634711Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8104-5
  a curric:KeyLearningPoint ;
  rdfs:label "Debating benefits versus risks and ethical issues."@en ;
  dcterms:modified "2026-02-12T08:59:21.634716Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7989-1
  a curric:KeyLearningPoint ;
  rdfs:label """An early animal embryo is made of unspecialised cells; these are embryonic stem cells."""@en ;
  dcterms:modified "2026-02-12T08:59:21.634768Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7989-2
  a curric:KeyLearningPoint ;
  rdfs:label """Embryonic stem cells can differentiate to become all types of cells in the animal’s body."""@en ;
  dcterms:modified "2026-02-12T08:59:21.634773Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7989-3
  a curric:KeyLearningPoint ;
  rdfs:label """As an animal develops into an adult, some cells remain unspecialised; these are adult stem cells."""@en ;
  dcterms:modified "2026-02-12T08:59:21.634778Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7989-4
  a curric:KeyLearningPoint ;
  rdfs:label """Adult stem cells can differentiate to become most but not all types of cells in the animal’s body."""@en ;
  dcterms:modified "2026-02-12T08:59:21.634783Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7989-5
  a curric:KeyLearningPoint ;
  rdfs:label """An example of adult stem cells in humans (e.g. in bone marrow; these can divide and differentiate to make blood cells)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.634788Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6293-1
  a curric:KeyLearningPoint ;
  rdfs:label "Quadrats can be used to sample an area to estimate population size (abundance)."@en ;
  dcterms:modified "2026-02-12T08:59:21.635603Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6293-2
  a curric:KeyLearningPoint ;
  rdfs:label "Quadrats are used to sample plants and small, slow-moving animals."@en ;
  dcterms:modified "2026-02-12T08:59:21.635610Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6293-3
  a curric:KeyLearningPoint ;
  rdfs:label "Quadrats can be placed at random to help avoid bias."@en ;
  dcterms:modified "2026-02-12T08:59:21.635615Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6293-4
  a curric:KeyLearningPoint ;
  rdfs:label "Using quadrats to estimate population size (species abundance) in an area."@en ;
  dcterms:modified "2026-02-12T08:59:21.635619Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6293-5
  a curric:KeyLearningPoint ;
  rdfs:label """Using quadrats to investigate the population size of a plant species using random sampling."""@en ;
  dcterms:modified "2026-02-12T08:59:21.635624Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6394-1
  a curric:KeyLearningPoint ;
  rdfs:label """Some plants and animals have features that are useful to us (e.g. they can provide food and materials, or do work)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.636168Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6394-2
  a curric:KeyLearningPoint ;
  rdfs:label """Selective breeding by humans causes particular features to become more (or less) common in the species."""@en ;
  dcterms:modified "2026-02-12T08:59:21.636173Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6394-3
  a curric:KeyLearningPoint ;
  rdfs:label """After many generations, the resulting domesticated species can be quite different to their wild ancestors."""@en ;
  dcterms:modified "2026-02-12T08:59:21.636178Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6394-4
  a curric:KeyLearningPoint ;
  rdfs:label """Examples of the selective breeding of a farm animal and a crop from their wild ancestors."""@en ;
  dcterms:modified "2026-02-12T08:59:21.636182Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6394-5
  a curric:KeyLearningPoint ;
  rdfs:label "The dependence of humans on domesticated animals and crops for food security."@en ;
  dcterms:modified "2026-02-12T08:59:21.636187Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7990-1
  a curric:KeyLearningPoint ;
  rdfs:label """Plants have unspecialised cells called meristem cells, which are located in the stem and the tips of roots and shoots."""@en ;
  dcterms:modified "2026-02-12T08:59:21.637140Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7990-2
  a curric:KeyLearningPoint ;
  rdfs:label """Meristem cells in roots and shoots divide and differentiate to enable roots and shoots to grow longer and wider."""@en ;
  dcterms:modified "2026-02-12T08:59:21.637145Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7990-3
  a curric:KeyLearningPoint ;
  rdfs:label """Meristem cells in the shoots also divide and differentiate to make leaves and flowers."""@en ;
  dcterms:modified "2026-02-12T08:59:21.637150Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7990-4
  a curric:KeyLearningPoint ;
  rdfs:label """Meristem cells in the stem and roots also divide and differentiate to make tissues such as xylem and phloem."""@en ;
  dcterms:modified "2026-02-12T08:59:21.637154Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7990-5
  a curric:KeyLearningPoint ;
  rdfs:label """Meristem tissue can be used to produce clones for crops or to protect endangered species."""@en ;
  dcterms:modified "2026-02-12T08:59:21.637159Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8103-1
  a curric:KeyLearningPoint ;
  rdfs:label """Reproduction is part of the life cycle of all organisms; sexual reproduction requires specialised cells called gametes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.637239Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8103-2
  a curric:KeyLearningPoint ;
  rdfs:label "Gametes are made from body cells by a type of cell division called meiosis."@en ;
  dcterms:modified "2026-02-12T08:59:21.637244Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8103-3
  a curric:KeyLearningPoint ;
  rdfs:label """During interphase the chromosomes are copied; meiosis follows this and includes two rounds of cell division."""@en ;
  dcterms:modified "2026-02-12T08:59:21.637248Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8103-4
  a curric:KeyLearningPoint ;
  rdfs:label """The gametes made by meiosis have half the usual number of chromosomes (one from each pair in the original body cell)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.637253Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8103-5
  a curric:KeyLearningPoint ;
  rdfs:label """Mitosis produces 2 genetically identical diploid cells, whereas meiosis produces 4 genetically different haploid cells."""@en ;
  dcterms:modified "2026-02-12T08:59:21.637258Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7985-1
  a curric:KeyLearningPoint ;
  rdfs:label """A light microscope can be used to observe plant cells in different stages of mitosis (e.g. from onion root tip)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638645Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7985-2
  a curric:KeyLearningPoint ;
  rdfs:label "The parts of a light microscope and their functions."@en ;
  dcterms:modified "2026-02-12T08:59:21.638650Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7985-3
  a curric:KeyLearningPoint ;
  rdfs:label """The sequence of steps for setting up a light microscope to observe cells, including changing the magnification  & focus."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638658Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7985-4
  a curric:KeyLearningPoint ;
  rdfs:label """Explaining observations from microscopy using ideas about what happens during stages of the cell cycle."""@en ;
  dcterms:modified "2026-02-12T08:59:21.638663Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28972-1
  a curric:KeyLearningPoint ;
  rdfs:label """Variation within a species may affect how well different individuals can survive when environmental conditions change"""@en ;
  dcterms:modified "2026-02-12T08:59:21.640971Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28972-2
  a curric:KeyLearningPoint ;
  rdfs:label """This leads to natural selection, favouring individuals better adapted to survive and reproduce in the new conditions"""@en ;
  dcterms:modified "2026-02-12T08:59:21.640976Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28972-3
  a curric:KeyLearningPoint ;
  rdfs:label """Climate change could result in natural selection of individuals that are more tolerant of drought and high temperatures"""@en ;
  dcterms:modified "2026-02-12T08:59:21.640981Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28972-4
  a curric:KeyLearningPoint ;
  rdfs:label """Some species may not evolve quickly enough to keep up with climate change and could become extinct"""@en ;
  dcterms:modified "2026-02-12T08:59:21.640986Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28972-5
  a curric:KeyLearningPoint ;
  rdfs:label """Humans can use various methods to help protect against species loss due to climate change, e.g. selective breeding"""@en ;
  dcterms:modified "2026-02-12T08:59:21.640991Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27994-1
  a curric:KeyLearningPoint ;
  rdfs:label """Process data and plot a graph of appropriate results to identify and describe patterns or trends in the results."""@en ;
  dcterms:modified "2026-02-12T08:59:21.641375Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27994-2
  a curric:KeyLearningPoint ;
  rdfs:label """Explaining the results using ideas about the requirement of light for photosynthesis."""@en ;
  dcterms:modified "2026-02-12T08:59:21.641379Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27994-3
  a curric:KeyLearningPoint ;
  rdfs:label """Identifying sources of systematic and random error that could affect the accuracy of the measurements."""@en ;
  dcterms:modified "2026-02-12T08:59:21.641384Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27994-4
  a curric:KeyLearningPoint ;
  rdfs:label """Suggesting improvements (e.g. ways to measure the amount of gas more accurately)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.641391Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27994-5
  a curric:KeyLearningPoint ;
  rdfs:label "Evaluating the precision, repeatability and reproducibility of the results."@en ;
  dcterms:modified "2026-02-12T08:59:21.641398Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7935-1
  a curric:KeyLearningPoint ;
  rdfs:label "Light waves spread out as they travel from a light source."@en ;
  dcterms:modified "2026-02-12T08:59:21.642785Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7935-2
  a curric:KeyLearningPoint ;
  rdfs:label """Further away from the light source, the same amount of light is spread out over a greater area."""@en ;
  dcterms:modified "2026-02-12T08:59:21.642790Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7935-3
  a curric:KeyLearningPoint ;
  rdfs:label """This means the light intensity decreases with increasing distance from a light source."""@en ;
  dcterms:modified "2026-02-12T08:59:21.642795Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7935-4
  a curric:KeyLearningPoint ;
  rdfs:label """Light intensity is inversely proportional to the square of the distance from a light source (inverse square law)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.642799Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6384-1
  a curric:KeyLearningPoint ;
  rdfs:label """Increasing human population size requires increased land use for resources (including food and fuels) and urbanisation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643892Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6384-2
  a curric:KeyLearningPoint ;
  rdfs:label """Increased land use by humans leads to habitat destruction, e.g. deforestation and biodiversity loss."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643896Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6384-3
  a curric:KeyLearningPoint ;
  rdfs:label """Increasing human population size increases production of waste and pollution, leading to biodiversity loss."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643901Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6384-4
  a curric:KeyLearningPoint ;
  rdfs:label """Release of greenhouse gases contributes to climate change, including global warming, leading to biodiversity loss."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643906Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6384-5
  a curric:KeyLearningPoint ;
  rdfs:label """There is very strong evidence linking human release of greenhouse gases to global climate change."""@en ;
  dcterms:modified "2026-02-12T08:59:21.643910Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27586-1
  a curric:KeyLearningPoint ;
  rdfs:label """Growing food helps feed the increasing human population, but can have negative impacts on ecosystems and biodiversity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.644812Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27586-2
  a curric:KeyLearningPoint ;
  rdfs:label "Fish farming and animal welfare as examples of positive and negative impacts."@en ;
  dcterms:modified "2026-02-12T08:59:21.644819Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27586-3
  a curric:KeyLearningPoint ;
  rdfs:label "Eutrophication as an example of a negative impact."@en ;
  dcterms:modified "2026-02-12T08:59:21.644825Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27586-4
  a curric:KeyLearningPoint ;
  rdfs:label "The introduction of non-indigenous species as an example of a negative impact."@en ;
  dcterms:modified "2026-02-12T08:59:21.644829Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27586-5
  a curric:KeyLearningPoint ;
  rdfs:label "Ways of mitigating some of these negative impacts."@en ;
  dcterms:modified "2026-02-12T08:59:21.644834Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20445-1
  a curric:KeyLearningPoint ;
  rdfs:label """Most cells in multicellular organisms go through different phases that are part of a cell cycle."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648562Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20445-2
  a curric:KeyLearningPoint ;
  rdfs:label "The main phases of the cell cycle are interphase and mitosis."@en ;
  dcterms:modified "2026-02-12T08:59:21.648569Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20445-3
  a curric:KeyLearningPoint ;
  rdfs:label """During cell interphase, each chromosome is copied, sub-cellular structures are copied."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648574Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20445-4
  a curric:KeyLearningPoint ;
  rdfs:label """The stages of mitosis are prophase, metaphase, anaphase, telophase and cytokinesis."""@en ;
  dcterms:modified "2026-02-12T08:59:21.648579Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20446-1
  a curric:KeyLearningPoint ;
  rdfs:label """A light microscope can be used to observe plant cells in different stages of mitosis (e.g. from onion root tip)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.651318Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20446-2
  a curric:KeyLearningPoint ;
  rdfs:label "The parts of a light microscope and their functions."@en ;
  dcterms:modified "2026-02-12T08:59:21.651323Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20446-3
  a curric:KeyLearningPoint ;
  rdfs:label """The sequence of steps to set up a light microscope to observe cells, including changing the magnification and focus."""@en ;
  dcterms:modified "2026-02-12T08:59:21.651327Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20446-4
  a curric:KeyLearningPoint ;
  rdfs:label """Explaining observations from microscopy using ideas about what happens during the cell cycle (including PMAT)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.651332Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5554-1
  a curric:KeyLearningPoint ;
  rdfs:label """The rate of a reaction is the amount of change (e.g. substrate broken down or product made) per unit of time."""@en ;
  dcterms:modified "2026-02-12T08:59:21.653602Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5554-2
  a curric:KeyLearningPoint ;
  rdfs:label """Enzyme reaction rate increases as substrate concentration increases, until an optimum when all active sites are full."""@en ;
  dcterms:modified "2026-02-12T08:59:21.653607Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5554-3
  a curric:KeyLearningPoint ;
  rdfs:label """Enzyme reaction rate increases with temperature due to more collisions, until an optimum when all active sites are full."""@en ;
  dcterms:modified "2026-02-12T08:59:21.653611Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5554-4
  a curric:KeyLearningPoint ;
  rdfs:label """Enzyme reaction rate decreases as temperature increases above the optimum, as the active site becomes denatured."""@en ;
  dcterms:modified "2026-02-12T08:59:21.653616Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5554-5
  a curric:KeyLearningPoint ;
  rdfs:label """Interpretation of graphs showing effects of substrate concentration and temperature on enzyme reaction rate."""@en ;
  dcterms:modified "2026-02-12T08:59:21.653620Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9159-1
  a curric:KeyLearningPoint ;
  rdfs:label "The animal cell model describes the common structures of animal cells."@en ;
  dcterms:modified "2026-02-12T08:59:21.653625Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9159-2
  a curric:KeyLearningPoint ;
  rdfs:label """These structures include the cytoplasm, cell membrane, nucleus and mitochondria. Each structure has a specific function."""@en ;
  dcterms:modified "2026-02-12T08:59:21.653632Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9159-3
  a curric:KeyLearningPoint ;
  rdfs:label """Specialised cells in animals have shapes, sizes and structures that are adapted for the jobs the cells do."""@en ;
  dcterms:modified "2026-02-12T08:59:21.653636Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9159-4
  a curric:KeyLearningPoint ;
  rdfs:label "Examples of specialised animal cells include blood cells and nerve cells."@en ;
  dcterms:modified "2026-02-12T08:59:21.653641Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27993-1
  a curric:KeyLearningPoint ;
  rdfs:label """Following an appropriate method to vary light intensity and measure the gas given off"""@en ;
  dcterms:modified "2026-02-12T08:59:21.653648Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27993-2
  a curric:KeyLearningPoint ;
  rdfs:label """Accurate measurement of variables (distance, time, amount of gas) and control of variables that might affect the results"""@en ;
  dcterms:modified "2026-02-12T08:59:21.653653Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27993-3
  a curric:KeyLearningPoint ;
  rdfs:label "Counting bubbles and measuring volume of gas given off"@en ;
  dcterms:modified "2026-02-12T08:59:21.653658Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27993-4
  a curric:KeyLearningPoint ;
  rdfs:label "Record results in an appropriate table"@en ;
  dcterms:modified "2026-02-12T08:59:21.653663Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9160-1
  a curric:KeyLearningPoint ;
  rdfs:label "The plant cell model describes the common structures of plant cells."@en ;
  dcterms:modified "2026-02-12T08:59:21.653667Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9160-2
  a curric:KeyLearningPoint ;
  rdfs:label """Some of these structures are common with animal cells, such as the cytoplasm, cell membrane, nucleus and mitochondria."""@en ;
  dcterms:modified "2026-02-12T08:59:21.653672Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9160-3
  a curric:KeyLearningPoint ;
  rdfs:label """Plant cells have additional structures, i.e. the cell wall, chloroplasts and vacuole; each has a specific function."""@en ;
  dcterms:modified "2026-02-12T08:59:21.653676Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9160-4
  a curric:KeyLearningPoint ;
  rdfs:label """Specialised cells in plants have shapes, sizes and structures that are adapted for the jobs the cells do."""@en ;
  dcterms:modified "2026-02-12T08:59:21.653681Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9160-5
  a curric:KeyLearningPoint ;
  rdfs:label "Examples of specialised plant cells include root hair cells and palisade cells."@en ;
  dcterms:modified "2026-02-12T08:59:21.653685Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7975-1
  a curric:KeyLearningPoint ;
  rdfs:label """The sequence of nucleotides in a gene is a template for assembling proteins from amino acids in a particular order."""@en ;
  dcterms:modified "2026-02-12T08:59:21.654147Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7975-2
  a curric:KeyLearningPoint ;
  rdfs:label """To make a protein, a copy of a gene is made to form messenger RNA (mRNA) in the nucleus."""@en ;
  dcterms:modified "2026-02-12T08:59:21.654151Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7975-3
  a curric:KeyLearningPoint ;
  rdfs:label "The mRNA leaves the nucleus and moves to a ribosome in the cytoplasm."@en ;
  dcterms:modified "2026-02-12T08:59:21.654161Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7975-4
  a curric:KeyLearningPoint ;
  rdfs:label "Transfer molecules (tRNA) carry specific amino acids to the ribosome."@en ;
  dcterms:modified "2026-02-12T08:59:21.654165Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7975-5
  a curric:KeyLearningPoint ;
  rdfs:label """The ribosome joins amino acids in an order determined by the sequence of triplet codes in the mRNA."""@en ;
  dcterms:modified "2026-02-12T08:59:21.654170Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5600-1
  a curric:KeyLearningPoint ;
  rdfs:label """Effect of temperature on aerobic cellular respiration investigated in small living organisms (e.g. germinating peas)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.654174Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5600-2
  a curric:KeyLearningPoint ;
  rdfs:label """The oxygen used by the respiring organisms in a set time can be measured using a simple respirometer."""@en ;
  dcterms:modified "2026-02-12T08:59:21.654182Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5600-3
  a curric:KeyLearningPoint ;
  rdfs:label """Identifying independent and dependent variables, and variables to control to increase the validity of the results."""@en ;
  dcterms:modified "2026-02-12T08:59:21.654186Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5600-4
  a curric:KeyLearningPoint ;
  rdfs:label """The height of coloured liquid in the capillary tube of the respirometer is measured at the start & end of the set time."""@en ;
  dcterms:modified "2026-02-12T08:59:21.654191Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5600-5
  a curric:KeyLearningPoint ;
  rdfs:label """Collecting repeat measurements at each temperature, and collecting data at different temperatures."""@en ;
  dcterms:modified "2026-02-12T08:59:21.654195Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7976-1
  a curric:KeyLearningPoint ;
  rdfs:label """A change in the sequence of nucleotide bases in the DNA of the genome is called a mutation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.655385Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7976-2
  a curric:KeyLearningPoint ;
  rdfs:label "Mutations can be caused by some substances and by ionising radiation."@en ;
  dcterms:modified "2026-02-12T08:59:21.655390Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7976-3
  a curric:KeyLearningPoint ;
  rdfs:label """Most mutations are caused by errors when DNA is copied, when cells divide to make new cells."""@en ;
  dcterms:modified "2026-02-12T08:59:21.655394Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7976-4
  a curric:KeyLearningPoint ;
  rdfs:label """How substitution, insertion and deletion mutations change the base sequence in DNA."""@en ;
  dcterms:modified "2026-02-12T08:59:21.655399Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7976-5
  a curric:KeyLearningPoint ;
  rdfs:label """A mutation creates a genetic variant (a region of DNA in which the sequence of nucleotide bases has been changed)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.655403Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6298-1
  a curric:KeyLearningPoint ;
  rdfs:label "Carbon is found in the atmosphere as carbon dioxide."@en ;
  dcterms:modified "2026-02-12T08:59:21.655408Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6298-2
  a curric:KeyLearningPoint ;
  rdfs:label """The carbon cycle shows how carbon is recycled between organisms and the atmosphere."""@en ;
  dcterms:modified "2026-02-12T08:59:21.655412Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6298-3
  a curric:KeyLearningPoint ;
  rdfs:label """Carbon dioxide can be removed from the atmosphere by plants, who use it during the process of photosynthesis."""@en ;
  dcterms:modified "2026-02-12T08:59:21.655417Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6298-4
  a curric:KeyLearningPoint ;
  rdfs:label """Carbon is returned to the atmosphere by the burning of fossil fuels and the decay of dead plant and animal material."""@en ;
  dcterms:modified "2026-02-12T08:59:21.655421Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5556-1
  a curric:KeyLearningPoint ;
  rdfs:label "Safe use of materials and apparatus."@en ;
  dcterms:modified "2026-02-12T08:59:21.655775Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5556-2
  a curric:KeyLearningPoint ;
  rdfs:label "Accurate measurement of reactants and reagents."@en ;
  dcterms:modified "2026-02-12T08:59:21.655780Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5556-3
  a curric:KeyLearningPoint ;
  rdfs:label "Control of temperature using a water bath or electric heater."@en ;
  dcterms:modified "2026-02-12T08:59:21.655784Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5556-4
  a curric:KeyLearningPoint ;
  rdfs:label """Continuous sampling of reaction mixture and testing with iodine for the presence of starch."""@en ;
  dcterms:modified "2026-02-12T08:59:21.655789Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5556-5
  a curric:KeyLearningPoint ;
  rdfs:label "Sampling at accurately timed intervals."@en ;
  dcterms:modified "2026-02-12T08:59:21.655793Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5606-1
  a curric:KeyLearningPoint ;
  rdfs:label """Plotting and interpretation of a graph showing the effect of sugar concentration on the mass of potato tissue."""@en ;
  dcterms:modified "2026-02-12T08:59:21.655798Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5606-2
  a curric:KeyLearningPoint ;
  rdfs:label """Increase in potato mass means water moved in by osmosis (because the sugar solution was more dilute outside)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.655805Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5606-3
  a curric:KeyLearningPoint ;
  rdfs:label """Decrease in potato mass means water moved out by osmosis (because the sugar solution was more concentrated outside)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.655810Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5606-4
  a curric:KeyLearningPoint ;
  rdfs:label """The concentration of sugar in the potato tissue can be determined from the point at which there was no change in mass."""@en ;
  dcterms:modified "2026-02-12T08:59:21.655817Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5606-5
  a curric:KeyLearningPoint ;
  rdfs:label """At this point the sugar concentration was equal inside and out, so there was no net movement of water."""@en ;
  dcterms:modified "2026-02-12T08:59:21.655822Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7972-1
  a curric:KeyLearningPoint ;
  rdfs:label "DNA is a type of biological molecule called a nucleic acid."@en ;
  dcterms:modified "2026-02-12T08:59:21.657830Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7972-2
  a curric:KeyLearningPoint ;
  rdfs:label """DNA is made of two strands, each a long polymer of nucleotides, wound together in a double helix shape."""@en ;
  dcterms:modified "2026-02-12T08:59:21.657837Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7972-3
  a curric:KeyLearningPoint ;
  rdfs:label "DNA is a polymer of four different nucleotides (A, C, G and T)."@en ;
  dcterms:modified "2026-02-12T08:59:21.657845Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7972-4
  a curric:KeyLearningPoint ;
  rdfs:label """Each of the four types of nucleotide in DNA is made of the same sugar and a phosphate group, bonded to a different base."""@en ;
  dcterms:modified "2026-02-12T08:59:21.657849Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7972-5
  a curric:KeyLearningPoint ;
  rdfs:label """Nucleotides in each strand of DNA pair up in a complementary way; A pairs with T, and C pairs with G."""@en ;
  dcterms:modified "2026-02-12T08:59:21.657854Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5557-1
  a curric:KeyLearningPoint ;
  rdfs:label """Interpretation of graphs showing data from an investigation of the effect of pH on the rate of an enzyme reaction."""@en ;
  dcterms:modified "2026-02-12T08:59:21.657859Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5557-2
  a curric:KeyLearningPoint ;
  rdfs:label """Consideration of whether the data increase or decrease confidence in the original prediction or hypothesis."""@en ;
  dcterms:modified "2026-02-12T08:59:21.657863Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5557-3
  a curric:KeyLearningPoint ;
  rdfs:label """Enzyme reaction rate is highest at an optimum pH, at which all active sites are full."""@en ;
  dcterms:modified "2026-02-12T08:59:21.657868Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5557-4
  a curric:KeyLearningPoint ;
  rdfs:label """Enzyme reaction rate decreases at pH values below and above the optimum as the active site becomes denatured."""@en ;
  dcterms:modified "2026-02-12T08:59:21.657872Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5601-1
  a curric:KeyLearningPoint ;
  rdfs:label """Living yeast cells immobilised in alginate beads will carry out cellular respiration and produce carbon dioxide gas."""@en ;
  dcterms:modified "2026-02-12T08:59:21.658512Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5601-2
  a curric:KeyLearningPoint ;
  rdfs:label """The gas can be collected and the volume of gas measured using an upturned measuring cylinder under water."""@en ;
  dcterms:modified "2026-02-12T08:59:21.658519Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5601-3
  a curric:KeyLearningPoint ;
  rdfs:label """Identifying independent and dependent variables, and variables to control to increase the validity of the results."""@en ;
  dcterms:modified "2026-02-12T08:59:21.658524Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5601-4
  a curric:KeyLearningPoint ;
  rdfs:label """How to read the volume of gas from the meniscus in the measuring cylinder after a set time."""@en ;
  dcterms:modified "2026-02-12T08:59:21.658528Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5601-5
  a curric:KeyLearningPoint ;
  rdfs:label """Collecting repeat measurements for each substrate, and collecting data for different substrates."""@en ;
  dcterms:modified "2026-02-12T08:59:21.658535Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9204-1
  a curric:KeyLearningPoint ;
  rdfs:label """Calculate the rate of respiration by dividing the distance moved up the capillary tube of a respirometer by the time."""@en ;
  dcterms:modified "2026-02-12T08:59:21.658540Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9204-2
  a curric:KeyLearningPoint ;
  rdfs:label "Use appropriate units for the rate of cellular respiration."@en ;
  dcterms:modified "2026-02-12T08:59:21.658545Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9204-3
  a curric:KeyLearningPoint ;
  rdfs:label "Compare the rate of respiration in small organisms at different temperatures."@en ;
  dcterms:modified "2026-02-12T08:59:21.658549Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9204-4
  a curric:KeyLearningPoint ;
  rdfs:label "Describe trends in the data."@en ;
  dcterms:modified "2026-02-12T08:59:21.658554Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9204-5
  a curric:KeyLearningPoint ;
  rdfs:label """Use ideas about enzymes and rate of chemical reactions to explain the effect of temperature on the rate of respiration."""@en ;
  dcterms:modified "2026-02-12T08:59:21.658558Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27996-1
  a curric:KeyLearningPoint ;
  rdfs:label """Following an appropriate method to vary light intensity and measure the colour change of indicator."""@en ;
  dcterms:modified "2026-02-12T08:59:21.658611Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27996-2
  a curric:KeyLearningPoint ;
  rdfs:label """Accurate measurement of variables (distance, time, colour change); control of variables that might affect the results."""@en ;
  dcterms:modified "2026-02-12T08:59:21.658616Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27996-3
  a curric:KeyLearningPoint ;
  rdfs:label "Comparison of indicator colour to a chart to determine pH."@en ;
  dcterms:modified "2026-02-12T08:59:21.658623Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27996-4
  a curric:KeyLearningPoint ;
  rdfs:label "Record results in an appropriate table."@en ;
  dcterms:modified "2026-02-12T08:59:21.658627Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5552-1
  a curric:KeyLearningPoint ;
  rdfs:label """All carbohydrates, proteins and lipids are made of the elements carbon, hydrogen and oxygen."""@en ;
  dcterms:modified "2026-02-12T08:59:21.658632Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5552-2
  a curric:KeyLearningPoint ;
  rdfs:label "All proteins and some lipids also contain the element nitrogen."@en ;
  dcterms:modified "2026-02-12T08:59:21.658637Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5552-3
  a curric:KeyLearningPoint ;
  rdfs:label """Producers obtain carbon and oxygen from the air, hydrogen from water, and nitrogen from the soil."""@en ;
  dcterms:modified "2026-02-12T08:59:21.658641Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5552-4
  a curric:KeyLearningPoint ;
  rdfs:label """Consumers cannot use carbon from carbon dioxide in air to make biological molecules; only producers can do that."""@en ;
  dcterms:modified "2026-02-12T08:59:21.658646Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5552-5
  a curric:KeyLearningPoint ;
  rdfs:label """Consumers absorb oxygen from the air but get all their carbon and nitrogen by eating producers."""@en ;
  dcterms:modified "2026-02-12T08:59:21.658651Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5586-1
  a curric:KeyLearningPoint ;
  rdfs:label """Water and mineral ions are transported from the roots, up the stem, to the leaves, in vessels made of xylem."""@en ;
  dcterms:modified "2026-02-12T08:59:21.658655Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5586-2
  a curric:KeyLearningPoint ;
  rdfs:label """Xylem is made of dead, empty cells with no cytoplasm, that form a tube with a tough wall made of lignin."""@en ;
  dcterms:modified "2026-02-12T08:59:21.658660Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5586-3
  a curric:KeyLearningPoint ;
  rdfs:label """Water is continually lost from the surface of a plant when water molecules diffuse into the air through open stomata."""@en ;
  dcterms:modified "2026-02-12T08:59:21.658664Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5586-4
  a curric:KeyLearningPoint ;
  rdfs:label """Water is pulled up through xylem tubes to replace the water lost through open stomata; this process is transpiration."""@en ;
  dcterms:modified "2026-02-12T08:59:21.658668Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5586-5
  a curric:KeyLearningPoint ;
  rdfs:label """The water that is pulled through xylem tubes has mineral ions dissolved in it, including nitrate ions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.658675Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27970-1
  a curric:KeyLearningPoint ;
  rdfs:label """Word and balanced symbol equations for anaerobic cellular respiration in humans, and conditions in which it occurs"""@en ;
  dcterms:modified "2026-02-12T08:59:21.658680Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27970-2
  a curric:KeyLearningPoint ;
  rdfs:label """Word and symbol equations for anaerobic respiration in plants and micro-organisms, and conditions in which it occurs"""@en ;
  dcterms:modified "2026-02-12T08:59:21.658685Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27970-3
  a curric:KeyLearningPoint ;
  rdfs:label """Anaerobic cellular respiration takes place only in the cell cytoplasm and does not involve mitochondria"""@en ;
  dcterms:modified "2026-02-12T08:59:21.658689Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27970-4
  a curric:KeyLearningPoint ;
  rdfs:label """Anaerobic cellular respiration provides less ATP (so less energy) than aerobic cellular respiration, but more quickly"""@en ;
  dcterms:modified "2026-02-12T08:59:21.658694Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27970-5
  a curric:KeyLearningPoint ;
  rdfs:label "Uses of anaerobic cellular respiration (fermentation) in yeast"@en ;
  dcterms:modified "2026-02-12T08:59:21.658698Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6387-1
  a curric:KeyLearningPoint ;
  rdfs:label "Benefits of high biodiversity, including ecosystem services and food security."@en ;
  dcterms:modified "2026-02-12T08:59:21.658770Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6387-2
  a curric:KeyLearningPoint ;
  rdfs:label """Humans can interact positively with ecosystems to prevent and reduce biodiversity loss."""@en ;
  dcterms:modified "2026-02-12T08:59:21.658775Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6387-3
  a curric:KeyLearningPoint ;
  rdfs:label """Resources can be used sustainably (e.g. at a rate at which they can be replaced)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.658781Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6387-4
  a curric:KeyLearningPoint ;
  rdfs:label """A range of conservation measures can be taken to protect biodiversity at the species, ecosystem and genetic levels."""@en ;
  dcterms:modified "2026-02-12T08:59:21.658786Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6387-5
  a curric:KeyLearningPoint ;
  rdfs:label "Conservation efforts range from very local actions to international ones."@en ;
  dcterms:modified "2026-02-12T08:59:21.658791Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9202-1
  a curric:KeyLearningPoint ;
  rdfs:label "Use an enzyme (e.g. lipase) to decompose milk."@en ;
  dcterms:modified "2026-02-12T08:59:21.658872Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9202-2
  a curric:KeyLearningPoint ;
  rdfs:label "Measure the change in pH as the milk is decomposed."@en ;
  dcterms:modified "2026-02-12T08:59:21.658876Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9202-3
  a curric:KeyLearningPoint ;
  rdfs:label "Estimate the rate of decomposition by measuring the change in pH."@en ;
  dcterms:modified "2026-02-12T08:59:21.658883Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9202-4
  a curric:KeyLearningPoint ;
  rdfs:label "Compare the rate of decomposition at different temperatures."@en ;
  dcterms:modified "2026-02-12T08:59:21.658890Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27585-1
  a curric:KeyLearningPoint ;
  rdfs:label """Growing food helps feed the increasing human population, but can have negative impacts on ecosystems and biodiversity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.658932Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27585-2
  a curric:KeyLearningPoint ;
  rdfs:label "The use of peat and destruction of peat bogs as an example of a negative impact."@en ;
  dcterms:modified "2026-02-12T08:59:21.658937Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27585-3
  a curric:KeyLearningPoint ;
  rdfs:label "Eutrophication as an example of a negative impact."@en ;
  dcterms:modified "2026-02-12T08:59:21.658941Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27585-4
  a curric:KeyLearningPoint ;
  rdfs:label "The introduction of non-indigenous species as an example of a negative impact."@en ;
  dcterms:modified "2026-02-12T08:59:21.658946Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27585-5
  a curric:KeyLearningPoint ;
  rdfs:label "Ways of mitigating some of these negative impacts."@en ;
  dcterms:modified "2026-02-12T08:59:21.658950Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9201-1
  a curric:KeyLearningPoint ;
  rdfs:label "Keys can be used to identify organisms in their habitat."@en ;
  dcterms:modified "2026-02-12T08:59:21.659701Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9201-2
  a curric:KeyLearningPoint ;
  rdfs:label """It is not possible to count all the organisms in a population, so we use sampling to estimate population size."""@en ;
  dcterms:modified "2026-02-12T08:59:21.659705Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9201-3
  a curric:KeyLearningPoint ;
  rdfs:label "Sampling organisms in habitats (e.g. a river using kick sampling and a net)."@en ;
  dcterms:modified "2026-02-12T08:59:21.659712Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9201-4
  a curric:KeyLearningPoint ;
  rdfs:label "Sampling animals using a pooter."@en ;
  dcterms:modified "2026-02-12T08:59:21.659717Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9201-5
  a curric:KeyLearningPoint ;
  rdfs:label "Estimating populations using capture-mark-recapture."@en ;
  dcterms:modified "2026-02-12T08:59:21.659722Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6297-1
  a curric:KeyLearningPoint ;
  rdfs:label "Microorganisms use enzymes to decompose biological material."@en ;
  dcterms:modified "2026-02-12T08:59:21.659798Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6297-2
  a curric:KeyLearningPoint ;
  rdfs:label """The rate of decomposition is affected by temperature, which affects the rate of enzyme-controlled reactions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.659805Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6297-3
  a curric:KeyLearningPoint ;
  rdfs:label """The rate of decomposition is affected by the availability of water, which microorganisms need to survive."""@en ;
  dcterms:modified "2026-02-12T08:59:21.659810Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6297-4
  a curric:KeyLearningPoint ;
  rdfs:label """The rate of decomposition is affected by the availability of oxygen to aerobic and anaerobic microorganisms."""@en ;
  dcterms:modified "2026-02-12T08:59:21.659815Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7167-1
  a curric:KeyLearningPoint ;
  rdfs:label """Vaccines have had a positive effect on public health (e.g. the eradication of smallpox)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.659998Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7167-2
  a curric:KeyLearningPoint ;
  rdfs:label """Vaccination is not risk free as it can have side effects, but the benefits outweigh the risks."""@en ;
  dcterms:modified "2026-02-12T08:59:21.660003Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7167-3
  a curric:KeyLearningPoint ;
  rdfs:label """New vaccines are trialled, and are only approved for use when the benefits of the vaccination outweigh the risks."""@en ;
  dcterms:modified "2026-02-12T08:59:21.660007Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7167-4
  a curric:KeyLearningPoint ;
  rdfs:label """It is necessary to vaccinate a high proportion of a population against a pathogen to provide herd immunity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.660012Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7167-5
  a curric:KeyLearningPoint ;
  rdfs:label "Herd immunity helps protect those who can’t or won’t have the vaccination."@en ;
  dcterms:modified "2026-02-12T08:59:21.660016Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9194-1
  a curric:KeyLearningPoint ;
  rdfs:label "The parts of a light microscope and their functions."@en ;
  dcterms:modified "2026-02-12T08:59:21.660398Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9194-2
  a curric:KeyLearningPoint ;
  rdfs:label """The sequence of steps for setting up a microscope to observe specimens, including changing the magnification and focus."""@en ;
  dcterms:modified "2026-02-12T08:59:21.660421Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9194-3
  a curric:KeyLearningPoint ;
  rdfs:label """The steps of applying nail varnish and clear sticky tape to a leaf surface, then observing imprints of stomata."""@en ;
  dcterms:modified "2026-02-12T08:59:21.660429Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9194-4
  a curric:KeyLearningPoint ;
  rdfs:label """Light microscopy can be used to observe and compare the density and distribution of stomata on different leaf surfaces."""@en ;
  dcterms:modified "2026-02-12T08:59:21.660434Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9194-5
  a curric:KeyLearningPoint ;
  rdfs:label """Explaining observations of stomatal density using ideas about transpiration and water loss."""@en ;
  dcterms:modified "2026-02-12T08:59:21.660439Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7165-1
  a curric:KeyLearningPoint ;
  rdfs:label """The human body has defences against infection that work against all pathogens (are not targeted at specific pathogens)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.660444Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7165-2
  a curric:KeyLearningPoint ;
  rdfs:label "Physical defences include the skin, hairs and cilia."@en ;
  dcterms:modified "2026-02-12T08:59:21.660448Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7165-3
  a curric:KeyLearningPoint ;
  rdfs:label "Chemical defences include tears, saliva and stomach acid."@en ;
  dcterms:modified "2026-02-12T08:59:21.660453Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7165-4
  a curric:KeyLearningPoint ;
  rdfs:label """Microbial defences are provided by microorganisms on, and in, our bodies that compete against pathogens."""@en ;
  dcterms:modified "2026-02-12T08:59:21.660457Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7165-5
  a curric:KeyLearningPoint ;
  rdfs:label """White blood cells called phagocytes are part of the immune system and engulf and destroy pathogens by phagocytosis."""@en ;
  dcterms:modified "2026-02-12T08:59:21.660462Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8007-1
  a curric:KeyLearningPoint ;
  rdfs:label """When a mutation changes the sequence of nucleotide bases in a gene, this creates a genetic variant of the gene."""@en ;
  dcterms:modified "2026-02-12T08:59:21.660556Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8007-2
  a curric:KeyLearningPoint ;
  rdfs:label """If a triplet code in a gene is changed, this may or may not change the amino acid sequence in the protein that is made."""@en ;
  dcterms:modified "2026-02-12T08:59:21.660561Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8007-3
  a curric:KeyLearningPoint ;
  rdfs:label """A change in the amino acid sequence of a protein can change the 3D shape of the protein."""@en ;
  dcterms:modified "2026-02-12T08:59:21.660566Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8007-4
  a curric:KeyLearningPoint ;
  rdfs:label """A change in the 3D shape of a protein can change what it does (e.g. by changing the shape of an enzyme’s active site)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.660570Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8007-5
  a curric:KeyLearningPoint ;
  rdfs:label "These changes can have impacts on an organism’s phenotype."@en ;
  dcterms:modified "2026-02-12T08:59:21.660575Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7981-1
  a curric:KeyLearningPoint ;
  rdfs:label """Most characteristics are influenced by multiple genes, but some are determined by just one."""@en ;
  dcterms:modified "2026-02-12T08:59:21.660579Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7981-2
  a curric:KeyLearningPoint ;
  rdfs:label """An individual will inherit two alleles for each gene, the alleles for a gene may be dominant or recessive."""@en ;
  dcterms:modified "2026-02-12T08:59:21.660584Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7981-3
  a curric:KeyLearningPoint ;
  rdfs:label """A Punnett square models inheritance of alleles showing possible genotypes of offspring as homozygous or  heterozygous."""@en ;
  dcterms:modified "2026-02-12T08:59:21.660588Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7981-4
  a curric:KeyLearningPoint ;
  rdfs:label """Punnett squares are used to predict proportion of genotypes/phenotypes, or probability of occurrence in the offspring."""@en ;
  dcterms:modified "2026-02-12T08:59:21.660593Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7981-5
  a curric:KeyLearningPoint ;
  rdfs:label """Each instance of sexual reproduction is independent, so does not affect the probability for subsequent offspring."""@en ;
  dcterms:modified "2026-02-12T08:59:21.660597Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6382-1
  a curric:KeyLearningPoint ;
  rdfs:label """All food chains start with a producer that makes the biomass that is transferred to consumers in higher trophic levels."""@en ;
  dcterms:modified "2026-02-12T08:59:21.660602Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6382-2
  a curric:KeyLearningPoint ;
  rdfs:label """Not all biomass from a trophic level is passed to the next one (due to respiration, uneaten parts, egestion, excretion)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.660606Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6382-3
  a curric:KeyLearningPoint ;
  rdfs:label """Pyramids of biomass are scaled diagrams that can be used to show the amount of biomass present at each trophic level."""@en ;
  dcterms:modified "2026-02-12T08:59:21.660611Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6382-4
  a curric:KeyLearningPoint ;
  rdfs:label """% efficiency of biomass transfer = (biomass in higher trophic level ÷ biomass in lower trophic level) × 100"""@en ;
  dcterms:modified "2026-02-12T08:59:21.660615Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6382-5
  a curric:KeyLearningPoint ;
  rdfs:label """How efficiency of biomass transfer affects the number of organisms in higher trophic levels."""@en ;
  dcterms:modified "2026-02-12T08:59:21.660622Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7962-1
  a curric:KeyLearningPoint ;
  rdfs:label """Plants can be infected by pathogens, such as viruses, bacteria and fungi, that cause diseases."""@en ;
  dcterms:modified "2026-02-12T08:59:21.660793Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7962-2
  a curric:KeyLearningPoint ;
  rdfs:label """Pests, including insects, can damage plants by feeding on them, and can spread pathogens that cause diseases."""@en ;
  dcterms:modified "2026-02-12T08:59:21.660797Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7962-3
  a curric:KeyLearningPoint ;
  rdfs:label "Plants have physical, chemical and mechanical defences against pathogens."@en ;
  dcterms:modified "2026-02-12T08:59:21.660802Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7962-4
  a curric:KeyLearningPoint ;
  rdfs:label "Examples of physical, chemical and mechanical defences in plants."@en ;
  dcterms:modified "2026-02-12T08:59:21.660806Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27969-1
  a curric:KeyLearningPoint ;
  rdfs:label """Cellular respiration happens continuously in all living organisms to transfer the energy needed for life processes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.660987Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27969-2
  a curric:KeyLearningPoint ;
  rdfs:label """Cellular respiration is an exothermic chemical process that uses glucose as a fuel, and makes ATP."""@en ;
  dcterms:modified "2026-02-12T08:59:21.660992Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27969-3
  a curric:KeyLearningPoint ;
  rdfs:label """Word equation and balanced symbol equation summarises the reactants and products of aerobic cellular respiration."""@en ;
  dcterms:modified "2026-02-12T08:59:21.660996Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27969-4
  a curric:KeyLearningPoint ;
  rdfs:label """Aerobic cellular respiration takes place in the mitochondria of eukaryotic cells."""@en ;
  dcterms:modified "2026-02-12T08:59:21.661003Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27969-5
  a curric:KeyLearningPoint ;
  rdfs:label """Aerobic cellular respiration takes place in the cytoplasm of prokaryotic cells, which do not have mitochondria."""@en ;
  dcterms:modified "2026-02-12T08:59:21.661008Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26663-1
  a curric:KeyLearningPoint ;
  rdfs:label """All cells, including our body cells and pathogens, have molecules called antigens on their surface."""@en ;
  dcterms:modified "2026-02-12T08:59:21.661138Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26663-2
  a curric:KeyLearningPoint ;
  rdfs:label "White blood cells only respond to non-self antigens on pathogens."@en ;
  dcterms:modified "2026-02-12T08:59:21.661143Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26663-3
  a curric:KeyLearningPoint ;
  rdfs:label """Lymphocytes are an important part of the human immune system and respond to antigens on specific pathogens."""@en ;
  dcterms:modified "2026-02-12T08:59:21.661148Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26663-4
  a curric:KeyLearningPoint ;
  rdfs:label "Lymphocytes produce antibodies against specific pathogens."@en ;
  dcterms:modified "2026-02-12T08:59:21.661152Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-26663-5
  a curric:KeyLearningPoint ;
  rdfs:label "Lymphocytes produce antitoxins to neutralise toxins produced by bacteria."@en ;
  dcterms:modified "2026-02-12T08:59:21.661157Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27895-1
  a curric:KeyLearningPoint ;
  rdfs:label "Calculate rate of reaction where rate = 1/time taken to reach the end point."@en ;
  dcterms:modified "2026-02-12T08:59:21.661171Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27895-2
  a curric:KeyLearningPoint ;
  rdfs:label """Plot a graph of results (x-axis = temperature and y-axis = rate, or time taken to reach end point)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.661175Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27895-3
  a curric:KeyLearningPoint ;
  rdfs:label "Interpret the results and evaluate how well they support the hypothesis."@en ;
  dcterms:modified "2026-02-12T08:59:21.661182Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27895-4
  a curric:KeyLearningPoint ;
  rdfs:label """Explain the results using ideas about the effect of temperature on the rate of enzyme activity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.661189Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28973-1
  a curric:KeyLearningPoint ;
  rdfs:label """Forests act as a global carbon sink, absorbing one-quarter of the annual global CO₂ emissions from the atmosphere."""@en ;
  dcterms:modified "2026-02-12T08:59:21.661231Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28973-2
  a curric:KeyLearningPoint ;
  rdfs:label """Deforestation contributes to climate change and is a major cause of habitat and biodiversity loss."""@en ;
  dcterms:modified "2026-02-12T08:59:21.661235Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28973-3
  a curric:KeyLearningPoint ;
  rdfs:label """Mitigation strategies include forest protection, reducing deforestation for farming, and replanting trees."""@en ;
  dcterms:modified "2026-02-12T08:59:21.661240Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28973-4
  a curric:KeyLearningPoint ;
  rdfs:label """Oceans act as a global carbon sink, absorbing one-quarter of annual global CO₂ emissions from the atmosphere."""@en ;
  dcterms:modified "2026-02-12T08:59:21.661244Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28973-5
  a curric:KeyLearningPoint ;
  rdfs:label """High CO₂ levels harm marine biodiversity through ocean acidification and reduced shell formation, alongside overfishing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.661249Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5565-1
  a curric:KeyLearningPoint ;
  rdfs:label "The concepts of surface area, volume, and surface area to volume ratio."@en ;
  dcterms:modified "2026-02-12T08:59:21.661286Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5565-2
  a curric:KeyLearningPoint ;
  rdfs:label """Calculation of the surface areas, volumes and surface area to volume ratios of cubes of different sizes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.661291Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5565-3
  a curric:KeyLearningPoint ;
  rdfs:label """Use of coloured agar cubes of different sizes to observe time taken for acid to diffuse to the centre of each cube."""@en ;
  dcterms:modified "2026-02-12T08:59:21.661295Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5565-4
  a curric:KeyLearningPoint ;
  rdfs:label """Interpretation of results and explanation using ideas about surface area to volume ratio and diffusion."""@en ;
  dcterms:modified "2026-02-12T08:59:21.661300Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6299-1
  a curric:KeyLearningPoint ;
  rdfs:label "The water cycle shows how water is recycled on planet Earth."@en ;
  dcterms:modified "2026-02-12T08:59:21.661943Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6299-2
  a curric:KeyLearningPoint ;
  rdfs:label "Water is continuously being evaporated and precipitated."@en ;
  dcterms:modified "2026-02-12T08:59:21.661948Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6299-3
  a curric:KeyLearningPoint ;
  rdfs:label "Plants lose water through transpiration."@en ;
  dcterms:modified "2026-02-12T08:59:21.661952Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6299-4
  a curric:KeyLearningPoint ;
  rdfs:label "Water availability impacts upon a species' ability to survive in a habitat."@en ;
  dcterms:modified "2026-02-12T08:59:21.661957Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6388-1
  a curric:KeyLearningPoint ;
  rdfs:label """Factors affecting food security, e.g. human population size, changing diets in wealthier populations, sustainability."""@en ;
  dcterms:modified "2026-02-12T08:59:21.662365Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6388-2
  a curric:KeyLearningPoint ;
  rdfs:label """Factors affecting food security, e.g. cost of agricultural inputs, environmental change, new pests and pathogens."""@en ;
  dcterms:modified "2026-02-12T08:59:21.662371Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6388-3
  a curric:KeyLearningPoint ;
  rdfs:label """Roles of biotechnology in food security, e.g. genetic engineering to improve yields; use of microorganisms to make food."""@en ;
  dcterms:modified "2026-02-12T08:59:21.662376Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6388-4
  a curric:KeyLearningPoint ;
  rdfs:label """Benefits of biotechnology must be weighed against risks, costs and ethical issues."""@en ;
  dcterms:modified "2026-02-12T08:59:21.662383Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6388-5
  a curric:KeyLearningPoint ;
  rdfs:label """Other ways to improve food security, e.g. sustainable production and use of food, limiting climate change."""@en ;
  dcterms:modified "2026-02-12T08:59:21.662388Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5583-1
  a curric:KeyLearningPoint ;
  rdfs:label """Plants need water for support (to remain turgid) because they don’t have bones, and for photosynthesis in cells."""@en ;
  dcterms:modified "2026-02-12T08:59:21.663069Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5583-2
  a curric:KeyLearningPoint ;
  rdfs:label """Plants need mineral ions for growth and repair, including nitrate ions as a source of nitrogen to make proteins."""@en ;
  dcterms:modified "2026-02-12T08:59:21.663074Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5583-3
  a curric:KeyLearningPoint ;
  rdfs:label """Particles of water are absorbed by osmosis, a type of diffusion, into plant root hair cells."""@en ;
  dcterms:modified "2026-02-12T08:59:21.663078Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5583-4
  a curric:KeyLearningPoint ;
  rdfs:label """Nitrate ions are absorbed into plant root hair cells by active transport, which requires energy."""@en ;
  dcterms:modified "2026-02-12T08:59:21.663083Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5583-5
  a curric:KeyLearningPoint ;
  rdfs:label """Root hair cells are adapted to increase the surface area of membrane for osmosis and active transport."""@en ;
  dcterms:modified "2026-02-12T08:59:21.663087Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7166-1
  a curric:KeyLearningPoint ;
  rdfs:label """After exposure to a pathogen, memory cells remain in the body to provide immunity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.663542Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7166-2
  a curric:KeyLearningPoint ;
  rdfs:label """Vaccination creates immunity by injecting a small amount of a dead or inactivated pathogen in a vaccine into the body."""@en ;
  dcterms:modified "2026-02-12T08:59:21.663547Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7166-3
  a curric:KeyLearningPoint ;
  rdfs:label """White blood cells mount an immune response by producing antibodies against the pathogen in the vaccine."""@en ;
  dcterms:modified "2026-02-12T08:59:21.663551Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7166-4
  a curric:KeyLearningPoint ;
  rdfs:label """Some of the white blood cells stay in the body as memory cells to provide immunity to the pathogen in the vaccine."""@en ;
  dcterms:modified "2026-02-12T08:59:21.663556Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7166-5
  a curric:KeyLearningPoint ;
  rdfs:label """Upon reinfection by the pathogen, memory cells respond by rapidly making antibodies against the pathogen."""@en ;
  dcterms:modified "2026-02-12T08:59:21.663561Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27630-1
  a curric:KeyLearningPoint ;
  rdfs:label """Process data to calculate the volume of gas collected in the measuring cylinder, and the mean of repeat measurements."""@en ;
  dcterms:modified "2026-02-12T08:59:21.663613Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27630-2
  a curric:KeyLearningPoint ;
  rdfs:label """Calculate the rate of respiration by dividing the volume of gas collected in the measuring cylinder by the time."""@en ;
  dcterms:modified "2026-02-12T08:59:21.663618Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27630-3
  a curric:KeyLearningPoint ;
  rdfs:label "Use appropriate units for the rate of cellular respiration."@en ;
  dcterms:modified "2026-02-12T08:59:21.663622Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27630-4
  a curric:KeyLearningPoint ;
  rdfs:label """Compare the rate of respiration in yeast given different substrates, and describe trends in the data."""@en ;
  dcterms:modified "2026-02-12T08:59:21.663627Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27630-5
  a curric:KeyLearningPoint ;
  rdfs:label """Use ideas about enzymes and active sites to explain the effect of different substrates on the rate of respiration."""@en ;
  dcterms:modified "2026-02-12T08:59:21.663631Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7993-1
  a curric:KeyLearningPoint ;
  rdfs:label """Genetic engineering involves modifying the genome of an organism by adding DNA from another organism."""@en ;
  dcterms:modified "2026-02-12T08:59:21.663636Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7993-2
  a curric:KeyLearningPoint ;
  rdfs:label "The aim of genetic engineering is to introduce a desirable characteristic."@en ;
  dcterms:modified "2026-02-12T08:59:21.663641Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7993-3
  a curric:KeyLearningPoint ;
  rdfs:label "Examples of genetically engineering crop plants and bacteria to benefit humans."@en ;
  dcterms:modified "2026-02-12T08:59:21.663645Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7993-4
  a curric:KeyLearningPoint ;
  rdfs:label "Benefits must be weighed against risks and ethical questions."@en ;
  dcterms:modified "2026-02-12T08:59:21.663653Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7172-1
  a curric:KeyLearningPoint ;
  rdfs:label """Plants can be infected by pathogens such as viruses, bacteria and fungi that cause diseases."""@en ;
  dcterms:modified "2026-02-12T08:59:21.664234Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7172-2
  a curric:KeyLearningPoint ;
  rdfs:label """Pests, including insects, can damage plants by feeding on them, and can spread pathogens that cause diseases."""@en ;
  dcterms:modified "2026-02-12T08:59:21.664239Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7172-3
  a curric:KeyLearningPoint ;
  rdfs:label "Plants have physical, chemical and mechanical defences against pathogens."@en ;
  dcterms:modified "2026-02-12T08:59:21.664244Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7172-4
  a curric:KeyLearningPoint ;
  rdfs:label "Examples of physical, chemical and mechanical defences in plants."@en ;
  dcterms:modified "2026-02-12T08:59:21.664248Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7172-5
  a curric:KeyLearningPoint ;
  rdfs:label "Ways to identify plant diseases and the pathogens that cause them."@en ;
  dcterms:modified "2026-02-12T08:59:21.664253Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8002-1
  a curric:KeyLearningPoint ;
  rdfs:label """Gibberellins are plant hormones that cause plants to produce flowers and cause seeds to germinate."""@en ;
  dcterms:modified "2026-02-12T08:59:21.664257Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8002-2
  a curric:KeyLearningPoint ;
  rdfs:label """Plant breeders use gibberellins to force plants to produce flowers so they can be pollinated and increase size of fruit."""@en ;
  dcterms:modified "2026-02-12T08:59:21.664262Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8002-3
  a curric:KeyLearningPoint ;
  rdfs:label "Ethene is a plant hormone that causes ripening of fruit."@en ;
  dcterms:modified "2026-02-12T08:59:21.664266Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8002-4
  a curric:KeyLearningPoint ;
  rdfs:label """Commercial fruit growers use ethene to speed up fruit ripening so that fruit is ready for sale."""@en ;
  dcterms:modified "2026-02-12T08:59:21.664271Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20050-1
  a curric:KeyLearningPoint ;
  rdfs:label """The rate of a reaction is the amount of change (e.g. substrate broken down or product made) per unit of time."""@en ;
  dcterms:modified "2026-02-12T08:59:21.664903Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20050-2
  a curric:KeyLearningPoint ;
  rdfs:label """Enzyme reaction rate increases as substrate concentration increases, until an optimum when all active sites are full."""@en ;
  dcterms:modified "2026-02-12T08:59:21.664907Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20050-3
  a curric:KeyLearningPoint ;
  rdfs:label """Enzyme reaction rate increases with temperature due to more collisions, until an optimum when all active sites are full."""@en ;
  dcterms:modified "2026-02-12T08:59:21.664912Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20050-4
  a curric:KeyLearningPoint ;
  rdfs:label """Enzyme rate decreases as temperature increases above the optimum as bonds break and the active site becomes denatured."""@en ;
  dcterms:modified "2026-02-12T08:59:21.664916Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20050-5
  a curric:KeyLearningPoint ;
  rdfs:label """Interpretation of graphs showing effects of substrate concentration and temperature on enzyme reaction rate."""@en ;
  dcterms:modified "2026-02-12T08:59:21.664921Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8192-1
  a curric:KeyLearningPoint ;
  rdfs:label """Increasing amounts of greenhouse gases in the atmosphere are associated with climate change."""@en ;
  dcterms:modified "2026-02-12T08:59:21.665204Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8192-2
  a curric:KeyLearningPoint ;
  rdfs:label "Changes in ecosystems can affect mean temperature and water availability."@en ;
  dcterms:modified "2026-02-12T08:59:21.665209Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8192-3
  a curric:KeyLearningPoint ;
  rdfs:label """Changes in ecosystems can leave organisms less well adapted to survive and thrive there."""@en ;
  dcterms:modified "2026-02-12T08:59:21.665213Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8192-4
  a curric:KeyLearningPoint ;
  rdfs:label """Evaluation of data linking changes in atmospheric gases and changes in biodiversity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.665218Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8192-5
  a curric:KeyLearningPoint ;
  rdfs:label """Evaluation of data linking changes in water availability and changes in biodiversity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.665222Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5605-1
  a curric:KeyLearningPoint ;
  rdfs:label """Water diffuses into and out of cells by osmosis; net movement is from a more dilute solution to a more concentrated one."""@en ;
  dcterms:modified "2026-02-12T08:59:21.665543Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5605-2
  a curric:KeyLearningPoint ;
  rdfs:label """Investigating the effect of sucrose solution concentration on the mass of potato chips."""@en ;
  dcterms:modified "2026-02-12T08:59:21.665548Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5605-3
  a curric:KeyLearningPoint ;
  rdfs:label "Use of appropriate apparatus to measure volumes, masses and times accurately."@en ;
  dcterms:modified "2026-02-12T08:59:21.665553Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5605-4
  a curric:KeyLearningPoint ;
  rdfs:label "Safe use of materials and apparatus."@en ;
  dcterms:modified "2026-02-12T08:59:21.665557Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5605-5
  a curric:KeyLearningPoint ;
  rdfs:label "Control of variables that might affect the results (e.g. temperature)."@en ;
  dcterms:modified "2026-02-12T08:59:21.665562Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5573-1
  a curric:KeyLearningPoint ;
  rdfs:label """The hormone adrenaline is secreted by the adrenal gland during stress; it causes the body to prepare for rapid action."""@en ;
  dcterms:modified "2026-02-12T08:59:21.667073Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5573-2
  a curric:KeyLearningPoint ;
  rdfs:label """The hormone thyroxine is secreted by the thyroid gland; it controls growth and the rates of chemical reactions in cells."""@en ;
  dcterms:modified "2026-02-12T08:59:21.667077Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5573-3
  a curric:KeyLearningPoint ;
  rdfs:label "The pituitary gland secretes hormones that can control other glands."@en ;
  dcterms:modified "2026-02-12T08:59:21.667082Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5573-4
  a curric:KeyLearningPoint ;
  rdfs:label """The pituitary gland secretes TSH, which causes the thyroid gland to secrete thyroxine."""@en ;
  dcterms:modified "2026-02-12T08:59:21.667086Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5573-5
  a curric:KeyLearningPoint ;
  rdfs:label """Thyroxine causes the pituitary gland to stop secreting TSH; this is an example of negative feedback."""@en ;
  dcterms:modified "2026-02-12T08:59:21.667091Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9197-1
  a curric:KeyLearningPoint ;
  rdfs:label "A light microscope can be used to observe microorganisms."@en ;
  dcterms:modified "2026-02-12T08:59:21.668024Z"^^xsd:dateTime .

