# ----------------------------------------------------------------------
# Key Learning Points
# ----------------------------------------------------------------------

oakcurric:keylearningpoint-lesson-9162-1
  a curric:KeyLearningPoint ;
  rdfs:label """Eukaryotic cells store their genetic material in a nucleus and have membrane bound sub-cellular structures."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486188Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9162-2
  a curric:KeyLearningPoint ;
  rdfs:label "Eukaryotic organisms can be unicellular or multicellular."@en ;
  dcterms:modified "2026-02-12T08:59:21.486192Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9162-3
  a curric:KeyLearningPoint ;
  rdfs:label "Examples of eukaryotic and prokaryotic organisms."@en ;
  dcterms:modified "2026-02-12T08:59:21.486196Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9162-4
  a curric:KeyLearningPoint ;
  rdfs:label """Prokaryotic cells do not have membrane bound sub-cellular structures including a nucleus; DNA is floating in cytoplasm."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486200Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9162-5
  a curric:KeyLearningPoint ;
  rdfs:label "Prokaryotic organisms are unicellular."@en ;
  dcterms:modified "2026-02-12T08:59:21.486204Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7973-1
  a curric:KeyLearningPoint ;
  rdfs:label """The genome stores instructions that are used by cells to make structural and functional proteins (including enzymes)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486210Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7973-2
  a curric:KeyLearningPoint ;
  rdfs:label """The proteins that are made are used to build other structures and control chemical reactions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486214Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7973-3
  a curric:KeyLearningPoint ;
  rdfs:label "The characteristics of an organism are called the phenotype."@en ;
  dcterms:modified "2026-02-12T08:59:21.486218Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7973-4
  a curric:KeyLearningPoint ;
  rdfs:label """Some characteristics in an organism’s phenotype are determined only by its genome (e.g. eye colour)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486222Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7973-5
  a curric:KeyLearningPoint ;
  rdfs:label """Most characteristics in the phenotype are influenced by the organism's genome and interaction with its environment."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486226Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9163-1
  a curric:KeyLearningPoint ;
  rdfs:label "Bacteria are prokaryotic organisms."@en ;
  dcterms:modified "2026-02-12T08:59:21.486229Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9163-2
  a curric:KeyLearningPoint ;
  rdfs:label """Common features of prokaryotic cells include the cell membrane, cytoplasm and cell wall."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486233Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9163-3
  a curric:KeyLearningPoint ;
  rdfs:label """Prokaryotic cells do not have a nucleus; they store their genetic material in the cell cytoplasm."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486239Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9163-4
  a curric:KeyLearningPoint ;
  rdfs:label "The genetic material is stored in one looped chromosome."@en ;
  dcterms:modified "2026-02-12T08:59:21.486243Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9163-5
  a curric:KeyLearningPoint ;
  rdfs:label "Extra genetic material can be stored in small loops called plasmids."@en ;
  dcterms:modified "2026-02-12T08:59:21.486247Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5542-1
  a curric:KeyLearningPoint ;
  rdfs:label """Some factors affect human reaction time (e.g. the time taken to catch a ruler after it is dropped)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486388Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5542-2
  a curric:KeyLearningPoint ;
  rdfs:label """Writing a testable prediction or hypothesis about the effect of a factor on human reaction time."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486392Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5542-3
  a curric:KeyLearningPoint ;
  rdfs:label """Identifying independent and dependent variables, range of values to test, and which factors to control and how."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486396Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5542-4
  a curric:KeyLearningPoint ;
  rdfs:label "Safe use of apparatus, and safe and ethical use of human test subjects."@en ;
  dcterms:modified "2026-02-12T08:59:21.486400Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5542-5
  a curric:KeyLearningPoint ;
  rdfs:label "Interpret data from measurements of human reaction time."@en ;
  dcterms:modified "2026-02-12T08:59:21.486403Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9157-1
  a curric:KeyLearningPoint ;
  rdfs:label """All organisms (including animals, plants, fungi and micro-organisms) are made up of one or more living cells."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486409Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9157-2
  a curric:KeyLearningPoint ;
  rdfs:label """All cells have some structures in common (cell membrane and cytoplasm) and have a three-dimensional shape."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486413Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9157-3
  a curric:KeyLearningPoint ;
  rdfs:label """Chemical reactions essential to life occur in cytoplasm; the cell membrane regulates the cell’s internal environment."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486417Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9157-4
  a curric:KeyLearningPoint ;
  rdfs:label """Many animals and plants are multicellular; they are made up of many cells organised to form tissues and organs."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486421Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9157-5
  a curric:KeyLearningPoint ;
  rdfs:label """Micro-organisms such as bacteria are unicellular – they are made of just one cell."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486425Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5562-1
  a curric:KeyLearningPoint ;
  rdfs:label "Blood contains blood cells suspended in a fluid called plasma."@en ;
  dcterms:modified "2026-02-12T08:59:21.486429Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5562-2
  a curric:KeyLearningPoint ;
  rdfs:label """Red blood cells transport oxygen, and have a structure adapted to carry as much oxygen as possible."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486433Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5562-3
  a curric:KeyLearningPoint ;
  rdfs:label """Plasma transports water, glucose and other nutrients, and waste products including carbon dioxide and urea."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486439Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5562-4
  a curric:KeyLearningPoint ;
  rdfs:label """Arteries carry blood away from the heart; capillaries carry blood to/from cells; veins carry blood back to the heart."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486443Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5562-5
  a curric:KeyLearningPoint ;
  rdfs:label """Arteries, capillaries and veins have structures adapted to their functions, including different vessel walls and valves."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486447Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5567-1
  a curric:KeyLearningPoint ;
  rdfs:label """Consequences for living organisms of relationship between surface area:volume ratio and diffusion time."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486522Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5567-2
  a curric:KeyLearningPoint ;
  rdfs:label """Reasons why a small surface area (relative to volume) could be a disadvantage to living organisms."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486526Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5567-3
  a curric:KeyLearningPoint ;
  rdfs:label """The circulatory system minimises diffusion distance for oxygen and food molecules so cells can be supplied quickly."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486530Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5567-4
  a curric:KeyLearningPoint ;
  rdfs:label """Examples of exchange surfaces in humans (e.g. alveoli in lungs, villi in digestive system)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486534Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5567-5
  a curric:KeyLearningPoint ;
  rdfs:label """The exchange surfaces are adapted to maximise surface area for diffusion of particles of essential substances and waste."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486538Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9203-1
  a curric:KeyLearningPoint ;
  rdfs:label """Common defects of the eye (e.g. cataracts, short- and long-sightedness) and how they impair vision."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486541Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9203-2
  a curric:KeyLearningPoint ;
  rdfs:label "How common defects of the eye can be treated."@en ;
  dcterms:modified "2026-02-12T08:59:21.486545Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9203-3
  a curric:KeyLearningPoint ;
  rdfs:label """Interpretation of ray diagrams to explain how common eye defects affect vision, and the effects of corrective lenses."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486549Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9203-4
  a curric:KeyLearningPoint ;
  rdfs:label "How colour blindness occurs and its impact on vision."@en ;
  dcterms:modified "2026-02-12T08:59:21.486553Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5553-1
  a curric:KeyLearningPoint ;
  rdfs:label "Enzymes are proteins that act as catalysts, speeding up chemical reactions."@en ;
  dcterms:modified "2026-02-12T08:59:21.486602Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5553-2
  a curric:KeyLearningPoint ;
  rdfs:label "Without enzymes, many reactions would happen too slowly to support life."@en ;
  dcterms:modified "2026-02-12T08:59:21.486606Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5553-3
  a curric:KeyLearningPoint ;
  rdfs:label """Enzymes catalyse reactions essential to life, including digestion and reactions in photosynthesis and respiration."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486610Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5553-4
  a curric:KeyLearningPoint ;
  rdfs:label """Each enzyme has a 3D shape with an active site that a specific substrate fits into."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486614Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5553-5
  a curric:KeyLearningPoint ;
  rdfs:label "The lock and key model to explain enzyme-substrate interactions."@en ;
  dcterms:modified "2026-02-12T08:59:21.486620Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9158-1
  a curric:KeyLearningPoint ;
  rdfs:label "A light microscope can be used to observe animal and plant cells."@en ;
  dcterms:modified "2026-02-12T08:59:21.486624Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9158-2
  a curric:KeyLearningPoint ;
  rdfs:label "The parts of a light microscope and their functions."@en ;
  dcterms:modified "2026-02-12T08:59:21.486628Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9158-3
  a curric:KeyLearningPoint ;
  rdfs:label """The sequence of steps setting up a light microscope to observe cells, including changing the magnification and focus."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486631Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9158-4
  a curric:KeyLearningPoint ;
  rdfs:label """Observations from a light microscope can be recorded in a labelled scientific line drawing with an indication of scale."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486636Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9158-5
  a curric:KeyLearningPoint ;
  rdfs:label """The magnification and real size of structures observed with a microscope can be calculated."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486640Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9164-1
  a curric:KeyLearningPoint ;
  rdfs:label "Most animals and plants are made up of millions or billions of cells."@en ;
  dcterms:modified "2026-02-12T08:59:21.486668Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9164-2
  a curric:KeyLearningPoint ;
  rdfs:label "Cells are usually too small to see with the unaided eye."@en ;
  dcterms:modified "2026-02-12T08:59:21.486672Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9164-3
  a curric:KeyLearningPoint ;
  rdfs:label """Comparison of the sizes of eukaryotic and prokaryotic cells, and cell structures, in micrometres."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486676Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27881-1
  a curric:KeyLearningPoint ;
  rdfs:label """The hormone adrenaline is secreted by the adrenal gland during stress; it causes the body to prepare for rapid action."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486682Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27881-2
  a curric:KeyLearningPoint ;
  rdfs:label """The hormone thyroxine is secreted by the thyroid gland; it controls growth and the rates of chemical reactions in cells."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486686Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27881-3
  a curric:KeyLearningPoint ;
  rdfs:label "The pituitary gland secretes hormones that control other glands."@en ;
  dcterms:modified "2026-02-12T08:59:21.486690Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27881-4
  a curric:KeyLearningPoint ;
  rdfs:label """Hypothalamus secretes TRH; this causes pituitary gland to secrete TSH; this causes thyroid gland to secrete thyroxine."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486694Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27881-5
  a curric:KeyLearningPoint ;
  rdfs:label """Thyroxine causes the pituitary gland to stop secreting TSH; this is an example of negative feedback."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486698Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7159-1
  a curric:KeyLearningPoint ;
  rdfs:label """Risk factors affect the chance that a person will develop a non-communicable disease."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486702Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7159-2
  a curric:KeyLearningPoint ;
  rdfs:label """Risk factors can be lifestyle factors, e.g. diet, smoking, environmental, e.g. air pollution, or genetic, e.g. alleles."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486705Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7159-3
  a curric:KeyLearningPoint ;
  rdfs:label """Experiencing multiple factors can increase the likelihood a person will develop a particular disease."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486709Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7159-4
  a curric:KeyLearningPoint ;
  rdfs:label """Interpreting data on non-communicable diseases and risk factors at local, national and global levels."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486716Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7159-5
  a curric:KeyLearningPoint ;
  rdfs:label """The importance of peer review and communicating research on risk factors to a range of audiences."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486720Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7980-1
  a curric:KeyLearningPoint ;
  rdfs:label """Offspring inherit two alleles, one from each parent, the combination of these alleles is the genotype."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486723Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7980-2
  a curric:KeyLearningPoint ;
  rdfs:label """The phenotypes of members of a family can be shown in a diagram such as a family tree (pedigree)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486727Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7980-3
  a curric:KeyLearningPoint ;
  rdfs:label """A family tree diagram is a model of inheritance, showing whether a characteristic was passed from parents to offspring."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486732Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7980-4
  a curric:KeyLearningPoint ;
  rdfs:label """A family tree can be used to work out an individual’s genotype if their phenotype and relatives’ genotypes are known."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486736Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7980-5
  a curric:KeyLearningPoint ;
  rdfs:label """A family tree can be used to determine the history and probability of genetic disorders: cystic fibrosis and polydactyly"""@en ;
  dcterms:modified "2026-02-12T08:59:21.486739Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5550-1
  a curric:KeyLearningPoint ;
  rdfs:label """Organisms are made of carbohydrates, proteins and lipids (including fats), plus water and minerals."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486992Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5550-2
  a curric:KeyLearningPoint ;
  rdfs:label """Carbohydrates, proteins and lipids are used to build cell structures including membranes and organelles."""@en ;
  dcterms:modified "2026-02-12T08:59:21.486995Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5550-3
  a curric:KeyLearningPoint ;
  rdfs:label "Carbohydrates are polymers made of sugars."@en ;
  dcterms:modified "2026-02-12T08:59:21.487002Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5550-4
  a curric:KeyLearningPoint ;
  rdfs:label "Proteins are polymers made of amino acids."@en ;
  dcterms:modified "2026-02-12T08:59:21.487006Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5550-5
  a curric:KeyLearningPoint ;
  rdfs:label "Lipids are molecules made of fatty acids and glycerol."@en ;
  dcterms:modified "2026-02-12T08:59:21.487010Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7974-1
  a curric:KeyLearningPoint ;
  rdfs:label "DNA is a polymer of four different nucleotides (A, C, G and T)."@en ;
  dcterms:modified "2026-02-12T08:59:21.487014Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7974-2
  a curric:KeyLearningPoint ;
  rdfs:label "Proteins are polymers of amino acids."@en ;
  dcterms:modified "2026-02-12T08:59:21.487020Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7974-3
  a curric:KeyLearningPoint ;
  rdfs:label """The sequence of nucleotides in a gene determines the order of amino acids in a protein."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487024Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7974-4
  a curric:KeyLearningPoint ;
  rdfs:label """Each set of three nucleotides is a triplet code that corresponds to an amino acid, this code is universal."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487028Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7974-5
  a curric:KeyLearningPoint ;
  rdfs:label """Different organisms have different sequences of nucleotides in their DNA, but share this common coding system."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487032Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5545-1
  a curric:KeyLearningPoint ;
  rdfs:label """Reflex responses are fast and involuntary, and are essential to the survival of many organisms."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487058Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5545-2
  a curric:KeyLearningPoint ;
  rdfs:label "Reflex responses do not involve a processing centre (e.g. the brain) in the CNS."@en ;
  dcterms:modified "2026-02-12T08:59:21.487063Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5545-3
  a curric:KeyLearningPoint ;
  rdfs:label """In a reflex arc, the nerve impulse travels across a synapse from the sensory neurone to a relay neurone in the CNS."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487067Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5545-4
  a curric:KeyLearningPoint ;
  rdfs:label """The nerve impulse travels across a synapse from the relay neurone to a motor neurone in the PNS."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487088Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5545-5
  a curric:KeyLearningPoint ;
  rdfs:label """Sometimes the brain can modify (e.g. stop) a reflex response via a neurone to the motor neurone of the reflex arc."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487092Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8100-1
  a curric:KeyLearningPoint ;
  rdfs:label """During sexual reproduction, an individual’s biological sex is determined by the chromosomes they inherit."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487098Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8100-2
  a curric:KeyLearningPoint ;
  rdfs:label """In humans, the 23rd pair of chromosomes are sex chromosomes; XX in females and XY in males."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487102Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8100-3
  a curric:KeyLearningPoint ;
  rdfs:label """A gene on the Y chromosome triggers the development of testes, which make male sex hormones (androgens)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487106Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8100-4
  a curric:KeyLearningPoint ;
  rdfs:label """Interpreting, completing and constructing Punnett squares showing the inheritance of human sex chromosomes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487110Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9206-1
  a curric:KeyLearningPoint ;
  rdfs:label "How to measure pulse rate."@en ;
  dcterms:modified "2026-02-12T08:59:21.487116Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9206-2
  a curric:KeyLearningPoint ;
  rdfs:label """How to control the type and duration of exercise to be undertaken by a test subject."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487120Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9206-3
  a curric:KeyLearningPoint ;
  rdfs:label """Record resting pulse rate before exercise and take repeated measurements of pulse rate after exercise."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487124Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9206-4
  a curric:KeyLearningPoint ;
  rdfs:label """The recovery time is the time it takes for the pulse rate to return to the resting rate after exercise."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487128Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5579-1
  a curric:KeyLearningPoint ;
  rdfs:label """Models are used in science to explain things that can be difficult to see or understand."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487132Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5579-2
  a curric:KeyLearningPoint ;
  rdfs:label """The word summary and symbol equation for photosynthesis are simple models of the process."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487136Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5579-3
  a curric:KeyLearningPoint ;
  rdfs:label "Photosynthesis can also be summarised using a model of the two main stages."@en ;
  dcterms:modified "2026-02-12T08:59:21.487140Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5579-4
  a curric:KeyLearningPoint ;
  rdfs:label """In the first stage, energy from light is required to split water molecules into hydrogen and waste oxygen."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487144Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5579-5
  a curric:KeyLearningPoint ;
  rdfs:label """In the second stage, the hydrogen is combined with carbon dioxide to make glucose."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487148Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8099-1
  a curric:KeyLearningPoint ;
  rdfs:label """Mendel investigated the inheritance of traits (e.g. flower colour and seed texture) in pea plants in the 1850s-60s."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487402Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8099-2
  a curric:KeyLearningPoint ;
  rdfs:label """Earlier scientists thought traits blended during sexual reproduction; Mendel showed traits were dominant and recessive."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487405Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8099-3
  a curric:KeyLearningPoint ;
  rdfs:label """Mendel suggested heritable ‘factors’ caused traits; other scientists discovered DNA in 1869 and genes in the 1900s."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487409Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8099-4
  a curric:KeyLearningPoint ;
  rdfs:label """Theories about heredity developed over time; 1943: DNA associated with inheritance; 1953: structure of DNA worked out."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487413Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8099-5
  a curric:KeyLearningPoint ;
  rdfs:label """Over recent decades scientists have discovered the importance of studying whole genomes, not just individual genes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487417Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5540-1
  a curric:KeyLearningPoint ;
  rdfs:label """The human body has a nervous system that enables us to sense and respond quickly to changes outside and inside the body."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487421Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5540-2
  a curric:KeyLearningPoint ;
  rdfs:label """Examples of stimulus (e.g. increase in temperature) and response (e.g. sweating)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487425Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5540-3
  a curric:KeyLearningPoint ;
  rdfs:label """The structures that make up the central nervous system (CNS) and peripheral nervous system (PNS)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487429Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5540-4
  a curric:KeyLearningPoint ;
  rdfs:label """Receptors detect stimuli; they can be single cells (e.g. in the skin) or groups of cells in sense organs (e.g. the eye)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487436Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5540-5
  a curric:KeyLearningPoint ;
  rdfs:label """Sensory neurones join receptors to the CNS; motor neurones join the CNS to effectors that carry out the response."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487440Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7983-1
  a curric:KeyLearningPoint ;
  rdfs:label """Most cells in multicellular organisms go through different phases that are part of a cell cycle."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487444Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7983-2
  a curric:KeyLearningPoint ;
  rdfs:label "The main phases of the cell cycle are interphase and mitosis."@en ;
  dcterms:modified "2026-02-12T08:59:21.487448Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7983-3
  a curric:KeyLearningPoint ;
  rdfs:label """During cell interphase, each chromosome is copied, sub-cellular structures are copied."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487452Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7983-4
  a curric:KeyLearningPoint ;
  rdfs:label """During mitosis, chromosome copies line up along the middle of the cell and the nucleus divides."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487456Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7983-5
  a curric:KeyLearningPoint ;
  rdfs:label "After division, the two new cells both have a copy of the same chromosomes."@en ;
  dcterms:modified "2026-02-12T08:59:21.487460Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5560-1
  a curric:KeyLearningPoint ;
  rdfs:label """Humans are multicellular organisms; the human body is made up of millions of living cells."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487463Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5560-2
  a curric:KeyLearningPoint ;
  rdfs:label """Every cell must be supplied with substances for respiration, growth and repair; waste products must be removed."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487467Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5560-3
  a curric:KeyLearningPoint ;
  rdfs:label """The circulatory system transports substances between cells and the gas exchange, digestive and excretory systems."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487471Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5560-4
  a curric:KeyLearningPoint ;
  rdfs:label "The circulatory system is made up of the heart, blood vessels and blood."@en ;
  dcterms:modified "2026-02-12T08:59:21.487475Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5578-1
  a curric:KeyLearningPoint ;
  rdfs:label """Some of the glucose made by photosynthesis is converted into starch and stored in starch grains in leaf cells."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487497Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5578-2
  a curric:KeyLearningPoint ;
  rdfs:label """Iodine solution can be used to test plant leaf tissue for the presence of starch."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487501Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5578-3
  a curric:KeyLearningPoint ;
  rdfs:label """A scientific prediction is a testable statement about a possible outcome, which can be tested in an experiment."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487505Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5578-4
  a curric:KeyLearningPoint ;
  rdfs:label """Predicting the iodine test result for destarched leaves kept in various conditions, and explaining the predictions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487511Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5578-5
  a curric:KeyLearningPoint ;
  rdfs:label """Observing the iodine test result for destarched leaves kept in various conditions, and explaining the observations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487516Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9182-1
  a curric:KeyLearningPoint ;
  rdfs:label """Some but not all bacteria are pathogens that can cause communicable diseases in humans."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487521Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9182-2
  a curric:KeyLearningPoint ;
  rdfs:label """Pathogenic bacteria can produce toxins that damage living tissue and cause disease."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487525Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9182-3
  a curric:KeyLearningPoint ;
  rdfs:label """Salmonella food poisoning as an example of a bacterial disease, how it is spread, and how the spread can be reduced."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487531Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9182-4
  a curric:KeyLearningPoint ;
  rdfs:label "Viruses invade cells to reproduce where they cause damage to cells."@en ;
  dcterms:modified "2026-02-12T08:59:21.487535Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9182-5
  a curric:KeyLearningPoint ;
  rdfs:label """Measles as an example of a viral disease, how it is spread, and how the spread can be reduced."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487539Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7160-1
  a curric:KeyLearningPoint ;
  rdfs:label "Cancer is a non-communicable disease."@en ;
  dcterms:modified "2026-02-12T08:59:21.487563Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7160-2
  a curric:KeyLearningPoint ;
  rdfs:label "Cancer is when cells divide uncontrollably and form a tumour."@en ;
  dcterms:modified "2026-02-12T08:59:21.487566Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7160-3
  a curric:KeyLearningPoint ;
  rdfs:label "Tumours can be benign or malignant."@en ;
  dcterms:modified "2026-02-12T08:59:21.487570Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7160-4
  a curric:KeyLearningPoint ;
  rdfs:label """Scientists have identified risk factors for certain cancers, including lifestyle and genetic factors."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487574Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7160-5
  a curric:KeyLearningPoint ;
  rdfs:label """Infection with the sexually transmitted infection HPV can increase the risk of cervical cancer."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487578Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9185-1
  a curric:KeyLearningPoint ;
  rdfs:label """Some, but not all, fungi are pathogens that can cause communicable diseases in humans."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487603Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9185-2
  a curric:KeyLearningPoint ;
  rdfs:label """Athlete’s foot as an example of a fungal disease, how it is spread, and how the spread can be reduced."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487608Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9185-3
  a curric:KeyLearningPoint ;
  rdfs:label "Protists are eukaryotic microorganisms."@en ;
  dcterms:modified "2026-02-12T08:59:21.487612Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9185-4
  a curric:KeyLearningPoint ;
  rdfs:label """Malaria as an example of a disease caused by a protist, spread by an insect vector, and how the spread can be reduced."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487616Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9185-5
  a curric:KeyLearningPoint ;
  rdfs:label """The interaction of sickle-cell trait and malaria as an example of interaction between different types of disease."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487620Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7954-1
  a curric:KeyLearningPoint ;
  rdfs:label "The hormone insulin helps to control blood sugar level in the human body."@en ;
  dcterms:modified "2026-02-12T08:59:21.487626Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7954-2
  a curric:KeyLearningPoint ;
  rdfs:label "Insulin is secreted by cells in a gland called the pancreas."@en ;
  dcterms:modified "2026-02-12T08:59:21.487630Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7954-3
  a curric:KeyLearningPoint ;
  rdfs:label """People living with diabetes have problems with controlling their blood sugar level."""@en ;
  dcterms:modified "2026-02-12T08:59:21.487634Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7954-4
  a curric:KeyLearningPoint ;
  rdfs:label "The cause and treatments for type 1 diabetes."@en ;
  dcterms:modified "2026-02-12T08:59:21.487638Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7954-5
  a curric:KeyLearningPoint ;
  rdfs:label "The cause and treatments for type 2 diabetes."@en ;
  dcterms:modified "2026-02-12T08:59:21.487642Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5541-1
  a curric:KeyLearningPoint ;
  rdfs:label "Neurones are specialised cells that transmit nerve impulses"@en ;
  dcterms:modified "2026-02-12T08:59:21.487665Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5541-2
  a curric:KeyLearningPoint ;
  rdfs:label "The common structures of neurones, including cell body and axon"@en ;
  dcterms:modified "2026-02-12T08:59:21.487669Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5541-3
  a curric:KeyLearningPoint ;
  rdfs:label "A myelin sheath on some neurones increases the speed of the nerve impulse"@en ;
  dcterms:modified "2026-02-12T08:59:21.487673Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5541-4
  a curric:KeyLearningPoint ;
  rdfs:label "Nerve impulses pass from one neurone to another across a gap called a synapse"@en ;
  dcterms:modified "2026-02-12T08:59:21.487677Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5541-5
  a curric:KeyLearningPoint ;
  rdfs:label """An impulse arriving at a synapse releases neurotransmitters that diffuse across the gap to receptors on the next neurone"""@en ;
  dcterms:modified "2026-02-12T08:59:21.487681Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9190-1
  a curric:KeyLearningPoint ;
  rdfs:label "Tobacco mosaic virus is an example of a disease in plants caused by a virus."@en ;
  dcterms:modified "2026-02-12T08:59:21.488044Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9190-2
  a curric:KeyLearningPoint ;
  rdfs:label "Crown gall disease is an example of a disease in plants caused by a bacterium."@en ;
  dcterms:modified "2026-02-12T08:59:21.488048Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9190-3
  a curric:KeyLearningPoint ;
  rdfs:label "Chalara ash dieback is an example of a disease in plants caused by a fungus."@en ;
  dcterms:modified "2026-02-12T08:59:21.488052Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9190-4
  a curric:KeyLearningPoint ;
  rdfs:label """Ways in which plant diseases can be spread, and ways in which the spread can be reduced."""@en ;
  dcterms:modified "2026-02-12T08:59:21.488059Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9190-5
  a curric:KeyLearningPoint ;
  rdfs:label "Impacts of plant diseases, including on biodiversity and human food security."@en ;
  dcterms:modified "2026-02-12T08:59:21.488063Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9167-1
  a curric:KeyLearningPoint ;
  rdfs:label "Most animals and plants are made up of millions or billions of cells."@en ;
  dcterms:modified "2026-02-12T08:59:21.488170Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9167-2
  a curric:KeyLearningPoint ;
  rdfs:label "Cell numbers can be expressed in standard form."@en ;
  dcterms:modified "2026-02-12T08:59:21.488174Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9167-3
  a curric:KeyLearningPoint ;
  rdfs:label "Cells are usually too small to see with the unaided eye."@en ;
  dcterms:modified "2026-02-12T08:59:21.488177Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9167-4
  a curric:KeyLearningPoint ;
  rdfs:label """Comparison of sizes of eukaryotic and prokaryotic cells, and cell structures, in µm, nm, and in metres in standard form."""@en ;
  dcterms:modified "2026-02-12T08:59:21.488182Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5551-1
  a curric:KeyLearningPoint ;
  rdfs:label """A reagent called Benedict’s solution is used to test for reducing sugars, including glucose."""@en ;
  dcterms:modified "2026-02-12T08:59:21.488186Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5551-2
  a curric:KeyLearningPoint ;
  rdfs:label """A reagent called iodine solution is used to test for starch, a type of carbohydrate."""@en ;
  dcterms:modified "2026-02-12T08:59:21.488194Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5551-3
  a curric:KeyLearningPoint ;
  rdfs:label "A reagent called Biuret solution is used to test for protein."@en ;
  dcterms:modified "2026-02-12T08:59:21.488198Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5551-4
  a curric:KeyLearningPoint ;
  rdfs:label "Ethanol (a type of alcohol) is used to test for lipids."@en ;
  dcterms:modified "2026-02-12T08:59:21.488202Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5551-5
  a curric:KeyLearningPoint ;
  rdfs:label "Interpretation of qualitative food test results."@en ;
  dcterms:modified "2026-02-12T08:59:21.488206Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7158-1
  a curric:KeyLearningPoint ;
  rdfs:label """Cardiovascular disease (including coronary heart disease) is a common non-communicable disease."""@en ;
  dcterms:modified "2026-02-12T08:59:21.488371Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7158-2
  a curric:KeyLearningPoint ;
  rdfs:label """The coronary arteries supply blood to the heart muscle, and can become blocked by fatty deposits."""@en ;
  dcterms:modified "2026-02-12T08:59:21.488378Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7158-3
  a curric:KeyLearningPoint ;
  rdfs:label """This restricts blood flow and causes a lack of oxygen to the heart muscle, which can cause a heart attack."""@en ;
  dcterms:modified "2026-02-12T08:59:21.488382Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7158-4
  a curric:KeyLearningPoint ;
  rdfs:label """Heart valves stop the backflow of blood in the heart and they can become damaged."""@en ;
  dcterms:modified "2026-02-12T08:59:21.488386Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7158-5
  a curric:KeyLearningPoint ;
  rdfs:label """Heart disease can be prevented with lifestyle changes, or treated with stents, medicines, transplants and surgery."""@en ;
  dcterms:modified "2026-02-12T08:59:21.488390Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28971-1
  a curric:KeyLearningPoint ;
  rdfs:label """Human health is affected by nutrition, fresh water availability, pathogens, and environmental conditions"""@en ;
  dcterms:modified "2026-02-12T08:59:21.488394Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28971-2
  a curric:KeyLearningPoint ;
  rdfs:label "Climate change affects fresh water availability and the growth of crops"@en ;
  dcterms:modified "2026-02-12T08:59:21.597053Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28971-3
  a curric:KeyLearningPoint ;
  rdfs:label """Heat-related ill health, malnutrition and communicable diseases are becoming more common as a result of climate change"""@en ;
  dcterms:modified "2026-02-12T08:59:21.597080Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28971-4
  a curric:KeyLearningPoint ;
  rdfs:label "The spread and prevalence of diseases are influenced by climate"@en ;
  dcterms:modified "2026-02-12T08:59:21.597092Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28971-5
  a curric:KeyLearningPoint ;
  rdfs:label """Communicable diseases (e.g. malaria) may spread more easily and into new geographical areas due to climate change"""@en ;
  dcterms:modified "2026-02-12T08:59:21.597103Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7969-1
  a curric:KeyLearningPoint ;
  rdfs:label """Genetic material is stored in the nucleus of plant and animal cells, and in the cytoplasm of bacterial cells."""@en ;
  dcterms:modified "2026-02-12T08:59:21.597209Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7969-2
  a curric:KeyLearningPoint ;
  rdfs:label """Genetic material of organisms is made of a chemical substance called DNA, which is made up of smaller chemical units."""@en ;
  dcterms:modified "2026-02-12T08:59:21.597223Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7969-3
  a curric:KeyLearningPoint ;
  rdfs:label """The DNA in every cell is wound up into tightly-packed structures called chromosomes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.597234Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7969-4
  a curric:KeyLearningPoint ;
  rdfs:label """Sections of chromosomes are called genes; short sections of DNA which carry instructions for features and processes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.597249Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7969-5
  a curric:KeyLearningPoint ;
  rdfs:label """All the DNA in a cell is called the genome, the similarity of a genome indicates how similar individuals or species are."""@en ;
  dcterms:modified "2026-02-12T08:59:21.597259Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7955-1
  a curric:KeyLearningPoint ;
  rdfs:label """If conditions in the body change too much this can be dangerous to our health (e.g. enzymes)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.597268Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7955-2
  a curric:KeyLearningPoint ;
  rdfs:label """Homeostasis is the regulation of internal conditions for optimum enzyme activity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.597278Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7955-3
  a curric:KeyLearningPoint ;
  rdfs:label """Glucose travels in the blood plasma and is delivered to cells for aerobic respiration."""@en ;
  dcterms:modified "2026-02-12T08:59:21.597287Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7955-4
  a curric:KeyLearningPoint ;
  rdfs:label "The hormone insulin helps to keep human blood sugar level constant."@en ;
  dcterms:modified "2026-02-12T08:59:21.597297Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7955-5
  a curric:KeyLearningPoint ;
  rdfs:label """The pancreas secretes insulin when blood sugar level is too high; it causes liver cells to convert glucose to glycogen."""@en ;
  dcterms:modified "2026-02-12T08:59:21.597306Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9186-1
  a curric:KeyLearningPoint ;
  rdfs:label """Some pathogens are spread by direct contact, or transfer of body fluids, during sexual activity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.597316Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9186-2
  a curric:KeyLearningPoint ;
  rdfs:label """Gonorrhoea and chlamydia as examples of common sexually transmitted infections caused by bacteria."""@en ;
  dcterms:modified "2026-02-12T08:59:21.597325Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9186-3
  a curric:KeyLearningPoint ;
  rdfs:label """Ways to prevent the spread of gonorrhoea and chlamydia, and issues in treating them (including resistance)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.597334Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9186-4
  a curric:KeyLearningPoint ;
  rdfs:label """HIV as an example of a common sexually transmitted infection caused by a virus, and ways to prevent the spread."""@en ;
  dcterms:modified "2026-02-12T08:59:21.597344Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9186-5
  a curric:KeyLearningPoint ;
  rdfs:label """Effects of AIDS on the body, increased risk of other diseases (inc. TB), and management of progression in HIV+ people ."""@en ;
  dcterms:modified "2026-02-12T08:59:21.597353Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7978-1
  a curric:KeyLearningPoint ;
  rdfs:label "An individual inherits two copies  of each gene in a pair of chromosomes."@en ;
  dcterms:modified "2026-02-12T08:59:21.597363Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7978-2
  a curric:KeyLearningPoint ;
  rdfs:label """Versions of genes are called alleles, they can be recessive or dominant, indicated with a capital or lowercase letter."""@en ;
  dcterms:modified "2026-02-12T08:59:21.597373Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7978-3
  a curric:KeyLearningPoint ;
  rdfs:label "The combination of alleles that an organism has is called its genotype."@en ;
  dcterms:modified "2026-02-12T08:59:21.597388Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7978-4
  a curric:KeyLearningPoint ;
  rdfs:label """Different alleles of a gene are associated with different versions of the same characteristic called the phenotype."""@en ;
  dcterms:modified "2026-02-12T08:59:21.597398Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7978-5
  a curric:KeyLearningPoint ;
  rdfs:label """Some phenotypes are determined only by genotype, others are also affected by the environment."""@en ;
  dcterms:modified "2026-02-12T08:59:21.597413Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5546-1
  a curric:KeyLearningPoint ;
  rdfs:label "The human eye is a sense organ that detects light to enables us to see."@en ;
  dcterms:modified "2026-02-12T08:59:21.597596Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5546-2
  a curric:KeyLearningPoint ;
  rdfs:label """The functions of the cornea, iris, lens, ciliary muscles, retina and optic nerve."""@en ;
  dcterms:modified "2026-02-12T08:59:21.597606Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5546-3
  a curric:KeyLearningPoint ;
  rdfs:label """Interpretation of ray diagrams showing refraction, to explain how the eye focuses light onto the retina."""@en ;
  dcterms:modified "2026-02-12T08:59:21.597615Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5546-4
  a curric:KeyLearningPoint ;
  rdfs:label """The iris expands and contracts (a reflex response) to control the amount of light entering the eye through the pupil."""@en ;
  dcterms:modified "2026-02-12T08:59:21.597625Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5546-5
  a curric:KeyLearningPoint ;
  rdfs:label """Use appropriate techniques to investigate the size of the pupil in different light levels."""@en ;
  dcterms:modified "2026-02-12T08:59:21.597634Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5570-1
  a curric:KeyLearningPoint ;
  rdfs:label """The human body has an endocrine system that uses hormones to control changes in the body."""@en ;
  dcterms:modified "2026-02-12T08:59:21.597728Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5570-2
  a curric:KeyLearningPoint ;
  rdfs:label """Hormones are chemicals secreted by glands, transported in blood plasma and detected by receptors on cells and tissues."""@en ;
  dcterms:modified "2026-02-12T08:59:21.597737Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5570-3
  a curric:KeyLearningPoint ;
  rdfs:label """Changes in the body can be triggered by an increase in hormones (e.g. puberty) and a decrease in them (e.g. menopause)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.597746Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5570-4
  a curric:KeyLearningPoint ;
  rdfs:label """Changes in the body are detected by receptors; the nervous system sends nerve impulses to glands to secrete hormones."""@en ;
  dcterms:modified "2026-02-12T08:59:21.597756Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5564-1
  a curric:KeyLearningPoint ;
  rdfs:label """Particles of substances move into and out of the blood through selectively-permeable cell membranes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.597765Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5564-2
  a curric:KeyLearningPoint ;
  rdfs:label """Oxygen, carbon dioxide and other small particles move into and out of the blood by diffusion."""@en ;
  dcterms:modified "2026-02-12T08:59:21.597779Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5564-3
  a curric:KeyLearningPoint ;
  rdfs:label "Water moves into and out of the blood by osmosis, a type of diffusion."@en ;
  dcterms:modified "2026-02-12T08:59:21.597790Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5564-4
  a curric:KeyLearningPoint ;
  rdfs:label """The net movement of particles by diffusion and osmosis is down a concentration gradient."""@en ;
  dcterms:modified "2026-02-12T08:59:21.597799Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5564-5
  a curric:KeyLearningPoint ;
  rdfs:label """Large particles are moved into and out of the blood by active transport, which requires energy."""@en ;
  dcterms:modified "2026-02-12T08:59:21.597809Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5555-1
  a curric:KeyLearningPoint ;
  rdfs:label """Planning an investigation into the effect of pH on the rate at which amylase enzyme breaks down starch into maltose"""@en ;
  dcterms:modified "2026-02-12T08:59:21.597818Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5555-2
  a curric:KeyLearningPoint ;
  rdfs:label "Writing an aim for the investigation, and a testable prediction"@en ;
  dcterms:modified "2026-02-12T08:59:21.597828Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5555-3
  a curric:KeyLearningPoint ;
  rdfs:label "Identifying independent and dependent variables, and which factors to control"@en ;
  dcterms:modified "2026-02-12T08:59:21.597837Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5555-4
  a curric:KeyLearningPoint ;
  rdfs:label """Planning a method, to include use of iodine in continuous sampling to indicate when all starch has been broken down"""@en ;
  dcterms:modified "2026-02-12T08:59:21.597847Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5555-5
  a curric:KeyLearningPoint ;
  rdfs:label "Identifying hazards and risks, and how to limit them"@en ;
  dcterms:modified "2026-02-12T08:59:21.597857Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5563-1
  a curric:KeyLearningPoint ;
  rdfs:label """The parts of a light microscope and their functions, and the sequence of steps for setting up a light microscope."""@en ;
  dcterms:modified "2026-02-12T08:59:21.598159Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5563-2
  a curric:KeyLearningPoint ;
  rdfs:label "A light microscope can be used to observe blood cells on a prepared slide."@en ;
  dcterms:modified "2026-02-12T08:59:21.598173Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5563-3
  a curric:KeyLearningPoint ;
  rdfs:label """Observations from a light microscope can be recorded in a labelled scientific line drawing with an indication of scale."""@en ;
  dcterms:modified "2026-02-12T08:59:21.598184Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5563-4
  a curric:KeyLearningPoint ;
  rdfs:label """A light microscope can be used to observe sections of blood vessels and differences in the structures of their walls."""@en ;
  dcterms:modified "2026-02-12T08:59:21.598193Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5563-5
  a curric:KeyLearningPoint ;
  rdfs:label """Explaining observations from microscopy of differences in the walls of different blood vessels."""@en ;
  dcterms:modified "2026-02-12T08:59:21.598204Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5577-1
  a curric:KeyLearningPoint ;
  rdfs:label """Word and balanced symbol equations to summarise the chemical reactants and products of photosynthesis."""@en ;
  dcterms:modified "2026-02-12T08:59:21.598301Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5577-2
  a curric:KeyLearningPoint ;
  rdfs:label """Photosynthesis is an endothermic chemical process that requires energy from a light source such as the Sun."""@en ;
  dcterms:modified "2026-02-12T08:59:21.598311Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5577-3
  a curric:KeyLearningPoint ;
  rdfs:label """Light is not a chemical reactant, but transfers energy to chlorophyll to enable photosynthesis to take place."""@en ;
  dcterms:modified "2026-02-12T08:59:21.598321Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5577-4
  a curric:KeyLearningPoint ;
  rdfs:label """Photosynthesis occurs in chloroplasts in cells in green parts of plants, which contain chlorophyll to absorb light."""@en ;
  dcterms:modified "2026-02-12T08:59:21.598336Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5577-5
  a curric:KeyLearningPoint ;
  rdfs:label """Chloroplasts and stomata are adaptations of leaves for photosynthesis and gas exchange."""@en ;
  dcterms:modified "2026-02-12T08:59:21.598346Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5547-1
  a curric:KeyLearningPoint ;
  rdfs:label """The importance and difficulties of investigating brain function and damage, including safety and ethical considerations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.598563Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5547-2
  a curric:KeyLearningPoint ;
  rdfs:label "Use of fMRI and electrical stimulation to study the brain."@en ;
  dcterms:modified "2026-02-12T08:59:21.598573Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5547-3
  a curric:KeyLearningPoint ;
  rdfs:label """Difficulties in treating disease and damage in the nervous system and brain (e.g. lack of mitosis in neurones)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.598582Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5547-4
  a curric:KeyLearningPoint ;
  rdfs:label """Potential treatments for disease and damage in the nervous system and brain (e.g. stem cells)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.598590Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9189-1
  a curric:KeyLearningPoint ;
  rdfs:label "Tobacco mosaic virus is an example of a disease in plants caused by a virus."@en ;
  dcterms:modified "2026-02-12T08:59:21.599041Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9189-2
  a curric:KeyLearningPoint ;
  rdfs:label "Crown gall disease is an example of a disease in plants caused by a bacterium."@en ;
  dcterms:modified "2026-02-12T08:59:21.599051Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9189-3
  a curric:KeyLearningPoint ;
  rdfs:label "Barley powdery mildew is an example of a disease in plants caused by a fungus."@en ;
  dcterms:modified "2026-02-12T08:59:21.599060Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9189-4
  a curric:KeyLearningPoint ;
  rdfs:label """Ways in which plant diseases can be spread, and ways in which the spread can be reduced."""@en ;
  dcterms:modified "2026-02-12T08:59:21.599069Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9189-5
  a curric:KeyLearningPoint ;
  rdfs:label "Impacts of plant diseases, including on biodiversity and human food security."@en ;
  dcterms:modified "2026-02-12T08:59:21.599077Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5576-1
  a curric:KeyLearningPoint ;
  rdfs:label """Producers use photosynthesis to make their own food in the form of glucose (a simple carbohydrate)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.599135Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5576-2
  a curric:KeyLearningPoint ;
  rdfs:label """Consumers can only get food by eating producers or other consumers; producers are the source of food for food chains."""@en ;
  dcterms:modified "2026-02-12T08:59:21.599145Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5576-3
  a curric:KeyLearningPoint ;
  rdfs:label """Consumers cannot use carbon and nitrogen from the environment to make biomass; they get them by eating producers."""@en ;
  dcterms:modified "2026-02-12T08:59:21.599160Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5576-4
  a curric:KeyLearningPoint ;
  rdfs:label """Producers and consumers use the carbohydrate from photosynthesis to make biomass for growth and as fuel for respiration."""@en ;
  dcterms:modified "2026-02-12T08:59:21.599169Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5576-5
  a curric:KeyLearningPoint ;
  rdfs:label """Consumers also depend upon producers to add oxygen to the atmosphere, which they use for aerobic cellular respiration."""@en ;
  dcterms:modified "2026-02-12T08:59:21.599177Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7953-1
  a curric:KeyLearningPoint ;
  rdfs:label "The human brain is an organ made of billions of neurones."@en ;
  dcterms:modified "2026-02-12T08:59:21.599740Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7953-2
  a curric:KeyLearningPoint ;
  rdfs:label "The brain acts as the processing centre for the nervous system."@en ;
  dcterms:modified "2026-02-12T08:59:21.599751Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7953-3
  a curric:KeyLearningPoint ;
  rdfs:label """Key regions of the brain (e.g. cerebral cortex, cerebellum, brain stem) and the processes they regulate."""@en ;
  dcterms:modified "2026-02-12T08:59:21.599759Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9183-1
  a curric:KeyLearningPoint ;
  rdfs:label """Some, but not all, bacteria are pathogens that can cause communicable diseases in humans."""@en ;
  dcterms:modified "2026-02-12T08:59:21.599866Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9183-2
  a curric:KeyLearningPoint ;
  rdfs:label "Pathogenic bacteria produce toxins that damage living tissue and cause disease."@en ;
  dcterms:modified "2026-02-12T08:59:21.599875Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9183-3
  a curric:KeyLearningPoint ;
  rdfs:label """Cholera, TB and Helicobacter stomach ulcers as example; how they are spread, and how the spread can be reduced."""@en ;
  dcterms:modified "2026-02-12T08:59:21.599884Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9183-4
  a curric:KeyLearningPoint ;
  rdfs:label "Viruses invade cells to reproduce where they cause damage to cells."@en ;
  dcterms:modified "2026-02-12T08:59:21.599893Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9183-5
  a curric:KeyLearningPoint ;
  rdfs:label """Ebola as an example of a viral disease; how it is spread, and how the spread can be reduced."""@en ;
  dcterms:modified "2026-02-12T08:59:21.599901Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5572-1
  a curric:KeyLearningPoint ;
  rdfs:label "If conditions in the body change too much, this can be dangerous to our health."@en ;
  dcterms:modified "2026-02-12T08:59:21.600702Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5572-2
  a curric:KeyLearningPoint ;
  rdfs:label "Glucose travels in the blood and is delivered to cells for respiration."@en ;
  dcterms:modified "2026-02-12T08:59:21.600710Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5572-3
  a curric:KeyLearningPoint ;
  rdfs:label "The hormones insulin and glucagon help to keep human blood sugar level constant."@en ;
  dcterms:modified "2026-02-12T08:59:21.600722Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5572-4
  a curric:KeyLearningPoint ;
  rdfs:label """The pancreas secretes insulin when blood sugar level is too high; the liver absorbs glucose and coverts it to glycogen."""@en ;
  dcterms:modified "2026-02-12T08:59:21.600731Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5572-5
  a curric:KeyLearningPoint ;
  rdfs:label """The pancreas secretes glucagon when blood sugar level is too low; the liver converts glycogen into glucose in the blood."""@en ;
  dcterms:modified "2026-02-12T08:59:21.600740Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9187-1
  a curric:KeyLearningPoint ;
  rdfs:label "Plant health can be affected by mineral deficiencies and pathogens."@en ;
  dcterms:modified "2026-02-12T08:59:21.600921Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9187-2
  a curric:KeyLearningPoint ;
  rdfs:label "Tobacco mosaic virus is an example of a disease in plants caused by a virus."@en ;
  dcterms:modified "2026-02-12T08:59:21.600929Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9187-3
  a curric:KeyLearningPoint ;
  rdfs:label "Rose black spot is an example of a disease in plants caused by a fungus."@en ;
  dcterms:modified "2026-02-12T08:59:21.600938Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9187-4
  a curric:KeyLearningPoint ;
  rdfs:label """Ways in which plant diseases can be spread, and ways in which the spread can be reduced."""@en ;
  dcterms:modified "2026-02-12T08:59:21.600946Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9187-5
  a curric:KeyLearningPoint ;
  rdfs:label "Impacts of plant diseases, including on biodiversity and human food security."@en ;
  dcterms:modified "2026-02-12T08:59:21.600958Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7157-1
  a curric:KeyLearningPoint ;
  rdfs:label """The good health of humans, other animals and plants can be compromised by diseases."""@en ;
  dcterms:modified "2026-02-12T08:59:21.601435Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7157-2
  a curric:KeyLearningPoint ;
  rdfs:label """Communicable diseases are spread by pathogens, including some bacteria, viruses, fungi and protists."""@en ;
  dcterms:modified "2026-02-12T08:59:21.601443Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7157-3
  a curric:KeyLearningPoint ;
  rdfs:label """Non-communicable diseases cannot be spread between organisms; they are caused by lifestyle and environmental factors."""@en ;
  dcterms:modified "2026-02-12T08:59:21.601471Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7157-4
