  dcterms:modified "2026-02-12T08:59:15.817094Z"^^xsd:dateTime .

oakcurric:keyword-side-effect
  a curric:Keyword ;
  schema:name "side effect"@en ;
  schema:description "An undesirable effect of a medicine or treatment."@en ;
  dcterms:modified "2026-02-12T08:59:15.817098Z"^^xsd:dateTime .

oakcurric:keyword-placebo
  a curric:Keyword ;
  schema:name "placebo"@en ;
  schema:description "A treatment or substance designed to have no therapeutic value."@en ;
  dcterms:modified "2026-02-12T08:59:15.817102Z"^^xsd:dateTime .

oakcurric:keyword-limiting-factor
  a curric:Keyword ;
  schema:name "limiting factor"@en ;
  schema:description """A condition that when in short supply slows down or limits the rate of photosynthesis."""@en ;
  dcterms:modified "2026-02-12T08:59:15.817107Z"^^xsd:dateTime .

oakcurric:keyword-vasoconstriction
  a curric:Keyword ;
  schema:name "vasoconstriction"@en ;
  schema:description "The narrowing of blood vessels, reducing blood flow through them."@en ;
  dcterms:modified "2026-02-12T08:59:15.817111Z"^^xsd:dateTime .

oakcurric:keyword-insulation
  a curric:Keyword ;
  schema:name "insulation"@en ;
  schema:description "A material that transfers energy by conduction very slowly or not at all."@en ;
  dcterms:modified "2026-02-12T08:59:15.817115Z"^^xsd:dateTime .

oakcurric:keyword-vasodilation
  a curric:Keyword ;
  schema:name "vasodilation"@en ;
  schema:description "The widening of blood vessels, increasing blood flow through them."@en ;
  dcterms:modified "2026-02-12T08:59:15.817119Z"^^xsd:dateTime .

oakcurric:keyword-antibiotics
  a curric:Keyword ;
  schema:name "antibiotics"@en ;
  schema:description "Antibiotics are substances that slow down or stop the growth of bacteria"@en ;
  dcterms:modified "2026-02-12T08:59:15.818305Z"^^xsd:dateTime .

oakcurric:keyword-bacterial-cell-wall
  a curric:Keyword ;
  schema:name "bacterial cell wall"@en ;
  schema:description """The bacterial cell wall is made of murein, which is strong enough to withstand osmotic pressure while also allowing substances to pass through."""@en ;
  dcterms:modified "2026-02-12T08:59:15.818310Z"^^xsd:dateTime .

oakcurric:keyword-antibiotic-resistance
  a curric:Keyword ;
  schema:name "antibiotic resistance"@en ;
  schema:description "When bacteria mutate and become less susceptible to the action of antibiotics."@en ;
  dcterms:modified "2026-02-12T08:59:15.818314Z"^^xsd:dateTime .

oakcurric:keyword-lh
  a curric:Keyword ;
  schema:name "LH"@en ;
  schema:description "luteinising hormone causes ovulation"@en ;
  dcterms:modified "2026-02-12T08:59:15.818526Z"^^xsd:dateTime .

oakcurric:keyword-oestrogen
  a curric:Keyword ;
  schema:name "oestrogen"@en ;
  schema:description """a hormone that causes thickening of the uterus lining and the release of LH from the pituitary gland"""@en ;
  dcterms:modified "2026-02-12T08:59:15.818531Z"^^xsd:dateTime .

oakcurric:keyword-progesterone
  a curric:Keyword ;
  schema:name "progesterone"@en ;
  schema:description """maintains the uterus lining and stops the release of FSH and LH from the pituitary gland"""@en ;
  dcterms:modified "2026-02-12T08:59:15.818535Z"^^xsd:dateTime .

oakcurric:keyword-electron-microscope
  a curric:Keyword ;
  schema:name "electron microscope"@en ;
  schema:description """A type of microscope that uses a beam of electrons instead of light to magnify objects."""@en ;
  dcterms:modified "2026-02-12T08:59:15.818961Z"^^xsd:dateTime .

oakcurric:keyword-potometer
  a curric:Keyword ;
  schema:name "potometer"@en ;
  schema:description "a piece of equipment used to measure the rate of water uptake by a plant"@en ;
  dcterms:modified "2026-02-12T08:59:15.818976Z"^^xsd:dateTime .

oakcurric:keyword-urea
  a curric:Keyword ;
  schema:name "urea"@en ;
  schema:description """a waste product created in the process of breaking down excess proteins and amino acids"""@en ;
  dcterms:modified "2026-02-12T08:59:15.820118Z"^^xsd:dateTime .

oakcurric:keyword-blood-plasma
  a curric:Keyword ;
  schema:name "blood plasma"@en ;
  schema:description """the liquid part of the blood which contains dissolved nutrients and waste products"""@en ;
  dcterms:modified "2026-02-12T08:59:15.820122Z"^^xsd:dateTime .

oakcurric:keyword-kidney
  a curric:Keyword ;
  schema:name "kidney"@en ;
  schema:description """the organ in the excretory system which filters waste products from blood plasma and controls water balance"""@en ;
  dcterms:modified "2026-02-12T08:59:15.820126Z"^^xsd:dateTime .

oakcurric:keyword-excretory-system
  a curric:Keyword ;
  schema:name "excretory system"@en ;
  schema:description "the organ system responsible for removing waste from blood plasma"@en ;
  dcterms:modified "2026-02-12T08:59:15.820133Z"^^xsd:dateTime .

oakcurric:keyword-urine
  a curric:Keyword ;
  schema:name "urine"@en ;
  schema:description """a combination of waste urea, water and other substances which is stored in the bladder until urinated"""@en ;
  dcterms:modified "2026-02-12T08:59:15.820137Z"^^xsd:dateTime .

oakcurric:keyword-adh
  a curric:Keyword ;
  schema:name "ADH"@en ;
  schema:description """Anti-diuretic hormone, secreted by the pituitary gland, which increases the permeability of the kidney tubules."""@en ;
  dcterms:modified "2026-02-12T08:59:15.820142Z"^^xsd:dateTime .

oakcurric:keyword-monoclonal-antibodies
  a curric:Keyword ;
  schema:name "monoclonal antibodies"@en ;
  schema:description "Antibodies produced from a single clone of a hybridoma."@en ;
  dcterms:modified "2026-02-12T08:59:15.820258Z"^^xsd:dateTime .

oakcurric:keyword-tumour-cell
  a curric:Keyword ;
  schema:name "tumour cell"@en ;
  schema:description "A cell that undergoes uncontrolled cell division."@en ;
  dcterms:modified "2026-02-12T08:59:15.820262Z"^^xsd:dateTime .

oakcurric:keyword-hybridoma
  a curric:Keyword ;
  schema:name "hybridoma"@en ;
  schema:description "An antibody-producing lymphocyte and a tumour cell fused together."@en ;
  dcterms:modified "2026-02-12T08:59:15.820267Z"^^xsd:dateTime .

oakcurric:keyword-turgid
  a curric:Keyword ;
  schema:name "turgid"@en ;
  schema:description "a cell which is swollen with water and firm"@en ;
  dcterms:modified "2026-02-12T08:59:15.820465Z"^^xsd:dateTime .

oakcurric:keyword-flaccid
  a curric:Keyword ;
  schema:name "flaccid"@en ;
  schema:description "a cell which has lost a lot of water and is soft and limp"@en ;
  dcterms:modified "2026-02-12T08:59:15.820470Z"^^xsd:dateTime .

oakcurric:keyword-trend
  a curric:Keyword ;
  schema:name "trend"@en ;
  schema:description "a pattern in data"@en ;
  dcterms:modified "2026-02-12T08:59:15.821770Z"^^xsd:dateTime .

oakcurric:keyword-gene-expression
  a curric:Keyword ;
  schema:name "gene expression"@en ;
  schema:description """The process in which genes are copied during the first step in protein synthesis."""@en ;
  dcterms:modified "2026-02-12T08:59:15.821774Z"^^xsd:dateTime .

oakcurric:keyword-auxin
  a curric:Keyword ;
  schema:name "auxin"@en ;
  schema:description "plant hormones that affect the growth of plants"@en ;
  dcterms:modified "2026-02-12T08:59:15.823153Z"^^xsd:dateTime .

oakcurric:keyword-scientific-line-drawing
  a curric:Keyword ;
  schema:name "scientific line drawing"@en ;
