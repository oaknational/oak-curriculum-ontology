<https://w3id.org/uk/oak/curriculum/oakcurriculum/biology-ks4>
  rdf:type owl:Ontology ;

  rdfs:label "Oak Curriculum Data - Biology KS4 Instance Data"@en ;
  dc:title "Oak Curriculum Data - Biology KS4 Instance Data"@en ;
  rdfs:comment """Instance data defining the Oak National Academy Curriculum
  programmes for Biology KS4."""@en ;

  owl:versionInfo "0.1.0" ;
  owl:versionIRI <https://w3id.org/uk/oak/curriculum/oakcurriculum/biology-ks4/0.1.0> ;

  dcterms:description """This file contains Programme, Unit, Unit Variant, and Lesson instances for
  Biology KS4, including exam board-specific unit variants and lesson sequences."""@en ;
  dc:creator "Oak National Academy" ;
