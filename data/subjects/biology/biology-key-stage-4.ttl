  dcterms:modified "2026-02-12T08:59:15.800484Z"^^xsd:dateTime .

oakcurric:keyword-resolution
  a curric:Keyword ;
  schema:name "resolution"@en ;
  schema:description "the point where the problems in a story are resolved"@en ;
  dcterms:modified "2026-02-12T08:59:15.800780Z"^^xsd:dateTime .

oakcurric:keyword-sustainability
  a curric:Keyword ;
  schema:name "sustainability"@en ;
  schema:description """Sustainability means using resources wisely without depleting them for future generations."""@en ;
  dcterms:modified "2026-02-12T08:59:15.801713Z"^^xsd:dateTime .

oakcurric:keyword-transect
  a curric:Keyword ;
  schema:name "transect"@en ;
  schema:description "an imaginary line along which samples of data are collected"@en ;
  dcterms:modified "2026-02-12T08:59:15.802443Z"^^xsd:dateTime .

oakcurric:keyword-quadrat
  a curric:Keyword ;
  schema:name "quadrat"@en ;
  schema:description "a square frame used at ground level to show the limits of a sample area"@en ;
  dcterms:modified "2026-02-12T08:59:15.802456Z"^^xsd:dateTime .

oakcurric:keyword-abundance
  a curric:Keyword ;
  schema:name "abundance"@en ;
  schema:description "a very large quantity of something"@en ;
  dcterms:modified "2026-02-12T08:59:15.802774Z"^^xsd:dateTime .

oakcurric:keyword-sampling
  a curric:Keyword ;
  schema:name "sampling"@en ;
  schema:description """the process of selecting a sample of data to study from a much larger population of data"""@en ;
  dcterms:modified "2026-02-12T08:59:15.803843Z"^^xsd:dateTime .

oakcurric:keyword-bias
  a curric:Keyword ;
  schema:name "bias"@en ;
  schema:description "an unfair favouritism for or against something"@en ;
  dcterms:modified "2026-02-12T08:59:15.803858Z"^^xsd:dateTime .

oakcurric:keyword-conclusion
  a curric:Keyword ;
  schema:name "conclusion"@en ;
  schema:description """the final part of a text that summarises the main points, providing closure to the subject"""@en ;
  dcterms:modified "2026-02-12T08:59:15.804054Z"^^xsd:dateTime .

oakcurric:keyword-nucleotides
  a curric:Keyword ;
  schema:name "nucleotides"@en ;
  schema:description "Individual subunits that make up DNA."@en ;
  dcterms:modified "2026-02-12T08:59:15.804063Z"^^xsd:dateTime .

oakcurric:keyword-complementary-base-pairing
  a curric:Keyword ;
  schema:name "complementary base pairing"@en ;
  schema:description "Bases form pairs with one other base: A pairs with T, and C pairs with G."@en ;
  dcterms:modified "2026-02-12T08:59:15.804069Z"^^xsd:dateTime .

oakcurric:keyword-abiotic-factor
  a curric:Keyword ;
  schema:name "abiotic factor"@en ;
  schema:description "Abiotic factors are the non-living components of an ecosystem."@en ;
  dcterms:modified "2026-02-12T08:59:15.804075Z"^^xsd:dateTime .

oakcurric:keyword-mutation
  a curric:Keyword ;
  schema:name "mutation"@en ;
  schema:description "A change in the nucleotide sequence of DNA that can cause mutated genes."@en ;
  dcterms:modified "2026-02-12T08:59:15.804093Z"^^xsd:dateTime .

oakcurric:keyword-genes
  a curric:Keyword ;
  schema:name "genes"@en ;
  schema:description "Short sections of DNA that code for a specific characteristic or protein."@en ;
  dcterms:modified "2026-02-12T08:59:15.804097Z"^^xsd:dateTime .

oakcurric:keyword-competition
  a curric:Keyword ;
  schema:name "competition"@en ;
  schema:description """Competition is when organisms in a community or population are seeking the same limited resource (e.g. food, mates)."""@en ;
  dcterms:modified "2026-02-12T08:59:15.804101Z"^^xsd:dateTime .

oakcurric:keyword-physiological
  a curric:Keyword ;
  schema:name "physiological"@en ;
  schema:description """Physiological adaptations are body processes that help an organism to survive and reproduce."""@en ;
  dcterms:modified "2026-02-12T08:59:15.804106Z"^^xsd:dateTime .

oakcurric:keyword-microorganism
  a curric:Keyword ;
  schema:name "microorganism"@en ;
  schema:description "A microorganism is an organism that can only be seen using a microscope."@en ;
  dcterms:modified "2026-02-12T08:59:15.804110Z"^^xsd:dateTime .

oakcurric:keyword-extremophile
  a curric:Keyword ;
  schema:name "extremophile"@en ;
  schema:description """Extremophiles are organisms that are able to successfully survive and reproduce in extreme environments (e.g. very hot/very cold)."""@en ;
  dcterms:modified "2026-02-12T08:59:15.804114Z"^^xsd:dateTime .

oakcurric:keyword-decomposer
  a curric:Keyword ;
  schema:name "decomposer"@en ;
  schema:description """A decomposer is an organism that feeds on the remains of other living organisms (organic matter)."""@en ;
  dcterms:modified "2026-02-12T08:59:15.804927Z"^^xsd:dateTime .

oakcurric:keyword-decay
  a curric:Keyword ;
  schema:name "decay"@en ;
  schema:description """Decay is the breakdown (or rotting) of organic matter by bacteria, fungi, or other organisms."""@en ;
  dcterms:modified "2026-02-12T08:59:15.804933Z"^^xsd:dateTime .

oakcurric:keyword-detritus
  a curric:Keyword ;
  schema:name "detritus"@en ;
  schema:description "Detritus is the remains of living organisms."@en ;
  dcterms:modified "2026-02-12T08:59:15.804939Z"^^xsd:dateTime .

oakcurric:keyword-evolution
  a curric:Keyword ;
  schema:name "evolution"@en ;
  schema:description """The process in which the characteristics of species change over many generations, sometimes becoming new species."""@en ;
  dcterms:modified "2026-02-12T08:59:15.804944Z"^^xsd:dateTime .

oakcurric:keyword-natural-selection
  a curric:Keyword ;
  schema:name "natural selection"@en ;
  schema:description """Organisms that are better adapted to their environment are more likely to survive, reproduce and pass on their genes to their offspring."""@en ;
  dcterms:modified "2026-02-12T08:59:15.804948Z"^^xsd:dateTime .

oakcurric:keyword-artificial-selection
  a curric:Keyword ;
  schema:name "artificial selection"@en ;
  schema:description """The process in which humans choose organisms with desirable traits and breed them in order to make offspring with these desirable traits. Also known as selective breeding."""@en ;
  dcterms:modified "2026-02-12T08:59:15.804952Z"^^xsd:dateTime .

oakcurric:keyword-antagonistic
  a curric:Keyword ;
  schema:name "antagonistic"@en ;
  schema:description "showing or feeling active opposition or hostility towards someone or something"@en ;
  dcterms:modified "2026-02-12T08:59:15.805371Z"^^xsd:dateTime .

oakcurric:keyword-specialised-cell
  a curric:Keyword ;
  schema:name "specialised cell"@en ;
  schema:description """Cells with adaptations to carry out a particular function in a multicellular organism."""@en ;
  dcterms:modified "2026-02-12T08:59:15.805376Z"^^xsd:dateTime .

oakcurric:keyword-unspecialised-cell
  a curric:Keyword ;
  schema:name "unspecialised cell"@en ;
  schema:description """Cell with no specific function, but has the capability to turn into different types of cells."""@en ;
  dcterms:modified "2026-02-12T08:59:15.805380Z"^^xsd:dateTime .

oakcurric:keyword-differentiation
  a curric:Keyword ;
  schema:name "differentiation"@en ;
  schema:description """The process of an unspecialised cell becoming a specialised one through the mechanism of turning genes on and off."""@en ;
  dcterms:modified "2026-02-12T08:59:15.805384Z"^^xsd:dateTime .

oakcurric:keyword-species
  a curric:Keyword ;
  schema:name "species"@en ;
  schema:description "A group of similar organisms that can reproduce and produce fertile offspring."@en ;
  dcterms:modified "2026-02-12T08:59:15.805458Z"^^xsd:dateTime .

oakcurric:keyword-speciation
  a curric:Keyword ;
  schema:name "speciation"@en ;
  schema:description "When natural selection causes new species to form."@en ;
  dcterms:modified "2026-02-12T08:59:15.805463Z"^^xsd:dateTime .

oakcurric:keyword-fossil-record
  a curric:Keyword ;
  schema:name "fossil record"@en ;
  schema:description """All the fossils ever found, and their ages, provide a body of evidence called the fossil record."""@en ;
  dcterms:modified "2026-02-12T08:59:15.805528Z"^^xsd:dateTime .

oakcurric:keyword-common-ancestor
  a curric:Keyword ;
  schema:name "common ancestor"@en ;
  schema:description """A species that several other species evolved from. For example, tigers and lions share a common ancestor."""@en ;
  dcterms:modified "2026-02-12T08:59:15.805533Z"^^xsd:dateTime .

oakcurric:keyword-evolutionary-tree
  a curric:Keyword ;
  schema:name "evolutionary tree"@en ;
  schema:description """A diagram that shows the evolutionary relationships between different groups of organisms."""@en ;
  dcterms:modified "2026-02-12T08:59:15.805537Z"^^xsd:dateTime .

oakcurric:keyword-transitional-species
  a curric:Keyword ;
  schema:name "transitional species"@en ;
  schema:description """A species that shows intermediate characteristics from evolutionary ancestors and modern species."""@en ;
  dcterms:modified "2026-02-12T08:59:15.805541Z"^^xsd:dateTime .

oakcurric:keyword-accurate
  a curric:Keyword ;
  schema:name "accurate"@en ;
  schema:description "being exact and precise"@en ;
  dcterms:modified "2026-02-12T08:59:15.805937Z"^^xsd:dateTime .

oakcurric:keyword-fossil
  a curric:Keyword ;
  schema:name "fossil"@en ;
  schema:description """Fossils are the mineralised remains of once-living organisms, or of traces left behind by organisms."""@en ;
  dcterms:modified "2026-02-12T08:59:15.805978Z"^^xsd:dateTime .

oakcurric:keyword-extinct
  a curric:Keyword ;
  schema:name "extinct"@en ;
  schema:description "An extinct species has no living members."@en ;
  dcterms:modified "2026-02-12T08:59:15.805983Z"^^xsd:dateTime .

oakcurric:keyword-embryonic-stem-cell
  a curric:Keyword ;
  schema:name "embryonic stem cell"@en ;
  schema:description """A cell taken from the embryo that can differentiate into any type of specialised cell."""@en ;
  dcterms:modified "2026-02-12T08:59:15.805996Z"^^xsd:dateTime .

oakcurric:keyword-adult-stem-cell
  a curric:Keyword ;
  schema:name "adult stem cell"@en ;
  schema:description """A cell found in specific regions of the body that can differentiate into a limited number of related specialised cells."""@en ;
  dcterms:modified "2026-02-12T08:59:15.806000Z"^^xsd:dateTime .

oakcurric:keyword-immune-rejection
  a curric:Keyword ;
  schema:name "immune rejection"@en ;
  schema:description "When a patient’s immune system attacks non-self cells (e.g. transplants)."@en ;
  dcterms:modified "2026-02-12T08:59:15.806004Z"^^xsd:dateTime .

oakcurric:keyword-embryo
  a curric:Keyword ;
  schema:name "embryo"@en ;
  schema:description "Formed from a zygote by cell division; it is the early stages of development."@en ;
  dcterms:modified "2026-02-12T08:59:15.806017Z"^^xsd:dateTime .

oakcurric:keyword-selective-breeding
  a curric:Keyword ;
  schema:name "Selective breeding"@en ;
  schema:description """The process in which humans choose individuals with desirable traits and mate them in order to make offspring with these desirable traits."""@en ;
  dcterms:modified "2026-02-12T08:59:15.806429Z"^^xsd:dateTime .

oakcurric:keyword-crop
  a curric:Keyword ;
  schema:name "Crop"@en ;
  schema:description "Plants grown on a large scale for food or profit."@en ;
  dcterms:modified "2026-02-12T08:59:15.806433Z"^^xsd:dateTime .

oakcurric:keyword-farm-animal
  a curric:Keyword ;
  schema:name "Farm animal"@en ;
  schema:description "Animals that are kept on farms for food or work."@en ;
  dcterms:modified "2026-02-12T08:59:15.806437Z"^^xsd:dateTime .

oakcurric:keyword-meristem
  a curric:Keyword ;
  schema:name "meristem"@en ;
  schema:description """unspecialised cells that undergo mitosis and can differentiate into any type of plant cell"""@en ;
  dcterms:modified "2026-02-12T08:59:15.806631Z"^^xsd:dateTime .

oakcurric:keyword-shoot
  a curric:Keyword ;
  schema:name "shoot"@en ;
  schema:description "where new plant growth occurs above the ground"@en ;
  dcterms:modified "2026-02-12T08:59:15.806637Z"^^xsd:dateTime .

oakcurric:keyword-root
  a curric:Keyword ;
  schema:name "root"@en ;
  schema:description "where new plant growth occurs underground"@en ;
  dcterms:modified "2026-02-12T08:59:15.806642Z"^^xsd:dateTime .

oakcurric:keyword-xylem
  a curric:Keyword ;
  schema:name "xylem"@en ;
  schema:description "a plant tissue that transports water upwards through the plant"@en ;
  dcterms:modified "2026-02-12T08:59:15.806646Z"^^xsd:dateTime .

oakcurric:keyword-phloem
  a curric:Keyword ;
  schema:name "phloem"@en ;
  schema:description "a plant tissue that transports sugars through the plant"@en ;
  dcterms:modified "2026-02-12T08:59:15.806650Z"^^xsd:dateTime .

oakcurric:keyword-gametes
  a curric:Keyword ;
  schema:name "gametes"@en ;
  schema:description "An organism's sex cells that contain half the number of chromosomes."@en ;
  dcterms:modified "2026-02-12T08:59:15.806687Z"^^xsd:dateTime .

oakcurric:keyword-meiosis
  a curric:Keyword ;
  schema:name "meiosis"@en ;
  schema:description "A type of cell division that forms the gametes."@en ;
  dcterms:modified "2026-02-12T08:59:15.806691Z"^^xsd:dateTime .

oakcurric:keyword-haploid
  a curric:Keyword ;
  schema:name "haploid"@en ;
  schema:description "A cell with half the number of chromosomes."@en ;
  dcterms:modified "2026-02-12T08:59:15.806695Z"^^xsd:dateTime .

oakcurric:keyword-extinction
  a curric:Keyword ;
  schema:name "extinction"@en ;
  schema:description "Extinction is the permanent loss of a species"@en ;
  dcterms:modified "2026-02-12T08:59:15.807954Z"^^xsd:dateTime .

oakcurric:keyword-accuracy
  a curric:Keyword ;
  schema:name "accuracy"@en ;
  schema:description """a measurement result is considered accurate if it is judged to be close to the true value"""@en ;
  dcterms:modified "2026-02-12T08:59:15.808059Z"^^xsd:dateTime .

oakcurric:keyword-error
  a curric:Keyword ;
  schema:name "error"@en ;
  schema:description """an error leads to measurements being different to what they would otherwise be (the true value)"""@en ;
  dcterms:modified "2026-02-12T08:59:15.808064Z"^^xsd:dateTime .

oakcurric:keyword-precision
  a curric:Keyword ;
  schema:name "precision"@en ;
  schema:description "the spread of results around the mean value"@en ;
  dcterms:modified "2026-02-12T08:59:15.808068Z"^^xsd:dateTime .

oakcurric:keyword-repeatability
  a curric:Keyword ;
  schema:name "repeatability"@en ;
  schema:description """measurements are similar when repeated by the same person or group using the same equipment and method"""@en ;
  dcterms:modified "2026-02-12T08:59:15.808072Z"^^xsd:dateTime .

oakcurric:keyword-reproducibility
  a curric:Keyword ;
  schema:name "reproducibility"@en ;
  schema:description """similar results are obtained when an investigation is repeated by another person or group using different equipment"""@en ;
  dcterms:modified "2026-02-12T08:59:15.808076Z"^^xsd:dateTime .

oakcurric:keyword-biotechnology
  a curric:Keyword ;
  schema:name "biotechnology"@en ;
  schema:description """use of technology to modify organic products or processes, for example, genetically-engineering crops"""@en ;
  dcterms:modified "2026-02-12T08:59:15.808341Z"^^xsd:dateTime .

oakcurric:keyword-carbon-sink
  a curric:Keyword ;
  schema:name "carbon sink"@en ;
  schema:description "a natural or artificial system that absorbs more carbon dioxide than it releases"@en ;
  dcterms:modified "2026-02-12T08:59:15.808500Z"^^xsd:dateTime .

oakcurric:keyword-light-intensity
  a curric:Keyword ;
  schema:name "light intensity"@en ;
  schema:description "the amount of light reaching a given surface area in a period of time"@en ;
  dcterms:modified "2026-02-12T08:59:15.808513Z"^^xsd:dateTime .

oakcurric:keyword-light-source
  a curric:Keyword ;
  schema:name "light source"@en ;
  schema:description "an object that emits light"@en ;
  dcterms:modified "2026-02-12T08:59:15.808519Z"^^xsd:dateTime .

oakcurric:keyword-light-waves
  a curric:Keyword ;
  schema:name "light waves"@en ;
  schema:description "oscillations/ripples in electric and magnetic fields"@en ;
  dcterms:modified "2026-02-12T08:59:15.808526Z"^^xsd:dateTime .

oakcurric:keyword-inversely-proportional
  a curric:Keyword ;
  schema:name "inversely proportional"@en ;
  schema:description """variables are inversely proportional when one increases and the other decreases at the same (proportional) rate, e.g. as one variable doubles, the other variable halves"""@en ;
  dcterms:modified "2026-02-12T08:59:15.808532Z"^^xsd:dateTime .

oakcurric:keyword-inverse-square-law
  a curric:Keyword ;
  schema:name "inverse square law"@en ;
  schema:description """light intensity is inversely proportional to the square of the distance from the light source"""@en ;
  dcterms:modified "2026-02-12T08:59:15.808537Z"^^xsd:dateTime .

oakcurric:keyword-fertiliser
  a curric:Keyword ;
  schema:name "fertiliser"@en ;
  schema:description "Fertiliser are minerals that are added to the soil to help plants to grow."@en ;
  dcterms:modified "2026-02-12T08:59:15.809028Z"^^xsd:dateTime .

oakcurric:keyword-eutrophication
  a curric:Keyword ;
  schema:name "eutrophication"@en ;
  schema:description """Eutrophication is the process in which a body of water is overly enriched with plant nutrients. This leads to excessive growth of simple plants such as algae."""@en ;
  dcterms:modified "2026-02-12T08:59:15.809034Z"^^xsd:dateTime .

oakcurric:keyword-indigenous-species
  a curric:Keyword ;
  schema:name "indigenous species"@en ;
  schema:description """Indigenous species are a species that occurs naturally in an ecosystem. They are sometimes referred to as native species."""@en ;
  dcterms:modified "2026-02-12T08:59:15.809039Z"^^xsd:dateTime .

oakcurric:keyword-estimate
  a curric:Keyword ;
  schema:name "Estimate"@en ;
  schema:description """Estimation means to find a value that is close enough to the right answer, usually with some thought or calculation involved."""@en ;
  dcterms:modified "2026-02-12T08:59:15.809426Z"^^xsd:dateTime .

oakcurric:keyword-radiation
  a curric:Keyword ;
  schema:name "radiation"@en ;
  schema:description """a form of energy that, when it comes from a nuclear explosion, can be very dangerous to health"""@en ;
  dcterms:modified "2026-02-12T08:59:15.810251Z"^^xsd:dateTime .

oakcurric:keyword-concentration
  a curric:Keyword ;
  schema:name "concentration"@en ;
  schema:description """A measure of the quantity of a dissolved substance in a given volume of solution."""@en ;
  dcterms:modified "2026-02-12T08:59:15.810826Z"^^xsd:dateTime .

oakcurric:keyword-optimum
  a curric:Keyword ;
  schema:name "optimum"@en ;
  schema:description "The conditions under which the maximum rate of reaction occurs."@en ;
  dcterms:modified "2026-02-12T08:59:15.810830Z"^^xsd:dateTime .

oakcurric:keyword-denatured
  a curric:Keyword ;
  schema:name "denatured"@en ;
  schema:description """A permanent change in the shape of an enzyme that stops it from working properly."""@en ;
  dcterms:modified "2026-02-12T08:59:15.810837Z"^^xsd:dateTime .

oakcurric:keyword-cytoplasm
  a curric:Keyword ;
  schema:name "cytoplasm"@en ;
  schema:description """A jelly-like substance containing dissolved nutrients and salts where many chemical reactions happen."""@en ;
  dcterms:modified "2026-02-12T08:59:15.810841Z"^^xsd:dateTime .

oakcurric:keyword-cell-membrane
  a curric:Keyword ;
  schema:name "cell membrane"@en ;
  schema:description """A partially permeable structure that surrounds the cell; it controls the movement of substances into and out of the cell."""@en ;
  dcterms:modified "2026-02-12T08:59:15.810846Z"^^xsd:dateTime .

oakcurric:keyword-mitochondria
  a curric:Keyword ;
  schema:name "mitochondria"@en ;
  schema:description """Sub-cellular structures that contain the enzymes for respiration, and is where most energy is released in respiration."""@en ;
  dcterms:modified "2026-02-12T08:59:15.810850Z"^^xsd:dateTime .

oakcurric:keyword-control-variable
  a curric:Keyword ;
  schema:name "control variable"@en ;
  schema:description "a factor that is kept the same during an experiment"@en ;
  dcterms:modified "2026-02-12T08:59:15.810854Z"^^xsd:dateTime .

oakcurric:keyword-cell-wall
  a curric:Keyword ;
  schema:name "cell wall"@en ;
  schema:description """A subcellular structure made from cellulose fibres that strengthens the cell and supports the plant."""@en ;
  dcterms:modified "2026-02-12T08:59:15.810858Z"^^xsd:dateTime .

oakcurric:keyword-permanent-vacuole
  a curric:Keyword ;
  schema:name "permanent vacuole"@en ;
  schema:description "A subcellular structure filled with cell sap that helps keep the cell turgid."@en ;
  dcterms:modified "2026-02-12T08:59:15.810863Z"^^xsd:dateTime .

oakcurric:keyword-base
  a curric:Keyword ;
  schema:name "Base"@en ;
  schema:description "The base is the side which is perpendicular to the shape’s height."@en ;
  dcterms:modified "2026-02-12T08:59:15.810916Z"^^xsd:dateTime .

oakcurric:keyword-mrna
  a curric:Keyword ;
  schema:name "mRNA"@en ;
  schema:description """A copy of a gene that is made and transported from the nucleus to the ribosomes in the cytoplasm."""@en ;
  dcterms:modified "2026-02-12T08:59:15.811074Z"^^xsd:dateTime .

oakcurric:keyword-ribosome
  a curric:Keyword ;
  schema:name "ribosome"@en ;
  schema:description "A structure in all cells whose function is to build proteins."@en ;
  dcterms:modified "2026-02-12T08:59:15.811080Z"^^xsd:dateTime .

oakcurric:keyword-aerobic
  a curric:Keyword ;
  schema:name "aerobic"@en ;
  schema:description "A process that requires oxygen."@en ;
  dcterms:modified "2026-02-12T08:59:15.811087Z"^^xsd:dateTime .

oakcurric:keyword-respirometer
  a curric:Keyword ;
  schema:name "respirometer"@en ;
  schema:description "Apparatus used to measure the rate of respiration in small organisms."@en ;
  dcterms:modified "2026-02-12T08:59:15.811092Z"^^xsd:dateTime .

oakcurric:keyword-independent-variable
  a curric:Keyword ;
  schema:name "independent variable"@en ;
  schema:description "The factor that we change in an experiment."@en ;
  dcterms:modified "2026-02-12T08:59:15.811096Z"^^xsd:dateTime .

oakcurric:keyword-dependent-variable
  a curric:Keyword ;
  schema:name "dependent variable"@en ;
  schema:description "The factor that we measure in an experiment."@en ;
  dcterms:modified "2026-02-12T08:59:15.811100Z"^^xsd:dateTime .

oakcurric:keyword-ionising-radiation
  a curric:Keyword ;
  schema:name "ionising radiation"@en ;
  schema:description """Ionising radiation (e.g. X-rays, gamma rays and high-energy ultraviolet) can cause mutations in DNA."""@en ;
  dcterms:modified "2026-02-12T08:59:15.811500Z"^^xsd:dateTime .

oakcurric:keyword-genetic-variant
  a curric:Keyword ;
