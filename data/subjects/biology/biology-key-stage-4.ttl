  dcterms:modified "2026-02-12T08:59:15.816962Z"^^xsd:dateTime .

oakcurric:keyword-evolutionary-trees
  a curric:Keyword ;
  schema:name "evolutionary trees"@en ;
  schema:description "diagrams that show the evolutionary relationships between organisms"@en ;
  dcterms:modified "2026-02-12T08:59:15.816966Z"^^xsd:dateTime .

oakcurric:keyword-genetic-variation
  a curric:Keyword ;
  schema:name "genetic variation"@en ;
  schema:description """Differences between individuals that are caused by the genetic material they inherit."""@en ;
  dcterms:modified "2026-02-12T08:59:15.816975Z"^^xsd:dateTime .

oakcurric:keyword-eukaryote
  a curric:Keyword ;
  schema:name "eukaryote"@en ;
  schema:description """A cell or organism which has a cell membrane, cytoplasm and genetic material enclosed in a nucleus."""@en ;
  dcterms:modified "2026-02-12T08:59:15.817069Z"^^xsd:dateTime .

oakcurric:keyword-prokaryote
  a curric:Keyword ;
  schema:name "prokaryote"@en ;
  schema:description """An organism whose cell has cytoplasm and a cell membrane surrounded by a cell wall. The genetic material is not enclosed in a nucleus."""@en ;
  dcterms:modified "2026-02-12T08:59:15.817073Z"^^xsd:dateTime .

oakcurric:keyword-oral-contraceptive-pill
  a curric:Keyword ;
  schema:name "oral contraceptive pill"@en ;
  schema:description "A contraceptive method; a pill taken regularly, containing hormones."@en ;
  dcterms:modified "2026-02-12T08:59:15.817077Z"^^xsd:dateTime .

oakcurric:keyword-fertilisation
  a curric:Keyword ;
  schema:name "fertilisation"@en ;
  schema:description "Process where the sperm and the egg fuse in the fallopian tube."@en ;
  dcterms:modified "2026-02-12T08:59:15.817081Z"^^xsd:dateTime .

oakcurric:keyword-sti
  a curric:Keyword ;
  schema:name "STI"@en ;
