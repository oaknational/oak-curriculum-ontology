oakcurric:keyword-safety
  a curric:Keyword ;
  schema:name "safety"@en ;
  schema:description "State of being not likely to be in danger, risk or injury."@en ;
  dcterms:modified "2026-02-12T08:59:15.817090Z"^^xsd:dateTime .

oakcurric:keyword-effectiveness
  a curric:Keyword ;
  schema:name "effectiveness"@en ;
