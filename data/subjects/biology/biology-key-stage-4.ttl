  a curric:KeyLearningPoint ;
  rdfs:label """Explaining the growth response of seedlings to light using ideas about auxins and phototropism"""@en ;
  dcterms:modified "2026-02-12T08:59:21.668070Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5598-1
  a curric:KeyLearningPoint ;
  rdfs:label """Cellular respiration happens continuously in all living organisms to transfer the energy needed for life processes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.668465Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5598-2
  a curric:KeyLearningPoint ;
  rdfs:label """Cellular respiration is an exothermic chemical process that uses glucose as a fuel."""@en ;
  dcterms:modified "2026-02-12T08:59:21.668469Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5598-3
  a curric:KeyLearningPoint ;
  rdfs:label """Word equation and balanced symbol equation summarises the reactants and products of aerobic cellular respiration."""@en ;
  dcterms:modified "2026-02-12T08:59:21.668474Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5598-4
  a curric:KeyLearningPoint ;
  rdfs:label """Aerobic cellular respiration takes place in the mitochondria of eukaryotic cells."""@en ;
  dcterms:modified "2026-02-12T08:59:21.668478Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5598-5
  a curric:KeyLearningPoint ;
  rdfs:label """Aerobic cellular respiration takes place in the cytoplasm of prokaryotic cells, which do not have mitochondria."""@en ;
  dcterms:modified "2026-02-12T08:59:21.668483Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5599-1
  a curric:KeyLearningPoint ;
  rdfs:label """Word and balanced symbol equations for anaerobic cellular respiration in humans, and conditions in which it occurs."""@en ;
  dcterms:modified "2026-02-12T08:59:21.668514Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5599-2
  a curric:KeyLearningPoint ;
  rdfs:label """Word and symbol equations for anaerobic respiration in plants and micro-organisms, and conditions in which it occurs."""@en ;
  dcterms:modified "2026-02-12T08:59:21.668518Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5599-3
  a curric:KeyLearningPoint ;
  rdfs:label """Anaerobic cellular respiration takes place only in the cell cytoplasm and does not involve mitochondria."""@en ;
  dcterms:modified "2026-02-12T08:59:21.668523Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5599-4
  a curric:KeyLearningPoint ;
  rdfs:label """Anaerobic cellular respiration transfers less energy than aerobic cellular respiration, but more quickly."""@en ;
  dcterms:modified "2026-02-12T08:59:21.668527Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5599-5
  a curric:KeyLearningPoint ;
  rdfs:label "Uses of anaerobic cellular respiration (fermentation) in yeast."@en ;
  dcterms:modified "2026-02-12T08:59:21.668532Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9192-1
  a curric:KeyLearningPoint ;
  rdfs:label "A light microscope can be used to observe plant root hair cells."@en ;
  dcterms:modified "2026-02-12T08:59:21.669982Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9192-2
  a curric:KeyLearningPoint ;
  rdfs:label "The parts of a light microscope and their functions."@en ;
  dcterms:modified "2026-02-12T08:59:21.669989Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9192-3
  a curric:KeyLearningPoint ;
  rdfs:label """The sequence of steps for setting up a light microscope to observe cells including changing the magnification and focus."""@en ;
  dcterms:modified "2026-02-12T08:59:21.669994Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9192-4
  a curric:KeyLearningPoint ;
  rdfs:label """Observations from a light microscope can be recorded in a labelled scientific line drawing."""@en ;
  dcterms:modified "2026-02-12T08:59:21.669999Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9192-5
  a curric:KeyLearningPoint ;
  rdfs:label """Total magnification = magnification of the eyepiece lens × magnification of the objective lens"""@en ;
  dcterms:modified "2026-02-12T08:59:21.670003Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28986-1
  a curric:KeyLearningPoint ;
  rdfs:label "The concepts of surface area, volume, and surface area to volume ratio."@en ;
  dcterms:modified "2026-02-12T08:59:21.672211Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28986-2
  a curric:KeyLearningPoint ;
  rdfs:label """Calculation of the surface areas, volumes and surface area to volume ratios of cubes of different sizes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.672216Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28986-3
  a curric:KeyLearningPoint ;
  rdfs:label """Use of coloured agar cubes of different sizes to observe time taken for acid to diffuse to the centre of each cube."""@en ;
  dcterms:modified "2026-02-12T08:59:21.672220Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28986-4
  a curric:KeyLearningPoint ;
  rdfs:label """Interpretation of results and explanation using ideas about surface area to volume ratio and diffusion."""@en ;
  dcterms:modified "2026-02-12T08:59:21.672227Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28986-5
  a curric:KeyLearningPoint ;
  rdfs:label "The rate of diffusion can be calculated using Fick’s law."@en ;
  dcterms:modified "2026-02-12T08:59:21.672232Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27961-1
  a curric:KeyLearningPoint ;
  rdfs:label """The diameter of a clear zone of inhibition around an antimicrobial disc can be measured."""@en ;
  dcterms:modified "2026-02-12T08:59:21.675414Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27961-2
  a curric:KeyLearningPoint ;
  rdfs:label """The areas of clear zones can be calculated using 𝜋r² and compared to investigate antimicrobial effectiveness."""@en ;
  dcterms:modified "2026-02-12T08:59:21.675418Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27961-3
  a curric:KeyLearningPoint ;
  rdfs:label """The larger the clear zone of inhibition, the more effective the antimicrobial has been in killing the bacteria."""@en ;
  dcterms:modified "2026-02-12T08:59:21.675427Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27961-4
  a curric:KeyLearningPoint ;
  rdfs:label """The importance of testing the effectiveness of antimicrobials in clinical settings."""@en ;
  dcterms:modified "2026-02-12T08:59:21.675432Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8003-1
  a curric:KeyLearningPoint ;
  rdfs:label """Hormones are chemicals that are made and secreted by groups of specialised cells called glands."""@en ;
  dcterms:modified "2026-02-12T08:59:21.675504Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8003-2
  a curric:KeyLearningPoint ;
  rdfs:label """Hormones are transported around the body in the blood plasma, and detected by receptors on cells and tissues."""@en ;
  dcterms:modified "2026-02-12T08:59:21.675509Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8003-3
  a curric:KeyLearningPoint ;
  rdfs:label """During puberty, hormones cause maturation of the sex organs and development of secondary sexual characteristics."""@en ;
  dcterms:modified "2026-02-12T08:59:21.675516Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8003-4
  a curric:KeyLearningPoint ;
  rdfs:label """Hormones control the menstrual cycle in adult human females, by causing ovulation and menstruation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.675521Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8003-5
  a curric:KeyLearningPoint ;
  rdfs:label """Decreases in hormone levels in older human females cause the menopause, after which the menstrual cycle stops."""@en ;
  dcterms:modified "2026-02-12T08:59:21.675526Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7998-1
  a curric:KeyLearningPoint ;
  rdfs:label """Hormones control growth and development in plants, and enable plants to respond to some environmental factors."""@en ;
  dcterms:modified "2026-02-12T08:59:21.675532Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7998-2
  a curric:KeyLearningPoint ;
  rdfs:label """Auxins are plant hormones that control tropisms, which are growth responses in plants that provide a survival advantage."""@en ;
  dcterms:modified "2026-02-12T08:59:21.675537Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7998-3
  a curric:KeyLearningPoint ;
  rdfs:label """Phototropism in a shoot: auxins build up on the shaded side and cause cell elongation, so it bends towards the light."""@en ;
  dcterms:modified "2026-02-12T08:59:21.675541Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7998-4
  a curric:KeyLearningPoint ;
  rdfs:label """Gravitropism in a shoot: auxins build up on the lower side and cause cell elongation, so it bends upwards."""@en ;
  dcterms:modified "2026-02-12T08:59:21.675546Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7998-5
  a curric:KeyLearningPoint ;
  rdfs:label """Gravitropism in a root: auxins build up on the lower side but this stops cell elongation, so it bends downwards."""@en ;
  dcterms:modified "2026-02-12T08:59:21.675550Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7994-1
  a curric:KeyLearningPoint ;
  rdfs:label """Genetic engineering involves modifying the genome of an organism by adding DNA from another organism."""@en ;
  dcterms:modified "2026-02-12T08:59:21.675594Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7994-2
  a curric:KeyLearningPoint ;
  rdfs:label "The aim of genetic engineering is to introduce a desirable characteristic."@en ;
  dcterms:modified "2026-02-12T08:59:21.675601Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7994-3
  a curric:KeyLearningPoint ;
  rdfs:label "Examples of genetically engineering crop plants and bacteria to benefit humans."@en ;
  dcterms:modified "2026-02-12T08:59:21.675609Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7994-4
  a curric:KeyLearningPoint ;
  rdfs:label "Benefits must be weighed against risks and ethical issues."@en ;
  dcterms:modified "2026-02-12T08:59:21.675614Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7994-5
  a curric:KeyLearningPoint ;
  rdfs:label "The main steps in the process of genetic engineering."@en ;
  dcterms:modified "2026-02-12T08:59:21.675618Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8107-1
  a curric:KeyLearningPoint ;
  rdfs:label "Infertility is the inability to become pregnant (conceive)."@en ;
  dcterms:modified "2026-02-12T08:59:21.675623Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8107-2
  a curric:KeyLearningPoint ;
  rdfs:label """In adult human females, some types of infertility are caused by problems with hormones that control the menstrual cycle."""@en ;
  dcterms:modified "2026-02-12T08:59:21.675628Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8107-3
  a curric:KeyLearningPoint ;
  rdfs:label "Hormones can be used as a treatment for these types of infertility."@en ;
  dcterms:modified "2026-02-12T08:59:21.675632Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8107-4
  a curric:KeyLearningPoint ;
  rdfs:label "The use of hormones in IVF treatment."@en ;
  dcterms:modified "2026-02-12T08:59:21.675637Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5585-1
  a curric:KeyLearningPoint ;
  rdfs:label """Sugars, amino acids and other organic substances (nutrients) are transported in phloem."""@en ;
  dcterms:modified "2026-02-12T08:59:21.675889Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5585-2
  a curric:KeyLearningPoint ;
  rdfs:label "Translocation starts at a source, such as a leaf where sugars are made."@en ;
  dcterms:modified "2026-02-12T08:59:21.675896Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5585-3
  a curric:KeyLearningPoint ;
  rdfs:label """Sugars are transported into phloem by active transport across the membranes of the living phloem cells."""@en ;
  dcterms:modified "2026-02-12T08:59:21.675901Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5585-4
  a curric:KeyLearningPoint ;
  rdfs:label """Water moves into the phloem cells by osmosis, which increases the pressure and pushes the sugars along the phloem tube."""@en ;
  dcterms:modified "2026-02-12T08:59:21.675909Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5585-5
  a curric:KeyLearningPoint ;
  rdfs:label """Sugars are transported out of the phloem by active transport at a sink, such as a developing root, stem or flower."""@en ;
  dcterms:modified "2026-02-12T08:59:21.675913Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7984-1
  a curric:KeyLearningPoint ;
  rdfs:label "Growth is part of the life cycle of all living organisms."@en ;
  dcterms:modified "2026-02-12T08:59:21.676748Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7984-2
  a curric:KeyLearningPoint ;
  rdfs:label "Multicellular organisms grow by making new cells."@en ;
  dcterms:modified "2026-02-12T08:59:21.676753Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7984-3
  a curric:KeyLearningPoint ;
  rdfs:label "Multicellular organisms need to repair tissue through cell division."@en ;
  dcterms:modified "2026-02-12T08:59:21.676757Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7984-4
  a curric:KeyLearningPoint ;
  rdfs:label """All new cells are made when existing cells copy their genetic material and then divide in two."""@en ;
  dcterms:modified "2026-02-12T08:59:21.676762Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6406-1
  a curric:KeyLearningPoint ;
  rdfs:label """Some mutations cause genetic variants that cause advantageous adaptations in phenotype."""@en ;
  dcterms:modified "2026-02-12T08:59:21.677536Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6406-2
  a curric:KeyLearningPoint ;
  rdfs:label """Individuals with these genetic variants are better adapted to compete, survive, reproduce and pass them on to offspring."""@en ;
  dcterms:modified "2026-02-12T08:59:21.677543Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6406-3
  a curric:KeyLearningPoint ;
  rdfs:label """Natural selection causes advantageous genetic variants to become more common in the population over generations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.677548Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6406-4
  a curric:KeyLearningPoint ;
  rdfs:label """This causes advantageous adaptations in phenotype to become more common in the population over generations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.677553Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6406-5
  a curric:KeyLearningPoint ;
  rdfs:label """Examples explained at the genetic level using ideas about mutation, genetic variants and natural selection."""@en ;
  dcterms:modified "2026-02-12T08:59:21.677560Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7991-1
  a curric:KeyLearningPoint ;
  rdfs:label """Some alleles affect health (e.g. increase the risk of non-communicable diseases or adverse reactions to treatments)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.677579Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7991-2
  a curric:KeyLearningPoint ;
  rdfs:label """Genetic testing and genome sequencing can identify the presence of these alleles in a person’s genome."""@en ;
  dcterms:modified "2026-02-12T08:59:21.677583Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7991-3
  a curric:KeyLearningPoint ;
  rdfs:label """Healthcare can be personalised and lifestyle changes can be implemented to decrease risk and improve health."""@en ;
  dcterms:modified "2026-02-12T08:59:21.677587Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7991-4
  a curric:KeyLearningPoint ;
  rdfs:label "Genetic test data could be misused, and its use must be regulated."@en ;
  dcterms:modified "2026-02-12T08:59:21.677592Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9193-1
  a curric:KeyLearningPoint ;
  rdfs:label "The parts of a light microscope and their functions."@en ;
  dcterms:modified "2026-02-12T08:59:21.679608Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9193-2
  a curric:KeyLearningPoint ;
  rdfs:label """The method for using a light microscope to observe xylem and phloem, including changing the magnification and focus."""@en ;
  dcterms:modified "2026-02-12T08:59:21.679612Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9193-3
  a curric:KeyLearningPoint ;
  rdfs:label """Light microscopy can be used to observe xylem and phloem in a cross-section of a plant shoot, root or leaf."""@en ;
  dcterms:modified "2026-02-12T08:59:21.679617Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9193-4
  a curric:KeyLearningPoint ;
  rdfs:label """The magnification and actual size of structures observed with a microscope can be calculated."""@en ;
  dcterms:modified "2026-02-12T08:59:21.679621Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5607-1
  a curric:KeyLearningPoint ;
  rdfs:label "If conditions in the body change too much, this can be dangerous to our health."@en ;
  dcterms:modified "2026-02-12T08:59:21.679698Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5607-2
  a curric:KeyLearningPoint ;
  rdfs:label """Changes in body temperature affect the rate of chemical reactions and can impact enzyme activity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.679702Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5607-3
  a curric:KeyLearningPoint ;
  rdfs:label """Extreme changes in body temperature can lead to hypothermia or hyperthermia and death."""@en ;
  dcterms:modified "2026-02-12T08:59:21.679707Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5607-4
  a curric:KeyLearningPoint ;
  rdfs:label """Changes in water content of the fluid around cells can lead to cells shrinking or bursting due to osmosis."""@en ;
  dcterms:modified "2026-02-12T08:59:21.679712Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5607-5
  a curric:KeyLearningPoint ;
  rdfs:label "Use of antagonistic effects to maintain a constant environment."@en ;
  dcterms:modified "2026-02-12T08:59:21.679717Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5610-1
  a curric:KeyLearningPoint ;
  rdfs:label """Temperature receptors in the skin and hypothalamus of the brain detect changes in external and blood temperature."""@en ;
  dcterms:modified "2026-02-12T08:59:21.679769Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5610-2
  a curric:KeyLearningPoint ;
  rdfs:label """When temperature increases, the hypothalamus sends impulses to effectors (sweat glands, muscles in artery walls)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.679773Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5610-3
  a curric:KeyLearningPoint ;
  rdfs:label """When temperature decreases, the hypothalamus sends impulses to effectors (hair erector muscles, artery wall muscles)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.679777Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5610-4
  a curric:KeyLearningPoint ;
  rdfs:label """These autonomic responses work antagonistically to keep body temperature within a narrow range."""@en ;
  dcterms:modified "2026-02-12T08:59:21.679785Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5589-1
  a curric:KeyLearningPoint ;
  rdfs:label """Cells in all parts of a multicellular plant need water and nutrients, such as mineral ions, to stay alive."""@en ;
  dcterms:modified "2026-02-12T08:59:21.680124Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5589-2
  a curric:KeyLearningPoint ;
  rdfs:label """Xylem and phloem transport substances around the plant and minimise the distance they have to diffuse to reach cells."""@en ;
  dcterms:modified "2026-02-12T08:59:21.680131Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5589-3
  a curric:KeyLearningPoint ;
  rdfs:label "Root hair cells are an example of an exchange surface in plants."@en ;
  dcterms:modified "2026-02-12T08:59:21.680135Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5589-4
  a curric:KeyLearningPoint ;
  rdfs:label """The root hair cell membrane is adapted to maximise the surface area for osmosis of water and active transport of ions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.680140Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6408-1
  a curric:KeyLearningPoint ;
  rdfs:label """An example of a mutation in bacteria that could be helpful to humans (e.g. ability to digest man-made waste)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.684730Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6408-2
  a curric:KeyLearningPoint ;
  rdfs:label """An example of a mutation in bacteria that is dangerous to humans (e.g. antibiotic resistance)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.684735Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6408-3
  a curric:KeyLearningPoint ;
  rdfs:label """Explanations of examples at the genetic level using ideas about mutation, natural selection and asexual reproduction."""@en ;
  dcterms:modified "2026-02-12T08:59:21.684742Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6408-4
  a curric:KeyLearningPoint ;
  rdfs:label """Explanations to include why advantageous genetic variants become more common in the bacteria over generations."""@en ;
  dcterms:modified "2026-02-12T08:59:21.684747Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6287-1
  a curric:KeyLearningPoint ;
  rdfs:label """Organisms are classified into groups within larger groups, from species up to kingdoms and domains"""@en ;
  dcterms:modified "2026-02-12T08:59:21.684774Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6287-2
  a curric:KeyLearningPoint ;
  rdfs:label """There are domains of eukaryotes (animals, plants, fungi and protists), bacteria and archaea (both prokaryotic)"""@en ;
  dcterms:modified "2026-02-12T08:59:21.684778Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6287-3
  a curric:KeyLearningPoint ;
  rdfs:label """Organisms can be classified using evidence of their macroscopic features (phenotype)"""@en ;
  dcterms:modified "2026-02-12T08:59:21.684783Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6287-4
  a curric:KeyLearningPoint ;
  rdfs:label """Organisms can be classified using evidence of their and microscopic cell structures"""@en ;
  dcterms:modified "2026-02-12T08:59:21.684787Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6289-1
  a curric:KeyLearningPoint ;
  rdfs:label "Organisms can now be classified using evidence from sequencing their genes"@en ;
  dcterms:modified "2026-02-12T08:59:21.684792Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6289-2
  a curric:KeyLearningPoint ;
  rdfs:label "Comparing gene sequences provides evidence of evolutionary relationships"@en ;
  dcterms:modified "2026-02-12T08:59:21.684796Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6289-3
  a curric:KeyLearningPoint ;
  rdfs:label """Sometimes organisms are reclassified into a different group if new evidence is discovered"""@en ;
  dcterms:modified "2026-02-12T08:59:21.684803Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6403-1
  a curric:KeyLearningPoint ;
  rdfs:label """Sexual reproduction creates genetic variation in offspring by combining alleles from male and female gametes."""@en ;
  dcterms:modified "2026-02-12T08:59:21.684849Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6403-2
  a curric:KeyLearningPoint ;
  rdfs:label """Sexual reproduction occurs at a slower rate than asexual reproduction but creates variation which can lead to evolution."""@en ;
  dcterms:modified "2026-02-12T08:59:21.684854Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6403-3
  a curric:KeyLearningPoint ;
  rdfs:label """Asexual reproduction creates genetically identical offspring with no genetic variation."""@en ;
  dcterms:modified "2026-02-12T08:59:21.684858Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6403-4
  a curric:KeyLearningPoint ;
  rdfs:label """Asexual reproduction typically occurs at a much faster rate than sexual reproduction."""@en ;
  dcterms:modified "2026-02-12T08:59:21.684863Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6403-5
  a curric:KeyLearningPoint ;
  rdfs:label """Organisms that reproduce asexually can evolve if the environment or DNA copying errors cause changes in their genome."""@en ;
  dcterms:modified "2026-02-12T08:59:21.684867Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6286-1
  a curric:KeyLearningPoint ;
  rdfs:label "The common features of animal and plant cells."@en ;
  dcterms:modified "2026-02-12T08:59:21.685562Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6286-2
  a curric:KeyLearningPoint ;
  rdfs:label """Animals, plants, fungi and protists are made up of cells with a nucleus in which their genome is stored."""@en ;
  dcterms:modified "2026-02-12T08:59:21.685566Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6286-3
  a curric:KeyLearningPoint ;
  rdfs:label "Organisms made of cells with a nucleus are classified as eukaryotic organisms."@en ;
  dcterms:modified "2026-02-12T08:59:21.685571Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6286-4
  a curric:KeyLearningPoint ;
  rdfs:label """Common features of bacteria cells, including cell membrane, cell wall, plasmids and storing the genome in the cytoplasm."""@en ;
  dcterms:modified "2026-02-12T08:59:21.685575Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6286-5
  a curric:KeyLearningPoint ;
  rdfs:label """Organisms made of cells without a nucleus are classified as prokaryotic organisms."""@en ;
  dcterms:modified "2026-02-12T08:59:21.685580Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8006-1
  a curric:KeyLearningPoint ;
  rdfs:label """Hormones can be used as a contraceptive to prevent pregnancy by disrupting the menstrual cycle."""@en ;
  dcterms:modified "2026-02-12T08:59:21.685587Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8006-2
  a curric:KeyLearningPoint ;
  rdfs:label """Some oral hormone contraceptive pills prevent ovulation. If no egg is released, fertilisation cannot take place."""@en ;
  dcterms:modified "2026-02-12T08:59:21.685594Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8006-3
  a curric:KeyLearningPoint ;
  rdfs:label """Reasons why hormone pills may not be 100% effective (e.g. missing/late dose, taking after ovulation)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.685598Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8006-4
  a curric:KeyLearningPoint ;
  rdfs:label """Non-hormonal contraceptives act as a barrier to prevent sperm from reaching the egg, so fertilisation cannot occur."""@en ;
  dcterms:modified "2026-02-12T08:59:21.685603Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8006-5
  a curric:KeyLearningPoint ;
  rdfs:label """Evaluating benefits and risks of hormonal and non-hormonal (barrier) methods of contraception (including STIs)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.685607Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27997-1
  a curric:KeyLearningPoint ;
  rdfs:label """Process data and plot a graph of appropriate results to identify and describe patterns or trends in the results."""@en ;
  dcterms:modified "2026-02-12T08:59:21.685612Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27997-2
  a curric:KeyLearningPoint ;
  rdfs:label """Explain the results using ideas about the requirement of light for photosynthesis."""@en ;
  dcterms:modified "2026-02-12T08:59:21.685616Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27997-3
  a curric:KeyLearningPoint ;
  rdfs:label """Identify sources of systematic and random error that could affect the accuracy of the measurements."""@en ;
  dcterms:modified "2026-02-12T08:59:21.685623Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27997-4
  a curric:KeyLearningPoint ;
  rdfs:label """Suggest improvements (e.g. ways to measure the pH change and/or the rate more accurately)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.685628Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27997-5
  a curric:KeyLearningPoint ;
  rdfs:label "Evaluate the precision, repeatability and reproducibility of the results."@en ;
  dcterms:modified "2026-02-12T08:59:21.685633Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8189-1
  a curric:KeyLearningPoint ;
  rdfs:label "If conditions in the body change too much this can be dangerous to our health."@en ;
  dcterms:modified "2026-02-12T08:59:21.685660Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8189-2
  a curric:KeyLearningPoint ;
  rdfs:label """Changes in body temperature affect the rate of chemical reactions and can impact enzyme activity."""@en ;
  dcterms:modified "2026-02-12T08:59:21.685664Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8189-3
  a curric:KeyLearningPoint ;
  rdfs:label "Changes in body temperature can lead to hypo- or hyperthermia and death."@en ;
  dcterms:modified "2026-02-12T08:59:21.685669Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8189-4
  a curric:KeyLearningPoint ;
  rdfs:label "Changes in water balance in the body can lead to dehydration and death."@en ;
  dcterms:modified "2026-02-12T08:59:21.685673Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8189-5
  a curric:KeyLearningPoint ;
  rdfs:label "Use of antagonistic effects to maintain a constant environment."@en ;
  dcterms:modified "2026-02-12T08:59:21.685678Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7967-1
  a curric:KeyLearningPoint ;
  rdfs:label """Plants and microorganisms provide new medicines; many others are synthesised in labs to target pathogens and host cells."""@en ;
  dcterms:modified "2026-02-12T08:59:21.685682Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7967-2
  a curric:KeyLearningPoint ;
  rdfs:label """Preclinical trials: the medicine is tested for safety and effectiveness on cultured human cells and on live animals."""@en ;
  dcterms:modified "2026-02-12T08:59:21.685686Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7967-3
  a curric:KeyLearningPoint ;
  rdfs:label """Clinical trials: the medicine is tested for safety in people without the disease."""@en ;
  dcterms:modified "2026-02-12T08:59:21.685693Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7967-4
  a curric:KeyLearningPoint ;
  rdfs:label """Clinical trials: the medicine is tested for safety and effectiveness in people with the disease."""@en ;
  dcterms:modified "2026-02-12T08:59:21.685698Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7967-5
  a curric:KeyLearningPoint ;
  rdfs:label """Use of placebos in clinical trials, and use of blind and double blind trials prevent to bias in the results."""@en ;
  dcterms:modified "2026-02-12T08:59:21.685702Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5616-1
  a curric:KeyLearningPoint ;
  rdfs:label """The rate of photosynthesis depends on factors including light, chlorophyll, water, temperature and carbon dioxide."""@en ;
  dcterms:modified "2026-02-12T08:59:21.685711Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5616-2
  a curric:KeyLearningPoint ;
  rdfs:label """A factor that when in short supply slows down or limits the rate of photosynthesis is called a limiting factor."""@en ;
  dcterms:modified "2026-02-12T08:59:21.685716Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5616-3
  a curric:KeyLearningPoint ;
  rdfs:label """Increased temperature increases photosynthesis rate up to the optimum (due to increased enzyme-substrate collisions)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.685721Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5616-4
  a curric:KeyLearningPoint ;
  rdfs:label """Above the optimum temperature, enzymes are denatured and rate of photosynthesis decreases."""@en ;
  dcterms:modified "2026-02-12T08:59:21.685725Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5616-5
  a curric:KeyLearningPoint ;
  rdfs:label """Increased CO2 concentration increases rate of photosynthesis up to the optimum, when all enzyme active sites are full."""@en ;
  dcterms:modified "2026-02-12T08:59:21.685730Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5608-1
  a curric:KeyLearningPoint ;
  rdfs:label """Human body temperature needs to be kept within a small range, around 37°C, to maintain body functions and health."""@en ;
  dcterms:modified "2026-02-12T08:59:21.685734Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5608-2
  a curric:KeyLearningPoint ;
  rdfs:label """Changes in the external environment can cause the internal body temperature to change."""@en ;
  dcterms:modified "2026-02-12T08:59:21.685739Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5608-3
  a curric:KeyLearningPoint ;
  rdfs:label """When temperature decreases, responses (erection of hairs, vasoconstriction) help to return body temperature to normal."""@en ;
  dcterms:modified "2026-02-12T08:59:21.685743Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5608-4
  a curric:KeyLearningPoint ;
  rdfs:label """When temperature increases, responses (sweating, vasodilation) help to return body temperature to normal."""@en ;
  dcterms:modified "2026-02-12T08:59:21.685748Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9188-1
  a curric:KeyLearningPoint ;
  rdfs:label "Plant health can be affected by pathogens."@en ;
  dcterms:modified "2026-02-12T08:59:21.688462Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9188-2
  a curric:KeyLearningPoint ;
  rdfs:label "Chalara ash dieback is an example of a disease in plants caused by a fungus."@en ;
  dcterms:modified "2026-02-12T08:59:21.688467Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9188-3
  a curric:KeyLearningPoint ;
  rdfs:label """Ways in which plant diseases can be spread, and ways in which the spread can be reduced."""@en ;
  dcterms:modified "2026-02-12T08:59:21.688472Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9188-4
  a curric:KeyLearningPoint ;
  rdfs:label "Impacts of ash dieback on biodiversity, including through habitat destruction."@en ;
  dcterms:modified "2026-02-12T08:59:21.688476Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7966-1
  a curric:KeyLearningPoint ;
  rdfs:label """Uncontaminated cultures of microorganisms are required to investigate the action of antimicrobials."""@en ;
  dcterms:modified "2026-02-12T08:59:21.689097Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7966-2
  a curric:KeyLearningPoint ;
  rdfs:label "Bacteria can be grown on an agar plate using aseptic techniques."@en ;
  dcterms:modified "2026-02-12T08:59:21.689101Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7966-3
  a curric:KeyLearningPoint ;
  rdfs:label "Examples of aseptic techniques used in culturing bacteria."@en ;
  dcterms:modified "2026-02-12T08:59:21.689108Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7966-4
  a curric:KeyLearningPoint ;
  rdfs:label """Discs soaked in antimicrobial substances can be used to investigate their effect on bacterial growth."""@en ;
  dcterms:modified "2026-02-12T08:59:21.689113Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7963-1
  a curric:KeyLearningPoint ;
  rdfs:label """Antibiotics are medicines that can only be used to treat bacterial infections; they do not work against viruses."""@en ;
  dcterms:modified "2026-02-12T08:59:21.690475Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7963-2
  a curric:KeyLearningPoint ;
  rdfs:label "Some antibiotics work by stopping bacteria developing a cell wall."@en ;
  dcterms:modified "2026-02-12T08:59:21.690479Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7963-3
  a curric:KeyLearningPoint ;
  rdfs:label """Bacteria can become resistant to antibiotics, and resistance can spread if antibiotics are not used correctly."""@en ;
  dcterms:modified "2026-02-12T08:59:21.690484Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7963-4
  a curric:KeyLearningPoint ;
  rdfs:label "Antibiotics must only be taken when they are prescribed by a doctor."@en ;
  dcterms:modified "2026-02-12T08:59:21.690490Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7963-5
  a curric:KeyLearningPoint ;
  rdfs:label """Do not take antibiotics for the wrong reasons and always complete the prescribed course."""@en ;
  dcterms:modified "2026-02-12T08:59:21.690495Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7992-1
  a curric:KeyLearningPoint ;
  rdfs:label """Some alleles are associated with conditions that affect people’s health (e.g. cystic fibrosis)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.692136Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7992-2
  a curric:KeyLearningPoint ;
  rdfs:label """Prospective parents can be tested for these alleles, as can embryos (embryo screening)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.692141Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7992-3
  a curric:KeyLearningPoint ;
  rdfs:label """A fetus can be tested for these alleles (e.g. by chorionic villus sampling or amniocentesis)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.692145Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7992-4
  a curric:KeyLearningPoint ;
  rdfs:label """Tests can have false negative or false positive results, and risks of miscarriage or infection."""@en ;
  dcterms:modified "2026-02-12T08:59:21.692150Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7992-5
  a curric:KeyLearningPoint ;
  rdfs:label """Parents must be supported to interpret test results, consider ethical questions and make difficult personal decisions."""@en ;
  dcterms:modified "2026-02-12T08:59:21.692154Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8005-1
  a curric:KeyLearningPoint ;
  rdfs:label "FSH causes follicle maturation and secretion of oestrogen by the ovaries."@en ;
  dcterms:modified "2026-02-12T08:59:21.692655Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8005-2
  a curric:KeyLearningPoint ;
  rdfs:label """Oestrogen causes thickening of uterus wall, secretion of LH by the pituitary gland and inhibits the release of FSH."""@en ;
  dcterms:modified "2026-02-12T08:59:21.692660Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8005-3
  a curric:KeyLearningPoint ;
  rdfs:label """LH causes ovulation; FSH and LH cause the mature follicle to break down and secrete progesterone."""@en ;
  dcterms:modified "2026-02-12T08:59:21.692664Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8005-4
  a curric:KeyLearningPoint ;
  rdfs:label """Progesterone prepares uterus lining for implantation of fertilised egg; stops secretion of LH & FSH by pituitary gland."""@en ;
  dcterms:modified "2026-02-12T08:59:21.692669Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8005-5
  a curric:KeyLearningPoint ;
  rdfs:label "Fall in progesterone causes menstruation."@en ;
  dcterms:modified "2026-02-12T08:59:21.692673Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6404-1
  a curric:KeyLearningPoint ;
  rdfs:label """Some variation in phenotype is caused only by the environment and is not heritable."""@en ;
  dcterms:modified "2026-02-12T08:59:21.695606Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6404-2
  a curric:KeyLearningPoint ;
  rdfs:label """Some variation is caused by genetic material; this can be passed on to offspring via gametes or asexual reproduction."""@en ;
  dcterms:modified "2026-02-12T08:59:21.695610Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6404-3
  a curric:KeyLearningPoint ;
  rdfs:label """A change in the sequence of bases in an organism's DNA is called a mutation and creates a genetic variant."""@en ;
  dcterms:modified "2026-02-12T08:59:21.695615Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6404-4
  a curric:KeyLearningPoint ;
  rdfs:label """Mutations happen at random (caused by carcinogens, or by ionising radiation, or by errors when DNA is copied)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.695619Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6404-5
  a curric:KeyLearningPoint ;
  rdfs:label """Most mutations have no effect on phenotype, some influence phenotype, and a few determine phenotype."""@en ;
  dcterms:modified "2026-02-12T08:59:21.695624Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6288-1
  a curric:KeyLearningPoint ;
  rdfs:label "Most cells are too small to be seen without a microscope."@en ;
  dcterms:modified "2026-02-12T08:59:21.695629Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6288-2
  a curric:KeyLearningPoint ;
  rdfs:label """Comparison of the sizes of cells and cell structures in µm, nm, and in mm in standard form."""@en ;
  dcterms:modified "2026-02-12T08:59:21.695635Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6288-3
  a curric:KeyLearningPoint ;
  rdfs:label "Light microscopes have limited magnification and resolution."@en ;
  dcterms:modified "2026-02-12T08:59:21.695640Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6288-4
  a curric:KeyLearningPoint ;
  rdfs:label """Electron microscopes have greater magnification and resolution, allowing much smaller structures to be seen clearly."""@en ;
  dcterms:modified "2026-02-12T08:59:21.695645Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-6288-5
  a curric:KeyLearningPoint ;
  rdfs:label "Electron microscopy has increased our understanding of sub-cellular structures."@en ;
  dcterms:modified "2026-02-12T08:59:21.695650Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27995-1
  a curric:KeyLearningPoint ;
  rdfs:label """Algae are living organisms that photosynthesise in the light, carbon dioxide is a reactant."""@en ;
  dcterms:modified "2026-02-12T08:59:21.695697Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27995-2
  a curric:KeyLearningPoint ;
  rdfs:label """Planning an investigation into the effect of light intensity on the rate of photosynthesis in algae."""@en ;
  dcterms:modified "2026-02-12T08:59:21.695702Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27995-3
  a curric:KeyLearningPoint ;
  rdfs:label """Identifying the independent variable (light intensity) and planning how to vary it."""@en ;
  dcterms:modified "2026-02-12T08:59:21.695706Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27995-4
  a curric:KeyLearningPoint ;
  rdfs:label """Identifying factors that should be controlled and how they could be (e.g. temperature)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.696120Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27995-5
  a curric:KeyLearningPoint ;
  rdfs:label """Planning a method to measure the dependent variable (colour change of indicator)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.696128Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5587-1
  a curric:KeyLearningPoint ;
  rdfs:label """Practical demonstration of the use of a simple potometer to measure water uptake by a leafy shoot."""@en ;
  dcterms:modified "2026-02-12T08:59:21.696215Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5587-2
  a curric:KeyLearningPoint ;
  rdfs:label "Use of a light source to vary light intensity."@en ;
  dcterms:modified "2026-02-12T08:59:21.696225Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5587-3
  a curric:KeyLearningPoint ;
  rdfs:label """Use of appropriate apparatus to control temperature (e.g. a water tank as a heat shield between light and plant)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.696229Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5587-4
  a curric:KeyLearningPoint ;
  rdfs:label """Use of a simple potometer to measure water uptake by a plant at a range of light intensities."""@en ;
  dcterms:modified "2026-02-12T08:59:21.696234Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5587-5
  a curric:KeyLearningPoint ;
  rdfs:label """Rate of water uptake = change in volume of water ÷ time taken for volume to change"""@en ;
  dcterms:modified "2026-02-12T08:59:21.696238Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28975-1
  a curric:KeyLearningPoint ;
  rdfs:label """Predictions about effects of factors such as temperature and availability of water and CO2 on rate of photosynthesis."""@en ;
  dcterms:modified "2026-02-12T08:59:21.701352Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28975-2
  a curric:KeyLearningPoint ;
  rdfs:label """Photosynthesis in producers creates the biomass for food chains, which all consumers (including humans) depend on."""@en ;
  dcterms:modified "2026-02-12T08:59:21.701357Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28975-3
  a curric:KeyLearningPoint ;
  rdfs:label """Climate change and global warming affect the temperature and the availability of water."""@en ;
  dcterms:modified "2026-02-12T08:59:21.701362Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28975-4
  a curric:KeyLearningPoint ;
  rdfs:label """Rising temperatures, droughts and floods will reduce the yields of crop plants that feed farm animals and humans."""@en ;
  dcterms:modified "2026-02-12T08:59:21.701368Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-28975-5
  a curric:KeyLearningPoint ;
  rdfs:label """Different regions of the world and the people living there will be affected in different ways."""@en ;
  dcterms:modified "2026-02-12T08:59:21.701373Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27990-1
  a curric:KeyLearningPoint ;
  rdfs:label """The kidneys are organs of the human excretory system; blood passes through the kidneys and is filtered."""@en ;
  dcterms:modified "2026-02-12T08:59:21.702195Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27990-2
  a curric:KeyLearningPoint ;
  rdfs:label """Water and urea diffuse out of the blood plasma into kidney tubules to be excreted as urine."""@en ;
  dcterms:modified "2026-02-12T08:59:21.702199Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27990-3
  a curric:KeyLearningPoint ;
  rdfs:label """The kidneys reabsorb as much water as needed from the urine into the blood plasma to maintain water balance in the body."""@en ;
  dcterms:modified "2026-02-12T08:59:21.702204Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27990-4
  a curric:KeyLearningPoint ;
  rdfs:label "Having too much water in the body leads to dilute urine, and vice versa."@en ;
  dcterms:modified "2026-02-12T08:59:21.702208Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27990-5
  a curric:KeyLearningPoint ;
  rdfs:label "What happens during kidney failure and ways it can be treated."@en ;
  dcterms:modified "2026-02-12T08:59:21.702213Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5611-1
  a curric:KeyLearningPoint ;
  rdfs:label """Receptors in the hypothalamus detect changes in the amount of water in the blood plasma."""@en ;
  dcterms:modified "2026-02-12T08:59:21.702218Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5611-2
  a curric:KeyLearningPoint ;
  rdfs:label """When there is too little water, the pituitary gland secretes a hormone called ADH."""@en ;
  dcterms:modified "2026-02-12T08:59:21.702222Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5611-3
  a curric:KeyLearningPoint ;
  rdfs:label """ADH increases the permeability of the kidney tubules so more water is reabsorbed into the blood plasma."""@en ;
  dcterms:modified "2026-02-12T08:59:21.702227Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5611-4
  a curric:KeyLearningPoint ;
  rdfs:label """When there is too much water, the pituitary gland secretes less ADH and less water is reabsorbed in the kidneys."""@en ;
  dcterms:modified "2026-02-12T08:59:21.702231Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5611-5
  a curric:KeyLearningPoint ;
  rdfs:label """Drinking alcohol causes less ADH to be produced, so urine becomes more dilute and this can cause dehydration."""@en ;
  dcterms:modified "2026-02-12T08:59:21.702236Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7968-1
  a curric:KeyLearningPoint ;
  rdfs:label """Monoclonal antibodies recognise a specific target, such as an antigen or other biological molecule."""@en ;
  dcterms:modified "2026-02-12T08:59:21.702879Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7968-2
  a curric:KeyLearningPoint ;
  rdfs:label """Monoclonal antibodies are produced by combining a lymphocyte and a tumour cell to produce a hybridoma."""@en ;
  dcterms:modified "2026-02-12T08:59:21.702883Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7968-3
  a curric:KeyLearningPoint ;
  rdfs:label """The hybridoma divides to make many copies of this single clone, which make monoclonal antibodies."""@en ;
  dcterms:modified "2026-02-12T08:59:21.702888Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7968-4
  a curric:KeyLearningPoint ;
  rdfs:label """Monoclonal antibodies are used to detect pathogen antigens & molecules associated with pregnancy, blood clots & cancer."""@en ;
  dcterms:modified "2026-02-12T08:59:21.702901Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7968-5
  a curric:KeyLearningPoint ;
  rdfs:label """Monoclonal antibodies can be attached to radioactive and toxic substances to treat diseased cells, e.g. tumour cells."""@en ;
  dcterms:modified "2026-02-12T08:59:21.702909Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27991-1
  a curric:KeyLearningPoint ;
  rdfs:label """The kidneys are organs of the human excretory system; blood passes through the kidneys and is filtered."""@en ;
  dcterms:modified "2026-02-12T08:59:21.703808Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27991-2
  a curric:KeyLearningPoint ;
  rdfs:label """Water and urea diffuse out of the blood plasma into kidney tubules to be excreted as urine, including nephron structure."""@en ;
  dcterms:modified "2026-02-12T08:59:21.703813Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27991-3
  a curric:KeyLearningPoint ;
  rdfs:label """The kidneys reabsorb as much water as needed from the urine into the blood plasma to maintain water balance in the body."""@en ;
  dcterms:modified "2026-02-12T08:59:21.703817Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27991-4
  a curric:KeyLearningPoint ;
  rdfs:label "Having too much water in the body leads to dilute urine, and vice versa."@en ;
  dcterms:modified "2026-02-12T08:59:21.703824Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9191-1
  a curric:KeyLearningPoint ;
  rdfs:label """Use a light microscope to observe effects of osmosis in plant cells (including: shrinking/crenation,  swelling/bursting)"""@en ;
  dcterms:modified "2026-02-12T08:59:21.703867Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9191-2
  a curric:KeyLearningPoint ;
  rdfs:label "The parts of a light microscope and their functions."@en ;
  dcterms:modified "2026-02-12T08:59:21.703872Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9191-3
  a curric:KeyLearningPoint ;
  rdfs:label """The sequence of steps for setting up a light microscope to observe cells, including changing magnification and focus."""@en ;
  dcterms:modified "2026-02-12T08:59:21.703879Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-9191-4
  a curric:KeyLearningPoint ;
  rdfs:label """Explaining observations from microscopy using ideas about osmosis and net movement of water into/out of cells."""@en ;
  dcterms:modified "2026-02-12T08:59:21.703884Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8193-1
  a curric:KeyLearningPoint ;
  rdfs:label "Most cells are too small to be seen without a microscope."@en ;
  dcterms:modified "2026-02-12T08:59:21.704246Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8193-2
  a curric:KeyLearningPoint ;
  rdfs:label "Comparison of the sizes of cells and cell structures."@en ;
  dcterms:modified "2026-02-12T08:59:21.704250Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8193-3
  a curric:KeyLearningPoint ;
  rdfs:label "Light microscopes have limited magnification and resolution."@en ;
  dcterms:modified "2026-02-12T08:59:21.704255Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8193-4
  a curric:KeyLearningPoint ;
  rdfs:label """Electron microscopes have greater magnification and resolution, allowing much smaller structures to be seen clearly."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704259Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8193-5
  a curric:KeyLearningPoint ;
  rdfs:label "Electron microscopy has increased our understanding of sub-cellular structures."@en ;
  dcterms:modified "2026-02-12T08:59:21.704266Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7936-1
  a curric:KeyLearningPoint ;
  rdfs:label """Rate of photosynthesis increases as CO₂ concentration, temperature and light intensity increase from low levels."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704802Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7936-2
  a curric:KeyLearningPoint ;
  rdfs:label """The rate of photosynthesis can be limited by one of these factors even if the others continue to increase."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704807Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7936-3
  a curric:KeyLearningPoint ;
  rdfs:label """The rate of photosynthesis increases until one of more factors becomes limiting, then does not increase further."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704811Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-7936-4
  a curric:KeyLearningPoint ;
  rdfs:label """Interpretation and explanation of graphs depicting effect of interacting limiting factors on the rate of photosynthesis."""@en ;
  dcterms:modified "2026-02-12T08:59:21.704816Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27992-1
  a curric:KeyLearningPoint ;
  rdfs:label """Pondweed is a plant that photosynthesises in the light, releasing oxygen gas as a waste product."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705897Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27992-2
  a curric:KeyLearningPoint ;
  rdfs:label """Planning an investigation into the effect of light intensity on the rate of photosynthesis in pondweed."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705901Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27992-3
  a curric:KeyLearningPoint ;
  rdfs:label """Identifying the independent variable (light intensity) and planning how to vary it."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705906Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27992-4
  a curric:KeyLearningPoint ;
  rdfs:label """Identifying factors that should be controlled and how they could be controlled (e.g. temperature)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705912Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-27992-5
  a curric:KeyLearningPoint ;
  rdfs:label """Planning methods to measure the dependent variable (number of bubbles and volume of gas given off)."""@en ;
  dcterms:modified "2026-02-12T08:59:21.705917Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5609-1
  a curric:KeyLearningPoint ;
  rdfs:label "The kidneys are organs of the excretory system in the human body."@en ;
  dcterms:modified "2026-02-12T08:59:21.708040Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5609-2
  a curric:KeyLearningPoint ;
  rdfs:label "Blood passes through the kidneys and is filtered."@en ;
  dcterms:modified "2026-02-12T08:59:21.708045Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5609-3
  a curric:KeyLearningPoint ;
  rdfs:label """Urea and excess water and ions move out of the blood plasma into the kidney tubules and are excreted as urine."""@en ;
  dcterms:modified "2026-02-12T08:59:21.708049Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5609-4
  a curric:KeyLearningPoint ;
  rdfs:label """The kidneys reabsorb as much water as needed from the urine into the blood plasma to maintain water balance in the body."""@en ;
  dcterms:modified "2026-02-12T08:59:21.708054Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5609-5
  a curric:KeyLearningPoint ;
  rdfs:label "Having too much water in the body leads to dilute urine, and vice versa."@en ;
  dcterms:modified "2026-02-12T08:59:21.708061Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5588-1
  a curric:KeyLearningPoint ;
  rdfs:label "Compare data on rate of water uptake by a plant at a range of light intensities."@en ;
  dcterms:modified "2026-02-12T08:59:21.710028Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5588-2
  a curric:KeyLearningPoint ;
  rdfs:label "Identify a pattern or trend in the data."@en ;
  dcterms:modified "2026-02-12T08:59:21.710034Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5588-3
  a curric:KeyLearningPoint ;
  rdfs:label """Higher light intensity increases transpiration rate as stomata open wider to increase gas exchange for photosynthesis."""@en ;
  dcterms:modified "2026-02-12T08:59:21.710039Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5588-4
  a curric:KeyLearningPoint ;
  rdfs:label "Increased temperature and air movement also increase the rate of water uptake."@en ;
  dcterms:modified "2026-02-12T08:59:21.710044Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-5588-5
  a curric:KeyLearningPoint ;
  rdfs:label """Higher temperature and air movement increase transpiration due to increased diffusion of water out through stomata."""@en ;
  dcterms:modified "2026-02-12T08:59:21.710049Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8008-1
  a curric:KeyLearningPoint ;
  rdfs:label """When a cell copies a gene to make mRNA (the instructions to make a protein), this is called gene expression."""@en ;
  dcterms:modified "2026-02-12T08:59:21.710078Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8008-2
  a curric:KeyLearningPoint ;
  rdfs:label """Only around 1-2% of the genome is genes; the rest contains code that controls gene expression."""@en ;
  dcterms:modified "2026-02-12T08:59:21.710083Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8008-3
  a curric:KeyLearningPoint ;
  rdfs:label """A genetic variant in a non-gene (so called "non-coding") section of the genome can affect gene expression."""@en ;
  dcterms:modified "2026-02-12T08:59:21.710088Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8008-4
  a curric:KeyLearningPoint ;
  rdfs:label """Non-coding DNA affects gene expression because it is where RNA polymerase starts copying the gene for protein synthesis."""@en ;
  dcterms:modified "2026-02-12T08:59:21.710092Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8008-5
  a curric:KeyLearningPoint ;
  rdfs:label """Genetic variants in non-coding DNA can impact gene expression and therefore an organism’s phenotype."""@en ;
  dcterms:modified "2026-02-12T08:59:21.710097Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8000-1
  a curric:KeyLearningPoint ;
  rdfs:label """Investigating the response of germinated seedlings to gravity (e.g. germinated beans placed vertically and horizontally)"""@en ;
  dcterms:modified "2026-02-12T08:59:21.716020Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8000-2
  a curric:KeyLearningPoint ;
  rdfs:label "Producing accurate, labelled scientific drawings to depict the growth response"@en ;
  dcterms:modified "2026-02-12T08:59:21.716025Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8000-3
  a curric:KeyLearningPoint ;
  rdfs:label "Interpreting and describing the results"@en ;
  dcterms:modified "2026-02-12T08:59:21.716029Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-8000-4
  a curric:KeyLearningPoint ;
  rdfs:label """Explaining the growth response of seedlings to gravity using ideas about auxins and gravitropism"""@en ;
  dcterms:modified "2026-02-12T08:59:21.716034Z"^^xsd:dateTime .

