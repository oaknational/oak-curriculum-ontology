  dcterms:modified "2026-02-12T08:59:21.609750Z"^^xsd:dateTime .

oakcurric:keylearningpoint-lesson-20444-5
  a curric:KeyLearningPoint ;
  rdfs:label """Some disorders are caused by alleles on the sex chromosomes, so have sex-linked inheritance."""@en ;
  dcterms:modified "2026-02-12T08:59:21.609761Z"^^xsd:dateTime .

