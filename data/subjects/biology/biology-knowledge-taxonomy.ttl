    natcurric:substrand-reproduction ,
    natcurric:substrand-health ,
    natcurric:substrand-cellular-respiration ,
    natcurric:substrand-relationships-in-an-ecosystem ,
    natcurric:substrand-inheritance-chromosomes-dna-genes ,
    natcurric:substrand-cell-biology ,
    natcurric:substrand-transport-systems ,
    natcurric:substrand-health-disease-medicines ,
    natcurric:substrand-coordination-and-control ,
    natcurric:substrand-photosynthesis ,
    natcurric:substrand-ecosystems ,
    natcurric:substrand-evolution-inheritance-variation ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2025-12-18T12:33:32Z"^^xsd:dateTime .

