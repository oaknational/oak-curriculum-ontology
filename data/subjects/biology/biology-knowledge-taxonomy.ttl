# ======================================================================
# National Curriculum for England - Biology Knowledge Taxonomy 
# ======================================================================

# ----------------------------------------------------------------------
# Ontology Declaration
# ----------------------------------------------------------------------

<https://w3id.org/uk/oak/curriculum/nationalcurriculum/biology-knowledge-taxonomy>
  rdf:type owl:Ontology ;

  rdfs:label "National Curriculum for England - Biology Knowledge Taxonomy"@en ;
  dc:title "National Curriculum for England - Biology Knowledge Taxonomy"@en ;
  rdfs:comment """The biology knowledge taxonomy for the National Curriculum in England, organizing 
  content through strands, sub-strands, content descriptors, and sub-content descriptors."""@en ;

  owl:versionInfo "0.1.0" ;
  owl:versionIRI <https://w3id.org/uk/oak/curriculum/nationalcurriculum/biology-knowledge-taxonomy/0.1.0> ;
  
  dcterms:description """The biology knowledge taxonomy for the National Curriculum in England, 
  organizing content through strands, sub-strands, content descriptors, and sub-content 
  descriptors."""@en ;
  dcterms:created "2025-11-24T12:33:32Z"^^xsd:dateTime ;
  dcterms:modified "2025-12-03T12:33:32Z"^^xsd:dateTime ;
  dcterms:issued "2025-12-03T12:33:32Z"^^xsd:dateTime ;
  
  # OGL 3.0 License
  dcterms:license <http://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/> ;
  dcterms:rights "Crown Copyright"@en ;

  vann:preferredNamespacePrefix "natcurric" ;
  vann:preferredNamespaceUri "https://w3id.org/uk/oak/curriculum/nationalcurriculum/" ;

  owl:imports <https://w3id.org/uk/oak/curriculum/ontology> ;
  owl:imports <https://w3id.org/uk/oak/curriculum/nationalcurriculum/biology-programme-structure> .

# ----------------------------------------------------------------------
# Knowledge Taxonomy
# ----------------------------------------------------------------------

natcurric:knowledge-taxonomy
  a skos:ConceptScheme ;
  skos:prefLabel "National Curriculum for England Knowledge Taxonomy"@en ;
  skos:hasTopConcept natcurric:discipline-science ;
  dcterms:modified "2025-12-18T12:33:32Z"^^xsd:dateTime .
  
# ----------------------------------------------------------------------
# Disciplines
# ----------------------------------------------------------------------

natcurric:discipline-science
  a skos:Concept, curric:Discipline ;
  skos:prefLabel "Science"@en ;
  skos:topConceptOf natcurric:knowledge-taxonomy ;
  skos:narrower 
    natcurric:strand-working-scientifically ,
    natcurric:strand-biological-science ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2025-12-18T12:33:32Z"^^xsd:dateTime .

# ----------------------------------------------------------------------
# Strands
# ----------------------------------------------------------------------

natcurric:strand-working-scientifically
  a skos:Concept, curric:Strand ;
  skos:prefLabel "Working Scientifically"@en ;
  skos:definition "Description of strand..." ;
  curric:displayOrder "1"^^xsd:positiveInteger ;
  skos:broader natcurric:discipline-science ;
  skos:narrower 
    natcurric:substrand-scientific-attitudes ,
    natcurric:substrand-experimental-skills-and-investigations ,
    natcurric:substrand-scientific-measurement ,
    natcurric:substrand-development-of-scientific-thinking ,
    natcurric:substrand-experimental-skills-and-strategies ,
    natcurric:substrand-analysis-and-evaluation ,
    natcurric:substrand-vocabulary-units-symbols-nomenclature ;
  skos:inScheme natcurric:knowledge-taxonomy ;
  dcterms:modified "2025-12-18T12:33:32Z"^^xsd:dateTime .

natcurric:strand-biological-science
  a skos:Concept, curric:Strand ;
  skos:prefLabel "Biological Science"@en ;
  skos:definition "Description of strand..." ;
  curric:displayOrder "2"^^xsd:positiveInteger ;
  skos:broader natcurric:discipline-science ;
  skos:narrower 
    natcurric:substrand-cells-and-organisation ,
    natcurric:substrand-skeletal-and-muscular-systems ,
