# ----------------------------------------------------------------------

natcurric:year-group-1
  a curric:YearGroup ;
  rdfs:label "Year Group 1"@en ;
  rdfs:comment "Year Group 1 (age 5-6)."@en ;
  curric:lowerAgeBoundary "5"^^xsd:nonNegativeInteger ;
  curric:upperAgeBoundary "6"^^xsd:positiveInteger ;
  curric:isYearGroupOf natcurric:key-stage-1 ;
  dcterms:modified "2025-12-18T12:33:32Z"^^xsd:dateTime .

natcurric:year-group-2
  a curric:YearGroup ;
  rdfs:label "Year Group 2"@en ;
  rdfs:comment "Year Group 2 (age 6-7)."@en ;
  curric:lowerAgeBoundary "6"^^xsd:nonNegativeInteger ;
  curric:upperAgeBoundary "7"^^xsd:positiveInteger ;
