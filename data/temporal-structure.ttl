@prefix curric: <https://w3id.org/uk/oak/curriculum/ontology/> .
@prefix natcurric: <https://w3id.org/uk/oak/curriculum/nationalcurriculum/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# ======================================================================
# National Curriculum for England - Temporal Structure Instance Data
# ======================================================================

# ----------------------------------------------------------------------
# Ontology Declaration
# ----------------------------------------------------------------------

<https://w3id.org/uk/oak/curriculum/nationalcurriculum/temporal-structure>
  rdf:type owl:Ontology ;

  rdfs:label "National Curriculum for England - Temporal Structure"@en ;
  dc:title "National Curriculum for England - Temporal Structure"@en ;
  rdfs:comment """Temporal structure defining the organizational framework of education 
  in England: phases, key stages, and year groups."""@en ;

  owl:versionInfo "0.1.0" ;
  owl:versionIRI <https://w3id.org/uk/oak/curriculum/nationalcurriculum/temporal-structure/0.1.0> ;
  
  dcterms:description """This ontology defines the organizational structure of education in 
  England, including phases (Primary, Secondary), key stages (KS1-4), and year groups (Year 1 - 
  Year 11) that provide the framework for curriculum delivery."""@en ;
  dcterms:created "2025-11-24T12:33:32Z"^^xsd:dateTime ;
  dcterms:modified "2025-12-03T12:33:32Z"^^xsd:dateTime ;
  dcterms:issued "2025-12-03T12:33:32Z"^^xsd:dateTime ;
  
  # OGL 3.0 License
  dcterms:license <http://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/> ;
  dcterms:rights "Copyright © 2026 Oak National Academy."@en ;

  vann:preferredNamespacePrefix "natcurric" ;
  vann:preferredNamespaceUri "https://w3id.org/uk/oak/curriculum/nationalcurriculum/" ;

  owl:imports <https://w3id.org/uk/oak/curriculum/ontology> .

# ----------------------------------------------------------------------
# Phases
# ----------------------------------------------------------------------

natcurric:phase-primary
  a curric:Phase ;
  rdfs:label "Primary"@en ;
  rdfs:comment "Primary education phase covering years 1-6."@en ;
  curric:lowerAgeBoundary "5"^^xsd:nonNegativeInteger ;
  curric:upperAgeBoundary "11"^^xsd:positiveInteger ;
  dcterms:modified "2025-12-18T12:33:32Z"^^xsd:dateTime .

natcurric:phase-secondary
  a curric:Phase ;
  rdfs:label "Secondary"@en ;
  rdfs:comment "Secondary education phase covering years 7-11."@en ;
  curric:lowerAgeBoundary "11"^^xsd:nonNegativeInteger ;
  curric:upperAgeBoundary "16"^^xsd:positiveInteger ;
  dcterms:modified "2025-12-18T12:33:32Z"^^xsd:dateTime .

# ----------------------------------------------------------------------
# Key Stages
# ----------------------------------------------------------------------

natcurric:key-stage-1
  a curric:KeyStage ;
  rdfs:label "Key Stage 1"@en ;
  rdfs:comment "Key Stage 1 covering years 1-2."@en ;
  curric:lowerAgeBoundary "5"^^xsd:nonNegativeInteger ;
  curric:upperAgeBoundary "7"^^xsd:positiveInteger ;
  curric:isKeyStageOf natcurric:phase-primary ;
  dcterms:modified "2025-12-18T12:33:32Z"^^xsd:dateTime .

natcurric:key-stage-2
  a curric:KeyStage ;
  rdfs:label "Key Stage 2"@en ;
  rdfs:comment "Key Stage 2 covering years 3-6."@en ;
  curric:lowerAgeBoundary "7"^^xsd:nonNegativeInteger ;
  curric:upperAgeBoundary "11"^^xsd:positiveInteger ;
  curric:isKeyStageOf natcurric:phase-primary ;
  dcterms:modified "2025-12-18T12:33:32Z"^^xsd:dateTime .

natcurric:key-stage-3
  a curric:KeyStage ;
  rdfs:label "Key Stage 3"@en ;
  rdfs:comment "Key Stage 3 covering years 7-9."@en ;
  curric:lowerAgeBoundary "11"^^xsd:nonNegativeInteger ;
  curric:upperAgeBoundary "14"^^xsd:positiveInteger ;
  curric:isKeyStageOf natcurric:phase-secondary ;
  dcterms:modified "2025-12-18T12:33:32Z"^^xsd:dateTime .

natcurric:key-stage-4
  a curric:KeyStage ;
  rdfs:label "Key Stage 4"@en ;
  rdfs:comment "Key Stage 4 covering years 10-11 (GCSE years)."@en ;
  curric:lowerAgeBoundary "14"^^xsd:nonNegativeInteger ;
  curric:upperAgeBoundary "16"^^xsd:positiveInteger ;
  curric:isKeyStageOf natcurric:phase-secondary ;
  dcterms:modified "2025-12-18T12:33:32Z"^^xsd:dateTime .

